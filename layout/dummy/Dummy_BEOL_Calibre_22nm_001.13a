    M2R2pre = M2R1 NOT (SIZE M2F2 BY (dmS_M2 + grid))
    M2R2 = WITH WIDTH M2R2pre >= dmW_M2

    M2F3 = RECTANGLES dmW_M2 dmL_M2 dmS_M2 OFFSET dmO_M2 INSIDE OF LAYER M2R2
    M2R3pre = M2R2 NOT (SIZE M2F3 BY (dmS_M2 + grid))
    M2R3 = WITH WIDTH M2R3pre >= dmW_M2

    M2F4 = RECTANGLES dmW_M2 dmL_M2 dmS_M2 INSIDE OF LAYER M2R3

    M2F = (((M2F1 OR M2F2) OR M2F3) OR M2F4) OR M2FW
    FM2 = M2F NOT INTERACT (EXT M2F < dmS_M2 ABUT SINGULAR REGION)

    maxOPENM2 = DENSITY M2x FM2 > maxD_M2 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M2Max.den

    FM2F = FM2 OUTSIDE maxOPENM2

    D25M2 = DENSITY M2x FM2F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M2Min.den

    RM2EXC = SIZE FM2F BY (Odm2DM2 + grid)
    D25M2pM = (((PUSH D25M2) NOT FRAME2) NOT RM2EXC) AND CHIP
    D25M2pM_1 = WITH WIDTH D25M2pM >= OdmW_M2

    RM2p1 = RECTANGLES OdmW_M2 OdmL_M2 OdmS_M2 INSIDE OF LAYER D25M2pM_1
    D25M2pM_2 = D25M2pM_1 NOT (SIZE RM2p1 BY (OdmS_M2 + grid))
    RM2p2 = RECTANGLES OdmL_M2 OdmW_M2 OdmS_M2 INSIDE OF LAYER D25M2pM_2

    RM2A = ((RM2p1 OR RM2p2) OUTSIDE RM2EXC) OUTSIDE FRAME2
    RM2  = RM2A NOT INTERACT (EXT RM2A < OdmS_M2 ABUT SINGULAR REGION)

    DM2F = FM2F OR RM2

    FRAME2_INDDMYA = SIZE M2i BY (dm2_s2m2_INDDMY + grid)
    FRAME2_INDDMYB = SIZE DUM2 BY (dm2_s_INDDMY + grid)
    FRAME2_INDDMYC = SIZE DM2F BY dm2_s_INDDMY
    FRAME2_INDDMY  = ((((FRAME2Pre OR BLOCK2) OR FRAME2_INDDMYA) OR FRAME2_INDDMYB) OR FRAME2_INDDMYC) OR NFILL
    FILL2_INDDMY   = ooINDDMY NOT FRAME2_INDDMY
    DM2F_INDDMY    = RECTANGLES dm2_w_INDDMY dm2_l_INDDMY dm2_s_INDDMY INSIDE OF LAYER FILL2_INDDMY

#IFDEF FILL_indDM2
    FILL2_INDDMY_HD = (SIZE INDDMY_HD BY -(dm2_s_INDDMY_HD + grid)) NOT FRAME2_INDDMY
    DM2F_INDDMY_HD  = RECTANGLES dm2_w_INDDMY_HD dm2_l_INDDMY_HD dm2_s_INDDMY_HD INSIDE OF LAYER FILL2_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M2

    D30M2 = DENSITY M2x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M2.den30
    D40M2 = DENSITY M2x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M2.den40
    D50M2 = DENSITY M2x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M2.den50
    emptyM2 = DENSITY M2x < emptyD_M2 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M2.den_empty

    M2InnerHole = HOLES M2i INNER

    M2BigHole = SIZE M2InnerHole BY - excludeHoleSize/2
    M2ExcHole = ((M2InnerHole OUTSIDE M2BigHole) NOT M2i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK2 = (SIZE DM2EXCL BY (dm2DMEXCL + grid)) OR MIM2_x

    FRAMEA2 = (SIZE M2i BY (DM2_301 + grid)) OR (SIZE (EXPAND EDGE (M2i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA2OPC = SIZE M2i BY (DM2_OPC + grid)
    FRAMEA2OPCDV33 = SIZE (M2i INTERACT M2_HVN_330Vx) BY (M2_S_1_1_a + grid)
    FRAMEA2OPCDV5 = SIZE (M2i INTERACT M2_HVN_500Vx) BY (M2_S_9_a + grid)
    FRAMEA2OPC45 = SIZE (EXPAND EDGE (M2i ANGLE == 45) OUTSIDE BY DM2_OPC_45 EXTEND BY DM2_OPC_45_E) BY grid
    FRAMEA2OPC45DV = SIZE (EXPAND EDGE ((M2i INTERACT M2_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM2_OPC_45 EXTEND BY DM2_OPC_45_E) BY grid

    FRAMEB2 = SIZE (WITH WIDTH M2i > wideM2) BY (dm2WM2 + grid)
    FRAMEC2 = SIZE DUM2 BY (dm2DM2 + grid)
    FRAMED2 = SIZE (WITH WIDTH M2i > wideM2_small) BY (dm2WM2_small + grid)
    FRAMEC2OPC = SIZE DUM2 BY (Odm2DM2 + grid)
    FRAME2Pre = ((FRAMEA2 OR FRAMEB2) OR (FRAMEC2 OR FRAMED2)) OR M2ExcHole
    FRAME2PreOPC = (((((((FRAMEA2OPC OR FRAMEA2OPCDV33) OR FRAMEA2OPCDV5) OR FRAMEC2OPC) OR M2ExcHole) OR FRAMEA2OPC45) OR FRAMEA2OPC45DV) OR FRAMEB2) OR FRAMED2
    FRAME2INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm2_s2m2_INDDMY + grid)

    FRAME2OPC = ((FRAME2PreOPC OR FRAME2INDDMY) OR BLOCK2) OR NFILLOPC

    FRAME2 = ((FRAME2Pre OR FRAME2INDDMY) OR BLOCK2) OR NFILL

    //****************************************************************************

    D30M2p = (PUSH D30M2) NOT FRAME2
    O30M2pre = D30M2p AND CHIP
    FD21M2s = COPY FRAME2

    O30M2preA = SIZE O30M2pre BY -DM2_303
    O30M2preB = O30M2preA WITH WIDTH >= WM2_303

    // 1st big
    F303M2 = RECTANGLES WM2_303 LM2_303 SM2_303 OFFSET OM2_303 INSIDE OF LAYER O30M2preB

    F303M2_EXP = SIZE F303M2 BY ( SM2_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M2preF1 = O30M2pre NOT (SIZE F303M2_EXP BY SM2_302)
    O30M2preF  = (SNAP (SIZE O30M2preF1 BY -grid) 5) AND O30M2preF1

    B30M2s = FD21M2s OR (SIZE F303M2_EXP BY (SM2_302+grid))
    O30M2 = O30M2preF NOT B30M2s

    // 3rd, middle
    F302M2 = RECTANGLES WM2_302 LM2_302 SM2_302 OFFSET OM2_302 INSIDE OF LAYER O30M2
    F302M2s = (SIZE F302M2 BY (SM2_301 + grid)) OR B30M2s
    R302M2pre = O30M2 NOT F302M2s
    R302M2 = WITH WIDTH R302M2pre >= WM2_301

    // 4th, small
    F3012M2 = RECTANGLES WM2_301 LM2_301 SM2_301 OFFSET OM2_301 INSIDE OF LAYER R302M2
    F3012M2s = (SIZE F3012M2 BY (SM2_301 + grid)) OR F302M2s
    R3012M2pre = R302M2pre NOT F3012M2s
    R3012M2 = WITH WIDTH R3012M2pre >= WM2_301

    // 5th, non-stagger small
    F301M2 = RECTANGLES WM2_301 LM2_301 SM2_301 INSIDE OF LAYER R3012M2 //MAINTAIN SPACING
    F301M2s = (SIZE F301M2 BY (SM2_301 + grid)) OR F3012M2s

    F30M2 = ((F302M2 OR F3012M2) OR F301M2) OR F303M2
    O40M2pre = (((PUSH D40M2) NOT FRAME2) NOT F301M2s) AND CHIP


    O40M2preA = SIZE O40M2pre BY -DM2_403
    O40M2preB = O40M2preA WITH WIDTH >= WM2_403

    // 1st big
    F403M2 = RECTANGLES WM2_403 LM2_403 SM2_403 OFFSET OM2_403 INSIDE OF LAYER O40M2preB

    F403M2_EXP = SIZE F403M2 BY ( SM2_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M2preF1 = O40M2pre NOT (SIZE F403M2_EXP BY SM2_402)
    O40M2preF  = (SNAP (SIZE O40M2preF1 BY -grid) 5) AND O40M2preF1

    B40M2s = F301M2s OR (SIZE F403M2_EXP BY (SM2_402+grid))
    O40M2 = O40M2preF NOT B40M2s

    // 3rd, middle
    F402M2 = RECTANGLES WM2_402 LM2_402 SM2_402 OFFSET OM2_402 INSIDE OF LAYER O40M2
    F402M2s = (SIZE F402M2 BY (SM2_401 + grid)) OR B40M2s
    R402M2pre = O40M2 NOT F402M2s
    R402M2 = WITH WIDTH R402M2pre >= WM2_401

    // 4th, small
    F4012M2 = RECTANGLES WM2_401 LM2_401 SM2_401 OFFSET OM2_401 INSIDE OF LAYER R402M2
    F4012M2s = (SIZE F4012M2 BY (SM2_401 + grid)) OR F402M2s
    R4012M2pre = R402M2pre NOT F4012M2s
    R4012M2 = WITH WIDTH R4012M2pre >= WM2_401

    // 5th, non-stagger small
    F401M2 = RECTANGLES WM2_401 LM2_401 SM2_401 INSIDE OF LAYER R4012M2 //MAINTAIN SPACING
    F401M2s = (SIZE F401M2 BY (SM2_401 + grid)) OR F4012M2s

    F40M2 = ((F402M2 OR F4012M2) OR F401M2) OR F403M2
    O50M2pre = (((PUSH (D50M2 OR emptyM2)) NOT FRAME2) NOT F401M2s) AND CHIP


    O50M2preA = SIZE O50M2pre BY -DM2_503
    O50M2preB = O50M2preA WITH WIDTH >= WM2_503

    // 1st big
    F503M2 = RECTANGLES WM2_503 LM2_503 SM2_503 OFFSET OM2_503 INSIDE OF LAYER O50M2preB

    F503M2_EXP = SIZE F503M2 BY ( SM2_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M2preF1 = O50M2pre NOT (SIZE F503M2_EXP BY SM2_502)
    O50M2preF  = (SNAP (SIZE O50M2preF1 BY -grid) 5) AND O50M2preF1

    B50M2s = F401M2s OR (SIZE F503M2_EXP BY (SM2_502+grid))
    O50M2 = O50M2preF NOT B50M2s

    // 3rd, middle
    F502M2 = RECTANGLES WM2_502 LM2_502 SM2_502 OFFSET OM2_502 INSIDE OF LAYER O50M2
    F502M2s = (SIZE F502M2 BY (SM2_501 + grid)) OR B50M2s
    R502M2pre = O50M2 NOT F502M2s
    R502M2 = WITH WIDTH R502M2pre >= WM2_501

    // 4th, small
    F5012M2 = RECTANGLES WM2_501 LM2_501 SM2_501 OFFSET OM2_501 INSIDE OF LAYER R502M2
    F5012M2s = (SIZE F5012M2 BY (SM2_501 + grid)) OR F502M2s
    R5012M2pre = R502M2pre NOT F5012M2s
    R5012M2 = WITH WIDTH R5012M2pre >= WM2_501

    // 5th, non-stagger small
    F501M2 = RECTANGLES WM2_501 LM2_501 SM2_501 INSIDE OF LAYER R5012M2 //MAINTAIN SPACING
    F501M2s = (SIZE F501M2 BY (SM2_501 + grid)) OR F5012M2s

    F50M2 = ((F502M2 OR F5012M2) OR F501M2) OR F503M2

//****************************************************************************

    exceedM2 = DENSITY M2x F30M2 F40M2 F50M2 > maxD_M2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M2.den_exceed

    removeM2R = ((PUSH (exceedM2 AND (D50M2 OR emptyM2))) NOT FRAME2) AND CHIP
    removeM2P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM2R

    F30M2x = F30M2 NOT INTERACT removeM2P
    F40M2x = F40M2 NOT INTERACT removeM2P
    F50M2x = F50M2 NOT INTERACT removeM2P
    FM2xA  = (F30M2x OR F40M2x) OR F50M2x
    FM2x   = FM2xA NOT INTERACT (EXT FM2xA < DM2_S_1 ABUT SINGULAR REGION)

    ALLM2x = M2x OR FM2x
    lackM2 = DENSITY ALLM2x CHIP < DM2_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M2.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM2x)/AREA(CHIP) ]

    WDM2EXC = DUM2 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM2EXC = (SIZE FM2x BY Odm2DM2) OR (SIZE (((F303M2_EXP OR F403M2_EXP) OR F503M2_EXP) OR WDM2EXC) BY 1.5)

    lackM2pRM = ((((PUSH lackM2) NOT RM2EXC) NOT FRAME2OPC) NOT exceedM2) AND CHIP
    lackM2pRM_1 = WITH WIDTH lackM2pRM >= SM2_OPC

    RM2p1 = RECTANGLES WM2_OPC LM2_OPC WSM2_OPC LSM2_OPC INSIDE OF LAYER lackM2pRM_1
    lackM2pRM_2 = lackM2pRM_1 NOT (SIZE RM2p1 BY SM2_OPC)
    RM2p2 = RECTANGLES LM2_OPC WM2_OPC LSM2_OPC WSM2_OPC INSIDE OF LAYER lackM2pRM_2

    ODM2A = ((RM2p1 OR RM2p2) OUTSIDE RM2EXC) OUTSIDE FRAME2OPC
    ODM2F = ODM2A NOT INTERACT (EXT ODM2A < SM2_OPC ABUT SINGULAR REGION)

    DM2F = COPY FM2x

    FRAME2_INDDMYA = SIZE M2i BY (dm2_s2m2_INDDMY + grid)
    FRAME2_INDDMYB = SIZE DUM2 BY (dm2_s_INDDMY + grid)
    FRAME2_INDDMYC = SIZE DM2F BY dm2_s_INDDMY
    FRAME2_INDDMYD = SIZE ODM2F BY dm2_s2m2_INDDMY
    FRAME2_INDDMY  = (((((FRAME2Pre OR BLOCK2) OR FRAME2_INDDMYA) OR FRAME2_INDDMYB) OR FRAME2_INDDMYC) OR FRAME2_INDDMYD) OR NFILL
    FILL2_INDDMY   = ooINDDMY NOT FRAME2_INDDMY
    DM2F_INDDMY    = RECTANGLES dm2_w_INDDMY dm2_l_INDDMY dm2_s_INDDMY INSIDE OF LAYER FILL2_INDDMY


#IFDEF FILL_indDM2
    FILL2_INDDMY_HD = (SIZE INDDMY_HD BY -(dm2_s_INDDMY_HD + grid)) NOT FRAME2_INDDMY
    DM2F_INDDMY_HD  = RECTANGLES dm2_w_INDDMY_HD dm2_l_INDDMY_HD dm2_s_INDDMY_HD INSIDE OF LAYER FILL2_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M2

    minOPENM2 = DENSITY M2x < minD_M2 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M2Min.den
    emptyOPENM2 = DENSITY M2x < emptyD_M2 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M2Empty.den

    M2InnerHole = HOLES M2i INNER

    M2BigHole = SIZE M2InnerHole BY - excludeHoleSize/2
    M2ExcHole = ((M2InnerHole OUTSIDE M2BigHole) NOT M2i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK2 = (SIZE DM2EXCL BY (dm2DMEXCL + grid)) OR MIM2_x // DM2 to DM2EXCL
    FRAMEA2 = SIZE M2i BY (dm2M2 + grid) // DM2 to metal
    FRAMEB2 = SIZE (WITH WIDTH M2i > wideM2) BY (dm2WM2 + grid)
    FRAMEC2 = SIZE DUM2 BY (dm2DM2 + grid)   // DM2 to existed dummy metal 0.6um
    FRAME2Pre = ((FRAMEA2 OR FRAMEB2) OR FRAMEC2) OR M2ExcHole
    FRAME2INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm2_s2m2_INDDMY + grid)
    FRAME2 = ((FRAME2Pre OR FRAME2INDDMY) OR BLOCK2) OR NFILL
    
    OPENM2 = PUSH ((minOPENM2 OR emptyOPENM2) AND CHIP)
    FILL2 = OPENM2 NOT FRAME2
    FILLW2pre = SIZE FILL2 BY - (Wdm2M2 + grid)
    FILLW2 = WITH WIDTH FILLW2pre >= WdmW_M2
    M2FW = RECTANGLES WdmW_M2 WdmL_M2 WdmS_M2 OFFSET WdmO_M2 INSIDE OF LAYER FILLW2
    M2FW_EXP = SIZE M2FW BY (WdmS_M2 /2 + grid) OVERUNDER //merge the gaps
    FILLM2pre = FILL2 NOT (SIZE M2FW_EXP BY (MdmS_M2 + grid))
    FILLM2 = WITH WIDTH FILLM2pre >= MdmW_M2
    M2F1 = RECTANGLES MdmW_M2 MdmL_M2 MdmS_M2 OFFSET MdmO_M2 INSIDE OF LAYER FILLM2
    M2R1pre = FILLM2pre NOT (SIZE M2F1 BY (dmS_M2 + grid))
    M2R1 = WITH WIDTH M2R1pre >= dmW_M2

    M2F2 = RECTANGLES dmW_M2 dmL_M2 dmS_M2 OFFSET dmO_M2 INSIDE OF LAYER M2R1
    M2R2pre = M2R1 NOT (SIZE M2F2 BY (dmS_M2 + grid))
    M2R2 = WITH WIDTH M2R2pre >= dmW_M2

    M2F3 = RECTANGLES dmW_M2 dmL_M2 dmS_M2 OFFSET dmO_M2 INSIDE OF LAYER M2R2
    M2R3pre = M2R2 NOT (SIZE M2F3 BY (dmS_M2 + grid))
    M2R3 = WITH WIDTH M2R3pre >= dmW_M2

    M2F4 = RECTANGLES dmW_M2 dmL_M2 dmS_M2 INSIDE OF LAYER M2R3

    M2F = (((M2F1 OR M2F2) OR M2F3) OR M2F4) OR M2FW
    FM2 = M2F NOT INTERACT (EXT M2F < dmS_M2 ABUT SINGULAR REGION)

    maxOPENM2 = DENSITY M2x FM2 > maxD_M2 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M2Max.den

    FM2F = FM2 OUTSIDE maxOPENM2

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M2 = DENSITY M2x FM2F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M2Min.den

    RM2EXC = SIZE FM2F BY (Odm2DM2 + grid)
    // do not fill DMz_S over CTMDMY
    D25M2pM = (((PUSH D25M2) NOT FRAME2) NOT RM2EXC) AND CHIP
    D25M2pM_1 = WITH WIDTH D25M2pM >= OdmW_M2

    RM2p1 = RECTANGLES OdmW_M2 OdmL_M2 OdmS_M2 INSIDE OF LAYER D25M2pM_1
    D25M2pM_2 = D25M2pM_1 NOT (SIZE RM2p1 BY (OdmS_M2 + grid))
    RM2p2 = RECTANGLES OdmL_M2 OdmW_M2 OdmS_M2 INSIDE OF LAYER D25M2pM_2

    RM2A = ((RM2p1 OR RM2p2) OUTSIDE RM2EXC) OUTSIDE FRAME2
    RM2  = RM2A NOT INTERACT (EXT RM2A < OdmS_M2 ABUT SINGULAR REGION)

    DM2F = FM2F OR RM2

    FRAME2_INDDMYA = SIZE M2i BY (dm2_s2m2_INDDMY + grid)
    FRAME2_INDDMYB = SIZE DUM2 BY (dm2_s_INDDMY + grid)
    FRAME2_INDDMYC = SIZE DM2F BY dm2_s_INDDMY
    FRAME2_INDDMY  = ((((FRAME2Pre OR BLOCK2) OR FRAME2_INDDMYA) OR FRAME2_INDDMYB) OR FRAME2_INDDMYC) OR NFILL
    FILL2_INDDMY   = ooINDDMY NOT FRAME2_INDDMY
    DM2F_INDDMY    = RECTANGLES dm2_w_INDDMY dm2_l_INDDMY dm2_s_INDDMY INSIDE OF LAYER FILL2_INDDMY

#IFDEF FILL_indDM2
    FILL2_INDDMY_HD = (SIZE INDDMY_HD BY -(dm2_s_INDDMY_HD + grid)) NOT FRAME2_INDDMY
    DM2F_INDDMY_HD  = RECTANGLES dm2_w_INDDMY_HD dm2_l_INDDMY_HD dm2_s_INDDMY_HD INSIDE OF LAYER FILL2_INDDMY_HD
#ENDIF	

#ELSE



    D30M2 = DENSITY M2x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M2.den30
    D40M2 = DENSITY M2x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M2.den40
    D50M2 = DENSITY M2x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M2.den50
    emptyM2 = DENSITY M2x < emptyD_M2 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M2.den_empty

    M2InnerHole = HOLES M2i INNER
#IFDEF FILL_M2_DTCD
    VARIABLE M2_DTCD2Chip      2.5  //
    VARIABLE M2_DTCD2LOGO      10   //
    VARIABLE M2_DTCD2MOMDMY    0    // 
    VARIABLE M2_DTCD2LOWMEDN   0    //
    VARIABLE M2_DTCD2POFUSE    0    //
    VARIABLE M2_DTCD2DM2EXCL   0    //
    VARIABLE M2_DTCD2DM2CB2   0    //
    VARIABLE M2_DTCD2M2        2.63  // CB2.S.2
    VARIABLE M2_DTCD2DM2       1.5  // DMx.S.2
    VARIABLE M2_DTCD2TCDDMY_M2 150  // for idu measurement
    VARIABLE M2_DTCD2CTMDMY_3 0.112  // MIM.VIAz.S.5
    VARIABLE M2_DTCD2ICOVL     8
	M2_DTCDxChip        = CHIP NOT (SIZE CHIP BY -(M2_DTCD2Chip + grid))
    M2_DTCDxLOGO        = SIZE LOGO               BY (M2_DTCD2LOGO      + grid)
    M2_DTCDxMOMDMY      = SIZE MOMDMY             BY (M2_DTCD2MOMDMY    + grid)
    M2_DTCDxLOWMEDN     = SIZE LOWMEDN            BY (M2_DTCD2LOWMEDN   + grid)
    M2_DTCDxPOFUSE      = SIZE (FUSELINK AND POi) BY (M2_DTCD2POFUSE    + grid)
    M2_DTCDxDM2EXCL     = SIZE DM2EXCL            BY (M2_DTCD2DM2EXCL   + grid)
    M2_DTCDxDM2CB2      = SIZE CB2i               BY (M2_DTCD2DM2CB2    + grid)
    M2_DTCDxM2          = SIZE M2i                BY (M2_DTCD2M2        + grid)
    M2_DTCDxDM2         = SIZE DUM2               BY (M2_DTCD2DM2       + grid)
    M2_DTCDxTCDDMY_M2   = SIZE TCDDMY_M2          BY (M2_DTCD2TCDDMY_M2 + grid)
    M2_DTCDxTCDDMY_FM2  = SIZE TCDDMY_FM2         BY (M2_DTCD2TCDDMY_M2 + grid)
    M2_DTCDxTCDDMY_FDM2 = SIZE TCDDMY_FDM2        BY (M2_DTCD2TCDDMY_M2 + grid)
    M2_DTCDxICOVL       = SIZE ICOVL              BY (M2_DTCD2ICOVL     + grid)
    M2_DTCDxCTMDMY_3   = SIZE CTMDMY_3          BY (M2_DTCD2CTMDMY_3  + grid)

    M2_DTCDx = (((((((((((((M2_DTCDxChip OR M2_DTCDxLOGO) OR M2_DTCDxLOWMEDN) OR M2_DTCDxPOFUSE) OR M2_DTCDxDM2EXCL) OR M2_DTCDxM2) OR M2_DTCDxDM2) OR M2_DTCDxTCDDMY_M2) OR M2_DTCDxTCDDMY_FM2) OR M2_DTCDxTCDDMY_FDM2) OR FRAME2INDDMY) OR M2_DTCDxMOMDMY) OR M2_DTCDxDM2CB2) OR M2_DTCDxCTMDMY_3) OR M2_DTCDxICOVL
    M2_DTCDo = CHIP NOT M2_DTCDx

    VARIABLE TCD_M2_W      4
    VARIABLE TCD_M2_L      4
    VARIABLE M2_DTCD_S     400
    VARIABLE M2_DTCD_MIN_S 150
    VARIABLE D2M2_DTCD     0.6

    M2_DTCD_pre = RECTANGLES TCD_M2_W TCD_M2_L M2_DTCD_S INSIDE OF LAYER M2_DTCDo
