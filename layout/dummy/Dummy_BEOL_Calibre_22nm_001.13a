    F402M4s = (SIZE F402M4 BY (SM4_401 + grid)) OR B40M4s
    R402M4pre = O40M4 NOT F402M4s
    R402M4 = WITH WIDTH R402M4pre >= WM4_401

    // 4th, small
    F4012M4 = RECTANGLES WM4_401 LM4_401 SM4_401 OFFSET OM4_401 INSIDE OF LAYER R402M4
    F4012M4s = (SIZE F4012M4 BY (SM4_401 + grid)) OR F402M4s
    R4012M4pre = R402M4pre NOT F4012M4s
    R4012M4 = WITH WIDTH R4012M4pre >= WM4_401

    // 5th, non-stagger small
    F401M4 = RECTANGLES WM4_401 LM4_401 SM4_401 INSIDE OF LAYER R4012M4 //MAINTAIN SPACING
    F401M4s = (SIZE F401M4 BY (SM4_401 + grid)) OR F4012M4s

    F40M4 = ((F402M4 OR F4012M4) OR F401M4) OR F403M4_SLOT
    O50M4pre = (((PUSH (D50M4 OR emptyM4)) NOT FRAME4) NOT F401M4s) AND CHIP


    O50M4preA = SIZE O50M4pre BY -DM4_503
    O50M4preB = O50M4preA WITH WIDTH >= WM4_503

    // 1st big
    F503M4 = RECTANGLES WM4_503 LM4_503 SM4_503 OFFSET OM4_503 INSIDE OF LAYER O50M4preB
    F503M4_SLOT = RECTANGLES WM4_503_SLOT LM4_503_SLOT SM4_503_SLOT INSIDE OF LAYER F503M4

    F503M4_EXP = SIZE F503M4_SLOT BY ( SM4_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M4preF1 = O50M4pre NOT (SIZE F503M4_EXP BY SM4_502)
    O50M4preF  = (SNAP (SIZE O50M4preF1 BY -grid) 5) AND O50M4preF1

    B50M4s = F401M4s OR (SIZE F503M4_EXP BY (SM4_502+grid))
    O50M4 = O50M4preF NOT B50M4s

    // 3rd, middle
    F502M4 = RECTANGLES WM4_502 LM4_502 SM4_502 OFFSET OM4_502 INSIDE OF LAYER O50M4
    F502M4s = (SIZE F502M4 BY (SM4_501 + grid)) OR B50M4s
    R502M4pre = O50M4 NOT F502M4s
    R502M4 = WITH WIDTH R502M4pre >= WM4_501

    // 4th, small
    F5012M4 = RECTANGLES WM4_501 LM4_501 SM4_501 OFFSET OM4_501 INSIDE OF LAYER R502M4
    F5012M4s = (SIZE F5012M4 BY (SM4_501 + grid)) OR F502M4s
    R5012M4pre = R502M4pre NOT F5012M4s
    R5012M4 = WITH WIDTH R5012M4pre >= WM4_501

    // 5th, non-stagger small
    F501M4 = RECTANGLES WM4_501 LM4_501 SM4_501 INSIDE OF LAYER R5012M4 //MAINTAIN SPACING
    F501M4s = (SIZE F501M4 BY (SM4_501 + grid)) OR F5012M4s

    F50M4 = ((F502M4 OR F5012M4) OR F501M4) OR F503M4_SLOT

    exceedM4 = DENSITY M4x F30M4 F40M4 F50M4 > maxD_M4 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M4.den_exceed

    removeM4R = ((PUSH (exceedM4 AND (D50M4 OR emptyM4))) NOT FRAME4) AND CHIP
    removeM4P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM4R

    F30M4x = F30M4 NOT INTERACT removeM4P
    F40M4x = F40M4 NOT INTERACT removeM4P
    F50M4x = F50M4 NOT INTERACT removeM4P
    FM4xA  = (F30M4x OR F40M4x) OR F50M4x
    FM4x   = FM4xA NOT INTERACT (EXT FM4xA < DM4_S_1 ABUT SINGULAR REGION)

    ALLM4x = M4x OR FM4x
    lackM4 = DENSITY ALLM4x CHIP < DM4_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M4.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM4x)/AREA(CHIP) ]

    WDM4EXC = DUM4 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM4EXC = (SIZE FM4x BY Odm2DM4) OR (SIZE (((F303M4_EXP OR F403M4_EXP) OR F503M4_EXP) OR WDM4EXC) BY 1.5)

    lackM4pRM = ((((PUSH lackM4) NOT RM4EXC) NOT FRAME4OPC) NOT exceedM4) AND CHIP
    lackM4pRM_1 = WITH WIDTH lackM4pRM >= SM4_OPC

    RM4p1 = RECTANGLES WM4_OPC LM4_OPC WSM4_OPC LSM4_OPC INSIDE OF LAYER lackM4pRM_1
    lackM4pRM_2 = lackM4pRM_1 NOT (SIZE RM4p1 BY SM4_OPC)
    RM4p2 = RECTANGLES LM4_OPC WM4_OPC LSM4_OPC WSM4_OPC INSIDE OF LAYER lackM4pRM_2

    ODM4A = ((RM4p1 OR RM4p2) OUTSIDE RM4EXC) OUTSIDE FRAME4OPC
    ODM4F_pre = ODM4A NOT INTERACT (EXT ODM4A < SM4_OPC ABUT SINGULAR REGION)

// M4.S.14 ~ M4.S.16
M4_S_14_CHK_REGION = M4i OR ODM4F_pre
// Find Wide Metal
Wide_M4_S_14_CHK_REGION = ENCLOSE RECTANGLE (M4_S_14_CHK_REGION NOT WITH WIDTH <= M4_S_14_W1B) M4_S_14_W1B+GRID M4_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M4_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M4_S_14_CHK_REGION == 0
Wide_M4_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M4_S_14_CHK_REGION == 90

// Find Wide Metal Space
M4_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M4_S_14_CHK_REGION_EDGE_H M4_S_14_CHK_REGION < M4_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M4_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M4_S_14_CHK_REGION_EDGE_V M4_S_14_CHK_REGION < M4_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M4_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M4_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M4_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M4_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M4_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M4_S_14_CHK_REGION_OPC_REGION_pre1_H M4_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M4_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M4_S_14_L1B
M4_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M4_S_14_CHK_REGION_OPC_REGION_pre1_V M4_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M4_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M4_S_14_L1B

M4_S_14_OPC_REGION = M4_S_14_CHK_REGION_OPC_REGION_pre2_H OR M4_S_14_CHK_REGION_OPC_REGION_pre2_V

// M4.S.17 ~ M4.S.19
M4_S_17_CHK_REGION = M4i OR ODM4F_pre
// Find Wide Metal
Wide_M4_S_17_CHK_REGION = ENCLOSE RECTANGLE (M4_S_17_CHK_REGION NOT WITH WIDTH <= M4_S_17_W1B) M4_S_17_W1B+GRID M4_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M4_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M4_S_17_CHK_REGION == 0
Wide_M4_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M4_S_17_CHK_REGION == 90

// Find Wide Metal Space
M4_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M4_S_17_CHK_REGION_EDGE_H M4_S_17_CHK_REGION < M4_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M4_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M4_S_17_CHK_REGION_EDGE_V M4_S_17_CHK_REGION < M4_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M4_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M4_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M4_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M4_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M4_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M4_S_17_CHK_REGION_OPC_REGION_pre1_H M4_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M4_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M4_S_17_L1B
M4_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M4_S_17_CHK_REGION_OPC_REGION_pre1_V M4_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M4_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M4_S_17_L1B

M4_S_17_OPC_REGION = M4_S_17_CHK_REGION_OPC_REGION_pre2_H OR M4_S_17_CHK_REGION_OPC_REGION_pre2_V

// M4.S.20 ~ M4.S.22
M4_S_20_CHK_REGION = M4i OR ODM4F_pre
// Find Wide Metal
Wide_M4_S_20_CHK_REGION = ENCLOSE RECTANGLE (M4_S_20_CHK_REGION NOT WITH WIDTH <= M4_S_20_W1B) M4_S_20_W1B+GRID M4_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M4_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M4_S_20_CHK_REGION == 0
Wide_M4_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M4_S_20_CHK_REGION == 90

// Find Wide Metal Space
M4_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M4_S_20_CHK_REGION_EDGE_H M4_S_20_CHK_REGION < M4_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M4_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M4_S_20_CHK_REGION_EDGE_V M4_S_20_CHK_REGION < M4_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M4_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M4_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M4_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M4_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M4_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M4_S_20_CHK_REGION_OPC_REGION_pre1_H M4_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M4_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M4_S_20_L1B
M4_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M4_S_20_CHK_REGION_OPC_REGION_pre1_V M4_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M4_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M4_S_20_L1B

M4_S_20_OPC_REGION = M4_S_20_CHK_REGION_OPC_REGION_pre2_H OR M4_S_20_CHK_REGION_OPC_REGION_pre2_V

// M4.S.23 ~ M4.S.25
M4_S_23_CHK_REGION = M4i OR ODM4F_pre
// Find Wide Metal
Wide_M4_S_23_CHK_REGION = ENCLOSE RECTANGLE (M4_S_23_CHK_REGION NOT WITH WIDTH <= M4_S_23_W1B) M4_S_23_W1B+GRID M4_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M4_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M4_S_23_CHK_REGION == 0
Wide_M4_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M4_S_23_CHK_REGION == 90

// Find Wide Metal Space
M4_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M4_S_23_CHK_REGION_EDGE_H M4_S_23_CHK_REGION < M4_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M4_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M4_S_23_CHK_REGION_EDGE_V M4_S_23_CHK_REGION < M4_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M4_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M4_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M4_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M4_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M4_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M4_S_23_CHK_REGION_OPC_REGION_pre1_H M4_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M4_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M4_S_23_L1B
M4_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M4_S_23_CHK_REGION_OPC_REGION_pre1_V M4_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M4_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M4_S_23_L1B

M4_S_23_OPC_REGION = M4_S_23_CHK_REGION_OPC_REGION_pre2_H OR M4_S_23_CHK_REGION_OPC_REGION_pre2_V

// M4.S.27
M4_S_27_CHK_REGION = M4i OR ODM4F_pre
// Find Wide Metal
Wide_M4_S_27_CHK_REGION = ENCLOSE RECTANGLE (M4_S_27_CHK_REGION NOT WITH WIDTH <= M4_S_27_W1B) M4_S_27_W1B+GRID M4_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M4_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M4_S_27_CHK_REGION == 0
Wide_M4_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M4_S_27_CHK_REGION == 90

// Find Wide Metal Space
M4_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M4_S_27_CHK_REGION_EDGE_H M4_S_27_CHK_REGION < M4_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M4_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M4_S_27_CHK_REGION_EDGE_V M4_S_27_CHK_REGION < M4_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M4_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M4_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M4_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M4_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M4_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M4_S_27_CHK_REGION_OPC_REGION_pre1_H M4_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M4_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M4_S_27_L1B
M4_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M4_S_27_CHK_REGION_OPC_REGION_pre1_V M4_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M4_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M4_S_27_L1B

M4_S_27_OPC_REGION = M4_S_27_CHK_REGION_OPC_REGION_pre2_H OR M4_S_27_CHK_REGION_OPC_REGION_pre2_V

M4_WMJ_OPC_REGION = (((M4_S_14_OPC_REGION OR M4_S_17_OPC_REGION) OR M4_S_20_OPC_REGION) OR M4_S_23_OPC_REGION) OR M4_S_27_OPC_REGION

    ODM4F = ODM4F_pre NOT INTERACT M4_WMJ_OPC_REGION

    DM4F = COPY FM4x

    FRAME4_INDDMYA = SIZE M4i BY (dm4_s2m4_INDDMY + grid)
    FRAME4_INDDMYB = SIZE DUM4 BY (dm4_s_INDDMY + grid)
    FRAME4_INDDMYC = SIZE DM4F BY dm4_s_INDDMY
    FRAME4_INDDMYD = SIZE ODM4F BY dm4_s2m4_INDDMY

    FRAME4_INDDMY  = ((((((FRAME4Pre OR xM4_DTCD) OR BLOCK4) OR FRAME4_INDDMYA) OR FRAME4_INDDMYB) OR FRAME4_INDDMYC) OR FRAME4_INDDMYD) OR NFILL_x
    FILL4_INDDMY   = ooINDDMY NOT FRAME4_INDDMY
    DM4F_INDDMY    = RECTANGLES dm4_w_INDDMY dm4_l_INDDMY dm4_s_INDDMY INSIDE OF LAYER FILL4_INDDMY

#IFDEF FILL_indDM4
    FILL4_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm4_s_INDDMY_HD + grid)) NOT FRAME4_INDDMY
    DM4F_INDDMY_HD_pre  = RECTANGLES dm4_w_INDDMY_HD dm4_l_INDDMY_HD dm4_s_INDDMY_HD INSIDE OF LAYER FILL4_INDDMY_HD

    FILL4_INDDMY_MD = (SIZE INDDMY_MD BY -(dm4_s_INDDMY_MD + grid)) NOT (FRAME4_INDDMY OR INDDMY_HD)
    DM4F_INDDMY_MD  = RECTANGLES dm4_w_INDDMY_MD dm4_l_INDDMY_MD dm4_s_INDDMY_MD INSIDE OF LAYER FILL4_INDDMY_MD

    DM4F_INDDMY_HD = DM4F_INDDMY_HD_pre OR DM4F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#IFDEF FILL_DM5


#IFDEF 34K_THICK_Mu_M5

    minOPENM5 = DENSITY M5x < minD_M5 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M5Min.den
    emptyOPENM5 = DENSITY M5x < emptyD_M5 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M5Empty.den

    M5InnerHole = HOLES M5i INNER

    M5BigHole = SIZE M5InnerHole BY - excludeHoleSize/2
    M5ExcHole = ((M5InnerHole OUTSIDE M5BigHole) NOT M5i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK5    = (SIZE DM5EXCL BY (dm2DMEXCL + grid)) OR MIM5_x
    FRAMEA5   = SIZE M5i BY (dm2M5 + grid) // DM5 to metal
    FRAMEB5   = SIZE (WITH WIDTH M5i > wideM5) BY (dm2WM5 + grid)
    FRAMEC5   = SIZE DUM5 BY (dm2DM5 + grid)
    FRAME5Pre = ((FRAMEA5 OR FRAMEB5) OR FRAMEC5) OR M5ExcHole
    FRAME5INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm5_s2m5_INDDMY + grid)
    FRAME5 = ((FRAME5Pre OR FRAME5INDDMY) OR BLOCK5) OR NFILL
    
    OPENM5 = PUSH ((minOPENM5 OR emptyOPENM5) AND CHIP)
    FILL5 = OPENM5 NOT FRAME5
    FILLW5pre = SIZE FILL5 BY - (Wdm2M5 + grid)
    FILLW5 = WITH WIDTH FILLW5pre >= WdmW_M5
    M5FW = RECTANGLES WdmW_M5 WdmL_M5 WdmS_M5 OFFSET WdmO_M5 INSIDE OF LAYER FILLW5
    M5FW_EXP = SIZE M5FW BY (WdmS_M5 /2 + grid) OVERUNDER   // merge the gaps
    FILLM5pre = FILL5 NOT (SIZE M5FW_EXP BY (MdmS_M5 + grid))
    FILLM5 = WITH WIDTH FILLM5pre >= MdmW_M5
    M5F1 = RECTANGLES MdmW_M5 MdmL_M5 MdmS_M5 OFFSET MdmO_M5 INSIDE OF LAYER FILLM5
    M5R1pre = FILLM5pre NOT (SIZE M5F1 BY (dmS_M5 + grid))
    M5R1 = WITH WIDTH M5R1pre >= dmW_M5

    M5F2 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 OFFSET dmO_M5 INSIDE OF LAYER M5R1
    M5R2pre = M5R1 NOT (SIZE M5F2 BY (dmS_M5 + grid))
    M5R2 = WITH WIDTH M5R2pre >= dmW_M5

    M5F3 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 OFFSET dmO_M5 INSIDE OF LAYER M5R2
    M5R3pre = M5R2 NOT (SIZE M5F3 BY (dmS_M5 + grid))
    M5R3 = WITH WIDTH M5R3pre >= dmW_M5

    M5F4 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 INSIDE OF LAYER M5R3

    M5F = (((M5F1 OR M5F2) OR M5F3) OR M5F4) OR M5FW
    FM5 = M5F NOT INTERACT (EXT M5F < dmS_M5 ABUT SINGULAR REGION)

    maxOPENM5 = DENSITY M5x FM5 > maxD_M5 WINDOW WindowSizeu*2 STEP WindowStepu*2
                INSIDE OF LAYER bulk BACKUP // PRINT M5Max.den

    DM5F = FM5 OUTSIDE maxOPENM5

    FRAME5_INDDMYA = SIZE M5i BY (dm5_s2m5_INDDMY + grid)
    FRAME5_INDDMYB = SIZE DUM5 BY (dm5_s_INDDMY + grid)
    FRAME5_INDDMYC = SIZE DM5F BY dm5_s_INDDMY
    FRAME5_INDDMY  = ((((FRAME5Pre OR BLOCK5) OR FRAME5_INDDMYA) OR FRAME5_INDDMYB) OR FRAME5_INDDMYC) OR NFILL
    FILL5_INDDMY   = ooINDDMY NOT FRAME5_INDDMY
    DM5F_INDDMY    = RECTANGLES dm5_w_INDDMY dm5_l_INDDMY dm5_s_INDDMY INSIDE OF LAYER FILL5_INDDMY
#IFDEF FILL_indDM5
    FILL5_INDDMY_HD = (SIZE INDDMY_HD BY -(dm5_s_INDDMY_HD + grid)) NOT FRAME5_INDDMY
    DM5F_INDDMY_HD  = RECTANGLES dm5_w_INDDMY_HD dm5_l_INDDMY_HD dm5_s_INDDMY_HD INSIDE OF LAYER FILL5_INDDMY_HD
#ENDIF	
	
#ELSE


#IFDEF 12K_THICK_Mr_M5

    minOPENM5 = DENSITY M5x < minD_M5 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M5Min.den
    emptyOPENM5 = DENSITY M5x < emptyD_M5 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M5Empty.den

    M5InnerHole = HOLES M5i INNER

    M5BigHole = SIZE M5InnerHole BY - excludeHoleSize/2
    M5ExcHole = ((M5InnerHole OUTSIDE M5BigHole) NOT M5i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK5  = (SIZE DM5EXCL BY (dm2DMEXCL + grid)) OR MIM5_x // DM5 to DM5EXCL
    FRAMEA5 = SIZE M5i BY (dm2M5 + grid) // DM5 to metal
    FRAMEB5 = SIZE (WITH WIDTH M5i > wideM5) BY (dm2WM5 + grid)
    FRAMEC5 = SIZE DUM5 BY (dm2DM5 + grid)   // DM5 to existed dummy metal 0.6um
    FRAME5Pre = ((FRAMEA5 OR FRAMEB5) OR FRAMEC5) OR M5ExcHole
    FRAME5INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm5_s2m5_INDDMY + grid)
    FRAME5 = ((FRAME5Pre OR FRAME5INDDMY) OR BLOCK5) OR NFILL
    
    OPENM5 = PUSH ((minOPENM5 OR emptyOPENM5) AND CHIP)
    FILL5 = OPENM5 NOT FRAME5
    FILLW5pre = SIZE FILL5 BY - (Wdm2M5 + grid)
    FILLW5 = WITH WIDTH FILLW5pre >= WdmW_M5
    M5FW = RECTANGLES WdmW_M5 WdmL_M5 WdmS_M5 OFFSET WdmO_M5 INSIDE OF LAYER FILLW5
    M5FW_EXP = SIZE M5FW BY (WdmS_M5 /2 + grid) OVERUNDER //merge the gaps
    FILLM5pre = FILL5 NOT (SIZE M5FW_EXP BY (MdmS_M5 + grid))
    FILLM5 = WITH WIDTH FILLM5pre >= MdmW_M5
    M5F1 = RECTANGLES MdmW_M5 MdmL_M5 MdmS_M5 OFFSET MdmO_M5 INSIDE OF LAYER FILLM5
    M5R1pre = FILLM5pre NOT (SIZE M5F1 BY (dmS_M5 + grid))
    M5R1 = WITH WIDTH M5R1pre >= dmW_M5

    M5F2 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 OFFSET dmO_M5 INSIDE OF LAYER M5R1
    M5R2pre = M5R1 NOT (SIZE M5F2 BY (dmS_M5 + grid))
    M5R2 = WITH WIDTH M5R2pre >= dmW_M5

    M5F3 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 OFFSET dmO_M5 INSIDE OF LAYER M5R2
    M5R3pre = M5R2 NOT (SIZE M5F3 BY (dmS_M5 + grid))
    M5R3 = WITH WIDTH M5R3pre >= dmW_M5

    M5F4 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 INSIDE OF LAYER M5R3

    M5F = (((M5F1 OR M5F2) OR M5F3) OR M5F4) OR M5FW
    FM5 = M5F NOT INTERACT (EXT M5F < dmS_M5 ABUT SINGULAR REGION)

    maxOPENM5 = DENSITY M5x FM5 > maxD_M5 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M5Max.den

    FM5F = FM5 OUTSIDE maxOPENM5

    // DMr_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M5 = DENSITY M5x FM5F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M5Min.den

    RM5EXC = SIZE FM5F BY (Odm2DM5 + grid)
    // do not fill DMy_S over CTMDMY
    D25M5pM = (((PUSH D25M5) NOT FRAME5) NOT RM5EXC) AND CHIP
    D25M5pM_1 = WITH WIDTH D25M5pM >= OdmW_M5

    RM5p1 = RECTANGLES OdmW_M5 OdmL_M5 OdmS_M5 INSIDE OF LAYER D25M5pM_1
    D25M5pM_2 = D25M5pM_1 NOT (SIZE RM5p1 BY (OdmS_M5 + grid))
    RM5p2 = RECTANGLES OdmL_M5 OdmW_M5 OdmS_M5 INSIDE OF LAYER D25M5pM_2

    RM5A = ((RM5p1 OR RM5p2) OUTSIDE RM5EXC) OUTSIDE FRAME5
    RM5  = RM5A NOT INTERACT (EXT RM5A < OdmS_M5 ABUT SINGULAR REGION)

    DM5F = FM5F OR RM5

    FRAME5_INDDMYA = SIZE M5i BY (dm5_s2m5_INDDMY + grid)
    FRAME5_INDDMYB = SIZE DUM5 BY (dm5_s_INDDMY + grid)
    FRAME5_INDDMYC = SIZE DM5F BY dm5_s_INDDMY
    FRAME5_INDDMY  = ((((FRAME5Pre OR BLOCK5) OR FRAME5_INDDMYA) OR FRAME5_INDDMYB) OR FRAME5_INDDMYC) OR NFILL
    FILL5_INDDMY   = ooINDDMY NOT FRAME5_INDDMY
    DM5F_INDDMY    = RECTANGLES dm5_w_INDDMY dm5_l_INDDMY dm5_s_INDDMY INSIDE OF LAYER FILL5_INDDMY

#IFDEF FILL_indDM5
    FILL5_INDDMY_HD = (SIZE INDDMY_HD BY -(dm5_s_INDDMY_HD + grid)) NOT FRAME5_INDDMY
    DM5F_INDDMY_HD  = RECTANGLES dm5_w_INDDMY_HD dm5_l_INDDMY_HD dm5_s_INDDMY_HD INSIDE OF LAYER FILL5_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 5K_THICK_Myz_M5

    minOPENM5 = DENSITY M5x < minD_M5 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M5Min.den
    emptyOPENM5 = DENSITY M5x < emptyD_M5 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M5Empty.den

    M5InnerHole = HOLES M5i INNER

    M5BigHole = SIZE M5InnerHole BY - excludeHoleSize/2
    M5ExcHole = ((M5InnerHole OUTSIDE M5BigHole) NOT M5i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK5 = (SIZE DM5EXCL BY (dm2DMEXCL + grid)) OR MIM5_x // DM5 to DM5EXCL
    FRAMEA5 = SIZE M5i BY (dm2M5 + grid) // DM5 to metal
    FRAMEB5 = SIZE (WITH WIDTH M5i > wideM5) BY (dm2WM5 + grid)
    FRAMEC5 = SIZE DUM5 BY (dm2DM5 + grid)   // DM5 to existed dummy metal 0.6um
    FRAME5Pre = ((FRAMEA5 OR FRAMEB5) OR FRAMEC5) OR M5ExcHole
    FRAME5INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm5_s2m5_INDDMY + grid)
    FRAME5 = ((FRAME5Pre OR FRAME5INDDMY) OR BLOCK5) OR NFILL
    
    OPENM5 = PUSH ((minOPENM5 OR emptyOPENM5) AND CHIP)
    FILL5 = OPENM5 NOT FRAME5
    FILLW5pre = SIZE FILL5 BY - (Wdm2M5 + grid)
    FILLW5 = WITH WIDTH FILLW5pre >= WdmW_M5
    M5FW = RECTANGLES WdmW_M5 WdmL_M5 WdmS_M5 OFFSET WdmO_M5 INSIDE OF LAYER FILLW5
    M5FW_EXP = SIZE M5FW BY (WdmS_M5 /2 + grid) OVERUNDER //merge the gaps
    FILLM5pre = FILL5 NOT (SIZE M5FW_EXP BY (MdmS_M5 + grid))
    FILLM5 = WITH WIDTH FILLM5pre >= MdmW_M5
    M5F1 = RECTANGLES MdmW_M5 MdmL_M5 MdmS_M5 OFFSET MdmO_M5 INSIDE OF LAYER FILLM5
    M5R1pre = FILLM5pre NOT (SIZE M5F1 BY (dmS_M5 + grid))
    M5R1 = WITH WIDTH M5R1pre >= dmW_M5

    M5F2 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 OFFSET dmO_M5 INSIDE OF LAYER M5R1
    M5R2pre = M5R1 NOT (SIZE M5F2 BY (dmS_M5 + grid))
    M5R2 = WITH WIDTH M5R2pre >= dmW_M5

    M5F3 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 OFFSET dmO_M5 INSIDE OF LAYER M5R2
    M5R3pre = M5R2 NOT (SIZE M5F3 BY (dmS_M5 + grid))
    M5R3 = WITH WIDTH M5R3pre >= dmW_M5

    M5F4 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 INSIDE OF LAYER M5R3

    M5F = (((M5F1 OR M5F2) OR M5F3) OR M5F4) OR M5FW
    FM5 = M5F NOT INTERACT (EXT M5F < dmS_M5 ABUT SINGULAR REGION)

    maxOPENM5 = DENSITY M5x FM5 > maxD_M5 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M5Max.den

    FM5F = FM5 OUTSIDE maxOPENM5

    // DMy_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M5 = DENSITY M5x FM5F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M5Min.den

    RM5EXC = SIZE FM5F BY (Odm2DM5 + grid)
    // do not fill DMy_S over CTMDMY
    D25M5pM = (((PUSH D25M5) NOT FRAME5) NOT RM5EXC) AND CHIP
    D25M5pM_1 = WITH WIDTH D25M5pM >= OdmW_M5

    RM5p1 = RECTANGLES OdmW_M5 OdmL_M5 OdmS_M5 INSIDE OF LAYER D25M5pM_1
    D25M5pM_2 = D25M5pM_1 NOT (SIZE RM5p1 BY (OdmS_M5 + grid))
    RM5p2 = RECTANGLES OdmL_M5 OdmW_M5 OdmS_M5 INSIDE OF LAYER D25M5pM_2

    RM5A = ((RM5p1 OR RM5p2) OUTSIDE RM5EXC) OUTSIDE FRAME5
    RM5  = RM5A NOT INTERACT (EXT RM5A < OdmS_M5 ABUT SINGULAR REGION)

    DM5F = FM5F OR RM5

    FRAME5_INDDMYA = SIZE M5i BY (dm5_s2m5_INDDMY + grid)
    FRAME5_INDDMYB = SIZE DUM5 BY (dm5_s_INDDMY + grid)
    FRAME5_INDDMYC = SIZE DM5F BY dm5_s_INDDMY
    FRAME5_INDDMY  = ((((FRAME5Pre OR BLOCK5) OR FRAME5_INDDMYA) OR FRAME5_INDDMYB) OR FRAME5_INDDMYC) OR NFILL
    FILL5_INDDMY   = ooINDDMY NOT FRAME5_INDDMY
    DM5F_INDDMY    = RECTANGLES dm5_w_INDDMY dm5_l_INDDMY dm5_s_INDDMY INSIDE OF LAYER FILL5_INDDMY


#IFDEF FILL_indDM5
    FILL5_INDDMY_HD = (SIZE INDDMY_HD BY -(dm5_s_INDDMY_HD + grid)) NOT FRAME5_INDDMY
    DM5F_INDDMY_HD  = RECTANGLES dm5_w_INDDMY_HD dm5_l_INDDMY_HD dm5_s_INDDMY_HD INSIDE OF LAYER FILL5_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2_6K_THICK_Mxy_M5

    minOPENM5 = DENSITY M5x < minD_M5 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M5Min.den
    emptyOPENM5 = DENSITY M5x < emptyD_M5 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M5Empty.den

    M5InnerHole = HOLES M5i INNER

    M5BigHole = SIZE M5InnerHole BY - excludeHoleSize/2
    M5ExcHole = ((M5InnerHole OUTSIDE M5BigHole) NOT M5i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK5 = (SIZE DM5EXCL BY (dm2DMEXCL + grid)) OR  MIM5_x // DM5 to DM5EXCL
    FRAMEA5 = SIZE M5i BY (dm2M5 + grid) // DM5 to metal
    FRAMEB5 = SIZE (WITH WIDTH M5i > wideM5) BY (dm2WM5 + grid)
    FRAMEC5 = SIZE DUM5 BY (dm2DM5 + grid)   // DM5 to existed dummy metal 0.6um
    FRAME5Pre = ((FRAMEA5 OR FRAMEB5) OR FRAMEC5) OR M5ExcHole
    FRAME5INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm5_s2m5_INDDMY + grid)
    FRAME5 = ((FRAME5Pre OR FRAME5INDDMY) OR BLOCK5) OR NFILL
    
    OPENM5 = PUSH ((minOPENM5 OR emptyOPENM5) AND CHIP)
    FILL5 = OPENM5 NOT FRAME5
    FILLW5pre = SIZE FILL5 BY - (Wdm2M5 + grid)
    FILLW5 = WITH WIDTH FILLW5pre >= WdmW_M5
    M5FW = RECTANGLES WdmW_M5 WdmL_M5 WdmS_M5 OFFSET WdmO_M5 INSIDE OF LAYER FILLW5
    M5FW_EXP = SIZE M5FW BY (WdmS_M5 /2 + grid) OVERUNDER //merge the gaps
    FILLM5pre = FILL5 NOT (SIZE M5FW_EXP BY (MdmS_M5 + grid))
    FILLM5 = WITH WIDTH FILLM5pre >= MdmW_M5
    M5F1 = RECTANGLES MdmW_M5 MdmL_M5 MdmS_M5 OFFSET MdmO_M5 INSIDE OF LAYER FILLM5
    M5R1pre = FILLM5pre NOT (SIZE M5F1 BY (dmS_M5 + grid))
    M5R1 = WITH WIDTH M5R1pre >= dmW_M5

    M5F2 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 OFFSET dmO_M5 INSIDE OF LAYER M5R1
    M5R2pre = M5R1 NOT (SIZE M5F2 BY (dmS_M5 + grid))
    M5R2 = WITH WIDTH M5R2pre >= dmW_M5

    M5F3 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 OFFSET dmO_M5 INSIDE OF LAYER M5R2
    M5R3pre = M5R2 NOT (SIZE M5F3 BY (dmS_M5 + grid))
    M5R3 = WITH WIDTH M5R3pre >= dmW_M5

    M5F4 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 INSIDE OF LAYER M5R3

    M5F = (((M5F1 OR M5F2) OR M5F3) OR M5F4) OR M5FW
    FM5 = M5F NOT INTERACT (EXT M5F < dmS_M5 ABUT SINGULAR REGION)

    maxOPENM5 = DENSITY M5x FM5 > maxD_M5 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M5Max.den

    FM5F = FM5 OUTSIDE maxOPENM5

    D25M5 = DENSITY M5x FM5F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M5Min.den

    RM5EXC = SIZE FM5F BY (Odm2DM5 + grid)
    D25M5pM = (((PUSH D25M5) NOT FRAME5) NOT RM5EXC) AND CHIP
    D25M5pM_1 = WITH WIDTH D25M5pM >= OdmW_M5

    RM5p1 = RECTANGLES OdmW_M5 OdmL_M5 OdmS_M5 INSIDE OF LAYER D25M5pM_1
    D25M5pM_2 = D25M5pM_1 NOT (SIZE RM5p1 BY (OdmS_M5 + grid))
    RM5p2 = RECTANGLES OdmL_M5 OdmW_M5 OdmS_M5 INSIDE OF LAYER D25M5pM_2

    RM5A = ((RM5p1 OR RM5p2) OUTSIDE RM5EXC) OUTSIDE FRAME5
    RM5  = RM5A NOT INTERACT (EXT RM5A < OdmS_M5 ABUT SINGULAR REGION)

    DM5F = FM5F OR RM5

    FRAME5_INDDMYA = SIZE M5i BY (dm5_s2m5_INDDMY + grid)
    FRAME5_INDDMYB = SIZE DUM5 BY (dm5_s_INDDMY + grid)
    FRAME5_INDDMYC = SIZE DM5F BY dm5_s_INDDMY
    FRAME5_INDDMY  = ((((FRAME5Pre OR BLOCK5) OR FRAME5_INDDMYA) OR FRAME5_INDDMYB) OR FRAME5_INDDMYC) OR NFILL
    FILL5_INDDMY   = ooINDDMY NOT FRAME5_INDDMY
    DM5F_INDDMY    = RECTANGLES dm5_w_INDDMY dm5_l_INDDMY dm5_s_INDDMY INSIDE OF LAYER FILL5_INDDMY

#IFDEF FILL_indDM5
    FILL5_INDDMY_HD = (SIZE INDDMY_HD BY -(dm5_s_INDDMY_HD + grid)) NOT FRAME5_INDDMY
    DM5F_INDDMY_HD  = RECTANGLES dm5_w_INDDMY_HD dm5_l_INDDMY_HD dm5_s_INDDMY_HD INSIDE OF LAYER FILL5_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M5

    D30M5 = DENSITY M5x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M5.den30
    D40M5 = DENSITY M5x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M5.den40
    D50M5 = DENSITY M5x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M5.den50
    emptyM5 = DENSITY M5x < emptyD_M5 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M5.den_empty

    M5InnerHole = HOLES M5i INNER

    M5BigHole = SIZE M5InnerHole BY - excludeHoleSize/2
    M5ExcHole = ((M5InnerHole OUTSIDE M5BigHole) NOT M5i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK5 = (SIZE DM5EXCL BY (dm2DMEXCL + grid)) OR MIM5_x

    FRAMEA5 = (SIZE M5i BY (DM5_301 + grid)) OR (SIZE (EXPAND EDGE (M5i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA5OPC = SIZE M5i BY (DM5_OPC + grid)
    FRAMEA5OPCDV33 = SIZE (M5i INTERACT M5_HVN_330Vx) BY (M5_S_1_1_a + grid)
    FRAMEA5OPCDV5 = SIZE (M5i INTERACT M5_HVN_500Vx) BY (M5_S_9_a + grid)
    FRAMEA5OPC45 = SIZE (EXPAND EDGE (M5i ANGLE == 45) OUTSIDE BY DM5_OPC_45 EXTEND BY DM5_OPC_45_E) BY grid
    FRAMEA5OPC45DV = SIZE (EXPAND EDGE ((M5i INTERACT M5_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM5_OPC_45 EXTEND BY DM5_OPC_45_E) BY grid

    FRAMEB5 = SIZE (WITH WIDTH M5i > wideM5) BY (dm2WM5 + grid)
    FRAMEC5 = SIZE DUM5 BY (dm2DM5 + grid)
    FRAMED5 = SIZE (WITH WIDTH M5i > wideM5_small) BY (dm2WM5_small + grid)
    FRAMEC5OPC = SIZE DUM5 BY (Odm2DM5 + grid)
    FRAME5Pre = ((FRAMEA5 OR FRAMEB5) OR (FRAMEC5 OR FRAMED5)) OR M5ExcHole
    FRAME5PreOPC = (((((((FRAMEA5OPC OR FRAMEA5OPCDV33) OR FRAMEA5OPCDV5) OR FRAMEC5OPC) OR M5ExcHole) OR FRAMEA5OPC45) OR FRAMEA5OPC45DV) OR FRAMEB5) OR FRAMED5
    FRAME5INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm5_s2m5_INDDMY + grid)

    FRAME5OPC = ((FRAME5PreOPC OR FRAME5INDDMY) OR BLOCK5) OR NFILLOPC

    FRAME5 = ((FRAME5Pre OR FRAME5INDDMY) OR BLOCK5) OR NFILL

    //****************************************************************************

    D30M5p = (PUSH D30M5) NOT FRAME5
    O30M5pre = D30M5p AND CHIP
    FD21M5s = COPY FRAME5

    O30M5preA = SIZE O30M5pre BY -DM5_303
    O30M5preB = O30M5preA WITH WIDTH >= WM5_303

    // 1st big
    F303M5 = RECTANGLES WM5_303 LM5_303 SM5_303 OFFSET OM5_303 INSIDE OF LAYER O30M5preB

    F303M5_EXP = SIZE F303M5 BY ( SM5_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M5preF1 = O30M5pre NOT (SIZE F303M5_EXP BY SM5_302)
    O30M5preF  = (SNAP (SIZE O30M5preF1 BY -grid) 5) AND O30M5preF1

    B30M5s = FD21M5s OR (SIZE F303M5_EXP BY (SM5_302+grid))
    O30M5 = O30M5preF NOT B30M5s

    // 3rd, middle
    F302M5 = RECTANGLES WM5_302 LM5_302 SM5_302 OFFSET OM5_302 INSIDE OF LAYER O30M5
    F302M5s = (SIZE F302M5 BY (SM5_301 + grid)) OR B30M5s
    R302M5pre = O30M5 NOT F302M5s
    R302M5 = WITH WIDTH R302M5pre >= WM5_301

    // 4th, small
    F3012M5 = RECTANGLES WM5_301 LM5_301 SM5_301 OFFSET OM5_301 INSIDE OF LAYER R302M5
    F3012M5s = (SIZE F3012M5 BY (SM5_301 + grid)) OR F302M5s
    R3012M5pre = R302M5pre NOT F3012M5s
    R3012M5 = WITH WIDTH R3012M5pre >= WM5_301

    // 5th, non-stagger small
    F301M5 = RECTANGLES WM5_301 LM5_301 SM5_301 INSIDE OF LAYER R3012M5 //MAINTAIN SPACING
    F301M5s = (SIZE F301M5 BY (SM5_301 + grid)) OR F3012M5s

    F30M5 = ((F302M5 OR F3012M5) OR F301M5) OR F303M5
    O40M5pre = (((PUSH D40M5) NOT FRAME5) NOT F301M5s) AND CHIP


    O40M5preA = SIZE O40M5pre BY -DM5_403
    O40M5preB = O40M5preA WITH WIDTH >= WM5_403

    // 1st big
    F403M5 = RECTANGLES WM5_403 LM5_403 SM5_403 OFFSET OM5_403 INSIDE OF LAYER O40M5preB

    F403M5_EXP = SIZE F403M5 BY ( SM5_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M5preF1 = O40M5pre NOT (SIZE F403M5_EXP BY SM5_402)
    O40M5preF  = (SNAP (SIZE O40M5preF1 BY -grid) 5) AND O40M5preF1

    B40M5s = F301M5s OR (SIZE F403M5_EXP BY (SM5_402+grid))
    O40M5 = O40M5preF NOT B40M5s

    // 3rd, middle
    F402M5 = RECTANGLES WM5_402 LM5_402 SM5_402 OFFSET OM5_402 INSIDE OF LAYER O40M5
    F402M5s = (SIZE F402M5 BY (SM5_401 + grid)) OR B40M5s
    R402M5pre = O40M5 NOT F402M5s
    R402M5 = WITH WIDTH R402M5pre >= WM5_401

    // 4th, small
    F4012M5 = RECTANGLES WM5_401 LM5_401 SM5_401 OFFSET OM5_401 INSIDE OF LAYER R402M5
    F4012M5s = (SIZE F4012M5 BY (SM5_401 + grid)) OR F402M5s
    R4012M5pre = R402M5pre NOT F4012M5s
    R4012M5 = WITH WIDTH R4012M5pre >= WM5_401

    // 5th, non-stagger small
    F401M5 = RECTANGLES WM5_401 LM5_401 SM5_401 INSIDE OF LAYER R4012M5 //MAINTAIN SPACING
    F401M5s = (SIZE F401M5 BY (SM5_401 + grid)) OR F4012M5s

    F40M5 = ((F402M5 OR F4012M5) OR F401M5) OR F403M5
    O50M5pre = (((PUSH (D50M5 OR emptyM5)) NOT FRAME5) NOT F401M5s) AND CHIP


    O50M5preA = SIZE O50M5pre BY -DM5_503
    O50M5preB = O50M5preA WITH WIDTH >= WM5_503

    // 1st big
    F503M5 = RECTANGLES WM5_503 LM5_503 SM5_503 OFFSET OM5_503 INSIDE OF LAYER O50M5preB

    F503M5_EXP = SIZE F503M5 BY ( SM5_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M5preF1 = O50M5pre NOT (SIZE F503M5_EXP BY SM5_502)
    O50M5preF  = (SNAP (SIZE O50M5preF1 BY -grid) 5) AND O50M5preF1

    B50M5s = F401M5s OR (SIZE F503M5_EXP BY (SM5_502+grid))
    O50M5 = O50M5preF NOT B50M5s

    // 3rd, middle
    F502M5 = RECTANGLES WM5_502 LM5_502 SM5_502 OFFSET OM5_502 INSIDE OF LAYER O50M5
    F502M5s = (SIZE F502M5 BY (SM5_501 + grid)) OR B50M5s
    R502M5pre = O50M5 NOT F502M5s
    R502M5 = WITH WIDTH R502M5pre >= WM5_501

    // 4th, small
    F5012M5 = RECTANGLES WM5_501 LM5_501 SM5_501 OFFSET OM5_501 INSIDE OF LAYER R502M5
    F5012M5s = (SIZE F5012M5 BY (SM5_501 + grid)) OR F502M5s
    R5012M5pre = R502M5pre NOT F5012M5s
    R5012M5 = WITH WIDTH R5012M5pre >= WM5_501

    // 5th, non-stagger small
    F501M5 = RECTANGLES WM5_501 LM5_501 SM5_501 INSIDE OF LAYER R5012M5 //MAINTAIN SPACING
    F501M5s = (SIZE F501M5 BY (SM5_501 + grid)) OR F5012M5s

    F50M5 = ((F502M5 OR F5012M5) OR F501M5) OR F503M5

//****************************************************************************

    exceedM5 = DENSITY M5x F30M5 F40M5 F50M5 > maxD_M5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M5.den_exceed

    removeM5R = ((PUSH (exceedM5 AND (D50M5 OR emptyM5))) NOT FRAME5) AND CHIP
    removeM5P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM5R

    F30M5x = F30M5 NOT INTERACT removeM5P
    F40M5x = F40M5 NOT INTERACT removeM5P
    F50M5x = F50M5 NOT INTERACT removeM5P
    FM5xA  = (F30M5x OR F40M5x) OR F50M5x
    FM5x   = FM5xA NOT INTERACT (EXT FM5xA < DM5_S_1 ABUT SINGULAR REGION)

    ALLM5x = M5x OR FM5x
    lackM5 = DENSITY ALLM5x CHIP < DM5_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M5.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM5x)/AREA(CHIP) ]

    WDM5EXC = DUM5 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM5EXC = (SIZE FM5x BY Odm2DM5) OR (SIZE (((F303M5_EXP OR F403M5_EXP) OR F503M5_EXP) OR WDM5EXC) BY 1.5)

    lackM5pRM = ((((PUSH lackM5) NOT RM5EXC) NOT FRAME5OPC) NOT exceedM5) AND CHIP
    lackM5pRM_1 = WITH WIDTH lackM5pRM >= SM5_OPC

    RM5p1 = RECTANGLES WM5_OPC LM5_OPC WSM5_OPC LSM5_OPC INSIDE OF LAYER lackM5pRM_1
    lackM5pRM_2 = lackM5pRM_1 NOT (SIZE RM5p1 BY SM5_OPC)
    RM5p2 = RECTANGLES LM5_OPC WM5_OPC LSM5_OPC WSM5_OPC INSIDE OF LAYER lackM5pRM_2

    ODM5A = ((RM5p1 OR RM5p2) OUTSIDE RM5EXC) OUTSIDE FRAME5OPC
    ODM5F = ODM5A NOT INTERACT (EXT ODM5A < SM5_OPC ABUT SINGULAR REGION)

    DM5F = COPY FM5x

    FRAME5_INDDMYA = SIZE M5i BY (dm5_s2m5_INDDMY + grid)
    FRAME5_INDDMYB = SIZE DUM5 BY (dm5_s_INDDMY + grid)
    FRAME5_INDDMYC = SIZE DM5F BY dm5_s_INDDMY
    FRAME5_INDDMYD = SIZE ODM5F BY dm5_s2m5_INDDMY
    FRAME5_INDDMY  = (((((FRAME5Pre OR BLOCK5) OR FRAME5_INDDMYA) OR FRAME5_INDDMYB) OR FRAME5_INDDMYC) OR FRAME5_INDDMYD) OR NFILL
    FILL5_INDDMY   = ooINDDMY NOT FRAME5_INDDMY
    DM5F_INDDMY    = RECTANGLES dm5_w_INDDMY dm5_l_INDDMY dm5_s_INDDMY INSIDE OF LAYER FILL5_INDDMY


#IFDEF FILL_indDM5
    FILL5_INDDMY_HD = (SIZE INDDMY_HD BY -(dm5_s_INDDMY_HD + grid)) NOT FRAME5_INDDMY
    DM5F_INDDMY_HD  = RECTANGLES dm5_w_INDDMY_HD dm5_l_INDDMY_HD dm5_s_INDDMY_HD INSIDE OF LAYER FILL5_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M5

    minOPENM5 = DENSITY M5x < minD_M5 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M5Min.den
    emptyOPENM5 = DENSITY M5x < emptyD_M5 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M5Empty.den

    M5InnerHole = HOLES M5i INNER

    M5BigHole = SIZE M5InnerHole BY - excludeHoleSize/2
    M5ExcHole = ((M5InnerHole OUTSIDE M5BigHole) NOT M5i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK5 = (SIZE DM5EXCL BY (dm2DMEXCL + grid)) OR MIM5_x // DM5 to DM5EXCL
    FRAMEA5 = SIZE M5i BY (dm2M5 + grid) // DM5 to metal
    FRAMEB5 = SIZE (WITH WIDTH M5i > wideM5) BY (dm2WM5 + grid)
    FRAMEC5 = SIZE DUM5 BY (dm2DM5 + grid)   // DM5 to existed dummy metal 0.6um
    FRAME5Pre = ((FRAMEA5 OR FRAMEB5) OR FRAMEC5) OR M5ExcHole
    FRAME5INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm5_s2m5_INDDMY + grid)
    FRAME5 = ((FRAME5Pre OR FRAME5INDDMY) OR BLOCK5) OR NFILL
    
    OPENM5 = PUSH ((minOPENM5 OR emptyOPENM5) AND CHIP)
    FILL5 = OPENM5 NOT FRAME5
    FILLW5pre = SIZE FILL5 BY - (Wdm2M5 + grid)
    FILLW5 = WITH WIDTH FILLW5pre >= WdmW_M5
    M5FW = RECTANGLES WdmW_M5 WdmL_M5 WdmS_M5 OFFSET WdmO_M5 INSIDE OF LAYER FILLW5
    M5FW_EXP = SIZE M5FW BY (WdmS_M5 /2 + grid) OVERUNDER //merge the gaps
    FILLM5pre = FILL5 NOT (SIZE M5FW_EXP BY (MdmS_M5 + grid))
    FILLM5 = WITH WIDTH FILLM5pre >= MdmW_M5
    M5F1 = RECTANGLES MdmW_M5 MdmL_M5 MdmS_M5 OFFSET MdmO_M5 INSIDE OF LAYER FILLM5
    M5R1pre = FILLM5pre NOT (SIZE M5F1 BY (dmS_M5 + grid))
    M5R1 = WITH WIDTH M5R1pre >= dmW_M5

    M5F2 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 OFFSET dmO_M5 INSIDE OF LAYER M5R1
    M5R2pre = M5R1 NOT (SIZE M5F2 BY (dmS_M5 + grid))
    M5R2 = WITH WIDTH M5R2pre >= dmW_M5

    M5F3 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 OFFSET dmO_M5 INSIDE OF LAYER M5R2
    M5R3pre = M5R2 NOT (SIZE M5F3 BY (dmS_M5 + grid))
    M5R3 = WITH WIDTH M5R3pre >= dmW_M5

    M5F4 = RECTANGLES dmW_M5 dmL_M5 dmS_M5 INSIDE OF LAYER M5R3

    M5F = (((M5F1 OR M5F2) OR M5F3) OR M5F4) OR M5FW
    FM5 = M5F NOT INTERACT (EXT M5F < dmS_M5 ABUT SINGULAR REGION)

    maxOPENM5 = DENSITY M5x FM5 > maxD_M5 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M5Max.den

    FM5F = FM5 OUTSIDE maxOPENM5

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M5 = DENSITY M5x FM5F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M5Min.den

    RM5EXC = SIZE FM5F BY (Odm2DM5 + grid)
    // do not fill DMz_S over CTMDMY
    D25M5pM = (((PUSH D25M5) NOT FRAME5) NOT RM5EXC) AND CHIP
    D25M5pM_1 = WITH WIDTH D25M5pM >= OdmW_M5

    RM5p1 = RECTANGLES OdmW_M5 OdmL_M5 OdmS_M5 INSIDE OF LAYER D25M5pM_1
    D25M5pM_2 = D25M5pM_1 NOT (SIZE RM5p1 BY (OdmS_M5 + grid))
    RM5p2 = RECTANGLES OdmL_M5 OdmW_M5 OdmS_M5 INSIDE OF LAYER D25M5pM_2

    RM5A = ((RM5p1 OR RM5p2) OUTSIDE RM5EXC) OUTSIDE FRAME5
    RM5  = RM5A NOT INTERACT (EXT RM5A < OdmS_M5 ABUT SINGULAR REGION)

    DM5F = FM5F OR RM5

    FRAME5_INDDMYA = SIZE M5i BY (dm5_s2m5_INDDMY + grid)
    FRAME5_INDDMYB = SIZE DUM5 BY (dm5_s_INDDMY + grid)
    FRAME5_INDDMYC = SIZE DM5F BY dm5_s_INDDMY
    FRAME5_INDDMY  = ((((FRAME5Pre OR BLOCK5) OR FRAME5_INDDMYA) OR FRAME5_INDDMYB) OR FRAME5_INDDMYC) OR NFILL
    FILL5_INDDMY   = ooINDDMY NOT FRAME5_INDDMY
    DM5F_INDDMY    = RECTANGLES dm5_w_INDDMY dm5_l_INDDMY dm5_s_INDDMY INSIDE OF LAYER FILL5_INDDMY

#IFDEF FILL_indDM5
    FILL5_INDDMY_HD = (SIZE INDDMY_HD BY -(dm5_s_INDDMY_HD + grid)) NOT FRAME5_INDDMY
    DM5F_INDDMY_HD  = RECTANGLES dm5_w_INDDMY_HD dm5_l_INDDMY_HD dm5_s_INDDMY_HD INSIDE OF LAYER FILL5_INDDMY_HD
#ENDIF	

#ELSE



    D30M5 = DENSITY M5x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M5.den30
    D40M5 = DENSITY M5x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M5.den40
    D50M5 = DENSITY M5x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M5.den50
    emptyM5 = DENSITY M5x < emptyD_M5 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M5.den_empty

    M5InnerHole = HOLES M5i INNER
#IFDEF FILL_M5_DTCD
    VARIABLE M5_DTCD2Chip      2.5  //
    VARIABLE M5_DTCD2LOGO      10   //
    VARIABLE M5_DTCD2MOMDMY    0    // 
    VARIABLE M5_DTCD2LOWMEDN   0    //
    VARIABLE M5_DTCD2POFUSE    0    //
    VARIABLE M5_DTCD2DM5EXCL   0    //
    VARIABLE M5_DTCD2DM5CB2   0    //
    VARIABLE M5_DTCD2M5        2.63  // CB2.S.2
    VARIABLE M5_DTCD2DM5       1.5  // DMx.S.2
    VARIABLE M5_DTCD2TCDDMY_M5 150  // for idu measurement
    VARIABLE M5_DTCD2CTMDMY_6 0.112  // MIM.VIAz.S.5
    VARIABLE M5_DTCD2ICOVL     8
	M5_DTCDxChip        = CHIP NOT (SIZE CHIP BY -(M5_DTCD2Chip + grid))
    M5_DTCDxLOGO        = SIZE LOGO               BY (M5_DTCD2LOGO      + grid)
    M5_DTCDxMOMDMY      = SIZE MOMDMY             BY (M5_DTCD2MOMDMY    + grid)
    M5_DTCDxLOWMEDN     = SIZE LOWMEDN            BY (M5_DTCD2LOWMEDN   + grid)
    M5_DTCDxPOFUSE      = SIZE (FUSELINK AND POi) BY (M5_DTCD2POFUSE    + grid)
    M5_DTCDxDM5EXCL     = SIZE DM5EXCL            BY (M5_DTCD2DM5EXCL   + grid)
    M5_DTCDxDM5CB2      = SIZE CB2i               BY (M5_DTCD2DM5CB2    + grid)
    M5_DTCDxM5          = SIZE M5i                BY (M5_DTCD2M5        + grid)
    M5_DTCDxDM5         = SIZE DUM5               BY (M5_DTCD2DM5       + grid)
    M5_DTCDxTCDDMY_M5   = SIZE TCDDMY_M5          BY (M5_DTCD2TCDDMY_M5 + grid)
    M5_DTCDxTCDDMY_FM5  = SIZE TCDDMY_FM5         BY (M5_DTCD2TCDDMY_M5 + grid)
    M5_DTCDxTCDDMY_FDM5 = SIZE TCDDMY_FDM5        BY (M5_DTCD2TCDDMY_M5 + grid)
    M5_DTCDxICOVL       = SIZE ICOVL              BY (M5_DTCD2ICOVL     + grid)
    M5_DTCDxCTMDMY_6   = SIZE CTMDMY_6          BY (M5_DTCD2CTMDMY_6  + grid)

    M5_DTCDx = (((((((((((((M5_DTCDxChip OR M5_DTCDxLOGO) OR M5_DTCDxLOWMEDN) OR M5_DTCDxPOFUSE) OR M5_DTCDxDM5EXCL) OR M5_DTCDxM5) OR M5_DTCDxDM5) OR M5_DTCDxTCDDMY_M5) OR M5_DTCDxTCDDMY_FM5) OR M5_DTCDxTCDDMY_FDM5) OR FRAME5INDDMY) OR M5_DTCDxMOMDMY) OR M5_DTCDxDM5CB2) OR M5_DTCDxCTMDMY_6) OR M5_DTCDxICOVL
    M5_DTCDo = CHIP NOT M5_DTCDx

    VARIABLE TCD_M5_W      4
    VARIABLE TCD_M5_L      4
    VARIABLE M5_DTCD_S     400
    VARIABLE M5_DTCD_MIN_S 150
    VARIABLE D2M5_DTCD     0.6

    M5_DTCD_pre = RECTANGLES TCD_M5_W TCD_M5_L M5_DTCD_S INSIDE OF LAYER M5_DTCDo
    TCD_M5 = M5_DTCD_pre NOT INTERACT (EXT M5_DTCD_pre < M5_DTCD_MIN_S ABUT SINGULAR REGION)

TCD_M5_165_95_1 = SHRINK TCD_M5 LEFT BY 0 BOTTOM BY 0 RIGHT BY (TCD_M5_W-4) TOP BY (TCD_M5_L-4)
TCD_M5_150_5_1 = SHRINK TCD_M5 LEFT BY 0 BOTTOM BY 0 RIGHT BY (TCD_M5_W-4) TOP BY (TCD_M5_L-4)
TCD_M5_35_0_1 = SHRINK TCD_M5 LEFT BY 2.075 BOTTOM BY 0.5 RIGHT BY (TCD_M5_W-2.125) TOP BY (TCD_M5_L-3.5)
TCD_M5_35_0_2 = SHRINK TCD_M5 LEFT BY 1.875 BOTTOM BY 0.5 RIGHT BY (TCD_M5_W-1.925) TOP BY (TCD_M5_L-3.5)
TCD_M5_35_0_3 = SHRINK TCD_M5 LEFT BY 1.425 BOTTOM BY 0.09 RIGHT BY (TCD_M5_W-2.575) TOP BY (TCD_M5_L-0.21)
