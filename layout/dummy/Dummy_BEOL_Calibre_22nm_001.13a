TCD_M5_150_5 = COPY TCD_M5_150_5_1
TCD_M5_165_95 = COPY TCD_M5_165_95_1
TCD_M5_35_0 = OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR TCD_M5_35_0_1 TCD_M5_35_0_2) TCD_M5_35_0_3) TCD_M5_35_0_4) TCD_M5_35_0_5) TCD_M5_35_0_6) TCD_M5_35_0_7) TCD_M5_35_0_8) TCD_M5_35_0_9) TCD_M5_35_0_10) TCD_M5_35_0_11) TCD_M5_35_0_12) TCD_M5_35_0_13) TCD_M5_35_0_14) TCD_M5_35_0_15) TCD_M5_35_0_16) TCD_M5_35_0_17) TCD_M5_35_0_18) TCD_M5_35_0_19) TCD_M5_35_0_20) TCD_M5_35_0_21) TCD_M5_35_0_22) TCD_M5_35_0_23) TCD_M5_35_0_24) TCD_M5_35_0_25) TCD_M5_35_0_26) TCD_M5_35_0_27) TCD_M5_35_0_28) TCD_M5_35_0_29) TCD_M5_35_0_30) TCD_M5_35_0_31) TCD_M5_35_0_32) TCD_M5_35_0_33) TCD_M5_35_0_34) TCD_M5_35_0_35) TCD_M5_35_0_36) TCD_M5_35_0_37) TCD_M5_35_0_38) TCD_M5_35_0_39) TCD_M5_35_0_40) TCD_M5_35_0_41) TCD_M5_35_0_42) TCD_M5_35_0_43) TCD_M5_35_0_44) TCD_M5_35_0_45) TCD_M5_35_0_46) TCD_M5_35_0_47) TCD_M5_35_0_48) TCD_M5_35_0_49) TCD_M5_35_0_50) TCD_M5_35_0_51) TCD_M5_35_0_52) TCD_M5_35_0_53) TCD_M5_35_0_54) TCD_M5_35_0_55) TCD_M5_35_0_56) TCD_M5_35_0_57

    xM5_DTCD = SIZE TCD_M5 BY D2M5_DTCD
#ELSE
    xM5_DTCD = COPY EMPTY
#ENDIF

    M5BigHole = SIZE M5InnerHole BY - excludeHoleSize/2
    M5ExcHole = ((M5InnerHole OUTSIDE M5BigHole) NOT M5i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK5 = (SIZE DM5EXCL BY (dm2DMEXCL + grid)) OR MIM5_x

    FRAMEA5 = (SIZE M5i BY (DM5_301 + grid)) OR (SIZE (EXPAND EDGE (M5i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA5OPC = SIZE M5i BY (DM5_OPC + grid)
    FRAMEA5OPCwide = SIZE (M5i WITH WIDTH > DM5_OPC_wide_w) BY (DM5_OPC_wide + grid)
    FRAMEA5OPC45 = SIZE (EXPAND EDGE (M5i ANGLE == 45) OUTSIDE BY DM5_OPC_45 EXTEND BY DM5_OPC_45_E) BY grid
    FRAMEA5OPC45DV = SIZE (EXPAND EDGE ((M5i INTERACT M5_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM5_OPC_45 EXTEND BY DM5_OPC_45_E) BY grid
    FRAMEA5OPC_M5_S_14_wide = SIZE (M5i WITH WIDTH > M5_S_14_wide_w) BY (M5_S_14_wide + grid)
    FRAMEA5OPC_M5_S_17_wide = SIZE (M5i WITH WIDTH > M5_S_17_wide_w) BY (M5_S_17_wide + grid)
    FRAMEA5OPC_M5_S_20_wide = SIZE (M5i WITH WIDTH > M5_S_20_wide_w) BY (M5_S_20_wide + grid)
    FRAMEA5OPC_M5_S_23_wide = SIZE (M5i WITH WIDTH > M5_S_23_wide_w) BY (M5_S_23_wide + grid)
    FRAMEA5OPC_M5_S_33_VIA4   = SIZE VIA4_HV_5V_CHK	BY (M5_S_33 + grid)
    FRAMEA5OPC_M5_S_33b_VIA4DV   = SIZE (VIA4i INTERACT (M4_HVN_330Vx OR M5_HVN_330Vx))	BY (M5_S_33b + grid)
    FRAMEA5OPC_M5_S_33_VIA5    = SIZE VIA5_HV_5V_CHK	BY (M5_S_33 + grid)
    FRAMEA5OPC_M5_S_33b_VIA5DV    = SIZE (VIA5i INTERACT (M5_HVN_330Vx OR M6_HVN_330Vx))	BY (M5_S_33b + grid)
    FRAMEA5OPC_M5_S_37_VIA4_b = SIZE VIA4i_55V		BY (M5_S_37 + grid)
    FRAMEA5OPC_M5_S_37a_VIA4_bDV = SIZE (VIA4i INTERACT (M4_HVN_500Vx OR M5_HVN_500Vx))		BY (M5_S_37a + grid)
    FRAMEA5OPC_M5_S_37_VIA5_b  = SIZE VIA5i_55V			BY (M5_S_37 + grid)
    FRAMEA5OPC_M5_S_37a_VIA5_bDV  = SIZE (VIA5i INTERACT (M5_HVN_500Vx OR M6_HVN_500Vx))		BY (M5_S_37a + grid)
    FRAMEA5OPC_M5_S_37_VIA4   = SIZE VIA4i_65V		BY (M5_S_37 + grid)
	FRAMEA5OPC_M5_S_37_VIA5    = SIZE VIA5i_65V			BY (M5_S_37 + grid)

    FRAMEHVD5 = SIZE  M5i_65V  BY (M5_S_38 + grid)
    FRAMEHVD5_55V = SIZE  M5i_55V  BY (M5_S_38 + grid)
    FRAMEHVD5_55VDV = SIZE  (M5i INTERACT M5_HVN_500Vx)  BY (M5_S_38a + grid)
    FRAMEB5 = SIZE (WITH WIDTH M5i > wideM5) BY (dm2WM5 + grid)
    FRAMEC5 = SIZE DUM5 BY (dm2DM5 + grid)
    FRAMED5 = SIZE (WITH WIDTH M5i > wideM5_small) BY (dm2WM5_small + grid)
    FRAMEC5OPC = SIZE DUM5 BY (Odm2DM5 + grid)
    FRAME5Pre = ((FRAMEA5 OR FRAMEB5) OR (FRAMEC5 OR FRAMED5)) OR M5ExcHole
    FRAME5PreOPC = (((((((((((((((((((((FRAMEA5OPC OR FRAMEC5OPC) OR M5ExcHole) OR FRAMEA5OPCwide) OR FRAMEA5OPC45) OR FRAMEA5OPC45DV) OR FRAMEA5OPC_M5_S_14_wide) OR FRAMEA5OPC_M5_S_17_wide) OR FRAMEA5OPC_M5_S_20_wide) OR FRAMEA5OPC_M5_S_23_wide) OR FRAMEA5OPC_M5_S_33_VIA4) OR FRAMEA5OPC_M5_S_33b_VIA4DV) OR FRAMEA5OPC_M5_S_33_VIA5) OR FRAMEA5OPC_M5_S_33b_VIA5DV) OR FRAMEHVD5) OR FRAMEA5OPC_M5_S_37_VIA4) OR FRAMEA5OPC_M5_S_37_VIA4_b) OR FRAMEA5OPC_M5_S_37a_VIA4_bDV) OR FRAMEA5OPC_M5_S_37_VIA5) OR FRAMEA5OPC_M5_S_37_VIA5_b) OR FRAMEA5OPC_M5_S_37a_VIA5_bDV) OR FRAMEHVD5_55V) OR FRAMEHVD5_55VDV


    FRAME5INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm5_s2m5_INDDMY + grid)
    FRAME5OPC = (((FRAME5PreOPC OR FRAME5INDDMY) OR xM5_DTCD) OR BLOCK5) OR NFILLOPC_x

    FRAME5 = (((FRAME5Pre OR FRAME5INDDMY) OR xM5_DTCD) OR BLOCK5) OR NFILL_x

    D30M5p = (PUSH D30M5) NOT FRAME5
    O30M5pre = D30M5p AND CHIP
    FD21M5s = COPY FRAME5

    O30M5preA = SIZE O30M5pre BY -DM5_303
    O30M5preB = O30M5preA WITH WIDTH >= WM5_303

    // 1st big
    F303M5 = RECTANGLES WM5_303 LM5_303 SM5_303 OFFSET OM5_303 INSIDE OF LAYER O30M5preB
    F303M5_SLOT = RECTANGLES WM5_303_SLOT LM5_303_SLOT SM5_303_SLOT INSIDE OF LAYER F303M5

    F303M5_EXP = SIZE F303M5_SLOT BY ( SM5_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M5preF1 = O30M5pre NOT (SIZE F303M5_EXP BY SM5_302)
    O30M5preF  = (SNAP (SIZE O30M5preF1 BY -grid) 5) AND O30M5preF1

    B30M5s = FD21M5s OR (SIZE F303M5_EXP BY (SM5_302+grid))
    O30M5 = O30M5preF NOT B30M5s

    // 3rd, middle
    F302M5 = RECTANGLES WM5_302 LM5_302 SM5_302 OFFSET OM5_302 INSIDE OF LAYER O30M5
    F302M5s = (SIZE F302M5 BY (SM5_301 + grid)) OR B30M5s
    R302M5pre = O30M5 NOT F302M5s
    R302M5 = WITH WIDTH R302M5pre >= WM5_301

    // 4th, small
    F3012M5 = RECTANGLES WM5_301 LM5_301 SM5_301 OFFSET OM5_301 INSIDE OF LAYER R302M5
    F3012M5s = (SIZE F3012M5 BY (SM5_301 + grid)) OR F302M5s
    R3012M5pre = R302M5pre NOT F3012M5s
    R3012M5 = WITH WIDTH R3012M5pre >= WM5_301

    // 5th, non-stagger small
    F301M5 = RECTANGLES WM5_301 LM5_301 SM5_301 INSIDE OF LAYER R3012M5 //MAINTAIN SPACING
    F301M5s = (SIZE F301M5 BY (SM5_301 + grid)) OR F3012M5s

    F30M5 = ((F302M5 OR F3012M5) OR F301M5) OR F303M5_SLOT
    O40M5pre = (((PUSH D40M5) NOT FRAME5) NOT F301M5s) AND CHIP


    O40M5preA = SIZE O40M5pre BY -DM5_403
    O40M5preB = O40M5preA WITH WIDTH >= WM5_403

    // 1st big
    F403M5 = RECTANGLES WM5_403 LM5_403 SM5_403 OFFSET OM5_403 INSIDE OF LAYER O40M5preB
    F403M5_SLOT = RECTANGLES WM5_403_SLOT LM5_403_SLOT SM5_403_SLOT INSIDE OF LAYER F403M5

    F403M5_EXP = SIZE F403M5_SLOT BY ( SM5_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M5preF1 = O40M5pre NOT (SIZE F403M5_EXP BY SM5_402)
    O40M5preF  = (SNAP (SIZE O40M5preF1 BY -grid) 5) AND O40M5preF1

    B40M5s = F301M5s OR (SIZE F403M5_EXP BY (SM5_402+grid))
    O40M5 = O40M5preF NOT B40M5s

    // 3rd, middle
    F402M5 = RECTANGLES WM5_402 LM5_402 SM5_402 OFFSET OM5_402 INSIDE OF LAYER O40M5
    F402M5s = (SIZE F402M5 BY (SM5_401 + grid)) OR B40M5s
    R402M5pre = O40M5 NOT F402M5s
    R402M5 = WITH WIDTH R402M5pre >= WM5_401

    // 4th, small
    F4012M5 = RECTANGLES WM5_401 LM5_401 SM5_401 OFFSET OM5_401 INSIDE OF LAYER R402M5
    F4012M5s = (SIZE F4012M5 BY (SM5_401 + grid)) OR F402M5s
    R4012M5pre = R402M5pre NOT F4012M5s
    R4012M5 = WITH WIDTH R4012M5pre >= WM5_401

    // 5th, non-stagger small
    F401M5 = RECTANGLES WM5_401 LM5_401 SM5_401 INSIDE OF LAYER R4012M5 //MAINTAIN SPACING
    F401M5s = (SIZE F401M5 BY (SM5_401 + grid)) OR F4012M5s

    F40M5 = ((F402M5 OR F4012M5) OR F401M5) OR F403M5_SLOT
    O50M5pre = (((PUSH (D50M5 OR emptyM5)) NOT FRAME5) NOT F401M5s) AND CHIP


    O50M5preA = SIZE O50M5pre BY -DM5_503
    O50M5preB = O50M5preA WITH WIDTH >= WM5_503

    // 1st big
    F503M5 = RECTANGLES WM5_503 LM5_503 SM5_503 OFFSET OM5_503 INSIDE OF LAYER O50M5preB
    F503M5_SLOT = RECTANGLES WM5_503_SLOT LM5_503_SLOT SM5_503_SLOT INSIDE OF LAYER F503M5

    F503M5_EXP = SIZE F503M5_SLOT BY ( SM5_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M5preF1 = O50M5pre NOT (SIZE F503M5_EXP BY SM5_502)
    O50M5preF  = (SNAP (SIZE O50M5preF1 BY -grid) 5) AND O50M5preF1

    B50M5s = F401M5s OR (SIZE F503M5_EXP BY (SM5_502+grid))
    O50M5 = O50M5preF NOT B50M5s

    // 3rd, middle
    F502M5 = RECTANGLES WM5_502 LM5_502 SM5_502 OFFSET OM5_502 INSIDE OF LAYER O50M5
    F502M5s = (SIZE F502M5 BY (SM5_501 + grid)) OR B50M5s
    R502M5pre = O50M5 NOT F502M5s
    R502M5 = WITH WIDTH R502M5pre >= WM5_501

    // 4th, small
    F5012M5 = RECTANGLES WM5_501 LM5_501 SM5_501 OFFSET OM5_501 INSIDE OF LAYER R502M5
    F5012M5s = (SIZE F5012M5 BY (SM5_501 + grid)) OR F502M5s
    R5012M5pre = R502M5pre NOT F5012M5s
    R5012M5 = WITH WIDTH R5012M5pre >= WM5_501

    // 5th, non-stagger small
    F501M5 = RECTANGLES WM5_501 LM5_501 SM5_501 INSIDE OF LAYER R5012M5 //MAINTAIN SPACING
    F501M5s = (SIZE F501M5 BY (SM5_501 + grid)) OR F5012M5s

    F50M5 = ((F502M5 OR F5012M5) OR F501M5) OR F503M5_SLOT

    exceedM5 = DENSITY M5x F30M5 F40M5 F50M5 > maxD_M5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M5.den_exceed

    removeM5R = ((PUSH (exceedM5 AND (D50M5 OR emptyM5))) NOT FRAME5) AND CHIP
    removeM5P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM5R

    F30M5x = F30M5 NOT INTERACT removeM5P
    F40M5x = F40M5 NOT INTERACT removeM5P
    F50M5x = F50M5 NOT INTERACT removeM5P
    FM5xA  = (F30M5x OR F40M5x) OR F50M5x
    FM5x   = FM5xA NOT INTERACT (EXT FM5xA < DM5_S_1 ABUT SINGULAR REGION)

    ALLM5x = M5x OR FM5x
    lackM5 = DENSITY ALLM5x CHIP < DM5_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M5.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM5x)/AREA(CHIP) ]

    WDM5EXC = DUM5 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM5EXC = (SIZE FM5x BY Odm2DM5) OR (SIZE (((F303M5_EXP OR F403M5_EXP) OR F503M5_EXP) OR WDM5EXC) BY 1.5)

    lackM5pRM = ((((PUSH lackM5) NOT RM5EXC) NOT FRAME5OPC) NOT exceedM5) AND CHIP
    lackM5pRM_1 = WITH WIDTH lackM5pRM >= SM5_OPC

    RM5p1 = RECTANGLES WM5_OPC LM5_OPC WSM5_OPC LSM5_OPC INSIDE OF LAYER lackM5pRM_1
    lackM5pRM_2 = lackM5pRM_1 NOT (SIZE RM5p1 BY SM5_OPC)
    RM5p2 = RECTANGLES LM5_OPC WM5_OPC LSM5_OPC WSM5_OPC INSIDE OF LAYER lackM5pRM_2

    ODM5A = ((RM5p1 OR RM5p2) OUTSIDE RM5EXC) OUTSIDE FRAME5OPC
    ODM5F_pre = ODM5A NOT INTERACT (EXT ODM5A < SM5_OPC ABUT SINGULAR REGION)

// M5.S.14 ~ M5.S.16
M5_S_14_CHK_REGION = M5i OR ODM5F_pre
// Find Wide Metal
Wide_M5_S_14_CHK_REGION = ENCLOSE RECTANGLE (M5_S_14_CHK_REGION NOT WITH WIDTH <= M5_S_14_W1B) M5_S_14_W1B+GRID M5_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M5_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M5_S_14_CHK_REGION == 0
Wide_M5_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M5_S_14_CHK_REGION == 90

// Find Wide Metal Space
M5_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M5_S_14_CHK_REGION_EDGE_H M5_S_14_CHK_REGION < M5_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M5_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M5_S_14_CHK_REGION_EDGE_V M5_S_14_CHK_REGION < M5_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M5_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M5_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M5_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M5_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M5_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M5_S_14_CHK_REGION_OPC_REGION_pre1_H M5_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M5_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M5_S_14_L1B
M5_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M5_S_14_CHK_REGION_OPC_REGION_pre1_V M5_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M5_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M5_S_14_L1B

M5_S_14_OPC_REGION = M5_S_14_CHK_REGION_OPC_REGION_pre2_H OR M5_S_14_CHK_REGION_OPC_REGION_pre2_V

// M5.S.17 ~ M5.S.19
M5_S_17_CHK_REGION = M5i OR ODM5F_pre
// Find Wide Metal
Wide_M5_S_17_CHK_REGION = ENCLOSE RECTANGLE (M5_S_17_CHK_REGION NOT WITH WIDTH <= M5_S_17_W1B) M5_S_17_W1B+GRID M5_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M5_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M5_S_17_CHK_REGION == 0
Wide_M5_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M5_S_17_CHK_REGION == 90

// Find Wide Metal Space
M5_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M5_S_17_CHK_REGION_EDGE_H M5_S_17_CHK_REGION < M5_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M5_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M5_S_17_CHK_REGION_EDGE_V M5_S_17_CHK_REGION < M5_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M5_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M5_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M5_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M5_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M5_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M5_S_17_CHK_REGION_OPC_REGION_pre1_H M5_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M5_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M5_S_17_L1B
M5_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M5_S_17_CHK_REGION_OPC_REGION_pre1_V M5_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M5_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M5_S_17_L1B

M5_S_17_OPC_REGION = M5_S_17_CHK_REGION_OPC_REGION_pre2_H OR M5_S_17_CHK_REGION_OPC_REGION_pre2_V

// M5.S.20 ~ M5.S.22
M5_S_20_CHK_REGION = M5i OR ODM5F_pre
// Find Wide Metal
Wide_M5_S_20_CHK_REGION = ENCLOSE RECTANGLE (M5_S_20_CHK_REGION NOT WITH WIDTH <= M5_S_20_W1B) M5_S_20_W1B+GRID M5_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M5_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M5_S_20_CHK_REGION == 0
Wide_M5_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M5_S_20_CHK_REGION == 90

// Find Wide Metal Space
M5_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M5_S_20_CHK_REGION_EDGE_H M5_S_20_CHK_REGION < M5_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M5_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M5_S_20_CHK_REGION_EDGE_V M5_S_20_CHK_REGION < M5_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M5_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M5_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M5_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M5_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M5_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M5_S_20_CHK_REGION_OPC_REGION_pre1_H M5_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M5_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M5_S_20_L1B
M5_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M5_S_20_CHK_REGION_OPC_REGION_pre1_V M5_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M5_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M5_S_20_L1B

M5_S_20_OPC_REGION = M5_S_20_CHK_REGION_OPC_REGION_pre2_H OR M5_S_20_CHK_REGION_OPC_REGION_pre2_V

// M5.S.23 ~ M5.S.25
M5_S_23_CHK_REGION = M5i OR ODM5F_pre
// Find Wide Metal
Wide_M5_S_23_CHK_REGION = ENCLOSE RECTANGLE (M5_S_23_CHK_REGION NOT WITH WIDTH <= M5_S_23_W1B) M5_S_23_W1B+GRID M5_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M5_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M5_S_23_CHK_REGION == 0
Wide_M5_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M5_S_23_CHK_REGION == 90

// Find Wide Metal Space
M5_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M5_S_23_CHK_REGION_EDGE_H M5_S_23_CHK_REGION < M5_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M5_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M5_S_23_CHK_REGION_EDGE_V M5_S_23_CHK_REGION < M5_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M5_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M5_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M5_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M5_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M5_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M5_S_23_CHK_REGION_OPC_REGION_pre1_H M5_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M5_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M5_S_23_L1B
M5_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M5_S_23_CHK_REGION_OPC_REGION_pre1_V M5_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M5_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M5_S_23_L1B

M5_S_23_OPC_REGION = M5_S_23_CHK_REGION_OPC_REGION_pre2_H OR M5_S_23_CHK_REGION_OPC_REGION_pre2_V

// M5.S.27
M5_S_27_CHK_REGION = M5i OR ODM5F_pre
// Find Wide Metal
Wide_M5_S_27_CHK_REGION = ENCLOSE RECTANGLE (M5_S_27_CHK_REGION NOT WITH WIDTH <= M5_S_27_W1B) M5_S_27_W1B+GRID M5_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M5_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M5_S_27_CHK_REGION == 0
Wide_M5_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M5_S_27_CHK_REGION == 90

// Find Wide Metal Space
M5_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M5_S_27_CHK_REGION_EDGE_H M5_S_27_CHK_REGION < M5_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M5_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M5_S_27_CHK_REGION_EDGE_V M5_S_27_CHK_REGION < M5_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M5_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M5_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M5_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M5_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M5_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M5_S_27_CHK_REGION_OPC_REGION_pre1_H M5_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M5_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M5_S_27_L1B
M5_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M5_S_27_CHK_REGION_OPC_REGION_pre1_V M5_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M5_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M5_S_27_L1B

M5_S_27_OPC_REGION = M5_S_27_CHK_REGION_OPC_REGION_pre2_H OR M5_S_27_CHK_REGION_OPC_REGION_pre2_V

M5_WMJ_OPC_REGION = (((M5_S_14_OPC_REGION OR M5_S_17_OPC_REGION) OR M5_S_20_OPC_REGION) OR M5_S_23_OPC_REGION) OR M5_S_27_OPC_REGION

    ODM5F = ODM5F_pre NOT INTERACT M5_WMJ_OPC_REGION

    DM5F = COPY FM5x

    FRAME5_INDDMYA = SIZE M5i BY (dm5_s2m5_INDDMY + grid)
    FRAME5_INDDMYB = SIZE DUM5 BY (dm5_s_INDDMY + grid)
    FRAME5_INDDMYC = SIZE DM5F BY dm5_s_INDDMY
    FRAME5_INDDMYD = SIZE ODM5F BY dm5_s2m5_INDDMY

    FRAME5_INDDMY  = ((((((FRAME5Pre OR xM5_DTCD) OR BLOCK5) OR FRAME5_INDDMYA) OR FRAME5_INDDMYB) OR FRAME5_INDDMYC) OR FRAME5_INDDMYD) OR NFILL_x
    FILL5_INDDMY   = ooINDDMY NOT FRAME5_INDDMY
    DM5F_INDDMY    = RECTANGLES dm5_w_INDDMY dm5_l_INDDMY dm5_s_INDDMY INSIDE OF LAYER FILL5_INDDMY

#IFDEF FILL_indDM5
    FILL5_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm5_s_INDDMY_HD + grid)) NOT FRAME5_INDDMY
    DM5F_INDDMY_HD_pre  = RECTANGLES dm5_w_INDDMY_HD dm5_l_INDDMY_HD dm5_s_INDDMY_HD INSIDE OF LAYER FILL5_INDDMY_HD

    FILL5_INDDMY_MD = (SIZE INDDMY_MD BY -(dm5_s_INDDMY_MD + grid)) NOT (FRAME5_INDDMY OR INDDMY_HD)
    DM5F_INDDMY_MD  = RECTANGLES dm5_w_INDDMY_MD dm5_l_INDDMY_MD dm5_s_INDDMY_MD INSIDE OF LAYER FILL5_INDDMY_MD

    DM5F_INDDMY_HD = DM5F_INDDMY_HD_pre OR DM5F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#IFDEF FILL_DM6


#IFDEF 34K_THICK_Mu_M6

    minOPENM6 = DENSITY M6x < minD_M6 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M6Min.den
    emptyOPENM6 = DENSITY M6x < emptyD_M6 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M6Empty.den

    M6InnerHole = HOLES M6i INNER

    M6BigHole = SIZE M6InnerHole BY - excludeHoleSize/2
    M6ExcHole = ((M6InnerHole OUTSIDE M6BigHole) NOT M6i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK6    = (SIZE DM6EXCL BY (dm2DMEXCL + grid)) OR MIM6_x
    FRAMEA6   = SIZE M6i BY (dm2M6 + grid) // DM6 to metal
    FRAMEB6   = SIZE (WITH WIDTH M6i > wideM6) BY (dm2WM6 + grid)
    FRAMEC6   = SIZE DUM6 BY (dm2DM6 + grid)
    FRAME6Pre = ((FRAMEA6 OR FRAMEB6) OR FRAMEC6) OR M6ExcHole
    FRAME6INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm6_s2m6_INDDMY + grid)
    FRAME6 = ((FRAME6Pre OR FRAME6INDDMY) OR BLOCK6) OR NFILL
    
    OPENM6 = PUSH ((minOPENM6 OR emptyOPENM6) AND CHIP)
    FILL6 = OPENM6 NOT FRAME6
    FILLW6pre = SIZE FILL6 BY - (Wdm2M6 + grid)
    FILLW6 = WITH WIDTH FILLW6pre >= WdmW_M6
    M6FW = RECTANGLES WdmW_M6 WdmL_M6 WdmS_M6 OFFSET WdmO_M6 INSIDE OF LAYER FILLW6
    M6FW_EXP = SIZE M6FW BY (WdmS_M6 /2 + grid) OVERUNDER   // merge the gaps
    FILLM6pre = FILL6 NOT (SIZE M6FW_EXP BY (MdmS_M6 + grid))
    FILLM6 = WITH WIDTH FILLM6pre >= MdmW_M6
    M6F1 = RECTANGLES MdmW_M6 MdmL_M6 MdmS_M6 OFFSET MdmO_M6 INSIDE OF LAYER FILLM6
    M6R1pre = FILLM6pre NOT (SIZE M6F1 BY (dmS_M6 + grid))
    M6R1 = WITH WIDTH M6R1pre >= dmW_M6

    M6F2 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 OFFSET dmO_M6 INSIDE OF LAYER M6R1
    M6R2pre = M6R1 NOT (SIZE M6F2 BY (dmS_M6 + grid))
    M6R2 = WITH WIDTH M6R2pre >= dmW_M6

    M6F3 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 OFFSET dmO_M6 INSIDE OF LAYER M6R2
    M6R3pre = M6R2 NOT (SIZE M6F3 BY (dmS_M6 + grid))
    M6R3 = WITH WIDTH M6R3pre >= dmW_M6

    M6F4 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 INSIDE OF LAYER M6R3

    M6F = (((M6F1 OR M6F2) OR M6F3) OR M6F4) OR M6FW
    FM6 = M6F NOT INTERACT (EXT M6F < dmS_M6 ABUT SINGULAR REGION)

    maxOPENM6 = DENSITY M6x FM6 > maxD_M6 WINDOW WindowSizeu*2 STEP WindowStepu*2
                INSIDE OF LAYER bulk BACKUP // PRINT M6Max.den

    DM6F = FM6 OUTSIDE maxOPENM6

    FRAME6_INDDMYA = SIZE M6i BY (dm6_s2m6_INDDMY + grid)
    FRAME6_INDDMYB = SIZE DUM6 BY (dm6_s_INDDMY + grid)
    FRAME6_INDDMYC = SIZE DM6F BY dm6_s_INDDMY
    FRAME6_INDDMY  = ((((FRAME6Pre OR BLOCK6) OR FRAME6_INDDMYA) OR FRAME6_INDDMYB) OR FRAME6_INDDMYC) OR NFILL
    FILL6_INDDMY   = ooINDDMY NOT FRAME6_INDDMY
    DM6F_INDDMY    = RECTANGLES dm6_w_INDDMY dm6_l_INDDMY dm6_s_INDDMY INSIDE OF LAYER FILL6_INDDMY
#IFDEF FILL_indDM6
    FILL6_INDDMY_HD = (SIZE INDDMY_HD BY -(dm6_s_INDDMY_HD + grid)) NOT FRAME6_INDDMY
    DM6F_INDDMY_HD  = RECTANGLES dm6_w_INDDMY_HD dm6_l_INDDMY_HD dm6_s_INDDMY_HD INSIDE OF LAYER FILL6_INDDMY_HD
#ENDIF	
	
#ELSE


#IFDEF 12K_THICK_Mr_M6

    minOPENM6 = DENSITY M6x < minD_M6 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M6Min.den
    emptyOPENM6 = DENSITY M6x < emptyD_M6 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M6Empty.den

    M6InnerHole = HOLES M6i INNER

    M6BigHole = SIZE M6InnerHole BY - excludeHoleSize/2
    M6ExcHole = ((M6InnerHole OUTSIDE M6BigHole) NOT M6i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK6  = (SIZE DM6EXCL BY (dm2DMEXCL + grid)) OR MIM6_x // DM6 to DM6EXCL
    FRAMEA6 = SIZE M6i BY (dm2M6 + grid) // DM6 to metal
    FRAMEB6 = SIZE (WITH WIDTH M6i > wideM6) BY (dm2WM6 + grid)
    FRAMEC6 = SIZE DUM6 BY (dm2DM6 + grid)   // DM6 to existed dummy metal 0.6um
    FRAME6Pre = ((FRAMEA6 OR FRAMEB6) OR FRAMEC6) OR M6ExcHole
    FRAME6INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm6_s2m6_INDDMY + grid)
    FRAME6 = ((FRAME6Pre OR FRAME6INDDMY) OR BLOCK6) OR NFILL
    
    OPENM6 = PUSH ((minOPENM6 OR emptyOPENM6) AND CHIP)
    FILL6 = OPENM6 NOT FRAME6
    FILLW6pre = SIZE FILL6 BY - (Wdm2M6 + grid)
    FILLW6 = WITH WIDTH FILLW6pre >= WdmW_M6
    M6FW = RECTANGLES WdmW_M6 WdmL_M6 WdmS_M6 OFFSET WdmO_M6 INSIDE OF LAYER FILLW6
    M6FW_EXP = SIZE M6FW BY (WdmS_M6 /2 + grid) OVERUNDER //merge the gaps
    FILLM6pre = FILL6 NOT (SIZE M6FW_EXP BY (MdmS_M6 + grid))
    FILLM6 = WITH WIDTH FILLM6pre >= MdmW_M6
    M6F1 = RECTANGLES MdmW_M6 MdmL_M6 MdmS_M6 OFFSET MdmO_M6 INSIDE OF LAYER FILLM6
    M6R1pre = FILLM6pre NOT (SIZE M6F1 BY (dmS_M6 + grid))
    M6R1 = WITH WIDTH M6R1pre >= dmW_M6

    M6F2 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 OFFSET dmO_M6 INSIDE OF LAYER M6R1
    M6R2pre = M6R1 NOT (SIZE M6F2 BY (dmS_M6 + grid))
    M6R2 = WITH WIDTH M6R2pre >= dmW_M6

    M6F3 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 OFFSET dmO_M6 INSIDE OF LAYER M6R2
    M6R3pre = M6R2 NOT (SIZE M6F3 BY (dmS_M6 + grid))
    M6R3 = WITH WIDTH M6R3pre >= dmW_M6

    M6F4 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 INSIDE OF LAYER M6R3

    M6F = (((M6F1 OR M6F2) OR M6F3) OR M6F4) OR M6FW
    FM6 = M6F NOT INTERACT (EXT M6F < dmS_M6 ABUT SINGULAR REGION)

    maxOPENM6 = DENSITY M6x FM6 > maxD_M6 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M6Max.den

    FM6F = FM6 OUTSIDE maxOPENM6

    // DMr_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M6 = DENSITY M6x FM6F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M6Min.den

    RM6EXC = SIZE FM6F BY (Odm2DM6 + grid)
    // do not fill DMy_S over CTMDMY
    D25M6pM = (((PUSH D25M6) NOT FRAME6) NOT RM6EXC) AND CHIP
    D25M6pM_1 = WITH WIDTH D25M6pM >= OdmW_M6

    RM6p1 = RECTANGLES OdmW_M6 OdmL_M6 OdmS_M6 INSIDE OF LAYER D25M6pM_1
    D25M6pM_2 = D25M6pM_1 NOT (SIZE RM6p1 BY (OdmS_M6 + grid))
    RM6p2 = RECTANGLES OdmL_M6 OdmW_M6 OdmS_M6 INSIDE OF LAYER D25M6pM_2

    RM6A = ((RM6p1 OR RM6p2) OUTSIDE RM6EXC) OUTSIDE FRAME6
    RM6  = RM6A NOT INTERACT (EXT RM6A < OdmS_M6 ABUT SINGULAR REGION)

    DM6F = FM6F OR RM6

    FRAME6_INDDMYA = SIZE M6i BY (dm6_s2m6_INDDMY + grid)
    FRAME6_INDDMYB = SIZE DUM6 BY (dm6_s_INDDMY + grid)
    FRAME6_INDDMYC = SIZE DM6F BY dm6_s_INDDMY
    FRAME6_INDDMY  = ((((FRAME6Pre OR BLOCK6) OR FRAME6_INDDMYA) OR FRAME6_INDDMYB) OR FRAME6_INDDMYC) OR NFILL
    FILL6_INDDMY   = ooINDDMY NOT FRAME6_INDDMY
    DM6F_INDDMY    = RECTANGLES dm6_w_INDDMY dm6_l_INDDMY dm6_s_INDDMY INSIDE OF LAYER FILL6_INDDMY

#IFDEF FILL_indDM6
    FILL6_INDDMY_HD = (SIZE INDDMY_HD BY -(dm6_s_INDDMY_HD + grid)) NOT FRAME6_INDDMY
    DM6F_INDDMY_HD  = RECTANGLES dm6_w_INDDMY_HD dm6_l_INDDMY_HD dm6_s_INDDMY_HD INSIDE OF LAYER FILL6_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 5K_THICK_Myz_M6

    minOPENM6 = DENSITY M6x < minD_M6 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M6Min.den
    emptyOPENM6 = DENSITY M6x < emptyD_M6 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M6Empty.den

    M6InnerHole = HOLES M6i INNER

    M6BigHole = SIZE M6InnerHole BY - excludeHoleSize/2
    M6ExcHole = ((M6InnerHole OUTSIDE M6BigHole) NOT M6i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK6 = (SIZE DM6EXCL BY (dm2DMEXCL + grid)) OR MIM6_x // DM6 to DM6EXCL
    FRAMEA6 = SIZE M6i BY (dm2M6 + grid) // DM6 to metal
    FRAMEB6 = SIZE (WITH WIDTH M6i > wideM6) BY (dm2WM6 + grid)
    FRAMEC6 = SIZE DUM6 BY (dm2DM6 + grid)   // DM6 to existed dummy metal 0.6um
    FRAME6Pre = ((FRAMEA6 OR FRAMEB6) OR FRAMEC6) OR M6ExcHole
    FRAME6INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm6_s2m6_INDDMY + grid)
    FRAME6 = ((FRAME6Pre OR FRAME6INDDMY) OR BLOCK6) OR NFILL
    
    OPENM6 = PUSH ((minOPENM6 OR emptyOPENM6) AND CHIP)
    FILL6 = OPENM6 NOT FRAME6
    FILLW6pre = SIZE FILL6 BY - (Wdm2M6 + grid)
    FILLW6 = WITH WIDTH FILLW6pre >= WdmW_M6
    M6FW = RECTANGLES WdmW_M6 WdmL_M6 WdmS_M6 OFFSET WdmO_M6 INSIDE OF LAYER FILLW6
    M6FW_EXP = SIZE M6FW BY (WdmS_M6 /2 + grid) OVERUNDER //merge the gaps
    FILLM6pre = FILL6 NOT (SIZE M6FW_EXP BY (MdmS_M6 + grid))
    FILLM6 = WITH WIDTH FILLM6pre >= MdmW_M6
    M6F1 = RECTANGLES MdmW_M6 MdmL_M6 MdmS_M6 OFFSET MdmO_M6 INSIDE OF LAYER FILLM6
    M6R1pre = FILLM6pre NOT (SIZE M6F1 BY (dmS_M6 + grid))
    M6R1 = WITH WIDTH M6R1pre >= dmW_M6

    M6F2 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 OFFSET dmO_M6 INSIDE OF LAYER M6R1
    M6R2pre = M6R1 NOT (SIZE M6F2 BY (dmS_M6 + grid))
    M6R2 = WITH WIDTH M6R2pre >= dmW_M6

    M6F3 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 OFFSET dmO_M6 INSIDE OF LAYER M6R2
    M6R3pre = M6R2 NOT (SIZE M6F3 BY (dmS_M6 + grid))
    M6R3 = WITH WIDTH M6R3pre >= dmW_M6

    M6F4 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 INSIDE OF LAYER M6R3

    M6F = (((M6F1 OR M6F2) OR M6F3) OR M6F4) OR M6FW
    FM6 = M6F NOT INTERACT (EXT M6F < dmS_M6 ABUT SINGULAR REGION)

    maxOPENM6 = DENSITY M6x FM6 > maxD_M6 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M6Max.den

    FM6F = FM6 OUTSIDE maxOPENM6

    // DMy_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M6 = DENSITY M6x FM6F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M6Min.den

    RM6EXC = SIZE FM6F BY (Odm2DM6 + grid)
    // do not fill DMy_S over CTMDMY
    D25M6pM = (((PUSH D25M6) NOT FRAME6) NOT RM6EXC) AND CHIP
    D25M6pM_1 = WITH WIDTH D25M6pM >= OdmW_M6

    RM6p1 = RECTANGLES OdmW_M6 OdmL_M6 OdmS_M6 INSIDE OF LAYER D25M6pM_1
    D25M6pM_2 = D25M6pM_1 NOT (SIZE RM6p1 BY (OdmS_M6 + grid))
    RM6p2 = RECTANGLES OdmL_M6 OdmW_M6 OdmS_M6 INSIDE OF LAYER D25M6pM_2

    RM6A = ((RM6p1 OR RM6p2) OUTSIDE RM6EXC) OUTSIDE FRAME6
    RM6  = RM6A NOT INTERACT (EXT RM6A < OdmS_M6 ABUT SINGULAR REGION)

    DM6F = FM6F OR RM6

    FRAME6_INDDMYA = SIZE M6i BY (dm6_s2m6_INDDMY + grid)
    FRAME6_INDDMYB = SIZE DUM6 BY (dm6_s_INDDMY + grid)
    FRAME6_INDDMYC = SIZE DM6F BY dm6_s_INDDMY
    FRAME6_INDDMY  = ((((FRAME6Pre OR BLOCK6) OR FRAME6_INDDMYA) OR FRAME6_INDDMYB) OR FRAME6_INDDMYC) OR NFILL
    FILL6_INDDMY   = ooINDDMY NOT FRAME6_INDDMY
    DM6F_INDDMY    = RECTANGLES dm6_w_INDDMY dm6_l_INDDMY dm6_s_INDDMY INSIDE OF LAYER FILL6_INDDMY


