    FRAME4PreOPC = (((((((((((((((((((((FRAMEA4OPC OR FRAMEC4OPC) OR M4ExcHole) OR FRAMEA4OPCwide) OR FRAMEA4OPC45) OR FRAMEA4OPC45DV) OR FRAMEA4OPC_M4_S_14_wide) OR FRAMEA4OPC_M4_S_17_wide) OR FRAMEA4OPC_M4_S_20_wide) OR FRAMEA4OPC_M4_S_23_wide) OR FRAMEA4OPC_M4_S_33_VIA3) OR FRAMEA4OPC_M4_S_33b_VIA3DV) OR FRAMEA4OPC_M4_S_33_VIA4) OR FRAMEA4OPC_M4_S_33b_VIA4DV) OR FRAMEHVD4) OR FRAMEA4OPC_M4_S_37_VIA3) OR FRAMEA4OPC_M4_S_37_VIA3_b) OR FRAMEA4OPC_M4_S_37a_VIA3_bDV) OR FRAMEA4OPC_M4_S_37_VIA4) OR FRAMEA4OPC_M4_S_37_VIA4_b) OR FRAMEA4OPC_M4_S_37a_VIA4_bDV) OR FRAMEHVD4_55V) OR FRAMEHVD4_55VDV


