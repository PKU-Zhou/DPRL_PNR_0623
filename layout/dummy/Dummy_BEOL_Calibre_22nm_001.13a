DM12F_FOR_DVIA11F_REGION_4parts = (DM12_F_4_REGION_DVIA11_spec_B OR DM12_F_4_REGION_DVIA11_spec_M) OR (DM12_F_4_REGION_DVIA11_spec_S OR DM12_F_4_REGION_DVIA11_square)
DM12F_FOR_DVIA11F_REGION_remainder_pre_not = (DM12_F_4_REGION_DVIA11_spec_B_pre OR DM12_F_4_REGION_DVIA11_spec_M_pre) OR (DM12_F_4_REGION_DVIA11_spec_S_pre OR DM12_F_4_REGION_DVIA11_square_pre)
DM12F_FOR_DVIA11F_REGION_remainder = DM12F_FOR_DVIA11F_REGION NOT DM12F_FOR_DVIA11F_REGION_remainder_pre_not

    DM12F_FOR_DVIA11F_REGION_remainder_EDGE = LENGTH DM12F_FOR_DVIA11F_REGION_remainder > 0
    DM12F_FOR_DVIA11F_REGION_remainder_PROP = DFM PROPERTY DM12F_FOR_DVIA11F_REGION_remainder DM12F_FOR_DVIA11F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM12F_FOR_DVIA11F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM12F_FOR_DVIA11F_REGION_remainder_EDGE)) ]
    DM12F_FOR_DVIA11F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM12F_FOR_DVIA11F_REGION_remainder_EDGE DM12F_FOR_DVIA11F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM12F_FOR_DVIA11F_REGION_remainder_EDGE) - PROPERTY(DM12F_FOR_DVIA11F_REGION_remainder_PROP, DM12F_FOR_DVIA11F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM12F_FOR_DVIA11F_REGION2 = DM12F_FOR_DVIA11F_REGION_remainder NOT (EXPAND EDGE DM12F_FOR_DVIA11F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM12_F_4_REGION_DVIA11_SHORTENED_LENGTH)

DVIA11F_BASE_REGION = (((((SIZE (DM11F_FOR_DVIA11F_REGION2 OR DM11F_FOR_DVIA11F_REGION_4parts) BY -DVIA11_EN_1) AND (SIZE (DM12F_FOR_DVIA11F_REGION2 OR DM12F_FOR_DVIA11F_REGION_4parts) BY -DM12_EN_2)) WITH WIDTH >= DVIA11_W_1) NOT (SIZE DVIA11EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA11i BY (DVIA11_S_1 + grid))) NOT (SIZE VIA11i BY (DVIA11_S_2 + grid))




// Merge DVIA11 fillable regions, and find DVIA11 seeds by maintaining spacing DVIA11_S_1.
DVIA11F_SEED_REGION_1 = (((SIZE DVIA11F_BASE_REGION BY DVIA11F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA11EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA11i BY (DVIA11_S_1 + grid))) NOT (SIZE VIA11i BY (DVIA11_S_2 + grid))
DVIA11F_SEED_1 = RECTANGLES DVIA11_W_1 DVIA11_W_1 DVIA11_S_1 INSIDE OF LAYER DVIA11F_SEED_REGION_1

// Find DVIA11 in the DVIA11 fillable and spacing-maintained regions.
DVIA11F_REGION_1 = (DVIA11F_BASE_REGION INTERACT DVIA11F_SEED_1) NOT TOUCH DVIA11F_SEED_1
DVIA11F_pre1_1_pre1 = RECTANGLES DVIA11_W_1 DVIA11_W_1 DVIA11_S_1 INSIDE OF LAYER DVIA11F_REGION_1

// post-DRC
DVIA11F_pre1_1_pre2 = DVIA11F_pre1_1_pre1 NOT INTERACT (EXT DVIA11F_pre1_1_pre1 < DVIA11_S_1 ABUT SINGULAR REGION)
DVIA11F_pre1_1_pre3 = DVIA11F_pre1_1_pre2 NOT INTERACT (EXT DVIA11F_pre1_1_pre2 DUVIA11i < DVIA11_S_1 ABUT SINGULAR REGION)
DVIA11F_pre1_1_pre4 = DVIA11F_pre1_1_pre3 NOT INTERACT (EXT DVIA11F_pre1_1_pre3 VIA11i < DVIA11_S_2 ABUT SINGULAR REGION)
DVIA11F_pre1_1_pre5 = DVIA11F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA11F_pre1_1_pre4 DM11F_FOR_DVIA11F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA11_EN_2 OPPOSITE 0 DVIA11_EN_2 OPPOSITE)
DVIA11F_pre1_1      = DVIA11F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA11F_pre1_1_pre5 DM12F_FOR_DVIA11F_REGION ABUT < 90 SINGULAR GOOD 0 DM12_EN_3 OPPOSITE 0 DM12_EN_3 OPPOSITE)

// Merge DVIA11 fillable regions, and find DVIA11 seeds by maintaining spacing DVIA11_S_1.
DVIA11F_SEED_REGION_2 = (((SIZE (DVIA11F_BASE_REGION NOT INTERACT (SIZE DVIA11F_pre1_1 BY DVIA11_S_1)) BY DVIA11F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA11EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA11i BY (DVIA11_S_1 + grid))) NOT (SIZE VIA11i BY (DVIA11_S_2 + grid))
DVIA11F_SEED_2 = RECTANGLES DVIA11_W_1 DVIA11_W_1 DVIA11_S_1 INSIDE OF LAYER DVIA11F_SEED_REGION_2

// Find DVIA11 in the DVIA11 fillable and spacing-maintained regions.
DVIA11F_REGION_2 = (DVIA11F_BASE_REGION INTERACT DVIA11F_SEED_2) NOT TOUCH DVIA11F_SEED_2
DVIA11F_pre1_2 = RECTANGLES DVIA11_W_1 DVIA11_W_1 DVIA11_S_1 INSIDE OF LAYER DVIA11F_REGION_2

// post-DRC
DVIA11F_pre1 = DVIA11F_pre1_1 OR DVIA11F_pre1_2
DVIA11F_pre2 = DVIA11F_pre1 NOT INTERACT (EXT DVIA11F_pre1 < DVIA11_S_1 ABUT SINGULAR REGION)
DVIA11F_pre3 = DVIA11F_pre2 NOT INTERACT (EXT DVIA11F_pre2 DUVIA11i < DVIA11_S_1 ABUT SINGULAR REGION)
DVIA11F_pre4 = DVIA11F_pre3 NOT INTERACT (EXT DVIA11F_pre3 VIA11i < DVIA11_S_2 ABUT SINGULAR REGION)
DVIA11F_pre5 = DVIA11F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA11F_pre4 DM11F_FOR_DVIA11F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA11_EN_2 OPPOSITE 0 DVIA11_EN_2 OPPOSITE)
DVIA11F      = DVIA11F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA11F_pre5 DM12F_FOR_DVIA11F_REGION ABUT < 90 SINGULAR GOOD 0 DM12_EN_3 OPPOSITE 0 DM12_EN_3 OPPOSITE)

#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF


#IFDEF 34K_THICK_Mu_M13
#ELSE
#IFDEF 12K_THICK_Mr_M13
#ELSE
#IFDEF 9K_THICK_Mz_M13
#ELSE
#IFDEF 5K_THICK_Myz_M13
#ELSE
#IFDEF 2_6K_THICK_Mxy_M13
#ELSE
#IFDEF 2K_THICK_My_M13
#ELSE
#IFDEF 34K_THICK_Mu_M12
#ELSE
#IFDEF 12K_THICK_Mr_M12
#ELSE
#IFDEF 9K_THICK_Mz_M12
#ELSE
#IFDEF 5K_THICK_Myz_M12
#ELSE
#IFDEF 2_6K_THICK_Mxy_M12
#ELSE
#IFDEF 2K_THICK_My_M12
#ELSE




#IFDEF FILL_DM12
DM12F_FOR_DVIA12F_REGION = ((DM12F OR DUM12) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM12F_FOR_DVIA12F_REGION = (DUM12 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

#IFDEF FILL_DM13
DM13F_FOR_DVIA12F_REGION = ((DM13F OR DUM13) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM13F_FOR_DVIA12F_REGION = (DUM13 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

// Find DVIA12 fillable regions.  Consider enclosure to lower DM12, enclosure to upper DM13, DVIA12 size.

VARIABLE DM12_F_4_REGION_DVIA12_SHORTENED_LENGTH DVIA12_EN_2 - DVIA12_EN_1

#IFDEF VERTICAL_DM12
DM12_F_4_REGION_DVIA12_spec_B_pre = RECTANGLE DM12F_FOR_DVIA12F_REGION == WM12_303_SLOT BY == LM12_303_SLOT
DM12_F_4_REGION_DVIA12_spec_B     = DM12_F_4_REGION_DVIA12_spec_B_pre NOT (EXPAND EDGE (LENGTH DM12_F_4_REGION_DVIA12_spec_B_pre == WM12_303_SLOT) INSIDE BY DM12_F_4_REGION_DVIA12_SHORTENED_LENGTH)

DM12_F_4_REGION_DVIA12_spec_M_pre = RECTANGLE DM12F_FOR_DVIA12F_REGION == WM12_302 BY == LM12_302
DM12_F_4_REGION_DVIA12_spec_M     = DM12_F_4_REGION_DVIA12_spec_M_pre NOT (EXPAND EDGE (LENGTH DM12_F_4_REGION_DVIA12_spec_M_pre == WM12_302) INSIDE BY DM12_F_4_REGION_DVIA12_SHORTENED_LENGTH)

DM12_F_4_REGION_DVIA12_spec_S_pre = RECTANGLE DM12F_FOR_DVIA12F_REGION == WM12_301 BY == LM12_301
DM12_F_4_REGION_DVIA12_spec_S     = DM12_F_4_REGION_DVIA12_spec_S_pre NOT (EXPAND EDGE (LENGTH DM12_F_4_REGION_DVIA12_spec_S_pre == WM12_301) INSIDE BY DM12_F_4_REGION_DVIA12_SHORTENED_LENGTH)
#ELSE
DM12_F_4_REGION_DVIA12_spec_B_pre = RECTANGLE DM12F_FOR_DVIA12F_REGION == LM12_303_SLOT BY == WM12_303_SLOT
DM12_F_4_REGION_DVIA12_spec_B     = DM12_F_4_REGION_DVIA12_spec_B_pre NOT (EXPAND EDGE (LENGTH DM12_F_4_REGION_DVIA12_spec_B_pre == LM12_303_SLOT) INSIDE BY DM12_F_4_REGION_DVIA12_SHORTENED_LENGTH)

DM12_F_4_REGION_DVIA12_spec_M_pre = RECTANGLE DM12F_FOR_DVIA12F_REGION == LM12_302 BY == WM12_302
DM12_F_4_REGION_DVIA12_spec_M     = DM12_F_4_REGION_DVIA12_spec_M_pre NOT (EXPAND EDGE (LENGTH DM12_F_4_REGION_DVIA12_spec_M_pre == LM12_302) INSIDE BY DM12_F_4_REGION_DVIA12_SHORTENED_LENGTH)

DM12_F_4_REGION_DVIA12_spec_S_pre = RECTANGLE DM12F_FOR_DVIA12F_REGION == LM12_301 BY == WM12_301
DM12_F_4_REGION_DVIA12_spec_S     = DM12_F_4_REGION_DVIA12_spec_S_pre NOT (EXPAND EDGE (LENGTH DM12_F_4_REGION_DVIA12_spec_S_pre == LM12_301) INSIDE BY DM12_F_4_REGION_DVIA12_SHORTENED_LENGTH)
#ENDIF
DM12_F_4_REGION_DVIA12_square_pre = RECTANGLE DM12F_FOR_DVIA12F_REGION ASPECT == 1
DM12_F_4_REGION_DVIA12_square     = SIZE DM12_F_4_REGION_DVIA12_square_pre BY -DM12_F_4_REGION_DVIA12_SHORTENED_LENGTH

DM12F_FOR_DVIA12F_REGION_4parts = (DM12_F_4_REGION_DVIA12_spec_B OR DM12_F_4_REGION_DVIA12_spec_M) OR (DM12_F_4_REGION_DVIA12_spec_S OR DM12_F_4_REGION_DVIA12_square)
DM12F_FOR_DVIA12F_REGION_remainder_pre_not = (DM12_F_4_REGION_DVIA12_spec_B_pre OR DM12_F_4_REGION_DVIA12_spec_M_pre) OR (DM12_F_4_REGION_DVIA12_spec_S_pre OR DM12_F_4_REGION_DVIA12_square_pre)
DM12F_FOR_DVIA12F_REGION_remainder = DM12F_FOR_DVIA12F_REGION NOT DM12F_FOR_DVIA12F_REGION_remainder_pre_not

    DM12F_FOR_DVIA12F_REGION_remainder_EDGE = LENGTH DM12F_FOR_DVIA12F_REGION_remainder > 0
    DM12F_FOR_DVIA12F_REGION_remainder_PROP = DFM PROPERTY DM12F_FOR_DVIA12F_REGION_remainder DM12F_FOR_DVIA12F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM12F_FOR_DVIA12F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM12F_FOR_DVIA12F_REGION_remainder_EDGE)) ]
    DM12F_FOR_DVIA12F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM12F_FOR_DVIA12F_REGION_remainder_EDGE DM12F_FOR_DVIA12F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM12F_FOR_DVIA12F_REGION_remainder_EDGE) - PROPERTY(DM12F_FOR_DVIA12F_REGION_remainder_PROP, DM12F_FOR_DVIA12F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM12F_FOR_DVIA12F_REGION2 = DM12F_FOR_DVIA12F_REGION_remainder NOT (EXPAND EDGE DM12F_FOR_DVIA12F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM12_F_4_REGION_DVIA12_SHORTENED_LENGTH)


VARIABLE DM13_F_4_REGION_DVIA12_SHORTENED_LENGTH DM13_EN_3 - DM13_EN_2

#IFDEF VERTICAL_DM13
DM13_F_4_REGION_DVIA12_spec_B_pre = RECTANGLE DM13F_FOR_DVIA12F_REGION == WM13_303_SLOT BY == LM13_303_SLOT
DM13_F_4_REGION_DVIA12_spec_B     = DM13_F_4_REGION_DVIA12_spec_B_pre NOT (EXPAND EDGE (LENGTH DM13_F_4_REGION_DVIA12_spec_B_pre == WM13_303_SLOT) INSIDE BY DM13_F_4_REGION_DVIA12_SHORTENED_LENGTH)

DM13_F_4_REGION_DVIA12_spec_M_pre = RECTANGLE DM13F_FOR_DVIA12F_REGION == WM13_302 BY == LM13_302
DM13_F_4_REGION_DVIA12_spec_M     = DM13_F_4_REGION_DVIA12_spec_M_pre NOT (EXPAND EDGE (LENGTH DM13_F_4_REGION_DVIA12_spec_M_pre == WM13_302) INSIDE BY DM13_F_4_REGION_DVIA12_SHORTENED_LENGTH)

DM13_F_4_REGION_DVIA12_spec_S_pre = RECTANGLE DM13F_FOR_DVIA12F_REGION == WM13_301 BY == LM13_301
DM13_F_4_REGION_DVIA12_spec_S     = DM13_F_4_REGION_DVIA12_spec_S_pre NOT (EXPAND EDGE (LENGTH DM13_F_4_REGION_DVIA12_spec_S_pre == WM13_301) INSIDE BY DM13_F_4_REGION_DVIA12_SHORTENED_LENGTH)
#ELSE
DM13_F_4_REGION_DVIA12_spec_B_pre = RECTANGLE DM13F_FOR_DVIA12F_REGION == LM13_303_SLOT BY == WM13_303_SLOT
DM13_F_4_REGION_DVIA12_spec_B     = DM13_F_4_REGION_DVIA12_spec_B_pre NOT (EXPAND EDGE (LENGTH DM13_F_4_REGION_DVIA12_spec_B_pre == LM13_303_SLOT) INSIDE BY DM13_F_4_REGION_DVIA12_SHORTENED_LENGTH)

DM13_F_4_REGION_DVIA12_spec_M_pre = RECTANGLE DM13F_FOR_DVIA12F_REGION == LM13_302 BY == WM13_302
DM13_F_4_REGION_DVIA12_spec_M     = DM13_F_4_REGION_DVIA12_spec_M_pre NOT (EXPAND EDGE (LENGTH DM13_F_4_REGION_DVIA12_spec_M_pre == LM13_302) INSIDE BY DM13_F_4_REGION_DVIA12_SHORTENED_LENGTH)

DM13_F_4_REGION_DVIA12_spec_S_pre = RECTANGLE DM13F_FOR_DVIA12F_REGION == LM13_301 BY == WM13_301
DM13_F_4_REGION_DVIA12_spec_S     = DM13_F_4_REGION_DVIA12_spec_S_pre NOT (EXPAND EDGE (LENGTH DM13_F_4_REGION_DVIA12_spec_S_pre == LM13_301) INSIDE BY DM13_F_4_REGION_DVIA12_SHORTENED_LENGTH)
#ENDIF

DM13_F_4_REGION_DVIA12_square_pre = RECTANGLE DM13F_FOR_DVIA12F_REGION ASPECT == 1
DM13_F_4_REGION_DVIA12_square     = SIZE DM13_F_4_REGION_DVIA12_square_pre BY -DM13_F_4_REGION_DVIA12_SHORTENED_LENGTH

DM13F_FOR_DVIA12F_REGION_4parts = (DM13_F_4_REGION_DVIA12_spec_B OR DM13_F_4_REGION_DVIA12_spec_M) OR (DM13_F_4_REGION_DVIA12_spec_S OR DM13_F_4_REGION_DVIA12_square)
DM13F_FOR_DVIA12F_REGION_remainder_pre_not = (DM13_F_4_REGION_DVIA12_spec_B_pre OR DM13_F_4_REGION_DVIA12_spec_M_pre) OR (DM13_F_4_REGION_DVIA12_spec_S_pre OR DM13_F_4_REGION_DVIA12_square_pre)
DM13F_FOR_DVIA12F_REGION_remainder = DM13F_FOR_DVIA12F_REGION NOT DM13F_FOR_DVIA12F_REGION_remainder_pre_not

    DM13F_FOR_DVIA12F_REGION_remainder_EDGE = LENGTH DM13F_FOR_DVIA12F_REGION_remainder > 0
    DM13F_FOR_DVIA12F_REGION_remainder_PROP = DFM PROPERTY DM13F_FOR_DVIA12F_REGION_remainder DM13F_FOR_DVIA12F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM13F_FOR_DVIA12F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM13F_FOR_DVIA12F_REGION_remainder_EDGE)) ]
    DM13F_FOR_DVIA12F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM13F_FOR_DVIA12F_REGION_remainder_EDGE DM13F_FOR_DVIA12F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM13F_FOR_DVIA12F_REGION_remainder_EDGE) - PROPERTY(DM13F_FOR_DVIA12F_REGION_remainder_PROP, DM13F_FOR_DVIA12F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM13F_FOR_DVIA12F_REGION2 = DM13F_FOR_DVIA12F_REGION_remainder NOT (EXPAND EDGE DM13F_FOR_DVIA12F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM13_F_4_REGION_DVIA12_SHORTENED_LENGTH)

DVIA12F_BASE_REGION = (((((SIZE (DM12F_FOR_DVIA12F_REGION2 OR DM12F_FOR_DVIA12F_REGION_4parts) BY -DVIA12_EN_1) AND (SIZE (DM13F_FOR_DVIA12F_REGION2 OR DM13F_FOR_DVIA12F_REGION_4parts) BY -DM13_EN_2)) WITH WIDTH >= DVIA12_W_1) NOT (SIZE DVIA12EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA12i BY (DVIA12_S_1 + grid))) NOT (SIZE VIA12i BY (DVIA12_S_2 + grid))




// Merge DVIA12 fillable regions, and find DVIA12 seeds by maintaining spacing DVIA12_S_1.
DVIA12F_SEED_REGION_1 = (((SIZE DVIA12F_BASE_REGION BY DVIA12F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA12EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA12i BY (DVIA12_S_1 + grid))) NOT (SIZE VIA12i BY (DVIA12_S_2 + grid))
DVIA12F_SEED_1 = RECTANGLES DVIA12_W_1 DVIA12_W_1 DVIA12_S_1 INSIDE OF LAYER DVIA12F_SEED_REGION_1

// Find DVIA12 in the DVIA12 fillable and spacing-maintained regions.
DVIA12F_REGION_1 = (DVIA12F_BASE_REGION INTERACT DVIA12F_SEED_1) NOT TOUCH DVIA12F_SEED_1
DVIA12F_pre1_1_pre1 = RECTANGLES DVIA12_W_1 DVIA12_W_1 DVIA12_S_1 INSIDE OF LAYER DVIA12F_REGION_1

// post-DRC
DVIA12F_pre1_1_pre2 = DVIA12F_pre1_1_pre1 NOT INTERACT (EXT DVIA12F_pre1_1_pre1 < DVIA12_S_1 ABUT SINGULAR REGION)
DVIA12F_pre1_1_pre3 = DVIA12F_pre1_1_pre2 NOT INTERACT (EXT DVIA12F_pre1_1_pre2 DUVIA12i < DVIA12_S_1 ABUT SINGULAR REGION)
DVIA12F_pre1_1_pre4 = DVIA12F_pre1_1_pre3 NOT INTERACT (EXT DVIA12F_pre1_1_pre3 VIA12i < DVIA12_S_2 ABUT SINGULAR REGION)
DVIA12F_pre1_1_pre5 = DVIA12F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA12F_pre1_1_pre4 DM12F_FOR_DVIA12F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA12_EN_2 OPPOSITE 0 DVIA12_EN_2 OPPOSITE)
DVIA12F_pre1_1      = DVIA12F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA12F_pre1_1_pre5 DM13F_FOR_DVIA12F_REGION ABUT < 90 SINGULAR GOOD 0 DM13_EN_3 OPPOSITE 0 DM13_EN_3 OPPOSITE)

// Merge DVIA12 fillable regions, and find DVIA12 seeds by maintaining spacing DVIA12_S_1.
DVIA12F_SEED_REGION_2 = (((SIZE (DVIA12F_BASE_REGION NOT INTERACT (SIZE DVIA12F_pre1_1 BY DVIA12_S_1)) BY DVIA12F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA12EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA12i BY (DVIA12_S_1 + grid))) NOT (SIZE VIA12i BY (DVIA12_S_2 + grid))
DVIA12F_SEED_2 = RECTANGLES DVIA12_W_1 DVIA12_W_1 DVIA12_S_1 INSIDE OF LAYER DVIA12F_SEED_REGION_2

// Find DVIA12 in the DVIA12 fillable and spacing-maintained regions.
DVIA12F_REGION_2 = (DVIA12F_BASE_REGION INTERACT DVIA12F_SEED_2) NOT TOUCH DVIA12F_SEED_2
DVIA12F_pre1_2 = RECTANGLES DVIA12_W_1 DVIA12_W_1 DVIA12_S_1 INSIDE OF LAYER DVIA12F_REGION_2

// post-DRC
DVIA12F_pre1 = DVIA12F_pre1_1 OR DVIA12F_pre1_2
DVIA12F_pre2 = DVIA12F_pre1 NOT INTERACT (EXT DVIA12F_pre1 < DVIA12_S_1 ABUT SINGULAR REGION)
DVIA12F_pre3 = DVIA12F_pre2 NOT INTERACT (EXT DVIA12F_pre2 DUVIA12i < DVIA12_S_1 ABUT SINGULAR REGION)
DVIA12F_pre4 = DVIA12F_pre3 NOT INTERACT (EXT DVIA12F_pre3 VIA12i < DVIA12_S_2 ABUT SINGULAR REGION)
DVIA12F_pre5 = DVIA12F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA12F_pre4 DM12F_FOR_DVIA12F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA12_EN_2 OPPOSITE 0 DVIA12_EN_2 OPPOSITE)
DVIA12F      = DVIA12F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA12F_pre5 DM13F_FOR_DVIA12F_REGION ABUT < 90 SINGULAR GOOD 0 DM13_EN_3 OPPOSITE 0 DM13_EN_3 OPPOSITE)

#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF



