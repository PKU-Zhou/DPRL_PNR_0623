    FRAMEA4OPC_M4_S_37_VIA3_b = SIZE VIA3i_55V		BY (M4_S_37 + grid)
    FRAMEA4OPC_M4_S_37a_VIA3_bDV = SIZE (VIA3i INTERACT (M3_HVN_500Vx OR M4_HVN_500Vx))		BY (M4_S_37a + grid)
