#ELSE
#IFDEF 9K_THICK_Mz_M4
#ELSE
#IFDEF 5K_THICK_Myz_M4
#ELSE
#IFDEF 2_6K_THICK_Mxy_M4
#ELSE
#IFDEF 2K_THICK_My_M4
#ELSE




#IFDEF FILL_DM4
DM4F_FOR_DVIA4F_REGION = ((DM4F OR DUM4) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM4F_FOR_DVIA4F_REGION = (DUM4 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

#IFDEF FILL_DM5
DM5F_FOR_DVIA4F_REGION = ((DM5F OR DUM5) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM5F_FOR_DVIA4F_REGION = (DUM5 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

// Find DVIA4 fillable regions.  Consider enclosure to lower DM4, enclosure to upper DM5, DVIA4 size.

VARIABLE DM4_F_4_REGION_DVIA4_SHORTENED_LENGTH DVIA4_EN_2 - DVIA4_EN_1

#IFDEF VERTICAL_DM4
DM4_F_4_REGION_DVIA4_spec_B_pre = RECTANGLE DM4F_FOR_DVIA4F_REGION == WM4_303_SLOT BY == LM4_303_SLOT
DM4_F_4_REGION_DVIA4_spec_B     = DM4_F_4_REGION_DVIA4_spec_B_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA4_spec_B_pre == WM4_303_SLOT) INSIDE BY DM4_F_4_REGION_DVIA4_SHORTENED_LENGTH)

DM4_F_4_REGION_DVIA4_spec_M_pre = RECTANGLE DM4F_FOR_DVIA4F_REGION == WM4_302 BY == LM4_302
DM4_F_4_REGION_DVIA4_spec_M     = DM4_F_4_REGION_DVIA4_spec_M_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA4_spec_M_pre == WM4_302) INSIDE BY DM4_F_4_REGION_DVIA4_SHORTENED_LENGTH)

DM4_F_4_REGION_DVIA4_spec_S_pre = RECTANGLE DM4F_FOR_DVIA4F_REGION == WM4_301 BY == LM4_301
DM4_F_4_REGION_DVIA4_spec_S     = DM4_F_4_REGION_DVIA4_spec_S_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA4_spec_S_pre == WM4_301) INSIDE BY DM4_F_4_REGION_DVIA4_SHORTENED_LENGTH)
#ELSE
DM4_F_4_REGION_DVIA4_spec_B_pre = RECTANGLE DM4F_FOR_DVIA4F_REGION == LM4_303_SLOT BY == WM4_303_SLOT
DM4_F_4_REGION_DVIA4_spec_B     = DM4_F_4_REGION_DVIA4_spec_B_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA4_spec_B_pre == LM4_303_SLOT) INSIDE BY DM4_F_4_REGION_DVIA4_SHORTENED_LENGTH)

DM4_F_4_REGION_DVIA4_spec_M_pre = RECTANGLE DM4F_FOR_DVIA4F_REGION == LM4_302 BY == WM4_302
DM4_F_4_REGION_DVIA4_spec_M     = DM4_F_4_REGION_DVIA4_spec_M_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA4_spec_M_pre == LM4_302) INSIDE BY DM4_F_4_REGION_DVIA4_SHORTENED_LENGTH)

DM4_F_4_REGION_DVIA4_spec_S_pre = RECTANGLE DM4F_FOR_DVIA4F_REGION == LM4_301 BY == WM4_301
DM4_F_4_REGION_DVIA4_spec_S     = DM4_F_4_REGION_DVIA4_spec_S_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA4_spec_S_pre == LM4_301) INSIDE BY DM4_F_4_REGION_DVIA4_SHORTENED_LENGTH)
#ENDIF
DM4_F_4_REGION_DVIA4_square_pre = RECTANGLE DM4F_FOR_DVIA4F_REGION ASPECT == 1
DM4_F_4_REGION_DVIA4_square     = SIZE DM4_F_4_REGION_DVIA4_square_pre BY -DM4_F_4_REGION_DVIA4_SHORTENED_LENGTH

DM4F_FOR_DVIA4F_REGION_4parts = (DM4_F_4_REGION_DVIA4_spec_B OR DM4_F_4_REGION_DVIA4_spec_M) OR (DM4_F_4_REGION_DVIA4_spec_S OR DM4_F_4_REGION_DVIA4_square)
DM4F_FOR_DVIA4F_REGION_remainder_pre_not = (DM4_F_4_REGION_DVIA4_spec_B_pre OR DM4_F_4_REGION_DVIA4_spec_M_pre) OR (DM4_F_4_REGION_DVIA4_spec_S_pre OR DM4_F_4_REGION_DVIA4_square_pre)
DM4F_FOR_DVIA4F_REGION_remainder = DM4F_FOR_DVIA4F_REGION NOT DM4F_FOR_DVIA4F_REGION_remainder_pre_not

    DM4F_FOR_DVIA4F_REGION_remainder_EDGE = LENGTH DM4F_FOR_DVIA4F_REGION_remainder > 0
    DM4F_FOR_DVIA4F_REGION_remainder_PROP = DFM PROPERTY DM4F_FOR_DVIA4F_REGION_remainder DM4F_FOR_DVIA4F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM4F_FOR_DVIA4F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM4F_FOR_DVIA4F_REGION_remainder_EDGE)) ]
    DM4F_FOR_DVIA4F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM4F_FOR_DVIA4F_REGION_remainder_EDGE DM4F_FOR_DVIA4F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM4F_FOR_DVIA4F_REGION_remainder_EDGE) - PROPERTY(DM4F_FOR_DVIA4F_REGION_remainder_PROP, DM4F_FOR_DVIA4F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM4F_FOR_DVIA4F_REGION2 = DM4F_FOR_DVIA4F_REGION_remainder NOT (EXPAND EDGE DM4F_FOR_DVIA4F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM4_F_4_REGION_DVIA4_SHORTENED_LENGTH)


VARIABLE DM5_F_4_REGION_DVIA4_SHORTENED_LENGTH DM5_EN_3 - DM5_EN_2

#IFDEF VERTICAL_DM5
DM5_F_4_REGION_DVIA4_spec_B_pre = RECTANGLE DM5F_FOR_DVIA4F_REGION == WM5_303_SLOT BY == LM5_303_SLOT
DM5_F_4_REGION_DVIA4_spec_B     = DM5_F_4_REGION_DVIA4_spec_B_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA4_spec_B_pre == WM5_303_SLOT) INSIDE BY DM5_F_4_REGION_DVIA4_SHORTENED_LENGTH)

DM5_F_4_REGION_DVIA4_spec_M_pre = RECTANGLE DM5F_FOR_DVIA4F_REGION == WM5_302 BY == LM5_302
DM5_F_4_REGION_DVIA4_spec_M     = DM5_F_4_REGION_DVIA4_spec_M_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA4_spec_M_pre == WM5_302) INSIDE BY DM5_F_4_REGION_DVIA4_SHORTENED_LENGTH)

DM5_F_4_REGION_DVIA4_spec_S_pre = RECTANGLE DM5F_FOR_DVIA4F_REGION == WM5_301 BY == LM5_301
DM5_F_4_REGION_DVIA4_spec_S     = DM5_F_4_REGION_DVIA4_spec_S_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA4_spec_S_pre == WM5_301) INSIDE BY DM5_F_4_REGION_DVIA4_SHORTENED_LENGTH)
#ELSE
DM5_F_4_REGION_DVIA4_spec_B_pre = RECTANGLE DM5F_FOR_DVIA4F_REGION == LM5_303_SLOT BY == WM5_303_SLOT
DM5_F_4_REGION_DVIA4_spec_B     = DM5_F_4_REGION_DVIA4_spec_B_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA4_spec_B_pre == LM5_303_SLOT) INSIDE BY DM5_F_4_REGION_DVIA4_SHORTENED_LENGTH)

DM5_F_4_REGION_DVIA4_spec_M_pre = RECTANGLE DM5F_FOR_DVIA4F_REGION == LM5_302 BY == WM5_302
DM5_F_4_REGION_DVIA4_spec_M     = DM5_F_4_REGION_DVIA4_spec_M_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA4_spec_M_pre == LM5_302) INSIDE BY DM5_F_4_REGION_DVIA4_SHORTENED_LENGTH)

DM5_F_4_REGION_DVIA4_spec_S_pre = RECTANGLE DM5F_FOR_DVIA4F_REGION == LM5_301 BY == WM5_301
DM5_F_4_REGION_DVIA4_spec_S     = DM5_F_4_REGION_DVIA4_spec_S_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA4_spec_S_pre == LM5_301) INSIDE BY DM5_F_4_REGION_DVIA4_SHORTENED_LENGTH)
#ENDIF

DM5_F_4_REGION_DVIA4_square_pre = RECTANGLE DM5F_FOR_DVIA4F_REGION ASPECT == 1
DM5_F_4_REGION_DVIA4_square     = SIZE DM5_F_4_REGION_DVIA4_square_pre BY -DM5_F_4_REGION_DVIA4_SHORTENED_LENGTH

DM5F_FOR_DVIA4F_REGION_4parts = (DM5_F_4_REGION_DVIA4_spec_B OR DM5_F_4_REGION_DVIA4_spec_M) OR (DM5_F_4_REGION_DVIA4_spec_S OR DM5_F_4_REGION_DVIA4_square)
DM5F_FOR_DVIA4F_REGION_remainder_pre_not = (DM5_F_4_REGION_DVIA4_spec_B_pre OR DM5_F_4_REGION_DVIA4_spec_M_pre) OR (DM5_F_4_REGION_DVIA4_spec_S_pre OR DM5_F_4_REGION_DVIA4_square_pre)
DM5F_FOR_DVIA4F_REGION_remainder = DM5F_FOR_DVIA4F_REGION NOT DM5F_FOR_DVIA4F_REGION_remainder_pre_not

    DM5F_FOR_DVIA4F_REGION_remainder_EDGE = LENGTH DM5F_FOR_DVIA4F_REGION_remainder > 0
    DM5F_FOR_DVIA4F_REGION_remainder_PROP = DFM PROPERTY DM5F_FOR_DVIA4F_REGION_remainder DM5F_FOR_DVIA4F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM5F_FOR_DVIA4F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM5F_FOR_DVIA4F_REGION_remainder_EDGE)) ]
    DM5F_FOR_DVIA4F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM5F_FOR_DVIA4F_REGION_remainder_EDGE DM5F_FOR_DVIA4F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM5F_FOR_DVIA4F_REGION_remainder_EDGE) - PROPERTY(DM5F_FOR_DVIA4F_REGION_remainder_PROP, DM5F_FOR_DVIA4F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM5F_FOR_DVIA4F_REGION2 = DM5F_FOR_DVIA4F_REGION_remainder NOT (EXPAND EDGE DM5F_FOR_DVIA4F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM5_F_4_REGION_DVIA4_SHORTENED_LENGTH)

DVIA4F_BASE_REGION = (((((SIZE (DM4F_FOR_DVIA4F_REGION2 OR DM4F_FOR_DVIA4F_REGION_4parts) BY -DVIA4_EN_1) AND (SIZE (DM5F_FOR_DVIA4F_REGION2 OR DM5F_FOR_DVIA4F_REGION_4parts) BY -DM5_EN_2)) WITH WIDTH >= DVIA4_W_1) NOT (SIZE DVIA4EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA4i BY (DVIA4_S_1 + grid))) NOT (SIZE VIA4i BY (DVIA4_S_2 + grid))




// Merge DVIA4 fillable regions, and find DVIA4 seeds by maintaining spacing DVIA4_S_1.
DVIA4F_SEED_REGION_1 = (((SIZE DVIA4F_BASE_REGION BY DVIA4F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA4EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA4i BY (DVIA4_S_1 + grid))) NOT (SIZE VIA4i BY (DVIA4_S_2 + grid))
DVIA4F_SEED_1 = RECTANGLES DVIA4_W_1 DVIA4_W_1 DVIA4_S_1 INSIDE OF LAYER DVIA4F_SEED_REGION_1

// Find DVIA4 in the DVIA4 fillable and spacing-maintained regions.
DVIA4F_REGION_1 = (DVIA4F_BASE_REGION INTERACT DVIA4F_SEED_1) NOT TOUCH DVIA4F_SEED_1
DVIA4F_pre1_1_pre1 = RECTANGLES DVIA4_W_1 DVIA4_W_1 DVIA4_S_1 INSIDE OF LAYER DVIA4F_REGION_1

// post-DRC
DVIA4F_pre1_1_pre2 = DVIA4F_pre1_1_pre1 NOT INTERACT (EXT DVIA4F_pre1_1_pre1 < DVIA4_S_1 ABUT SINGULAR REGION)
DVIA4F_pre1_1_pre3 = DVIA4F_pre1_1_pre2 NOT INTERACT (EXT DVIA4F_pre1_1_pre2 DUVIA4i < DVIA4_S_1 ABUT SINGULAR REGION)
DVIA4F_pre1_1_pre4 = DVIA4F_pre1_1_pre3 NOT INTERACT (EXT DVIA4F_pre1_1_pre3 VIA4i < DVIA4_S_2 ABUT SINGULAR REGION)
DVIA4F_pre1_1_pre5 = DVIA4F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA4F_pre1_1_pre4 DM4F_FOR_DVIA4F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA4_EN_2 OPPOSITE 0 DVIA4_EN_2 OPPOSITE)
DVIA4F_pre1_1      = DVIA4F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA4F_pre1_1_pre5 DM5F_FOR_DVIA4F_REGION ABUT < 90 SINGULAR GOOD 0 DM5_EN_3 OPPOSITE 0 DM5_EN_3 OPPOSITE)

// Merge DVIA4 fillable regions, and find DVIA4 seeds by maintaining spacing DVIA4_S_1.
DVIA4F_SEED_REGION_2 = (((SIZE (DVIA4F_BASE_REGION NOT INTERACT (SIZE DVIA4F_pre1_1 BY DVIA4_S_1)) BY DVIA4F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA4EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA4i BY (DVIA4_S_1 + grid))) NOT (SIZE VIA4i BY (DVIA4_S_2 + grid))
DVIA4F_SEED_2 = RECTANGLES DVIA4_W_1 DVIA4_W_1 DVIA4_S_1 INSIDE OF LAYER DVIA4F_SEED_REGION_2

// Find DVIA4 in the DVIA4 fillable and spacing-maintained regions.
DVIA4F_REGION_2 = (DVIA4F_BASE_REGION INTERACT DVIA4F_SEED_2) NOT TOUCH DVIA4F_SEED_2
DVIA4F_pre1_2 = RECTANGLES DVIA4_W_1 DVIA4_W_1 DVIA4_S_1 INSIDE OF LAYER DVIA4F_REGION_2

// post-DRC
DVIA4F_pre1 = DVIA4F_pre1_1 OR DVIA4F_pre1_2
DVIA4F_pre2 = DVIA4F_pre1 NOT INTERACT (EXT DVIA4F_pre1 < DVIA4_S_1 ABUT SINGULAR REGION)
DVIA4F_pre3 = DVIA4F_pre2 NOT INTERACT (EXT DVIA4F_pre2 DUVIA4i < DVIA4_S_1 ABUT SINGULAR REGION)
DVIA4F_pre4 = DVIA4F_pre3 NOT INTERACT (EXT DVIA4F_pre3 VIA4i < DVIA4_S_2 ABUT SINGULAR REGION)
DVIA4F_pre5 = DVIA4F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA4F_pre4 DM4F_FOR_DVIA4F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA4_EN_2 OPPOSITE 0 DVIA4_EN_2 OPPOSITE)
DVIA4F      = DVIA4F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA4F_pre5 DM5F_FOR_DVIA4F_REGION ABUT < 90 SINGULAR GOOD 0 DM5_EN_3 OPPOSITE 0 DM5_EN_3 OPPOSITE)

#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF


