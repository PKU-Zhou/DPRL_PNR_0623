DM11_F_4_REGION_DVIA11_spec_S     = DM11_F_4_REGION_DVIA11_spec_S_pre NOT (EXPAND EDGE (LENGTH DM11_F_4_REGION_DVIA11_spec_S_pre == WM11_301) INSIDE BY DM11_F_4_REGION_DVIA11_SHORTENED_LENGTH)
