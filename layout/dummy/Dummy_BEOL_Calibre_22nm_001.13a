ALL_DM1F = DM1F OR DM1F_INDDMY
#ENDIF
ALL_DM1F_DRC = ALL_DM1F NOT INTERACT (EXT ALL_DM1F < dm2DM1 ABUT SINGULAR REGION)

DM1_FILL { COPY ALL_DM1F_DRC }


