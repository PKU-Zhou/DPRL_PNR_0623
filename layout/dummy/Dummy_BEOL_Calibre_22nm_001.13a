DM8F_FOR_DVIA8F_REGION_4parts = (DM8_F_4_REGION_DVIA8_spec_B OR DM8_F_4_REGION_DVIA8_spec_M) OR (DM8_F_4_REGION_DVIA8_spec_S OR DM8_F_4_REGION_DVIA8_square)
DM8F_FOR_DVIA8F_REGION_remainder_pre_not = (DM8_F_4_REGION_DVIA8_spec_B_pre OR DM8_F_4_REGION_DVIA8_spec_M_pre) OR (DM8_F_4_REGION_DVIA8_spec_S_pre OR DM8_F_4_REGION_DVIA8_square_pre)
DM8F_FOR_DVIA8F_REGION_remainder = DM8F_FOR_DVIA8F_REGION NOT DM8F_FOR_DVIA8F_REGION_remainder_pre_not

    DM8F_FOR_DVIA8F_REGION_remainder_EDGE = LENGTH DM8F_FOR_DVIA8F_REGION_remainder > 0
    DM8F_FOR_DVIA8F_REGION_remainder_PROP = DFM PROPERTY DM8F_FOR_DVIA8F_REGION_remainder DM8F_FOR_DVIA8F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM8F_FOR_DVIA8F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM8F_FOR_DVIA8F_REGION_remainder_EDGE)) ]
    DM8F_FOR_DVIA8F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM8F_FOR_DVIA8F_REGION_remainder_EDGE DM8F_FOR_DVIA8F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM8F_FOR_DVIA8F_REGION_remainder_EDGE) - PROPERTY(DM8F_FOR_DVIA8F_REGION_remainder_PROP, DM8F_FOR_DVIA8F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM8F_FOR_DVIA8F_REGION2 = DM8F_FOR_DVIA8F_REGION_remainder NOT (EXPAND EDGE DM8F_FOR_DVIA8F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM8_F_4_REGION_DVIA8_SHORTENED_LENGTH)


VARIABLE DM9_F_4_REGION_DVIA8_SHORTENED_LENGTH DM9_EN_3 - DM9_EN_2

#IFDEF VERTICAL_DM9
DM9_F_4_REGION_DVIA8_spec_B_pre = RECTANGLE DM9F_FOR_DVIA8F_REGION == WM9_303_SLOT BY == LM9_303_SLOT
DM9_F_4_REGION_DVIA8_spec_B     = DM9_F_4_REGION_DVIA8_spec_B_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA8_spec_B_pre == WM9_303_SLOT) INSIDE BY DM9_F_4_REGION_DVIA8_SHORTENED_LENGTH)

DM9_F_4_REGION_DVIA8_spec_M_pre = RECTANGLE DM9F_FOR_DVIA8F_REGION == WM9_302 BY == LM9_302
DM9_F_4_REGION_DVIA8_spec_M     = DM9_F_4_REGION_DVIA8_spec_M_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA8_spec_M_pre == WM9_302) INSIDE BY DM9_F_4_REGION_DVIA8_SHORTENED_LENGTH)

DM9_F_4_REGION_DVIA8_spec_S_pre = RECTANGLE DM9F_FOR_DVIA8F_REGION == WM9_301 BY == LM9_301
DM9_F_4_REGION_DVIA8_spec_S     = DM9_F_4_REGION_DVIA8_spec_S_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA8_spec_S_pre == WM9_301) INSIDE BY DM9_F_4_REGION_DVIA8_SHORTENED_LENGTH)
#ELSE
DM9_F_4_REGION_DVIA8_spec_B_pre = RECTANGLE DM9F_FOR_DVIA8F_REGION == LM9_303_SLOT BY == WM9_303_SLOT
DM9_F_4_REGION_DVIA8_spec_B     = DM9_F_4_REGION_DVIA8_spec_B_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA8_spec_B_pre == LM9_303_SLOT) INSIDE BY DM9_F_4_REGION_DVIA8_SHORTENED_LENGTH)

DM9_F_4_REGION_DVIA8_spec_M_pre = RECTANGLE DM9F_FOR_DVIA8F_REGION == LM9_302 BY == WM9_302
DM9_F_4_REGION_DVIA8_spec_M     = DM9_F_4_REGION_DVIA8_spec_M_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA8_spec_M_pre == LM9_302) INSIDE BY DM9_F_4_REGION_DVIA8_SHORTENED_LENGTH)

DM9_F_4_REGION_DVIA8_spec_S_pre = RECTANGLE DM9F_FOR_DVIA8F_REGION == LM9_301 BY == WM9_301
DM9_F_4_REGION_DVIA8_spec_S     = DM9_F_4_REGION_DVIA8_spec_S_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA8_spec_S_pre == LM9_301) INSIDE BY DM9_F_4_REGION_DVIA8_SHORTENED_LENGTH)
#ENDIF

DM9_F_4_REGION_DVIA8_square_pre = RECTANGLE DM9F_FOR_DVIA8F_REGION ASPECT == 1
DM9_F_4_REGION_DVIA8_square     = SIZE DM9_F_4_REGION_DVIA8_square_pre BY -DM9_F_4_REGION_DVIA8_SHORTENED_LENGTH

DM9F_FOR_DVIA8F_REGION_4parts = (DM9_F_4_REGION_DVIA8_spec_B OR DM9_F_4_REGION_DVIA8_spec_M) OR (DM9_F_4_REGION_DVIA8_spec_S OR DM9_F_4_REGION_DVIA8_square)
DM9F_FOR_DVIA8F_REGION_remainder_pre_not = (DM9_F_4_REGION_DVIA8_spec_B_pre OR DM9_F_4_REGION_DVIA8_spec_M_pre) OR (DM9_F_4_REGION_DVIA8_spec_S_pre OR DM9_F_4_REGION_DVIA8_square_pre)
DM9F_FOR_DVIA8F_REGION_remainder = DM9F_FOR_DVIA8F_REGION NOT DM9F_FOR_DVIA8F_REGION_remainder_pre_not

    DM9F_FOR_DVIA8F_REGION_remainder_EDGE = LENGTH DM9F_FOR_DVIA8F_REGION_remainder > 0
    DM9F_FOR_DVIA8F_REGION_remainder_PROP = DFM PROPERTY DM9F_FOR_DVIA8F_REGION_remainder DM9F_FOR_DVIA8F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM9F_FOR_DVIA8F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM9F_FOR_DVIA8F_REGION_remainder_EDGE)) ]
    DM9F_FOR_DVIA8F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM9F_FOR_DVIA8F_REGION_remainder_EDGE DM9F_FOR_DVIA8F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM9F_FOR_DVIA8F_REGION_remainder_EDGE) - PROPERTY(DM9F_FOR_DVIA8F_REGION_remainder_PROP, DM9F_FOR_DVIA8F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM9F_FOR_DVIA8F_REGION2 = DM9F_FOR_DVIA8F_REGION_remainder NOT (EXPAND EDGE DM9F_FOR_DVIA8F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM9_F_4_REGION_DVIA8_SHORTENED_LENGTH)

DVIA8F_BASE_REGION = (((((SIZE (DM8F_FOR_DVIA8F_REGION2 OR DM8F_FOR_DVIA8F_REGION_4parts) BY -DVIA8_EN_1) AND (SIZE (DM9F_FOR_DVIA8F_REGION2 OR DM9F_FOR_DVIA8F_REGION_4parts) BY -DM9_EN_2)) WITH WIDTH >= DVIA8_W_1) NOT (SIZE DVIA8EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA8i BY (DVIA8_S_1 + grid))) NOT (SIZE VIA8i BY (DVIA8_S_2 + grid))




// Merge DVIA8 fillable regions, and find DVIA8 seeds by maintaining spacing DVIA8_S_1.
DVIA8F_SEED_REGION_1 = (((SIZE DVIA8F_BASE_REGION BY DVIA8F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA8EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA8i BY (DVIA8_S_1 + grid))) NOT (SIZE VIA8i BY (DVIA8_S_2 + grid))
DVIA8F_SEED_1 = RECTANGLES DVIA8_W_1 DVIA8_W_1 DVIA8_S_1 INSIDE OF LAYER DVIA8F_SEED_REGION_1

// Find DVIA8 in the DVIA8 fillable and spacing-maintained regions.
DVIA8F_REGION_1 = (DVIA8F_BASE_REGION INTERACT DVIA8F_SEED_1) NOT TOUCH DVIA8F_SEED_1
DVIA8F_pre1_1_pre1 = RECTANGLES DVIA8_W_1 DVIA8_W_1 DVIA8_S_1 INSIDE OF LAYER DVIA8F_REGION_1

// post-DRC
DVIA8F_pre1_1_pre2 = DVIA8F_pre1_1_pre1 NOT INTERACT (EXT DVIA8F_pre1_1_pre1 < DVIA8_S_1 ABUT SINGULAR REGION)
DVIA8F_pre1_1_pre3 = DVIA8F_pre1_1_pre2 NOT INTERACT (EXT DVIA8F_pre1_1_pre2 DUVIA8i < DVIA8_S_1 ABUT SINGULAR REGION)
DVIA8F_pre1_1_pre4 = DVIA8F_pre1_1_pre3 NOT INTERACT (EXT DVIA8F_pre1_1_pre3 VIA8i < DVIA8_S_2 ABUT SINGULAR REGION)
DVIA8F_pre1_1_pre5 = DVIA8F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA8F_pre1_1_pre4 DM8F_FOR_DVIA8F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA8_EN_2 OPPOSITE 0 DVIA8_EN_2 OPPOSITE)
DVIA8F_pre1_1      = DVIA8F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA8F_pre1_1_pre5 DM9F_FOR_DVIA8F_REGION ABUT < 90 SINGULAR GOOD 0 DM9_EN_3 OPPOSITE 0 DM9_EN_3 OPPOSITE)

// Merge DVIA8 fillable regions, and find DVIA8 seeds by maintaining spacing DVIA8_S_1.
DVIA8F_SEED_REGION_2 = (((SIZE (DVIA8F_BASE_REGION NOT INTERACT (SIZE DVIA8F_pre1_1 BY DVIA8_S_1)) BY DVIA8F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA8EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA8i BY (DVIA8_S_1 + grid))) NOT (SIZE VIA8i BY (DVIA8_S_2 + grid))
DVIA8F_SEED_2 = RECTANGLES DVIA8_W_1 DVIA8_W_1 DVIA8_S_1 INSIDE OF LAYER DVIA8F_SEED_REGION_2

// Find DVIA8 in the DVIA8 fillable and spacing-maintained regions.
DVIA8F_REGION_2 = (DVIA8F_BASE_REGION INTERACT DVIA8F_SEED_2) NOT TOUCH DVIA8F_SEED_2
DVIA8F_pre1_2 = RECTANGLES DVIA8_W_1 DVIA8_W_1 DVIA8_S_1 INSIDE OF LAYER DVIA8F_REGION_2

// post-DRC
DVIA8F_pre1 = DVIA8F_pre1_1 OR DVIA8F_pre1_2
DVIA8F_pre2 = DVIA8F_pre1 NOT INTERACT (EXT DVIA8F_pre1 < DVIA8_S_1 ABUT SINGULAR REGION)
DVIA8F_pre3 = DVIA8F_pre2 NOT INTERACT (EXT DVIA8F_pre2 DUVIA8i < DVIA8_S_1 ABUT SINGULAR REGION)
DVIA8F_pre4 = DVIA8F_pre3 NOT INTERACT (EXT DVIA8F_pre3 VIA8i < DVIA8_S_2 ABUT SINGULAR REGION)
DVIA8F_pre5 = DVIA8F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA8F_pre4 DM8F_FOR_DVIA8F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA8_EN_2 OPPOSITE 0 DVIA8_EN_2 OPPOSITE)
DVIA8F      = DVIA8F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA8F_pre5 DM9F_FOR_DVIA8F_REGION ABUT < 90 SINGULAR GOOD 0 DM9_EN_3 OPPOSITE 0 DM9_EN_3 OPPOSITE)

#ENDIF
#ENDIF
