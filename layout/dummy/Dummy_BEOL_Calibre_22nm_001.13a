//#DEFINE OLD_METAL_SCHEME  // turn on to output non-OPC dummy metal in GDS file with
                            // datatype 1 for all thick metal

/* SWITCH DEFINITION END */
#IFNDEF COMBINE_DODPO_DMVIA

//***** Layer Assignment ******************

LAYER DNWi       10000     // deep-nwell
LAYER MAP 1 DATATYPE 0 10000

LAYER NWii      3000            // nwell technology
LAYER MAP 3 DATATYPE 0 3000

LAYER NWiOTHERS 3001
LAYER MAP 3 DATATYPE >=1   <=129 3001
LAYER MAP 3 DATATYPE >=150 <=169 3001
LAYER MAP 3 DATATYPE >=180 <=255 3001

LAYER NWLVTi    1671            // LVT NWELL for N28HPA process
LAYER MAP 167 DATATYPE 1 1671

NWi = NWii OR NWLVTi

LAYER PMi        5050     // Polymide (if drawn)
