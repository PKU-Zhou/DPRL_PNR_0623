TCD_M3_150_3 = COPY TCD_M3_150_3_1
TCD_M3_165_93 = COPY TCD_M3_165_93_1
TCD_M3_33_0 = OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR TCD_M3_33_0_1 TCD_M3_33_0_2) TCD_M3_33_0_3) TCD_M3_33_0_4) TCD_M3_33_0_5) TCD_M3_33_0_6) TCD_M3_33_0_7) TCD_M3_33_0_8) TCD_M3_33_0_9) TCD_M3_33_0_10) TCD_M3_33_0_11) TCD_M3_33_0_12) TCD_M3_33_0_13) TCD_M3_33_0_14) TCD_M3_33_0_15) TCD_M3_33_0_16) TCD_M3_33_0_17) TCD_M3_33_0_18) TCD_M3_33_0_19) TCD_M3_33_0_20) TCD_M3_33_0_21) TCD_M3_33_0_22) TCD_M3_33_0_23) TCD_M3_33_0_24) TCD_M3_33_0_25) TCD_M3_33_0_26) TCD_M3_33_0_27) TCD_M3_33_0_28) TCD_M3_33_0_29) TCD_M3_33_0_30) TCD_M3_33_0_31) TCD_M3_33_0_32) TCD_M3_33_0_33) TCD_M3_33_0_34) TCD_M3_33_0_35) TCD_M3_33_0_36) TCD_M3_33_0_37) TCD_M3_33_0_38) TCD_M3_33_0_39) TCD_M3_33_0_40) TCD_M3_33_0_41) TCD_M3_33_0_42) TCD_M3_33_0_43) TCD_M3_33_0_44) TCD_M3_33_0_45) TCD_M3_33_0_46) TCD_M3_33_0_47) TCD_M3_33_0_48) TCD_M3_33_0_49) TCD_M3_33_0_50) TCD_M3_33_0_51) TCD_M3_33_0_52) TCD_M3_33_0_53) TCD_M3_33_0_54) TCD_M3_33_0_55) TCD_M3_33_0_56) TCD_M3_33_0_57

    xM3_DTCD = SIZE TCD_M3 BY D2M3_DTCD
#ELSE
    xM3_DTCD = COPY EMPTY
#ENDIF

    M3BigHole = SIZE M3InnerHole BY - excludeHoleSize/2
    M3ExcHole = ((M3InnerHole OUTSIDE M3BigHole) NOT M3i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK3 = (SIZE DM3EXCL BY (dm2DMEXCL + grid)) OR MIM3_x

    FRAMEA3 = (SIZE M3i BY (DM3_301 + grid)) OR (SIZE (EXPAND EDGE (M3i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA3OPC = SIZE M3i BY (DM3_OPC + grid)
    FRAMEA3OPCwide = SIZE (M3i WITH WIDTH > DM3_OPC_wide_w) BY (DM3_OPC_wide + grid)
    FRAMEA3OPC45 = SIZE (EXPAND EDGE (M3i ANGLE == 45) OUTSIDE BY DM3_OPC_45 EXTEND BY DM3_OPC_45_E) BY grid
    FRAMEA3OPC45DV = SIZE (EXPAND EDGE ((M3i INTERACT M3_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM3_OPC_45 EXTEND BY DM3_OPC_45_E) BY grid
    FRAMEA3OPC_M3_S_14_wide = SIZE (M3i WITH WIDTH > M3_S_14_wide_w) BY (M3_S_14_wide + grid)
    FRAMEA3OPC_M3_S_17_wide = SIZE (M3i WITH WIDTH > M3_S_17_wide_w) BY (M3_S_17_wide + grid)
    FRAMEA3OPC_M3_S_20_wide = SIZE (M3i WITH WIDTH > M3_S_20_wide_w) BY (M3_S_20_wide + grid)
    FRAMEA3OPC_M3_S_23_wide = SIZE (M3i WITH WIDTH > M3_S_23_wide_w) BY (M3_S_23_wide + grid)
    FRAMEA3OPC_M3_S_33_VIA2   = SIZE VIA2_HV_5V_CHK	BY (M3_S_33 + grid)
    FRAMEA3OPC_M3_S_33b_VIA2DV   = SIZE (VIA2i INTERACT (M2_HVN_330Vx OR M3_HVN_330Vx))	BY (M3_S_33b + grid)
    FRAMEA3OPC_M3_S_33_VIA3    = SIZE VIA3_HV_5V_CHK	BY (M3_S_33 + grid)
    FRAMEA3OPC_M3_S_33b_VIA3DV    = SIZE (VIA3i INTERACT (M3_HVN_330Vx OR M4_HVN_330Vx))	BY (M3_S_33b + grid)
    FRAMEA3OPC_M3_S_37_VIA2_b = SIZE VIA2i_55V		BY (M3_S_37 + grid)
    FRAMEA3OPC_M3_S_37a_VIA2_bDV = SIZE (VIA2i INTERACT (M2_HVN_500Vx OR M3_HVN_500Vx))		BY (M3_S_37a + grid)
    FRAMEA3OPC_M3_S_37_VIA3_b  = SIZE VIA3i_55V			BY (M3_S_37 + grid)
    FRAMEA3OPC_M3_S_37a_VIA3_bDV  = SIZE (VIA3i INTERACT (M3_HVN_500Vx OR M4_HVN_500Vx))		BY (M3_S_37a + grid)
    FRAMEA3OPC_M3_S_37_VIA2   = SIZE VIA2i_65V		BY (M3_S_37 + grid)
	FRAMEA3OPC_M3_S_37_VIA3    = SIZE VIA3i_65V			BY (M3_S_37 + grid)

    FRAMEHVD3 = SIZE  M3i_65V  BY (M3_S_38 + grid)
    FRAMEHVD3_55V = SIZE  M3i_55V  BY (M3_S_38 + grid)
    FRAMEHVD3_55VDV = SIZE  (M3i INTERACT M3_HVN_500Vx)  BY (M3_S_38a + grid)
    FRAMEB3 = SIZE (WITH WIDTH M3i > wideM3) BY (dm2WM3 + grid)
    FRAMEC3 = SIZE DUM3 BY (dm2DM3 + grid)
    FRAMED3 = SIZE (WITH WIDTH M3i > wideM3_small) BY (dm2WM3_small + grid)
    FRAMEC3OPC = SIZE DUM3 BY (Odm2DM3 + grid)
    FRAME3Pre = ((FRAMEA3 OR FRAMEB3) OR (FRAMEC3 OR FRAMED3)) OR M3ExcHole
    FRAME3PreOPC = (((((((((((((((((((((FRAMEA3OPC OR FRAMEC3OPC) OR M3ExcHole) OR FRAMEA3OPCwide) OR FRAMEA3OPC45) OR FRAMEA3OPC45DV) OR FRAMEA3OPC_M3_S_14_wide) OR FRAMEA3OPC_M3_S_17_wide) OR FRAMEA3OPC_M3_S_20_wide) OR FRAMEA3OPC_M3_S_23_wide) OR FRAMEA3OPC_M3_S_33_VIA2) OR FRAMEA3OPC_M3_S_33b_VIA2DV) OR FRAMEA3OPC_M3_S_33_VIA3) OR FRAMEA3OPC_M3_S_33b_VIA3DV) OR FRAMEHVD3) OR FRAMEA3OPC_M3_S_37_VIA2) OR FRAMEA3OPC_M3_S_37_VIA2_b) OR FRAMEA3OPC_M3_S_37a_VIA2_bDV) OR FRAMEA3OPC_M3_S_37_VIA3) OR FRAMEA3OPC_M3_S_37_VIA3_b) OR FRAMEA3OPC_M3_S_37a_VIA3_bDV) OR FRAMEHVD3_55V) OR FRAMEHVD3_55VDV


    FRAME3INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm3_s2m3_INDDMY + grid)
    FRAME3OPC = (((FRAME3PreOPC OR FRAME3INDDMY) OR xM3_DTCD) OR BLOCK3) OR NFILLOPC_x

    FRAME3 = (((FRAME3Pre OR FRAME3INDDMY) OR xM3_DTCD) OR BLOCK3) OR NFILL_x

    D30M3p = (PUSH D30M3) NOT FRAME3
    O30M3pre = D30M3p AND CHIP
    FD21M3s = COPY FRAME3

    O30M3preA = SIZE O30M3pre BY -DM3_303
    O30M3preB = O30M3preA WITH WIDTH >= WM3_303

    // 1st big
    F303M3 = RECTANGLES WM3_303 LM3_303 SM3_303 OFFSET OM3_303 INSIDE OF LAYER O30M3preB
    F303M3_SLOT = RECTANGLES WM3_303_SLOT LM3_303_SLOT SM3_303_SLOT INSIDE OF LAYER F303M3

    F303M3_EXP = SIZE F303M3_SLOT BY ( SM3_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M3preF1 = O30M3pre NOT (SIZE F303M3_EXP BY SM3_302)
    O30M3preF  = (SNAP (SIZE O30M3preF1 BY -grid) 5) AND O30M3preF1

    B30M3s = FD21M3s OR (SIZE F303M3_EXP BY (SM3_302+grid))
    O30M3 = O30M3preF NOT B30M3s

    // 3rd, middle
    F302M3 = RECTANGLES WM3_302 LM3_302 SM3_302 OFFSET OM3_302 INSIDE OF LAYER O30M3
    F302M3s = (SIZE F302M3 BY (SM3_301 + grid)) OR B30M3s
    R302M3pre = O30M3 NOT F302M3s
    R302M3 = WITH WIDTH R302M3pre >= WM3_301

    // 4th, small
    F3012M3 = RECTANGLES WM3_301 LM3_301 SM3_301 OFFSET OM3_301 INSIDE OF LAYER R302M3
    F3012M3s = (SIZE F3012M3 BY (SM3_301 + grid)) OR F302M3s
    R3012M3pre = R302M3pre NOT F3012M3s
    R3012M3 = WITH WIDTH R3012M3pre >= WM3_301

    // 5th, non-stagger small
    F301M3 = RECTANGLES WM3_301 LM3_301 SM3_301 INSIDE OF LAYER R3012M3 //MAINTAIN SPACING
    F301M3s = (SIZE F301M3 BY (SM3_301 + grid)) OR F3012M3s

    F30M3 = ((F302M3 OR F3012M3) OR F301M3) OR F303M3_SLOT
    O40M3pre = (((PUSH D40M3) NOT FRAME3) NOT F301M3s) AND CHIP


    O40M3preA = SIZE O40M3pre BY -DM3_403
    O40M3preB = O40M3preA WITH WIDTH >= WM3_403

    // 1st big
    F403M3 = RECTANGLES WM3_403 LM3_403 SM3_403 OFFSET OM3_403 INSIDE OF LAYER O40M3preB
    F403M3_SLOT = RECTANGLES WM3_403_SLOT LM3_403_SLOT SM3_403_SLOT INSIDE OF LAYER F403M3

    F403M3_EXP = SIZE F403M3_SLOT BY ( SM3_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M3preF1 = O40M3pre NOT (SIZE F403M3_EXP BY SM3_402)
    O40M3preF  = (SNAP (SIZE O40M3preF1 BY -grid) 5) AND O40M3preF1

    B40M3s = F301M3s OR (SIZE F403M3_EXP BY (SM3_402+grid))
    O40M3 = O40M3preF NOT B40M3s

    // 3rd, middle
    F402M3 = RECTANGLES WM3_402 LM3_402 SM3_402 OFFSET OM3_402 INSIDE OF LAYER O40M3
    F402M3s = (SIZE F402M3 BY (SM3_401 + grid)) OR B40M3s
    R402M3pre = O40M3 NOT F402M3s
    R402M3 = WITH WIDTH R402M3pre >= WM3_401

    // 4th, small
    F4012M3 = RECTANGLES WM3_401 LM3_401 SM3_401 OFFSET OM3_401 INSIDE OF LAYER R402M3
    F4012M3s = (SIZE F4012M3 BY (SM3_401 + grid)) OR F402M3s
    R4012M3pre = R402M3pre NOT F4012M3s
    R4012M3 = WITH WIDTH R4012M3pre >= WM3_401

    // 5th, non-stagger small
    F401M3 = RECTANGLES WM3_401 LM3_401 SM3_401 INSIDE OF LAYER R4012M3 //MAINTAIN SPACING
    F401M3s = (SIZE F401M3 BY (SM3_401 + grid)) OR F4012M3s

    F40M3 = ((F402M3 OR F4012M3) OR F401M3) OR F403M3_SLOT
    O50M3pre = (((PUSH (D50M3 OR emptyM3)) NOT FRAME3) NOT F401M3s) AND CHIP


    O50M3preA = SIZE O50M3pre BY -DM3_503
    O50M3preB = O50M3preA WITH WIDTH >= WM3_503

    // 1st big
    F503M3 = RECTANGLES WM3_503 LM3_503 SM3_503 OFFSET OM3_503 INSIDE OF LAYER O50M3preB
    F503M3_SLOT = RECTANGLES WM3_503_SLOT LM3_503_SLOT SM3_503_SLOT INSIDE OF LAYER F503M3

    F503M3_EXP = SIZE F503M3_SLOT BY ( SM3_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M3preF1 = O50M3pre NOT (SIZE F503M3_EXP BY SM3_502)
    O50M3preF  = (SNAP (SIZE O50M3preF1 BY -grid) 5) AND O50M3preF1

    B50M3s = F401M3s OR (SIZE F503M3_EXP BY (SM3_502+grid))
    O50M3 = O50M3preF NOT B50M3s

    // 3rd, middle
    F502M3 = RECTANGLES WM3_502 LM3_502 SM3_502 OFFSET OM3_502 INSIDE OF LAYER O50M3
    F502M3s = (SIZE F502M3 BY (SM3_501 + grid)) OR B50M3s
    R502M3pre = O50M3 NOT F502M3s
    R502M3 = WITH WIDTH R502M3pre >= WM3_501

    // 4th, small
    F5012M3 = RECTANGLES WM3_501 LM3_501 SM3_501 OFFSET OM3_501 INSIDE OF LAYER R502M3
    F5012M3s = (SIZE F5012M3 BY (SM3_501 + grid)) OR F502M3s
    R5012M3pre = R502M3pre NOT F5012M3s
    R5012M3 = WITH WIDTH R5012M3pre >= WM3_501

    // 5th, non-stagger small
    F501M3 = RECTANGLES WM3_501 LM3_501 SM3_501 INSIDE OF LAYER R5012M3 //MAINTAIN SPACING
    F501M3s = (SIZE F501M3 BY (SM3_501 + grid)) OR F5012M3s

    F50M3 = ((F502M3 OR F5012M3) OR F501M3) OR F503M3_SLOT

    exceedM3 = DENSITY M3x F30M3 F40M3 F50M3 > maxD_M3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M3.den_exceed

    removeM3R = ((PUSH (exceedM3 AND (D50M3 OR emptyM3))) NOT FRAME3) AND CHIP
    removeM3P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM3R

    F30M3x = F30M3 NOT INTERACT removeM3P
    F40M3x = F40M3 NOT INTERACT removeM3P
    F50M3x = F50M3 NOT INTERACT removeM3P
    FM3xA  = (F30M3x OR F40M3x) OR F50M3x
    FM3x   = FM3xA NOT INTERACT (EXT FM3xA < DM3_S_1 ABUT SINGULAR REGION)

    ALLM3x = M3x OR FM3x
    lackM3 = DENSITY ALLM3x CHIP < DM3_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M3.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM3x)/AREA(CHIP) ]

    WDM3EXC = DUM3 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM3EXC = (SIZE FM3x BY Odm2DM3) OR (SIZE (((F303M3_EXP OR F403M3_EXP) OR F503M3_EXP) OR WDM3EXC) BY 1.5)

    lackM3pRM = ((((PUSH lackM3) NOT RM3EXC) NOT FRAME3OPC) NOT exceedM3) AND CHIP
    lackM3pRM_1 = WITH WIDTH lackM3pRM >= SM3_OPC

    RM3p1 = RECTANGLES WM3_OPC LM3_OPC WSM3_OPC LSM3_OPC INSIDE OF LAYER lackM3pRM_1
    lackM3pRM_2 = lackM3pRM_1 NOT (SIZE RM3p1 BY SM3_OPC)
    RM3p2 = RECTANGLES LM3_OPC WM3_OPC LSM3_OPC WSM3_OPC INSIDE OF LAYER lackM3pRM_2

    ODM3A = ((RM3p1 OR RM3p2) OUTSIDE RM3EXC) OUTSIDE FRAME3OPC
    ODM3F_pre = ODM3A NOT INTERACT (EXT ODM3A < SM3_OPC ABUT SINGULAR REGION)

// M3.S.14 ~ M3.S.16
M3_S_14_CHK_REGION = M3i OR ODM3F_pre
// Find Wide Metal
Wide_M3_S_14_CHK_REGION = ENCLOSE RECTANGLE (M3_S_14_CHK_REGION NOT WITH WIDTH <= M3_S_14_W1B) M3_S_14_W1B+GRID M3_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M3_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M3_S_14_CHK_REGION == 0
Wide_M3_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M3_S_14_CHK_REGION == 90

// Find Wide Metal Space
M3_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M3_S_14_CHK_REGION_EDGE_H M3_S_14_CHK_REGION < M3_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M3_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M3_S_14_CHK_REGION_EDGE_V M3_S_14_CHK_REGION < M3_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M3_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M3_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M3_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M3_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M3_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M3_S_14_CHK_REGION_OPC_REGION_pre1_H M3_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M3_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M3_S_14_L1B
M3_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M3_S_14_CHK_REGION_OPC_REGION_pre1_V M3_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M3_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M3_S_14_L1B

M3_S_14_OPC_REGION = M3_S_14_CHK_REGION_OPC_REGION_pre2_H OR M3_S_14_CHK_REGION_OPC_REGION_pre2_V

// M3.S.17 ~ M3.S.19
M3_S_17_CHK_REGION = M3i OR ODM3F_pre
// Find Wide Metal
Wide_M3_S_17_CHK_REGION = ENCLOSE RECTANGLE (M3_S_17_CHK_REGION NOT WITH WIDTH <= M3_S_17_W1B) M3_S_17_W1B+GRID M3_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M3_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M3_S_17_CHK_REGION == 0
Wide_M3_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M3_S_17_CHK_REGION == 90

// Find Wide Metal Space
M3_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M3_S_17_CHK_REGION_EDGE_H M3_S_17_CHK_REGION < M3_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M3_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M3_S_17_CHK_REGION_EDGE_V M3_S_17_CHK_REGION < M3_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M3_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M3_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M3_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M3_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M3_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M3_S_17_CHK_REGION_OPC_REGION_pre1_H M3_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M3_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M3_S_17_L1B
M3_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M3_S_17_CHK_REGION_OPC_REGION_pre1_V M3_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M3_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M3_S_17_L1B

M3_S_17_OPC_REGION = M3_S_17_CHK_REGION_OPC_REGION_pre2_H OR M3_S_17_CHK_REGION_OPC_REGION_pre2_V

// M3.S.20 ~ M3.S.22
M3_S_20_CHK_REGION = M3i OR ODM3F_pre
// Find Wide Metal
Wide_M3_S_20_CHK_REGION = ENCLOSE RECTANGLE (M3_S_20_CHK_REGION NOT WITH WIDTH <= M3_S_20_W1B) M3_S_20_W1B+GRID M3_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M3_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M3_S_20_CHK_REGION == 0
Wide_M3_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M3_S_20_CHK_REGION == 90

// Find Wide Metal Space
M3_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M3_S_20_CHK_REGION_EDGE_H M3_S_20_CHK_REGION < M3_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M3_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M3_S_20_CHK_REGION_EDGE_V M3_S_20_CHK_REGION < M3_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M3_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M3_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M3_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M3_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M3_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M3_S_20_CHK_REGION_OPC_REGION_pre1_H M3_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M3_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M3_S_20_L1B
M3_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M3_S_20_CHK_REGION_OPC_REGION_pre1_V M3_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M3_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M3_S_20_L1B

M3_S_20_OPC_REGION = M3_S_20_CHK_REGION_OPC_REGION_pre2_H OR M3_S_20_CHK_REGION_OPC_REGION_pre2_V

// M3.S.23 ~ M3.S.25
M3_S_23_CHK_REGION = M3i OR ODM3F_pre
// Find Wide Metal
Wide_M3_S_23_CHK_REGION = ENCLOSE RECTANGLE (M3_S_23_CHK_REGION NOT WITH WIDTH <= M3_S_23_W1B) M3_S_23_W1B+GRID M3_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M3_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M3_S_23_CHK_REGION == 0
Wide_M3_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M3_S_23_CHK_REGION == 90

// Find Wide Metal Space
M3_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M3_S_23_CHK_REGION_EDGE_H M3_S_23_CHK_REGION < M3_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M3_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M3_S_23_CHK_REGION_EDGE_V M3_S_23_CHK_REGION < M3_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M3_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M3_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M3_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M3_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M3_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M3_S_23_CHK_REGION_OPC_REGION_pre1_H M3_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M3_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M3_S_23_L1B
M3_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M3_S_23_CHK_REGION_OPC_REGION_pre1_V M3_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M3_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M3_S_23_L1B

M3_S_23_OPC_REGION = M3_S_23_CHK_REGION_OPC_REGION_pre2_H OR M3_S_23_CHK_REGION_OPC_REGION_pre2_V

// M3.S.27
M3_S_27_CHK_REGION = M3i OR ODM3F_pre
// Find Wide Metal
Wide_M3_S_27_CHK_REGION = ENCLOSE RECTANGLE (M3_S_27_CHK_REGION NOT WITH WIDTH <= M3_S_27_W1B) M3_S_27_W1B+GRID M3_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M3_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M3_S_27_CHK_REGION == 0
Wide_M3_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M3_S_27_CHK_REGION == 90

// Find Wide Metal Space
M3_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M3_S_27_CHK_REGION_EDGE_H M3_S_27_CHK_REGION < M3_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M3_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M3_S_27_CHK_REGION_EDGE_V M3_S_27_CHK_REGION < M3_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M3_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M3_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M3_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M3_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M3_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M3_S_27_CHK_REGION_OPC_REGION_pre1_H M3_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M3_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M3_S_27_L1B
M3_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M3_S_27_CHK_REGION_OPC_REGION_pre1_V M3_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M3_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M3_S_27_L1B

M3_S_27_OPC_REGION = M3_S_27_CHK_REGION_OPC_REGION_pre2_H OR M3_S_27_CHK_REGION_OPC_REGION_pre2_V

M3_WMJ_OPC_REGION = (((M3_S_14_OPC_REGION OR M3_S_17_OPC_REGION) OR M3_S_20_OPC_REGION) OR M3_S_23_OPC_REGION) OR M3_S_27_OPC_REGION

    ODM3F = ODM3F_pre NOT INTERACT M3_WMJ_OPC_REGION

    DM3F = COPY FM3x

    FRAME3_INDDMYA = SIZE M3i BY (dm3_s2m3_INDDMY + grid)
    FRAME3_INDDMYB = SIZE DUM3 BY (dm3_s_INDDMY + grid)
    FRAME3_INDDMYC = SIZE DM3F BY dm3_s_INDDMY
    FRAME3_INDDMYD = SIZE ODM3F BY dm3_s2m3_INDDMY

    FRAME3_INDDMY  = ((((((FRAME3Pre OR xM3_DTCD) OR BLOCK3) OR FRAME3_INDDMYA) OR FRAME3_INDDMYB) OR FRAME3_INDDMYC) OR FRAME3_INDDMYD) OR NFILL_x
    FILL3_INDDMY   = ooINDDMY NOT FRAME3_INDDMY
    DM3F_INDDMY    = RECTANGLES dm3_w_INDDMY dm3_l_INDDMY dm3_s_INDDMY INSIDE OF LAYER FILL3_INDDMY

#IFDEF FILL_indDM3
    FILL3_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm3_s_INDDMY_HD + grid)) NOT FRAME3_INDDMY
    DM3F_INDDMY_HD_pre  = RECTANGLES dm3_w_INDDMY_HD dm3_l_INDDMY_HD dm3_s_INDDMY_HD INSIDE OF LAYER FILL3_INDDMY_HD

    FILL3_INDDMY_MD = (SIZE INDDMY_MD BY -(dm3_s_INDDMY_MD + grid)) NOT (FRAME3_INDDMY OR INDDMY_HD)
    DM3F_INDDMY_MD  = RECTANGLES dm3_w_INDDMY_MD dm3_l_INDDMY_MD dm3_s_INDDMY_MD INSIDE OF LAYER FILL3_INDDMY_MD

    DM3F_INDDMY_HD = DM3F_INDDMY_HD_pre OR DM3F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#IFDEF FILL_DM4


#IFDEF 34K_THICK_Mu_M4

    minOPENM4 = DENSITY M4x < minD_M4 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M4Min.den
    emptyOPENM4 = DENSITY M4x < emptyD_M4 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M4Empty.den

    M4InnerHole = HOLES M4i INNER

    M4BigHole = SIZE M4InnerHole BY - excludeHoleSize/2
    M4ExcHole = ((M4InnerHole OUTSIDE M4BigHole) NOT M4i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK4    = (SIZE DM4EXCL BY (dm2DMEXCL + grid)) OR MIM4_x
    FRAMEA4   = SIZE M4i BY (dm2M4 + grid) // DM4 to metal
    FRAMEB4   = SIZE (WITH WIDTH M4i > wideM4) BY (dm2WM4 + grid)
    FRAMEC4   = SIZE DUM4 BY (dm2DM4 + grid)
    FRAME4Pre = ((FRAMEA4 OR FRAMEB4) OR FRAMEC4) OR M4ExcHole
    FRAME4INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm4_s2m4_INDDMY + grid)
    FRAME4 = ((FRAME4Pre OR FRAME4INDDMY) OR BLOCK4) OR NFILL
    
    OPENM4 = PUSH ((minOPENM4 OR emptyOPENM4) AND CHIP)
    FILL4 = OPENM4 NOT FRAME4
    FILLW4pre = SIZE FILL4 BY - (Wdm2M4 + grid)
    FILLW4 = WITH WIDTH FILLW4pre >= WdmW_M4
    M4FW = RECTANGLES WdmW_M4 WdmL_M4 WdmS_M4 OFFSET WdmO_M4 INSIDE OF LAYER FILLW4
    M4FW_EXP = SIZE M4FW BY (WdmS_M4 /2 + grid) OVERUNDER   // merge the gaps
    FILLM4pre = FILL4 NOT (SIZE M4FW_EXP BY (MdmS_M4 + grid))
    FILLM4 = WITH WIDTH FILLM4pre >= MdmW_M4
    M4F1 = RECTANGLES MdmW_M4 MdmL_M4 MdmS_M4 OFFSET MdmO_M4 INSIDE OF LAYER FILLM4
    M4R1pre = FILLM4pre NOT (SIZE M4F1 BY (dmS_M4 + grid))
    M4R1 = WITH WIDTH M4R1pre >= dmW_M4

    M4F2 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 OFFSET dmO_M4 INSIDE OF LAYER M4R1
    M4R2pre = M4R1 NOT (SIZE M4F2 BY (dmS_M4 + grid))
    M4R2 = WITH WIDTH M4R2pre >= dmW_M4

    M4F3 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 OFFSET dmO_M4 INSIDE OF LAYER M4R2
    M4R3pre = M4R2 NOT (SIZE M4F3 BY (dmS_M4 + grid))
    M4R3 = WITH WIDTH M4R3pre >= dmW_M4

    M4F4 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 INSIDE OF LAYER M4R3

    M4F = (((M4F1 OR M4F2) OR M4F3) OR M4F4) OR M4FW
    FM4 = M4F NOT INTERACT (EXT M4F < dmS_M4 ABUT SINGULAR REGION)

    maxOPENM4 = DENSITY M4x FM4 > maxD_M4 WINDOW WindowSizeu*2 STEP WindowStepu*2
                INSIDE OF LAYER bulk BACKUP // PRINT M4Max.den

    DM4F = FM4 OUTSIDE maxOPENM4

    FRAME4_INDDMYA = SIZE M4i BY (dm4_s2m4_INDDMY + grid)
    FRAME4_INDDMYB = SIZE DUM4 BY (dm4_s_INDDMY + grid)
    FRAME4_INDDMYC = SIZE DM4F BY dm4_s_INDDMY
    FRAME4_INDDMY  = ((((FRAME4Pre OR BLOCK4) OR FRAME4_INDDMYA) OR FRAME4_INDDMYB) OR FRAME4_INDDMYC) OR NFILL
    FILL4_INDDMY   = ooINDDMY NOT FRAME4_INDDMY
    DM4F_INDDMY    = RECTANGLES dm4_w_INDDMY dm4_l_INDDMY dm4_s_INDDMY INSIDE OF LAYER FILL4_INDDMY
#IFDEF FILL_indDM4
    FILL4_INDDMY_HD = (SIZE INDDMY_HD BY -(dm4_s_INDDMY_HD + grid)) NOT FRAME4_INDDMY
    DM4F_INDDMY_HD  = RECTANGLES dm4_w_INDDMY_HD dm4_l_INDDMY_HD dm4_s_INDDMY_HD INSIDE OF LAYER FILL4_INDDMY_HD
#ENDIF	
	
#ELSE


#IFDEF 12K_THICK_Mr_M4

    minOPENM4 = DENSITY M4x < minD_M4 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M4Min.den
    emptyOPENM4 = DENSITY M4x < emptyD_M4 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M4Empty.den

    M4InnerHole = HOLES M4i INNER

    M4BigHole = SIZE M4InnerHole BY - excludeHoleSize/2
    M4ExcHole = ((M4InnerHole OUTSIDE M4BigHole) NOT M4i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK4  = (SIZE DM4EXCL BY (dm2DMEXCL + grid)) OR MIM4_x // DM4 to DM4EXCL
    FRAMEA4 = SIZE M4i BY (dm2M4 + grid) // DM4 to metal
    FRAMEB4 = SIZE (WITH WIDTH M4i > wideM4) BY (dm2WM4 + grid)
    FRAMEC4 = SIZE DUM4 BY (dm2DM4 + grid)   // DM4 to existed dummy metal 0.6um
    FRAME4Pre = ((FRAMEA4 OR FRAMEB4) OR FRAMEC4) OR M4ExcHole
    FRAME4INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm4_s2m4_INDDMY + grid)
    FRAME4 = ((FRAME4Pre OR FRAME4INDDMY) OR BLOCK4) OR NFILL
    
    OPENM4 = PUSH ((minOPENM4 OR emptyOPENM4) AND CHIP)
    FILL4 = OPENM4 NOT FRAME4
    FILLW4pre = SIZE FILL4 BY - (Wdm2M4 + grid)
    FILLW4 = WITH WIDTH FILLW4pre >= WdmW_M4
    M4FW = RECTANGLES WdmW_M4 WdmL_M4 WdmS_M4 OFFSET WdmO_M4 INSIDE OF LAYER FILLW4
    M4FW_EXP = SIZE M4FW BY (WdmS_M4 /2 + grid) OVERUNDER //merge the gaps
    FILLM4pre = FILL4 NOT (SIZE M4FW_EXP BY (MdmS_M4 + grid))
    FILLM4 = WITH WIDTH FILLM4pre >= MdmW_M4
    M4F1 = RECTANGLES MdmW_M4 MdmL_M4 MdmS_M4 OFFSET MdmO_M4 INSIDE OF LAYER FILLM4
    M4R1pre = FILLM4pre NOT (SIZE M4F1 BY (dmS_M4 + grid))
    M4R1 = WITH WIDTH M4R1pre >= dmW_M4

    M4F2 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 OFFSET dmO_M4 INSIDE OF LAYER M4R1
    M4R2pre = M4R1 NOT (SIZE M4F2 BY (dmS_M4 + grid))
    M4R2 = WITH WIDTH M4R2pre >= dmW_M4

    M4F3 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 OFFSET dmO_M4 INSIDE OF LAYER M4R2
    M4R3pre = M4R2 NOT (SIZE M4F3 BY (dmS_M4 + grid))
    M4R3 = WITH WIDTH M4R3pre >= dmW_M4

    M4F4 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 INSIDE OF LAYER M4R3

    M4F = (((M4F1 OR M4F2) OR M4F3) OR M4F4) OR M4FW
    FM4 = M4F NOT INTERACT (EXT M4F < dmS_M4 ABUT SINGULAR REGION)

    maxOPENM4 = DENSITY M4x FM4 > maxD_M4 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M4Max.den

    FM4F = FM4 OUTSIDE maxOPENM4

    // DMr_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M4 = DENSITY M4x FM4F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M4Min.den

    RM4EXC = SIZE FM4F BY (Odm2DM4 + grid)
    // do not fill DMy_S over CTMDMY
    D25M4pM = (((PUSH D25M4) NOT FRAME4) NOT RM4EXC) AND CHIP
    D25M4pM_1 = WITH WIDTH D25M4pM >= OdmW_M4

    RM4p1 = RECTANGLES OdmW_M4 OdmL_M4 OdmS_M4 INSIDE OF LAYER D25M4pM_1
    D25M4pM_2 = D25M4pM_1 NOT (SIZE RM4p1 BY (OdmS_M4 + grid))
    RM4p2 = RECTANGLES OdmL_M4 OdmW_M4 OdmS_M4 INSIDE OF LAYER D25M4pM_2

    RM4A = ((RM4p1 OR RM4p2) OUTSIDE RM4EXC) OUTSIDE FRAME4
    RM4  = RM4A NOT INTERACT (EXT RM4A < OdmS_M4 ABUT SINGULAR REGION)

    DM4F = FM4F OR RM4

    FRAME4_INDDMYA = SIZE M4i BY (dm4_s2m4_INDDMY + grid)
    FRAME4_INDDMYB = SIZE DUM4 BY (dm4_s_INDDMY + grid)
    FRAME4_INDDMYC = SIZE DM4F BY dm4_s_INDDMY
    FRAME4_INDDMY  = ((((FRAME4Pre OR BLOCK4) OR FRAME4_INDDMYA) OR FRAME4_INDDMYB) OR FRAME4_INDDMYC) OR NFILL
    FILL4_INDDMY   = ooINDDMY NOT FRAME4_INDDMY
    DM4F_INDDMY    = RECTANGLES dm4_w_INDDMY dm4_l_INDDMY dm4_s_INDDMY INSIDE OF LAYER FILL4_INDDMY

#IFDEF FILL_indDM4
    FILL4_INDDMY_HD = (SIZE INDDMY_HD BY -(dm4_s_INDDMY_HD + grid)) NOT FRAME4_INDDMY
    DM4F_INDDMY_HD  = RECTANGLES dm4_w_INDDMY_HD dm4_l_INDDMY_HD dm4_s_INDDMY_HD INSIDE OF LAYER FILL4_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 5K_THICK_Myz_M4

    minOPENM4 = DENSITY M4x < minD_M4 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M4Min.den
    emptyOPENM4 = DENSITY M4x < emptyD_M4 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M4Empty.den

    M4InnerHole = HOLES M4i INNER

    M4BigHole = SIZE M4InnerHole BY - excludeHoleSize/2
    M4ExcHole = ((M4InnerHole OUTSIDE M4BigHole) NOT M4i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK4 = (SIZE DM4EXCL BY (dm2DMEXCL + grid)) OR MIM4_x // DM4 to DM4EXCL
    FRAMEA4 = SIZE M4i BY (dm2M4 + grid) // DM4 to metal
    FRAMEB4 = SIZE (WITH WIDTH M4i > wideM4) BY (dm2WM4 + grid)
    FRAMEC4 = SIZE DUM4 BY (dm2DM4 + grid)   // DM4 to existed dummy metal 0.6um
    FRAME4Pre = ((FRAMEA4 OR FRAMEB4) OR FRAMEC4) OR M4ExcHole
    FRAME4INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm4_s2m4_INDDMY + grid)
    FRAME4 = ((FRAME4Pre OR FRAME4INDDMY) OR BLOCK4) OR NFILL
    
    OPENM4 = PUSH ((minOPENM4 OR emptyOPENM4) AND CHIP)
    FILL4 = OPENM4 NOT FRAME4
    FILLW4pre = SIZE FILL4 BY - (Wdm2M4 + grid)
    FILLW4 = WITH WIDTH FILLW4pre >= WdmW_M4
    M4FW = RECTANGLES WdmW_M4 WdmL_M4 WdmS_M4 OFFSET WdmO_M4 INSIDE OF LAYER FILLW4
    M4FW_EXP = SIZE M4FW BY (WdmS_M4 /2 + grid) OVERUNDER //merge the gaps
    FILLM4pre = FILL4 NOT (SIZE M4FW_EXP BY (MdmS_M4 + grid))
    FILLM4 = WITH WIDTH FILLM4pre >= MdmW_M4
    M4F1 = RECTANGLES MdmW_M4 MdmL_M4 MdmS_M4 OFFSET MdmO_M4 INSIDE OF LAYER FILLM4
    M4R1pre = FILLM4pre NOT (SIZE M4F1 BY (dmS_M4 + grid))
    M4R1 = WITH WIDTH M4R1pre >= dmW_M4

    M4F2 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 OFFSET dmO_M4 INSIDE OF LAYER M4R1
    M4R2pre = M4R1 NOT (SIZE M4F2 BY (dmS_M4 + grid))
    M4R2 = WITH WIDTH M4R2pre >= dmW_M4

    M4F3 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 OFFSET dmO_M4 INSIDE OF LAYER M4R2
    M4R3pre = M4R2 NOT (SIZE M4F3 BY (dmS_M4 + grid))
    M4R3 = WITH WIDTH M4R3pre >= dmW_M4

    M4F4 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 INSIDE OF LAYER M4R3

