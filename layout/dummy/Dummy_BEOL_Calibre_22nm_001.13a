    FRAME12_INDDMY  = ((((FRAME12Pre OR BLOCK12) OR FRAME12_INDDMYA) OR FRAME12_INDDMYB) OR FRAME12_INDDMYC) OR NFILL
    FILL12_INDDMY   = ooINDDMY NOT FRAME12_INDDMY
