#ENDIF

// Find DVIA7 fillable regions.  Consider enclosure to lower DM7, enclosure to upper DM8, DVIA7 size.

VARIABLE DM7_F_4_REGION_DVIA7_SHORTENED_LENGTH DVIA7_EN_2 - DVIA7_EN_1

#IFDEF VERTICAL_DM7
DM7_F_4_REGION_DVIA7_spec_B_pre = RECTANGLE DM7F_FOR_DVIA7F_REGION == WM7_303_SLOT BY == LM7_303_SLOT
DM7_F_4_REGION_DVIA7_spec_B     = DM7_F_4_REGION_DVIA7_spec_B_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA7_spec_B_pre == WM7_303_SLOT) INSIDE BY DM7_F_4_REGION_DVIA7_SHORTENED_LENGTH)

DM7_F_4_REGION_DVIA7_spec_M_pre = RECTANGLE DM7F_FOR_DVIA7F_REGION == WM7_302 BY == LM7_302
DM7_F_4_REGION_DVIA7_spec_M     = DM7_F_4_REGION_DVIA7_spec_M_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA7_spec_M_pre == WM7_302) INSIDE BY DM7_F_4_REGION_DVIA7_SHORTENED_LENGTH)

DM7_F_4_REGION_DVIA7_spec_S_pre = RECTANGLE DM7F_FOR_DVIA7F_REGION == WM7_301 BY == LM7_301
DM7_F_4_REGION_DVIA7_spec_S     = DM7_F_4_REGION_DVIA7_spec_S_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA7_spec_S_pre == WM7_301) INSIDE BY DM7_F_4_REGION_DVIA7_SHORTENED_LENGTH)
#ELSE
DM7_F_4_REGION_DVIA7_spec_B_pre = RECTANGLE DM7F_FOR_DVIA7F_REGION == LM7_303_SLOT BY == WM7_303_SLOT
DM7_F_4_REGION_DVIA7_spec_B     = DM7_F_4_REGION_DVIA7_spec_B_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA7_spec_B_pre == LM7_303_SLOT) INSIDE BY DM7_F_4_REGION_DVIA7_SHORTENED_LENGTH)

DM7_F_4_REGION_DVIA7_spec_M_pre = RECTANGLE DM7F_FOR_DVIA7F_REGION == LM7_302 BY == WM7_302
DM7_F_4_REGION_DVIA7_spec_M     = DM7_F_4_REGION_DVIA7_spec_M_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA7_spec_M_pre == LM7_302) INSIDE BY DM7_F_4_REGION_DVIA7_SHORTENED_LENGTH)

DM7_F_4_REGION_DVIA7_spec_S_pre = RECTANGLE DM7F_FOR_DVIA7F_REGION == LM7_301 BY == WM7_301
DM7_F_4_REGION_DVIA7_spec_S     = DM7_F_4_REGION_DVIA7_spec_S_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA7_spec_S_pre == LM7_301) INSIDE BY DM7_F_4_REGION_DVIA7_SHORTENED_LENGTH)
#ENDIF
DM7_F_4_REGION_DVIA7_square_pre = RECTANGLE DM7F_FOR_DVIA7F_REGION ASPECT == 1
DM7_F_4_REGION_DVIA7_square     = SIZE DM7_F_4_REGION_DVIA7_square_pre BY -DM7_F_4_REGION_DVIA7_SHORTENED_LENGTH

DM7F_FOR_DVIA7F_REGION_4parts = (DM7_F_4_REGION_DVIA7_spec_B OR DM7_F_4_REGION_DVIA7_spec_M) OR (DM7_F_4_REGION_DVIA7_spec_S OR DM7_F_4_REGION_DVIA7_square)
DM7F_FOR_DVIA7F_REGION_remainder_pre_not = (DM7_F_4_REGION_DVIA7_spec_B_pre OR DM7_F_4_REGION_DVIA7_spec_M_pre) OR (DM7_F_4_REGION_DVIA7_spec_S_pre OR DM7_F_4_REGION_DVIA7_square_pre)
DM7F_FOR_DVIA7F_REGION_remainder = DM7F_FOR_DVIA7F_REGION NOT DM7F_FOR_DVIA7F_REGION_remainder_pre_not

    DM7F_FOR_DVIA7F_REGION_remainder_EDGE = LENGTH DM7F_FOR_DVIA7F_REGION_remainder > 0
    DM7F_FOR_DVIA7F_REGION_remainder_PROP = DFM PROPERTY DM7F_FOR_DVIA7F_REGION_remainder DM7F_FOR_DVIA7F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM7F_FOR_DVIA7F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM7F_FOR_DVIA7F_REGION_remainder_EDGE)) ]
    DM7F_FOR_DVIA7F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM7F_FOR_DVIA7F_REGION_remainder_EDGE DM7F_FOR_DVIA7F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM7F_FOR_DVIA7F_REGION_remainder_EDGE) - PROPERTY(DM7F_FOR_DVIA7F_REGION_remainder_PROP, DM7F_FOR_DVIA7F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM7F_FOR_DVIA7F_REGION2 = DM7F_FOR_DVIA7F_REGION_remainder NOT (EXPAND EDGE DM7F_FOR_DVIA7F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM7_F_4_REGION_DVIA7_SHORTENED_LENGTH)


VARIABLE DM8_F_4_REGION_DVIA7_SHORTENED_LENGTH DM8_EN_3 - DM8_EN_2

#IFDEF VERTICAL_DM8
DM8_F_4_REGION_DVIA7_spec_B_pre = RECTANGLE DM8F_FOR_DVIA7F_REGION == WM8_303_SLOT BY == LM8_303_SLOT
DM8_F_4_REGION_DVIA7_spec_B     = DM8_F_4_REGION_DVIA7_spec_B_pre NOT (EXPAND EDGE (LENGTH DM8_F_4_REGION_DVIA7_spec_B_pre == WM8_303_SLOT) INSIDE BY DM8_F_4_REGION_DVIA7_SHORTENED_LENGTH)

DM8_F_4_REGION_DVIA7_spec_M_pre = RECTANGLE DM8F_FOR_DVIA7F_REGION == WM8_302 BY == LM8_302
DM8_F_4_REGION_DVIA7_spec_M     = DM8_F_4_REGION_DVIA7_spec_M_pre NOT (EXPAND EDGE (LENGTH DM8_F_4_REGION_DVIA7_spec_M_pre == WM8_302) INSIDE BY DM8_F_4_REGION_DVIA7_SHORTENED_LENGTH)

DM8_F_4_REGION_DVIA7_spec_S_pre = RECTANGLE DM8F_FOR_DVIA7F_REGION == WM8_301 BY == LM8_301
DM8_F_4_REGION_DVIA7_spec_S     = DM8_F_4_REGION_DVIA7_spec_S_pre NOT (EXPAND EDGE (LENGTH DM8_F_4_REGION_DVIA7_spec_S_pre == WM8_301) INSIDE BY DM8_F_4_REGION_DVIA7_SHORTENED_LENGTH)
#ELSE
DM8_F_4_REGION_DVIA7_spec_B_pre = RECTANGLE DM8F_FOR_DVIA7F_REGION == LM8_303_SLOT BY == WM8_303_SLOT
DM8_F_4_REGION_DVIA7_spec_B     = DM8_F_4_REGION_DVIA7_spec_B_pre NOT (EXPAND EDGE (LENGTH DM8_F_4_REGION_DVIA7_spec_B_pre == LM8_303_SLOT) INSIDE BY DM8_F_4_REGION_DVIA7_SHORTENED_LENGTH)

DM8_F_4_REGION_DVIA7_spec_M_pre = RECTANGLE DM8F_FOR_DVIA7F_REGION == LM8_302 BY == WM8_302
DM8_F_4_REGION_DVIA7_spec_M     = DM8_F_4_REGION_DVIA7_spec_M_pre NOT (EXPAND EDGE (LENGTH DM8_F_4_REGION_DVIA7_spec_M_pre == LM8_302) INSIDE BY DM8_F_4_REGION_DVIA7_SHORTENED_LENGTH)

DM8_F_4_REGION_DVIA7_spec_S_pre = RECTANGLE DM8F_FOR_DVIA7F_REGION == LM8_301 BY == WM8_301
DM8_F_4_REGION_DVIA7_spec_S     = DM8_F_4_REGION_DVIA7_spec_S_pre NOT (EXPAND EDGE (LENGTH DM8_F_4_REGION_DVIA7_spec_S_pre == LM8_301) INSIDE BY DM8_F_4_REGION_DVIA7_SHORTENED_LENGTH)
#ENDIF

DM8_F_4_REGION_DVIA7_square_pre = RECTANGLE DM8F_FOR_DVIA7F_REGION ASPECT == 1
DM8_F_4_REGION_DVIA7_square     = SIZE DM8_F_4_REGION_DVIA7_square_pre BY -DM8_F_4_REGION_DVIA7_SHORTENED_LENGTH

DM8F_FOR_DVIA7F_REGION_4parts = (DM8_F_4_REGION_DVIA7_spec_B OR DM8_F_4_REGION_DVIA7_spec_M) OR (DM8_F_4_REGION_DVIA7_spec_S OR DM8_F_4_REGION_DVIA7_square)
DM8F_FOR_DVIA7F_REGION_remainder_pre_not = (DM8_F_4_REGION_DVIA7_spec_B_pre OR DM8_F_4_REGION_DVIA7_spec_M_pre) OR (DM8_F_4_REGION_DVIA7_spec_S_pre OR DM8_F_4_REGION_DVIA7_square_pre)
DM8F_FOR_DVIA7F_REGION_remainder = DM8F_FOR_DVIA7F_REGION NOT DM8F_FOR_DVIA7F_REGION_remainder_pre_not

    DM8F_FOR_DVIA7F_REGION_remainder_EDGE = LENGTH DM8F_FOR_DVIA7F_REGION_remainder > 0
    DM8F_FOR_DVIA7F_REGION_remainder_PROP = DFM PROPERTY DM8F_FOR_DVIA7F_REGION_remainder DM8F_FOR_DVIA7F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM8F_FOR_DVIA7F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM8F_FOR_DVIA7F_REGION_remainder_EDGE)) ]
    DM8F_FOR_DVIA7F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM8F_FOR_DVIA7F_REGION_remainder_EDGE DM8F_FOR_DVIA7F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM8F_FOR_DVIA7F_REGION_remainder_EDGE) - PROPERTY(DM8F_FOR_DVIA7F_REGION_remainder_PROP, DM8F_FOR_DVIA7F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM8F_FOR_DVIA7F_REGION2 = DM8F_FOR_DVIA7F_REGION_remainder NOT (EXPAND EDGE DM8F_FOR_DVIA7F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM8_F_4_REGION_DVIA7_SHORTENED_LENGTH)

DVIA7F_BASE_REGION = (((((SIZE (DM7F_FOR_DVIA7F_REGION2 OR DM7F_FOR_DVIA7F_REGION_4parts) BY -DVIA7_EN_1) AND (SIZE (DM8F_FOR_DVIA7F_REGION2 OR DM8F_FOR_DVIA7F_REGION_4parts) BY -DM8_EN_2)) WITH WIDTH >= DVIA7_W_1) NOT (SIZE DVIA7EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA7i BY (DVIA7_S_1 + grid))) NOT (SIZE VIA7i BY (DVIA7_S_2 + grid))




// Merge DVIA7 fillable regions, and find DVIA7 seeds by maintaining spacing DVIA7_S_1.
DVIA7F_SEED_REGION_1 = (((SIZE DVIA7F_BASE_REGION BY DVIA7F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA7EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA7i BY (DVIA7_S_1 + grid))) NOT (SIZE VIA7i BY (DVIA7_S_2 + grid))
DVIA7F_SEED_1 = RECTANGLES DVIA7_W_1 DVIA7_W_1 DVIA7_S_1 INSIDE OF LAYER DVIA7F_SEED_REGION_1

// Find DVIA7 in the DVIA7 fillable and spacing-maintained regions.
DVIA7F_REGION_1 = (DVIA7F_BASE_REGION INTERACT DVIA7F_SEED_1) NOT TOUCH DVIA7F_SEED_1
DVIA7F_pre1_1_pre1 = RECTANGLES DVIA7_W_1 DVIA7_W_1 DVIA7_S_1 INSIDE OF LAYER DVIA7F_REGION_1

// post-DRC
DVIA7F_pre1_1_pre2 = DVIA7F_pre1_1_pre1 NOT INTERACT (EXT DVIA7F_pre1_1_pre1 < DVIA7_S_1 ABUT SINGULAR REGION)
DVIA7F_pre1_1_pre3 = DVIA7F_pre1_1_pre2 NOT INTERACT (EXT DVIA7F_pre1_1_pre2 DUVIA7i < DVIA7_S_1 ABUT SINGULAR REGION)
DVIA7F_pre1_1_pre4 = DVIA7F_pre1_1_pre3 NOT INTERACT (EXT DVIA7F_pre1_1_pre3 VIA7i < DVIA7_S_2 ABUT SINGULAR REGION)
DVIA7F_pre1_1_pre5 = DVIA7F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA7F_pre1_1_pre4 DM7F_FOR_DVIA7F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA7_EN_2 OPPOSITE 0 DVIA7_EN_2 OPPOSITE)
DVIA7F_pre1_1      = DVIA7F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA7F_pre1_1_pre5 DM8F_FOR_DVIA7F_REGION ABUT < 90 SINGULAR GOOD 0 DM8_EN_3 OPPOSITE 0 DM8_EN_3 OPPOSITE)

// Merge DVIA7 fillable regions, and find DVIA7 seeds by maintaining spacing DVIA7_S_1.
DVIA7F_SEED_REGION_2 = (((SIZE (DVIA7F_BASE_REGION NOT INTERACT (SIZE DVIA7F_pre1_1 BY DVIA7_S_1)) BY DVIA7F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA7EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA7i BY (DVIA7_S_1 + grid))) NOT (SIZE VIA7i BY (DVIA7_S_2 + grid))
DVIA7F_SEED_2 = RECTANGLES DVIA7_W_1 DVIA7_W_1 DVIA7_S_1 INSIDE OF LAYER DVIA7F_SEED_REGION_2

// Find DVIA7 in the DVIA7 fillable and spacing-maintained regions.
DVIA7F_REGION_2 = (DVIA7F_BASE_REGION INTERACT DVIA7F_SEED_2) NOT TOUCH DVIA7F_SEED_2
DVIA7F_pre1_2 = RECTANGLES DVIA7_W_1 DVIA7_W_1 DVIA7_S_1 INSIDE OF LAYER DVIA7F_REGION_2

// post-DRC
DVIA7F_pre1 = DVIA7F_pre1_1 OR DVIA7F_pre1_2
DVIA7F_pre2 = DVIA7F_pre1 NOT INTERACT (EXT DVIA7F_pre1 < DVIA7_S_1 ABUT SINGULAR REGION)
DVIA7F_pre3 = DVIA7F_pre2 NOT INTERACT (EXT DVIA7F_pre2 DUVIA7i < DVIA7_S_1 ABUT SINGULAR REGION)
DVIA7F_pre4 = DVIA7F_pre3 NOT INTERACT (EXT DVIA7F_pre3 VIA7i < DVIA7_S_2 ABUT SINGULAR REGION)
DVIA7F_pre5 = DVIA7F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA7F_pre4 DM7F_FOR_DVIA7F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA7_EN_2 OPPOSITE 0 DVIA7_EN_2 OPPOSITE)
DVIA7F      = DVIA7F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA7F_pre5 DM8F_FOR_DVIA7F_REGION ABUT < 90 SINGULAR GOOD 0 DM8_EN_3 OPPOSITE 0 DM8_EN_3 OPPOSITE)

#ENDIF
