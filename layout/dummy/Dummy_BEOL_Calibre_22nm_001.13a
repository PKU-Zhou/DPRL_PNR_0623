#ELSE




#IFDEF FILL_DM5
DM5F_FOR_DVIA5F_REGION = ((DM5F OR DUM5) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM5F_FOR_DVIA5F_REGION = (DUM5 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

#IFDEF FILL_DM6
DM6F_FOR_DVIA5F_REGION = ((DM6F OR DUM6) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM6F_FOR_DVIA5F_REGION = (DUM6 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

// Find DVIA5 fillable regions.  Consider enclosure to lower DM5, enclosure to upper DM6, DVIA5 size.

VARIABLE DM5_F_4_REGION_DVIA5_SHORTENED_LENGTH DVIA5_EN_2 - DVIA5_EN_1

#IFDEF VERTICAL_DM5
DM5_F_4_REGION_DVIA5_spec_B_pre = RECTANGLE DM5F_FOR_DVIA5F_REGION == WM5_303_SLOT BY == LM5_303_SLOT
DM5_F_4_REGION_DVIA5_spec_B     = DM5_F_4_REGION_DVIA5_spec_B_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA5_spec_B_pre == WM5_303_SLOT) INSIDE BY DM5_F_4_REGION_DVIA5_SHORTENED_LENGTH)

DM5_F_4_REGION_DVIA5_spec_M_pre = RECTANGLE DM5F_FOR_DVIA5F_REGION == WM5_302 BY == LM5_302
DM5_F_4_REGION_DVIA5_spec_M     = DM5_F_4_REGION_DVIA5_spec_M_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA5_spec_M_pre == WM5_302) INSIDE BY DM5_F_4_REGION_DVIA5_SHORTENED_LENGTH)

DM5_F_4_REGION_DVIA5_spec_S_pre = RECTANGLE DM5F_FOR_DVIA5F_REGION == WM5_301 BY == LM5_301
DM5_F_4_REGION_DVIA5_spec_S     = DM5_F_4_REGION_DVIA5_spec_S_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA5_spec_S_pre == WM5_301) INSIDE BY DM5_F_4_REGION_DVIA5_SHORTENED_LENGTH)
#ELSE
DM5_F_4_REGION_DVIA5_spec_B_pre = RECTANGLE DM5F_FOR_DVIA5F_REGION == LM5_303_SLOT BY == WM5_303_SLOT
DM5_F_4_REGION_DVIA5_spec_B     = DM5_F_4_REGION_DVIA5_spec_B_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA5_spec_B_pre == LM5_303_SLOT) INSIDE BY DM5_F_4_REGION_DVIA5_SHORTENED_LENGTH)

DM5_F_4_REGION_DVIA5_spec_M_pre = RECTANGLE DM5F_FOR_DVIA5F_REGION == LM5_302 BY == WM5_302
DM5_F_4_REGION_DVIA5_spec_M     = DM5_F_4_REGION_DVIA5_spec_M_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA5_spec_M_pre == LM5_302) INSIDE BY DM5_F_4_REGION_DVIA5_SHORTENED_LENGTH)

DM5_F_4_REGION_DVIA5_spec_S_pre = RECTANGLE DM5F_FOR_DVIA5F_REGION == LM5_301 BY == WM5_301
DM5_F_4_REGION_DVIA5_spec_S     = DM5_F_4_REGION_DVIA5_spec_S_pre NOT (EXPAND EDGE (LENGTH DM5_F_4_REGION_DVIA5_spec_S_pre == LM5_301) INSIDE BY DM5_F_4_REGION_DVIA5_SHORTENED_LENGTH)
#ENDIF
DM5_F_4_REGION_DVIA5_square_pre = RECTANGLE DM5F_FOR_DVIA5F_REGION ASPECT == 1
DM5_F_4_REGION_DVIA5_square     = SIZE DM5_F_4_REGION_DVIA5_square_pre BY -DM5_F_4_REGION_DVIA5_SHORTENED_LENGTH

DM5F_FOR_DVIA5F_REGION_4parts = (DM5_F_4_REGION_DVIA5_spec_B OR DM5_F_4_REGION_DVIA5_spec_M) OR (DM5_F_4_REGION_DVIA5_spec_S OR DM5_F_4_REGION_DVIA5_square)
DM5F_FOR_DVIA5F_REGION_remainder_pre_not = (DM5_F_4_REGION_DVIA5_spec_B_pre OR DM5_F_4_REGION_DVIA5_spec_M_pre) OR (DM5_F_4_REGION_DVIA5_spec_S_pre OR DM5_F_4_REGION_DVIA5_square_pre)
DM5F_FOR_DVIA5F_REGION_remainder = DM5F_FOR_DVIA5F_REGION NOT DM5F_FOR_DVIA5F_REGION_remainder_pre_not

    DM5F_FOR_DVIA5F_REGION_remainder_EDGE = LENGTH DM5F_FOR_DVIA5F_REGION_remainder > 0
    DM5F_FOR_DVIA5F_REGION_remainder_PROP = DFM PROPERTY DM5F_FOR_DVIA5F_REGION_remainder DM5F_FOR_DVIA5F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM5F_FOR_DVIA5F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM5F_FOR_DVIA5F_REGION_remainder_EDGE)) ]
    DM5F_FOR_DVIA5F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM5F_FOR_DVIA5F_REGION_remainder_EDGE DM5F_FOR_DVIA5F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM5F_FOR_DVIA5F_REGION_remainder_EDGE) - PROPERTY(DM5F_FOR_DVIA5F_REGION_remainder_PROP, DM5F_FOR_DVIA5F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM5F_FOR_DVIA5F_REGION2 = DM5F_FOR_DVIA5F_REGION_remainder NOT (EXPAND EDGE DM5F_FOR_DVIA5F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM5_F_4_REGION_DVIA5_SHORTENED_LENGTH)


VARIABLE DM6_F_4_REGION_DVIA5_SHORTENED_LENGTH DM6_EN_3 - DM6_EN_2

#IFDEF VERTICAL_DM6
DM6_F_4_REGION_DVIA5_spec_B_pre = RECTANGLE DM6F_FOR_DVIA5F_REGION == WM6_303_SLOT BY == LM6_303_SLOT
DM6_F_4_REGION_DVIA5_spec_B     = DM6_F_4_REGION_DVIA5_spec_B_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA5_spec_B_pre == WM6_303_SLOT) INSIDE BY DM6_F_4_REGION_DVIA5_SHORTENED_LENGTH)

DM6_F_4_REGION_DVIA5_spec_M_pre = RECTANGLE DM6F_FOR_DVIA5F_REGION == WM6_302 BY == LM6_302
DM6_F_4_REGION_DVIA5_spec_M     = DM6_F_4_REGION_DVIA5_spec_M_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA5_spec_M_pre == WM6_302) INSIDE BY DM6_F_4_REGION_DVIA5_SHORTENED_LENGTH)

DM6_F_4_REGION_DVIA5_spec_S_pre = RECTANGLE DM6F_FOR_DVIA5F_REGION == WM6_301 BY == LM6_301
DM6_F_4_REGION_DVIA5_spec_S     = DM6_F_4_REGION_DVIA5_spec_S_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA5_spec_S_pre == WM6_301) INSIDE BY DM6_F_4_REGION_DVIA5_SHORTENED_LENGTH)
#ELSE
DM6_F_4_REGION_DVIA5_spec_B_pre = RECTANGLE DM6F_FOR_DVIA5F_REGION == LM6_303_SLOT BY == WM6_303_SLOT
DM6_F_4_REGION_DVIA5_spec_B     = DM6_F_4_REGION_DVIA5_spec_B_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA5_spec_B_pre == LM6_303_SLOT) INSIDE BY DM6_F_4_REGION_DVIA5_SHORTENED_LENGTH)

DM6_F_4_REGION_DVIA5_spec_M_pre = RECTANGLE DM6F_FOR_DVIA5F_REGION == LM6_302 BY == WM6_302
DM6_F_4_REGION_DVIA5_spec_M     = DM6_F_4_REGION_DVIA5_spec_M_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA5_spec_M_pre == LM6_302) INSIDE BY DM6_F_4_REGION_DVIA5_SHORTENED_LENGTH)

DM6_F_4_REGION_DVIA5_spec_S_pre = RECTANGLE DM6F_FOR_DVIA5F_REGION == LM6_301 BY == WM6_301
DM6_F_4_REGION_DVIA5_spec_S     = DM6_F_4_REGION_DVIA5_spec_S_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA5_spec_S_pre == LM6_301) INSIDE BY DM6_F_4_REGION_DVIA5_SHORTENED_LENGTH)
#ENDIF

DM6_F_4_REGION_DVIA5_square_pre = RECTANGLE DM6F_FOR_DVIA5F_REGION ASPECT == 1
DM6_F_4_REGION_DVIA5_square     = SIZE DM6_F_4_REGION_DVIA5_square_pre BY -DM6_F_4_REGION_DVIA5_SHORTENED_LENGTH

DM6F_FOR_DVIA5F_REGION_4parts = (DM6_F_4_REGION_DVIA5_spec_B OR DM6_F_4_REGION_DVIA5_spec_M) OR (DM6_F_4_REGION_DVIA5_spec_S OR DM6_F_4_REGION_DVIA5_square)
DM6F_FOR_DVIA5F_REGION_remainder_pre_not = (DM6_F_4_REGION_DVIA5_spec_B_pre OR DM6_F_4_REGION_DVIA5_spec_M_pre) OR (DM6_F_4_REGION_DVIA5_spec_S_pre OR DM6_F_4_REGION_DVIA5_square_pre)
DM6F_FOR_DVIA5F_REGION_remainder = DM6F_FOR_DVIA5F_REGION NOT DM6F_FOR_DVIA5F_REGION_remainder_pre_not

    DM6F_FOR_DVIA5F_REGION_remainder_EDGE = LENGTH DM6F_FOR_DVIA5F_REGION_remainder > 0
    DM6F_FOR_DVIA5F_REGION_remainder_PROP = DFM PROPERTY DM6F_FOR_DVIA5F_REGION_remainder DM6F_FOR_DVIA5F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM6F_FOR_DVIA5F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM6F_FOR_DVIA5F_REGION_remainder_EDGE)) ]
    DM6F_FOR_DVIA5F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM6F_FOR_DVIA5F_REGION_remainder_EDGE DM6F_FOR_DVIA5F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM6F_FOR_DVIA5F_REGION_remainder_EDGE) - PROPERTY(DM6F_FOR_DVIA5F_REGION_remainder_PROP, DM6F_FOR_DVIA5F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM6F_FOR_DVIA5F_REGION2 = DM6F_FOR_DVIA5F_REGION_remainder NOT (EXPAND EDGE DM6F_FOR_DVIA5F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM6_F_4_REGION_DVIA5_SHORTENED_LENGTH)

DVIA5F_BASE_REGION = (((((SIZE (DM5F_FOR_DVIA5F_REGION2 OR DM5F_FOR_DVIA5F_REGION_4parts) BY -DVIA5_EN_1) AND (SIZE (DM6F_FOR_DVIA5F_REGION2 OR DM6F_FOR_DVIA5F_REGION_4parts) BY -DM6_EN_2)) WITH WIDTH >= DVIA5_W_1) NOT (SIZE DVIA5EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA5i BY (DVIA5_S_1 + grid))) NOT (SIZE VIA5i BY (DVIA5_S_2 + grid))




// Merge DVIA5 fillable regions, and find DVIA5 seeds by maintaining spacing DVIA5_S_1.
DVIA5F_SEED_REGION_1 = (((SIZE DVIA5F_BASE_REGION BY DVIA5F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA5EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA5i BY (DVIA5_S_1 + grid))) NOT (SIZE VIA5i BY (DVIA5_S_2 + grid))
DVIA5F_SEED_1 = RECTANGLES DVIA5_W_1 DVIA5_W_1 DVIA5_S_1 INSIDE OF LAYER DVIA5F_SEED_REGION_1

// Find DVIA5 in the DVIA5 fillable and spacing-maintained regions.
DVIA5F_REGION_1 = (DVIA5F_BASE_REGION INTERACT DVIA5F_SEED_1) NOT TOUCH DVIA5F_SEED_1
DVIA5F_pre1_1_pre1 = RECTANGLES DVIA5_W_1 DVIA5_W_1 DVIA5_S_1 INSIDE OF LAYER DVIA5F_REGION_1

// post-DRC
DVIA5F_pre1_1_pre2 = DVIA5F_pre1_1_pre1 NOT INTERACT (EXT DVIA5F_pre1_1_pre1 < DVIA5_S_1 ABUT SINGULAR REGION)
DVIA5F_pre1_1_pre3 = DVIA5F_pre1_1_pre2 NOT INTERACT (EXT DVIA5F_pre1_1_pre2 DUVIA5i < DVIA5_S_1 ABUT SINGULAR REGION)
DVIA5F_pre1_1_pre4 = DVIA5F_pre1_1_pre3 NOT INTERACT (EXT DVIA5F_pre1_1_pre3 VIA5i < DVIA5_S_2 ABUT SINGULAR REGION)
DVIA5F_pre1_1_pre5 = DVIA5F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA5F_pre1_1_pre4 DM5F_FOR_DVIA5F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA5_EN_2 OPPOSITE 0 DVIA5_EN_2 OPPOSITE)
DVIA5F_pre1_1      = DVIA5F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA5F_pre1_1_pre5 DM6F_FOR_DVIA5F_REGION ABUT < 90 SINGULAR GOOD 0 DM6_EN_3 OPPOSITE 0 DM6_EN_3 OPPOSITE)

// Merge DVIA5 fillable regions, and find DVIA5 seeds by maintaining spacing DVIA5_S_1.
DVIA5F_SEED_REGION_2 = (((SIZE (DVIA5F_BASE_REGION NOT INTERACT (SIZE DVIA5F_pre1_1 BY DVIA5_S_1)) BY DVIA5F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA5EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA5i BY (DVIA5_S_1 + grid))) NOT (SIZE VIA5i BY (DVIA5_S_2 + grid))
DVIA5F_SEED_2 = RECTANGLES DVIA5_W_1 DVIA5_W_1 DVIA5_S_1 INSIDE OF LAYER DVIA5F_SEED_REGION_2

// Find DVIA5 in the DVIA5 fillable and spacing-maintained regions.
DVIA5F_REGION_2 = (DVIA5F_BASE_REGION INTERACT DVIA5F_SEED_2) NOT TOUCH DVIA5F_SEED_2
DVIA5F_pre1_2 = RECTANGLES DVIA5_W_1 DVIA5_W_1 DVIA5_S_1 INSIDE OF LAYER DVIA5F_REGION_2

// post-DRC
DVIA5F_pre1 = DVIA5F_pre1_1 OR DVIA5F_pre1_2
DVIA5F_pre2 = DVIA5F_pre1 NOT INTERACT (EXT DVIA5F_pre1 < DVIA5_S_1 ABUT SINGULAR REGION)
DVIA5F_pre3 = DVIA5F_pre2 NOT INTERACT (EXT DVIA5F_pre2 DUVIA5i < DVIA5_S_1 ABUT SINGULAR REGION)
DVIA5F_pre4 = DVIA5F_pre3 NOT INTERACT (EXT DVIA5F_pre3 VIA5i < DVIA5_S_2 ABUT SINGULAR REGION)
DVIA5F_pre5 = DVIA5F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA5F_pre4 DM5F_FOR_DVIA5F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA5_EN_2 OPPOSITE 0 DVIA5_EN_2 OPPOSITE)
DVIA5F      = DVIA5F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA5F_pre5 DM6F_FOR_DVIA5F_REGION ABUT < 90 SINGULAR GOOD 0 DM6_EN_3 OPPOSITE 0 DM6_EN_3 OPPOSITE)

#ENDIF
#ENDIF
#ENDIF
#ENDIF
