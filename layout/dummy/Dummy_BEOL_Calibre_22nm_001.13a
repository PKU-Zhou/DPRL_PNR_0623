TCD_M1_31_0_55 = SHRINK TCD_M1 LEFT BY 1.535 BOTTOM BY 0.09 RIGHT BY (TCD_M1_W-1.585) TOP BY (TCD_M1_L-0.42)
TCD_M1_31_0_56 = SHRINK TCD_M1 LEFT BY 1.875 BOTTOM BY 0.5 RIGHT BY (TCD_M1_W-1.925) TOP BY (TCD_M1_L-3.5)
TCD_M1_31_0_57 = SHRINK TCD_M1 LEFT BY 2.075 BOTTOM BY 0.5 RIGHT BY (TCD_M1_W-2.125) TOP BY (TCD_M1_L-3.5)
TCD_M1_150_1 = COPY TCD_M1_150_1_1
TCD_M1_165_91 = COPY TCD_M1_165_91_1
TCD_M1_31_0 = OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR TCD_M1_31_0_1 TCD_M1_31_0_2) TCD_M1_31_0_3) TCD_M1_31_0_4) TCD_M1_31_0_5) TCD_M1_31_0_6) TCD_M1_31_0_7) TCD_M1_31_0_8) TCD_M1_31_0_9) TCD_M1_31_0_10) TCD_M1_31_0_11) TCD_M1_31_0_12) TCD_M1_31_0_13) TCD_M1_31_0_14) TCD_M1_31_0_15) TCD_M1_31_0_16) TCD_M1_31_0_17) TCD_M1_31_0_18) TCD_M1_31_0_19) TCD_M1_31_0_20) TCD_M1_31_0_21) TCD_M1_31_0_22) TCD_M1_31_0_23) TCD_M1_31_0_24) TCD_M1_31_0_25) TCD_M1_31_0_26) TCD_M1_31_0_27) TCD_M1_31_0_28) TCD_M1_31_0_29) TCD_M1_31_0_30) TCD_M1_31_0_31) TCD_M1_31_0_32) TCD_M1_31_0_33) TCD_M1_31_0_34) TCD_M1_31_0_35) TCD_M1_31_0_36) TCD_M1_31_0_37) TCD_M1_31_0_38) TCD_M1_31_0_39) TCD_M1_31_0_40) TCD_M1_31_0_41) TCD_M1_31_0_42) TCD_M1_31_0_43) TCD_M1_31_0_44) TCD_M1_31_0_45) TCD_M1_31_0_46) TCD_M1_31_0_47) TCD_M1_31_0_48) TCD_M1_31_0_49) TCD_M1_31_0_50) TCD_M1_31_0_51) TCD_M1_31_0_52) TCD_M1_31_0_53) TCD_M1_31_0_54) TCD_M1_31_0_55) TCD_M1_31_0_56) TCD_M1_31_0_57

    xM1_DTCD = SIZE TCD_M1 BY D2M1_DTCD
#ELSE
    xM1_DTCD = COPY EMPTY
#ENDIF

    M1BigHole = SIZE M1InnerHole BY - excludeHoleSize/2
    M1ExcHole = ((M1InnerHole OUTSIDE M1BigHole) NOT M1i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK1 = (SIZE DM1EXCL BY (dm2DMEXCL + grid)) OR MIM1_x

    FRAMEA1 = (SIZE M1i BY (DM1_301 + grid)) OR (SIZE (EXPAND EDGE (M1i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA1OPC = SIZE M1i BY (DM1_OPC + grid)
    FRAMEA1OPCwide = SIZE (M1i WITH WIDTH > DM1_OPC_wide_w) BY (DM1_OPC_wide + grid)
    FRAMEA1OPC45 = SIZE (EXPAND EDGE (M1i ANGLE == 45) OUTSIDE BY DM1_OPC_45 EXTEND BY DM1_OPC_45_E) BY grid
    FRAMEA1OPC45DV = SIZE (EXPAND EDGE ((M1i INTERACT M1_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM1_OPC_45 EXTEND BY DM1_OPC_45_E) BY grid
    FRAMEA1OPC_M1_S_14_wide = SIZE (M1i WITH WIDTH > M1_S_14_wide_w) BY (M1_S_14_wide + grid)
    FRAMEA1OPC_M1_S_17_wide = SIZE (M1i WITH WIDTH > M1_S_17_wide_w) BY (M1_S_17_wide + grid)
    FRAMEA1OPC_M1_S_20_wide = SIZE (M1i WITH WIDTH > M1_S_20_wide_w) BY (M1_S_20_wide + grid)
    FRAMEA1OPC_M1_S_23_wide = SIZE (M1i WITH WIDTH > M1_S_23_wide_w) BY (M1_S_23_wide + grid)
    FRAMEA1OPC_M1_S_33_VIA1  = SIZE VIA1_HV_5V_CHK  BY (M1_S_33 + grid)
    FRAMEA1OPC_M1_S_33b_VIA1DV  = SIZE (VIA1i INTERACT (M1_HVN_330Vx OR M2_HVN_330Vx))  BY (M1_S_33b + grid)
    CO_VIA1_55V_65V = OR CO_55V CO_65V VIA1i_55V VIA1i_65V
    FRAMEA1OPC_M1_S_37_VIA1    = SIZE CO_VIA1_55V_65V	BY (M1_S_37 + grid)
    FRAMEA1OPC_M1_S_36a_VIA1DV    = (SIZE (COi INTERACT (OR PO_HVN_500Vx OD_HVN_500Vx M1_HVN_500Vx))	BY (M1_S_36a + grid)) OR (SIZE (VIA1i INTERACT (M1_HVN_500Vx OR M2_HVN_500Vx))	BY (M1_S_36a + grid))

    FRAMEHVD1 = SIZE  M1i_65V  BY (M1_S_38 + grid)
    FRAMEHVD1_55V = SIZE  M1i_55V  BY (M1_S_38 + grid)
    FRAMEHVD1_55VDV = SIZE  (M1i INTERACT M1_HVN_500Vx)  BY (M1_S_38a + grid)
    FRAMEB1 = SIZE (WITH WIDTH M1i > wideM1) BY (dm2WM1 + grid)
    FRAMEC1 = SIZE DUM1 BY (dm2DM1 + grid)
    FRAMED1 = SIZE (WITH WIDTH M1i > wideM1_small) BY (dm2WM1_small + grid)
    FRAMEC1OPC = SIZE DUM1 BY (Odm2DM1 + grid)
    FRAME1Pre = ((FRAMEA1 OR FRAMEB1) OR (FRAMEC1 OR FRAMED1)) OR M1ExcHole
    FRAME1PreOPC = (((((((((((((((FRAMEA1OPC OR FRAMEC1OPC) OR M1ExcHole) OR FRAMEA1OPCwide) OR FRAMEA1OPC45) OR FRAMEA1OPC45DV) OR FRAMEA1OPC_M1_S_14_wide) OR FRAMEA1OPC_M1_S_17_wide) OR FRAMEA1OPC_M1_S_20_wide) OR FRAMEA1OPC_M1_S_23_wide) OR FRAMEA1OPC_M1_S_33_VIA1) OR FRAMEA1OPC_M1_S_33b_VIA1DV) OR  FRAMEHVD1) OR FRAMEA1OPC_M1_S_37_VIA1) OR FRAMEA1OPC_M1_S_36a_VIA1DV) OR FRAMEHVD1_55V) OR FRAMEHVD1_55VDV

    FRAME1INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm1_s2m1_INDDMY + grid)
    FRAME1OPC = ((((FRAME1PreOPC OR FRAME1INDDMY) OR xM1_DTCD) OR BLOCK1) OR NFILLOPC_x) OR FUSELINKx

    FRAME1 = ((((FRAME1Pre OR FRAME1INDDMY) OR xM1_DTCD) OR BLOCK1) OR NFILL_x) OR FUSELINKx

    D30M1p = (PUSH D30M1) NOT FRAME1
    O30M1pre = D30M1p AND CHIP
    FD21M1s = COPY FRAME1

    O30M1preA = SIZE O30M1pre BY -DM1_303
    O30M1preB = O30M1preA WITH WIDTH >= WM1_303

    // 1st big
    F303M1 = RECTANGLES WM1_303 LM1_303 SM1_303 OFFSET OM1_303 INSIDE OF LAYER O30M1preB
    F303M1_SLOT = RECTANGLES WM1_303_SLOT LM1_303_SLOT SM1_303_SLOT INSIDE OF LAYER F303M1

    F303M1_EXP = SIZE F303M1_SLOT BY ( SM1_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M1preF1 = O30M1pre NOT (SIZE F303M1_EXP BY SM1_302)
    O30M1preF  = (SNAP (SIZE O30M1preF1 BY -grid) 5) AND O30M1preF1

    B30M1s = FD21M1s OR (SIZE F303M1_EXP BY (SM1_302+grid))
    O30M1 = O30M1preF NOT B30M1s

    // 3rd, middle
    F302M1 = RECTANGLES WM1_302 LM1_302 SM1_302 OFFSET OM1_302 INSIDE OF LAYER O30M1
    F302M1s = (SIZE F302M1 BY (SM1_301 + grid)) OR B30M1s
    R302M1pre = O30M1 NOT F302M1s
    R302M1 = WITH WIDTH R302M1pre >= WM1_301

    // 4th, small
    F3012M1 = RECTANGLES WM1_301 LM1_301 SM1_301 OFFSET OM1_301 INSIDE OF LAYER R302M1
    F3012M1s = (SIZE F3012M1 BY (SM1_301 + grid)) OR F302M1s
    R3012M1pre = R302M1pre NOT F3012M1s
    R3012M1 = WITH WIDTH R3012M1pre >= WM1_301

    // 5th, non-stagger small
    F301M1 = RECTANGLES WM1_301 LM1_301 SM1_301 INSIDE OF LAYER R3012M1 //MAINTAIN SPACING
    F301M1s = (SIZE F301M1 BY (SM1_301 + grid)) OR F3012M1s

    F30M1 = ((F302M1 OR F3012M1) OR F301M1) OR F303M1_SLOT
    O40M1pre = (((PUSH D40M1) NOT FRAME1) NOT F301M1s) AND CHIP


    O40M1preA = SIZE O40M1pre BY -DM1_403
    O40M1preB = O40M1preA WITH WIDTH >= WM1_403

    // 1st big
    F403M1 = RECTANGLES WM1_403 LM1_403 SM1_403 OFFSET OM1_403 INSIDE OF LAYER O40M1preB
    F403M1_SLOT = RECTANGLES WM1_403_SLOT LM1_403_SLOT SM1_403_SLOT INSIDE OF LAYER F403M1

    F403M1_EXP = SIZE F403M1_SLOT BY ( SM1_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M1preF1 = O40M1pre NOT (SIZE F403M1_EXP BY SM1_402)
    O40M1preF  = (SNAP (SIZE O40M1preF1 BY -grid) 5) AND O40M1preF1

    B40M1s = F301M1s OR (SIZE F403M1_EXP BY (SM1_402+grid))
    O40M1 = O40M1preF NOT B40M1s

    // 3rd, middle
    F402M1 = RECTANGLES WM1_402 LM1_402 SM1_402 OFFSET OM1_402 INSIDE OF LAYER O40M1
    F402M1s = (SIZE F402M1 BY (SM1_401 + grid)) OR B40M1s
    R402M1pre = O40M1 NOT F402M1s
    R402M1 = WITH WIDTH R402M1pre >= WM1_401

    // 4th, small
    F4012M1 = RECTANGLES WM1_401 LM1_401 SM1_401 OFFSET OM1_401 INSIDE OF LAYER R402M1
    F4012M1s = (SIZE F4012M1 BY (SM1_401 + grid)) OR F402M1s
    R4012M1pre = R402M1pre NOT F4012M1s
    R4012M1 = WITH WIDTH R4012M1pre >= WM1_401

    // 5th, non-stagger small
    F401M1 = RECTANGLES WM1_401 LM1_401 SM1_401 INSIDE OF LAYER R4012M1 //MAINTAIN SPACING
    F401M1s = (SIZE F401M1 BY (SM1_401 + grid)) OR F4012M1s

    F40M1 = ((F402M1 OR F4012M1) OR F401M1) OR F403M1_SLOT
    O50M1pre = (((PUSH (D50M1 OR emptyM1)) NOT FRAME1) NOT F401M1s) AND CHIP


    O50M1preA = SIZE O50M1pre BY -DM1_503
    O50M1preB = O50M1preA WITH WIDTH >= WM1_503

    // 1st big
    F503M1 = RECTANGLES WM1_503 LM1_503 SM1_503 OFFSET OM1_503 INSIDE OF LAYER O50M1preB
    F503M1_SLOT = RECTANGLES WM1_503_SLOT LM1_503_SLOT SM1_503_SLOT INSIDE OF LAYER F503M1

    F503M1_EXP = SIZE F503M1_SLOT BY ( SM1_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M1preF1 = O50M1pre NOT (SIZE F503M1_EXP BY SM1_502)
    O50M1preF  = (SNAP (SIZE O50M1preF1 BY -grid) 5) AND O50M1preF1

    B50M1s = F401M1s OR (SIZE F503M1_EXP BY (SM1_502+grid))
    O50M1 = O50M1preF NOT B50M1s

    // 3rd, middle
    F502M1 = RECTANGLES WM1_502 LM1_502 SM1_502 OFFSET OM1_502 INSIDE OF LAYER O50M1
    F502M1s = (SIZE F502M1 BY (SM1_501 + grid)) OR B50M1s
    R502M1pre = O50M1 NOT F502M1s
    R502M1 = WITH WIDTH R502M1pre >= WM1_501

    // 4th, small
    F5012M1 = RECTANGLES WM1_501 LM1_501 SM1_501 OFFSET OM1_501 INSIDE OF LAYER R502M1
    F5012M1s = (SIZE F5012M1 BY (SM1_501 + grid)) OR F502M1s
    R5012M1pre = R502M1pre NOT F5012M1s
    R5012M1 = WITH WIDTH R5012M1pre >= WM1_501

    // 5th, non-stagger small
    F501M1 = RECTANGLES WM1_501 LM1_501 SM1_501 INSIDE OF LAYER R5012M1 //MAINTAIN SPACING
    F501M1s = (SIZE F501M1 BY (SM1_501 + grid)) OR F5012M1s

    F50M1 = ((F502M1 OR F5012M1) OR F501M1) OR F503M1_SLOT

    exceedM1 = DENSITY M1x F30M1 F40M1 F50M1 > maxD_M1 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M1.den_exceed

    removeM1R = ((PUSH (exceedM1 AND (D50M1 OR emptyM1))) NOT FRAME1) AND CHIP
    removeM1P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM1R

    F30M1x = F30M1 NOT INTERACT removeM1P
    F40M1x = F40M1 NOT INTERACT removeM1P
    F50M1x = F50M1 NOT INTERACT removeM1P
    FM1xA  = (F30M1x OR F40M1x) OR F50M1x
    FM1x   = FM1xA NOT INTERACT (EXT FM1xA < DM1_S_1 ABUT SINGULAR REGION)

    ALLM1x = M1x OR FM1x
    lackM1 = DENSITY ALLM1x CHIP < DM1_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M1.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM1x)/AREA(CHIP) ]

    WDM1EXC = DUM1 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM1EXC = (SIZE FM1x BY Odm2DM1) OR (SIZE (((F303M1_EXP OR F403M1_EXP) OR F503M1_EXP) OR WDM1EXC) BY 1.5)

    lackM1pRM = ((((PUSH lackM1) NOT RM1EXC) NOT FRAME1OPC) NOT exceedM1) AND CHIP
    lackM1pRM_1 = WITH WIDTH lackM1pRM >= SM1_OPC

    RM1p1 = RECTANGLES WM1_OPC LM1_OPC WSM1_OPC LSM1_OPC INSIDE OF LAYER lackM1pRM_1
    lackM1pRM_2 = lackM1pRM_1 NOT (SIZE RM1p1 BY SM1_OPC)
    RM1p2 = RECTANGLES LM1_OPC WM1_OPC LSM1_OPC WSM1_OPC INSIDE OF LAYER lackM1pRM_2

    ODM1A = ((RM1p1 OR RM1p2) OUTSIDE RM1EXC) OUTSIDE FRAME1OPC
    ODM1F_pre = ODM1A NOT INTERACT (EXT ODM1A < SM1_OPC ABUT SINGULAR REGION)

// M1.S.14 ~ M1.S.16
M1_S_14_CHK_REGION = M1i OR ODM1F_pre
// Find Wide Metal
Wide_M1_S_14_CHK_REGION = ENCLOSE RECTANGLE (M1_S_14_CHK_REGION NOT WITH WIDTH <= M1_S_14_W1B) M1_S_14_W1B+GRID M1_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M1_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M1_S_14_CHK_REGION == 0
Wide_M1_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M1_S_14_CHK_REGION == 90

// Find Wide Metal Space
M1_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M1_S_14_CHK_REGION_EDGE_H M1_S_14_CHK_REGION < M1_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M1_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M1_S_14_CHK_REGION_EDGE_V M1_S_14_CHK_REGION < M1_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M1_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M1_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M1_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M1_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M1_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M1_S_14_CHK_REGION_OPC_REGION_pre1_H M1_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M1_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M1_S_14_L1B
M1_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M1_S_14_CHK_REGION_OPC_REGION_pre1_V M1_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M1_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M1_S_14_L1B

M1_S_14_OPC_REGION = M1_S_14_CHK_REGION_OPC_REGION_pre2_H OR M1_S_14_CHK_REGION_OPC_REGION_pre2_V

// M1.S.17 ~ M1.S.19
M1_S_17_CHK_REGION = M1i OR ODM1F_pre
// Find Wide Metal
Wide_M1_S_17_CHK_REGION = ENCLOSE RECTANGLE (M1_S_17_CHK_REGION NOT WITH WIDTH <= M1_S_17_W1B) M1_S_17_W1B+GRID M1_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M1_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M1_S_17_CHK_REGION == 0
Wide_M1_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M1_S_17_CHK_REGION == 90

// Find Wide Metal Space
M1_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M1_S_17_CHK_REGION_EDGE_H M1_S_17_CHK_REGION < M1_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M1_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M1_S_17_CHK_REGION_EDGE_V M1_S_17_CHK_REGION < M1_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M1_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M1_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M1_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M1_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M1_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M1_S_17_CHK_REGION_OPC_REGION_pre1_H M1_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M1_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M1_S_17_L1B
M1_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M1_S_17_CHK_REGION_OPC_REGION_pre1_V M1_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M1_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M1_S_17_L1B

M1_S_17_OPC_REGION = M1_S_17_CHK_REGION_OPC_REGION_pre2_H OR M1_S_17_CHK_REGION_OPC_REGION_pre2_V

// M1.S.20 ~ M1.S.22
M1_S_20_CHK_REGION = M1i OR ODM1F_pre
// Find Wide Metal
Wide_M1_S_20_CHK_REGION = ENCLOSE RECTANGLE (M1_S_20_CHK_REGION NOT WITH WIDTH <= M1_S_20_W1B) M1_S_20_W1B+GRID M1_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M1_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M1_S_20_CHK_REGION == 0
Wide_M1_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M1_S_20_CHK_REGION == 90

// Find Wide Metal Space
M1_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M1_S_20_CHK_REGION_EDGE_H M1_S_20_CHK_REGION < M1_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M1_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M1_S_20_CHK_REGION_EDGE_V M1_S_20_CHK_REGION < M1_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M1_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M1_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M1_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M1_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M1_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M1_S_20_CHK_REGION_OPC_REGION_pre1_H M1_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M1_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M1_S_20_L1B
M1_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M1_S_20_CHK_REGION_OPC_REGION_pre1_V M1_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M1_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M1_S_20_L1B

M1_S_20_OPC_REGION = M1_S_20_CHK_REGION_OPC_REGION_pre2_H OR M1_S_20_CHK_REGION_OPC_REGION_pre2_V

// M1.S.23 ~ M1.S.25
M1_S_23_CHK_REGION = M1i OR ODM1F_pre
// Find Wide Metal
Wide_M1_S_23_CHK_REGION = ENCLOSE RECTANGLE (M1_S_23_CHK_REGION NOT WITH WIDTH <= M1_S_23_W1B) M1_S_23_W1B+GRID M1_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M1_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M1_S_23_CHK_REGION == 0
Wide_M1_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M1_S_23_CHK_REGION == 90

// Find Wide Metal Space
M1_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M1_S_23_CHK_REGION_EDGE_H M1_S_23_CHK_REGION < M1_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M1_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M1_S_23_CHK_REGION_EDGE_V M1_S_23_CHK_REGION < M1_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M1_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M1_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M1_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M1_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M1_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M1_S_23_CHK_REGION_OPC_REGION_pre1_H M1_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M1_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M1_S_23_L1B
M1_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M1_S_23_CHK_REGION_OPC_REGION_pre1_V M1_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M1_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M1_S_23_L1B

M1_S_23_OPC_REGION = M1_S_23_CHK_REGION_OPC_REGION_pre2_H OR M1_S_23_CHK_REGION_OPC_REGION_pre2_V

// M1.S.27
M1_S_27_CHK_REGION = M1i OR ODM1F_pre
// Find Wide Metal
Wide_M1_S_27_CHK_REGION = ENCLOSE RECTANGLE (M1_S_27_CHK_REGION NOT WITH WIDTH <= M1_S_27_W1B) M1_S_27_W1B+GRID M1_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M1_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M1_S_27_CHK_REGION == 0
Wide_M1_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M1_S_27_CHK_REGION == 90

// Find Wide Metal Space
M1_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M1_S_27_CHK_REGION_EDGE_H M1_S_27_CHK_REGION < M1_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M1_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M1_S_27_CHK_REGION_EDGE_V M1_S_27_CHK_REGION < M1_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M1_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M1_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M1_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M1_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M1_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M1_S_27_CHK_REGION_OPC_REGION_pre1_H M1_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M1_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M1_S_27_L1B
M1_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M1_S_27_CHK_REGION_OPC_REGION_pre1_V M1_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M1_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M1_S_27_L1B

M1_S_27_OPC_REGION = M1_S_27_CHK_REGION_OPC_REGION_pre2_H OR M1_S_27_CHK_REGION_OPC_REGION_pre2_V

M1_WMJ_OPC_REGION = (((M1_S_14_OPC_REGION OR M1_S_17_OPC_REGION) OR M1_S_20_OPC_REGION) OR M1_S_23_OPC_REGION) OR M1_S_27_OPC_REGION

    ODM1F = ODM1F_pre NOT INTERACT M1_WMJ_OPC_REGION

    DM1F = COPY FM1x

    FRAME1_INDDMYA = SIZE M1i BY (dm1_s2m1_INDDMY + grid)
    FRAME1_INDDMYB = SIZE DUM1 BY (dm1_s_INDDMY + grid)
    FRAME1_INDDMYC = SIZE DM1F BY dm1_s_INDDMY
    FRAME1_INDDMYD = SIZE ODM1F BY dm1_s2m1_INDDMY

    FRAME1_INDDMY  = (((((((FRAME1Pre OR xM1_DTCD) OR BLOCK1) OR FRAME1_INDDMYA) OR FRAME1_INDDMYB) OR FRAME1_INDDMYC) OR FRAME1_INDDMYD) OR NFILL_x) OR FUSELINKx
    FILL1_INDDMY   = ooINDDMY NOT FRAME1_INDDMY
    DM1F_INDDMY    = RECTANGLES dm1_w_INDDMY dm1_l_INDDMY dm1_s_INDDMY INSIDE OF LAYER FILL1_INDDMY

#IFDEF FILL_indDM1
    FILL1_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm1_s_INDDMY_HD + grid)) NOT FRAME1_INDDMY
    DM1F_INDDMY_HD_pre  = RECTANGLES dm1_w_INDDMY_HD dm1_l_INDDMY_HD dm1_s_INDDMY_HD INSIDE OF LAYER FILL1_INDDMY_HD

    FILL1_INDDMY_MD = (SIZE INDDMY_MD BY -(dm1_s_INDDMY_MD + grid)) NOT (FRAME1_INDDMY OR INDDMY_HD)
    DM1F_INDDMY_MD  = RECTANGLES dm1_w_INDDMY_MD dm1_l_INDDMY_MD dm1_s_INDDMY_MD INSIDE OF LAYER FILL1_INDDMY_MD

    DM1F_INDDMY_HD = DM1F_INDDMY_HD_pre OR DM1F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#IFDEF FILL_DM2


#IFDEF 34K_THICK_Mu_M2

    minOPENM2 = DENSITY M2x < minD_M2 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M2Min.den
    emptyOPENM2 = DENSITY M2x < emptyD_M2 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M2Empty.den

    M2InnerHole = HOLES M2i INNER

    M2BigHole = SIZE M2InnerHole BY - excludeHoleSize/2
    M2ExcHole = ((M2InnerHole OUTSIDE M2BigHole) NOT M2i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK2    = (SIZE DM2EXCL BY (dm2DMEXCL + grid)) OR MIM2_x
    FRAMEA2   = SIZE M2i BY (dm2M2 + grid) // DM2 to metal
    FRAMEB2   = SIZE (WITH WIDTH M2i > wideM2) BY (dm2WM2 + grid)
    FRAMEC2   = SIZE DUM2 BY (dm2DM2 + grid)
    FRAME2Pre = ((FRAMEA2 OR FRAMEB2) OR FRAMEC2) OR M2ExcHole
    FRAME2INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm2_s2m2_INDDMY + grid)
    FRAME2 = ((FRAME2Pre OR FRAME2INDDMY) OR BLOCK2) OR NFILL
    
    OPENM2 = PUSH ((minOPENM2 OR emptyOPENM2) AND CHIP)
    FILL2 = OPENM2 NOT FRAME2
    FILLW2pre = SIZE FILL2 BY - (Wdm2M2 + grid)
    FILLW2 = WITH WIDTH FILLW2pre >= WdmW_M2
    M2FW = RECTANGLES WdmW_M2 WdmL_M2 WdmS_M2 OFFSET WdmO_M2 INSIDE OF LAYER FILLW2
    M2FW_EXP = SIZE M2FW BY (WdmS_M2 /2 + grid) OVERUNDER   // merge the gaps
    FILLM2pre = FILL2 NOT (SIZE M2FW_EXP BY (MdmS_M2 + grid))
    FILLM2 = WITH WIDTH FILLM2pre >= MdmW_M2
    M2F1 = RECTANGLES MdmW_M2 MdmL_M2 MdmS_M2 OFFSET MdmO_M2 INSIDE OF LAYER FILLM2
    M2R1pre = FILLM2pre NOT (SIZE M2F1 BY (dmS_M2 + grid))
    M2R1 = WITH WIDTH M2R1pre >= dmW_M2

    M2F2 = RECTANGLES dmW_M2 dmL_M2 dmS_M2 OFFSET dmO_M2 INSIDE OF LAYER M2R1
    M2R2pre = M2R1 NOT (SIZE M2F2 BY (dmS_M2 + grid))
    M2R2 = WITH WIDTH M2R2pre >= dmW_M2

    M2F3 = RECTANGLES dmW_M2 dmL_M2 dmS_M2 OFFSET dmO_M2 INSIDE OF LAYER M2R2
    M2R3pre = M2R2 NOT (SIZE M2F3 BY (dmS_M2 + grid))
    M2R3 = WITH WIDTH M2R3pre >= dmW_M2

    M2F4 = RECTANGLES dmW_M2 dmL_M2 dmS_M2 INSIDE OF LAYER M2R3

    M2F = (((M2F1 OR M2F2) OR M2F3) OR M2F4) OR M2FW
    FM2 = M2F NOT INTERACT (EXT M2F < dmS_M2 ABUT SINGULAR REGION)

    maxOPENM2 = DENSITY M2x FM2 > maxD_M2 WINDOW WindowSizeu*2 STEP WindowStepu*2
                INSIDE OF LAYER bulk BACKUP // PRINT M2Max.den

    DM2F = FM2 OUTSIDE maxOPENM2

    FRAME2_INDDMYA = SIZE M2i BY (dm2_s2m2_INDDMY + grid)
    FRAME2_INDDMYB = SIZE DUM2 BY (dm2_s_INDDMY + grid)
    FRAME2_INDDMYC = SIZE DM2F BY dm2_s_INDDMY
    FRAME2_INDDMY  = ((((FRAME2Pre OR BLOCK2) OR FRAME2_INDDMYA) OR FRAME2_INDDMYB) OR FRAME2_INDDMYC) OR NFILL
    FILL2_INDDMY   = ooINDDMY NOT FRAME2_INDDMY
    DM2F_INDDMY    = RECTANGLES dm2_w_INDDMY dm2_l_INDDMY dm2_s_INDDMY INSIDE OF LAYER FILL2_INDDMY
#IFDEF FILL_indDM2
    FILL2_INDDMY_HD = (SIZE INDDMY_HD BY -(dm2_s_INDDMY_HD + grid)) NOT FRAME2_INDDMY
    DM2F_INDDMY_HD  = RECTANGLES dm2_w_INDDMY_HD dm2_l_INDDMY_HD dm2_s_INDDMY_HD INSIDE OF LAYER FILL2_INDDMY_HD
#ENDIF	
	
#ELSE


#IFDEF 12K_THICK_Mr_M2

    minOPENM2 = DENSITY M2x < minD_M2 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M2Min.den
    emptyOPENM2 = DENSITY M2x < emptyD_M2 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M2Empty.den

    M2InnerHole = HOLES M2i INNER

    M2BigHole = SIZE M2InnerHole BY - excludeHoleSize/2
    M2ExcHole = ((M2InnerHole OUTSIDE M2BigHole) NOT M2i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK2  = (SIZE DM2EXCL BY (dm2DMEXCL + grid)) OR MIM2_x // DM2 to DM2EXCL
    FRAMEA2 = SIZE M2i BY (dm2M2 + grid) // DM2 to metal
    FRAMEB2 = SIZE (WITH WIDTH M2i > wideM2) BY (dm2WM2 + grid)
