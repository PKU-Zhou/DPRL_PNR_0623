#ENDIF

// Find DVIA9 fillable regions.  Consider enclosure to lower DM9, enclosure to upper DM10, DVIA9 size.

VARIABLE DM9_F_4_REGION_DVIA9_SHORTENED_LENGTH DVIA9_EN_2 - DVIA9_EN_1

#IFDEF VERTICAL_DM9
DM9_F_4_REGION_DVIA9_spec_B_pre = RECTANGLE DM9F_FOR_DVIA9F_REGION == WM9_303_SLOT BY == LM9_303_SLOT
DM9_F_4_REGION_DVIA9_spec_B     = DM9_F_4_REGION_DVIA9_spec_B_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA9_spec_B_pre == WM9_303_SLOT) INSIDE BY DM9_F_4_REGION_DVIA9_SHORTENED_LENGTH)

DM9_F_4_REGION_DVIA9_spec_M_pre = RECTANGLE DM9F_FOR_DVIA9F_REGION == WM9_302 BY == LM9_302
DM9_F_4_REGION_DVIA9_spec_M     = DM9_F_4_REGION_DVIA9_spec_M_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA9_spec_M_pre == WM9_302) INSIDE BY DM9_F_4_REGION_DVIA9_SHORTENED_LENGTH)

DM9_F_4_REGION_DVIA9_spec_S_pre = RECTANGLE DM9F_FOR_DVIA9F_REGION == WM9_301 BY == LM9_301
DM9_F_4_REGION_DVIA9_spec_S     = DM9_F_4_REGION_DVIA9_spec_S_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA9_spec_S_pre == WM9_301) INSIDE BY DM9_F_4_REGION_DVIA9_SHORTENED_LENGTH)
#ELSE
DM9_F_4_REGION_DVIA9_spec_B_pre = RECTANGLE DM9F_FOR_DVIA9F_REGION == LM9_303_SLOT BY == WM9_303_SLOT
DM9_F_4_REGION_DVIA9_spec_B     = DM9_F_4_REGION_DVIA9_spec_B_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA9_spec_B_pre == LM9_303_SLOT) INSIDE BY DM9_F_4_REGION_DVIA9_SHORTENED_LENGTH)

DM9_F_4_REGION_DVIA9_spec_M_pre = RECTANGLE DM9F_FOR_DVIA9F_REGION == LM9_302 BY == WM9_302
DM9_F_4_REGION_DVIA9_spec_M     = DM9_F_4_REGION_DVIA9_spec_M_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA9_spec_M_pre == LM9_302) INSIDE BY DM9_F_4_REGION_DVIA9_SHORTENED_LENGTH)

DM9_F_4_REGION_DVIA9_spec_S_pre = RECTANGLE DM9F_FOR_DVIA9F_REGION == LM9_301 BY == WM9_301
DM9_F_4_REGION_DVIA9_spec_S     = DM9_F_4_REGION_DVIA9_spec_S_pre NOT (EXPAND EDGE (LENGTH DM9_F_4_REGION_DVIA9_spec_S_pre == LM9_301) INSIDE BY DM9_F_4_REGION_DVIA9_SHORTENED_LENGTH)
#ENDIF
DM9_F_4_REGION_DVIA9_square_pre = RECTANGLE DM9F_FOR_DVIA9F_REGION ASPECT == 1
DM9_F_4_REGION_DVIA9_square     = SIZE DM9_F_4_REGION_DVIA9_square_pre BY -DM9_F_4_REGION_DVIA9_SHORTENED_LENGTH

DM9F_FOR_DVIA9F_REGION_4parts = (DM9_F_4_REGION_DVIA9_spec_B OR DM9_F_4_REGION_DVIA9_spec_M) OR (DM9_F_4_REGION_DVIA9_spec_S OR DM9_F_4_REGION_DVIA9_square)
DM9F_FOR_DVIA9F_REGION_remainder_pre_not = (DM9_F_4_REGION_DVIA9_spec_B_pre OR DM9_F_4_REGION_DVIA9_spec_M_pre) OR (DM9_F_4_REGION_DVIA9_spec_S_pre OR DM9_F_4_REGION_DVIA9_square_pre)
DM9F_FOR_DVIA9F_REGION_remainder = DM9F_FOR_DVIA9F_REGION NOT DM9F_FOR_DVIA9F_REGION_remainder_pre_not

    DM9F_FOR_DVIA9F_REGION_remainder_EDGE = LENGTH DM9F_FOR_DVIA9F_REGION_remainder > 0
    DM9F_FOR_DVIA9F_REGION_remainder_PROP = DFM PROPERTY DM9F_FOR_DVIA9F_REGION_remainder DM9F_FOR_DVIA9F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM9F_FOR_DVIA9F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM9F_FOR_DVIA9F_REGION_remainder_EDGE)) ]
    DM9F_FOR_DVIA9F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM9F_FOR_DVIA9F_REGION_remainder_EDGE DM9F_FOR_DVIA9F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM9F_FOR_DVIA9F_REGION_remainder_EDGE) - PROPERTY(DM9F_FOR_DVIA9F_REGION_remainder_PROP, DM9F_FOR_DVIA9F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM9F_FOR_DVIA9F_REGION2 = DM9F_FOR_DVIA9F_REGION_remainder NOT (EXPAND EDGE DM9F_FOR_DVIA9F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM9_F_4_REGION_DVIA9_SHORTENED_LENGTH)


VARIABLE DM10_F_4_REGION_DVIA9_SHORTENED_LENGTH DM10_EN_3 - DM10_EN_2

#IFDEF VERTICAL_DM10
DM10_F_4_REGION_DVIA9_spec_B_pre = RECTANGLE DM10F_FOR_DVIA9F_REGION == WM10_303_SLOT BY == LM10_303_SLOT
DM10_F_4_REGION_DVIA9_spec_B     = DM10_F_4_REGION_DVIA9_spec_B_pre NOT (EXPAND EDGE (LENGTH DM10_F_4_REGION_DVIA9_spec_B_pre == WM10_303_SLOT) INSIDE BY DM10_F_4_REGION_DVIA9_SHORTENED_LENGTH)

DM10_F_4_REGION_DVIA9_spec_M_pre = RECTANGLE DM10F_FOR_DVIA9F_REGION == WM10_302 BY == LM10_302
DM10_F_4_REGION_DVIA9_spec_M     = DM10_F_4_REGION_DVIA9_spec_M_pre NOT (EXPAND EDGE (LENGTH DM10_F_4_REGION_DVIA9_spec_M_pre == WM10_302) INSIDE BY DM10_F_4_REGION_DVIA9_SHORTENED_LENGTH)

DM10_F_4_REGION_DVIA9_spec_S_pre = RECTANGLE DM10F_FOR_DVIA9F_REGION == WM10_301 BY == LM10_301
DM10_F_4_REGION_DVIA9_spec_S     = DM10_F_4_REGION_DVIA9_spec_S_pre NOT (EXPAND EDGE (LENGTH DM10_F_4_REGION_DVIA9_spec_S_pre == WM10_301) INSIDE BY DM10_F_4_REGION_DVIA9_SHORTENED_LENGTH)
#ELSE
DM10_F_4_REGION_DVIA9_spec_B_pre = RECTANGLE DM10F_FOR_DVIA9F_REGION == LM10_303_SLOT BY == WM10_303_SLOT
DM10_F_4_REGION_DVIA9_spec_B     = DM10_F_4_REGION_DVIA9_spec_B_pre NOT (EXPAND EDGE (LENGTH DM10_F_4_REGION_DVIA9_spec_B_pre == LM10_303_SLOT) INSIDE BY DM10_F_4_REGION_DVIA9_SHORTENED_LENGTH)

DM10_F_4_REGION_DVIA9_spec_M_pre = RECTANGLE DM10F_FOR_DVIA9F_REGION == LM10_302 BY == WM10_302
DM10_F_4_REGION_DVIA9_spec_M     = DM10_F_4_REGION_DVIA9_spec_M_pre NOT (EXPAND EDGE (LENGTH DM10_F_4_REGION_DVIA9_spec_M_pre == LM10_302) INSIDE BY DM10_F_4_REGION_DVIA9_SHORTENED_LENGTH)

DM10_F_4_REGION_DVIA9_spec_S_pre = RECTANGLE DM10F_FOR_DVIA9F_REGION == LM10_301 BY == WM10_301
DM10_F_4_REGION_DVIA9_spec_S     = DM10_F_4_REGION_DVIA9_spec_S_pre NOT (EXPAND EDGE (LENGTH DM10_F_4_REGION_DVIA9_spec_S_pre == LM10_301) INSIDE BY DM10_F_4_REGION_DVIA9_SHORTENED_LENGTH)
#ENDIF

DM10_F_4_REGION_DVIA9_square_pre = RECTANGLE DM10F_FOR_DVIA9F_REGION ASPECT == 1
DM10_F_4_REGION_DVIA9_square     = SIZE DM10_F_4_REGION_DVIA9_square_pre BY -DM10_F_4_REGION_DVIA9_SHORTENED_LENGTH

DM10F_FOR_DVIA9F_REGION_4parts = (DM10_F_4_REGION_DVIA9_spec_B OR DM10_F_4_REGION_DVIA9_spec_M) OR (DM10_F_4_REGION_DVIA9_spec_S OR DM10_F_4_REGION_DVIA9_square)
DM10F_FOR_DVIA9F_REGION_remainder_pre_not = (DM10_F_4_REGION_DVIA9_spec_B_pre OR DM10_F_4_REGION_DVIA9_spec_M_pre) OR (DM10_F_4_REGION_DVIA9_spec_S_pre OR DM10_F_4_REGION_DVIA9_square_pre)
DM10F_FOR_DVIA9F_REGION_remainder = DM10F_FOR_DVIA9F_REGION NOT DM10F_FOR_DVIA9F_REGION_remainder_pre_not

    DM10F_FOR_DVIA9F_REGION_remainder_EDGE = LENGTH DM10F_FOR_DVIA9F_REGION_remainder > 0
    DM10F_FOR_DVIA9F_REGION_remainder_PROP = DFM PROPERTY DM10F_FOR_DVIA9F_REGION_remainder DM10F_FOR_DVIA9F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM10F_FOR_DVIA9F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM10F_FOR_DVIA9F_REGION_remainder_EDGE)) ]
    DM10F_FOR_DVIA9F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM10F_FOR_DVIA9F_REGION_remainder_EDGE DM10F_FOR_DVIA9F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM10F_FOR_DVIA9F_REGION_remainder_EDGE) - PROPERTY(DM10F_FOR_DVIA9F_REGION_remainder_PROP, DM10F_FOR_DVIA9F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM10F_FOR_DVIA9F_REGION2 = DM10F_FOR_DVIA9F_REGION_remainder NOT (EXPAND EDGE DM10F_FOR_DVIA9F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM10_F_4_REGION_DVIA9_SHORTENED_LENGTH)

DVIA9F_BASE_REGION = (((((SIZE (DM9F_FOR_DVIA9F_REGION2 OR DM9F_FOR_DVIA9F_REGION_4parts) BY -DVIA9_EN_1) AND (SIZE (DM10F_FOR_DVIA9F_REGION2 OR DM10F_FOR_DVIA9F_REGION_4parts) BY -DM10_EN_2)) WITH WIDTH >= DVIA9_W_1) NOT (SIZE DVIA9EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA9i BY (DVIA9_S_1 + grid))) NOT (SIZE VIA9i BY (DVIA9_S_2 + grid))




// Merge DVIA9 fillable regions, and find DVIA9 seeds by maintaining spacing DVIA9_S_1.
DVIA9F_SEED_REGION_1 = (((SIZE DVIA9F_BASE_REGION BY DVIA9F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA9EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA9i BY (DVIA9_S_1 + grid))) NOT (SIZE VIA9i BY (DVIA9_S_2 + grid))
DVIA9F_SEED_1 = RECTANGLES DVIA9_W_1 DVIA9_W_1 DVIA9_S_1 INSIDE OF LAYER DVIA9F_SEED_REGION_1

// Find DVIA9 in the DVIA9 fillable and spacing-maintained regions.
DVIA9F_REGION_1 = (DVIA9F_BASE_REGION INTERACT DVIA9F_SEED_1) NOT TOUCH DVIA9F_SEED_1
DVIA9F_pre1_1_pre1 = RECTANGLES DVIA9_W_1 DVIA9_W_1 DVIA9_S_1 INSIDE OF LAYER DVIA9F_REGION_1

// post-DRC
DVIA9F_pre1_1_pre2 = DVIA9F_pre1_1_pre1 NOT INTERACT (EXT DVIA9F_pre1_1_pre1 < DVIA9_S_1 ABUT SINGULAR REGION)
DVIA9F_pre1_1_pre3 = DVIA9F_pre1_1_pre2 NOT INTERACT (EXT DVIA9F_pre1_1_pre2 DUVIA9i < DVIA9_S_1 ABUT SINGULAR REGION)
DVIA9F_pre1_1_pre4 = DVIA9F_pre1_1_pre3 NOT INTERACT (EXT DVIA9F_pre1_1_pre3 VIA9i < DVIA9_S_2 ABUT SINGULAR REGION)
DVIA9F_pre1_1_pre5 = DVIA9F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA9F_pre1_1_pre4 DM9F_FOR_DVIA9F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA9_EN_2 OPPOSITE 0 DVIA9_EN_2 OPPOSITE)
DVIA9F_pre1_1      = DVIA9F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA9F_pre1_1_pre5 DM10F_FOR_DVIA9F_REGION ABUT < 90 SINGULAR GOOD 0 DM10_EN_3 OPPOSITE 0 DM10_EN_3 OPPOSITE)

// Merge DVIA9 fillable regions, and find DVIA9 seeds by maintaining spacing DVIA9_S_1.
DVIA9F_SEED_REGION_2 = (((SIZE (DVIA9F_BASE_REGION NOT INTERACT (SIZE DVIA9F_pre1_1 BY DVIA9_S_1)) BY DVIA9F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA9EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA9i BY (DVIA9_S_1 + grid))) NOT (SIZE VIA9i BY (DVIA9_S_2 + grid))
DVIA9F_SEED_2 = RECTANGLES DVIA9_W_1 DVIA9_W_1 DVIA9_S_1 INSIDE OF LAYER DVIA9F_SEED_REGION_2

// Find DVIA9 in the DVIA9 fillable and spacing-maintained regions.
DVIA9F_REGION_2 = (DVIA9F_BASE_REGION INTERACT DVIA9F_SEED_2) NOT TOUCH DVIA9F_SEED_2
DVIA9F_pre1_2 = RECTANGLES DVIA9_W_1 DVIA9_W_1 DVIA9_S_1 INSIDE OF LAYER DVIA9F_REGION_2

// post-DRC
DVIA9F_pre1 = DVIA9F_pre1_1 OR DVIA9F_pre1_2
DVIA9F_pre2 = DVIA9F_pre1 NOT INTERACT (EXT DVIA9F_pre1 < DVIA9_S_1 ABUT SINGULAR REGION)
DVIA9F_pre3 = DVIA9F_pre2 NOT INTERACT (EXT DVIA9F_pre2 DUVIA9i < DVIA9_S_1 ABUT SINGULAR REGION)
DVIA9F_pre4 = DVIA9F_pre3 NOT INTERACT (EXT DVIA9F_pre3 VIA9i < DVIA9_S_2 ABUT SINGULAR REGION)
DVIA9F_pre5 = DVIA9F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA9F_pre4 DM9F_FOR_DVIA9F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA9_EN_2 OPPOSITE 0 DVIA9_EN_2 OPPOSITE)
DVIA9F      = DVIA9F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA9F_pre5 DM10F_FOR_DVIA9F_REGION ABUT < 90 SINGULAR GOOD 0 DM10_EN_3 OPPOSITE 0 DM10_EN_3 OPPOSITE)

#ENDIF
#ENDIF
