    BLOCK4 = (SIZE DM4EXCL BY (dm2DMEXCL + grid)) OR  MIM4_x // DM4 to DM4EXCL
    FRAMEA4 = SIZE M4i BY (dm2M4 + grid) // DM4 to metal
    FRAMEB4 = SIZE (WITH WIDTH M4i > wideM4) BY (dm2WM4 + grid)
    FRAMEC4 = SIZE DUM4 BY (dm2DM4 + grid)   // DM4 to existed dummy metal 0.6um
    FRAME4Pre = ((FRAMEA4 OR FRAMEB4) OR FRAMEC4) OR M4ExcHole
    FRAME4INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm4_s2m4_INDDMY + grid)
    FRAME4 = ((FRAME4Pre OR FRAME4INDDMY) OR BLOCK4) OR NFILL
    
    OPENM4 = PUSH ((minOPENM4 OR emptyOPENM4) AND CHIP)
    FILL4 = OPENM4 NOT FRAME4
    FILLW4pre = SIZE FILL4 BY - (Wdm2M4 + grid)
    FILLW4 = WITH WIDTH FILLW4pre >= WdmW_M4
    M4FW = RECTANGLES WdmW_M4 WdmL_M4 WdmS_M4 OFFSET WdmO_M4 INSIDE OF LAYER FILLW4
    M4FW_EXP = SIZE M4FW BY (WdmS_M4 /2 + grid) OVERUNDER //merge the gaps
    FILLM4pre = FILL4 NOT (SIZE M4FW_EXP BY (MdmS_M4 + grid))
    FILLM4 = WITH WIDTH FILLM4pre >= MdmW_M4
    M4F1 = RECTANGLES MdmW_M4 MdmL_M4 MdmS_M4 OFFSET MdmO_M4 INSIDE OF LAYER FILLM4
    M4R1pre = FILLM4pre NOT (SIZE M4F1 BY (dmS_M4 + grid))
    M4R1 = WITH WIDTH M4R1pre >= dmW_M4

    M4F2 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 OFFSET dmO_M4 INSIDE OF LAYER M4R1
    M4R2pre = M4R1 NOT (SIZE M4F2 BY (dmS_M4 + grid))
    M4R2 = WITH WIDTH M4R2pre >= dmW_M4

    M4F3 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 OFFSET dmO_M4 INSIDE OF LAYER M4R2
    M4R3pre = M4R2 NOT (SIZE M4F3 BY (dmS_M4 + grid))
    M4R3 = WITH WIDTH M4R3pre >= dmW_M4

    M4F4 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 INSIDE OF LAYER M4R3

    M4F = (((M4F1 OR M4F2) OR M4F3) OR M4F4) OR M4FW
    FM4 = M4F NOT INTERACT (EXT M4F < dmS_M4 ABUT SINGULAR REGION)

    maxOPENM4 = DENSITY M4x FM4 > maxD_M4 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M4Max.den

    FM4F = FM4 OUTSIDE maxOPENM4

    D25M4 = DENSITY M4x FM4F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M4Min.den

    RM4EXC = SIZE FM4F BY (Odm2DM4 + grid)
    D25M4pM = (((PUSH D25M4) NOT FRAME4) NOT RM4EXC) AND CHIP
    D25M4pM_1 = WITH WIDTH D25M4pM >= OdmW_M4

    RM4p1 = RECTANGLES OdmW_M4 OdmL_M4 OdmS_M4 INSIDE OF LAYER D25M4pM_1
    D25M4pM_2 = D25M4pM_1 NOT (SIZE RM4p1 BY (OdmS_M4 + grid))
    RM4p2 = RECTANGLES OdmL_M4 OdmW_M4 OdmS_M4 INSIDE OF LAYER D25M4pM_2

    RM4A = ((RM4p1 OR RM4p2) OUTSIDE RM4EXC) OUTSIDE FRAME4
    RM4  = RM4A NOT INTERACT (EXT RM4A < OdmS_M4 ABUT SINGULAR REGION)

    DM4F = FM4F OR RM4

    FRAME4_INDDMYA = SIZE M4i BY (dm4_s2m4_INDDMY + grid)
    FRAME4_INDDMYB = SIZE DUM4 BY (dm4_s_INDDMY + grid)
    FRAME4_INDDMYC = SIZE DM4F BY dm4_s_INDDMY
    FRAME4_INDDMY  = ((((FRAME4Pre OR BLOCK4) OR FRAME4_INDDMYA) OR FRAME4_INDDMYB) OR FRAME4_INDDMYC) OR NFILL
    FILL4_INDDMY   = ooINDDMY NOT FRAME4_INDDMY
    DM4F_INDDMY    = RECTANGLES dm4_w_INDDMY dm4_l_INDDMY dm4_s_INDDMY INSIDE OF LAYER FILL4_INDDMY

#IFDEF FILL_indDM4
    FILL4_INDDMY_HD = (SIZE INDDMY_HD BY -(dm4_s_INDDMY_HD + grid)) NOT FRAME4_INDDMY
    DM4F_INDDMY_HD  = RECTANGLES dm4_w_INDDMY_HD dm4_l_INDDMY_HD dm4_s_INDDMY_HD INSIDE OF LAYER FILL4_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M4

    D30M4 = DENSITY M4x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M4.den30
    D40M4 = DENSITY M4x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M4.den40
    D50M4 = DENSITY M4x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M4.den50
    emptyM4 = DENSITY M4x < emptyD_M4 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M4.den_empty

    M4InnerHole = HOLES M4i INNER

    M4BigHole = SIZE M4InnerHole BY - excludeHoleSize/2
    M4ExcHole = ((M4InnerHole OUTSIDE M4BigHole) NOT M4i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK4 = (SIZE DM4EXCL BY (dm2DMEXCL + grid)) OR MIM4_x

    FRAMEA4 = (SIZE M4i BY (DM4_301 + grid)) OR (SIZE (EXPAND EDGE (M4i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA4OPC = SIZE M4i BY (DM4_OPC + grid)
    FRAMEA4OPCDV33 = SIZE (M4i INTERACT M4_HVN_330Vx) BY (M4_S_1_1_a + grid)
    FRAMEA4OPCDV5 = SIZE (M4i INTERACT M4_HVN_500Vx) BY (M4_S_9_a + grid)
    FRAMEA4OPC45 = SIZE (EXPAND EDGE (M4i ANGLE == 45) OUTSIDE BY DM4_OPC_45 EXTEND BY DM4_OPC_45_E) BY grid
    FRAMEA4OPC45DV = SIZE (EXPAND EDGE ((M4i INTERACT M4_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM4_OPC_45 EXTEND BY DM4_OPC_45_E) BY grid

    FRAMEB4 = SIZE (WITH WIDTH M4i > wideM4) BY (dm2WM4 + grid)
    FRAMEC4 = SIZE DUM4 BY (dm2DM4 + grid)
    FRAMED4 = SIZE (WITH WIDTH M4i > wideM4_small) BY (dm2WM4_small + grid)
    FRAMEC4OPC = SIZE DUM4 BY (Odm2DM4 + grid)
    FRAME4Pre = ((FRAMEA4 OR FRAMEB4) OR (FRAMEC4 OR FRAMED4)) OR M4ExcHole
    FRAME4PreOPC = (((((((FRAMEA4OPC OR FRAMEA4OPCDV33) OR FRAMEA4OPCDV5) OR FRAMEC4OPC) OR M4ExcHole) OR FRAMEA4OPC45) OR FRAMEA4OPC45DV) OR FRAMEB4) OR FRAMED4
    FRAME4INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm4_s2m4_INDDMY + grid)

    FRAME4OPC = ((FRAME4PreOPC OR FRAME4INDDMY) OR BLOCK4) OR NFILLOPC

    FRAME4 = ((FRAME4Pre OR FRAME4INDDMY) OR BLOCK4) OR NFILL

    //****************************************************************************

    D30M4p = (PUSH D30M4) NOT FRAME4
    O30M4pre = D30M4p AND CHIP
    FD21M4s = COPY FRAME4

    O30M4preA = SIZE O30M4pre BY -DM4_303
    O30M4preB = O30M4preA WITH WIDTH >= WM4_303

    // 1st big
    F303M4 = RECTANGLES WM4_303 LM4_303 SM4_303 OFFSET OM4_303 INSIDE OF LAYER O30M4preB

    F303M4_EXP = SIZE F303M4 BY ( SM4_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M4preF1 = O30M4pre NOT (SIZE F303M4_EXP BY SM4_302)
    O30M4preF  = (SNAP (SIZE O30M4preF1 BY -grid) 5) AND O30M4preF1

    B30M4s = FD21M4s OR (SIZE F303M4_EXP BY (SM4_302+grid))
    O30M4 = O30M4preF NOT B30M4s

    // 3rd, middle
    F302M4 = RECTANGLES WM4_302 LM4_302 SM4_302 OFFSET OM4_302 INSIDE OF LAYER O30M4
    F302M4s = (SIZE F302M4 BY (SM4_301 + grid)) OR B30M4s
    R302M4pre = O30M4 NOT F302M4s
    R302M4 = WITH WIDTH R302M4pre >= WM4_301

    // 4th, small
    F3012M4 = RECTANGLES WM4_301 LM4_301 SM4_301 OFFSET OM4_301 INSIDE OF LAYER R302M4
    F3012M4s = (SIZE F3012M4 BY (SM4_301 + grid)) OR F302M4s
    R3012M4pre = R302M4pre NOT F3012M4s
    R3012M4 = WITH WIDTH R3012M4pre >= WM4_301

    // 5th, non-stagger small
    F301M4 = RECTANGLES WM4_301 LM4_301 SM4_301 INSIDE OF LAYER R3012M4 //MAINTAIN SPACING
    F301M4s = (SIZE F301M4 BY (SM4_301 + grid)) OR F3012M4s

    F30M4 = ((F302M4 OR F3012M4) OR F301M4) OR F303M4
    O40M4pre = (((PUSH D40M4) NOT FRAME4) NOT F301M4s) AND CHIP


    O40M4preA = SIZE O40M4pre BY -DM4_403
    O40M4preB = O40M4preA WITH WIDTH >= WM4_403

    // 1st big
    F403M4 = RECTANGLES WM4_403 LM4_403 SM4_403 OFFSET OM4_403 INSIDE OF LAYER O40M4preB

    F403M4_EXP = SIZE F403M4 BY ( SM4_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M4preF1 = O40M4pre NOT (SIZE F403M4_EXP BY SM4_402)
    O40M4preF  = (SNAP (SIZE O40M4preF1 BY -grid) 5) AND O40M4preF1

    B40M4s = F301M4s OR (SIZE F403M4_EXP BY (SM4_402+grid))
    O40M4 = O40M4preF NOT B40M4s

    // 3rd, middle
    F402M4 = RECTANGLES WM4_402 LM4_402 SM4_402 OFFSET OM4_402 INSIDE OF LAYER O40M4
    F402M4s = (SIZE F402M4 BY (SM4_401 + grid)) OR B40M4s
    R402M4pre = O40M4 NOT F402M4s
    R402M4 = WITH WIDTH R402M4pre >= WM4_401

    // 4th, small
    F4012M4 = RECTANGLES WM4_401 LM4_401 SM4_401 OFFSET OM4_401 INSIDE OF LAYER R402M4
    F4012M4s = (SIZE F4012M4 BY (SM4_401 + grid)) OR F402M4s
    R4012M4pre = R402M4pre NOT F4012M4s
    R4012M4 = WITH WIDTH R4012M4pre >= WM4_401

    // 5th, non-stagger small
    F401M4 = RECTANGLES WM4_401 LM4_401 SM4_401 INSIDE OF LAYER R4012M4 //MAINTAIN SPACING
    F401M4s = (SIZE F401M4 BY (SM4_401 + grid)) OR F4012M4s

    F40M4 = ((F402M4 OR F4012M4) OR F401M4) OR F403M4
    O50M4pre = (((PUSH (D50M4 OR emptyM4)) NOT FRAME4) NOT F401M4s) AND CHIP


    O50M4preA = SIZE O50M4pre BY -DM4_503
    O50M4preB = O50M4preA WITH WIDTH >= WM4_503

    // 1st big
    F503M4 = RECTANGLES WM4_503 LM4_503 SM4_503 OFFSET OM4_503 INSIDE OF LAYER O50M4preB

    F503M4_EXP = SIZE F503M4 BY ( SM4_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M4preF1 = O50M4pre NOT (SIZE F503M4_EXP BY SM4_502)
    O50M4preF  = (SNAP (SIZE O50M4preF1 BY -grid) 5) AND O50M4preF1

    B50M4s = F401M4s OR (SIZE F503M4_EXP BY (SM4_502+grid))
    O50M4 = O50M4preF NOT B50M4s

    // 3rd, middle
    F502M4 = RECTANGLES WM4_502 LM4_502 SM4_502 OFFSET OM4_502 INSIDE OF LAYER O50M4
    F502M4s = (SIZE F502M4 BY (SM4_501 + grid)) OR B50M4s
    R502M4pre = O50M4 NOT F502M4s
    R502M4 = WITH WIDTH R502M4pre >= WM4_501

    // 4th, small
    F5012M4 = RECTANGLES WM4_501 LM4_501 SM4_501 OFFSET OM4_501 INSIDE OF LAYER R502M4
    F5012M4s = (SIZE F5012M4 BY (SM4_501 + grid)) OR F502M4s
    R5012M4pre = R502M4pre NOT F5012M4s
    R5012M4 = WITH WIDTH R5012M4pre >= WM4_501

    // 5th, non-stagger small
    F501M4 = RECTANGLES WM4_501 LM4_501 SM4_501 INSIDE OF LAYER R5012M4 //MAINTAIN SPACING
    F501M4s = (SIZE F501M4 BY (SM4_501 + grid)) OR F5012M4s

    F50M4 = ((F502M4 OR F5012M4) OR F501M4) OR F503M4

//****************************************************************************

    exceedM4 = DENSITY M4x F30M4 F40M4 F50M4 > maxD_M4 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M4.den_exceed

    removeM4R = ((PUSH (exceedM4 AND (D50M4 OR emptyM4))) NOT FRAME4) AND CHIP
    removeM4P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM4R

    F30M4x = F30M4 NOT INTERACT removeM4P
    F40M4x = F40M4 NOT INTERACT removeM4P
    F50M4x = F50M4 NOT INTERACT removeM4P
    FM4xA  = (F30M4x OR F40M4x) OR F50M4x
    FM4x   = FM4xA NOT INTERACT (EXT FM4xA < DM4_S_1 ABUT SINGULAR REGION)

    ALLM4x = M4x OR FM4x
    lackM4 = DENSITY ALLM4x CHIP < DM4_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M4.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM4x)/AREA(CHIP) ]

    WDM4EXC = DUM4 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM4EXC = (SIZE FM4x BY Odm2DM4) OR (SIZE (((F303M4_EXP OR F403M4_EXP) OR F503M4_EXP) OR WDM4EXC) BY 1.5)

    lackM4pRM = ((((PUSH lackM4) NOT RM4EXC) NOT FRAME4OPC) NOT exceedM4) AND CHIP
    lackM4pRM_1 = WITH WIDTH lackM4pRM >= SM4_OPC

    RM4p1 = RECTANGLES WM4_OPC LM4_OPC WSM4_OPC LSM4_OPC INSIDE OF LAYER lackM4pRM_1
    lackM4pRM_2 = lackM4pRM_1 NOT (SIZE RM4p1 BY SM4_OPC)
    RM4p2 = RECTANGLES LM4_OPC WM4_OPC LSM4_OPC WSM4_OPC INSIDE OF LAYER lackM4pRM_2

    ODM4A = ((RM4p1 OR RM4p2) OUTSIDE RM4EXC) OUTSIDE FRAME4OPC
    ODM4F = ODM4A NOT INTERACT (EXT ODM4A < SM4_OPC ABUT SINGULAR REGION)

    DM4F = COPY FM4x

    FRAME4_INDDMYA = SIZE M4i BY (dm4_s2m4_INDDMY + grid)
    FRAME4_INDDMYB = SIZE DUM4 BY (dm4_s_INDDMY + grid)
    FRAME4_INDDMYC = SIZE DM4F BY dm4_s_INDDMY
    FRAME4_INDDMYD = SIZE ODM4F BY dm4_s2m4_INDDMY
    FRAME4_INDDMY  = (((((FRAME4Pre OR BLOCK4) OR FRAME4_INDDMYA) OR FRAME4_INDDMYB) OR FRAME4_INDDMYC) OR FRAME4_INDDMYD) OR NFILL
    FILL4_INDDMY   = ooINDDMY NOT FRAME4_INDDMY
    DM4F_INDDMY    = RECTANGLES dm4_w_INDDMY dm4_l_INDDMY dm4_s_INDDMY INSIDE OF LAYER FILL4_INDDMY


#IFDEF FILL_indDM4
    FILL4_INDDMY_HD = (SIZE INDDMY_HD BY -(dm4_s_INDDMY_HD + grid)) NOT FRAME4_INDDMY
    DM4F_INDDMY_HD  = RECTANGLES dm4_w_INDDMY_HD dm4_l_INDDMY_HD dm4_s_INDDMY_HD INSIDE OF LAYER FILL4_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M4

    minOPENM4 = DENSITY M4x < minD_M4 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M4Min.den
    emptyOPENM4 = DENSITY M4x < emptyD_M4 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M4Empty.den

    M4InnerHole = HOLES M4i INNER

    M4BigHole = SIZE M4InnerHole BY - excludeHoleSize/2
    M4ExcHole = ((M4InnerHole OUTSIDE M4BigHole) NOT M4i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK4 = (SIZE DM4EXCL BY (dm2DMEXCL + grid)) OR MIM4_x // DM4 to DM4EXCL
    FRAMEA4 = SIZE M4i BY (dm2M4 + grid) // DM4 to metal
    FRAMEB4 = SIZE (WITH WIDTH M4i > wideM4) BY (dm2WM4 + grid)
    FRAMEC4 = SIZE DUM4 BY (dm2DM4 + grid)   // DM4 to existed dummy metal 0.6um
    FRAME4Pre = ((FRAMEA4 OR FRAMEB4) OR FRAMEC4) OR M4ExcHole
    FRAME4INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm4_s2m4_INDDMY + grid)
    FRAME4 = ((FRAME4Pre OR FRAME4INDDMY) OR BLOCK4) OR NFILL
    
    OPENM4 = PUSH ((minOPENM4 OR emptyOPENM4) AND CHIP)
    FILL4 = OPENM4 NOT FRAME4
    FILLW4pre = SIZE FILL4 BY - (Wdm2M4 + grid)
    FILLW4 = WITH WIDTH FILLW4pre >= WdmW_M4
    M4FW = RECTANGLES WdmW_M4 WdmL_M4 WdmS_M4 OFFSET WdmO_M4 INSIDE OF LAYER FILLW4
    M4FW_EXP = SIZE M4FW BY (WdmS_M4 /2 + grid) OVERUNDER //merge the gaps
    FILLM4pre = FILL4 NOT (SIZE M4FW_EXP BY (MdmS_M4 + grid))
    FILLM4 = WITH WIDTH FILLM4pre >= MdmW_M4
    M4F1 = RECTANGLES MdmW_M4 MdmL_M4 MdmS_M4 OFFSET MdmO_M4 INSIDE OF LAYER FILLM4
    M4R1pre = FILLM4pre NOT (SIZE M4F1 BY (dmS_M4 + grid))
    M4R1 = WITH WIDTH M4R1pre >= dmW_M4

    M4F2 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 OFFSET dmO_M4 INSIDE OF LAYER M4R1
    M4R2pre = M4R1 NOT (SIZE M4F2 BY (dmS_M4 + grid))
    M4R2 = WITH WIDTH M4R2pre >= dmW_M4

    M4F3 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 OFFSET dmO_M4 INSIDE OF LAYER M4R2
    M4R3pre = M4R2 NOT (SIZE M4F3 BY (dmS_M4 + grid))
    M4R3 = WITH WIDTH M4R3pre >= dmW_M4

    M4F4 = RECTANGLES dmW_M4 dmL_M4 dmS_M4 INSIDE OF LAYER M4R3

    M4F = (((M4F1 OR M4F2) OR M4F3) OR M4F4) OR M4FW
    FM4 = M4F NOT INTERACT (EXT M4F < dmS_M4 ABUT SINGULAR REGION)

    maxOPENM4 = DENSITY M4x FM4 > maxD_M4 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M4Max.den

    FM4F = FM4 OUTSIDE maxOPENM4

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M4 = DENSITY M4x FM4F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M4Min.den

    RM4EXC = SIZE FM4F BY (Odm2DM4 + grid)
    // do not fill DMz_S over CTMDMY
    D25M4pM = (((PUSH D25M4) NOT FRAME4) NOT RM4EXC) AND CHIP
    D25M4pM_1 = WITH WIDTH D25M4pM >= OdmW_M4

    RM4p1 = RECTANGLES OdmW_M4 OdmL_M4 OdmS_M4 INSIDE OF LAYER D25M4pM_1
    D25M4pM_2 = D25M4pM_1 NOT (SIZE RM4p1 BY (OdmS_M4 + grid))
    RM4p2 = RECTANGLES OdmL_M4 OdmW_M4 OdmS_M4 INSIDE OF LAYER D25M4pM_2

    RM4A = ((RM4p1 OR RM4p2) OUTSIDE RM4EXC) OUTSIDE FRAME4
    RM4  = RM4A NOT INTERACT (EXT RM4A < OdmS_M4 ABUT SINGULAR REGION)

    DM4F = FM4F OR RM4

    FRAME4_INDDMYA = SIZE M4i BY (dm4_s2m4_INDDMY + grid)
    FRAME4_INDDMYB = SIZE DUM4 BY (dm4_s_INDDMY + grid)
    FRAME4_INDDMYC = SIZE DM4F BY dm4_s_INDDMY
    FRAME4_INDDMY  = ((((FRAME4Pre OR BLOCK4) OR FRAME4_INDDMYA) OR FRAME4_INDDMYB) OR FRAME4_INDDMYC) OR NFILL
    FILL4_INDDMY   = ooINDDMY NOT FRAME4_INDDMY
    DM4F_INDDMY    = RECTANGLES dm4_w_INDDMY dm4_l_INDDMY dm4_s_INDDMY INSIDE OF LAYER FILL4_INDDMY

#IFDEF FILL_indDM4
    FILL4_INDDMY_HD = (SIZE INDDMY_HD BY -(dm4_s_INDDMY_HD + grid)) NOT FRAME4_INDDMY
    DM4F_INDDMY_HD  = RECTANGLES dm4_w_INDDMY_HD dm4_l_INDDMY_HD dm4_s_INDDMY_HD INSIDE OF LAYER FILL4_INDDMY_HD
#ENDIF	

#ELSE



    D30M4 = DENSITY M4x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M4.den30
    D40M4 = DENSITY M4x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M4.den40
    D50M4 = DENSITY M4x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M4.den50
    emptyM4 = DENSITY M4x < emptyD_M4 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M4.den_empty

    M4InnerHole = HOLES M4i INNER
#IFDEF FILL_M4_DTCD
    VARIABLE M4_DTCD2Chip      2.5  //
    VARIABLE M4_DTCD2LOGO      10   //
    VARIABLE M4_DTCD2MOMDMY    0    // 
    VARIABLE M4_DTCD2LOWMEDN   0    //
    VARIABLE M4_DTCD2POFUSE    0    //
    VARIABLE M4_DTCD2DM4EXCL   0    //
    VARIABLE M4_DTCD2DM4CB2   0    //
    VARIABLE M4_DTCD2M4        2.63  // CB2.S.2
    VARIABLE M4_DTCD2DM4       1.5  // DMx.S.2
    VARIABLE M4_DTCD2TCDDMY_M4 150  // for idu measurement
    VARIABLE M4_DTCD2CTMDMY_5 0.112  // MIM.VIAz.S.5
    VARIABLE M4_DTCD2ICOVL     8
	M4_DTCDxChip        = CHIP NOT (SIZE CHIP BY -(M4_DTCD2Chip + grid))
    M4_DTCDxLOGO        = SIZE LOGO               BY (M4_DTCD2LOGO      + grid)
    M4_DTCDxMOMDMY      = SIZE MOMDMY             BY (M4_DTCD2MOMDMY    + grid)
    M4_DTCDxLOWMEDN     = SIZE LOWMEDN            BY (M4_DTCD2LOWMEDN   + grid)
    M4_DTCDxPOFUSE      = SIZE (FUSELINK AND POi) BY (M4_DTCD2POFUSE    + grid)
    M4_DTCDxDM4EXCL     = SIZE DM4EXCL            BY (M4_DTCD2DM4EXCL   + grid)
    M4_DTCDxDM4CB2      = SIZE CB2i               BY (M4_DTCD2DM4CB2    + grid)
    M4_DTCDxM4          = SIZE M4i                BY (M4_DTCD2M4        + grid)
    M4_DTCDxDM4         = SIZE DUM4               BY (M4_DTCD2DM4       + grid)
    M4_DTCDxTCDDMY_M4   = SIZE TCDDMY_M4          BY (M4_DTCD2TCDDMY_M4 + grid)
    M4_DTCDxTCDDMY_FM4  = SIZE TCDDMY_FM4         BY (M4_DTCD2TCDDMY_M4 + grid)
    M4_DTCDxTCDDMY_FDM4 = SIZE TCDDMY_FDM4        BY (M4_DTCD2TCDDMY_M4 + grid)
    M4_DTCDxICOVL       = SIZE ICOVL              BY (M4_DTCD2ICOVL     + grid)
    M4_DTCDxCTMDMY_5   = SIZE CTMDMY_5          BY (M4_DTCD2CTMDMY_5  + grid)

    M4_DTCDx = (((((((((((((M4_DTCDxChip OR M4_DTCDxLOGO) OR M4_DTCDxLOWMEDN) OR M4_DTCDxPOFUSE) OR M4_DTCDxDM4EXCL) OR M4_DTCDxM4) OR M4_DTCDxDM4) OR M4_DTCDxTCDDMY_M4) OR M4_DTCDxTCDDMY_FM4) OR M4_DTCDxTCDDMY_FDM4) OR FRAME4INDDMY) OR M4_DTCDxMOMDMY) OR M4_DTCDxDM4CB2) OR M4_DTCDxCTMDMY_5) OR M4_DTCDxICOVL
    M4_DTCDo = CHIP NOT M4_DTCDx

