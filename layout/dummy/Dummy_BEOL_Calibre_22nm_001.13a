    FM4 = M4F NOT INTERACT (EXT M4F < dmS_M4 ABUT SINGULAR REGION)

    maxOPENM4 = DENSITY M4x FM4 > maxD_M4 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M4Max.den

    FM4F = FM4 OUTSIDE maxOPENM4

    // DMy_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M4 = DENSITY M4x FM4F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M4Min.den

    RM4EXC = SIZE FM4F BY (Odm2DM4 + grid)
    // do not fill DMy_S over CTMDMY
    D25M4pM = (((PUSH D25M4) NOT FRAME4) NOT RM4EXC) AND CHIP
    D25M4pM_1 = WITH WIDTH D25M4pM >= OdmW_M4

    RM4p1 = RECTANGLES OdmW_M4 OdmL_M4 OdmS_M4 INSIDE OF LAYER D25M4pM_1
    D25M4pM_2 = D25M4pM_1 NOT (SIZE RM4p1 BY (OdmS_M4 + grid))
    RM4p2 = RECTANGLES OdmL_M4 OdmW_M4 OdmS_M4 INSIDE OF LAYER D25M4pM_2

    RM4A = ((RM4p1 OR RM4p2) OUTSIDE RM4EXC) OUTSIDE FRAME4
    RM4  = RM4A NOT INTERACT (EXT RM4A < OdmS_M4 ABUT SINGULAR REGION)

    DM4F = FM4F OR RM4

    FRAME4_INDDMYA = SIZE M4i BY (dm4_s2m4_INDDMY + grid)
    FRAME4_INDDMYB = SIZE DUM4 BY (dm4_s_INDDMY + grid)
    FRAME4_INDDMYC = SIZE DM4F BY dm4_s_INDDMY
    FRAME4_INDDMY  = ((((FRAME4Pre OR BLOCK4) OR FRAME4_INDDMYA) OR FRAME4_INDDMYB) OR FRAME4_INDDMYC) OR NFILL
    FILL4_INDDMY   = ooINDDMY NOT FRAME4_INDDMY
    DM4F_INDDMY    = RECTANGLES dm4_w_INDDMY dm4_l_INDDMY dm4_s_INDDMY INSIDE OF LAYER FILL4_INDDMY


