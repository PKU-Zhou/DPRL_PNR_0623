    M12InnerHole = HOLES M12i INNER

    M12BigHole = SIZE M12InnerHole BY - excludeHoleSize/2
    M12ExcHole = ((M12InnerHole OUTSIDE M12BigHole) NOT M12i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK12 = (SIZE DM12EXCL BY (dm2DMEXCL + grid)) OR MIM12_x

    FRAMEA12 = (SIZE M12i BY (DM12_301 + grid)) OR (SIZE (EXPAND EDGE (M12i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA12OPC = SIZE M12i BY (DM12_OPC + grid)
    FRAMEA12OPCDV33 = SIZE (M12i INTERACT M12_HVN_330Vx) BY (M12_S_1_1_a + grid)
    FRAMEA12OPCDV5 = SIZE (M12i INTERACT M12_HVN_500Vx) BY (M12_S_9_a + grid)
    FRAMEA12OPC45 = SIZE (EXPAND EDGE (M12i ANGLE == 45) OUTSIDE BY DM12_OPC_45 EXTEND BY DM12_OPC_45_E) BY grid
    FRAMEA12OPC45DV = SIZE (EXPAND EDGE ((M12i INTERACT M12_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM12_OPC_45 EXTEND BY DM12_OPC_45_E) BY grid

    FRAMEB12 = SIZE (WITH WIDTH M12i > wideM12) BY (dm2WM12 + grid)
    FRAMEC12 = SIZE DUM12 BY (dm2DM12 + grid)
    FRAMED12 = SIZE (WITH WIDTH M12i > wideM12_small) BY (dm2WM12_small + grid)
    FRAMEC12OPC = SIZE DUM12 BY (Odm2DM12 + grid)
    FRAME12Pre = ((FRAMEA12 OR FRAMEB12) OR (FRAMEC12 OR FRAMED12)) OR M12ExcHole
    FRAME12PreOPC = (((((((FRAMEA12OPC OR FRAMEA12OPCDV33) OR FRAMEA12OPCDV5) OR FRAMEC12OPC) OR M12ExcHole) OR FRAMEA12OPC45) OR FRAMEA12OPC45DV) OR FRAMEB12) OR FRAMED12
    FRAME12INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm12_s2m12_INDDMY + grid)

    FRAME12OPC = ((FRAME12PreOPC OR FRAME12INDDMY) OR BLOCK12) OR NFILLOPC

    FRAME12 = ((FRAME12Pre OR FRAME12INDDMY) OR BLOCK12) OR NFILL

    //****************************************************************************

    D30M12p = (PUSH D30M12) NOT FRAME12
    O30M12pre = D30M12p AND CHIP
    FD21M12s = COPY FRAME12

    O30M12preA = SIZE O30M12pre BY -DM12_303
    O30M12preB = O30M12preA WITH WIDTH >= WM12_303

    // 1st big
    F303M12 = RECTANGLES WM12_303 LM12_303 SM12_303 OFFSET OM12_303 INSIDE OF LAYER O30M12preB

    F303M12_EXP = SIZE F303M12 BY ( SM12_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M12preF1 = O30M12pre NOT (SIZE F303M12_EXP BY SM12_302)
    O30M12preF  = (SNAP (SIZE O30M12preF1 BY -grid) 5) AND O30M12preF1

    B30M12s = FD21M12s OR (SIZE F303M12_EXP BY (SM12_302+grid))
    O30M12 = O30M12preF NOT B30M12s

    // 3rd, middle
    F302M12 = RECTANGLES WM12_302 LM12_302 SM12_302 OFFSET OM12_302 INSIDE OF LAYER O30M12
    F302M12s = (SIZE F302M12 BY (SM12_301 + grid)) OR B30M12s
    R302M12pre = O30M12 NOT F302M12s
    R302M12 = WITH WIDTH R302M12pre >= WM12_301

    // 4th, small
    F3012M12 = RECTANGLES WM12_301 LM12_301 SM12_301 OFFSET OM12_301 INSIDE OF LAYER R302M12
    F3012M12s = (SIZE F3012M12 BY (SM12_301 + grid)) OR F302M12s
    R3012M12pre = R302M12pre NOT F3012M12s
    R3012M12 = WITH WIDTH R3012M12pre >= WM12_301

    // 5th, non-stagger small
    F301M12 = RECTANGLES WM12_301 LM12_301 SM12_301 INSIDE OF LAYER R3012M12 //MAINTAIN SPACING
    F301M12s = (SIZE F301M12 BY (SM12_301 + grid)) OR F3012M12s

    F30M12 = ((F302M12 OR F3012M12) OR F301M12) OR F303M12
    O40M12pre = (((PUSH D40M12) NOT FRAME12) NOT F301M12s) AND CHIP


    O40M12preA = SIZE O40M12pre BY -DM12_403
    O40M12preB = O40M12preA WITH WIDTH >= WM12_403

    // 1st big
    F403M12 = RECTANGLES WM12_403 LM12_403 SM12_403 OFFSET OM12_403 INSIDE OF LAYER O40M12preB

    F403M12_EXP = SIZE F403M12 BY ( SM12_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M12preF1 = O40M12pre NOT (SIZE F403M12_EXP BY SM12_402)
    O40M12preF  = (SNAP (SIZE O40M12preF1 BY -grid) 5) AND O40M12preF1

    B40M12s = F301M12s OR (SIZE F403M12_EXP BY (SM12_402+grid))
    O40M12 = O40M12preF NOT B40M12s

    // 3rd, middle
    F402M12 = RECTANGLES WM12_402 LM12_402 SM12_402 OFFSET OM12_402 INSIDE OF LAYER O40M12
    F402M12s = (SIZE F402M12 BY (SM12_401 + grid)) OR B40M12s
    R402M12pre = O40M12 NOT F402M12s
    R402M12 = WITH WIDTH R402M12pre >= WM12_401

    // 4th, small
    F4012M12 = RECTANGLES WM12_401 LM12_401 SM12_401 OFFSET OM12_401 INSIDE OF LAYER R402M12
    F4012M12s = (SIZE F4012M12 BY (SM12_401 + grid)) OR F402M12s
    R4012M12pre = R402M12pre NOT F4012M12s
    R4012M12 = WITH WIDTH R4012M12pre >= WM12_401

    // 5th, non-stagger small
    F401M12 = RECTANGLES WM12_401 LM12_401 SM12_401 INSIDE OF LAYER R4012M12 //MAINTAIN SPACING
    F401M12s = (SIZE F401M12 BY (SM12_401 + grid)) OR F4012M12s

    F40M12 = ((F402M12 OR F4012M12) OR F401M12) OR F403M12
    O50M12pre = (((PUSH (D50M12 OR emptyM12)) NOT FRAME12) NOT F401M12s) AND CHIP


    O50M12preA = SIZE O50M12pre BY -DM12_503
    O50M12preB = O50M12preA WITH WIDTH >= WM12_503

    // 1st big
    F503M12 = RECTANGLES WM12_503 LM12_503 SM12_503 OFFSET OM12_503 INSIDE OF LAYER O50M12preB

    F503M12_EXP = SIZE F503M12 BY ( SM12_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M12preF1 = O50M12pre NOT (SIZE F503M12_EXP BY SM12_502)
    O50M12preF  = (SNAP (SIZE O50M12preF1 BY -grid) 5) AND O50M12preF1

    B50M12s = F401M12s OR (SIZE F503M12_EXP BY (SM12_502+grid))
    O50M12 = O50M12preF NOT B50M12s

    // 3rd, middle
    F502M12 = RECTANGLES WM12_502 LM12_502 SM12_502 OFFSET OM12_502 INSIDE OF LAYER O50M12
    F502M12s = (SIZE F502M12 BY (SM12_501 + grid)) OR B50M12s
    R502M12pre = O50M12 NOT F502M12s
    R502M12 = WITH WIDTH R502M12pre >= WM12_501

    // 4th, small
    F5012M12 = RECTANGLES WM12_501 LM12_501 SM12_501 OFFSET OM12_501 INSIDE OF LAYER R502M12
    F5012M12s = (SIZE F5012M12 BY (SM12_501 + grid)) OR F502M12s
    R5012M12pre = R502M12pre NOT F5012M12s
    R5012M12 = WITH WIDTH R5012M12pre >= WM12_501

    // 5th, non-stagger small
    F501M12 = RECTANGLES WM12_501 LM12_501 SM12_501 INSIDE OF LAYER R5012M12 //MAINTAIN SPACING
    F501M12s = (SIZE F501M12 BY (SM12_501 + grid)) OR F5012M12s

    F50M12 = ((F502M12 OR F5012M12) OR F501M12) OR F503M12

//****************************************************************************

    exceedM12 = DENSITY M12x F30M12 F40M12 F50M12 > maxD_M12 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M12.den_exceed

    removeM12R = ((PUSH (exceedM12 AND (D50M12 OR emptyM12))) NOT FRAME12) AND CHIP
    removeM12P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM12R

    F30M12x = F30M12 NOT INTERACT removeM12P
    F40M12x = F40M12 NOT INTERACT removeM12P
    F50M12x = F50M12 NOT INTERACT removeM12P
    FM12xA  = (F30M12x OR F40M12x) OR F50M12x
    FM12x   = FM12xA NOT INTERACT (EXT FM12xA < DM12_S_1 ABUT SINGULAR REGION)

    ALLM12x = M12x OR FM12x
    lackM12 = DENSITY ALLM12x CHIP < DM12_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M12.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM12x)/AREA(CHIP) ]

    WDM12EXC = DUM12 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM12EXC = (SIZE FM12x BY Odm2DM12) OR (SIZE (((F303M12_EXP OR F403M12_EXP) OR F503M12_EXP) OR WDM12EXC) BY 1.5)

    lackM12pRM = ((((PUSH lackM12) NOT RM12EXC) NOT FRAME12OPC) NOT exceedM12) AND CHIP
    lackM12pRM_1 = WITH WIDTH lackM12pRM >= SM12_OPC

    RM12p1 = RECTANGLES WM12_OPC LM12_OPC WSM12_OPC LSM12_OPC INSIDE OF LAYER lackM12pRM_1
    lackM12pRM_2 = lackM12pRM_1 NOT (SIZE RM12p1 BY SM12_OPC)
    RM12p2 = RECTANGLES LM12_OPC WM12_OPC LSM12_OPC WSM12_OPC INSIDE OF LAYER lackM12pRM_2

    ODM12A = ((RM12p1 OR RM12p2) OUTSIDE RM12EXC) OUTSIDE FRAME12OPC
    ODM12F = ODM12A NOT INTERACT (EXT ODM12A < SM12_OPC ABUT SINGULAR REGION)

    DM12F = COPY FM12x

    FRAME12_INDDMYA = SIZE M12i BY (dm12_s2m12_INDDMY + grid)
    FRAME12_INDDMYB = SIZE DUM12 BY (dm12_s_INDDMY + grid)
    FRAME12_INDDMYC = SIZE DM12F BY dm12_s_INDDMY
    FRAME12_INDDMYD = SIZE ODM12F BY dm12_s2m12_INDDMY
    FRAME12_INDDMY  = (((((FRAME12Pre OR BLOCK12) OR FRAME12_INDDMYA) OR FRAME12_INDDMYB) OR FRAME12_INDDMYC) OR FRAME12_INDDMYD) OR NFILL
    FILL12_INDDMY   = ooINDDMY NOT FRAME12_INDDMY
    DM12F_INDDMY    = RECTANGLES dm12_w_INDDMY dm12_l_INDDMY dm12_s_INDDMY INSIDE OF LAYER FILL12_INDDMY


#IFDEF FILL_indDM12
    FILL12_INDDMY_HD = (SIZE INDDMY_HD BY -(dm12_s_INDDMY_HD + grid)) NOT FRAME12_INDDMY
    DM12F_INDDMY_HD  = RECTANGLES dm12_w_INDDMY_HD dm12_l_INDDMY_HD dm12_s_INDDMY_HD INSIDE OF LAYER FILL12_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M12

    minOPENM12 = DENSITY M12x < minD_M12 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M12Min.den
    emptyOPENM12 = DENSITY M12x < emptyD_M12 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M12Empty.den

    M12InnerHole = HOLES M12i INNER

    M12BigHole = SIZE M12InnerHole BY - excludeHoleSize/2
    M12ExcHole = ((M12InnerHole OUTSIDE M12BigHole) NOT M12i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK12 = (SIZE DM12EXCL BY (dm2DMEXCL + grid)) OR MIM12_x // DM12 to DM12EXCL
    FRAMEA12 = SIZE M12i BY (dm2M12 + grid) // DM12 to metal
    FRAMEB12 = SIZE (WITH WIDTH M12i > wideM12) BY (dm2WM12 + grid)
    FRAMEC12 = SIZE DUM12 BY (dm2DM12 + grid)   // DM12 to existed dummy metal 0.6um
    FRAME12Pre = ((FRAMEA12 OR FRAMEB12) OR FRAMEC12) OR M12ExcHole
    FRAME12INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm12_s2m12_INDDMY + grid)
    FRAME12 = ((FRAME12Pre OR FRAME12INDDMY) OR BLOCK12) OR NFILL
    
    OPENM12 = PUSH ((minOPENM12 OR emptyOPENM12) AND CHIP)
    FILL12 = OPENM12 NOT FRAME12
    FILLW12pre = SIZE FILL12 BY - (Wdm2M12 + grid)
    FILLW12 = WITH WIDTH FILLW12pre >= WdmW_M12
    M12FW = RECTANGLES WdmW_M12 WdmL_M12 WdmS_M12 OFFSET WdmO_M12 INSIDE OF LAYER FILLW12
    M12FW_EXP = SIZE M12FW BY (WdmS_M12 /2 + grid) OVERUNDER //merge the gaps
    FILLM12pre = FILL12 NOT (SIZE M12FW_EXP BY (MdmS_M12 + grid))
    FILLM12 = WITH WIDTH FILLM12pre >= MdmW_M12
    M12F1 = RECTANGLES MdmW_M12 MdmL_M12 MdmS_M12 OFFSET MdmO_M12 INSIDE OF LAYER FILLM12
    M12R1pre = FILLM12pre NOT (SIZE M12F1 BY (dmS_M12 + grid))
    M12R1 = WITH WIDTH M12R1pre >= dmW_M12

    M12F2 = RECTANGLES dmW_M12 dmL_M12 dmS_M12 OFFSET dmO_M12 INSIDE OF LAYER M12R1
    M12R2pre = M12R1 NOT (SIZE M12F2 BY (dmS_M12 + grid))
    M12R2 = WITH WIDTH M12R2pre >= dmW_M12

    M12F3 = RECTANGLES dmW_M12 dmL_M12 dmS_M12 OFFSET dmO_M12 INSIDE OF LAYER M12R2
    M12R3pre = M12R2 NOT (SIZE M12F3 BY (dmS_M12 + grid))
    M12R3 = WITH WIDTH M12R3pre >= dmW_M12

    M12F4 = RECTANGLES dmW_M12 dmL_M12 dmS_M12 INSIDE OF LAYER M12R3

    M12F = (((M12F1 OR M12F2) OR M12F3) OR M12F4) OR M12FW
    FM12 = M12F NOT INTERACT (EXT M12F < dmS_M12 ABUT SINGULAR REGION)

    maxOPENM12 = DENSITY M12x FM12 > maxD_M12 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M12Max.den

    FM12F = FM12 OUTSIDE maxOPENM12

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M12 = DENSITY M12x FM12F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M12Min.den

    RM12EXC = SIZE FM12F BY (Odm2DM12 + grid)
    // do not fill DMz_S over CTMDMY
    D25M12pM = (((PUSH D25M12) NOT FRAME12) NOT RM12EXC) AND CHIP
    D25M12pM_1 = WITH WIDTH D25M12pM >= OdmW_M12

    RM12p1 = RECTANGLES OdmW_M12 OdmL_M12 OdmS_M12 INSIDE OF LAYER D25M12pM_1
    D25M12pM_2 = D25M12pM_1 NOT (SIZE RM12p1 BY (OdmS_M12 + grid))
    RM12p2 = RECTANGLES OdmL_M12 OdmW_M12 OdmS_M12 INSIDE OF LAYER D25M12pM_2

    RM12A = ((RM12p1 OR RM12p2) OUTSIDE RM12EXC) OUTSIDE FRAME12
    RM12  = RM12A NOT INTERACT (EXT RM12A < OdmS_M12 ABUT SINGULAR REGION)

    DM12F = FM12F OR RM12

    FRAME12_INDDMYA = SIZE M12i BY (dm12_s2m12_INDDMY + grid)
    FRAME12_INDDMYB = SIZE DUM12 BY (dm12_s_INDDMY + grid)
    FRAME12_INDDMYC = SIZE DM12F BY dm12_s_INDDMY
    FRAME12_INDDMY  = ((((FRAME12Pre OR BLOCK12) OR FRAME12_INDDMYA) OR FRAME12_INDDMYB) OR FRAME12_INDDMYC) OR NFILL
    FILL12_INDDMY   = ooINDDMY NOT FRAME12_INDDMY
    DM12F_INDDMY    = RECTANGLES dm12_w_INDDMY dm12_l_INDDMY dm12_s_INDDMY INSIDE OF LAYER FILL12_INDDMY

#IFDEF FILL_indDM12
    FILL12_INDDMY_HD = (SIZE INDDMY_HD BY -(dm12_s_INDDMY_HD + grid)) NOT FRAME12_INDDMY
    DM12F_INDDMY_HD  = RECTANGLES dm12_w_INDDMY_HD dm12_l_INDDMY_HD dm12_s_INDDMY_HD INSIDE OF LAYER FILL12_INDDMY_HD
#ENDIF	

#ELSE



    D30M12 = DENSITY M12x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M12.den30
    D40M12 = DENSITY M12x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M12.den40
    D50M12 = DENSITY M12x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M12.den50
    emptyM12 = DENSITY M12x < emptyD_M12 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M12.den_empty

    M12InnerHole = HOLES M12i INNER
    xM12_DTCD = COPY EMPTY

    M12BigHole = SIZE M12InnerHole BY - excludeHoleSize/2
    M12ExcHole = ((M12InnerHole OUTSIDE M12BigHole) NOT M12i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK12 = (SIZE DM12EXCL BY (dm2DMEXCL + grid)) OR MIM12_x

    FRAMEA12 = (SIZE M12i BY (DM12_301 + grid)) OR (SIZE (EXPAND EDGE (M12i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA12OPC = SIZE M12i BY (DM12_OPC + grid)
    FRAMEA12OPCwide = SIZE (M12i WITH WIDTH > DM12_OPC_wide_w) BY (DM12_OPC_wide + grid)
    FRAMEA12OPC45 = SIZE (EXPAND EDGE (M12i ANGLE == 45) OUTSIDE BY DM12_OPC_45 EXTEND BY DM12_OPC_45_E) BY grid
    FRAMEA12OPC45DV = SIZE (EXPAND EDGE ((M12i INTERACT M12_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM12_OPC_45 EXTEND BY DM12_OPC_45_E) BY grid
    FRAMEA12OPC_M12_S_14_wide = SIZE (M12i WITH WIDTH > M12_S_14_wide_w) BY (M12_S_14_wide + grid)
    FRAMEA12OPC_M12_S_17_wide = SIZE (M12i WITH WIDTH > M12_S_17_wide_w) BY (M12_S_17_wide + grid)
    FRAMEA12OPC_M12_S_20_wide = SIZE (M12i WITH WIDTH > M12_S_20_wide_w) BY (M12_S_20_wide + grid)
    FRAMEA12OPC_M12_S_23_wide = SIZE (M12i WITH WIDTH > M12_S_23_wide_w) BY (M12_S_23_wide + grid)
    FRAMEA12OPC_M12_S_33_VIA11   = SIZE VIA11_HV_5V_CHK	BY (M12_S_33 + grid)
    FRAMEA12OPC_M12_S_33b_VIA11DV   = SIZE (VIA11i INTERACT (M11_HVN_330Vx OR M12_HVN_330Vx))	BY (M12_S_33b + grid)
    FRAMEA12OPC_M12_S_33_VIA12    = SIZE VIA12_HV_5V_CHK	BY (M12_S_33 + grid)
    FRAMEA12OPC_M12_S_33b_VIA12DV    = SIZE (VIA12i INTERACT (M12_HVN_330Vx OR M13_HVN_330Vx))	BY (M12_S_33b + grid)
    FRAMEA12OPC_M12_S_37_VIA11_b = SIZE VIA11i_55V		BY (M12_S_37 + grid)
    FRAMEA12OPC_M12_S_37a_VIA11_bDV = SIZE (VIA11i INTERACT (M11_HVN_500Vx OR M12_HVN_500Vx))		BY (M12_S_37a + grid)
    FRAMEA12OPC_M12_S_37_VIA12_b  = SIZE VIA12i_55V			BY (M12_S_37 + grid)
    FRAMEA12OPC_M12_S_37a_VIA12_bDV  = SIZE (VIA12i INTERACT (M12_HVN_500Vx OR M13_HVN_500Vx))		BY (M12_S_37a + grid)
    FRAMEA12OPC_M12_S_37_VIA11   = SIZE VIA11i_65V		BY (M12_S_37 + grid)
	FRAMEA12OPC_M12_S_37_VIA12    = SIZE VIA12i_65V			BY (M12_S_37 + grid)

    FRAMEHVD12 = SIZE  M12i_65V  BY (M12_S_38 + grid)
    FRAMEHVD12_55V = SIZE  M12i_55V  BY (M12_S_38 + grid)
    FRAMEHVD12_55VDV = SIZE  (M12i INTERACT M12_HVN_500Vx)  BY (M12_S_38a + grid)
    FRAMEB12 = SIZE (WITH WIDTH M12i > wideM12) BY (dm2WM12 + grid)
    FRAMEC12 = SIZE DUM12 BY (dm2DM12 + grid)
    FRAMED12 = SIZE (WITH WIDTH M12i > wideM12_small) BY (dm2WM12_small + grid)
    FRAMEC12OPC = SIZE DUM12 BY (Odm2DM12 + grid)
    FRAME12Pre = ((FRAMEA12 OR FRAMEB12) OR (FRAMEC12 OR FRAMED12)) OR M12ExcHole
    FRAME12PreOPC = (((((((((((((((((((((FRAMEA12OPC OR FRAMEC12OPC) OR M12ExcHole) OR FRAMEA12OPCwide) OR FRAMEA12OPC45) OR FRAMEA12OPC45DV) OR FRAMEA12OPC_M12_S_14_wide) OR FRAMEA12OPC_M12_S_17_wide) OR FRAMEA12OPC_M12_S_20_wide) OR FRAMEA12OPC_M12_S_23_wide) OR FRAMEA12OPC_M12_S_33_VIA11) OR FRAMEA12OPC_M12_S_33b_VIA11DV) OR FRAMEA12OPC_M12_S_33_VIA12) OR FRAMEA12OPC_M12_S_33b_VIA12DV) OR FRAMEHVD12) OR FRAMEA12OPC_M12_S_37_VIA11) OR FRAMEA12OPC_M12_S_37_VIA11_b) OR FRAMEA12OPC_M12_S_37a_VIA11_bDV) OR FRAMEA12OPC_M12_S_37_VIA12) OR FRAMEA12OPC_M12_S_37_VIA12_b) OR FRAMEA12OPC_M12_S_37a_VIA12_bDV) OR FRAMEHVD12_55V) OR FRAMEHVD12_55VDV


    FRAME12INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm12_s2m12_INDDMY + grid)
    FRAME12OPC = (((FRAME12PreOPC OR FRAME12INDDMY) OR xM12_DTCD) OR BLOCK12) OR NFILLOPC_x

    FRAME12 = (((FRAME12Pre OR FRAME12INDDMY) OR xM12_DTCD) OR BLOCK12) OR NFILL_x

    D30M12p = (PUSH D30M12) NOT FRAME12
    O30M12pre = D30M12p AND CHIP
    FD21M12s = COPY FRAME12

    O30M12preA = SIZE O30M12pre BY -DM12_303
    O30M12preB = O30M12preA WITH WIDTH >= WM12_303

    // 1st big
    F303M12 = RECTANGLES WM12_303 LM12_303 SM12_303 OFFSET OM12_303 INSIDE OF LAYER O30M12preB
    F303M12_SLOT = RECTANGLES WM12_303_SLOT LM12_303_SLOT SM12_303_SLOT INSIDE OF LAYER F303M12

    F303M12_EXP = SIZE F303M12_SLOT BY ( SM12_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M12preF1 = O30M12pre NOT (SIZE F303M12_EXP BY SM12_302)
    O30M12preF  = (SNAP (SIZE O30M12preF1 BY -grid) 5) AND O30M12preF1

    B30M12s = FD21M12s OR (SIZE F303M12_EXP BY (SM12_302+grid))
    O30M12 = O30M12preF NOT B30M12s

    // 3rd, middle
    F302M12 = RECTANGLES WM12_302 LM12_302 SM12_302 OFFSET OM12_302 INSIDE OF LAYER O30M12
    F302M12s = (SIZE F302M12 BY (SM12_301 + grid)) OR B30M12s
    R302M12pre = O30M12 NOT F302M12s
    R302M12 = WITH WIDTH R302M12pre >= WM12_301

    // 4th, small
    F3012M12 = RECTANGLES WM12_301 LM12_301 SM12_301 OFFSET OM12_301 INSIDE OF LAYER R302M12
    F3012M12s = (SIZE F3012M12 BY (SM12_301 + grid)) OR F302M12s
    R3012M12pre = R302M12pre NOT F3012M12s
    R3012M12 = WITH WIDTH R3012M12pre >= WM12_301

    // 5th, non-stagger small
    F301M12 = RECTANGLES WM12_301 LM12_301 SM12_301 INSIDE OF LAYER R3012M12 //MAINTAIN SPACING
    F301M12s = (SIZE F301M12 BY (SM12_301 + grid)) OR F3012M12s

    F30M12 = ((F302M12 OR F3012M12) OR F301M12) OR F303M12_SLOT
    O40M12pre = (((PUSH D40M12) NOT FRAME12) NOT F301M12s) AND CHIP


    O40M12preA = SIZE O40M12pre BY -DM12_403
    O40M12preB = O40M12preA WITH WIDTH >= WM12_403

    // 1st big
    F403M12 = RECTANGLES WM12_403 LM12_403 SM12_403 OFFSET OM12_403 INSIDE OF LAYER O40M12preB
    F403M12_SLOT = RECTANGLES WM12_403_SLOT LM12_403_SLOT SM12_403_SLOT INSIDE OF LAYER F403M12

    F403M12_EXP = SIZE F403M12_SLOT BY ( SM12_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M12preF1 = O40M12pre NOT (SIZE F403M12_EXP BY SM12_402)
    O40M12preF  = (SNAP (SIZE O40M12preF1 BY -grid) 5) AND O40M12preF1

    B40M12s = F301M12s OR (SIZE F403M12_EXP BY (SM12_402+grid))
    O40M12 = O40M12preF NOT B40M12s

    // 3rd, middle
    F402M12 = RECTANGLES WM12_402 LM12_402 SM12_402 OFFSET OM12_402 INSIDE OF LAYER O40M12
    F402M12s = (SIZE F402M12 BY (SM12_401 + grid)) OR B40M12s
    R402M12pre = O40M12 NOT F402M12s
    R402M12 = WITH WIDTH R402M12pre >= WM12_401

    // 4th, small
    F4012M12 = RECTANGLES WM12_401 LM12_401 SM12_401 OFFSET OM12_401 INSIDE OF LAYER R402M12
    F4012M12s = (SIZE F4012M12 BY (SM12_401 + grid)) OR F402M12s
    R4012M12pre = R402M12pre NOT F4012M12s
    R4012M12 = WITH WIDTH R4012M12pre >= WM12_401

    // 5th, non-stagger small
    F401M12 = RECTANGLES WM12_401 LM12_401 SM12_401 INSIDE OF LAYER R4012M12 //MAINTAIN SPACING
    F401M12s = (SIZE F401M12 BY (SM12_401 + grid)) OR F4012M12s

    F40M12 = ((F402M12 OR F4012M12) OR F401M12) OR F403M12_SLOT
    O50M12pre = (((PUSH (D50M12 OR emptyM12)) NOT FRAME12) NOT F401M12s) AND CHIP


    O50M12preA = SIZE O50M12pre BY -DM12_503
    O50M12preB = O50M12preA WITH WIDTH >= WM12_503

    // 1st big
    F503M12 = RECTANGLES WM12_503 LM12_503 SM12_503 OFFSET OM12_503 INSIDE OF LAYER O50M12preB
    F503M12_SLOT = RECTANGLES WM12_503_SLOT LM12_503_SLOT SM12_503_SLOT INSIDE OF LAYER F503M12

    F503M12_EXP = SIZE F503M12_SLOT BY ( SM12_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M12preF1 = O50M12pre NOT (SIZE F503M12_EXP BY SM12_502)
    O50M12preF  = (SNAP (SIZE O50M12preF1 BY -grid) 5) AND O50M12preF1

    B50M12s = F401M12s OR (SIZE F503M12_EXP BY (SM12_502+grid))
    O50M12 = O50M12preF NOT B50M12s

    // 3rd, middle
    F502M12 = RECTANGLES WM12_502 LM12_502 SM12_502 OFFSET OM12_502 INSIDE OF LAYER O50M12
    F502M12s = (SIZE F502M12 BY (SM12_501 + grid)) OR B50M12s
    R502M12pre = O50M12 NOT F502M12s
    R502M12 = WITH WIDTH R502M12pre >= WM12_501

    // 4th, small
    F5012M12 = RECTANGLES WM12_501 LM12_501 SM12_501 OFFSET OM12_501 INSIDE OF LAYER R502M12
    F5012M12s = (SIZE F5012M12 BY (SM12_501 + grid)) OR F502M12s
    R5012M12pre = R502M12pre NOT F5012M12s
    R5012M12 = WITH WIDTH R5012M12pre >= WM12_501

    // 5th, non-stagger small
    F501M12 = RECTANGLES WM12_501 LM12_501 SM12_501 INSIDE OF LAYER R5012M12 //MAINTAIN SPACING
    F501M12s = (SIZE F501M12 BY (SM12_501 + grid)) OR F5012M12s

    F50M12 = ((F502M12 OR F5012M12) OR F501M12) OR F503M12_SLOT

    exceedM12 = DENSITY M12x F30M12 F40M12 F50M12 > maxD_M12 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M12.den_exceed

    removeM12R = ((PUSH (exceedM12 AND (D50M12 OR emptyM12))) NOT FRAME12) AND CHIP
    removeM12P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM12R

    F30M12x = F30M12 NOT INTERACT removeM12P
    F40M12x = F40M12 NOT INTERACT removeM12P
    F50M12x = F50M12 NOT INTERACT removeM12P
    FM12xA  = (F30M12x OR F40M12x) OR F50M12x
    FM12x   = FM12xA NOT INTERACT (EXT FM12xA < DM12_S_1 ABUT SINGULAR REGION)

    ALLM12x = M12x OR FM12x
    lackM12 = DENSITY ALLM12x CHIP < DM12_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M12.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM12x)/AREA(CHIP) ]

    WDM12EXC = DUM12 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM12EXC = (SIZE FM12x BY Odm2DM12) OR (SIZE (((F303M12_EXP OR F403M12_EXP) OR F503M12_EXP) OR WDM12EXC) BY 1.5)

    lackM12pRM = ((((PUSH lackM12) NOT RM12EXC) NOT FRAME12OPC) NOT exceedM12) AND CHIP
    lackM12pRM_1 = WITH WIDTH lackM12pRM >= SM12_OPC

    RM12p1 = RECTANGLES WM12_OPC LM12_OPC WSM12_OPC LSM12_OPC INSIDE OF LAYER lackM12pRM_1
    lackM12pRM_2 = lackM12pRM_1 NOT (SIZE RM12p1 BY SM12_OPC)
    RM12p2 = RECTANGLES LM12_OPC WM12_OPC LSM12_OPC WSM12_OPC INSIDE OF LAYER lackM12pRM_2

    ODM12A = ((RM12p1 OR RM12p2) OUTSIDE RM12EXC) OUTSIDE FRAME12OPC
    ODM12F_pre = ODM12A NOT INTERACT (EXT ODM12A < SM12_OPC ABUT SINGULAR REGION)

// M12.S.14 ~ M12.S.16
M12_S_14_CHK_REGION = M12i OR ODM12F_pre
// Find Wide Metal
Wide_M12_S_14_CHK_REGION = ENCLOSE RECTANGLE (M12_S_14_CHK_REGION NOT WITH WIDTH <= M12_S_14_W1B) M12_S_14_W1B+GRID M12_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M12_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M12_S_14_CHK_REGION == 0
Wide_M12_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M12_S_14_CHK_REGION == 90

// Find Wide Metal Space
M12_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M12_S_14_CHK_REGION_EDGE_H M12_S_14_CHK_REGION < M12_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M12_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M12_S_14_CHK_REGION_EDGE_V M12_S_14_CHK_REGION < M12_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M12_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M12_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M12_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M12_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M12_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M12_S_14_CHK_REGION_OPC_REGION_pre1_H M12_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M12_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M12_S_14_L1B
M12_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M12_S_14_CHK_REGION_OPC_REGION_pre1_V M12_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M12_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M12_S_14_L1B

M12_S_14_OPC_REGION = M12_S_14_CHK_REGION_OPC_REGION_pre2_H OR M12_S_14_CHK_REGION_OPC_REGION_pre2_V

// M12.S.17 ~ M12.S.19
M12_S_17_CHK_REGION = M12i OR ODM12F_pre
// Find Wide Metal
Wide_M12_S_17_CHK_REGION = ENCLOSE RECTANGLE (M12_S_17_CHK_REGION NOT WITH WIDTH <= M12_S_17_W1B) M12_S_17_W1B+GRID M12_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M12_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M12_S_17_CHK_REGION == 0
Wide_M12_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M12_S_17_CHK_REGION == 90

// Find Wide Metal Space
M12_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M12_S_17_CHK_REGION_EDGE_H M12_S_17_CHK_REGION < M12_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M12_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M12_S_17_CHK_REGION_EDGE_V M12_S_17_CHK_REGION < M12_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M12_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M12_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M12_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M12_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M12_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M12_S_17_CHK_REGION_OPC_REGION_pre1_H M12_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M12_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M12_S_17_L1B
M12_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M12_S_17_CHK_REGION_OPC_REGION_pre1_V M12_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M12_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M12_S_17_L1B

M12_S_17_OPC_REGION = M12_S_17_CHK_REGION_OPC_REGION_pre2_H OR M12_S_17_CHK_REGION_OPC_REGION_pre2_V

// M12.S.20 ~ M12.S.22
M12_S_20_CHK_REGION = M12i OR ODM12F_pre
// Find Wide Metal
Wide_M12_S_20_CHK_REGION = ENCLOSE RECTANGLE (M12_S_20_CHK_REGION NOT WITH WIDTH <= M12_S_20_W1B) M12_S_20_W1B+GRID M12_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M12_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M12_S_20_CHK_REGION == 0
Wide_M12_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M12_S_20_CHK_REGION == 90

// Find Wide Metal Space
M12_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M12_S_20_CHK_REGION_EDGE_H M12_S_20_CHK_REGION < M12_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M12_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M12_S_20_CHK_REGION_EDGE_V M12_S_20_CHK_REGION < M12_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M12_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M12_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M12_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M12_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M12_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M12_S_20_CHK_REGION_OPC_REGION_pre1_H M12_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M12_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M12_S_20_L1B
M12_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M12_S_20_CHK_REGION_OPC_REGION_pre1_V M12_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M12_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M12_S_20_L1B

M12_S_20_OPC_REGION = M12_S_20_CHK_REGION_OPC_REGION_pre2_H OR M12_S_20_CHK_REGION_OPC_REGION_pre2_V

// M12.S.23 ~ M12.S.25
M12_S_23_CHK_REGION = M12i OR ODM12F_pre
// Find Wide Metal
Wide_M12_S_23_CHK_REGION = ENCLOSE RECTANGLE (M12_S_23_CHK_REGION NOT WITH WIDTH <= M12_S_23_W1B) M12_S_23_W1B+GRID M12_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M12_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M12_S_23_CHK_REGION == 0
Wide_M12_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M12_S_23_CHK_REGION == 90

// Find Wide Metal Space
M12_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M12_S_23_CHK_REGION_EDGE_H M12_S_23_CHK_REGION < M12_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M12_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M12_S_23_CHK_REGION_EDGE_V M12_S_23_CHK_REGION < M12_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M12_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M12_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M12_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M12_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M12_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M12_S_23_CHK_REGION_OPC_REGION_pre1_H M12_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M12_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M12_S_23_L1B
M12_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M12_S_23_CHK_REGION_OPC_REGION_pre1_V M12_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M12_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M12_S_23_L1B

M12_S_23_OPC_REGION = M12_S_23_CHK_REGION_OPC_REGION_pre2_H OR M12_S_23_CHK_REGION_OPC_REGION_pre2_V

// M12.S.27
M12_S_27_CHK_REGION = M12i OR ODM12F_pre
// Find Wide Metal
Wide_M12_S_27_CHK_REGION = ENCLOSE RECTANGLE (M12_S_27_CHK_REGION NOT WITH WIDTH <= M12_S_27_W1B) M12_S_27_W1B+GRID M12_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M12_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M12_S_27_CHK_REGION == 0
Wide_M12_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M12_S_27_CHK_REGION == 90

// Find Wide Metal Space
M12_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M12_S_27_CHK_REGION_EDGE_H M12_S_27_CHK_REGION < M12_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M12_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M12_S_27_CHK_REGION_EDGE_V M12_S_27_CHK_REGION < M12_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M12_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M12_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M12_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M12_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M12_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M12_S_27_CHK_REGION_OPC_REGION_pre1_H M12_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M12_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M12_S_27_L1B
M12_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M12_S_27_CHK_REGION_OPC_REGION_pre1_V M12_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M12_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M12_S_27_L1B

M12_S_27_OPC_REGION = M12_S_27_CHK_REGION_OPC_REGION_pre2_H OR M12_S_27_CHK_REGION_OPC_REGION_pre2_V

M12_WMJ_OPC_REGION = (((M12_S_14_OPC_REGION OR M12_S_17_OPC_REGION) OR M12_S_20_OPC_REGION) OR M12_S_23_OPC_REGION) OR M12_S_27_OPC_REGION

    ODM12F = ODM12F_pre NOT INTERACT M12_WMJ_OPC_REGION

    DM12F = COPY FM12x

    FRAME12_INDDMYA = SIZE M12i BY (dm12_s2m12_INDDMY + grid)
    FRAME12_INDDMYB = SIZE DUM12 BY (dm12_s_INDDMY + grid)
    FRAME12_INDDMYC = SIZE DM12F BY dm12_s_INDDMY
    FRAME12_INDDMYD = SIZE ODM12F BY dm12_s2m12_INDDMY

    FRAME12_INDDMY  = ((((((FRAME12Pre OR xM12_DTCD) OR BLOCK12) OR FRAME12_INDDMYA) OR FRAME12_INDDMYB) OR FRAME12_INDDMYC) OR FRAME12_INDDMYD) OR NFILL_x
    FILL12_INDDMY   = ooINDDMY NOT FRAME12_INDDMY
    DM12F_INDDMY    = RECTANGLES dm12_w_INDDMY dm12_l_INDDMY dm12_s_INDDMY INSIDE OF LAYER FILL12_INDDMY

#IFDEF FILL_indDM12
    FILL12_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm12_s_INDDMY_HD + grid)) NOT FRAME12_INDDMY
    DM12F_INDDMY_HD_pre  = RECTANGLES dm12_w_INDDMY_HD dm12_l_INDDMY_HD dm12_s_INDDMY_HD INSIDE OF LAYER FILL12_INDDMY_HD

    FILL12_INDDMY_MD = (SIZE INDDMY_MD BY -(dm12_s_INDDMY_MD + grid)) NOT (FRAME12_INDDMY OR INDDMY_HD)
    DM12F_INDDMY_MD  = RECTANGLES dm12_w_INDDMY_MD dm12_l_INDDMY_MD dm12_s_INDDMY_MD INSIDE OF LAYER FILL12_INDDMY_MD

    DM12F_INDDMY_HD = DM12F_INDDMY_HD_pre OR DM12F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#IFDEF FILL_DM13


#IFDEF 34K_THICK_Mu_M13

    minOPENM13 = DENSITY M13x < minD_M13 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M13Min.den
    emptyOPENM13 = DENSITY M13x < emptyD_M13 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M13Empty.den

    M13InnerHole = HOLES M13i INNER

    M13BigHole = SIZE M13InnerHole BY - excludeHoleSize/2
    M13ExcHole = ((M13InnerHole OUTSIDE M13BigHole) NOT M13i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK13    = (SIZE DM13EXCL BY (dm2DMEXCL + grid)) OR MIM13_x
    FRAMEA13   = SIZE M13i BY (dm2M13 + grid) // DM13 to metal
    FRAMEB13   = SIZE (WITH WIDTH M13i > wideM13) BY (dm2WM13 + grid)
    FRAMEC13   = SIZE DUM13 BY (dm2DM13 + grid)
    FRAME13Pre = ((FRAMEA13 OR FRAMEB13) OR FRAMEC13) OR M13ExcHole
    FRAME13INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm13_s2m13_INDDMY + grid)
    FRAME13 = ((FRAME13Pre OR FRAME13INDDMY) OR BLOCK13) OR NFILL
    
    OPENM13 = PUSH ((minOPENM13 OR emptyOPENM13) AND CHIP)
    FILL13 = OPENM13 NOT FRAME13
    FILLW13pre = SIZE FILL13 BY - (Wdm2M13 + grid)
    FILLW13 = WITH WIDTH FILLW13pre >= WdmW_M13
    M13FW = RECTANGLES WdmW_M13 WdmL_M13 WdmS_M13 OFFSET WdmO_M13 INSIDE OF LAYER FILLW13
    M13FW_EXP = SIZE M13FW BY (WdmS_M13 /2 + grid) OVERUNDER   // merge the gaps
    FILLM13pre = FILL13 NOT (SIZE M13FW_EXP BY (MdmS_M13 + grid))
    FILLM13 = WITH WIDTH FILLM13pre >= MdmW_M13
    M13F1 = RECTANGLES MdmW_M13 MdmL_M13 MdmS_M13 OFFSET MdmO_M13 INSIDE OF LAYER FILLM13
    M13R1pre = FILLM13pre NOT (SIZE M13F1 BY (dmS_M13 + grid))
    M13R1 = WITH WIDTH M13R1pre >= dmW_M13

    M13F2 = RECTANGLES dmW_M13 dmL_M13 dmS_M13 OFFSET dmO_M13 INSIDE OF LAYER M13R1
    M13R2pre = M13R1 NOT (SIZE M13F2 BY (dmS_M13 + grid))
    M13R2 = WITH WIDTH M13R2pre >= dmW_M13

    M13F3 = RECTANGLES dmW_M13 dmL_M13 dmS_M13 OFFSET dmO_M13 INSIDE OF LAYER M13R2
    M13R3pre = M13R2 NOT (SIZE M13F3 BY (dmS_M13 + grid))
    M13R3 = WITH WIDTH M13R3pre >= dmW_M13

    M13F4 = RECTANGLES dmW_M13 dmL_M13 dmS_M13 INSIDE OF LAYER M13R3

    M13F = (((M13F1 OR M13F2) OR M13F3) OR M13F4) OR M13FW
    FM13 = M13F NOT INTERACT (EXT M13F < dmS_M13 ABUT SINGULAR REGION)

