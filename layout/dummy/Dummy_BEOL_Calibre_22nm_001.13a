DM8_F_4_REGION_DVIA8_spec_S_pre = RECTANGLE DM8F_FOR_DVIA8F_REGION == WM8_301 BY == LM8_301
DM8_F_4_REGION_DVIA8_spec_S     = DM8_F_4_REGION_DVIA8_spec_S_pre NOT (EXPAND EDGE (LENGTH DM8_F_4_REGION_DVIA8_spec_S_pre == WM8_301) INSIDE BY DM8_F_4_REGION_DVIA8_SHORTENED_LENGTH)
#ELSE
DM8_F_4_REGION_DVIA8_spec_B_pre = RECTANGLE DM8F_FOR_DVIA8F_REGION == LM8_303_SLOT BY == WM8_303_SLOT
DM8_F_4_REGION_DVIA8_spec_B     = DM8_F_4_REGION_DVIA8_spec_B_pre NOT (EXPAND EDGE (LENGTH DM8_F_4_REGION_DVIA8_spec_B_pre == LM8_303_SLOT) INSIDE BY DM8_F_4_REGION_DVIA8_SHORTENED_LENGTH)

DM8_F_4_REGION_DVIA8_spec_M_pre = RECTANGLE DM8F_FOR_DVIA8F_REGION == LM8_302 BY == WM8_302
