    DM11F_FOR_DVIA11F_REGION_remainder_EDGE = LENGTH DM11F_FOR_DVIA11F_REGION_remainder > 0
    DM11F_FOR_DVIA11F_REGION_remainder_PROP = DFM PROPERTY DM11F_FOR_DVIA11F_REGION_remainder DM11F_FOR_DVIA11F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM11F_FOR_DVIA11F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM11F_FOR_DVIA11F_REGION_remainder_EDGE)) ]
    DM11F_FOR_DVIA11F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM11F_FOR_DVIA11F_REGION_remainder_EDGE DM11F_FOR_DVIA11F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM11F_FOR_DVIA11F_REGION_remainder_EDGE) - PROPERTY(DM11F_FOR_DVIA11F_REGION_remainder_PROP, DM11F_FOR_DVIA11F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM11F_FOR_DVIA11F_REGION2 = DM11F_FOR_DVIA11F_REGION_remainder NOT (EXPAND EDGE DM11F_FOR_DVIA11F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM11_F_4_REGION_DVIA11_SHORTENED_LENGTH)


VARIABLE DM12_F_4_REGION_DVIA11_SHORTENED_LENGTH DM12_EN_3 - DM12_EN_2

#IFDEF VERTICAL_DM12
