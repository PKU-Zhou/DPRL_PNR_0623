//***** Chip boundary pre-definition ******

// *********************************************
// begin pre-generation process : find open area
// *********************************************
#IFDEF UseprBoundary
  bulk_pre = COPY prBoundary
#ELSE
#IFDEF ChipWindowUsed
  POLYGON xLB yLB xRT yRT ChipWindow
  bulk_pre = PUSH ChipWindow
#ELSE
  bulk_ext = EXTENT MT_LAYERS
  bulk_pre = PUSH bulk_ext
#ENDIF
#ENDIF

#IFDEF WithSealring
  bulk = SIZE bulk_pre BY -(SRwidth + grid)
#ELSE
  bulk = COPY bulk_pre
#ENDIF

#IFDEF dmOnCorner
  CHIP = COPY bulk
#ELSE
// for seal-ring and chip corner excluding regions.
  EMPTY_AREA = INT bulk < CSR_R_1 ABUT==90 REGION INTERSECTING ONLY
  CHIP = bulk NOT EMPTY_AREA
#ENDIF

VARIABLE grid    0.005
VARIABLE CSR_R_1 74
VARIABLE SRwidth 24.0      // width of sealring including CDU and isolation regions
GATEi = ODi AND POi
SD    = ODi NOT POi
FPO   = POi NOT ODi
GATE  = (GATEi TOUCH SD == 2) TOUCH FPO == 2
#ENDIF


//******* Density Definitions (Same for all layers M1 - M13) ************
VARIABLE WindowSize     50   // density check window for M1/Mx/My/Mz/Mr
VARIABLE WindowStep     25   // movement of density check window
VARIABLE WindowSizeu    50   // density check window for Mu
VARIABLE WindowStepu    25   // movement of density check window
VARIABLE emptyWindowSize 2   // empty window size
VARIABLE emptyWindowStep 1   // movement of empty window
VARIABLE excludeHoleSize 4   // exclude insertion when hole width less than this value

//******* Fill region and spacing definitions **************************
VARIABLE dm2DMEXCL     0.6   // DMx.S.2: dummy to blockage layer spacing
VARIABLE dm2DVIAEXCL   0.6   // dummy to blockage layer spacing
VARIABLE dm2Chip       1.8   // dummy to Chip Edge spacing
VARIABLE dm2Chip_x     0.6   // dummy Mx to Chip Edge spacing
VARIABLE dm2LOWMEDN    0     // dummy to LOWMEDN spacing, LOWMEDN.W.1/2/3/4, LOWMEDN.S.1/2/3/4
VARIABLE OPCdm2LOGO   10.0   // LOGO.S.1: OPC dummy to LOGO spacing
VARIABLE dm2bentMetal  0.4   // M1.S.9, Mx.S.9, My.S.6: dummy metal to 45 degree METAL
VARIABLE dm2bentMn_E  0.140  // M1.S.32.1, M1.S.37.1, Mx.S.32.1, Mx.S.38.1: Negative PRL for 45 degree METAL
VARIABLE IND_S_1_1    16     // INDDMY 16um buffer region
VARIABLE MIM_VIA_S    0.08   // MIM.VIA.S.10
VARIABLE dm2ICOVLx    0.2      // ICOVL.S.6

//***** Blockage layers pre-defined ******
CHIP_DM       = CHIP NOT (SIZE CHIP BY - (dm2Chip + grid))
CHIP_DMx      = CHIP NOT (SIZE CHIP BY - (dm2Chip_x + grid))

LOWMEDN_RINGx = (SIZE LOWMEDN BY (dm2LOWMEDN + grid)) NOT (SIZE LOWMEDN BY -(dm2LOWMEDN + grid))

LOGOx    = SIZE LOGO BY (OPCdm2LOGO+grid)  // DMx_O to LOGO >= 10um, LOGO.S.1
LOWMEDNx = SIZE LOWMEDN BY (dm2LOWMEDN + grid)

FUSELINKx = SIZE (FUSELINK AND POi) BY grid
ICOVLx    = SIZE ICOVL BY (dm2ICOVLx + grid)

NFILL      = (CHIP_DM OR LOGO) OR LOWMEDN_RINGx
NFILLOPC   = (CHIP_DM OR LOGOx) OR LOWMEDNx
NFILL_x    = ((CHIP_DMx OR LOGO) OR LOWMEDN_RINGx) OR ICOVLx
NFILLOPC_x = ((CHIP_DMx OR LOGOx) OR LOWMEDNx) OR ICOVLx

ooINDDMY = ((SIZE INDDMY_all BY IND_S_1_1) NOT INDDMY_all) AND CHIP
INDDMYx_BEOL = SIZE INDDMY_all BY IND_S_1_1
