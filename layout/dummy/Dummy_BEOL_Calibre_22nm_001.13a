#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M13

    D30M13 = DENSITY M13x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M13.den30
    D40M13 = DENSITY M13x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M13.den40
    D50M13 = DENSITY M13x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M13.den50
    emptyM13 = DENSITY M13x < emptyD_M13 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M13.den_empty

    M13InnerHole = HOLES M13i INNER

    M13BigHole = SIZE M13InnerHole BY - excludeHoleSize/2
    M13ExcHole = ((M13InnerHole OUTSIDE M13BigHole) NOT M13i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK13 = (SIZE DM13EXCL BY (dm2DMEXCL + grid)) OR MIM13_x

    FRAMEA13 = (SIZE M13i BY (DM13_301 + grid)) OR (SIZE (EXPAND EDGE (M13i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA13OPC = SIZE M13i BY (DM13_OPC + grid)
    FRAMEA13OPCDV33 = SIZE (M13i INTERACT M13_HVN_330Vx) BY (M13_S_1_1_a + grid)
    FRAMEA13OPCDV5 = SIZE (M13i INTERACT M13_HVN_500Vx) BY (M13_S_9_a + grid)
    FRAMEA13OPC45 = SIZE (EXPAND EDGE (M13i ANGLE == 45) OUTSIDE BY DM13_OPC_45 EXTEND BY DM13_OPC_45_E) BY grid
    FRAMEA13OPC45DV = SIZE (EXPAND EDGE ((M13i INTERACT M13_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM13_OPC_45 EXTEND BY DM13_OPC_45_E) BY grid

    FRAMEB13 = SIZE (WITH WIDTH M13i > wideM13) BY (dm2WM13 + grid)
    FRAMEC13 = SIZE DUM13 BY (dm2DM13 + grid)
    FRAMED13 = SIZE (WITH WIDTH M13i > wideM13_small) BY (dm2WM13_small + grid)
    FRAMEC13OPC = SIZE DUM13 BY (Odm2DM13 + grid)
    FRAME13Pre = ((FRAMEA13 OR FRAMEB13) OR (FRAMEC13 OR FRAMED13)) OR M13ExcHole
    FRAME13PreOPC = (((((((FRAMEA13OPC OR FRAMEA13OPCDV33) OR FRAMEA13OPCDV5) OR FRAMEC13OPC) OR M13ExcHole) OR FRAMEA13OPC45) OR FRAMEA13OPC45DV) OR FRAMEB13) OR FRAMED13
    FRAME13INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm13_s2m13_INDDMY + grid)

    FRAME13OPC = ((FRAME13PreOPC OR FRAME13INDDMY) OR BLOCK13) OR NFILLOPC

    FRAME13 = ((FRAME13Pre OR FRAME13INDDMY) OR BLOCK13) OR NFILL

    //****************************************************************************

    D30M13p = (PUSH D30M13) NOT FRAME13
    O30M13pre = D30M13p AND CHIP
    FD21M13s = COPY FRAME13

    O30M13preA = SIZE O30M13pre BY -DM13_303
    O30M13preB = O30M13preA WITH WIDTH >= WM13_303

    // 1st big
    F303M13 = RECTANGLES WM13_303 LM13_303 SM13_303 OFFSET OM13_303 INSIDE OF LAYER O30M13preB

    F303M13_EXP = SIZE F303M13 BY ( SM13_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M13preF1 = O30M13pre NOT (SIZE F303M13_EXP BY SM13_302)
    O30M13preF  = (SNAP (SIZE O30M13preF1 BY -grid) 5) AND O30M13preF1

    B30M13s = FD21M13s OR (SIZE F303M13_EXP BY (SM13_302+grid))
    O30M13 = O30M13preF NOT B30M13s

    // 3rd, middle
    F302M13 = RECTANGLES WM13_302 LM13_302 SM13_302 OFFSET OM13_302 INSIDE OF LAYER O30M13
    F302M13s = (SIZE F302M13 BY (SM13_301 + grid)) OR B30M13s
    R302M13pre = O30M13 NOT F302M13s
    R302M13 = WITH WIDTH R302M13pre >= WM13_301

    // 4th, small
    F3012M13 = RECTANGLES WM13_301 LM13_301 SM13_301 OFFSET OM13_301 INSIDE OF LAYER R302M13
    F3012M13s = (SIZE F3012M13 BY (SM13_301 + grid)) OR F302M13s
    R3012M13pre = R302M13pre NOT F3012M13s
    R3012M13 = WITH WIDTH R3012M13pre >= WM13_301

    // 5th, non-stagger small
    F301M13 = RECTANGLES WM13_301 LM13_301 SM13_301 INSIDE OF LAYER R3012M13 //MAINTAIN SPACING
    F301M13s = (SIZE F301M13 BY (SM13_301 + grid)) OR F3012M13s

    F30M13 = ((F302M13 OR F3012M13) OR F301M13) OR F303M13
    O40M13pre = (((PUSH D40M13) NOT FRAME13) NOT F301M13s) AND CHIP


    O40M13preA = SIZE O40M13pre BY -DM13_403
    O40M13preB = O40M13preA WITH WIDTH >= WM13_403

    // 1st big
    F403M13 = RECTANGLES WM13_403 LM13_403 SM13_403 OFFSET OM13_403 INSIDE OF LAYER O40M13preB

    F403M13_EXP = SIZE F403M13 BY ( SM13_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M13preF1 = O40M13pre NOT (SIZE F403M13_EXP BY SM13_402)
    O40M13preF  = (SNAP (SIZE O40M13preF1 BY -grid) 5) AND O40M13preF1

    B40M13s = F301M13s OR (SIZE F403M13_EXP BY (SM13_402+grid))
    O40M13 = O40M13preF NOT B40M13s

    // 3rd, middle
    F402M13 = RECTANGLES WM13_402 LM13_402 SM13_402 OFFSET OM13_402 INSIDE OF LAYER O40M13
    F402M13s = (SIZE F402M13 BY (SM13_401 + grid)) OR B40M13s
    R402M13pre = O40M13 NOT F402M13s
    R402M13 = WITH WIDTH R402M13pre >= WM13_401

    // 4th, small
    F4012M13 = RECTANGLES WM13_401 LM13_401 SM13_401 OFFSET OM13_401 INSIDE OF LAYER R402M13
    F4012M13s = (SIZE F4012M13 BY (SM13_401 + grid)) OR F402M13s
    R4012M13pre = R402M13pre NOT F4012M13s
    R4012M13 = WITH WIDTH R4012M13pre >= WM13_401

    // 5th, non-stagger small
    F401M13 = RECTANGLES WM13_401 LM13_401 SM13_401 INSIDE OF LAYER R4012M13 //MAINTAIN SPACING
    F401M13s = (SIZE F401M13 BY (SM13_401 + grid)) OR F4012M13s

    F40M13 = ((F402M13 OR F4012M13) OR F401M13) OR F403M13
    O50M13pre = (((PUSH (D50M13 OR emptyM13)) NOT FRAME13) NOT F401M13s) AND CHIP


    O50M13preA = SIZE O50M13pre BY -DM13_503
    O50M13preB = O50M13preA WITH WIDTH >= WM13_503

    // 1st big
    F503M13 = RECTANGLES WM13_503 LM13_503 SM13_503 OFFSET OM13_503 INSIDE OF LAYER O50M13preB

    F503M13_EXP = SIZE F503M13 BY ( SM13_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M13preF1 = O50M13pre NOT (SIZE F503M13_EXP BY SM13_502)
    O50M13preF  = (SNAP (SIZE O50M13preF1 BY -grid) 5) AND O50M13preF1

    B50M13s = F401M13s OR (SIZE F503M13_EXP BY (SM13_502+grid))
    O50M13 = O50M13preF NOT B50M13s

    // 3rd, middle
    F502M13 = RECTANGLES WM13_502 LM13_502 SM13_502 OFFSET OM13_502 INSIDE OF LAYER O50M13
    F502M13s = (SIZE F502M13 BY (SM13_501 + grid)) OR B50M13s
    R502M13pre = O50M13 NOT F502M13s
    R502M13 = WITH WIDTH R502M13pre >= WM13_501

    // 4th, small
    F5012M13 = RECTANGLES WM13_501 LM13_501 SM13_501 OFFSET OM13_501 INSIDE OF LAYER R502M13
    F5012M13s = (SIZE F5012M13 BY (SM13_501 + grid)) OR F502M13s
    R5012M13pre = R502M13pre NOT F5012M13s
    R5012M13 = WITH WIDTH R5012M13pre >= WM13_501

    // 5th, non-stagger small
    F501M13 = RECTANGLES WM13_501 LM13_501 SM13_501 INSIDE OF LAYER R5012M13 //MAINTAIN SPACING
    F501M13s = (SIZE F501M13 BY (SM13_501 + grid)) OR F5012M13s

    F50M13 = ((F502M13 OR F5012M13) OR F501M13) OR F503M13

//****************************************************************************

    exceedM13 = DENSITY M13x F30M13 F40M13 F50M13 > maxD_M13 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M13.den_exceed

    removeM13R = ((PUSH (exceedM13 AND (D50M13 OR emptyM13))) NOT FRAME13) AND CHIP
    removeM13P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM13R

    F30M13x = F30M13 NOT INTERACT removeM13P
    F40M13x = F40M13 NOT INTERACT removeM13P
    F50M13x = F50M13 NOT INTERACT removeM13P
    FM13xA  = (F30M13x OR F40M13x) OR F50M13x
    FM13x   = FM13xA NOT INTERACT (EXT FM13xA < DM13_S_1 ABUT SINGULAR REGION)

    ALLM13x = M13x OR FM13x
    lackM13 = DENSITY ALLM13x CHIP < DM13_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M13.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM13x)/AREA(CHIP) ]

    WDM13EXC = DUM13 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM13EXC = (SIZE FM13x BY Odm2DM13) OR (SIZE (((F303M13_EXP OR F403M13_EXP) OR F503M13_EXP) OR WDM13EXC) BY 1.5)

    lackM13pRM = ((((PUSH lackM13) NOT RM13EXC) NOT FRAME13OPC) NOT exceedM13) AND CHIP
    lackM13pRM_1 = WITH WIDTH lackM13pRM >= SM13_OPC

    RM13p1 = RECTANGLES WM13_OPC LM13_OPC WSM13_OPC LSM13_OPC INSIDE OF LAYER lackM13pRM_1
    lackM13pRM_2 = lackM13pRM_1 NOT (SIZE RM13p1 BY SM13_OPC)
    RM13p2 = RECTANGLES LM13_OPC WM13_OPC LSM13_OPC WSM13_OPC INSIDE OF LAYER lackM13pRM_2

    ODM13A = ((RM13p1 OR RM13p2) OUTSIDE RM13EXC) OUTSIDE FRAME13OPC
    ODM13F = ODM13A NOT INTERACT (EXT ODM13A < SM13_OPC ABUT SINGULAR REGION)

    DM13F = COPY FM13x

    FRAME13_INDDMYA = SIZE M13i BY (dm13_s2m13_INDDMY + grid)
    FRAME13_INDDMYB = SIZE DUM13 BY (dm13_s_INDDMY + grid)
    FRAME13_INDDMYC = SIZE DM13F BY dm13_s_INDDMY
    FRAME13_INDDMYD = SIZE ODM13F BY dm13_s2m13_INDDMY
    FRAME13_INDDMY  = (((((FRAME13Pre OR BLOCK13) OR FRAME13_INDDMYA) OR FRAME13_INDDMYB) OR FRAME13_INDDMYC) OR FRAME13_INDDMYD) OR NFILL
    FILL13_INDDMY   = ooINDDMY NOT FRAME13_INDDMY
    DM13F_INDDMY    = RECTANGLES dm13_w_INDDMY dm13_l_INDDMY dm13_s_INDDMY INSIDE OF LAYER FILL13_INDDMY


#IFDEF FILL_indDM13
    FILL13_INDDMY_HD = (SIZE INDDMY_HD BY -(dm13_s_INDDMY_HD + grid)) NOT FRAME13_INDDMY
    DM13F_INDDMY_HD  = RECTANGLES dm13_w_INDDMY_HD dm13_l_INDDMY_HD dm13_s_INDDMY_HD INSIDE OF LAYER FILL13_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M13

    minOPENM13 = DENSITY M13x < minD_M13 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M13Min.den
    emptyOPENM13 = DENSITY M13x < emptyD_M13 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M13Empty.den

    M13InnerHole = HOLES M13i INNER

    M13BigHole = SIZE M13InnerHole BY - excludeHoleSize/2
    M13ExcHole = ((M13InnerHole OUTSIDE M13BigHole) NOT M13i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK13 = (SIZE DM13EXCL BY (dm2DMEXCL + grid)) OR MIM13_x // DM13 to DM13EXCL
    FRAMEA13 = SIZE M13i BY (dm2M13 + grid) // DM13 to metal
    FRAMEB13 = SIZE (WITH WIDTH M13i > wideM13) BY (dm2WM13 + grid)
    FRAMEC13 = SIZE DUM13 BY (dm2DM13 + grid)   // DM13 to existed dummy metal 0.6um
    FRAME13Pre = ((FRAMEA13 OR FRAMEB13) OR FRAMEC13) OR M13ExcHole
    FRAME13INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm13_s2m13_INDDMY + grid)
    FRAME13 = ((FRAME13Pre OR FRAME13INDDMY) OR BLOCK13) OR NFILL
    
    OPENM13 = PUSH ((minOPENM13 OR emptyOPENM13) AND CHIP)
    FILL13 = OPENM13 NOT FRAME13
    FILLW13pre = SIZE FILL13 BY - (Wdm2M13 + grid)
    FILLW13 = WITH WIDTH FILLW13pre >= WdmW_M13
    M13FW = RECTANGLES WdmW_M13 WdmL_M13 WdmS_M13 OFFSET WdmO_M13 INSIDE OF LAYER FILLW13
    M13FW_EXP = SIZE M13FW BY (WdmS_M13 /2 + grid) OVERUNDER //merge the gaps
    FILLM13pre = FILL13 NOT (SIZE M13FW_EXP BY (MdmS_M13 + grid))
    FILLM13 = WITH WIDTH FILLM13pre >= MdmW_M13
    M13F1 = RECTANGLES MdmW_M13 MdmL_M13 MdmS_M13 OFFSET MdmO_M13 INSIDE OF LAYER FILLM13
    M13R1pre = FILLM13pre NOT (SIZE M13F1 BY (dmS_M13 + grid))
    M13R1 = WITH WIDTH M13R1pre >= dmW_M13

    M13F2 = RECTANGLES dmW_M13 dmL_M13 dmS_M13 OFFSET dmO_M13 INSIDE OF LAYER M13R1
    M13R2pre = M13R1 NOT (SIZE M13F2 BY (dmS_M13 + grid))
    M13R2 = WITH WIDTH M13R2pre >= dmW_M13

    M13F3 = RECTANGLES dmW_M13 dmL_M13 dmS_M13 OFFSET dmO_M13 INSIDE OF LAYER M13R2
    M13R3pre = M13R2 NOT (SIZE M13F3 BY (dmS_M13 + grid))
    M13R3 = WITH WIDTH M13R3pre >= dmW_M13

    M13F4 = RECTANGLES dmW_M13 dmL_M13 dmS_M13 INSIDE OF LAYER M13R3

    M13F = (((M13F1 OR M13F2) OR M13F3) OR M13F4) OR M13FW
    FM13 = M13F NOT INTERACT (EXT M13F < dmS_M13 ABUT SINGULAR REGION)

    maxOPENM13 = DENSITY M13x FM13 > maxD_M13 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M13Max.den

    FM13F = FM13 OUTSIDE maxOPENM13

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M13 = DENSITY M13x FM13F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M13Min.den

    RM13EXC = SIZE FM13F BY (Odm2DM13 + grid)
    // do not fill DMz_S over CTMDMY
    D25M13pM = (((PUSH D25M13) NOT FRAME13) NOT RM13EXC) AND CHIP
    D25M13pM_1 = WITH WIDTH D25M13pM >= OdmW_M13

    RM13p1 = RECTANGLES OdmW_M13 OdmL_M13 OdmS_M13 INSIDE OF LAYER D25M13pM_1
    D25M13pM_2 = D25M13pM_1 NOT (SIZE RM13p1 BY (OdmS_M13 + grid))
    RM13p2 = RECTANGLES OdmL_M13 OdmW_M13 OdmS_M13 INSIDE OF LAYER D25M13pM_2

    RM13A = ((RM13p1 OR RM13p2) OUTSIDE RM13EXC) OUTSIDE FRAME13
    RM13  = RM13A NOT INTERACT (EXT RM13A < OdmS_M13 ABUT SINGULAR REGION)

    DM13F = FM13F OR RM13

    FRAME13_INDDMYA = SIZE M13i BY (dm13_s2m13_INDDMY + grid)
    FRAME13_INDDMYB = SIZE DUM13 BY (dm13_s_INDDMY + grid)
    FRAME13_INDDMYC = SIZE DM13F BY dm13_s_INDDMY
    FRAME13_INDDMY  = ((((FRAME13Pre OR BLOCK13) OR FRAME13_INDDMYA) OR FRAME13_INDDMYB) OR FRAME13_INDDMYC) OR NFILL
    FILL13_INDDMY   = ooINDDMY NOT FRAME13_INDDMY
    DM13F_INDDMY    = RECTANGLES dm13_w_INDDMY dm13_l_INDDMY dm13_s_INDDMY INSIDE OF LAYER FILL13_INDDMY

#IFDEF FILL_indDM13
    FILL13_INDDMY_HD = (SIZE INDDMY_HD BY -(dm13_s_INDDMY_HD + grid)) NOT FRAME13_INDDMY
    DM13F_INDDMY_HD  = RECTANGLES dm13_w_INDDMY_HD dm13_l_INDDMY_HD dm13_s_INDDMY_HD INSIDE OF LAYER FILL13_INDDMY_HD
#ENDIF	

#ELSE



    D30M13 = DENSITY M13x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M13.den30
    D40M13 = DENSITY M13x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M13.den40
    D50M13 = DENSITY M13x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M13.den50
    emptyM13 = DENSITY M13x < emptyD_M13 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M13.den_empty

    M13InnerHole = HOLES M13i INNER
    xM13_DTCD = COPY EMPTY

    M13BigHole = SIZE M13InnerHole BY - excludeHoleSize/2
    M13ExcHole = ((M13InnerHole OUTSIDE M13BigHole) NOT M13i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK13 = (SIZE DM13EXCL BY (dm2DMEXCL + grid)) OR MIM13_x

    FRAMEA13 = (SIZE M13i BY (DM13_301 + grid)) OR (SIZE (EXPAND EDGE (M13i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA13OPC = SIZE M13i BY (DM13_OPC + grid)
    FRAMEA13OPCwide = SIZE (M13i WITH WIDTH > DM13_OPC_wide_w) BY (DM13_OPC_wide + grid)
    FRAMEA13OPC45 = SIZE (EXPAND EDGE (M13i ANGLE == 45) OUTSIDE BY DM13_OPC_45 EXTEND BY DM13_OPC_45_E) BY grid
    FRAMEA13OPC45DV = SIZE (EXPAND EDGE ((M13i INTERACT M13_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM13_OPC_45 EXTEND BY DM13_OPC_45_E) BY grid
    FRAMEA13OPC_M13_S_14_wide = SIZE (M13i WITH WIDTH > M13_S_14_wide_w) BY (M13_S_14_wide + grid)
    FRAMEA13OPC_M13_S_17_wide = SIZE (M13i WITH WIDTH > M13_S_17_wide_w) BY (M13_S_17_wide + grid)
    FRAMEA13OPC_M13_S_20_wide = SIZE (M13i WITH WIDTH > M13_S_20_wide_w) BY (M13_S_20_wide + grid)
    FRAMEA13OPC_M13_S_23_wide = SIZE (M13i WITH WIDTH > M13_S_23_wide_w) BY (M13_S_23_wide + grid)
    FRAMEA13OPC_M13_S_33_VIA12   = SIZE VIA12_HV_5V_CHK 	BY (M13_S_33 + grid)
    FRAMEA13OPC_M13_S_33b_VIA12DV   = SIZE (VIA12i INTERACT (M12_HVN_330Vx OR M13_HVN_330Vx)) 	BY (M13_S_33b + grid)
	FRAMEA13OPC_M13_S_37_VIA12_b = SIZE VIA12i_55V 		BY (M13_S_37 + grid)
	FRAMEA13OPC_M13_S_37a_VIA12_bDV = SIZE (VIA12i INTERACT (M12_HVN_500Vx OR M13_HVN_500Vx)) 	BY (M13_S_37a + grid)
    FRAMEA13OPC_M13_S_37_VIA12   = SIZE VIA12i_65V		BY (M13_S_37 + grid)

    FRAMEHVD13 = SIZE  M13i_65V  BY (M13_S_38 + grid)
    FRAMEHVD13_55V = SIZE  M13i_55V  BY (M13_S_38 + grid)
    FRAMEHVD13_55VDV = SIZE  (M13i INTERACT M13_HVN_500Vx)  BY (M13_S_38a + grid)
    FRAMEB13 = SIZE (WITH WIDTH M13i > wideM13) BY (dm2WM13 + grid)
    FRAMEC13 = SIZE DUM13 BY (dm2DM13 + grid)
    FRAMED13 = SIZE (WITH WIDTH M13i > wideM13_small) BY (dm2WM13_small + grid)
    FRAMEC13OPC = SIZE DUM13 BY (Odm2DM13 + grid)
    FRAME13Pre = ((FRAMEA13 OR FRAMEB13) OR (FRAMEC13 OR FRAMED13)) OR M13ExcHole
    FRAME13PreOPC = ((((((((((((((((FRAMEA13OPC OR FRAMEC13OPC) OR M13ExcHole) OR FRAMEA13OPCwide) OR FRAMEA13OPC45) OR FRAMEA13OPC45DV) OR FRAMEA13OPC_M13_S_14_wide) OR FRAMEA13OPC_M13_S_17_wide) OR FRAMEA13OPC_M13_S_20_wide) OR FRAMEA13OPC_M13_S_23_wide) OR FRAMEA13OPC_M13_S_33_VIA12) OR FRAMEA13OPC_M13_S_33b_VIA12DV) OR FRAMEHVD13) OR FRAMEA13OPC_M13_S_37_VIA12) OR FRAMEA13OPC_M13_S_37_VIA12_b) OR FRAMEA13OPC_M13_S_37a_VIA12_bDV) OR FRAMEHVD13_55V) OR FRAMEHVD13_55VDV

    FRAME13INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm13_s2m13_INDDMY + grid)
    FRAME13OPC = (((FRAME13PreOPC OR FRAME13INDDMY) OR xM13_DTCD) OR BLOCK13) OR NFILLOPC_x

    FRAME13 = (((FRAME13Pre OR FRAME13INDDMY) OR xM13_DTCD) OR BLOCK13) OR NFILL_x

    D30M13p = (PUSH D30M13) NOT FRAME13
    O30M13pre = D30M13p AND CHIP
    FD21M13s = COPY FRAME13

    O30M13preA = SIZE O30M13pre BY -DM13_303
    O30M13preB = O30M13preA WITH WIDTH >= WM13_303

    // 1st big
    F303M13 = RECTANGLES WM13_303 LM13_303 SM13_303 OFFSET OM13_303 INSIDE OF LAYER O30M13preB
    F303M13_SLOT = RECTANGLES WM13_303_SLOT LM13_303_SLOT SM13_303_SLOT INSIDE OF LAYER F303M13

    F303M13_EXP = SIZE F303M13_SLOT BY ( SM13_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M13preF1 = O30M13pre NOT (SIZE F303M13_EXP BY SM13_302)
    O30M13preF  = (SNAP (SIZE O30M13preF1 BY -grid) 5) AND O30M13preF1

    B30M13s = FD21M13s OR (SIZE F303M13_EXP BY (SM13_302+grid))
    O30M13 = O30M13preF NOT B30M13s

    // 3rd, middle
    F302M13 = RECTANGLES WM13_302 LM13_302 SM13_302 OFFSET OM13_302 INSIDE OF LAYER O30M13
    F302M13s = (SIZE F302M13 BY (SM13_301 + grid)) OR B30M13s
    R302M13pre = O30M13 NOT F302M13s
    R302M13 = WITH WIDTH R302M13pre >= WM13_301

    // 4th, small
    F3012M13 = RECTANGLES WM13_301 LM13_301 SM13_301 OFFSET OM13_301 INSIDE OF LAYER R302M13
    F3012M13s = (SIZE F3012M13 BY (SM13_301 + grid)) OR F302M13s
    R3012M13pre = R302M13pre NOT F3012M13s
    R3012M13 = WITH WIDTH R3012M13pre >= WM13_301

    // 5th, non-stagger small
    F301M13 = RECTANGLES WM13_301 LM13_301 SM13_301 INSIDE OF LAYER R3012M13 //MAINTAIN SPACING
    F301M13s = (SIZE F301M13 BY (SM13_301 + grid)) OR F3012M13s

    F30M13 = ((F302M13 OR F3012M13) OR F301M13) OR F303M13_SLOT
    O40M13pre = (((PUSH D40M13) NOT FRAME13) NOT F301M13s) AND CHIP


    O40M13preA = SIZE O40M13pre BY -DM13_403
    O40M13preB = O40M13preA WITH WIDTH >= WM13_403

    // 1st big
    F403M13 = RECTANGLES WM13_403 LM13_403 SM13_403 OFFSET OM13_403 INSIDE OF LAYER O40M13preB
    F403M13_SLOT = RECTANGLES WM13_403_SLOT LM13_403_SLOT SM13_403_SLOT INSIDE OF LAYER F403M13

    F403M13_EXP = SIZE F403M13_SLOT BY ( SM13_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M13preF1 = O40M13pre NOT (SIZE F403M13_EXP BY SM13_402)
    O40M13preF  = (SNAP (SIZE O40M13preF1 BY -grid) 5) AND O40M13preF1

    B40M13s = F301M13s OR (SIZE F403M13_EXP BY (SM13_402+grid))
    O40M13 = O40M13preF NOT B40M13s

    // 3rd, middle
    F402M13 = RECTANGLES WM13_402 LM13_402 SM13_402 OFFSET OM13_402 INSIDE OF LAYER O40M13
    F402M13s = (SIZE F402M13 BY (SM13_401 + grid)) OR B40M13s
    R402M13pre = O40M13 NOT F402M13s
    R402M13 = WITH WIDTH R402M13pre >= WM13_401

    // 4th, small
    F4012M13 = RECTANGLES WM13_401 LM13_401 SM13_401 OFFSET OM13_401 INSIDE OF LAYER R402M13
    F4012M13s = (SIZE F4012M13 BY (SM13_401 + grid)) OR F402M13s
    R4012M13pre = R402M13pre NOT F4012M13s
    R4012M13 = WITH WIDTH R4012M13pre >= WM13_401

    // 5th, non-stagger small
    F401M13 = RECTANGLES WM13_401 LM13_401 SM13_401 INSIDE OF LAYER R4012M13 //MAINTAIN SPACING
    F401M13s = (SIZE F401M13 BY (SM13_401 + grid)) OR F4012M13s

    F40M13 = ((F402M13 OR F4012M13) OR F401M13) OR F403M13_SLOT
    O50M13pre = (((PUSH (D50M13 OR emptyM13)) NOT FRAME13) NOT F401M13s) AND CHIP


    O50M13preA = SIZE O50M13pre BY -DM13_503
    O50M13preB = O50M13preA WITH WIDTH >= WM13_503

    // 1st big
    F503M13 = RECTANGLES WM13_503 LM13_503 SM13_503 OFFSET OM13_503 INSIDE OF LAYER O50M13preB
    F503M13_SLOT = RECTANGLES WM13_503_SLOT LM13_503_SLOT SM13_503_SLOT INSIDE OF LAYER F503M13

    F503M13_EXP = SIZE F503M13_SLOT BY ( SM13_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M13preF1 = O50M13pre NOT (SIZE F503M13_EXP BY SM13_502)
    O50M13preF  = (SNAP (SIZE O50M13preF1 BY -grid) 5) AND O50M13preF1

    B50M13s = F401M13s OR (SIZE F503M13_EXP BY (SM13_502+grid))
    O50M13 = O50M13preF NOT B50M13s

    // 3rd, middle
    F502M13 = RECTANGLES WM13_502 LM13_502 SM13_502 OFFSET OM13_502 INSIDE OF LAYER O50M13
    F502M13s = (SIZE F502M13 BY (SM13_501 + grid)) OR B50M13s
    R502M13pre = O50M13 NOT F502M13s
    R502M13 = WITH WIDTH R502M13pre >= WM13_501

    // 4th, small
    F5012M13 = RECTANGLES WM13_501 LM13_501 SM13_501 OFFSET OM13_501 INSIDE OF LAYER R502M13
    F5012M13s = (SIZE F5012M13 BY (SM13_501 + grid)) OR F502M13s
    R5012M13pre = R502M13pre NOT F5012M13s
    R5012M13 = WITH WIDTH R5012M13pre >= WM13_501

    // 5th, non-stagger small
    F501M13 = RECTANGLES WM13_501 LM13_501 SM13_501 INSIDE OF LAYER R5012M13 //MAINTAIN SPACING
    F501M13s = (SIZE F501M13 BY (SM13_501 + grid)) OR F5012M13s

    F50M13 = ((F502M13 OR F5012M13) OR F501M13) OR F503M13_SLOT

    exceedM13 = DENSITY M13x F30M13 F40M13 F50M13 > maxD_M13 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M13.den_exceed

    removeM13R = ((PUSH (exceedM13 AND (D50M13 OR emptyM13))) NOT FRAME13) AND CHIP
    removeM13P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM13R

    F30M13x = F30M13 NOT INTERACT removeM13P
    F40M13x = F40M13 NOT INTERACT removeM13P
    F50M13x = F50M13 NOT INTERACT removeM13P
    FM13xA  = (F30M13x OR F40M13x) OR F50M13x
    FM13x   = FM13xA NOT INTERACT (EXT FM13xA < DM13_S_1 ABUT SINGULAR REGION)

    ALLM13x = M13x OR FM13x
    lackM13 = DENSITY ALLM13x CHIP < DM13_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M13.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM13x)/AREA(CHIP) ]

    WDM13EXC = DUM13 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM13EXC = (SIZE FM13x BY Odm2DM13) OR (SIZE (((F303M13_EXP OR F403M13_EXP) OR F503M13_EXP) OR WDM13EXC) BY 1.5)

    lackM13pRM = ((((PUSH lackM13) NOT RM13EXC) NOT FRAME13OPC) NOT exceedM13) AND CHIP
    lackM13pRM_1 = WITH WIDTH lackM13pRM >= SM13_OPC

    RM13p1 = RECTANGLES WM13_OPC LM13_OPC WSM13_OPC LSM13_OPC INSIDE OF LAYER lackM13pRM_1
    lackM13pRM_2 = lackM13pRM_1 NOT (SIZE RM13p1 BY SM13_OPC)
    RM13p2 = RECTANGLES LM13_OPC WM13_OPC LSM13_OPC WSM13_OPC INSIDE OF LAYER lackM13pRM_2

    ODM13A = ((RM13p1 OR RM13p2) OUTSIDE RM13EXC) OUTSIDE FRAME13OPC
    ODM13F_pre = ODM13A NOT INTERACT (EXT ODM13A < SM13_OPC ABUT SINGULAR REGION)

// M13.S.14 ~ M13.S.16
M13_S_14_CHK_REGION = M13i OR ODM13F_pre
// Find Wide Metal
Wide_M13_S_14_CHK_REGION = ENCLOSE RECTANGLE (M13_S_14_CHK_REGION NOT WITH WIDTH <= M13_S_14_W1B) M13_S_14_W1B+GRID M13_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M13_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M13_S_14_CHK_REGION == 0
Wide_M13_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M13_S_14_CHK_REGION == 90

// Find Wide Metal Space
M13_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M13_S_14_CHK_REGION_EDGE_H M13_S_14_CHK_REGION < M13_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M13_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M13_S_14_CHK_REGION_EDGE_V M13_S_14_CHK_REGION < M13_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M13_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M13_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M13_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M13_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M13_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M13_S_14_CHK_REGION_OPC_REGION_pre1_H M13_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M13_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M13_S_14_L1B
M13_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M13_S_14_CHK_REGION_OPC_REGION_pre1_V M13_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M13_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M13_S_14_L1B

M13_S_14_OPC_REGION = M13_S_14_CHK_REGION_OPC_REGION_pre2_H OR M13_S_14_CHK_REGION_OPC_REGION_pre2_V

// M13.S.17 ~ M13.S.19
M13_S_17_CHK_REGION = M13i OR ODM13F_pre
// Find Wide Metal
Wide_M13_S_17_CHK_REGION = ENCLOSE RECTANGLE (M13_S_17_CHK_REGION NOT WITH WIDTH <= M13_S_17_W1B) M13_S_17_W1B+GRID M13_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M13_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M13_S_17_CHK_REGION == 0
Wide_M13_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M13_S_17_CHK_REGION == 90

// Find Wide Metal Space
M13_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M13_S_17_CHK_REGION_EDGE_H M13_S_17_CHK_REGION < M13_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M13_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M13_S_17_CHK_REGION_EDGE_V M13_S_17_CHK_REGION < M13_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M13_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M13_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M13_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M13_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M13_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M13_S_17_CHK_REGION_OPC_REGION_pre1_H M13_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M13_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M13_S_17_L1B
M13_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M13_S_17_CHK_REGION_OPC_REGION_pre1_V M13_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M13_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M13_S_17_L1B

M13_S_17_OPC_REGION = M13_S_17_CHK_REGION_OPC_REGION_pre2_H OR M13_S_17_CHK_REGION_OPC_REGION_pre2_V

// M13.S.20 ~ M13.S.22
M13_S_20_CHK_REGION = M13i OR ODM13F_pre
// Find Wide Metal
Wide_M13_S_20_CHK_REGION = ENCLOSE RECTANGLE (M13_S_20_CHK_REGION NOT WITH WIDTH <= M13_S_20_W1B) M13_S_20_W1B+GRID M13_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M13_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M13_S_20_CHK_REGION == 0
Wide_M13_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M13_S_20_CHK_REGION == 90

// Find Wide Metal Space
M13_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M13_S_20_CHK_REGION_EDGE_H M13_S_20_CHK_REGION < M13_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M13_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M13_S_20_CHK_REGION_EDGE_V M13_S_20_CHK_REGION < M13_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M13_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M13_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M13_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M13_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M13_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M13_S_20_CHK_REGION_OPC_REGION_pre1_H M13_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M13_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M13_S_20_L1B
M13_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M13_S_20_CHK_REGION_OPC_REGION_pre1_V M13_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M13_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M13_S_20_L1B

M13_S_20_OPC_REGION = M13_S_20_CHK_REGION_OPC_REGION_pre2_H OR M13_S_20_CHK_REGION_OPC_REGION_pre2_V

// M13.S.23 ~ M13.S.25
M13_S_23_CHK_REGION = M13i OR ODM13F_pre
// Find Wide Metal
Wide_M13_S_23_CHK_REGION = ENCLOSE RECTANGLE (M13_S_23_CHK_REGION NOT WITH WIDTH <= M13_S_23_W1B) M13_S_23_W1B+GRID M13_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M13_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M13_S_23_CHK_REGION == 0
Wide_M13_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M13_S_23_CHK_REGION == 90

// Find Wide Metal Space
M13_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M13_S_23_CHK_REGION_EDGE_H M13_S_23_CHK_REGION < M13_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M13_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M13_S_23_CHK_REGION_EDGE_V M13_S_23_CHK_REGION < M13_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M13_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M13_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M13_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M13_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M13_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M13_S_23_CHK_REGION_OPC_REGION_pre1_H M13_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M13_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M13_S_23_L1B
M13_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M13_S_23_CHK_REGION_OPC_REGION_pre1_V M13_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M13_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M13_S_23_L1B

M13_S_23_OPC_REGION = M13_S_23_CHK_REGION_OPC_REGION_pre2_H OR M13_S_23_CHK_REGION_OPC_REGION_pre2_V

// M13.S.27
M13_S_27_CHK_REGION = M13i OR ODM13F_pre
// Find Wide Metal
Wide_M13_S_27_CHK_REGION = ENCLOSE RECTANGLE (M13_S_27_CHK_REGION NOT WITH WIDTH <= M13_S_27_W1B) M13_S_27_W1B+GRID M13_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M13_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M13_S_27_CHK_REGION == 0
Wide_M13_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M13_S_27_CHK_REGION == 90

// Find Wide Metal Space
M13_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M13_S_27_CHK_REGION_EDGE_H M13_S_27_CHK_REGION < M13_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M13_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M13_S_27_CHK_REGION_EDGE_V M13_S_27_CHK_REGION < M13_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M13_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M13_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M13_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M13_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M13_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M13_S_27_CHK_REGION_OPC_REGION_pre1_H M13_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M13_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M13_S_27_L1B
M13_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M13_S_27_CHK_REGION_OPC_REGION_pre1_V M13_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M13_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M13_S_27_L1B

M13_S_27_OPC_REGION = M13_S_27_CHK_REGION_OPC_REGION_pre2_H OR M13_S_27_CHK_REGION_OPC_REGION_pre2_V

M13_WMJ_OPC_REGION = (((M13_S_14_OPC_REGION OR M13_S_17_OPC_REGION) OR M13_S_20_OPC_REGION) OR M13_S_23_OPC_REGION) OR M13_S_27_OPC_REGION

    ODM13F = ODM13F_pre NOT INTERACT M13_WMJ_OPC_REGION

    DM13F = COPY FM13x

    FRAME13_INDDMYA = SIZE M13i BY (dm13_s2m13_INDDMY + grid)
    FRAME13_INDDMYB = SIZE DUM13 BY (dm13_s_INDDMY + grid)
    FRAME13_INDDMYC = SIZE DM13F BY dm13_s_INDDMY
    FRAME13_INDDMYD = SIZE ODM13F BY dm13_s2m13_INDDMY

    FRAME13_INDDMY  = ((((((FRAME13Pre OR xM13_DTCD) OR BLOCK13) OR FRAME13_INDDMYA) OR FRAME13_INDDMYB) OR FRAME13_INDDMYC) OR FRAME13_INDDMYD) OR NFILL_x
    FILL13_INDDMY   = ooINDDMY NOT FRAME13_INDDMY
    DM13F_INDDMY    = RECTANGLES dm13_w_INDDMY dm13_l_INDDMY dm13_s_INDDMY INSIDE OF LAYER FILL13_INDDMY

#IFDEF FILL_indDM13
    FILL13_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm13_s_INDDMY_HD + grid)) NOT FRAME13_INDDMY
    DM13F_INDDMY_HD_pre  = RECTANGLES dm13_w_INDDMY_HD dm13_l_INDDMY_HD dm13_s_INDDMY_HD INSIDE OF LAYER FILL13_INDDMY_HD

    FILL13_INDDMY_MD = (SIZE INDDMY_MD BY -(dm13_s_INDDMY_MD + grid)) NOT (FRAME13_INDDMY OR INDDMY_HD)
    DM13F_INDDMY_MD  = RECTANGLES dm13_w_INDDMY_MD dm13_l_INDDMY_MD dm13_s_INDDMY_MD INSIDE OF LAYER FILL13_INDDMY_MD

    DM13F_INDDMY_HD = DM13F_INDDMY_HD_pre OR DM13F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF



#IFDEF 34K_THICK_Mu_M2
#ELSE
#IFDEF 12K_THICK_Mr_M2
#ELSE
