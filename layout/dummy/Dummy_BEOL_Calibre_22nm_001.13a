TCD_M7_150_7 = COPY TCD_M7_150_7_1
TCD_M7_165_97 = COPY TCD_M7_165_97_1
TCD_M7_37_0 = OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR TCD_M7_37_0_1 TCD_M7_37_0_2) TCD_M7_37_0_3) TCD_M7_37_0_4) TCD_M7_37_0_5) TCD_M7_37_0_6) TCD_M7_37_0_7) TCD_M7_37_0_8) TCD_M7_37_0_9) TCD_M7_37_0_10) TCD_M7_37_0_11) TCD_M7_37_0_12) TCD_M7_37_0_13) TCD_M7_37_0_14) TCD_M7_37_0_15) TCD_M7_37_0_16) TCD_M7_37_0_17) TCD_M7_37_0_18) TCD_M7_37_0_19) TCD_M7_37_0_20) TCD_M7_37_0_21) TCD_M7_37_0_22) TCD_M7_37_0_23) TCD_M7_37_0_24) TCD_M7_37_0_25) TCD_M7_37_0_26) TCD_M7_37_0_27) TCD_M7_37_0_28) TCD_M7_37_0_29) TCD_M7_37_0_30) TCD_M7_37_0_31) TCD_M7_37_0_32) TCD_M7_37_0_33) TCD_M7_37_0_34) TCD_M7_37_0_35) TCD_M7_37_0_36) TCD_M7_37_0_37) TCD_M7_37_0_38) TCD_M7_37_0_39) TCD_M7_37_0_40) TCD_M7_37_0_41) TCD_M7_37_0_42) TCD_M7_37_0_43) TCD_M7_37_0_44) TCD_M7_37_0_45) TCD_M7_37_0_46) TCD_M7_37_0_47) TCD_M7_37_0_48) TCD_M7_37_0_49) TCD_M7_37_0_50) TCD_M7_37_0_51) TCD_M7_37_0_52) TCD_M7_37_0_53) TCD_M7_37_0_54) TCD_M7_37_0_55) TCD_M7_37_0_56) TCD_M7_37_0_57

    xM7_DTCD = SIZE TCD_M7 BY D2M7_DTCD
#ELSE
    xM7_DTCD = COPY EMPTY
#ENDIF

    M7BigHole = SIZE M7InnerHole BY - excludeHoleSize/2
    M7ExcHole = ((M7InnerHole OUTSIDE M7BigHole) NOT M7i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK7 = (SIZE DM7EXCL BY (dm2DMEXCL + grid)) OR MIM7_x

    FRAMEA7 = (SIZE M7i BY (DM7_301 + grid)) OR (SIZE (EXPAND EDGE (M7i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA7OPC = SIZE M7i BY (DM7_OPC + grid)
    FRAMEA7OPCwide = SIZE (M7i WITH WIDTH > DM7_OPC_wide_w) BY (DM7_OPC_wide + grid)
    FRAMEA7OPC45 = SIZE (EXPAND EDGE (M7i ANGLE == 45) OUTSIDE BY DM7_OPC_45 EXTEND BY DM7_OPC_45_E) BY grid
    FRAMEA7OPC45DV = SIZE (EXPAND EDGE ((M7i INTERACT M7_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM7_OPC_45 EXTEND BY DM7_OPC_45_E) BY grid
    FRAMEA7OPC_M7_S_14_wide = SIZE (M7i WITH WIDTH > M7_S_14_wide_w) BY (M7_S_14_wide + grid)
    FRAMEA7OPC_M7_S_17_wide = SIZE (M7i WITH WIDTH > M7_S_17_wide_w) BY (M7_S_17_wide + grid)
    FRAMEA7OPC_M7_S_20_wide = SIZE (M7i WITH WIDTH > M7_S_20_wide_w) BY (M7_S_20_wide + grid)
    FRAMEA7OPC_M7_S_23_wide = SIZE (M7i WITH WIDTH > M7_S_23_wide_w) BY (M7_S_23_wide + grid)
    FRAMEA7OPC_M7_S_33_VIA6   = SIZE VIA6_HV_5V_CHK	BY (M7_S_33 + grid)
    FRAMEA7OPC_M7_S_33b_VIA6DV   = SIZE (VIA6i INTERACT (M6_HVN_330Vx OR M7_HVN_330Vx))	BY (M7_S_33b + grid)
    FRAMEA7OPC_M7_S_33_VIA7    = SIZE VIA7_HV_5V_CHK	BY (M7_S_33 + grid)
    FRAMEA7OPC_M7_S_33b_VIA7DV    = SIZE (VIA7i INTERACT (M7_HVN_330Vx OR M8_HVN_330Vx))	BY (M7_S_33b + grid)
    FRAMEA7OPC_M7_S_37_VIA6_b = SIZE VIA6i_55V		BY (M7_S_37 + grid)
    FRAMEA7OPC_M7_S_37a_VIA6_bDV = SIZE (VIA6i INTERACT (M6_HVN_500Vx OR M7_HVN_500Vx))		BY (M7_S_37a + grid)
    FRAMEA7OPC_M7_S_37_VIA7_b  = SIZE VIA7i_55V			BY (M7_S_37 + grid)
    FRAMEA7OPC_M7_S_37a_VIA7_bDV  = SIZE (VIA7i INTERACT (M7_HVN_500Vx OR M8_HVN_500Vx))		BY (M7_S_37a + grid)
    FRAMEA7OPC_M7_S_37_VIA6   = SIZE VIA6i_65V		BY (M7_S_37 + grid)
	FRAMEA7OPC_M7_S_37_VIA7    = SIZE VIA7i_65V			BY (M7_S_37 + grid)

    FRAMEHVD7 = SIZE  M7i_65V  BY (M7_S_38 + grid)
    FRAMEHVD7_55V = SIZE  M7i_55V  BY (M7_S_38 + grid)
    FRAMEHVD7_55VDV = SIZE  (M7i INTERACT M7_HVN_500Vx)  BY (M7_S_38a + grid)
    FRAMEB7 = SIZE (WITH WIDTH M7i > wideM7) BY (dm2WM7 + grid)
    FRAMEC7 = SIZE DUM7 BY (dm2DM7 + grid)
    FRAMED7 = SIZE (WITH WIDTH M7i > wideM7_small) BY (dm2WM7_small + grid)
    FRAMEC7OPC = SIZE DUM7 BY (Odm2DM7 + grid)
    FRAME7Pre = ((FRAMEA7 OR FRAMEB7) OR (FRAMEC7 OR FRAMED7)) OR M7ExcHole
    FRAME7PreOPC = (((((((((((((((((((((FRAMEA7OPC OR FRAMEC7OPC) OR M7ExcHole) OR FRAMEA7OPCwide) OR FRAMEA7OPC45) OR FRAMEA7OPC45DV) OR FRAMEA7OPC_M7_S_14_wide) OR FRAMEA7OPC_M7_S_17_wide) OR FRAMEA7OPC_M7_S_20_wide) OR FRAMEA7OPC_M7_S_23_wide) OR FRAMEA7OPC_M7_S_33_VIA6) OR FRAMEA7OPC_M7_S_33b_VIA6DV) OR FRAMEA7OPC_M7_S_33_VIA7) OR FRAMEA7OPC_M7_S_33b_VIA7DV) OR FRAMEHVD7) OR FRAMEA7OPC_M7_S_37_VIA6) OR FRAMEA7OPC_M7_S_37_VIA6_b) OR FRAMEA7OPC_M7_S_37a_VIA6_bDV) OR FRAMEA7OPC_M7_S_37_VIA7) OR FRAMEA7OPC_M7_S_37_VIA7_b) OR FRAMEA7OPC_M7_S_37a_VIA7_bDV) OR FRAMEHVD7_55V) OR FRAMEHVD7_55VDV


    FRAME7INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm7_s2m7_INDDMY + grid)
    FRAME7OPC = (((FRAME7PreOPC OR FRAME7INDDMY) OR xM7_DTCD) OR BLOCK7) OR NFILLOPC_x

    FRAME7 = (((FRAME7Pre OR FRAME7INDDMY) OR xM7_DTCD) OR BLOCK7) OR NFILL_x

    D30M7p = (PUSH D30M7) NOT FRAME7
    O30M7pre = D30M7p AND CHIP
    FD21M7s = COPY FRAME7

    O30M7preA = SIZE O30M7pre BY -DM7_303
    O30M7preB = O30M7preA WITH WIDTH >= WM7_303

    // 1st big
    F303M7 = RECTANGLES WM7_303 LM7_303 SM7_303 OFFSET OM7_303 INSIDE OF LAYER O30M7preB
    F303M7_SLOT = RECTANGLES WM7_303_SLOT LM7_303_SLOT SM7_303_SLOT INSIDE OF LAYER F303M7

    F303M7_EXP = SIZE F303M7_SLOT BY ( SM7_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M7preF1 = O30M7pre NOT (SIZE F303M7_EXP BY SM7_302)
    O30M7preF  = (SNAP (SIZE O30M7preF1 BY -grid) 5) AND O30M7preF1

    B30M7s = FD21M7s OR (SIZE F303M7_EXP BY (SM7_302+grid))
    O30M7 = O30M7preF NOT B30M7s

    // 3rd, middle
    F302M7 = RECTANGLES WM7_302 LM7_302 SM7_302 OFFSET OM7_302 INSIDE OF LAYER O30M7
    F302M7s = (SIZE F302M7 BY (SM7_301 + grid)) OR B30M7s
    R302M7pre = O30M7 NOT F302M7s
    R302M7 = WITH WIDTH R302M7pre >= WM7_301

    // 4th, small
    F3012M7 = RECTANGLES WM7_301 LM7_301 SM7_301 OFFSET OM7_301 INSIDE OF LAYER R302M7
    F3012M7s = (SIZE F3012M7 BY (SM7_301 + grid)) OR F302M7s
    R3012M7pre = R302M7pre NOT F3012M7s
    R3012M7 = WITH WIDTH R3012M7pre >= WM7_301

    // 5th, non-stagger small
    F301M7 = RECTANGLES WM7_301 LM7_301 SM7_301 INSIDE OF LAYER R3012M7 //MAINTAIN SPACING
    F301M7s = (SIZE F301M7 BY (SM7_301 + grid)) OR F3012M7s

    F30M7 = ((F302M7 OR F3012M7) OR F301M7) OR F303M7_SLOT
    O40M7pre = (((PUSH D40M7) NOT FRAME7) NOT F301M7s) AND CHIP


    O40M7preA = SIZE O40M7pre BY -DM7_403
    O40M7preB = O40M7preA WITH WIDTH >= WM7_403

    // 1st big
    F403M7 = RECTANGLES WM7_403 LM7_403 SM7_403 OFFSET OM7_403 INSIDE OF LAYER O40M7preB
    F403M7_SLOT = RECTANGLES WM7_403_SLOT LM7_403_SLOT SM7_403_SLOT INSIDE OF LAYER F403M7

    F403M7_EXP = SIZE F403M7_SLOT BY ( SM7_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M7preF1 = O40M7pre NOT (SIZE F403M7_EXP BY SM7_402)
    O40M7preF  = (SNAP (SIZE O40M7preF1 BY -grid) 5) AND O40M7preF1

    B40M7s = F301M7s OR (SIZE F403M7_EXP BY (SM7_402+grid))
    O40M7 = O40M7preF NOT B40M7s

    // 3rd, middle
    F402M7 = RECTANGLES WM7_402 LM7_402 SM7_402 OFFSET OM7_402 INSIDE OF LAYER O40M7
    F402M7s = (SIZE F402M7 BY (SM7_401 + grid)) OR B40M7s
    R402M7pre = O40M7 NOT F402M7s
    R402M7 = WITH WIDTH R402M7pre >= WM7_401

    // 4th, small
    F4012M7 = RECTANGLES WM7_401 LM7_401 SM7_401 OFFSET OM7_401 INSIDE OF LAYER R402M7
    F4012M7s = (SIZE F4012M7 BY (SM7_401 + grid)) OR F402M7s
    R4012M7pre = R402M7pre NOT F4012M7s
    R4012M7 = WITH WIDTH R4012M7pre >= WM7_401

    // 5th, non-stagger small
    F401M7 = RECTANGLES WM7_401 LM7_401 SM7_401 INSIDE OF LAYER R4012M7 //MAINTAIN SPACING
    F401M7s = (SIZE F401M7 BY (SM7_401 + grid)) OR F4012M7s

    F40M7 = ((F402M7 OR F4012M7) OR F401M7) OR F403M7_SLOT
    O50M7pre = (((PUSH (D50M7 OR emptyM7)) NOT FRAME7) NOT F401M7s) AND CHIP


    O50M7preA = SIZE O50M7pre BY -DM7_503
    O50M7preB = O50M7preA WITH WIDTH >= WM7_503

    // 1st big
    F503M7 = RECTANGLES WM7_503 LM7_503 SM7_503 OFFSET OM7_503 INSIDE OF LAYER O50M7preB
    F503M7_SLOT = RECTANGLES WM7_503_SLOT LM7_503_SLOT SM7_503_SLOT INSIDE OF LAYER F503M7

    F503M7_EXP = SIZE F503M7_SLOT BY ( SM7_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M7preF1 = O50M7pre NOT (SIZE F503M7_EXP BY SM7_502)
    O50M7preF  = (SNAP (SIZE O50M7preF1 BY -grid) 5) AND O50M7preF1

    B50M7s = F401M7s OR (SIZE F503M7_EXP BY (SM7_502+grid))
    O50M7 = O50M7preF NOT B50M7s

    // 3rd, middle
    F502M7 = RECTANGLES WM7_502 LM7_502 SM7_502 OFFSET OM7_502 INSIDE OF LAYER O50M7
    F502M7s = (SIZE F502M7 BY (SM7_501 + grid)) OR B50M7s
    R502M7pre = O50M7 NOT F502M7s
    R502M7 = WITH WIDTH R502M7pre >= WM7_501

    // 4th, small
    F5012M7 = RECTANGLES WM7_501 LM7_501 SM7_501 OFFSET OM7_501 INSIDE OF LAYER R502M7
    F5012M7s = (SIZE F5012M7 BY (SM7_501 + grid)) OR F502M7s
    R5012M7pre = R502M7pre NOT F5012M7s
    R5012M7 = WITH WIDTH R5012M7pre >= WM7_501

    // 5th, non-stagger small
    F501M7 = RECTANGLES WM7_501 LM7_501 SM7_501 INSIDE OF LAYER R5012M7 //MAINTAIN SPACING
    F501M7s = (SIZE F501M7 BY (SM7_501 + grid)) OR F5012M7s

    F50M7 = ((F502M7 OR F5012M7) OR F501M7) OR F503M7_SLOT

    exceedM7 = DENSITY M7x F30M7 F40M7 F50M7 > maxD_M7 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M7.den_exceed

    removeM7R = ((PUSH (exceedM7 AND (D50M7 OR emptyM7))) NOT FRAME7) AND CHIP
    removeM7P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM7R

    F30M7x = F30M7 NOT INTERACT removeM7P
    F40M7x = F40M7 NOT INTERACT removeM7P
    F50M7x = F50M7 NOT INTERACT removeM7P
    FM7xA  = (F30M7x OR F40M7x) OR F50M7x
    FM7x   = FM7xA NOT INTERACT (EXT FM7xA < DM7_S_1 ABUT SINGULAR REGION)

    ALLM7x = M7x OR FM7x
    lackM7 = DENSITY ALLM7x CHIP < DM7_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M7.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM7x)/AREA(CHIP) ]

    WDM7EXC = DUM7 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM7EXC = (SIZE FM7x BY Odm2DM7) OR (SIZE (((F303M7_EXP OR F403M7_EXP) OR F503M7_EXP) OR WDM7EXC) BY 1.5)

    lackM7pRM = ((((PUSH lackM7) NOT RM7EXC) NOT FRAME7OPC) NOT exceedM7) AND CHIP
    lackM7pRM_1 = WITH WIDTH lackM7pRM >= SM7_OPC

    RM7p1 = RECTANGLES WM7_OPC LM7_OPC WSM7_OPC LSM7_OPC INSIDE OF LAYER lackM7pRM_1
    lackM7pRM_2 = lackM7pRM_1 NOT (SIZE RM7p1 BY SM7_OPC)
    RM7p2 = RECTANGLES LM7_OPC WM7_OPC LSM7_OPC WSM7_OPC INSIDE OF LAYER lackM7pRM_2

    ODM7A = ((RM7p1 OR RM7p2) OUTSIDE RM7EXC) OUTSIDE FRAME7OPC
    ODM7F_pre = ODM7A NOT INTERACT (EXT ODM7A < SM7_OPC ABUT SINGULAR REGION)

// M7.S.14 ~ M7.S.16
M7_S_14_CHK_REGION = M7i OR ODM7F_pre
// Find Wide Metal
Wide_M7_S_14_CHK_REGION = ENCLOSE RECTANGLE (M7_S_14_CHK_REGION NOT WITH WIDTH <= M7_S_14_W1B) M7_S_14_W1B+GRID M7_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M7_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M7_S_14_CHK_REGION == 0
Wide_M7_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M7_S_14_CHK_REGION == 90

// Find Wide Metal Space
M7_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M7_S_14_CHK_REGION_EDGE_H M7_S_14_CHK_REGION < M7_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M7_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M7_S_14_CHK_REGION_EDGE_V M7_S_14_CHK_REGION < M7_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M7_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M7_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M7_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M7_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M7_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M7_S_14_CHK_REGION_OPC_REGION_pre1_H M7_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M7_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M7_S_14_L1B
M7_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M7_S_14_CHK_REGION_OPC_REGION_pre1_V M7_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M7_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M7_S_14_L1B

M7_S_14_OPC_REGION = M7_S_14_CHK_REGION_OPC_REGION_pre2_H OR M7_S_14_CHK_REGION_OPC_REGION_pre2_V

// M7.S.17 ~ M7.S.19
M7_S_17_CHK_REGION = M7i OR ODM7F_pre
// Find Wide Metal
Wide_M7_S_17_CHK_REGION = ENCLOSE RECTANGLE (M7_S_17_CHK_REGION NOT WITH WIDTH <= M7_S_17_W1B) M7_S_17_W1B+GRID M7_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M7_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M7_S_17_CHK_REGION == 0
Wide_M7_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M7_S_17_CHK_REGION == 90

// Find Wide Metal Space
M7_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M7_S_17_CHK_REGION_EDGE_H M7_S_17_CHK_REGION < M7_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M7_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M7_S_17_CHK_REGION_EDGE_V M7_S_17_CHK_REGION < M7_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M7_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M7_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M7_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M7_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M7_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M7_S_17_CHK_REGION_OPC_REGION_pre1_H M7_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M7_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M7_S_17_L1B
M7_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M7_S_17_CHK_REGION_OPC_REGION_pre1_V M7_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M7_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M7_S_17_L1B

M7_S_17_OPC_REGION = M7_S_17_CHK_REGION_OPC_REGION_pre2_H OR M7_S_17_CHK_REGION_OPC_REGION_pre2_V

// M7.S.20 ~ M7.S.22
M7_S_20_CHK_REGION = M7i OR ODM7F_pre
// Find Wide Metal
Wide_M7_S_20_CHK_REGION = ENCLOSE RECTANGLE (M7_S_20_CHK_REGION NOT WITH WIDTH <= M7_S_20_W1B) M7_S_20_W1B+GRID M7_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M7_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M7_S_20_CHK_REGION == 0
Wide_M7_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M7_S_20_CHK_REGION == 90

// Find Wide Metal Space
M7_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M7_S_20_CHK_REGION_EDGE_H M7_S_20_CHK_REGION < M7_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M7_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M7_S_20_CHK_REGION_EDGE_V M7_S_20_CHK_REGION < M7_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M7_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M7_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M7_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M7_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M7_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M7_S_20_CHK_REGION_OPC_REGION_pre1_H M7_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M7_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M7_S_20_L1B
M7_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M7_S_20_CHK_REGION_OPC_REGION_pre1_V M7_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M7_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M7_S_20_L1B

M7_S_20_OPC_REGION = M7_S_20_CHK_REGION_OPC_REGION_pre2_H OR M7_S_20_CHK_REGION_OPC_REGION_pre2_V

// M7.S.23 ~ M7.S.25
M7_S_23_CHK_REGION = M7i OR ODM7F_pre
// Find Wide Metal
Wide_M7_S_23_CHK_REGION = ENCLOSE RECTANGLE (M7_S_23_CHK_REGION NOT WITH WIDTH <= M7_S_23_W1B) M7_S_23_W1B+GRID M7_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M7_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M7_S_23_CHK_REGION == 0
Wide_M7_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M7_S_23_CHK_REGION == 90

// Find Wide Metal Space
M7_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M7_S_23_CHK_REGION_EDGE_H M7_S_23_CHK_REGION < M7_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M7_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M7_S_23_CHK_REGION_EDGE_V M7_S_23_CHK_REGION < M7_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M7_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M7_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M7_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M7_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M7_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M7_S_23_CHK_REGION_OPC_REGION_pre1_H M7_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M7_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M7_S_23_L1B
M7_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M7_S_23_CHK_REGION_OPC_REGION_pre1_V M7_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M7_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M7_S_23_L1B

M7_S_23_OPC_REGION = M7_S_23_CHK_REGION_OPC_REGION_pre2_H OR M7_S_23_CHK_REGION_OPC_REGION_pre2_V

// M7.S.27
M7_S_27_CHK_REGION = M7i OR ODM7F_pre
// Find Wide Metal
Wide_M7_S_27_CHK_REGION = ENCLOSE RECTANGLE (M7_S_27_CHK_REGION NOT WITH WIDTH <= M7_S_27_W1B) M7_S_27_W1B+GRID M7_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M7_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M7_S_27_CHK_REGION == 0
Wide_M7_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M7_S_27_CHK_REGION == 90

// Find Wide Metal Space
M7_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M7_S_27_CHK_REGION_EDGE_H M7_S_27_CHK_REGION < M7_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M7_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M7_S_27_CHK_REGION_EDGE_V M7_S_27_CHK_REGION < M7_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M7_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M7_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M7_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M7_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M7_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M7_S_27_CHK_REGION_OPC_REGION_pre1_H M7_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M7_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M7_S_27_L1B
M7_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M7_S_27_CHK_REGION_OPC_REGION_pre1_V M7_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M7_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M7_S_27_L1B

M7_S_27_OPC_REGION = M7_S_27_CHK_REGION_OPC_REGION_pre2_H OR M7_S_27_CHK_REGION_OPC_REGION_pre2_V

M7_WMJ_OPC_REGION = (((M7_S_14_OPC_REGION OR M7_S_17_OPC_REGION) OR M7_S_20_OPC_REGION) OR M7_S_23_OPC_REGION) OR M7_S_27_OPC_REGION

    ODM7F = ODM7F_pre NOT INTERACT M7_WMJ_OPC_REGION

    DM7F = COPY FM7x

    FRAME7_INDDMYA = SIZE M7i BY (dm7_s2m7_INDDMY + grid)
    FRAME7_INDDMYB = SIZE DUM7 BY (dm7_s_INDDMY + grid)
    FRAME7_INDDMYC = SIZE DM7F BY dm7_s_INDDMY
    FRAME7_INDDMYD = SIZE ODM7F BY dm7_s2m7_INDDMY

    FRAME7_INDDMY  = ((((((FRAME7Pre OR xM7_DTCD) OR BLOCK7) OR FRAME7_INDDMYA) OR FRAME7_INDDMYB) OR FRAME7_INDDMYC) OR FRAME7_INDDMYD) OR NFILL_x
    FILL7_INDDMY   = ooINDDMY NOT FRAME7_INDDMY
    DM7F_INDDMY    = RECTANGLES dm7_w_INDDMY dm7_l_INDDMY dm7_s_INDDMY INSIDE OF LAYER FILL7_INDDMY

#IFDEF FILL_indDM7
    FILL7_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm7_s_INDDMY_HD + grid)) NOT FRAME7_INDDMY
    DM7F_INDDMY_HD_pre  = RECTANGLES dm7_w_INDDMY_HD dm7_l_INDDMY_HD dm7_s_INDDMY_HD INSIDE OF LAYER FILL7_INDDMY_HD

    FILL7_INDDMY_MD = (SIZE INDDMY_MD BY -(dm7_s_INDDMY_MD + grid)) NOT (FRAME7_INDDMY OR INDDMY_HD)
    DM7F_INDDMY_MD  = RECTANGLES dm7_w_INDDMY_MD dm7_l_INDDMY_MD dm7_s_INDDMY_MD INSIDE OF LAYER FILL7_INDDMY_MD

    DM7F_INDDMY_HD = DM7F_INDDMY_HD_pre OR DM7F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#IFDEF FILL_DM8


#IFDEF 34K_THICK_Mu_M8

    minOPENM8 = DENSITY M8x < minD_M8 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M8Min.den
    emptyOPENM8 = DENSITY M8x < emptyD_M8 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M8Empty.den

    M8InnerHole = HOLES M8i INNER

    M8BigHole = SIZE M8InnerHole BY - excludeHoleSize/2
    M8ExcHole = ((M8InnerHole OUTSIDE M8BigHole) NOT M8i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK8    = (SIZE DM8EXCL BY (dm2DMEXCL + grid)) OR MIM8_x
    FRAMEA8   = SIZE M8i BY (dm2M8 + grid) // DM8 to metal
    FRAMEB8   = SIZE (WITH WIDTH M8i > wideM8) BY (dm2WM8 + grid)
    FRAMEC8   = SIZE DUM8 BY (dm2DM8 + grid)
    FRAME8Pre = ((FRAMEA8 OR FRAMEB8) OR FRAMEC8) OR M8ExcHole
    FRAME8INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm8_s2m8_INDDMY + grid)
    FRAME8 = ((FRAME8Pre OR FRAME8INDDMY) OR BLOCK8) OR NFILL
    
    OPENM8 = PUSH ((minOPENM8 OR emptyOPENM8) AND CHIP)
    FILL8 = OPENM8 NOT FRAME8
    FILLW8pre = SIZE FILL8 BY - (Wdm2M8 + grid)
    FILLW8 = WITH WIDTH FILLW8pre >= WdmW_M8
    M8FW = RECTANGLES WdmW_M8 WdmL_M8 WdmS_M8 OFFSET WdmO_M8 INSIDE OF LAYER FILLW8
    M8FW_EXP = SIZE M8FW BY (WdmS_M8 /2 + grid) OVERUNDER   // merge the gaps
    FILLM8pre = FILL8 NOT (SIZE M8FW_EXP BY (MdmS_M8 + grid))
    FILLM8 = WITH WIDTH FILLM8pre >= MdmW_M8
    M8F1 = RECTANGLES MdmW_M8 MdmL_M8 MdmS_M8 OFFSET MdmO_M8 INSIDE OF LAYER FILLM8
    M8R1pre = FILLM8pre NOT (SIZE M8F1 BY (dmS_M8 + grid))
    M8R1 = WITH WIDTH M8R1pre >= dmW_M8

    M8F2 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 OFFSET dmO_M8 INSIDE OF LAYER M8R1
    M8R2pre = M8R1 NOT (SIZE M8F2 BY (dmS_M8 + grid))
    M8R2 = WITH WIDTH M8R2pre >= dmW_M8

    M8F3 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 OFFSET dmO_M8 INSIDE OF LAYER M8R2
    M8R3pre = M8R2 NOT (SIZE M8F3 BY (dmS_M8 + grid))
    M8R3 = WITH WIDTH M8R3pre >= dmW_M8

    M8F4 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 INSIDE OF LAYER M8R3

    M8F = (((M8F1 OR M8F2) OR M8F3) OR M8F4) OR M8FW
    FM8 = M8F NOT INTERACT (EXT M8F < dmS_M8 ABUT SINGULAR REGION)

    maxOPENM8 = DENSITY M8x FM8 > maxD_M8 WINDOW WindowSizeu*2 STEP WindowStepu*2
                INSIDE OF LAYER bulk BACKUP // PRINT M8Max.den

    DM8F = FM8 OUTSIDE maxOPENM8

    FRAME8_INDDMYA = SIZE M8i BY (dm8_s2m8_INDDMY + grid)
    FRAME8_INDDMYB = SIZE DUM8 BY (dm8_s_INDDMY + grid)
    FRAME8_INDDMYC = SIZE DM8F BY dm8_s_INDDMY
    FRAME8_INDDMY  = ((((FRAME8Pre OR BLOCK8) OR FRAME8_INDDMYA) OR FRAME8_INDDMYB) OR FRAME8_INDDMYC) OR NFILL
    FILL8_INDDMY   = ooINDDMY NOT FRAME8_INDDMY
    DM8F_INDDMY    = RECTANGLES dm8_w_INDDMY dm8_l_INDDMY dm8_s_INDDMY INSIDE OF LAYER FILL8_INDDMY
#IFDEF FILL_indDM8
    FILL8_INDDMY_HD = (SIZE INDDMY_HD BY -(dm8_s_INDDMY_HD + grid)) NOT FRAME8_INDDMY
    DM8F_INDDMY_HD  = RECTANGLES dm8_w_INDDMY_HD dm8_l_INDDMY_HD dm8_s_INDDMY_HD INSIDE OF LAYER FILL8_INDDMY_HD
#ENDIF	
	
#ELSE


#IFDEF 12K_THICK_Mr_M8

    minOPENM8 = DENSITY M8x < minD_M8 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M8Min.den
    emptyOPENM8 = DENSITY M8x < emptyD_M8 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M8Empty.den

    M8InnerHole = HOLES M8i INNER

    M8BigHole = SIZE M8InnerHole BY - excludeHoleSize/2
    M8ExcHole = ((M8InnerHole OUTSIDE M8BigHole) NOT M8i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK8  = (SIZE DM8EXCL BY (dm2DMEXCL + grid)) OR MIM8_x // DM8 to DM8EXCL
    FRAMEA8 = SIZE M8i BY (dm2M8 + grid) // DM8 to metal
    FRAMEB8 = SIZE (WITH WIDTH M8i > wideM8) BY (dm2WM8 + grid)
    FRAMEC8 = SIZE DUM8 BY (dm2DM8 + grid)   // DM8 to existed dummy metal 0.6um
    FRAME8Pre = ((FRAMEA8 OR FRAMEB8) OR FRAMEC8) OR M8ExcHole
    FRAME8INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm8_s2m8_INDDMY + grid)
    FRAME8 = ((FRAME8Pre OR FRAME8INDDMY) OR BLOCK8) OR NFILL
    
    OPENM8 = PUSH ((minOPENM8 OR emptyOPENM8) AND CHIP)
    FILL8 = OPENM8 NOT FRAME8
    FILLW8pre = SIZE FILL8 BY - (Wdm2M8 + grid)
    FILLW8 = WITH WIDTH FILLW8pre >= WdmW_M8
    M8FW = RECTANGLES WdmW_M8 WdmL_M8 WdmS_M8 OFFSET WdmO_M8 INSIDE OF LAYER FILLW8
    M8FW_EXP = SIZE M8FW BY (WdmS_M8 /2 + grid) OVERUNDER //merge the gaps
    FILLM8pre = FILL8 NOT (SIZE M8FW_EXP BY (MdmS_M8 + grid))
    FILLM8 = WITH WIDTH FILLM8pre >= MdmW_M8
    M8F1 = RECTANGLES MdmW_M8 MdmL_M8 MdmS_M8 OFFSET MdmO_M8 INSIDE OF LAYER FILLM8
    M8R1pre = FILLM8pre NOT (SIZE M8F1 BY (dmS_M8 + grid))
    M8R1 = WITH WIDTH M8R1pre >= dmW_M8

    M8F2 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 OFFSET dmO_M8 INSIDE OF LAYER M8R1
    M8R2pre = M8R1 NOT (SIZE M8F2 BY (dmS_M8 + grid))
    M8R2 = WITH WIDTH M8R2pre >= dmW_M8

    M8F3 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 OFFSET dmO_M8 INSIDE OF LAYER M8R2
    M8R3pre = M8R2 NOT (SIZE M8F3 BY (dmS_M8 + grid))
    M8R3 = WITH WIDTH M8R3pre >= dmW_M8

    M8F4 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 INSIDE OF LAYER M8R3

    M8F = (((M8F1 OR M8F2) OR M8F3) OR M8F4) OR M8FW
    FM8 = M8F NOT INTERACT (EXT M8F < dmS_M8 ABUT SINGULAR REGION)

    maxOPENM8 = DENSITY M8x FM8 > maxD_M8 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M8Max.den

    FM8F = FM8 OUTSIDE maxOPENM8

    // DMr_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M8 = DENSITY M8x FM8F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M8Min.den

    RM8EXC = SIZE FM8F BY (Odm2DM8 + grid)
    // do not fill DMy_S over CTMDMY
    D25M8pM = (((PUSH D25M8) NOT FRAME8) NOT RM8EXC) AND CHIP
    D25M8pM_1 = WITH WIDTH D25M8pM >= OdmW_M8

    RM8p1 = RECTANGLES OdmW_M8 OdmL_M8 OdmS_M8 INSIDE OF LAYER D25M8pM_1
    D25M8pM_2 = D25M8pM_1 NOT (SIZE RM8p1 BY (OdmS_M8 + grid))
    RM8p2 = RECTANGLES OdmL_M8 OdmW_M8 OdmS_M8 INSIDE OF LAYER D25M8pM_2

    RM8A = ((RM8p1 OR RM8p2) OUTSIDE RM8EXC) OUTSIDE FRAME8
    RM8  = RM8A NOT INTERACT (EXT RM8A < OdmS_M8 ABUT SINGULAR REGION)

    DM8F = FM8F OR RM8

    FRAME8_INDDMYA = SIZE M8i BY (dm8_s2m8_INDDMY + grid)
    FRAME8_INDDMYB = SIZE DUM8 BY (dm8_s_INDDMY + grid)
    FRAME8_INDDMYC = SIZE DM8F BY dm8_s_INDDMY
    FRAME8_INDDMY  = ((((FRAME8Pre OR BLOCK8) OR FRAME8_INDDMYA) OR FRAME8_INDDMYB) OR FRAME8_INDDMYC) OR NFILL
    FILL8_INDDMY   = ooINDDMY NOT FRAME8_INDDMY
    DM8F_INDDMY    = RECTANGLES dm8_w_INDDMY dm8_l_INDDMY dm8_s_INDDMY INSIDE OF LAYER FILL8_INDDMY

#IFDEF FILL_indDM8
    FILL8_INDDMY_HD = (SIZE INDDMY_HD BY -(dm8_s_INDDMY_HD + grid)) NOT FRAME8_INDDMY
    DM8F_INDDMY_HD  = RECTANGLES dm8_w_INDDMY_HD dm8_l_INDDMY_HD dm8_s_INDDMY_HD INSIDE OF LAYER FILL8_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 5K_THICK_Myz_M8

