    FRAMEC8 = SIZE DUM8 BY (dm2DM8 + grid)   // DM8 to existed dummy metal 0.6um
    FRAME8Pre = ((FRAMEA8 OR FRAMEB8) OR FRAMEC8) OR M8ExcHole
    FRAME8INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm8_s2m8_INDDMY + grid)
    FRAME8 = ((FRAME8Pre OR FRAME8INDDMY) OR BLOCK8) OR NFILL
    
    OPENM8 = PUSH ((minOPENM8 OR emptyOPENM8) AND CHIP)
    FILL8 = OPENM8 NOT FRAME8
    FILLW8pre = SIZE FILL8 BY - (Wdm2M8 + grid)
    FILLW8 = WITH WIDTH FILLW8pre >= WdmW_M8
    M8FW = RECTANGLES WdmW_M8 WdmL_M8 WdmS_M8 OFFSET WdmO_M8 INSIDE OF LAYER FILLW8
    M8FW_EXP = SIZE M8FW BY (WdmS_M8 /2 + grid) OVERUNDER //merge the gaps
    FILLM8pre = FILL8 NOT (SIZE M8FW_EXP BY (MdmS_M8 + grid))
    FILLM8 = WITH WIDTH FILLM8pre >= MdmW_M8
    M8F1 = RECTANGLES MdmW_M8 MdmL_M8 MdmS_M8 OFFSET MdmO_M8 INSIDE OF LAYER FILLM8
    M8R1pre = FILLM8pre NOT (SIZE M8F1 BY (dmS_M8 + grid))
    M8R1 = WITH WIDTH M8R1pre >= dmW_M8

    M8F2 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 OFFSET dmO_M8 INSIDE OF LAYER M8R1
    M8R2pre = M8R1 NOT (SIZE M8F2 BY (dmS_M8 + grid))
    M8R2 = WITH WIDTH M8R2pre >= dmW_M8

    M8F3 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 OFFSET dmO_M8 INSIDE OF LAYER M8R2
    M8R3pre = M8R2 NOT (SIZE M8F3 BY (dmS_M8 + grid))
    M8R3 = WITH WIDTH M8R3pre >= dmW_M8

    M8F4 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 INSIDE OF LAYER M8R3

    M8F = (((M8F1 OR M8F2) OR M8F3) OR M8F4) OR M8FW
    FM8 = M8F NOT INTERACT (EXT M8F < dmS_M8 ABUT SINGULAR REGION)

    maxOPENM8 = DENSITY M8x FM8 > maxD_M8 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M8Max.den

    FM8F = FM8 OUTSIDE maxOPENM8

    D25M8 = DENSITY M8x FM8F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M8Min.den

    RM8EXC = SIZE FM8F BY (Odm2DM8 + grid)
    D25M8pM = (((PUSH D25M8) NOT FRAME8) NOT RM8EXC) AND CHIP
    D25M8pM_1 = WITH WIDTH D25M8pM >= OdmW_M8

    RM8p1 = RECTANGLES OdmW_M8 OdmL_M8 OdmS_M8 INSIDE OF LAYER D25M8pM_1
    D25M8pM_2 = D25M8pM_1 NOT (SIZE RM8p1 BY (OdmS_M8 + grid))
    RM8p2 = RECTANGLES OdmL_M8 OdmW_M8 OdmS_M8 INSIDE OF LAYER D25M8pM_2

    RM8A = ((RM8p1 OR RM8p2) OUTSIDE RM8EXC) OUTSIDE FRAME8
    RM8  = RM8A NOT INTERACT (EXT RM8A < OdmS_M8 ABUT SINGULAR REGION)

    DM8F = FM8F OR RM8

    FRAME8_INDDMYA = SIZE M8i BY (dm8_s2m8_INDDMY + grid)
    FRAME8_INDDMYB = SIZE DUM8 BY (dm8_s_INDDMY + grid)
    FRAME8_INDDMYC = SIZE DM8F BY dm8_s_INDDMY
    FRAME8_INDDMY  = ((((FRAME8Pre OR BLOCK8) OR FRAME8_INDDMYA) OR FRAME8_INDDMYB) OR FRAME8_INDDMYC) OR NFILL
    FILL8_INDDMY   = ooINDDMY NOT FRAME8_INDDMY
    DM8F_INDDMY    = RECTANGLES dm8_w_INDDMY dm8_l_INDDMY dm8_s_INDDMY INSIDE OF LAYER FILL8_INDDMY

#IFDEF FILL_indDM8
    FILL8_INDDMY_HD = (SIZE INDDMY_HD BY -(dm8_s_INDDMY_HD + grid)) NOT FRAME8_INDDMY
    DM8F_INDDMY_HD  = RECTANGLES dm8_w_INDDMY_HD dm8_l_INDDMY_HD dm8_s_INDDMY_HD INSIDE OF LAYER FILL8_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M8

    D30M8 = DENSITY M8x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M8.den30
    D40M8 = DENSITY M8x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M8.den40
    D50M8 = DENSITY M8x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M8.den50
    emptyM8 = DENSITY M8x < emptyD_M8 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M8.den_empty

    M8InnerHole = HOLES M8i INNER

    M8BigHole = SIZE M8InnerHole BY - excludeHoleSize/2
    M8ExcHole = ((M8InnerHole OUTSIDE M8BigHole) NOT M8i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK8 = (SIZE DM8EXCL BY (dm2DMEXCL + grid)) OR MIM8_x

    FRAMEA8 = (SIZE M8i BY (DM8_301 + grid)) OR (SIZE (EXPAND EDGE (M8i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA8OPC = SIZE M8i BY (DM8_OPC + grid)
    FRAMEA8OPCDV33 = SIZE (M8i INTERACT M8_HVN_330Vx) BY (M8_S_1_1_a + grid)
    FRAMEA8OPCDV5 = SIZE (M8i INTERACT M8_HVN_500Vx) BY (M8_S_9_a + grid)
    FRAMEA8OPC45 = SIZE (EXPAND EDGE (M8i ANGLE == 45) OUTSIDE BY DM8_OPC_45 EXTEND BY DM8_OPC_45_E) BY grid
    FRAMEA8OPC45DV = SIZE (EXPAND EDGE ((M8i INTERACT M8_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM8_OPC_45 EXTEND BY DM8_OPC_45_E) BY grid

    FRAMEB8 = SIZE (WITH WIDTH M8i > wideM8) BY (dm2WM8 + grid)
    FRAMEC8 = SIZE DUM8 BY (dm2DM8 + grid)
    FRAMED8 = SIZE (WITH WIDTH M8i > wideM8_small) BY (dm2WM8_small + grid)
    FRAMEC8OPC = SIZE DUM8 BY (Odm2DM8 + grid)
    FRAME8Pre = ((FRAMEA8 OR FRAMEB8) OR (FRAMEC8 OR FRAMED8)) OR M8ExcHole
    FRAME8PreOPC = (((((((FRAMEA8OPC OR FRAMEA8OPCDV33) OR FRAMEA8OPCDV5) OR FRAMEC8OPC) OR M8ExcHole) OR FRAMEA8OPC45) OR FRAMEA8OPC45DV) OR FRAMEB8) OR FRAMED8
    FRAME8INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm8_s2m8_INDDMY + grid)

    FRAME8OPC = ((FRAME8PreOPC OR FRAME8INDDMY) OR BLOCK8) OR NFILLOPC

    FRAME8 = ((FRAME8Pre OR FRAME8INDDMY) OR BLOCK8) OR NFILL

    //****************************************************************************

    D30M8p = (PUSH D30M8) NOT FRAME8
    O30M8pre = D30M8p AND CHIP
    FD21M8s = COPY FRAME8

    O30M8preA = SIZE O30M8pre BY -DM8_303
    O30M8preB = O30M8preA WITH WIDTH >= WM8_303

    // 1st big
    F303M8 = RECTANGLES WM8_303 LM8_303 SM8_303 OFFSET OM8_303 INSIDE OF LAYER O30M8preB

    F303M8_EXP = SIZE F303M8 BY ( SM8_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M8preF1 = O30M8pre NOT (SIZE F303M8_EXP BY SM8_302)
    O30M8preF  = (SNAP (SIZE O30M8preF1 BY -grid) 5) AND O30M8preF1

    B30M8s = FD21M8s OR (SIZE F303M8_EXP BY (SM8_302+grid))
    O30M8 = O30M8preF NOT B30M8s

    // 3rd, middle
    F302M8 = RECTANGLES WM8_302 LM8_302 SM8_302 OFFSET OM8_302 INSIDE OF LAYER O30M8
    F302M8s = (SIZE F302M8 BY (SM8_301 + grid)) OR B30M8s
    R302M8pre = O30M8 NOT F302M8s
    R302M8 = WITH WIDTH R302M8pre >= WM8_301

    // 4th, small
    F3012M8 = RECTANGLES WM8_301 LM8_301 SM8_301 OFFSET OM8_301 INSIDE OF LAYER R302M8
    F3012M8s = (SIZE F3012M8 BY (SM8_301 + grid)) OR F302M8s
    R3012M8pre = R302M8pre NOT F3012M8s
    R3012M8 = WITH WIDTH R3012M8pre >= WM8_301

    // 5th, non-stagger small
    F301M8 = RECTANGLES WM8_301 LM8_301 SM8_301 INSIDE OF LAYER R3012M8 //MAINTAIN SPACING
    F301M8s = (SIZE F301M8 BY (SM8_301 + grid)) OR F3012M8s

    F30M8 = ((F302M8 OR F3012M8) OR F301M8) OR F303M8
    O40M8pre = (((PUSH D40M8) NOT FRAME8) NOT F301M8s) AND CHIP


    O40M8preA = SIZE O40M8pre BY -DM8_403
    O40M8preB = O40M8preA WITH WIDTH >= WM8_403

    // 1st big
    F403M8 = RECTANGLES WM8_403 LM8_403 SM8_403 OFFSET OM8_403 INSIDE OF LAYER O40M8preB

    F403M8_EXP = SIZE F403M8 BY ( SM8_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M8preF1 = O40M8pre NOT (SIZE F403M8_EXP BY SM8_402)
    O40M8preF  = (SNAP (SIZE O40M8preF1 BY -grid) 5) AND O40M8preF1

    B40M8s = F301M8s OR (SIZE F403M8_EXP BY (SM8_402+grid))
    O40M8 = O40M8preF NOT B40M8s

    // 3rd, middle
    F402M8 = RECTANGLES WM8_402 LM8_402 SM8_402 OFFSET OM8_402 INSIDE OF LAYER O40M8
    F402M8s = (SIZE F402M8 BY (SM8_401 + grid)) OR B40M8s
    R402M8pre = O40M8 NOT F402M8s
    R402M8 = WITH WIDTH R402M8pre >= WM8_401

    // 4th, small
    F4012M8 = RECTANGLES WM8_401 LM8_401 SM8_401 OFFSET OM8_401 INSIDE OF LAYER R402M8
    F4012M8s = (SIZE F4012M8 BY (SM8_401 + grid)) OR F402M8s
    R4012M8pre = R402M8pre NOT F4012M8s
    R4012M8 = WITH WIDTH R4012M8pre >= WM8_401

    // 5th, non-stagger small
    F401M8 = RECTANGLES WM8_401 LM8_401 SM8_401 INSIDE OF LAYER R4012M8 //MAINTAIN SPACING
    F401M8s = (SIZE F401M8 BY (SM8_401 + grid)) OR F4012M8s

    F40M8 = ((F402M8 OR F4012M8) OR F401M8) OR F403M8
    O50M8pre = (((PUSH (D50M8 OR emptyM8)) NOT FRAME8) NOT F401M8s) AND CHIP


    O50M8preA = SIZE O50M8pre BY -DM8_503
    O50M8preB = O50M8preA WITH WIDTH >= WM8_503

    // 1st big
    F503M8 = RECTANGLES WM8_503 LM8_503 SM8_503 OFFSET OM8_503 INSIDE OF LAYER O50M8preB

    F503M8_EXP = SIZE F503M8 BY ( SM8_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M8preF1 = O50M8pre NOT (SIZE F503M8_EXP BY SM8_502)
    O50M8preF  = (SNAP (SIZE O50M8preF1 BY -grid) 5) AND O50M8preF1

    B50M8s = F401M8s OR (SIZE F503M8_EXP BY (SM8_502+grid))
    O50M8 = O50M8preF NOT B50M8s

    // 3rd, middle
    F502M8 = RECTANGLES WM8_502 LM8_502 SM8_502 OFFSET OM8_502 INSIDE OF LAYER O50M8
    F502M8s = (SIZE F502M8 BY (SM8_501 + grid)) OR B50M8s
    R502M8pre = O50M8 NOT F502M8s
    R502M8 = WITH WIDTH R502M8pre >= WM8_501

    // 4th, small
    F5012M8 = RECTANGLES WM8_501 LM8_501 SM8_501 OFFSET OM8_501 INSIDE OF LAYER R502M8
    F5012M8s = (SIZE F5012M8 BY (SM8_501 + grid)) OR F502M8s
    R5012M8pre = R502M8pre NOT F5012M8s
    R5012M8 = WITH WIDTH R5012M8pre >= WM8_501

    // 5th, non-stagger small
    F501M8 = RECTANGLES WM8_501 LM8_501 SM8_501 INSIDE OF LAYER R5012M8 //MAINTAIN SPACING
    F501M8s = (SIZE F501M8 BY (SM8_501 + grid)) OR F5012M8s

    F50M8 = ((F502M8 OR F5012M8) OR F501M8) OR F503M8

//****************************************************************************

    exceedM8 = DENSITY M8x F30M8 F40M8 F50M8 > maxD_M8 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M8.den_exceed

    removeM8R = ((PUSH (exceedM8 AND (D50M8 OR emptyM8))) NOT FRAME8) AND CHIP
    removeM8P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM8R

    F30M8x = F30M8 NOT INTERACT removeM8P
    F40M8x = F40M8 NOT INTERACT removeM8P
    F50M8x = F50M8 NOT INTERACT removeM8P
    FM8xA  = (F30M8x OR F40M8x) OR F50M8x
    FM8x   = FM8xA NOT INTERACT (EXT FM8xA < DM8_S_1 ABUT SINGULAR REGION)

    ALLM8x = M8x OR FM8x
    lackM8 = DENSITY ALLM8x CHIP < DM8_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M8.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM8x)/AREA(CHIP) ]

    WDM8EXC = DUM8 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM8EXC = (SIZE FM8x BY Odm2DM8) OR (SIZE (((F303M8_EXP OR F403M8_EXP) OR F503M8_EXP) OR WDM8EXC) BY 1.5)

    lackM8pRM = ((((PUSH lackM8) NOT RM8EXC) NOT FRAME8OPC) NOT exceedM8) AND CHIP
    lackM8pRM_1 = WITH WIDTH lackM8pRM >= SM8_OPC

    RM8p1 = RECTANGLES WM8_OPC LM8_OPC WSM8_OPC LSM8_OPC INSIDE OF LAYER lackM8pRM_1
    lackM8pRM_2 = lackM8pRM_1 NOT (SIZE RM8p1 BY SM8_OPC)
    RM8p2 = RECTANGLES LM8_OPC WM8_OPC LSM8_OPC WSM8_OPC INSIDE OF LAYER lackM8pRM_2

    ODM8A = ((RM8p1 OR RM8p2) OUTSIDE RM8EXC) OUTSIDE FRAME8OPC
    ODM8F = ODM8A NOT INTERACT (EXT ODM8A < SM8_OPC ABUT SINGULAR REGION)

    DM8F = COPY FM8x

    FRAME8_INDDMYA = SIZE M8i BY (dm8_s2m8_INDDMY + grid)
    FRAME8_INDDMYB = SIZE DUM8 BY (dm8_s_INDDMY + grid)
    FRAME8_INDDMYC = SIZE DM8F BY dm8_s_INDDMY
    FRAME8_INDDMYD = SIZE ODM8F BY dm8_s2m8_INDDMY
    FRAME8_INDDMY  = (((((FRAME8Pre OR BLOCK8) OR FRAME8_INDDMYA) OR FRAME8_INDDMYB) OR FRAME8_INDDMYC) OR FRAME8_INDDMYD) OR NFILL
    FILL8_INDDMY   = ooINDDMY NOT FRAME8_INDDMY
    DM8F_INDDMY    = RECTANGLES dm8_w_INDDMY dm8_l_INDDMY dm8_s_INDDMY INSIDE OF LAYER FILL8_INDDMY


#IFDEF FILL_indDM8
    FILL8_INDDMY_HD = (SIZE INDDMY_HD BY -(dm8_s_INDDMY_HD + grid)) NOT FRAME8_INDDMY
    DM8F_INDDMY_HD  = RECTANGLES dm8_w_INDDMY_HD dm8_l_INDDMY_HD dm8_s_INDDMY_HD INSIDE OF LAYER FILL8_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M8

    minOPENM8 = DENSITY M8x < minD_M8 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M8Min.den
    emptyOPENM8 = DENSITY M8x < emptyD_M8 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M8Empty.den

    M8InnerHole = HOLES M8i INNER

    M8BigHole = SIZE M8InnerHole BY - excludeHoleSize/2
    M8ExcHole = ((M8InnerHole OUTSIDE M8BigHole) NOT M8i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK8 = (SIZE DM8EXCL BY (dm2DMEXCL + grid)) OR MIM8_x // DM8 to DM8EXCL
    FRAMEA8 = SIZE M8i BY (dm2M8 + grid) // DM8 to metal
    FRAMEB8 = SIZE (WITH WIDTH M8i > wideM8) BY (dm2WM8 + grid)
    FRAMEC8 = SIZE DUM8 BY (dm2DM8 + grid)   // DM8 to existed dummy metal 0.6um
    FRAME8Pre = ((FRAMEA8 OR FRAMEB8) OR FRAMEC8) OR M8ExcHole
    FRAME8INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm8_s2m8_INDDMY + grid)
    FRAME8 = ((FRAME8Pre OR FRAME8INDDMY) OR BLOCK8) OR NFILL
    
    OPENM8 = PUSH ((minOPENM8 OR emptyOPENM8) AND CHIP)
    FILL8 = OPENM8 NOT FRAME8
    FILLW8pre = SIZE FILL8 BY - (Wdm2M8 + grid)
    FILLW8 = WITH WIDTH FILLW8pre >= WdmW_M8
    M8FW = RECTANGLES WdmW_M8 WdmL_M8 WdmS_M8 OFFSET WdmO_M8 INSIDE OF LAYER FILLW8
    M8FW_EXP = SIZE M8FW BY (WdmS_M8 /2 + grid) OVERUNDER //merge the gaps
    FILLM8pre = FILL8 NOT (SIZE M8FW_EXP BY (MdmS_M8 + grid))
    FILLM8 = WITH WIDTH FILLM8pre >= MdmW_M8
    M8F1 = RECTANGLES MdmW_M8 MdmL_M8 MdmS_M8 OFFSET MdmO_M8 INSIDE OF LAYER FILLM8
    M8R1pre = FILLM8pre NOT (SIZE M8F1 BY (dmS_M8 + grid))
    M8R1 = WITH WIDTH M8R1pre >= dmW_M8

    M8F2 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 OFFSET dmO_M8 INSIDE OF LAYER M8R1
    M8R2pre = M8R1 NOT (SIZE M8F2 BY (dmS_M8 + grid))
    M8R2 = WITH WIDTH M8R2pre >= dmW_M8

    M8F3 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 OFFSET dmO_M8 INSIDE OF LAYER M8R2
    M8R3pre = M8R2 NOT (SIZE M8F3 BY (dmS_M8 + grid))
    M8R3 = WITH WIDTH M8R3pre >= dmW_M8

    M8F4 = RECTANGLES dmW_M8 dmL_M8 dmS_M8 INSIDE OF LAYER M8R3

    M8F = (((M8F1 OR M8F2) OR M8F3) OR M8F4) OR M8FW
    FM8 = M8F NOT INTERACT (EXT M8F < dmS_M8 ABUT SINGULAR REGION)

    maxOPENM8 = DENSITY M8x FM8 > maxD_M8 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M8Max.den

    FM8F = FM8 OUTSIDE maxOPENM8

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M8 = DENSITY M8x FM8F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M8Min.den

    RM8EXC = SIZE FM8F BY (Odm2DM8 + grid)
    // do not fill DMz_S over CTMDMY
    D25M8pM = (((PUSH D25M8) NOT FRAME8) NOT RM8EXC) AND CHIP
    D25M8pM_1 = WITH WIDTH D25M8pM >= OdmW_M8

    RM8p1 = RECTANGLES OdmW_M8 OdmL_M8 OdmS_M8 INSIDE OF LAYER D25M8pM_1
    D25M8pM_2 = D25M8pM_1 NOT (SIZE RM8p1 BY (OdmS_M8 + grid))
    RM8p2 = RECTANGLES OdmL_M8 OdmW_M8 OdmS_M8 INSIDE OF LAYER D25M8pM_2

    RM8A = ((RM8p1 OR RM8p2) OUTSIDE RM8EXC) OUTSIDE FRAME8
    RM8  = RM8A NOT INTERACT (EXT RM8A < OdmS_M8 ABUT SINGULAR REGION)

    DM8F = FM8F OR RM8

    FRAME8_INDDMYA = SIZE M8i BY (dm8_s2m8_INDDMY + grid)
    FRAME8_INDDMYB = SIZE DUM8 BY (dm8_s_INDDMY + grid)
    FRAME8_INDDMYC = SIZE DM8F BY dm8_s_INDDMY
    FRAME8_INDDMY  = ((((FRAME8Pre OR BLOCK8) OR FRAME8_INDDMYA) OR FRAME8_INDDMYB) OR FRAME8_INDDMYC) OR NFILL
    FILL8_INDDMY   = ooINDDMY NOT FRAME8_INDDMY
    DM8F_INDDMY    = RECTANGLES dm8_w_INDDMY dm8_l_INDDMY dm8_s_INDDMY INSIDE OF LAYER FILL8_INDDMY

#IFDEF FILL_indDM8
    FILL8_INDDMY_HD = (SIZE INDDMY_HD BY -(dm8_s_INDDMY_HD + grid)) NOT FRAME8_INDDMY
    DM8F_INDDMY_HD  = RECTANGLES dm8_w_INDDMY_HD dm8_l_INDDMY_HD dm8_s_INDDMY_HD INSIDE OF LAYER FILL8_INDDMY_HD
#ENDIF	

#ELSE



    D30M8 = DENSITY M8x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M8.den30
    D40M8 = DENSITY M8x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M8.den40
    D50M8 = DENSITY M8x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M8.den50
    emptyM8 = DENSITY M8x < emptyD_M8 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M8.den_empty

    M8InnerHole = HOLES M8i INNER
#IFDEF FILL_M8_DTCD
    VARIABLE M8_DTCD2Chip      2.5  //
    VARIABLE M8_DTCD2LOGO      10   //
    VARIABLE M8_DTCD2MOMDMY    0    // 
    VARIABLE M8_DTCD2LOWMEDN   0    //
    VARIABLE M8_DTCD2POFUSE    0    //
    VARIABLE M8_DTCD2DM8EXCL   0    //
    VARIABLE M8_DTCD2DM8CB2   0    //
    VARIABLE M8_DTCD2M8        2.63  // CB2.S.2
    VARIABLE M8_DTCD2DM8       1.5  // DMx.S.2
    VARIABLE M8_DTCD2TCDDMY_M8 150  // for idu measurement
    VARIABLE M8_DTCD2CTMDMY_9 0.112  // MIM.VIAz.S.5
    VARIABLE M8_DTCD2ICOVL     8
	M8_DTCDxChip        = CHIP NOT (SIZE CHIP BY -(M8_DTCD2Chip + grid))
    M8_DTCDxLOGO        = SIZE LOGO               BY (M8_DTCD2LOGO      + grid)
    M8_DTCDxMOMDMY      = SIZE MOMDMY             BY (M8_DTCD2MOMDMY    + grid)
    M8_DTCDxLOWMEDN     = SIZE LOWMEDN            BY (M8_DTCD2LOWMEDN   + grid)
    M8_DTCDxPOFUSE      = SIZE (FUSELINK AND POi) BY (M8_DTCD2POFUSE    + grid)
    M8_DTCDxDM8EXCL     = SIZE DM8EXCL            BY (M8_DTCD2DM8EXCL   + grid)
    M8_DTCDxDM8CB2      = SIZE CB2i               BY (M8_DTCD2DM8CB2    + grid)
    M8_DTCDxM8          = SIZE M8i                BY (M8_DTCD2M8        + grid)
    M8_DTCDxDM8         = SIZE DUM8               BY (M8_DTCD2DM8       + grid)
    M8_DTCDxTCDDMY_M8   = SIZE TCDDMY_M8          BY (M8_DTCD2TCDDMY_M8 + grid)
    M8_DTCDxTCDDMY_FM8  = SIZE TCDDMY_FM8         BY (M8_DTCD2TCDDMY_M8 + grid)
    M8_DTCDxTCDDMY_FDM8 = SIZE TCDDMY_FDM8        BY (M8_DTCD2TCDDMY_M8 + grid)
    M8_DTCDxICOVL       = SIZE ICOVL              BY (M8_DTCD2ICOVL     + grid)
    M8_DTCDxCTMDMY_9   = SIZE CTMDMY_9          BY (M8_DTCD2CTMDMY_9  + grid)

    M8_DTCDx = (((((((((((((M8_DTCDxChip OR M8_DTCDxLOGO) OR M8_DTCDxLOWMEDN) OR M8_DTCDxPOFUSE) OR M8_DTCDxDM8EXCL) OR M8_DTCDxM8) OR M8_DTCDxDM8) OR M8_DTCDxTCDDMY_M8) OR M8_DTCDxTCDDMY_FM8) OR M8_DTCDxTCDDMY_FDM8) OR FRAME8INDDMY) OR M8_DTCDxMOMDMY) OR M8_DTCDxDM8CB2) OR M8_DTCDxCTMDMY_9) OR M8_DTCDxICOVL
    M8_DTCDo = CHIP NOT M8_DTCDx

