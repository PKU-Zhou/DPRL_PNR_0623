    F402M8s = (SIZE F402M8 BY (SM8_401 + grid)) OR B40M8s
    R402M8pre = O40M8 NOT F402M8s
    R402M8 = WITH WIDTH R402M8pre >= WM8_401

    // 4th, small
    F4012M8 = RECTANGLES WM8_401 LM8_401 SM8_401 OFFSET OM8_401 INSIDE OF LAYER R402M8
    F4012M8s = (SIZE F4012M8 BY (SM8_401 + grid)) OR F402M8s
    R4012M8pre = R402M8pre NOT F4012M8s
    R4012M8 = WITH WIDTH R4012M8pre >= WM8_401

    // 5th, non-stagger small
    F401M8 = RECTANGLES WM8_401 LM8_401 SM8_401 INSIDE OF LAYER R4012M8 //MAINTAIN SPACING
    F401M8s = (SIZE F401M8 BY (SM8_401 + grid)) OR F4012M8s

    F40M8 = ((F402M8 OR F4012M8) OR F401M8) OR F403M8_SLOT
    O50M8pre = (((PUSH (D50M8 OR emptyM8)) NOT FRAME8) NOT F401M8s) AND CHIP


    O50M8preA = SIZE O50M8pre BY -DM8_503
    O50M8preB = O50M8preA WITH WIDTH >= WM8_503

    // 1st big
    F503M8 = RECTANGLES WM8_503 LM8_503 SM8_503 OFFSET OM8_503 INSIDE OF LAYER O50M8preB
    F503M8_SLOT = RECTANGLES WM8_503_SLOT LM8_503_SLOT SM8_503_SLOT INSIDE OF LAYER F503M8

    F503M8_EXP = SIZE F503M8_SLOT BY ( SM8_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M8preF1 = O50M8pre NOT (SIZE F503M8_EXP BY SM8_502)
    O50M8preF  = (SNAP (SIZE O50M8preF1 BY -grid) 5) AND O50M8preF1

    B50M8s = F401M8s OR (SIZE F503M8_EXP BY (SM8_502+grid))
    O50M8 = O50M8preF NOT B50M8s

    // 3rd, middle
    F502M8 = RECTANGLES WM8_502 LM8_502 SM8_502 OFFSET OM8_502 INSIDE OF LAYER O50M8
    F502M8s = (SIZE F502M8 BY (SM8_501 + grid)) OR B50M8s
    R502M8pre = O50M8 NOT F502M8s
    R502M8 = WITH WIDTH R502M8pre >= WM8_501

    // 4th, small
    F5012M8 = RECTANGLES WM8_501 LM8_501 SM8_501 OFFSET OM8_501 INSIDE OF LAYER R502M8
    F5012M8s = (SIZE F5012M8 BY (SM8_501 + grid)) OR F502M8s
    R5012M8pre = R502M8pre NOT F5012M8s
    R5012M8 = WITH WIDTH R5012M8pre >= WM8_501

    // 5th, non-stagger small
    F501M8 = RECTANGLES WM8_501 LM8_501 SM8_501 INSIDE OF LAYER R5012M8 //MAINTAIN SPACING
    F501M8s = (SIZE F501M8 BY (SM8_501 + grid)) OR F5012M8s

    F50M8 = ((F502M8 OR F5012M8) OR F501M8) OR F503M8_SLOT

    exceedM8 = DENSITY M8x F30M8 F40M8 F50M8 > maxD_M8 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M8.den_exceed

    removeM8R = ((PUSH (exceedM8 AND (D50M8 OR emptyM8))) NOT FRAME8) AND CHIP
    removeM8P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM8R

    F30M8x = F30M8 NOT INTERACT removeM8P
    F40M8x = F40M8 NOT INTERACT removeM8P
    F50M8x = F50M8 NOT INTERACT removeM8P
    FM8xA  = (F30M8x OR F40M8x) OR F50M8x
    FM8x   = FM8xA NOT INTERACT (EXT FM8xA < DM8_S_1 ABUT SINGULAR REGION)

    ALLM8x = M8x OR FM8x
    lackM8 = DENSITY ALLM8x CHIP < DM8_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M8.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM8x)/AREA(CHIP) ]

    WDM8EXC = DUM8 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM8EXC = (SIZE FM8x BY Odm2DM8) OR (SIZE (((F303M8_EXP OR F403M8_EXP) OR F503M8_EXP) OR WDM8EXC) BY 1.5)

    lackM8pRM = ((((PUSH lackM8) NOT RM8EXC) NOT FRAME8OPC) NOT exceedM8) AND CHIP
    lackM8pRM_1 = WITH WIDTH lackM8pRM >= SM8_OPC

    RM8p1 = RECTANGLES WM8_OPC LM8_OPC WSM8_OPC LSM8_OPC INSIDE OF LAYER lackM8pRM_1
    lackM8pRM_2 = lackM8pRM_1 NOT (SIZE RM8p1 BY SM8_OPC)
    RM8p2 = RECTANGLES LM8_OPC WM8_OPC LSM8_OPC WSM8_OPC INSIDE OF LAYER lackM8pRM_2

    ODM8A = ((RM8p1 OR RM8p2) OUTSIDE RM8EXC) OUTSIDE FRAME8OPC
    ODM8F_pre = ODM8A NOT INTERACT (EXT ODM8A < SM8_OPC ABUT SINGULAR REGION)

// M8.S.14 ~ M8.S.16
M8_S_14_CHK_REGION = M8i OR ODM8F_pre
// Find Wide Metal
Wide_M8_S_14_CHK_REGION = ENCLOSE RECTANGLE (M8_S_14_CHK_REGION NOT WITH WIDTH <= M8_S_14_W1B) M8_S_14_W1B+GRID M8_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M8_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M8_S_14_CHK_REGION == 0
Wide_M8_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M8_S_14_CHK_REGION == 90

// Find Wide Metal Space
M8_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M8_S_14_CHK_REGION_EDGE_H M8_S_14_CHK_REGION < M8_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M8_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M8_S_14_CHK_REGION_EDGE_V M8_S_14_CHK_REGION < M8_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M8_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M8_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M8_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M8_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M8_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M8_S_14_CHK_REGION_OPC_REGION_pre1_H M8_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M8_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M8_S_14_L1B
M8_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M8_S_14_CHK_REGION_OPC_REGION_pre1_V M8_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M8_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M8_S_14_L1B

M8_S_14_OPC_REGION = M8_S_14_CHK_REGION_OPC_REGION_pre2_H OR M8_S_14_CHK_REGION_OPC_REGION_pre2_V

// M8.S.17 ~ M8.S.19
M8_S_17_CHK_REGION = M8i OR ODM8F_pre
// Find Wide Metal
Wide_M8_S_17_CHK_REGION = ENCLOSE RECTANGLE (M8_S_17_CHK_REGION NOT WITH WIDTH <= M8_S_17_W1B) M8_S_17_W1B+GRID M8_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M8_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M8_S_17_CHK_REGION == 0
Wide_M8_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M8_S_17_CHK_REGION == 90

// Find Wide Metal Space
M8_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M8_S_17_CHK_REGION_EDGE_H M8_S_17_CHK_REGION < M8_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M8_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M8_S_17_CHK_REGION_EDGE_V M8_S_17_CHK_REGION < M8_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M8_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M8_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M8_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M8_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M8_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M8_S_17_CHK_REGION_OPC_REGION_pre1_H M8_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M8_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M8_S_17_L1B
M8_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M8_S_17_CHK_REGION_OPC_REGION_pre1_V M8_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M8_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M8_S_17_L1B

M8_S_17_OPC_REGION = M8_S_17_CHK_REGION_OPC_REGION_pre2_H OR M8_S_17_CHK_REGION_OPC_REGION_pre2_V

// M8.S.20 ~ M8.S.22
M8_S_20_CHK_REGION = M8i OR ODM8F_pre
// Find Wide Metal
Wide_M8_S_20_CHK_REGION = ENCLOSE RECTANGLE (M8_S_20_CHK_REGION NOT WITH WIDTH <= M8_S_20_W1B) M8_S_20_W1B+GRID M8_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M8_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M8_S_20_CHK_REGION == 0
Wide_M8_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M8_S_20_CHK_REGION == 90

// Find Wide Metal Space
M8_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M8_S_20_CHK_REGION_EDGE_H M8_S_20_CHK_REGION < M8_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M8_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M8_S_20_CHK_REGION_EDGE_V M8_S_20_CHK_REGION < M8_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M8_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M8_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M8_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M8_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M8_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M8_S_20_CHK_REGION_OPC_REGION_pre1_H M8_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M8_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M8_S_20_L1B
M8_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M8_S_20_CHK_REGION_OPC_REGION_pre1_V M8_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M8_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M8_S_20_L1B

M8_S_20_OPC_REGION = M8_S_20_CHK_REGION_OPC_REGION_pre2_H OR M8_S_20_CHK_REGION_OPC_REGION_pre2_V

// M8.S.23 ~ M8.S.25
M8_S_23_CHK_REGION = M8i OR ODM8F_pre
// Find Wide Metal
Wide_M8_S_23_CHK_REGION = ENCLOSE RECTANGLE (M8_S_23_CHK_REGION NOT WITH WIDTH <= M8_S_23_W1B) M8_S_23_W1B+GRID M8_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M8_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M8_S_23_CHK_REGION == 0
Wide_M8_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M8_S_23_CHK_REGION == 90

// Find Wide Metal Space
M8_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M8_S_23_CHK_REGION_EDGE_H M8_S_23_CHK_REGION < M8_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M8_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M8_S_23_CHK_REGION_EDGE_V M8_S_23_CHK_REGION < M8_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M8_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M8_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M8_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M8_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M8_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M8_S_23_CHK_REGION_OPC_REGION_pre1_H M8_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M8_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M8_S_23_L1B
M8_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M8_S_23_CHK_REGION_OPC_REGION_pre1_V M8_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M8_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M8_S_23_L1B

M8_S_23_OPC_REGION = M8_S_23_CHK_REGION_OPC_REGION_pre2_H OR M8_S_23_CHK_REGION_OPC_REGION_pre2_V

// M8.S.27
M8_S_27_CHK_REGION = M8i OR ODM8F_pre
// Find Wide Metal
Wide_M8_S_27_CHK_REGION = ENCLOSE RECTANGLE (M8_S_27_CHK_REGION NOT WITH WIDTH <= M8_S_27_W1B) M8_S_27_W1B+GRID M8_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M8_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M8_S_27_CHK_REGION == 0
Wide_M8_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M8_S_27_CHK_REGION == 90

// Find Wide Metal Space
M8_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M8_S_27_CHK_REGION_EDGE_H M8_S_27_CHK_REGION < M8_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M8_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M8_S_27_CHK_REGION_EDGE_V M8_S_27_CHK_REGION < M8_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M8_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M8_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M8_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M8_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M8_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M8_S_27_CHK_REGION_OPC_REGION_pre1_H M8_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M8_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M8_S_27_L1B
M8_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M8_S_27_CHK_REGION_OPC_REGION_pre1_V M8_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M8_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M8_S_27_L1B

M8_S_27_OPC_REGION = M8_S_27_CHK_REGION_OPC_REGION_pre2_H OR M8_S_27_CHK_REGION_OPC_REGION_pre2_V

M8_WMJ_OPC_REGION = (((M8_S_14_OPC_REGION OR M8_S_17_OPC_REGION) OR M8_S_20_OPC_REGION) OR M8_S_23_OPC_REGION) OR M8_S_27_OPC_REGION

    ODM8F = ODM8F_pre NOT INTERACT M8_WMJ_OPC_REGION

    DM8F = COPY FM8x

    FRAME8_INDDMYA = SIZE M8i BY (dm8_s2m8_INDDMY + grid)
    FRAME8_INDDMYB = SIZE DUM8 BY (dm8_s_INDDMY + grid)
    FRAME8_INDDMYC = SIZE DM8F BY dm8_s_INDDMY
    FRAME8_INDDMYD = SIZE ODM8F BY dm8_s2m8_INDDMY

    FRAME8_INDDMY  = ((((((FRAME8Pre OR xM8_DTCD) OR BLOCK8) OR FRAME8_INDDMYA) OR FRAME8_INDDMYB) OR FRAME8_INDDMYC) OR FRAME8_INDDMYD) OR NFILL_x
    FILL8_INDDMY   = ooINDDMY NOT FRAME8_INDDMY
    DM8F_INDDMY    = RECTANGLES dm8_w_INDDMY dm8_l_INDDMY dm8_s_INDDMY INSIDE OF LAYER FILL8_INDDMY

#IFDEF FILL_indDM8
    FILL8_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm8_s_INDDMY_HD + grid)) NOT FRAME8_INDDMY
    DM8F_INDDMY_HD_pre  = RECTANGLES dm8_w_INDDMY_HD dm8_l_INDDMY_HD dm8_s_INDDMY_HD INSIDE OF LAYER FILL8_INDDMY_HD

    FILL8_INDDMY_MD = (SIZE INDDMY_MD BY -(dm8_s_INDDMY_MD + grid)) NOT (FRAME8_INDDMY OR INDDMY_HD)
    DM8F_INDDMY_MD  = RECTANGLES dm8_w_INDDMY_MD dm8_l_INDDMY_MD dm8_s_INDDMY_MD INSIDE OF LAYER FILL8_INDDMY_MD

    DM8F_INDDMY_HD = DM8F_INDDMY_HD_pre OR DM8F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#IFDEF FILL_DM9


#IFDEF 34K_THICK_Mu_M9

    minOPENM9 = DENSITY M9x < minD_M9 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M9Min.den
    emptyOPENM9 = DENSITY M9x < emptyD_M9 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M9Empty.den

    M9InnerHole = HOLES M9i INNER

    M9BigHole = SIZE M9InnerHole BY - excludeHoleSize/2
    M9ExcHole = ((M9InnerHole OUTSIDE M9BigHole) NOT M9i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK9    = (SIZE DM9EXCL BY (dm2DMEXCL + grid)) OR MIM9_x
    FRAMEA9   = SIZE M9i BY (dm2M9 + grid) // DM9 to metal
    FRAMEB9   = SIZE (WITH WIDTH M9i > wideM9) BY (dm2WM9 + grid)
    FRAMEC9   = SIZE DUM9 BY (dm2DM9 + grid)
    FRAME9Pre = ((FRAMEA9 OR FRAMEB9) OR FRAMEC9) OR M9ExcHole
    FRAME9INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm9_s2m9_INDDMY + grid)
    FRAME9 = ((FRAME9Pre OR FRAME9INDDMY) OR BLOCK9) OR NFILL
    
    OPENM9 = PUSH ((minOPENM9 OR emptyOPENM9) AND CHIP)
    FILL9 = OPENM9 NOT FRAME9
    FILLW9pre = SIZE FILL9 BY - (Wdm2M9 + grid)
    FILLW9 = WITH WIDTH FILLW9pre >= WdmW_M9
    M9FW = RECTANGLES WdmW_M9 WdmL_M9 WdmS_M9 OFFSET WdmO_M9 INSIDE OF LAYER FILLW9
    M9FW_EXP = SIZE M9FW BY (WdmS_M9 /2 + grid) OVERUNDER   // merge the gaps
    FILLM9pre = FILL9 NOT (SIZE M9FW_EXP BY (MdmS_M9 + grid))
    FILLM9 = WITH WIDTH FILLM9pre >= MdmW_M9
    M9F1 = RECTANGLES MdmW_M9 MdmL_M9 MdmS_M9 OFFSET MdmO_M9 INSIDE OF LAYER FILLM9
    M9R1pre = FILLM9pre NOT (SIZE M9F1 BY (dmS_M9 + grid))
    M9R1 = WITH WIDTH M9R1pre >= dmW_M9

    M9F2 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 OFFSET dmO_M9 INSIDE OF LAYER M9R1
    M9R2pre = M9R1 NOT (SIZE M9F2 BY (dmS_M9 + grid))
    M9R2 = WITH WIDTH M9R2pre >= dmW_M9

    M9F3 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 OFFSET dmO_M9 INSIDE OF LAYER M9R2
    M9R3pre = M9R2 NOT (SIZE M9F3 BY (dmS_M9 + grid))
    M9R3 = WITH WIDTH M9R3pre >= dmW_M9

    M9F4 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 INSIDE OF LAYER M9R3

    M9F = (((M9F1 OR M9F2) OR M9F3) OR M9F4) OR M9FW
    FM9 = M9F NOT INTERACT (EXT M9F < dmS_M9 ABUT SINGULAR REGION)

    maxOPENM9 = DENSITY M9x FM9 > maxD_M9 WINDOW WindowSizeu*2 STEP WindowStepu*2
                INSIDE OF LAYER bulk BACKUP // PRINT M9Max.den

    DM9F = FM9 OUTSIDE maxOPENM9

    FRAME9_INDDMYA = SIZE M9i BY (dm9_s2m9_INDDMY + grid)
    FRAME9_INDDMYB = SIZE DUM9 BY (dm9_s_INDDMY + grid)
    FRAME9_INDDMYC = SIZE DM9F BY dm9_s_INDDMY
    FRAME9_INDDMY  = ((((FRAME9Pre OR BLOCK9) OR FRAME9_INDDMYA) OR FRAME9_INDDMYB) OR FRAME9_INDDMYC) OR NFILL
    FILL9_INDDMY   = ooINDDMY NOT FRAME9_INDDMY
    DM9F_INDDMY    = RECTANGLES dm9_w_INDDMY dm9_l_INDDMY dm9_s_INDDMY INSIDE OF LAYER FILL9_INDDMY
#IFDEF FILL_indDM9
    FILL9_INDDMY_HD = (SIZE INDDMY_HD BY -(dm9_s_INDDMY_HD + grid)) NOT FRAME9_INDDMY
    DM9F_INDDMY_HD  = RECTANGLES dm9_w_INDDMY_HD dm9_l_INDDMY_HD dm9_s_INDDMY_HD INSIDE OF LAYER FILL9_INDDMY_HD
#ENDIF	
	
#ELSE


#IFDEF 12K_THICK_Mr_M9

    minOPENM9 = DENSITY M9x < minD_M9 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M9Min.den
    emptyOPENM9 = DENSITY M9x < emptyD_M9 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M9Empty.den

    M9InnerHole = HOLES M9i INNER

    M9BigHole = SIZE M9InnerHole BY - excludeHoleSize/2
    M9ExcHole = ((M9InnerHole OUTSIDE M9BigHole) NOT M9i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK9  = (SIZE DM9EXCL BY (dm2DMEXCL + grid)) OR MIM9_x // DM9 to DM9EXCL
    FRAMEA9 = SIZE M9i BY (dm2M9 + grid) // DM9 to metal
    FRAMEB9 = SIZE (WITH WIDTH M9i > wideM9) BY (dm2WM9 + grid)
    FRAMEC9 = SIZE DUM9 BY (dm2DM9 + grid)   // DM9 to existed dummy metal 0.6um
    FRAME9Pre = ((FRAMEA9 OR FRAMEB9) OR FRAMEC9) OR M9ExcHole
    FRAME9INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm9_s2m9_INDDMY + grid)
    FRAME9 = ((FRAME9Pre OR FRAME9INDDMY) OR BLOCK9) OR NFILL
    
    OPENM9 = PUSH ((minOPENM9 OR emptyOPENM9) AND CHIP)
    FILL9 = OPENM9 NOT FRAME9
    FILLW9pre = SIZE FILL9 BY - (Wdm2M9 + grid)
    FILLW9 = WITH WIDTH FILLW9pre >= WdmW_M9
    M9FW = RECTANGLES WdmW_M9 WdmL_M9 WdmS_M9 OFFSET WdmO_M9 INSIDE OF LAYER FILLW9
    M9FW_EXP = SIZE M9FW BY (WdmS_M9 /2 + grid) OVERUNDER //merge the gaps
    FILLM9pre = FILL9 NOT (SIZE M9FW_EXP BY (MdmS_M9 + grid))
    FILLM9 = WITH WIDTH FILLM9pre >= MdmW_M9
    M9F1 = RECTANGLES MdmW_M9 MdmL_M9 MdmS_M9 OFFSET MdmO_M9 INSIDE OF LAYER FILLM9
    M9R1pre = FILLM9pre NOT (SIZE M9F1 BY (dmS_M9 + grid))
    M9R1 = WITH WIDTH M9R1pre >= dmW_M9

    M9F2 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 OFFSET dmO_M9 INSIDE OF LAYER M9R1
    M9R2pre = M9R1 NOT (SIZE M9F2 BY (dmS_M9 + grid))
    M9R2 = WITH WIDTH M9R2pre >= dmW_M9

    M9F3 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 OFFSET dmO_M9 INSIDE OF LAYER M9R2
    M9R3pre = M9R2 NOT (SIZE M9F3 BY (dmS_M9 + grid))
    M9R3 = WITH WIDTH M9R3pre >= dmW_M9

    M9F4 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 INSIDE OF LAYER M9R3

    M9F = (((M9F1 OR M9F2) OR M9F3) OR M9F4) OR M9FW
    FM9 = M9F NOT INTERACT (EXT M9F < dmS_M9 ABUT SINGULAR REGION)

    maxOPENM9 = DENSITY M9x FM9 > maxD_M9 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M9Max.den

    FM9F = FM9 OUTSIDE maxOPENM9

    // DMr_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M9 = DENSITY M9x FM9F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M9Min.den

    RM9EXC = SIZE FM9F BY (Odm2DM9 + grid)
    // do not fill DMy_S over CTMDMY
    D25M9pM = (((PUSH D25M9) NOT FRAME9) NOT RM9EXC) AND CHIP
    D25M9pM_1 = WITH WIDTH D25M9pM >= OdmW_M9

    RM9p1 = RECTANGLES OdmW_M9 OdmL_M9 OdmS_M9 INSIDE OF LAYER D25M9pM_1
    D25M9pM_2 = D25M9pM_1 NOT (SIZE RM9p1 BY (OdmS_M9 + grid))
    RM9p2 = RECTANGLES OdmL_M9 OdmW_M9 OdmS_M9 INSIDE OF LAYER D25M9pM_2

    RM9A = ((RM9p1 OR RM9p2) OUTSIDE RM9EXC) OUTSIDE FRAME9
    RM9  = RM9A NOT INTERACT (EXT RM9A < OdmS_M9 ABUT SINGULAR REGION)

    DM9F = FM9F OR RM9

    FRAME9_INDDMYA = SIZE M9i BY (dm9_s2m9_INDDMY + grid)
    FRAME9_INDDMYB = SIZE DUM9 BY (dm9_s_INDDMY + grid)
    FRAME9_INDDMYC = SIZE DM9F BY dm9_s_INDDMY
    FRAME9_INDDMY  = ((((FRAME9Pre OR BLOCK9) OR FRAME9_INDDMYA) OR FRAME9_INDDMYB) OR FRAME9_INDDMYC) OR NFILL
    FILL9_INDDMY   = ooINDDMY NOT FRAME9_INDDMY
    DM9F_INDDMY    = RECTANGLES dm9_w_INDDMY dm9_l_INDDMY dm9_s_INDDMY INSIDE OF LAYER FILL9_INDDMY

#IFDEF FILL_indDM9
    FILL9_INDDMY_HD = (SIZE INDDMY_HD BY -(dm9_s_INDDMY_HD + grid)) NOT FRAME9_INDDMY
    DM9F_INDDMY_HD  = RECTANGLES dm9_w_INDDMY_HD dm9_l_INDDMY_HD dm9_s_INDDMY_HD INSIDE OF LAYER FILL9_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 5K_THICK_Myz_M9

    minOPENM9 = DENSITY M9x < minD_M9 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M9Min.den
    emptyOPENM9 = DENSITY M9x < emptyD_M9 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M9Empty.den

    M9InnerHole = HOLES M9i INNER

    M9BigHole = SIZE M9InnerHole BY - excludeHoleSize/2
    M9ExcHole = ((M9InnerHole OUTSIDE M9BigHole) NOT M9i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK9 = (SIZE DM9EXCL BY (dm2DMEXCL + grid)) OR MIM9_x // DM9 to DM9EXCL
    FRAMEA9 = SIZE M9i BY (dm2M9 + grid) // DM9 to metal
    FRAMEB9 = SIZE (WITH WIDTH M9i > wideM9) BY (dm2WM9 + grid)
    FRAMEC9 = SIZE DUM9 BY (dm2DM9 + grid)   // DM9 to existed dummy metal 0.6um
    FRAME9Pre = ((FRAMEA9 OR FRAMEB9) OR FRAMEC9) OR M9ExcHole
    FRAME9INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm9_s2m9_INDDMY + grid)
    FRAME9 = ((FRAME9Pre OR FRAME9INDDMY) OR BLOCK9) OR NFILL
    
    OPENM9 = PUSH ((minOPENM9 OR emptyOPENM9) AND CHIP)
    FILL9 = OPENM9 NOT FRAME9
    FILLW9pre = SIZE FILL9 BY - (Wdm2M9 + grid)
    FILLW9 = WITH WIDTH FILLW9pre >= WdmW_M9
    M9FW = RECTANGLES WdmW_M9 WdmL_M9 WdmS_M9 OFFSET WdmO_M9 INSIDE OF LAYER FILLW9
    M9FW_EXP = SIZE M9FW BY (WdmS_M9 /2 + grid) OVERUNDER //merge the gaps
    FILLM9pre = FILL9 NOT (SIZE M9FW_EXP BY (MdmS_M9 + grid))
    FILLM9 = WITH WIDTH FILLM9pre >= MdmW_M9
    M9F1 = RECTANGLES MdmW_M9 MdmL_M9 MdmS_M9 OFFSET MdmO_M9 INSIDE OF LAYER FILLM9
    M9R1pre = FILLM9pre NOT (SIZE M9F1 BY (dmS_M9 + grid))
    M9R1 = WITH WIDTH M9R1pre >= dmW_M9

    M9F2 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 OFFSET dmO_M9 INSIDE OF LAYER M9R1
    M9R2pre = M9R1 NOT (SIZE M9F2 BY (dmS_M9 + grid))
    M9R2 = WITH WIDTH M9R2pre >= dmW_M9

    M9F3 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 OFFSET dmO_M9 INSIDE OF LAYER M9R2
    M9R3pre = M9R2 NOT (SIZE M9F3 BY (dmS_M9 + grid))
    M9R3 = WITH WIDTH M9R3pre >= dmW_M9

    M9F4 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 INSIDE OF LAYER M9R3

    M9F = (((M9F1 OR M9F2) OR M9F3) OR M9F4) OR M9FW
    FM9 = M9F NOT INTERACT (EXT M9F < dmS_M9 ABUT SINGULAR REGION)

    maxOPENM9 = DENSITY M9x FM9 > maxD_M9 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M9Max.den

    FM9F = FM9 OUTSIDE maxOPENM9

    // DMy_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M9 = DENSITY M9x FM9F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M9Min.den

    RM9EXC = SIZE FM9F BY (Odm2DM9 + grid)
    // do not fill DMy_S over CTMDMY
    D25M9pM = (((PUSH D25M9) NOT FRAME9) NOT RM9EXC) AND CHIP
    D25M9pM_1 = WITH WIDTH D25M9pM >= OdmW_M9

    RM9p1 = RECTANGLES OdmW_M9 OdmL_M9 OdmS_M9 INSIDE OF LAYER D25M9pM_1
    D25M9pM_2 = D25M9pM_1 NOT (SIZE RM9p1 BY (OdmS_M9 + grid))
    RM9p2 = RECTANGLES OdmL_M9 OdmW_M9 OdmS_M9 INSIDE OF LAYER D25M9pM_2

    RM9A = ((RM9p1 OR RM9p2) OUTSIDE RM9EXC) OUTSIDE FRAME9
    RM9  = RM9A NOT INTERACT (EXT RM9A < OdmS_M9 ABUT SINGULAR REGION)

    DM9F = FM9F OR RM9

    FRAME9_INDDMYA = SIZE M9i BY (dm9_s2m9_INDDMY + grid)
    FRAME9_INDDMYB = SIZE DUM9 BY (dm9_s_INDDMY + grid)
    FRAME9_INDDMYC = SIZE DM9F BY dm9_s_INDDMY
    FRAME9_INDDMY  = ((((FRAME9Pre OR BLOCK9) OR FRAME9_INDDMYA) OR FRAME9_INDDMYB) OR FRAME9_INDDMYC) OR NFILL
    FILL9_INDDMY   = ooINDDMY NOT FRAME9_INDDMY
    DM9F_INDDMY    = RECTANGLES dm9_w_INDDMY dm9_l_INDDMY dm9_s_INDDMY INSIDE OF LAYER FILL9_INDDMY


#IFDEF FILL_indDM9
    FILL9_INDDMY_HD = (SIZE INDDMY_HD BY -(dm9_s_INDDMY_HD + grid)) NOT FRAME9_INDDMY
    DM9F_INDDMY_HD  = RECTANGLES dm9_w_INDDMY_HD dm9_l_INDDMY_HD dm9_s_INDDMY_HD INSIDE OF LAYER FILL9_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2_6K_THICK_Mxy_M9

    minOPENM9 = DENSITY M9x < minD_M9 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M9Min.den
    emptyOPENM9 = DENSITY M9x < emptyD_M9 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M9Empty.den

    M9InnerHole = HOLES M9i INNER

    M9BigHole = SIZE M9InnerHole BY - excludeHoleSize/2
    M9ExcHole = ((M9InnerHole OUTSIDE M9BigHole) NOT M9i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK9 = (SIZE DM9EXCL BY (dm2DMEXCL + grid)) OR  MIM9_x // DM9 to DM9EXCL
    FRAMEA9 = SIZE M9i BY (dm2M9 + grid) // DM9 to metal
    FRAMEB9 = SIZE (WITH WIDTH M9i > wideM9) BY (dm2WM9 + grid)
    FRAMEC9 = SIZE DUM9 BY (dm2DM9 + grid)   // DM9 to existed dummy metal 0.6um
    FRAME9Pre = ((FRAMEA9 OR FRAMEB9) OR FRAMEC9) OR M9ExcHole
    FRAME9INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm9_s2m9_INDDMY + grid)
    FRAME9 = ((FRAME9Pre OR FRAME9INDDMY) OR BLOCK9) OR NFILL
    
    OPENM9 = PUSH ((minOPENM9 OR emptyOPENM9) AND CHIP)
    FILL9 = OPENM9 NOT FRAME9
    FILLW9pre = SIZE FILL9 BY - (Wdm2M9 + grid)
    FILLW9 = WITH WIDTH FILLW9pre >= WdmW_M9
    M9FW = RECTANGLES WdmW_M9 WdmL_M9 WdmS_M9 OFFSET WdmO_M9 INSIDE OF LAYER FILLW9
    M9FW_EXP = SIZE M9FW BY (WdmS_M9 /2 + grid) OVERUNDER //merge the gaps
    FILLM9pre = FILL9 NOT (SIZE M9FW_EXP BY (MdmS_M9 + grid))
    FILLM9 = WITH WIDTH FILLM9pre >= MdmW_M9
    M9F1 = RECTANGLES MdmW_M9 MdmL_M9 MdmS_M9 OFFSET MdmO_M9 INSIDE OF LAYER FILLM9
    M9R1pre = FILLM9pre NOT (SIZE M9F1 BY (dmS_M9 + grid))
    M9R1 = WITH WIDTH M9R1pre >= dmW_M9

    M9F2 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 OFFSET dmO_M9 INSIDE OF LAYER M9R1
    M9R2pre = M9R1 NOT (SIZE M9F2 BY (dmS_M9 + grid))
    M9R2 = WITH WIDTH M9R2pre >= dmW_M9

    M9F3 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 OFFSET dmO_M9 INSIDE OF LAYER M9R2
    M9R3pre = M9R2 NOT (SIZE M9F3 BY (dmS_M9 + grid))
    M9R3 = WITH WIDTH M9R3pre >= dmW_M9

    M9F4 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 INSIDE OF LAYER M9R3

    M9F = (((M9F1 OR M9F2) OR M9F3) OR M9F4) OR M9FW
    FM9 = M9F NOT INTERACT (EXT M9F < dmS_M9 ABUT SINGULAR REGION)

    maxOPENM9 = DENSITY M9x FM9 > maxD_M9 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M9Max.den

    FM9F = FM9 OUTSIDE maxOPENM9

    D25M9 = DENSITY M9x FM9F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M9Min.den

    RM9EXC = SIZE FM9F BY (Odm2DM9 + grid)
    D25M9pM = (((PUSH D25M9) NOT FRAME9) NOT RM9EXC) AND CHIP
    D25M9pM_1 = WITH WIDTH D25M9pM >= OdmW_M9

    RM9p1 = RECTANGLES OdmW_M9 OdmL_M9 OdmS_M9 INSIDE OF LAYER D25M9pM_1
    D25M9pM_2 = D25M9pM_1 NOT (SIZE RM9p1 BY (OdmS_M9 + grid))
    RM9p2 = RECTANGLES OdmL_M9 OdmW_M9 OdmS_M9 INSIDE OF LAYER D25M9pM_2

    RM9A = ((RM9p1 OR RM9p2) OUTSIDE RM9EXC) OUTSIDE FRAME9
    RM9  = RM9A NOT INTERACT (EXT RM9A < OdmS_M9 ABUT SINGULAR REGION)

    DM9F = FM9F OR RM9

    FRAME9_INDDMYA = SIZE M9i BY (dm9_s2m9_INDDMY + grid)
    FRAME9_INDDMYB = SIZE DUM9 BY (dm9_s_INDDMY + grid)
    FRAME9_INDDMYC = SIZE DM9F BY dm9_s_INDDMY
    FRAME9_INDDMY  = ((((FRAME9Pre OR BLOCK9) OR FRAME9_INDDMYA) OR FRAME9_INDDMYB) OR FRAME9_INDDMYC) OR NFILL
    FILL9_INDDMY   = ooINDDMY NOT FRAME9_INDDMY
    DM9F_INDDMY    = RECTANGLES dm9_w_INDDMY dm9_l_INDDMY dm9_s_INDDMY INSIDE OF LAYER FILL9_INDDMY

#IFDEF FILL_indDM9
    FILL9_INDDMY_HD = (SIZE INDDMY_HD BY -(dm9_s_INDDMY_HD + grid)) NOT FRAME9_INDDMY
    DM9F_INDDMY_HD  = RECTANGLES dm9_w_INDDMY_HD dm9_l_INDDMY_HD dm9_s_INDDMY_HD INSIDE OF LAYER FILL9_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M9

    D30M9 = DENSITY M9x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M9.den30
    D40M9 = DENSITY M9x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M9.den40
    D50M9 = DENSITY M9x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M9.den50
    emptyM9 = DENSITY M9x < emptyD_M9 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M9.den_empty

    M9InnerHole = HOLES M9i INNER

    M9BigHole = SIZE M9InnerHole BY - excludeHoleSize/2
    M9ExcHole = ((M9InnerHole OUTSIDE M9BigHole) NOT M9i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK9 = (SIZE DM9EXCL BY (dm2DMEXCL + grid)) OR MIM9_x

    FRAMEA9 = (SIZE M9i BY (DM9_301 + grid)) OR (SIZE (EXPAND EDGE (M9i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA9OPC = SIZE M9i BY (DM9_OPC + grid)
    FRAMEA9OPCDV33 = SIZE (M9i INTERACT M9_HVN_330Vx) BY (M9_S_1_1_a + grid)
    FRAMEA9OPCDV5 = SIZE (M9i INTERACT M9_HVN_500Vx) BY (M9_S_9_a + grid)
    FRAMEA9OPC45 = SIZE (EXPAND EDGE (M9i ANGLE == 45) OUTSIDE BY DM9_OPC_45 EXTEND BY DM9_OPC_45_E) BY grid
    FRAMEA9OPC45DV = SIZE (EXPAND EDGE ((M9i INTERACT M9_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM9_OPC_45 EXTEND BY DM9_OPC_45_E) BY grid

    FRAMEB9 = SIZE (WITH WIDTH M9i > wideM9) BY (dm2WM9 + grid)
    FRAMEC9 = SIZE DUM9 BY (dm2DM9 + grid)
    FRAMED9 = SIZE (WITH WIDTH M9i > wideM9_small) BY (dm2WM9_small + grid)
    FRAMEC9OPC = SIZE DUM9 BY (Odm2DM9 + grid)
    FRAME9Pre = ((FRAMEA9 OR FRAMEB9) OR (FRAMEC9 OR FRAMED9)) OR M9ExcHole
    FRAME9PreOPC = (((((((FRAMEA9OPC OR FRAMEA9OPCDV33) OR FRAMEA9OPCDV5) OR FRAMEC9OPC) OR M9ExcHole) OR FRAMEA9OPC45) OR FRAMEA9OPC45DV) OR FRAMEB9) OR FRAMED9
    FRAME9INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm9_s2m9_INDDMY + grid)

    FRAME9OPC = ((FRAME9PreOPC OR FRAME9INDDMY) OR BLOCK9) OR NFILLOPC

    FRAME9 = ((FRAME9Pre OR FRAME9INDDMY) OR BLOCK9) OR NFILL

    //****************************************************************************

    D30M9p = (PUSH D30M9) NOT FRAME9
    O30M9pre = D30M9p AND CHIP
    FD21M9s = COPY FRAME9

    O30M9preA = SIZE O30M9pre BY -DM9_303
    O30M9preB = O30M9preA WITH WIDTH >= WM9_303

    // 1st big
    F303M9 = RECTANGLES WM9_303 LM9_303 SM9_303 OFFSET OM9_303 INSIDE OF LAYER O30M9preB

    F303M9_EXP = SIZE F303M9 BY ( SM9_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M9preF1 = O30M9pre NOT (SIZE F303M9_EXP BY SM9_302)
    O30M9preF  = (SNAP (SIZE O30M9preF1 BY -grid) 5) AND O30M9preF1

    B30M9s = FD21M9s OR (SIZE F303M9_EXP BY (SM9_302+grid))
    O30M9 = O30M9preF NOT B30M9s

    // 3rd, middle
    F302M9 = RECTANGLES WM9_302 LM9_302 SM9_302 OFFSET OM9_302 INSIDE OF LAYER O30M9
    F302M9s = (SIZE F302M9 BY (SM9_301 + grid)) OR B30M9s
    R302M9pre = O30M9 NOT F302M9s
    R302M9 = WITH WIDTH R302M9pre >= WM9_301

    // 4th, small
    F3012M9 = RECTANGLES WM9_301 LM9_301 SM9_301 OFFSET OM9_301 INSIDE OF LAYER R302M9
    F3012M9s = (SIZE F3012M9 BY (SM9_301 + grid)) OR F302M9s
    R3012M9pre = R302M9pre NOT F3012M9s
    R3012M9 = WITH WIDTH R3012M9pre >= WM9_301

    // 5th, non-stagger small
    F301M9 = RECTANGLES WM9_301 LM9_301 SM9_301 INSIDE OF LAYER R3012M9 //MAINTAIN SPACING
    F301M9s = (SIZE F301M9 BY (SM9_301 + grid)) OR F3012M9s

    F30M9 = ((F302M9 OR F3012M9) OR F301M9) OR F303M9
    O40M9pre = (((PUSH D40M9) NOT FRAME9) NOT F301M9s) AND CHIP


    O40M9preA = SIZE O40M9pre BY -DM9_403
    O40M9preB = O40M9preA WITH WIDTH >= WM9_403

    // 1st big
    F403M9 = RECTANGLES WM9_403 LM9_403 SM9_403 OFFSET OM9_403 INSIDE OF LAYER O40M9preB

    F403M9_EXP = SIZE F403M9 BY ( SM9_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M9preF1 = O40M9pre NOT (SIZE F403M9_EXP BY SM9_402)
    O40M9preF  = (SNAP (SIZE O40M9preF1 BY -grid) 5) AND O40M9preF1

    B40M9s = F301M9s OR (SIZE F403M9_EXP BY (SM9_402+grid))
    O40M9 = O40M9preF NOT B40M9s

    // 3rd, middle
    F402M9 = RECTANGLES WM9_402 LM9_402 SM9_402 OFFSET OM9_402 INSIDE OF LAYER O40M9
    F402M9s = (SIZE F402M9 BY (SM9_401 + grid)) OR B40M9s
    R402M9pre = O40M9 NOT F402M9s
    R402M9 = WITH WIDTH R402M9pre >= WM9_401

    // 4th, small
    F4012M9 = RECTANGLES WM9_401 LM9_401 SM9_401 OFFSET OM9_401 INSIDE OF LAYER R402M9
    F4012M9s = (SIZE F4012M9 BY (SM9_401 + grid)) OR F402M9s
    R4012M9pre = R402M9pre NOT F4012M9s
    R4012M9 = WITH WIDTH R4012M9pre >= WM9_401

    // 5th, non-stagger small
    F401M9 = RECTANGLES WM9_401 LM9_401 SM9_401 INSIDE OF LAYER R4012M9 //MAINTAIN SPACING
    F401M9s = (SIZE F401M9 BY (SM9_401 + grid)) OR F4012M9s

    F40M9 = ((F402M9 OR F4012M9) OR F401M9) OR F403M9
    O50M9pre = (((PUSH (D50M9 OR emptyM9)) NOT FRAME9) NOT F401M9s) AND CHIP


    O50M9preA = SIZE O50M9pre BY -DM9_503
    O50M9preB = O50M9preA WITH WIDTH >= WM9_503

    // 1st big
    F503M9 = RECTANGLES WM9_503 LM9_503 SM9_503 OFFSET OM9_503 INSIDE OF LAYER O50M9preB

    F503M9_EXP = SIZE F503M9 BY ( SM9_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M9preF1 = O50M9pre NOT (SIZE F503M9_EXP BY SM9_502)
    O50M9preF  = (SNAP (SIZE O50M9preF1 BY -grid) 5) AND O50M9preF1

    B50M9s = F401M9s OR (SIZE F503M9_EXP BY (SM9_502+grid))
    O50M9 = O50M9preF NOT B50M9s

    // 3rd, middle
    F502M9 = RECTANGLES WM9_502 LM9_502 SM9_502 OFFSET OM9_502 INSIDE OF LAYER O50M9
    F502M9s = (SIZE F502M9 BY (SM9_501 + grid)) OR B50M9s
    R502M9pre = O50M9 NOT F502M9s
    R502M9 = WITH WIDTH R502M9pre >= WM9_501

    // 4th, small
    F5012M9 = RECTANGLES WM9_501 LM9_501 SM9_501 OFFSET OM9_501 INSIDE OF LAYER R502M9
    F5012M9s = (SIZE F5012M9 BY (SM9_501 + grid)) OR F502M9s
    R5012M9pre = R502M9pre NOT F5012M9s
    R5012M9 = WITH WIDTH R5012M9pre >= WM9_501

    // 5th, non-stagger small
    F501M9 = RECTANGLES WM9_501 LM9_501 SM9_501 INSIDE OF LAYER R5012M9 //MAINTAIN SPACING
    F501M9s = (SIZE F501M9 BY (SM9_501 + grid)) OR F5012M9s

    F50M9 = ((F502M9 OR F5012M9) OR F501M9) OR F503M9

//****************************************************************************

    exceedM9 = DENSITY M9x F30M9 F40M9 F50M9 > maxD_M9 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M9.den_exceed

    removeM9R = ((PUSH (exceedM9 AND (D50M9 OR emptyM9))) NOT FRAME9) AND CHIP
    removeM9P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM9R

    F30M9x = F30M9 NOT INTERACT removeM9P
    F40M9x = F40M9 NOT INTERACT removeM9P
    F50M9x = F50M9 NOT INTERACT removeM9P
    FM9xA  = (F30M9x OR F40M9x) OR F50M9x
    FM9x   = FM9xA NOT INTERACT (EXT FM9xA < DM9_S_1 ABUT SINGULAR REGION)

    ALLM9x = M9x OR FM9x
    lackM9 = DENSITY ALLM9x CHIP < DM9_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M9.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM9x)/AREA(CHIP) ]

    WDM9EXC = DUM9 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM9EXC = (SIZE FM9x BY Odm2DM9) OR (SIZE (((F303M9_EXP OR F403M9_EXP) OR F503M9_EXP) OR WDM9EXC) BY 1.5)

    lackM9pRM = ((((PUSH lackM9) NOT RM9EXC) NOT FRAME9OPC) NOT exceedM9) AND CHIP
    lackM9pRM_1 = WITH WIDTH lackM9pRM >= SM9_OPC

    RM9p1 = RECTANGLES WM9_OPC LM9_OPC WSM9_OPC LSM9_OPC INSIDE OF LAYER lackM9pRM_1
    lackM9pRM_2 = lackM9pRM_1 NOT (SIZE RM9p1 BY SM9_OPC)
    RM9p2 = RECTANGLES LM9_OPC WM9_OPC LSM9_OPC WSM9_OPC INSIDE OF LAYER lackM9pRM_2

    ODM9A = ((RM9p1 OR RM9p2) OUTSIDE RM9EXC) OUTSIDE FRAME9OPC
    ODM9F = ODM9A NOT INTERACT (EXT ODM9A < SM9_OPC ABUT SINGULAR REGION)

    DM9F = COPY FM9x

    FRAME9_INDDMYA = SIZE M9i BY (dm9_s2m9_INDDMY + grid)
    FRAME9_INDDMYB = SIZE DUM9 BY (dm9_s_INDDMY + grid)
    FRAME9_INDDMYC = SIZE DM9F BY dm9_s_INDDMY
    FRAME9_INDDMYD = SIZE ODM9F BY dm9_s2m9_INDDMY
    FRAME9_INDDMY  = (((((FRAME9Pre OR BLOCK9) OR FRAME9_INDDMYA) OR FRAME9_INDDMYB) OR FRAME9_INDDMYC) OR FRAME9_INDDMYD) OR NFILL
    FILL9_INDDMY   = ooINDDMY NOT FRAME9_INDDMY
    DM9F_INDDMY    = RECTANGLES dm9_w_INDDMY dm9_l_INDDMY dm9_s_INDDMY INSIDE OF LAYER FILL9_INDDMY


#IFDEF FILL_indDM9
    FILL9_INDDMY_HD = (SIZE INDDMY_HD BY -(dm9_s_INDDMY_HD + grid)) NOT FRAME9_INDDMY
    DM9F_INDDMY_HD  = RECTANGLES dm9_w_INDDMY_HD dm9_l_INDDMY_HD dm9_s_INDDMY_HD INSIDE OF LAYER FILL9_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M9

    minOPENM9 = DENSITY M9x < minD_M9 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M9Min.den
    emptyOPENM9 = DENSITY M9x < emptyD_M9 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M9Empty.den

    M9InnerHole = HOLES M9i INNER

    M9BigHole = SIZE M9InnerHole BY - excludeHoleSize/2
    M9ExcHole = ((M9InnerHole OUTSIDE M9BigHole) NOT M9i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK9 = (SIZE DM9EXCL BY (dm2DMEXCL + grid)) OR MIM9_x // DM9 to DM9EXCL
    FRAMEA9 = SIZE M9i BY (dm2M9 + grid) // DM9 to metal
    FRAMEB9 = SIZE (WITH WIDTH M9i > wideM9) BY (dm2WM9 + grid)
    FRAMEC9 = SIZE DUM9 BY (dm2DM9 + grid)   // DM9 to existed dummy metal 0.6um
    FRAME9Pre = ((FRAMEA9 OR FRAMEB9) OR FRAMEC9) OR M9ExcHole
    FRAME9INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm9_s2m9_INDDMY + grid)
    FRAME9 = ((FRAME9Pre OR FRAME9INDDMY) OR BLOCK9) OR NFILL
    
    OPENM9 = PUSH ((minOPENM9 OR emptyOPENM9) AND CHIP)
    FILL9 = OPENM9 NOT FRAME9
    FILLW9pre = SIZE FILL9 BY - (Wdm2M9 + grid)
    FILLW9 = WITH WIDTH FILLW9pre >= WdmW_M9
    M9FW = RECTANGLES WdmW_M9 WdmL_M9 WdmS_M9 OFFSET WdmO_M9 INSIDE OF LAYER FILLW9
    M9FW_EXP = SIZE M9FW BY (WdmS_M9 /2 + grid) OVERUNDER //merge the gaps
    FILLM9pre = FILL9 NOT (SIZE M9FW_EXP BY (MdmS_M9 + grid))
    FILLM9 = WITH WIDTH FILLM9pre >= MdmW_M9
    M9F1 = RECTANGLES MdmW_M9 MdmL_M9 MdmS_M9 OFFSET MdmO_M9 INSIDE OF LAYER FILLM9
    M9R1pre = FILLM9pre NOT (SIZE M9F1 BY (dmS_M9 + grid))
    M9R1 = WITH WIDTH M9R1pre >= dmW_M9

    M9F2 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 OFFSET dmO_M9 INSIDE OF LAYER M9R1
    M9R2pre = M9R1 NOT (SIZE M9F2 BY (dmS_M9 + grid))
    M9R2 = WITH WIDTH M9R2pre >= dmW_M9

    M9F3 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 OFFSET dmO_M9 INSIDE OF LAYER M9R2
    M9R3pre = M9R2 NOT (SIZE M9F3 BY (dmS_M9 + grid))
    M9R3 = WITH WIDTH M9R3pre >= dmW_M9

    M9F4 = RECTANGLES dmW_M9 dmL_M9 dmS_M9 INSIDE OF LAYER M9R3

    M9F = (((M9F1 OR M9F2) OR M9F3) OR M9F4) OR M9FW
    FM9 = M9F NOT INTERACT (EXT M9F < dmS_M9 ABUT SINGULAR REGION)

    maxOPENM9 = DENSITY M9x FM9 > maxD_M9 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M9Max.den

    FM9F = FM9 OUTSIDE maxOPENM9

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M9 = DENSITY M9x FM9F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M9Min.den

    RM9EXC = SIZE FM9F BY (Odm2DM9 + grid)
    // do not fill DMz_S over CTMDMY
    D25M9pM = (((PUSH D25M9) NOT FRAME9) NOT RM9EXC) AND CHIP
    D25M9pM_1 = WITH WIDTH D25M9pM >= OdmW_M9

    RM9p1 = RECTANGLES OdmW_M9 OdmL_M9 OdmS_M9 INSIDE OF LAYER D25M9pM_1
    D25M9pM_2 = D25M9pM_1 NOT (SIZE RM9p1 BY (OdmS_M9 + grid))
    RM9p2 = RECTANGLES OdmL_M9 OdmW_M9 OdmS_M9 INSIDE OF LAYER D25M9pM_2

    RM9A = ((RM9p1 OR RM9p2) OUTSIDE RM9EXC) OUTSIDE FRAME9
    RM9  = RM9A NOT INTERACT (EXT RM9A < OdmS_M9 ABUT SINGULAR REGION)

    DM9F = FM9F OR RM9

    FRAME9_INDDMYA = SIZE M9i BY (dm9_s2m9_INDDMY + grid)
    FRAME9_INDDMYB = SIZE DUM9 BY (dm9_s_INDDMY + grid)
    FRAME9_INDDMYC = SIZE DM9F BY dm9_s_INDDMY
    FRAME9_INDDMY  = ((((FRAME9Pre OR BLOCK9) OR FRAME9_INDDMYA) OR FRAME9_INDDMYB) OR FRAME9_INDDMYC) OR NFILL
    FILL9_INDDMY   = ooINDDMY NOT FRAME9_INDDMY
    DM9F_INDDMY    = RECTANGLES dm9_w_INDDMY dm9_l_INDDMY dm9_s_INDDMY INSIDE OF LAYER FILL9_INDDMY

#IFDEF FILL_indDM9
    FILL9_INDDMY_HD = (SIZE INDDMY_HD BY -(dm9_s_INDDMY_HD + grid)) NOT FRAME9_INDDMY
    DM9F_INDDMY_HD  = RECTANGLES dm9_w_INDDMY_HD dm9_l_INDDMY_HD dm9_s_INDDMY_HD INSIDE OF LAYER FILL9_INDDMY_HD
#ENDIF	

#ELSE



    D30M9 = DENSITY M9x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M9.den30
    D40M9 = DENSITY M9x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M9.den40
    D50M9 = DENSITY M9x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M9.den50
    emptyM9 = DENSITY M9x < emptyD_M9 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M9.den_empty

    M9InnerHole = HOLES M9i INNER
    xM9_DTCD = COPY EMPTY

    M9BigHole = SIZE M9InnerHole BY - excludeHoleSize/2
    M9ExcHole = ((M9InnerHole OUTSIDE M9BigHole) NOT M9i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK9 = (SIZE DM9EXCL BY (dm2DMEXCL + grid)) OR MIM9_x

    FRAMEA9 = (SIZE M9i BY (DM9_301 + grid)) OR (SIZE (EXPAND EDGE (M9i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA9OPC = SIZE M9i BY (DM9_OPC + grid)
    FRAMEA9OPCwide = SIZE (M9i WITH WIDTH > DM9_OPC_wide_w) BY (DM9_OPC_wide + grid)
    FRAMEA9OPC45 = SIZE (EXPAND EDGE (M9i ANGLE == 45) OUTSIDE BY DM9_OPC_45 EXTEND BY DM9_OPC_45_E) BY grid
    FRAMEA9OPC45DV = SIZE (EXPAND EDGE ((M9i INTERACT M9_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM9_OPC_45 EXTEND BY DM9_OPC_45_E) BY grid
    FRAMEA9OPC_M9_S_14_wide = SIZE (M9i WITH WIDTH > M9_S_14_wide_w) BY (M9_S_14_wide + grid)
    FRAMEA9OPC_M9_S_17_wide = SIZE (M9i WITH WIDTH > M9_S_17_wide_w) BY (M9_S_17_wide + grid)
    FRAMEA9OPC_M9_S_20_wide = SIZE (M9i WITH WIDTH > M9_S_20_wide_w) BY (M9_S_20_wide + grid)
    FRAMEA9OPC_M9_S_23_wide = SIZE (M9i WITH WIDTH > M9_S_23_wide_w) BY (M9_S_23_wide + grid)
    FRAMEA9OPC_M9_S_33_VIA8   = SIZE VIA8_HV_5V_CHK	BY (M9_S_33 + grid)
    FRAMEA9OPC_M9_S_33b_VIA8DV   = SIZE (VIA8i INTERACT (M8_HVN_330Vx OR M9_HVN_330Vx))	BY (M9_S_33b + grid)
    FRAMEA9OPC_M9_S_33_VIA9    = SIZE VIA9_HV_5V_CHK	BY (M9_S_33 + grid)
    FRAMEA9OPC_M9_S_33b_VIA9DV    = SIZE (VIA9i INTERACT (M9_HVN_330Vx OR M10_HVN_330Vx))	BY (M9_S_33b + grid)
    FRAMEA9OPC_M9_S_37_VIA8_b = SIZE VIA8i_55V		BY (M9_S_37 + grid)
    FRAMEA9OPC_M9_S_37a_VIA8_bDV = SIZE (VIA8i INTERACT (M8_HVN_500Vx OR M9_HVN_500Vx))		BY (M9_S_37a + grid)
    FRAMEA9OPC_M9_S_37_VIA9_b  = SIZE VIA9i_55V			BY (M9_S_37 + grid)
    FRAMEA9OPC_M9_S_37a_VIA9_bDV  = SIZE (VIA9i INTERACT (M9_HVN_500Vx OR M10_HVN_500Vx))		BY (M9_S_37a + grid)
    FRAMEA9OPC_M9_S_37_VIA8   = SIZE VIA8i_65V		BY (M9_S_37 + grid)
	FRAMEA9OPC_M9_S_37_VIA9    = SIZE VIA9i_65V			BY (M9_S_37 + grid)

    FRAMEHVD9 = SIZE  M9i_65V  BY (M9_S_38 + grid)
    FRAMEHVD9_55V = SIZE  M9i_55V  BY (M9_S_38 + grid)
    FRAMEHVD9_55VDV = SIZE  (M9i INTERACT M9_HVN_500Vx)  BY (M9_S_38a + grid)
    FRAMEB9 = SIZE (WITH WIDTH M9i > wideM9) BY (dm2WM9 + grid)
    FRAMEC9 = SIZE DUM9 BY (dm2DM9 + grid)
    FRAMED9 = SIZE (WITH WIDTH M9i > wideM9_small) BY (dm2WM9_small + grid)
    FRAMEC9OPC = SIZE DUM9 BY (Odm2DM9 + grid)
    FRAME9Pre = ((FRAMEA9 OR FRAMEB9) OR (FRAMEC9 OR FRAMED9)) OR M9ExcHole
    FRAME9PreOPC = (((((((((((((((((((((FRAMEA9OPC OR FRAMEC9OPC) OR M9ExcHole) OR FRAMEA9OPCwide) OR FRAMEA9OPC45) OR FRAMEA9OPC45DV) OR FRAMEA9OPC_M9_S_14_wide) OR FRAMEA9OPC_M9_S_17_wide) OR FRAMEA9OPC_M9_S_20_wide) OR FRAMEA9OPC_M9_S_23_wide) OR FRAMEA9OPC_M9_S_33_VIA8) OR FRAMEA9OPC_M9_S_33b_VIA8DV) OR FRAMEA9OPC_M9_S_33_VIA9) OR FRAMEA9OPC_M9_S_33b_VIA9DV) OR FRAMEHVD9) OR FRAMEA9OPC_M9_S_37_VIA8) OR FRAMEA9OPC_M9_S_37_VIA8_b) OR FRAMEA9OPC_M9_S_37a_VIA8_bDV) OR FRAMEA9OPC_M9_S_37_VIA9) OR FRAMEA9OPC_M9_S_37_VIA9_b) OR FRAMEA9OPC_M9_S_37a_VIA9_bDV) OR FRAMEHVD9_55V) OR FRAMEHVD9_55VDV


    FRAME9INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm9_s2m9_INDDMY + grid)
    FRAME9OPC = (((FRAME9PreOPC OR FRAME9INDDMY) OR xM9_DTCD) OR BLOCK9) OR NFILLOPC_x

    FRAME9 = (((FRAME9Pre OR FRAME9INDDMY) OR xM9_DTCD) OR BLOCK9) OR NFILL_x

    D30M9p = (PUSH D30M9) NOT FRAME9
    O30M9pre = D30M9p AND CHIP
    FD21M9s = COPY FRAME9

    O30M9preA = SIZE O30M9pre BY -DM9_303
    O30M9preB = O30M9preA WITH WIDTH >= WM9_303

    // 1st big
    F303M9 = RECTANGLES WM9_303 LM9_303 SM9_303 OFFSET OM9_303 INSIDE OF LAYER O30M9preB
    F303M9_SLOT = RECTANGLES WM9_303_SLOT LM9_303_SLOT SM9_303_SLOT INSIDE OF LAYER F303M9

    F303M9_EXP = SIZE F303M9_SLOT BY ( SM9_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M9preF1 = O30M9pre NOT (SIZE F303M9_EXP BY SM9_302)
    O30M9preF  = (SNAP (SIZE O30M9preF1 BY -grid) 5) AND O30M9preF1

    B30M9s = FD21M9s OR (SIZE F303M9_EXP BY (SM9_302+grid))
    O30M9 = O30M9preF NOT B30M9s

    // 3rd, middle
    F302M9 = RECTANGLES WM9_302 LM9_302 SM9_302 OFFSET OM9_302 INSIDE OF LAYER O30M9
    F302M9s = (SIZE F302M9 BY (SM9_301 + grid)) OR B30M9s
    R302M9pre = O30M9 NOT F302M9s
    R302M9 = WITH WIDTH R302M9pre >= WM9_301

    // 4th, small
    F3012M9 = RECTANGLES WM9_301 LM9_301 SM9_301 OFFSET OM9_301 INSIDE OF LAYER R302M9
    F3012M9s = (SIZE F3012M9 BY (SM9_301 + grid)) OR F302M9s
    R3012M9pre = R302M9pre NOT F3012M9s
    R3012M9 = WITH WIDTH R3012M9pre >= WM9_301

    // 5th, non-stagger small
    F301M9 = RECTANGLES WM9_301 LM9_301 SM9_301 INSIDE OF LAYER R3012M9 //MAINTAIN SPACING
    F301M9s = (SIZE F301M9 BY (SM9_301 + grid)) OR F3012M9s

    F30M9 = ((F302M9 OR F3012M9) OR F301M9) OR F303M9_SLOT
    O40M9pre = (((PUSH D40M9) NOT FRAME9) NOT F301M9s) AND CHIP


    O40M9preA = SIZE O40M9pre BY -DM9_403
    O40M9preB = O40M9preA WITH WIDTH >= WM9_403

    // 1st big
    F403M9 = RECTANGLES WM9_403 LM9_403 SM9_403 OFFSET OM9_403 INSIDE OF LAYER O40M9preB
    F403M9_SLOT = RECTANGLES WM9_403_SLOT LM9_403_SLOT SM9_403_SLOT INSIDE OF LAYER F403M9

    F403M9_EXP = SIZE F403M9_SLOT BY ( SM9_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M9preF1 = O40M9pre NOT (SIZE F403M9_EXP BY SM9_402)
    O40M9preF  = (SNAP (SIZE O40M9preF1 BY -grid) 5) AND O40M9preF1

    B40M9s = F301M9s OR (SIZE F403M9_EXP BY (SM9_402+grid))
    O40M9 = O40M9preF NOT B40M9s

    // 3rd, middle
    F402M9 = RECTANGLES WM9_402 LM9_402 SM9_402 OFFSET OM9_402 INSIDE OF LAYER O40M9
    F402M9s = (SIZE F402M9 BY (SM9_401 + grid)) OR B40M9s
    R402M9pre = O40M9 NOT F402M9s
    R402M9 = WITH WIDTH R402M9pre >= WM9_401

    // 4th, small
    F4012M9 = RECTANGLES WM9_401 LM9_401 SM9_401 OFFSET OM9_401 INSIDE OF LAYER R402M9
    F4012M9s = (SIZE F4012M9 BY (SM9_401 + grid)) OR F402M9s
    R4012M9pre = R402M9pre NOT F4012M9s
    R4012M9 = WITH WIDTH R4012M9pre >= WM9_401

    // 5th, non-stagger small
    F401M9 = RECTANGLES WM9_401 LM9_401 SM9_401 INSIDE OF LAYER R4012M9 //MAINTAIN SPACING
    F401M9s = (SIZE F401M9 BY (SM9_401 + grid)) OR F4012M9s

    F40M9 = ((F402M9 OR F4012M9) OR F401M9) OR F403M9_SLOT
    O50M9pre = (((PUSH (D50M9 OR emptyM9)) NOT FRAME9) NOT F401M9s) AND CHIP


    O50M9preA = SIZE O50M9pre BY -DM9_503
    O50M9preB = O50M9preA WITH WIDTH >= WM9_503

    // 1st big
    F503M9 = RECTANGLES WM9_503 LM9_503 SM9_503 OFFSET OM9_503 INSIDE OF LAYER O50M9preB
    F503M9_SLOT = RECTANGLES WM9_503_SLOT LM9_503_SLOT SM9_503_SLOT INSIDE OF LAYER F503M9

    F503M9_EXP = SIZE F503M9_SLOT BY ( SM9_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M9preF1 = O50M9pre NOT (SIZE F503M9_EXP BY SM9_502)
    O50M9preF  = (SNAP (SIZE O50M9preF1 BY -grid) 5) AND O50M9preF1

    B50M9s = F401M9s OR (SIZE F503M9_EXP BY (SM9_502+grid))
    O50M9 = O50M9preF NOT B50M9s

    // 3rd, middle
    F502M9 = RECTANGLES WM9_502 LM9_502 SM9_502 OFFSET OM9_502 INSIDE OF LAYER O50M9
    F502M9s = (SIZE F502M9 BY (SM9_501 + grid)) OR B50M9s
    R502M9pre = O50M9 NOT F502M9s
    R502M9 = WITH WIDTH R502M9pre >= WM9_501

    // 4th, small
    F5012M9 = RECTANGLES WM9_501 LM9_501 SM9_501 OFFSET OM9_501 INSIDE OF LAYER R502M9
    F5012M9s = (SIZE F5012M9 BY (SM9_501 + grid)) OR F502M9s
    R5012M9pre = R502M9pre NOT F5012M9s
    R5012M9 = WITH WIDTH R5012M9pre >= WM9_501

    // 5th, non-stagger small
    F501M9 = RECTANGLES WM9_501 LM9_501 SM9_501 INSIDE OF LAYER R5012M9 //MAINTAIN SPACING
    F501M9s = (SIZE F501M9 BY (SM9_501 + grid)) OR F5012M9s

    F50M9 = ((F502M9 OR F5012M9) OR F501M9) OR F503M9_SLOT

    exceedM9 = DENSITY M9x F30M9 F40M9 F50M9 > maxD_M9 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M9.den_exceed

    removeM9R = ((PUSH (exceedM9 AND (D50M9 OR emptyM9))) NOT FRAME9) AND CHIP
    removeM9P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM9R

    F30M9x = F30M9 NOT INTERACT removeM9P
    F40M9x = F40M9 NOT INTERACT removeM9P
    F50M9x = F50M9 NOT INTERACT removeM9P
    FM9xA  = (F30M9x OR F40M9x) OR F50M9x
    FM9x   = FM9xA NOT INTERACT (EXT FM9xA < DM9_S_1 ABUT SINGULAR REGION)

    ALLM9x = M9x OR FM9x
    lackM9 = DENSITY ALLM9x CHIP < DM9_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M9.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM9x)/AREA(CHIP) ]

    WDM9EXC = DUM9 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM9EXC = (SIZE FM9x BY Odm2DM9) OR (SIZE (((F303M9_EXP OR F403M9_EXP) OR F503M9_EXP) OR WDM9EXC) BY 1.5)

    lackM9pRM = ((((PUSH lackM9) NOT RM9EXC) NOT FRAME9OPC) NOT exceedM9) AND CHIP
    lackM9pRM_1 = WITH WIDTH lackM9pRM >= SM9_OPC

    RM9p1 = RECTANGLES WM9_OPC LM9_OPC WSM9_OPC LSM9_OPC INSIDE OF LAYER lackM9pRM_1
    lackM9pRM_2 = lackM9pRM_1 NOT (SIZE RM9p1 BY SM9_OPC)
    RM9p2 = RECTANGLES LM9_OPC WM9_OPC LSM9_OPC WSM9_OPC INSIDE OF LAYER lackM9pRM_2

    ODM9A = ((RM9p1 OR RM9p2) OUTSIDE RM9EXC) OUTSIDE FRAME9OPC
    ODM9F_pre = ODM9A NOT INTERACT (EXT ODM9A < SM9_OPC ABUT SINGULAR REGION)

// M9.S.14 ~ M9.S.16
M9_S_14_CHK_REGION = M9i OR ODM9F_pre
// Find Wide Metal
Wide_M9_S_14_CHK_REGION = ENCLOSE RECTANGLE (M9_S_14_CHK_REGION NOT WITH WIDTH <= M9_S_14_W1B) M9_S_14_W1B+GRID M9_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M9_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M9_S_14_CHK_REGION == 0
Wide_M9_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M9_S_14_CHK_REGION == 90

// Find Wide Metal Space
M9_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M9_S_14_CHK_REGION_EDGE_H M9_S_14_CHK_REGION < M9_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M9_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M9_S_14_CHK_REGION_EDGE_V M9_S_14_CHK_REGION < M9_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M9_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M9_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M9_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M9_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M9_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M9_S_14_CHK_REGION_OPC_REGION_pre1_H M9_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M9_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M9_S_14_L1B
M9_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M9_S_14_CHK_REGION_OPC_REGION_pre1_V M9_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M9_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M9_S_14_L1B

M9_S_14_OPC_REGION = M9_S_14_CHK_REGION_OPC_REGION_pre2_H OR M9_S_14_CHK_REGION_OPC_REGION_pre2_V

// M9.S.17 ~ M9.S.19
M9_S_17_CHK_REGION = M9i OR ODM9F_pre
// Find Wide Metal
Wide_M9_S_17_CHK_REGION = ENCLOSE RECTANGLE (M9_S_17_CHK_REGION NOT WITH WIDTH <= M9_S_17_W1B) M9_S_17_W1B+GRID M9_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M9_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M9_S_17_CHK_REGION == 0
Wide_M9_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M9_S_17_CHK_REGION == 90

// Find Wide Metal Space
M9_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M9_S_17_CHK_REGION_EDGE_H M9_S_17_CHK_REGION < M9_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M9_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M9_S_17_CHK_REGION_EDGE_V M9_S_17_CHK_REGION < M9_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M9_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M9_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M9_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M9_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M9_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M9_S_17_CHK_REGION_OPC_REGION_pre1_H M9_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M9_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M9_S_17_L1B
M9_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M9_S_17_CHK_REGION_OPC_REGION_pre1_V M9_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M9_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M9_S_17_L1B

M9_S_17_OPC_REGION = M9_S_17_CHK_REGION_OPC_REGION_pre2_H OR M9_S_17_CHK_REGION_OPC_REGION_pre2_V

// M9.S.20 ~ M9.S.22
M9_S_20_CHK_REGION = M9i OR ODM9F_pre
// Find Wide Metal
Wide_M9_S_20_CHK_REGION = ENCLOSE RECTANGLE (M9_S_20_CHK_REGION NOT WITH WIDTH <= M9_S_20_W1B) M9_S_20_W1B+GRID M9_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M9_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M9_S_20_CHK_REGION == 0
Wide_M9_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M9_S_20_CHK_REGION == 90

// Find Wide Metal Space
M9_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M9_S_20_CHK_REGION_EDGE_H M9_S_20_CHK_REGION < M9_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M9_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M9_S_20_CHK_REGION_EDGE_V M9_S_20_CHK_REGION < M9_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M9_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M9_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M9_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M9_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M9_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M9_S_20_CHK_REGION_OPC_REGION_pre1_H M9_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M9_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M9_S_20_L1B
M9_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M9_S_20_CHK_REGION_OPC_REGION_pre1_V M9_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M9_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M9_S_20_L1B

M9_S_20_OPC_REGION = M9_S_20_CHK_REGION_OPC_REGION_pre2_H OR M9_S_20_CHK_REGION_OPC_REGION_pre2_V

// M9.S.23 ~ M9.S.25
M9_S_23_CHK_REGION = M9i OR ODM9F_pre
// Find Wide Metal
Wide_M9_S_23_CHK_REGION = ENCLOSE RECTANGLE (M9_S_23_CHK_REGION NOT WITH WIDTH <= M9_S_23_W1B) M9_S_23_W1B+GRID M9_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M9_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M9_S_23_CHK_REGION == 0
Wide_M9_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M9_S_23_CHK_REGION == 90

// Find Wide Metal Space
M9_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M9_S_23_CHK_REGION_EDGE_H M9_S_23_CHK_REGION < M9_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M9_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M9_S_23_CHK_REGION_EDGE_V M9_S_23_CHK_REGION < M9_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M9_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M9_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M9_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M9_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M9_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M9_S_23_CHK_REGION_OPC_REGION_pre1_H M9_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M9_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M9_S_23_L1B
M9_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M9_S_23_CHK_REGION_OPC_REGION_pre1_V M9_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M9_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M9_S_23_L1B

M9_S_23_OPC_REGION = M9_S_23_CHK_REGION_OPC_REGION_pre2_H OR M9_S_23_CHK_REGION_OPC_REGION_pre2_V

// M9.S.27
M9_S_27_CHK_REGION = M9i OR ODM9F_pre
// Find Wide Metal
Wide_M9_S_27_CHK_REGION = ENCLOSE RECTANGLE (M9_S_27_CHK_REGION NOT WITH WIDTH <= M9_S_27_W1B) M9_S_27_W1B+GRID M9_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M9_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M9_S_27_CHK_REGION == 0
Wide_M9_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M9_S_27_CHK_REGION == 90

// Find Wide Metal Space
M9_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M9_S_27_CHK_REGION_EDGE_H M9_S_27_CHK_REGION < M9_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M9_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M9_S_27_CHK_REGION_EDGE_V M9_S_27_CHK_REGION < M9_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M9_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M9_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M9_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M9_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M9_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M9_S_27_CHK_REGION_OPC_REGION_pre1_H M9_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M9_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M9_S_27_L1B
M9_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M9_S_27_CHK_REGION_OPC_REGION_pre1_V M9_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M9_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M9_S_27_L1B

M9_S_27_OPC_REGION = M9_S_27_CHK_REGION_OPC_REGION_pre2_H OR M9_S_27_CHK_REGION_OPC_REGION_pre2_V

M9_WMJ_OPC_REGION = (((M9_S_14_OPC_REGION OR M9_S_17_OPC_REGION) OR M9_S_20_OPC_REGION) OR M9_S_23_OPC_REGION) OR M9_S_27_OPC_REGION

    ODM9F = ODM9F_pre NOT INTERACT M9_WMJ_OPC_REGION

    DM9F = COPY FM9x

    FRAME9_INDDMYA = SIZE M9i BY (dm9_s2m9_INDDMY + grid)
    FRAME9_INDDMYB = SIZE DUM9 BY (dm9_s_INDDMY + grid)
    FRAME9_INDDMYC = SIZE DM9F BY dm9_s_INDDMY
    FRAME9_INDDMYD = SIZE ODM9F BY dm9_s2m9_INDDMY

    FRAME9_INDDMY  = ((((((FRAME9Pre OR xM9_DTCD) OR BLOCK9) OR FRAME9_INDDMYA) OR FRAME9_INDDMYB) OR FRAME9_INDDMYC) OR FRAME9_INDDMYD) OR NFILL_x
    FILL9_INDDMY   = ooINDDMY NOT FRAME9_INDDMY
    DM9F_INDDMY    = RECTANGLES dm9_w_INDDMY dm9_l_INDDMY dm9_s_INDDMY INSIDE OF LAYER FILL9_INDDMY

#IFDEF FILL_indDM9
    FILL9_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm9_s_INDDMY_HD + grid)) NOT FRAME9_INDDMY
    DM9F_INDDMY_HD_pre  = RECTANGLES dm9_w_INDDMY_HD dm9_l_INDDMY_HD dm9_s_INDDMY_HD INSIDE OF LAYER FILL9_INDDMY_HD

    FILL9_INDDMY_MD = (SIZE INDDMY_MD BY -(dm9_s_INDDMY_MD + grid)) NOT (FRAME9_INDDMY OR INDDMY_HD)
    DM9F_INDDMY_MD  = RECTANGLES dm9_w_INDDMY_MD dm9_l_INDDMY_MD dm9_s_INDDMY_MD INSIDE OF LAYER FILL9_INDDMY_MD

    DM9F_INDDMY_HD = DM9F_INDDMY_HD_pre OR DM9F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#IFDEF FILL_DM10


#IFDEF 34K_THICK_Mu_M10

    minOPENM10 = DENSITY M10x < minD_M10 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M10Min.den
    emptyOPENM10 = DENSITY M10x < emptyD_M10 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M10Empty.den

    M10InnerHole = HOLES M10i INNER

    M10BigHole = SIZE M10InnerHole BY - excludeHoleSize/2
    M10ExcHole = ((M10InnerHole OUTSIDE M10BigHole) NOT M10i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK10    = (SIZE DM10EXCL BY (dm2DMEXCL + grid)) OR MIM10_x
    FRAMEA10   = SIZE M10i BY (dm2M10 + grid) // DM10 to metal
    FRAMEB10   = SIZE (WITH WIDTH M10i > wideM10) BY (dm2WM10 + grid)
    FRAMEC10   = SIZE DUM10 BY (dm2DM10 + grid)
    FRAME10Pre = ((FRAMEA10 OR FRAMEB10) OR FRAMEC10) OR M10ExcHole
    FRAME10INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm10_s2m10_INDDMY + grid)
    FRAME10 = ((FRAME10Pre OR FRAME10INDDMY) OR BLOCK10) OR NFILL
    
    OPENM10 = PUSH ((minOPENM10 OR emptyOPENM10) AND CHIP)
    FILL10 = OPENM10 NOT FRAME10
    FILLW10pre = SIZE FILL10 BY - (Wdm2M10 + grid)
    FILLW10 = WITH WIDTH FILLW10pre >= WdmW_M10
    M10FW = RECTANGLES WdmW_M10 WdmL_M10 WdmS_M10 OFFSET WdmO_M10 INSIDE OF LAYER FILLW10
    M10FW_EXP = SIZE M10FW BY (WdmS_M10 /2 + grid) OVERUNDER   // merge the gaps
    FILLM10pre = FILL10 NOT (SIZE M10FW_EXP BY (MdmS_M10 + grid))
    FILLM10 = WITH WIDTH FILLM10pre >= MdmW_M10
    M10F1 = RECTANGLES MdmW_M10 MdmL_M10 MdmS_M10 OFFSET MdmO_M10 INSIDE OF LAYER FILLM10
    M10R1pre = FILLM10pre NOT (SIZE M10F1 BY (dmS_M10 + grid))
    M10R1 = WITH WIDTH M10R1pre >= dmW_M10

    M10F2 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 OFFSET dmO_M10 INSIDE OF LAYER M10R1
    M10R2pre = M10R1 NOT (SIZE M10F2 BY (dmS_M10 + grid))
    M10R2 = WITH WIDTH M10R2pre >= dmW_M10

    M10F3 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 OFFSET dmO_M10 INSIDE OF LAYER M10R2
    M10R3pre = M10R2 NOT (SIZE M10F3 BY (dmS_M10 + grid))
    M10R3 = WITH WIDTH M10R3pre >= dmW_M10

    M10F4 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 INSIDE OF LAYER M10R3

    M10F = (((M10F1 OR M10F2) OR M10F3) OR M10F4) OR M10FW
    FM10 = M10F NOT INTERACT (EXT M10F < dmS_M10 ABUT SINGULAR REGION)

    maxOPENM10 = DENSITY M10x FM10 > maxD_M10 WINDOW WindowSizeu*2 STEP WindowStepu*2
                INSIDE OF LAYER bulk BACKUP // PRINT M10Max.den

    DM10F = FM10 OUTSIDE maxOPENM10

    FRAME10_INDDMYA = SIZE M10i BY (dm10_s2m10_INDDMY + grid)
    FRAME10_INDDMYB = SIZE DUM10 BY (dm10_s_INDDMY + grid)
    FRAME10_INDDMYC = SIZE DM10F BY dm10_s_INDDMY
    FRAME10_INDDMY  = ((((FRAME10Pre OR BLOCK10) OR FRAME10_INDDMYA) OR FRAME10_INDDMYB) OR FRAME10_INDDMYC) OR NFILL
    FILL10_INDDMY   = ooINDDMY NOT FRAME10_INDDMY
    DM10F_INDDMY    = RECTANGLES dm10_w_INDDMY dm10_l_INDDMY dm10_s_INDDMY INSIDE OF LAYER FILL10_INDDMY
#IFDEF FILL_indDM10
    FILL10_INDDMY_HD = (SIZE INDDMY_HD BY -(dm10_s_INDDMY_HD + grid)) NOT FRAME10_INDDMY
    DM10F_INDDMY_HD  = RECTANGLES dm10_w_INDDMY_HD dm10_l_INDDMY_HD dm10_s_INDDMY_HD INSIDE OF LAYER FILL10_INDDMY_HD
#ENDIF	
	
#ELSE


#IFDEF 12K_THICK_Mr_M10

    minOPENM10 = DENSITY M10x < minD_M10 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M10Min.den
    emptyOPENM10 = DENSITY M10x < emptyD_M10 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M10Empty.den

    M10InnerHole = HOLES M10i INNER

    M10BigHole = SIZE M10InnerHole BY - excludeHoleSize/2
    M10ExcHole = ((M10InnerHole OUTSIDE M10BigHole) NOT M10i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK10  = (SIZE DM10EXCL BY (dm2DMEXCL + grid)) OR MIM10_x // DM10 to DM10EXCL
    FRAMEA10 = SIZE M10i BY (dm2M10 + grid) // DM10 to metal
    FRAMEB10 = SIZE (WITH WIDTH M10i > wideM10) BY (dm2WM10 + grid)
    FRAMEC10 = SIZE DUM10 BY (dm2DM10 + grid)   // DM10 to existed dummy metal 0.6um
    FRAME10Pre = ((FRAMEA10 OR FRAMEB10) OR FRAMEC10) OR M10ExcHole
    FRAME10INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm10_s2m10_INDDMY + grid)
    FRAME10 = ((FRAME10Pre OR FRAME10INDDMY) OR BLOCK10) OR NFILL
    
    OPENM10 = PUSH ((minOPENM10 OR emptyOPENM10) AND CHIP)
    FILL10 = OPENM10 NOT FRAME10
    FILLW10pre = SIZE FILL10 BY - (Wdm2M10 + grid)
    FILLW10 = WITH WIDTH FILLW10pre >= WdmW_M10
    M10FW = RECTANGLES WdmW_M10 WdmL_M10 WdmS_M10 OFFSET WdmO_M10 INSIDE OF LAYER FILLW10
    M10FW_EXP = SIZE M10FW BY (WdmS_M10 /2 + grid) OVERUNDER //merge the gaps
    FILLM10pre = FILL10 NOT (SIZE M10FW_EXP BY (MdmS_M10 + grid))
    FILLM10 = WITH WIDTH FILLM10pre >= MdmW_M10
    M10F1 = RECTANGLES MdmW_M10 MdmL_M10 MdmS_M10 OFFSET MdmO_M10 INSIDE OF LAYER FILLM10
    M10R1pre = FILLM10pre NOT (SIZE M10F1 BY (dmS_M10 + grid))
    M10R1 = WITH WIDTH M10R1pre >= dmW_M10

    M10F2 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 OFFSET dmO_M10 INSIDE OF LAYER M10R1
    M10R2pre = M10R1 NOT (SIZE M10F2 BY (dmS_M10 + grid))
    M10R2 = WITH WIDTH M10R2pre >= dmW_M10

    M10F3 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 OFFSET dmO_M10 INSIDE OF LAYER M10R2
    M10R3pre = M10R2 NOT (SIZE M10F3 BY (dmS_M10 + grid))
    M10R3 = WITH WIDTH M10R3pre >= dmW_M10

    M10F4 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 INSIDE OF LAYER M10R3

    M10F = (((M10F1 OR M10F2) OR M10F3) OR M10F4) OR M10FW
    FM10 = M10F NOT INTERACT (EXT M10F < dmS_M10 ABUT SINGULAR REGION)

    maxOPENM10 = DENSITY M10x FM10 > maxD_M10 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M10Max.den

    FM10F = FM10 OUTSIDE maxOPENM10

    // DMr_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M10 = DENSITY M10x FM10F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M10Min.den

    RM10EXC = SIZE FM10F BY (Odm2DM10 + grid)
    // do not fill DMy_S over CTMDMY
    D25M10pM = (((PUSH D25M10) NOT FRAME10) NOT RM10EXC) AND CHIP
    D25M10pM_1 = WITH WIDTH D25M10pM >= OdmW_M10

    RM10p1 = RECTANGLES OdmW_M10 OdmL_M10 OdmS_M10 INSIDE OF LAYER D25M10pM_1
    D25M10pM_2 = D25M10pM_1 NOT (SIZE RM10p1 BY (OdmS_M10 + grid))
    RM10p2 = RECTANGLES OdmL_M10 OdmW_M10 OdmS_M10 INSIDE OF LAYER D25M10pM_2

    RM10A = ((RM10p1 OR RM10p2) OUTSIDE RM10EXC) OUTSIDE FRAME10
    RM10  = RM10A NOT INTERACT (EXT RM10A < OdmS_M10 ABUT SINGULAR REGION)

    DM10F = FM10F OR RM10

    FRAME10_INDDMYA = SIZE M10i BY (dm10_s2m10_INDDMY + grid)
    FRAME10_INDDMYB = SIZE DUM10 BY (dm10_s_INDDMY + grid)
    FRAME10_INDDMYC = SIZE DM10F BY dm10_s_INDDMY
    FRAME10_INDDMY  = ((((FRAME10Pre OR BLOCK10) OR FRAME10_INDDMYA) OR FRAME10_INDDMYB) OR FRAME10_INDDMYC) OR NFILL
    FILL10_INDDMY   = ooINDDMY NOT FRAME10_INDDMY
    DM10F_INDDMY    = RECTANGLES dm10_w_INDDMY dm10_l_INDDMY dm10_s_INDDMY INSIDE OF LAYER FILL10_INDDMY

#IFDEF FILL_indDM10
    FILL10_INDDMY_HD = (SIZE INDDMY_HD BY -(dm10_s_INDDMY_HD + grid)) NOT FRAME10_INDDMY
    DM10F_INDDMY_HD  = RECTANGLES dm10_w_INDDMY_HD dm10_l_INDDMY_HD dm10_s_INDDMY_HD INSIDE OF LAYER FILL10_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 5K_THICK_Myz_M10

    minOPENM10 = DENSITY M10x < minD_M10 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M10Min.den
    emptyOPENM10 = DENSITY M10x < emptyD_M10 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M10Empty.den

    M10InnerHole = HOLES M10i INNER

    M10BigHole = SIZE M10InnerHole BY - excludeHoleSize/2
    M10ExcHole = ((M10InnerHole OUTSIDE M10BigHole) NOT M10i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK10 = (SIZE DM10EXCL BY (dm2DMEXCL + grid)) OR MIM10_x // DM10 to DM10EXCL
    FRAMEA10 = SIZE M10i BY (dm2M10 + grid) // DM10 to metal
    FRAMEB10 = SIZE (WITH WIDTH M10i > wideM10) BY (dm2WM10 + grid)
    FRAMEC10 = SIZE DUM10 BY (dm2DM10 + grid)   // DM10 to existed dummy metal 0.6um
    FRAME10Pre = ((FRAMEA10 OR FRAMEB10) OR FRAMEC10) OR M10ExcHole
    FRAME10INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm10_s2m10_INDDMY + grid)
    FRAME10 = ((FRAME10Pre OR FRAME10INDDMY) OR BLOCK10) OR NFILL
    
    OPENM10 = PUSH ((minOPENM10 OR emptyOPENM10) AND CHIP)
    FILL10 = OPENM10 NOT FRAME10
    FILLW10pre = SIZE FILL10 BY - (Wdm2M10 + grid)
    FILLW10 = WITH WIDTH FILLW10pre >= WdmW_M10
    M10FW = RECTANGLES WdmW_M10 WdmL_M10 WdmS_M10 OFFSET WdmO_M10 INSIDE OF LAYER FILLW10
    M10FW_EXP = SIZE M10FW BY (WdmS_M10 /2 + grid) OVERUNDER //merge the gaps
    FILLM10pre = FILL10 NOT (SIZE M10FW_EXP BY (MdmS_M10 + grid))
    FILLM10 = WITH WIDTH FILLM10pre >= MdmW_M10
    M10F1 = RECTANGLES MdmW_M10 MdmL_M10 MdmS_M10 OFFSET MdmO_M10 INSIDE OF LAYER FILLM10
    M10R1pre = FILLM10pre NOT (SIZE M10F1 BY (dmS_M10 + grid))
    M10R1 = WITH WIDTH M10R1pre >= dmW_M10

    M10F2 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 OFFSET dmO_M10 INSIDE OF LAYER M10R1
    M10R2pre = M10R1 NOT (SIZE M10F2 BY (dmS_M10 + grid))
    M10R2 = WITH WIDTH M10R2pre >= dmW_M10

    M10F3 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 OFFSET dmO_M10 INSIDE OF LAYER M10R2
    M10R3pre = M10R2 NOT (SIZE M10F3 BY (dmS_M10 + grid))
    M10R3 = WITH WIDTH M10R3pre >= dmW_M10

    M10F4 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 INSIDE OF LAYER M10R3

    M10F = (((M10F1 OR M10F2) OR M10F3) OR M10F4) OR M10FW
    FM10 = M10F NOT INTERACT (EXT M10F < dmS_M10 ABUT SINGULAR REGION)

    maxOPENM10 = DENSITY M10x FM10 > maxD_M10 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M10Max.den

    FM10F = FM10 OUTSIDE maxOPENM10

    // DMy_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M10 = DENSITY M10x FM10F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M10Min.den

    RM10EXC = SIZE FM10F BY (Odm2DM10 + grid)
    // do not fill DMy_S over CTMDMY
    D25M10pM = (((PUSH D25M10) NOT FRAME10) NOT RM10EXC) AND CHIP
    D25M10pM_1 = WITH WIDTH D25M10pM >= OdmW_M10

    RM10p1 = RECTANGLES OdmW_M10 OdmL_M10 OdmS_M10 INSIDE OF LAYER D25M10pM_1
    D25M10pM_2 = D25M10pM_1 NOT (SIZE RM10p1 BY (OdmS_M10 + grid))
    RM10p2 = RECTANGLES OdmL_M10 OdmW_M10 OdmS_M10 INSIDE OF LAYER D25M10pM_2

    RM10A = ((RM10p1 OR RM10p2) OUTSIDE RM10EXC) OUTSIDE FRAME10
    RM10  = RM10A NOT INTERACT (EXT RM10A < OdmS_M10 ABUT SINGULAR REGION)

    DM10F = FM10F OR RM10

    FRAME10_INDDMYA = SIZE M10i BY (dm10_s2m10_INDDMY + grid)
    FRAME10_INDDMYB = SIZE DUM10 BY (dm10_s_INDDMY + grid)
    FRAME10_INDDMYC = SIZE DM10F BY dm10_s_INDDMY
    FRAME10_INDDMY  = ((((FRAME10Pre OR BLOCK10) OR FRAME10_INDDMYA) OR FRAME10_INDDMYB) OR FRAME10_INDDMYC) OR NFILL
    FILL10_INDDMY   = ooINDDMY NOT FRAME10_INDDMY
    DM10F_INDDMY    = RECTANGLES dm10_w_INDDMY dm10_l_INDDMY dm10_s_INDDMY INSIDE OF LAYER FILL10_INDDMY


#IFDEF FILL_indDM10
    FILL10_INDDMY_HD = (SIZE INDDMY_HD BY -(dm10_s_INDDMY_HD + grid)) NOT FRAME10_INDDMY
    DM10F_INDDMY_HD  = RECTANGLES dm10_w_INDDMY_HD dm10_l_INDDMY_HD dm10_s_INDDMY_HD INSIDE OF LAYER FILL10_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2_6K_THICK_Mxy_M10

    minOPENM10 = DENSITY M10x < minD_M10 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M10Min.den
    emptyOPENM10 = DENSITY M10x < emptyD_M10 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M10Empty.den

    M10InnerHole = HOLES M10i INNER

    M10BigHole = SIZE M10InnerHole BY - excludeHoleSize/2
    M10ExcHole = ((M10InnerHole OUTSIDE M10BigHole) NOT M10i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK10 = (SIZE DM10EXCL BY (dm2DMEXCL + grid)) OR  MIM10_x // DM10 to DM10EXCL
    FRAMEA10 = SIZE M10i BY (dm2M10 + grid) // DM10 to metal
    FRAMEB10 = SIZE (WITH WIDTH M10i > wideM10) BY (dm2WM10 + grid)
    FRAMEC10 = SIZE DUM10 BY (dm2DM10 + grid)   // DM10 to existed dummy metal 0.6um
    FRAME10Pre = ((FRAMEA10 OR FRAMEB10) OR FRAMEC10) OR M10ExcHole
    FRAME10INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm10_s2m10_INDDMY + grid)
    FRAME10 = ((FRAME10Pre OR FRAME10INDDMY) OR BLOCK10) OR NFILL
    
    OPENM10 = PUSH ((minOPENM10 OR emptyOPENM10) AND CHIP)
    FILL10 = OPENM10 NOT FRAME10
    FILLW10pre = SIZE FILL10 BY - (Wdm2M10 + grid)
    FILLW10 = WITH WIDTH FILLW10pre >= WdmW_M10
    M10FW = RECTANGLES WdmW_M10 WdmL_M10 WdmS_M10 OFFSET WdmO_M10 INSIDE OF LAYER FILLW10
    M10FW_EXP = SIZE M10FW BY (WdmS_M10 /2 + grid) OVERUNDER //merge the gaps
    FILLM10pre = FILL10 NOT (SIZE M10FW_EXP BY (MdmS_M10 + grid))
    FILLM10 = WITH WIDTH FILLM10pre >= MdmW_M10
    M10F1 = RECTANGLES MdmW_M10 MdmL_M10 MdmS_M10 OFFSET MdmO_M10 INSIDE OF LAYER FILLM10
    M10R1pre = FILLM10pre NOT (SIZE M10F1 BY (dmS_M10 + grid))
    M10R1 = WITH WIDTH M10R1pre >= dmW_M10

    M10F2 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 OFFSET dmO_M10 INSIDE OF LAYER M10R1
    M10R2pre = M10R1 NOT (SIZE M10F2 BY (dmS_M10 + grid))
    M10R2 = WITH WIDTH M10R2pre >= dmW_M10

    M10F3 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 OFFSET dmO_M10 INSIDE OF LAYER M10R2
    M10R3pre = M10R2 NOT (SIZE M10F3 BY (dmS_M10 + grid))
    M10R3 = WITH WIDTH M10R3pre >= dmW_M10

    M10F4 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 INSIDE OF LAYER M10R3

    M10F = (((M10F1 OR M10F2) OR M10F3) OR M10F4) OR M10FW
    FM10 = M10F NOT INTERACT (EXT M10F < dmS_M10 ABUT SINGULAR REGION)

    maxOPENM10 = DENSITY M10x FM10 > maxD_M10 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M10Max.den

    FM10F = FM10 OUTSIDE maxOPENM10

    D25M10 = DENSITY M10x FM10F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M10Min.den

    RM10EXC = SIZE FM10F BY (Odm2DM10 + grid)
    D25M10pM = (((PUSH D25M10) NOT FRAME10) NOT RM10EXC) AND CHIP
    D25M10pM_1 = WITH WIDTH D25M10pM >= OdmW_M10

    RM10p1 = RECTANGLES OdmW_M10 OdmL_M10 OdmS_M10 INSIDE OF LAYER D25M10pM_1
    D25M10pM_2 = D25M10pM_1 NOT (SIZE RM10p1 BY (OdmS_M10 + grid))
    RM10p2 = RECTANGLES OdmL_M10 OdmW_M10 OdmS_M10 INSIDE OF LAYER D25M10pM_2

    RM10A = ((RM10p1 OR RM10p2) OUTSIDE RM10EXC) OUTSIDE FRAME10
    RM10  = RM10A NOT INTERACT (EXT RM10A < OdmS_M10 ABUT SINGULAR REGION)

    DM10F = FM10F OR RM10

    FRAME10_INDDMYA = SIZE M10i BY (dm10_s2m10_INDDMY + grid)
    FRAME10_INDDMYB = SIZE DUM10 BY (dm10_s_INDDMY + grid)
    FRAME10_INDDMYC = SIZE DM10F BY dm10_s_INDDMY
    FRAME10_INDDMY  = ((((FRAME10Pre OR BLOCK10) OR FRAME10_INDDMYA) OR FRAME10_INDDMYB) OR FRAME10_INDDMYC) OR NFILL
    FILL10_INDDMY   = ooINDDMY NOT FRAME10_INDDMY
    DM10F_INDDMY    = RECTANGLES dm10_w_INDDMY dm10_l_INDDMY dm10_s_INDDMY INSIDE OF LAYER FILL10_INDDMY

#IFDEF FILL_indDM10
    FILL10_INDDMY_HD = (SIZE INDDMY_HD BY -(dm10_s_INDDMY_HD + grid)) NOT FRAME10_INDDMY
    DM10F_INDDMY_HD  = RECTANGLES dm10_w_INDDMY_HD dm10_l_INDDMY_HD dm10_s_INDDMY_HD INSIDE OF LAYER FILL10_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M10

    D30M10 = DENSITY M10x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M10.den30
    D40M10 = DENSITY M10x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M10.den40
    D50M10 = DENSITY M10x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M10.den50
    emptyM10 = DENSITY M10x < emptyD_M10 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M10.den_empty

    M10InnerHole = HOLES M10i INNER

    M10BigHole = SIZE M10InnerHole BY - excludeHoleSize/2
    M10ExcHole = ((M10InnerHole OUTSIDE M10BigHole) NOT M10i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK10 = (SIZE DM10EXCL BY (dm2DMEXCL + grid)) OR MIM10_x

    FRAMEA10 = (SIZE M10i BY (DM10_301 + grid)) OR (SIZE (EXPAND EDGE (M10i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA10OPC = SIZE M10i BY (DM10_OPC + grid)
    FRAMEA10OPCDV33 = SIZE (M10i INTERACT M10_HVN_330Vx) BY (M10_S_1_1_a + grid)
    FRAMEA10OPCDV5 = SIZE (M10i INTERACT M10_HVN_500Vx) BY (M10_S_9_a + grid)
    FRAMEA10OPC45 = SIZE (EXPAND EDGE (M10i ANGLE == 45) OUTSIDE BY DM10_OPC_45 EXTEND BY DM10_OPC_45_E) BY grid
    FRAMEA10OPC45DV = SIZE (EXPAND EDGE ((M10i INTERACT M10_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM10_OPC_45 EXTEND BY DM10_OPC_45_E) BY grid

    FRAMEB10 = SIZE (WITH WIDTH M10i > wideM10) BY (dm2WM10 + grid)
    FRAMEC10 = SIZE DUM10 BY (dm2DM10 + grid)
    FRAMED10 = SIZE (WITH WIDTH M10i > wideM10_small) BY (dm2WM10_small + grid)
    FRAMEC10OPC = SIZE DUM10 BY (Odm2DM10 + grid)
    FRAME10Pre = ((FRAMEA10 OR FRAMEB10) OR (FRAMEC10 OR FRAMED10)) OR M10ExcHole
    FRAME10PreOPC = (((((((FRAMEA10OPC OR FRAMEA10OPCDV33) OR FRAMEA10OPCDV5) OR FRAMEC10OPC) OR M10ExcHole) OR FRAMEA10OPC45) OR FRAMEA10OPC45DV) OR FRAMEB10) OR FRAMED10
    FRAME10INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm10_s2m10_INDDMY + grid)

    FRAME10OPC = ((FRAME10PreOPC OR FRAME10INDDMY) OR BLOCK10) OR NFILLOPC

    FRAME10 = ((FRAME10Pre OR FRAME10INDDMY) OR BLOCK10) OR NFILL

    //****************************************************************************

    D30M10p = (PUSH D30M10) NOT FRAME10
    O30M10pre = D30M10p AND CHIP
    FD21M10s = COPY FRAME10

    O30M10preA = SIZE O30M10pre BY -DM10_303
    O30M10preB = O30M10preA WITH WIDTH >= WM10_303

    // 1st big
    F303M10 = RECTANGLES WM10_303 LM10_303 SM10_303 OFFSET OM10_303 INSIDE OF LAYER O30M10preB

    F303M10_EXP = SIZE F303M10 BY ( SM10_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M10preF1 = O30M10pre NOT (SIZE F303M10_EXP BY SM10_302)
    O30M10preF  = (SNAP (SIZE O30M10preF1 BY -grid) 5) AND O30M10preF1

    B30M10s = FD21M10s OR (SIZE F303M10_EXP BY (SM10_302+grid))
    O30M10 = O30M10preF NOT B30M10s

    // 3rd, middle
    F302M10 = RECTANGLES WM10_302 LM10_302 SM10_302 OFFSET OM10_302 INSIDE OF LAYER O30M10
    F302M10s = (SIZE F302M10 BY (SM10_301 + grid)) OR B30M10s
    R302M10pre = O30M10 NOT F302M10s
    R302M10 = WITH WIDTH R302M10pre >= WM10_301

    // 4th, small
    F3012M10 = RECTANGLES WM10_301 LM10_301 SM10_301 OFFSET OM10_301 INSIDE OF LAYER R302M10
    F3012M10s = (SIZE F3012M10 BY (SM10_301 + grid)) OR F302M10s
    R3012M10pre = R302M10pre NOT F3012M10s
    R3012M10 = WITH WIDTH R3012M10pre >= WM10_301

    // 5th, non-stagger small
    F301M10 = RECTANGLES WM10_301 LM10_301 SM10_301 INSIDE OF LAYER R3012M10 //MAINTAIN SPACING
    F301M10s = (SIZE F301M10 BY (SM10_301 + grid)) OR F3012M10s

    F30M10 = ((F302M10 OR F3012M10) OR F301M10) OR F303M10
    O40M10pre = (((PUSH D40M10) NOT FRAME10) NOT F301M10s) AND CHIP


    O40M10preA = SIZE O40M10pre BY -DM10_403
    O40M10preB = O40M10preA WITH WIDTH >= WM10_403

    // 1st big
    F403M10 = RECTANGLES WM10_403 LM10_403 SM10_403 OFFSET OM10_403 INSIDE OF LAYER O40M10preB

    F403M10_EXP = SIZE F403M10 BY ( SM10_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M10preF1 = O40M10pre NOT (SIZE F403M10_EXP BY SM10_402)
    O40M10preF  = (SNAP (SIZE O40M10preF1 BY -grid) 5) AND O40M10preF1

    B40M10s = F301M10s OR (SIZE F403M10_EXP BY (SM10_402+grid))
    O40M10 = O40M10preF NOT B40M10s

    // 3rd, middle
    F402M10 = RECTANGLES WM10_402 LM10_402 SM10_402 OFFSET OM10_402 INSIDE OF LAYER O40M10
    F402M10s = (SIZE F402M10 BY (SM10_401 + grid)) OR B40M10s
    R402M10pre = O40M10 NOT F402M10s
    R402M10 = WITH WIDTH R402M10pre >= WM10_401

    // 4th, small
    F4012M10 = RECTANGLES WM10_401 LM10_401 SM10_401 OFFSET OM10_401 INSIDE OF LAYER R402M10
    F4012M10s = (SIZE F4012M10 BY (SM10_401 + grid)) OR F402M10s
    R4012M10pre = R402M10pre NOT F4012M10s
    R4012M10 = WITH WIDTH R4012M10pre >= WM10_401

    // 5th, non-stagger small
    F401M10 = RECTANGLES WM10_401 LM10_401 SM10_401 INSIDE OF LAYER R4012M10 //MAINTAIN SPACING
    F401M10s = (SIZE F401M10 BY (SM10_401 + grid)) OR F4012M10s

    F40M10 = ((F402M10 OR F4012M10) OR F401M10) OR F403M10
    O50M10pre = (((PUSH (D50M10 OR emptyM10)) NOT FRAME10) NOT F401M10s) AND CHIP


    O50M10preA = SIZE O50M10pre BY -DM10_503
    O50M10preB = O50M10preA WITH WIDTH >= WM10_503

    // 1st big
    F503M10 = RECTANGLES WM10_503 LM10_503 SM10_503 OFFSET OM10_503 INSIDE OF LAYER O50M10preB

    F503M10_EXP = SIZE F503M10 BY ( SM10_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M10preF1 = O50M10pre NOT (SIZE F503M10_EXP BY SM10_502)
    O50M10preF  = (SNAP (SIZE O50M10preF1 BY -grid) 5) AND O50M10preF1

    B50M10s = F401M10s OR (SIZE F503M10_EXP BY (SM10_502+grid))
    O50M10 = O50M10preF NOT B50M10s

    // 3rd, middle
    F502M10 = RECTANGLES WM10_502 LM10_502 SM10_502 OFFSET OM10_502 INSIDE OF LAYER O50M10
    F502M10s = (SIZE F502M10 BY (SM10_501 + grid)) OR B50M10s
    R502M10pre = O50M10 NOT F502M10s
    R502M10 = WITH WIDTH R502M10pre >= WM10_501

    // 4th, small
    F5012M10 = RECTANGLES WM10_501 LM10_501 SM10_501 OFFSET OM10_501 INSIDE OF LAYER R502M10
    F5012M10s = (SIZE F5012M10 BY (SM10_501 + grid)) OR F502M10s
    R5012M10pre = R502M10pre NOT F5012M10s
    R5012M10 = WITH WIDTH R5012M10pre >= WM10_501

    // 5th, non-stagger small
    F501M10 = RECTANGLES WM10_501 LM10_501 SM10_501 INSIDE OF LAYER R5012M10 //MAINTAIN SPACING
    F501M10s = (SIZE F501M10 BY (SM10_501 + grid)) OR F5012M10s

    F50M10 = ((F502M10 OR F5012M10) OR F501M10) OR F503M10

//****************************************************************************

    exceedM10 = DENSITY M10x F30M10 F40M10 F50M10 > maxD_M10 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M10.den_exceed

    removeM10R = ((PUSH (exceedM10 AND (D50M10 OR emptyM10))) NOT FRAME10) AND CHIP
    removeM10P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM10R

    F30M10x = F30M10 NOT INTERACT removeM10P
    F40M10x = F40M10 NOT INTERACT removeM10P
    F50M10x = F50M10 NOT INTERACT removeM10P
    FM10xA  = (F30M10x OR F40M10x) OR F50M10x
    FM10x   = FM10xA NOT INTERACT (EXT FM10xA < DM10_S_1 ABUT SINGULAR REGION)

    ALLM10x = M10x OR FM10x
    lackM10 = DENSITY ALLM10x CHIP < DM10_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M10.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM10x)/AREA(CHIP) ]

    WDM10EXC = DUM10 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM10EXC = (SIZE FM10x BY Odm2DM10) OR (SIZE (((F303M10_EXP OR F403M10_EXP) OR F503M10_EXP) OR WDM10EXC) BY 1.5)

    lackM10pRM = ((((PUSH lackM10) NOT RM10EXC) NOT FRAME10OPC) NOT exceedM10) AND CHIP
    lackM10pRM_1 = WITH WIDTH lackM10pRM >= SM10_OPC

    RM10p1 = RECTANGLES WM10_OPC LM10_OPC WSM10_OPC LSM10_OPC INSIDE OF LAYER lackM10pRM_1
    lackM10pRM_2 = lackM10pRM_1 NOT (SIZE RM10p1 BY SM10_OPC)
    RM10p2 = RECTANGLES LM10_OPC WM10_OPC LSM10_OPC WSM10_OPC INSIDE OF LAYER lackM10pRM_2

    ODM10A = ((RM10p1 OR RM10p2) OUTSIDE RM10EXC) OUTSIDE FRAME10OPC
    ODM10F = ODM10A NOT INTERACT (EXT ODM10A < SM10_OPC ABUT SINGULAR REGION)

    DM10F = COPY FM10x

    FRAME10_INDDMYA = SIZE M10i BY (dm10_s2m10_INDDMY + grid)
    FRAME10_INDDMYB = SIZE DUM10 BY (dm10_s_INDDMY + grid)
    FRAME10_INDDMYC = SIZE DM10F BY dm10_s_INDDMY
    FRAME10_INDDMYD = SIZE ODM10F BY dm10_s2m10_INDDMY
    FRAME10_INDDMY  = (((((FRAME10Pre OR BLOCK10) OR FRAME10_INDDMYA) OR FRAME10_INDDMYB) OR FRAME10_INDDMYC) OR FRAME10_INDDMYD) OR NFILL
    FILL10_INDDMY   = ooINDDMY NOT FRAME10_INDDMY
    DM10F_INDDMY    = RECTANGLES dm10_w_INDDMY dm10_l_INDDMY dm10_s_INDDMY INSIDE OF LAYER FILL10_INDDMY


#IFDEF FILL_indDM10
    FILL10_INDDMY_HD = (SIZE INDDMY_HD BY -(dm10_s_INDDMY_HD + grid)) NOT FRAME10_INDDMY
    DM10F_INDDMY_HD  = RECTANGLES dm10_w_INDDMY_HD dm10_l_INDDMY_HD dm10_s_INDDMY_HD INSIDE OF LAYER FILL10_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M10

    minOPENM10 = DENSITY M10x < minD_M10 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M10Min.den
    emptyOPENM10 = DENSITY M10x < emptyD_M10 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M10Empty.den

    M10InnerHole = HOLES M10i INNER

    M10BigHole = SIZE M10InnerHole BY - excludeHoleSize/2
    M10ExcHole = ((M10InnerHole OUTSIDE M10BigHole) NOT M10i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK10 = (SIZE DM10EXCL BY (dm2DMEXCL + grid)) OR MIM10_x // DM10 to DM10EXCL
    FRAMEA10 = SIZE M10i BY (dm2M10 + grid) // DM10 to metal
    FRAMEB10 = SIZE (WITH WIDTH M10i > wideM10) BY (dm2WM10 + grid)
    FRAMEC10 = SIZE DUM10 BY (dm2DM10 + grid)   // DM10 to existed dummy metal 0.6um
    FRAME10Pre = ((FRAMEA10 OR FRAMEB10) OR FRAMEC10) OR M10ExcHole
    FRAME10INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm10_s2m10_INDDMY + grid)
    FRAME10 = ((FRAME10Pre OR FRAME10INDDMY) OR BLOCK10) OR NFILL
    
    OPENM10 = PUSH ((minOPENM10 OR emptyOPENM10) AND CHIP)
    FILL10 = OPENM10 NOT FRAME10
    FILLW10pre = SIZE FILL10 BY - (Wdm2M10 + grid)
    FILLW10 = WITH WIDTH FILLW10pre >= WdmW_M10
    M10FW = RECTANGLES WdmW_M10 WdmL_M10 WdmS_M10 OFFSET WdmO_M10 INSIDE OF LAYER FILLW10
    M10FW_EXP = SIZE M10FW BY (WdmS_M10 /2 + grid) OVERUNDER //merge the gaps
    FILLM10pre = FILL10 NOT (SIZE M10FW_EXP BY (MdmS_M10 + grid))
    FILLM10 = WITH WIDTH FILLM10pre >= MdmW_M10
    M10F1 = RECTANGLES MdmW_M10 MdmL_M10 MdmS_M10 OFFSET MdmO_M10 INSIDE OF LAYER FILLM10
    M10R1pre = FILLM10pre NOT (SIZE M10F1 BY (dmS_M10 + grid))
    M10R1 = WITH WIDTH M10R1pre >= dmW_M10

    M10F2 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 OFFSET dmO_M10 INSIDE OF LAYER M10R1
    M10R2pre = M10R1 NOT (SIZE M10F2 BY (dmS_M10 + grid))
    M10R2 = WITH WIDTH M10R2pre >= dmW_M10

    M10F3 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 OFFSET dmO_M10 INSIDE OF LAYER M10R2
    M10R3pre = M10R2 NOT (SIZE M10F3 BY (dmS_M10 + grid))
    M10R3 = WITH WIDTH M10R3pre >= dmW_M10

    M10F4 = RECTANGLES dmW_M10 dmL_M10 dmS_M10 INSIDE OF LAYER M10R3

    M10F = (((M10F1 OR M10F2) OR M10F3) OR M10F4) OR M10FW
    FM10 = M10F NOT INTERACT (EXT M10F < dmS_M10 ABUT SINGULAR REGION)

    maxOPENM10 = DENSITY M10x FM10 > maxD_M10 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M10Max.den

    FM10F = FM10 OUTSIDE maxOPENM10

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M10 = DENSITY M10x FM10F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M10Min.den

    RM10EXC = SIZE FM10F BY (Odm2DM10 + grid)
    // do not fill DMz_S over CTMDMY
    D25M10pM = (((PUSH D25M10) NOT FRAME10) NOT RM10EXC) AND CHIP
    D25M10pM_1 = WITH WIDTH D25M10pM >= OdmW_M10

    RM10p1 = RECTANGLES OdmW_M10 OdmL_M10 OdmS_M10 INSIDE OF LAYER D25M10pM_1
    D25M10pM_2 = D25M10pM_1 NOT (SIZE RM10p1 BY (OdmS_M10 + grid))
    RM10p2 = RECTANGLES OdmL_M10 OdmW_M10 OdmS_M10 INSIDE OF LAYER D25M10pM_2

    RM10A = ((RM10p1 OR RM10p2) OUTSIDE RM10EXC) OUTSIDE FRAME10
    RM10  = RM10A NOT INTERACT (EXT RM10A < OdmS_M10 ABUT SINGULAR REGION)

    DM10F = FM10F OR RM10

    FRAME10_INDDMYA = SIZE M10i BY (dm10_s2m10_INDDMY + grid)
    FRAME10_INDDMYB = SIZE DUM10 BY (dm10_s_INDDMY + grid)
    FRAME10_INDDMYC = SIZE DM10F BY dm10_s_INDDMY
    FRAME10_INDDMY  = ((((FRAME10Pre OR BLOCK10) OR FRAME10_INDDMYA) OR FRAME10_INDDMYB) OR FRAME10_INDDMYC) OR NFILL
    FILL10_INDDMY   = ooINDDMY NOT FRAME10_INDDMY
    DM10F_INDDMY    = RECTANGLES dm10_w_INDDMY dm10_l_INDDMY dm10_s_INDDMY INSIDE OF LAYER FILL10_INDDMY

#IFDEF FILL_indDM10
    FILL10_INDDMY_HD = (SIZE INDDMY_HD BY -(dm10_s_INDDMY_HD + grid)) NOT FRAME10_INDDMY
    DM10F_INDDMY_HD  = RECTANGLES dm10_w_INDDMY_HD dm10_l_INDDMY_HD dm10_s_INDDMY_HD INSIDE OF LAYER FILL10_INDDMY_HD
#ENDIF	

#ELSE



    D30M10 = DENSITY M10x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M10.den30
    D40M10 = DENSITY M10x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M10.den40
    D50M10 = DENSITY M10x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M10.den50
    emptyM10 = DENSITY M10x < emptyD_M10 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M10.den_empty

    M10InnerHole = HOLES M10i INNER
    xM10_DTCD = COPY EMPTY

    M10BigHole = SIZE M10InnerHole BY - excludeHoleSize/2
    M10ExcHole = ((M10InnerHole OUTSIDE M10BigHole) NOT M10i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK10 = (SIZE DM10EXCL BY (dm2DMEXCL + grid)) OR MIM10_x

    FRAMEA10 = (SIZE M10i BY (DM10_301 + grid)) OR (SIZE (EXPAND EDGE (M10i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA10OPC = SIZE M10i BY (DM10_OPC + grid)
    FRAMEA10OPCwide = SIZE (M10i WITH WIDTH > DM10_OPC_wide_w) BY (DM10_OPC_wide + grid)
    FRAMEA10OPC45 = SIZE (EXPAND EDGE (M10i ANGLE == 45) OUTSIDE BY DM10_OPC_45 EXTEND BY DM10_OPC_45_E) BY grid
    FRAMEA10OPC45DV = SIZE (EXPAND EDGE ((M10i INTERACT M10_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM10_OPC_45 EXTEND BY DM10_OPC_45_E) BY grid
    FRAMEA10OPC_M10_S_14_wide = SIZE (M10i WITH WIDTH > M10_S_14_wide_w) BY (M10_S_14_wide + grid)
    FRAMEA10OPC_M10_S_17_wide = SIZE (M10i WITH WIDTH > M10_S_17_wide_w) BY (M10_S_17_wide + grid)
    FRAMEA10OPC_M10_S_20_wide = SIZE (M10i WITH WIDTH > M10_S_20_wide_w) BY (M10_S_20_wide + grid)
    FRAMEA10OPC_M10_S_23_wide = SIZE (M10i WITH WIDTH > M10_S_23_wide_w) BY (M10_S_23_wide + grid)
    FRAMEA10OPC_M10_S_33_VIA9   = SIZE VIA9_HV_5V_CHK	BY (M10_S_33 + grid)
    FRAMEA10OPC_M10_S_33b_VIA9DV   = SIZE (VIA9i INTERACT (M9_HVN_330Vx OR M10_HVN_330Vx))	BY (M10_S_33b + grid)
    FRAMEA10OPC_M10_S_33_VIA10    = SIZE VIA10_HV_5V_CHK	BY (M10_S_33 + grid)
    FRAMEA10OPC_M10_S_33b_VIA10DV    = SIZE (VIA10i INTERACT (M10_HVN_330Vx OR M11_HVN_330Vx))	BY (M10_S_33b + grid)
    FRAMEA10OPC_M10_S_37_VIA9_b = SIZE VIA9i_55V		BY (M10_S_37 + grid)
    FRAMEA10OPC_M10_S_37a_VIA9_bDV = SIZE (VIA9i INTERACT (M9_HVN_500Vx OR M10_HVN_500Vx))		BY (M10_S_37a + grid)
    FRAMEA10OPC_M10_S_37_VIA10_b  = SIZE VIA10i_55V			BY (M10_S_37 + grid)
    FRAMEA10OPC_M10_S_37a_VIA10_bDV  = SIZE (VIA10i INTERACT (M10_HVN_500Vx OR M11_HVN_500Vx))		BY (M10_S_37a + grid)
    FRAMEA10OPC_M10_S_37_VIA9   = SIZE VIA9i_65V		BY (M10_S_37 + grid)
	FRAMEA10OPC_M10_S_37_VIA10    = SIZE VIA10i_65V			BY (M10_S_37 + grid)

    FRAMEHVD10 = SIZE  M10i_65V  BY (M10_S_38 + grid)
    FRAMEHVD10_55V = SIZE  M10i_55V  BY (M10_S_38 + grid)
    FRAMEHVD10_55VDV = SIZE  (M10i INTERACT M10_HVN_500Vx)  BY (M10_S_38a + grid)
    FRAMEB10 = SIZE (WITH WIDTH M10i > wideM10) BY (dm2WM10 + grid)
    FRAMEC10 = SIZE DUM10 BY (dm2DM10 + grid)
    FRAMED10 = SIZE (WITH WIDTH M10i > wideM10_small) BY (dm2WM10_small + grid)
    FRAMEC10OPC = SIZE DUM10 BY (Odm2DM10 + grid)
    FRAME10Pre = ((FRAMEA10 OR FRAMEB10) OR (FRAMEC10 OR FRAMED10)) OR M10ExcHole
    FRAME10PreOPC = (((((((((((((((((((((FRAMEA10OPC OR FRAMEC10OPC) OR M10ExcHole) OR FRAMEA10OPCwide) OR FRAMEA10OPC45) OR FRAMEA10OPC45DV) OR FRAMEA10OPC_M10_S_14_wide) OR FRAMEA10OPC_M10_S_17_wide) OR FRAMEA10OPC_M10_S_20_wide) OR FRAMEA10OPC_M10_S_23_wide) OR FRAMEA10OPC_M10_S_33_VIA9) OR FRAMEA10OPC_M10_S_33b_VIA9DV) OR FRAMEA10OPC_M10_S_33_VIA10) OR FRAMEA10OPC_M10_S_33b_VIA10DV) OR FRAMEHVD10) OR FRAMEA10OPC_M10_S_37_VIA9) OR FRAMEA10OPC_M10_S_37_VIA9_b) OR FRAMEA10OPC_M10_S_37a_VIA9_bDV) OR FRAMEA10OPC_M10_S_37_VIA10) OR FRAMEA10OPC_M10_S_37_VIA10_b) OR FRAMEA10OPC_M10_S_37a_VIA10_bDV) OR FRAMEHVD10_55V) OR FRAMEHVD10_55VDV


    FRAME10INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm10_s2m10_INDDMY + grid)
    FRAME10OPC = (((FRAME10PreOPC OR FRAME10INDDMY) OR xM10_DTCD) OR BLOCK10) OR NFILLOPC_x

    FRAME10 = (((FRAME10Pre OR FRAME10INDDMY) OR xM10_DTCD) OR BLOCK10) OR NFILL_x

    D30M10p = (PUSH D30M10) NOT FRAME10
    O30M10pre = D30M10p AND CHIP
    FD21M10s = COPY FRAME10

    O30M10preA = SIZE O30M10pre BY -DM10_303
    O30M10preB = O30M10preA WITH WIDTH >= WM10_303

    // 1st big
    F303M10 = RECTANGLES WM10_303 LM10_303 SM10_303 OFFSET OM10_303 INSIDE OF LAYER O30M10preB
    F303M10_SLOT = RECTANGLES WM10_303_SLOT LM10_303_SLOT SM10_303_SLOT INSIDE OF LAYER F303M10

    F303M10_EXP = SIZE F303M10_SLOT BY ( SM10_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M10preF1 = O30M10pre NOT (SIZE F303M10_EXP BY SM10_302)
    O30M10preF  = (SNAP (SIZE O30M10preF1 BY -grid) 5) AND O30M10preF1

    B30M10s = FD21M10s OR (SIZE F303M10_EXP BY (SM10_302+grid))
    O30M10 = O30M10preF NOT B30M10s

    // 3rd, middle
    F302M10 = RECTANGLES WM10_302 LM10_302 SM10_302 OFFSET OM10_302 INSIDE OF LAYER O30M10
    F302M10s = (SIZE F302M10 BY (SM10_301 + grid)) OR B30M10s
    R302M10pre = O30M10 NOT F302M10s
    R302M10 = WITH WIDTH R302M10pre >= WM10_301

    // 4th, small
    F3012M10 = RECTANGLES WM10_301 LM10_301 SM10_301 OFFSET OM10_301 INSIDE OF LAYER R302M10
    F3012M10s = (SIZE F3012M10 BY (SM10_301 + grid)) OR F302M10s
    R3012M10pre = R302M10pre NOT F3012M10s
    R3012M10 = WITH WIDTH R3012M10pre >= WM10_301

    // 5th, non-stagger small
    F301M10 = RECTANGLES WM10_301 LM10_301 SM10_301 INSIDE OF LAYER R3012M10 //MAINTAIN SPACING
    F301M10s = (SIZE F301M10 BY (SM10_301 + grid)) OR F3012M10s

    F30M10 = ((F302M10 OR F3012M10) OR F301M10) OR F303M10_SLOT
    O40M10pre = (((PUSH D40M10) NOT FRAME10) NOT F301M10s) AND CHIP


    O40M10preA = SIZE O40M10pre BY -DM10_403
    O40M10preB = O40M10preA WITH WIDTH >= WM10_403

    // 1st big
    F403M10 = RECTANGLES WM10_403 LM10_403 SM10_403 OFFSET OM10_403 INSIDE OF LAYER O40M10preB
    F403M10_SLOT = RECTANGLES WM10_403_SLOT LM10_403_SLOT SM10_403_SLOT INSIDE OF LAYER F403M10

    F403M10_EXP = SIZE F403M10_SLOT BY ( SM10_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M10preF1 = O40M10pre NOT (SIZE F403M10_EXP BY SM10_402)
    O40M10preF  = (SNAP (SIZE O40M10preF1 BY -grid) 5) AND O40M10preF1

    B40M10s = F301M10s OR (SIZE F403M10_EXP BY (SM10_402+grid))
    O40M10 = O40M10preF NOT B40M10s

    // 3rd, middle
    F402M10 = RECTANGLES WM10_402 LM10_402 SM10_402 OFFSET OM10_402 INSIDE OF LAYER O40M10
    F402M10s = (SIZE F402M10 BY (SM10_401 + grid)) OR B40M10s
    R402M10pre = O40M10 NOT F402M10s
    R402M10 = WITH WIDTH R402M10pre >= WM10_401

    // 4th, small
    F4012M10 = RECTANGLES WM10_401 LM10_401 SM10_401 OFFSET OM10_401 INSIDE OF LAYER R402M10
    F4012M10s = (SIZE F4012M10 BY (SM10_401 + grid)) OR F402M10s
    R4012M10pre = R402M10pre NOT F4012M10s
    R4012M10 = WITH WIDTH R4012M10pre >= WM10_401

    // 5th, non-stagger small
    F401M10 = RECTANGLES WM10_401 LM10_401 SM10_401 INSIDE OF LAYER R4012M10 //MAINTAIN SPACING
    F401M10s = (SIZE F401M10 BY (SM10_401 + grid)) OR F4012M10s

    F40M10 = ((F402M10 OR F4012M10) OR F401M10) OR F403M10_SLOT
    O50M10pre = (((PUSH (D50M10 OR emptyM10)) NOT FRAME10) NOT F401M10s) AND CHIP


    O50M10preA = SIZE O50M10pre BY -DM10_503
    O50M10preB = O50M10preA WITH WIDTH >= WM10_503

    // 1st big
    F503M10 = RECTANGLES WM10_503 LM10_503 SM10_503 OFFSET OM10_503 INSIDE OF LAYER O50M10preB
    F503M10_SLOT = RECTANGLES WM10_503_SLOT LM10_503_SLOT SM10_503_SLOT INSIDE OF LAYER F503M10

    F503M10_EXP = SIZE F503M10_SLOT BY ( SM10_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M10preF1 = O50M10pre NOT (SIZE F503M10_EXP BY SM10_502)
    O50M10preF  = (SNAP (SIZE O50M10preF1 BY -grid) 5) AND O50M10preF1

    B50M10s = F401M10s OR (SIZE F503M10_EXP BY (SM10_502+grid))
    O50M10 = O50M10preF NOT B50M10s

    // 3rd, middle
    F502M10 = RECTANGLES WM10_502 LM10_502 SM10_502 OFFSET OM10_502 INSIDE OF LAYER O50M10
    F502M10s = (SIZE F502M10 BY (SM10_501 + grid)) OR B50M10s
    R502M10pre = O50M10 NOT F502M10s
    R502M10 = WITH WIDTH R502M10pre >= WM10_501

    // 4th, small
    F5012M10 = RECTANGLES WM10_501 LM10_501 SM10_501 OFFSET OM10_501 INSIDE OF LAYER R502M10
    F5012M10s = (SIZE F5012M10 BY (SM10_501 + grid)) OR F502M10s
    R5012M10pre = R502M10pre NOT F5012M10s
    R5012M10 = WITH WIDTH R5012M10pre >= WM10_501

    // 5th, non-stagger small
    F501M10 = RECTANGLES WM10_501 LM10_501 SM10_501 INSIDE OF LAYER R5012M10 //MAINTAIN SPACING
    F501M10s = (SIZE F501M10 BY (SM10_501 + grid)) OR F5012M10s

    F50M10 = ((F502M10 OR F5012M10) OR F501M10) OR F503M10_SLOT

    exceedM10 = DENSITY M10x F30M10 F40M10 F50M10 > maxD_M10 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M10.den_exceed

    removeM10R = ((PUSH (exceedM10 AND (D50M10 OR emptyM10))) NOT FRAME10) AND CHIP
    removeM10P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM10R

    F30M10x = F30M10 NOT INTERACT removeM10P
    F40M10x = F40M10 NOT INTERACT removeM10P
    F50M10x = F50M10 NOT INTERACT removeM10P
    FM10xA  = (F30M10x OR F40M10x) OR F50M10x
    FM10x   = FM10xA NOT INTERACT (EXT FM10xA < DM10_S_1 ABUT SINGULAR REGION)

    ALLM10x = M10x OR FM10x
    lackM10 = DENSITY ALLM10x CHIP < DM10_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M10.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM10x)/AREA(CHIP) ]

    WDM10EXC = DUM10 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM10EXC = (SIZE FM10x BY Odm2DM10) OR (SIZE (((F303M10_EXP OR F403M10_EXP) OR F503M10_EXP) OR WDM10EXC) BY 1.5)

    lackM10pRM = ((((PUSH lackM10) NOT RM10EXC) NOT FRAME10OPC) NOT exceedM10) AND CHIP
    lackM10pRM_1 = WITH WIDTH lackM10pRM >= SM10_OPC

    RM10p1 = RECTANGLES WM10_OPC LM10_OPC WSM10_OPC LSM10_OPC INSIDE OF LAYER lackM10pRM_1
    lackM10pRM_2 = lackM10pRM_1 NOT (SIZE RM10p1 BY SM10_OPC)
    RM10p2 = RECTANGLES LM10_OPC WM10_OPC LSM10_OPC WSM10_OPC INSIDE OF LAYER lackM10pRM_2

    ODM10A = ((RM10p1 OR RM10p2) OUTSIDE RM10EXC) OUTSIDE FRAME10OPC
    ODM10F_pre = ODM10A NOT INTERACT (EXT ODM10A < SM10_OPC ABUT SINGULAR REGION)

// M10.S.14 ~ M10.S.16
M10_S_14_CHK_REGION = M10i OR ODM10F_pre
// Find Wide Metal
Wide_M10_S_14_CHK_REGION = ENCLOSE RECTANGLE (M10_S_14_CHK_REGION NOT WITH WIDTH <= M10_S_14_W1B) M10_S_14_W1B+GRID M10_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M10_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M10_S_14_CHK_REGION == 0
Wide_M10_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M10_S_14_CHK_REGION == 90

// Find Wide Metal Space
M10_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M10_S_14_CHK_REGION_EDGE_H M10_S_14_CHK_REGION < M10_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M10_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M10_S_14_CHK_REGION_EDGE_V M10_S_14_CHK_REGION < M10_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M10_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M10_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M10_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M10_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M10_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M10_S_14_CHK_REGION_OPC_REGION_pre1_H M10_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M10_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M10_S_14_L1B
M10_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M10_S_14_CHK_REGION_OPC_REGION_pre1_V M10_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M10_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M10_S_14_L1B

M10_S_14_OPC_REGION = M10_S_14_CHK_REGION_OPC_REGION_pre2_H OR M10_S_14_CHK_REGION_OPC_REGION_pre2_V

// M10.S.17 ~ M10.S.19
M10_S_17_CHK_REGION = M10i OR ODM10F_pre
// Find Wide Metal
Wide_M10_S_17_CHK_REGION = ENCLOSE RECTANGLE (M10_S_17_CHK_REGION NOT WITH WIDTH <= M10_S_17_W1B) M10_S_17_W1B+GRID M10_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M10_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M10_S_17_CHK_REGION == 0
Wide_M10_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M10_S_17_CHK_REGION == 90

// Find Wide Metal Space
M10_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M10_S_17_CHK_REGION_EDGE_H M10_S_17_CHK_REGION < M10_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M10_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M10_S_17_CHK_REGION_EDGE_V M10_S_17_CHK_REGION < M10_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M10_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M10_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M10_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M10_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M10_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M10_S_17_CHK_REGION_OPC_REGION_pre1_H M10_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M10_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M10_S_17_L1B
M10_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M10_S_17_CHK_REGION_OPC_REGION_pre1_V M10_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M10_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M10_S_17_L1B

M10_S_17_OPC_REGION = M10_S_17_CHK_REGION_OPC_REGION_pre2_H OR M10_S_17_CHK_REGION_OPC_REGION_pre2_V

// M10.S.20 ~ M10.S.22
M10_S_20_CHK_REGION = M10i OR ODM10F_pre
// Find Wide Metal
Wide_M10_S_20_CHK_REGION = ENCLOSE RECTANGLE (M10_S_20_CHK_REGION NOT WITH WIDTH <= M10_S_20_W1B) M10_S_20_W1B+GRID M10_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M10_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M10_S_20_CHK_REGION == 0
Wide_M10_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M10_S_20_CHK_REGION == 90

// Find Wide Metal Space
M10_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M10_S_20_CHK_REGION_EDGE_H M10_S_20_CHK_REGION < M10_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M10_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M10_S_20_CHK_REGION_EDGE_V M10_S_20_CHK_REGION < M10_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M10_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M10_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M10_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M10_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M10_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M10_S_20_CHK_REGION_OPC_REGION_pre1_H M10_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M10_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M10_S_20_L1B
M10_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M10_S_20_CHK_REGION_OPC_REGION_pre1_V M10_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M10_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M10_S_20_L1B

M10_S_20_OPC_REGION = M10_S_20_CHK_REGION_OPC_REGION_pre2_H OR M10_S_20_CHK_REGION_OPC_REGION_pre2_V

// M10.S.23 ~ M10.S.25
M10_S_23_CHK_REGION = M10i OR ODM10F_pre
// Find Wide Metal
Wide_M10_S_23_CHK_REGION = ENCLOSE RECTANGLE (M10_S_23_CHK_REGION NOT WITH WIDTH <= M10_S_23_W1B) M10_S_23_W1B+GRID M10_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M10_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M10_S_23_CHK_REGION == 0
Wide_M10_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M10_S_23_CHK_REGION == 90

// Find Wide Metal Space
M10_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M10_S_23_CHK_REGION_EDGE_H M10_S_23_CHK_REGION < M10_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M10_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M10_S_23_CHK_REGION_EDGE_V M10_S_23_CHK_REGION < M10_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M10_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M10_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M10_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M10_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M10_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M10_S_23_CHK_REGION_OPC_REGION_pre1_H M10_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M10_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M10_S_23_L1B
M10_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M10_S_23_CHK_REGION_OPC_REGION_pre1_V M10_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M10_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M10_S_23_L1B

M10_S_23_OPC_REGION = M10_S_23_CHK_REGION_OPC_REGION_pre2_H OR M10_S_23_CHK_REGION_OPC_REGION_pre2_V

// M10.S.27
M10_S_27_CHK_REGION = M10i OR ODM10F_pre
// Find Wide Metal
Wide_M10_S_27_CHK_REGION = ENCLOSE RECTANGLE (M10_S_27_CHK_REGION NOT WITH WIDTH <= M10_S_27_W1B) M10_S_27_W1B+GRID M10_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M10_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M10_S_27_CHK_REGION == 0
Wide_M10_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M10_S_27_CHK_REGION == 90

// Find Wide Metal Space
M10_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M10_S_27_CHK_REGION_EDGE_H M10_S_27_CHK_REGION < M10_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M10_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M10_S_27_CHK_REGION_EDGE_V M10_S_27_CHK_REGION < M10_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M10_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M10_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M10_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M10_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M10_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M10_S_27_CHK_REGION_OPC_REGION_pre1_H M10_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M10_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M10_S_27_L1B
M10_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M10_S_27_CHK_REGION_OPC_REGION_pre1_V M10_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M10_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M10_S_27_L1B

M10_S_27_OPC_REGION = M10_S_27_CHK_REGION_OPC_REGION_pre2_H OR M10_S_27_CHK_REGION_OPC_REGION_pre2_V

M10_WMJ_OPC_REGION = (((M10_S_14_OPC_REGION OR M10_S_17_OPC_REGION) OR M10_S_20_OPC_REGION) OR M10_S_23_OPC_REGION) OR M10_S_27_OPC_REGION

    ODM10F = ODM10F_pre NOT INTERACT M10_WMJ_OPC_REGION

    DM10F = COPY FM10x

    FRAME10_INDDMYA = SIZE M10i BY (dm10_s2m10_INDDMY + grid)
    FRAME10_INDDMYB = SIZE DUM10 BY (dm10_s_INDDMY + grid)
    FRAME10_INDDMYC = SIZE DM10F BY dm10_s_INDDMY
    FRAME10_INDDMYD = SIZE ODM10F BY dm10_s2m10_INDDMY

    FRAME10_INDDMY  = ((((((FRAME10Pre OR xM10_DTCD) OR BLOCK10) OR FRAME10_INDDMYA) OR FRAME10_INDDMYB) OR FRAME10_INDDMYC) OR FRAME10_INDDMYD) OR NFILL_x
    FILL10_INDDMY   = ooINDDMY NOT FRAME10_INDDMY
    DM10F_INDDMY    = RECTANGLES dm10_w_INDDMY dm10_l_INDDMY dm10_s_INDDMY INSIDE OF LAYER FILL10_INDDMY

#IFDEF FILL_indDM10
    FILL10_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm10_s_INDDMY_HD + grid)) NOT FRAME10_INDDMY
    DM10F_INDDMY_HD_pre  = RECTANGLES dm10_w_INDDMY_HD dm10_l_INDDMY_HD dm10_s_INDDMY_HD INSIDE OF LAYER FILL10_INDDMY_HD

    FILL10_INDDMY_MD = (SIZE INDDMY_MD BY -(dm10_s_INDDMY_MD + grid)) NOT (FRAME10_INDDMY OR INDDMY_HD)
    DM10F_INDDMY_MD  = RECTANGLES dm10_w_INDDMY_MD dm10_l_INDDMY_MD dm10_s_INDDMY_MD INSIDE OF LAYER FILL10_INDDMY_MD

    DM10F_INDDMY_HD = DM10F_INDDMY_HD_pre OR DM10F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#IFDEF FILL_DM11


#IFDEF 34K_THICK_Mu_M11

    minOPENM11 = DENSITY M11x < minD_M11 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M11Min.den
    emptyOPENM11 = DENSITY M11x < emptyD_M11 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M11Empty.den

    M11InnerHole = HOLES M11i INNER

    M11BigHole = SIZE M11InnerHole BY - excludeHoleSize/2
    M11ExcHole = ((M11InnerHole OUTSIDE M11BigHole) NOT M11i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK11    = (SIZE DM11EXCL BY (dm2DMEXCL + grid)) OR MIM11_x
    FRAMEA11   = SIZE M11i BY (dm2M11 + grid) // DM11 to metal
    FRAMEB11   = SIZE (WITH WIDTH M11i > wideM11) BY (dm2WM11 + grid)
    FRAMEC11   = SIZE DUM11 BY (dm2DM11 + grid)
    FRAME11Pre = ((FRAMEA11 OR FRAMEB11) OR FRAMEC11) OR M11ExcHole
    FRAME11INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm11_s2m11_INDDMY + grid)
    FRAME11 = ((FRAME11Pre OR FRAME11INDDMY) OR BLOCK11) OR NFILL
    
    OPENM11 = PUSH ((minOPENM11 OR emptyOPENM11) AND CHIP)
    FILL11 = OPENM11 NOT FRAME11
    FILLW11pre = SIZE FILL11 BY - (Wdm2M11 + grid)
    FILLW11 = WITH WIDTH FILLW11pre >= WdmW_M11
    M11FW = RECTANGLES WdmW_M11 WdmL_M11 WdmS_M11 OFFSET WdmO_M11 INSIDE OF LAYER FILLW11
    M11FW_EXP = SIZE M11FW BY (WdmS_M11 /2 + grid) OVERUNDER   // merge the gaps
    FILLM11pre = FILL11 NOT (SIZE M11FW_EXP BY (MdmS_M11 + grid))
    FILLM11 = WITH WIDTH FILLM11pre >= MdmW_M11
    M11F1 = RECTANGLES MdmW_M11 MdmL_M11 MdmS_M11 OFFSET MdmO_M11 INSIDE OF LAYER FILLM11
    M11R1pre = FILLM11pre NOT (SIZE M11F1 BY (dmS_M11 + grid))
    M11R1 = WITH WIDTH M11R1pre >= dmW_M11

    M11F2 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 OFFSET dmO_M11 INSIDE OF LAYER M11R1
    M11R2pre = M11R1 NOT (SIZE M11F2 BY (dmS_M11 + grid))
    M11R2 = WITH WIDTH M11R2pre >= dmW_M11

    M11F3 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 OFFSET dmO_M11 INSIDE OF LAYER M11R2
    M11R3pre = M11R2 NOT (SIZE M11F3 BY (dmS_M11 + grid))
    M11R3 = WITH WIDTH M11R3pre >= dmW_M11

    M11F4 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 INSIDE OF LAYER M11R3

    M11F = (((M11F1 OR M11F2) OR M11F3) OR M11F4) OR M11FW
    FM11 = M11F NOT INTERACT (EXT M11F < dmS_M11 ABUT SINGULAR REGION)

    maxOPENM11 = DENSITY M11x FM11 > maxD_M11 WINDOW WindowSizeu*2 STEP WindowStepu*2
                INSIDE OF LAYER bulk BACKUP // PRINT M11Max.den

    DM11F = FM11 OUTSIDE maxOPENM11

    FRAME11_INDDMYA = SIZE M11i BY (dm11_s2m11_INDDMY + grid)
    FRAME11_INDDMYB = SIZE DUM11 BY (dm11_s_INDDMY + grid)
    FRAME11_INDDMYC = SIZE DM11F BY dm11_s_INDDMY
    FRAME11_INDDMY  = ((((FRAME11Pre OR BLOCK11) OR FRAME11_INDDMYA) OR FRAME11_INDDMYB) OR FRAME11_INDDMYC) OR NFILL
    FILL11_INDDMY   = ooINDDMY NOT FRAME11_INDDMY
    DM11F_INDDMY    = RECTANGLES dm11_w_INDDMY dm11_l_INDDMY dm11_s_INDDMY INSIDE OF LAYER FILL11_INDDMY
#IFDEF FILL_indDM11
    FILL11_INDDMY_HD = (SIZE INDDMY_HD BY -(dm11_s_INDDMY_HD + grid)) NOT FRAME11_INDDMY
    DM11F_INDDMY_HD  = RECTANGLES dm11_w_INDDMY_HD dm11_l_INDDMY_HD dm11_s_INDDMY_HD INSIDE OF LAYER FILL11_INDDMY_HD
#ENDIF	
	
#ELSE


#IFDEF 12K_THICK_Mr_M11

    minOPENM11 = DENSITY M11x < minD_M11 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M11Min.den
    emptyOPENM11 = DENSITY M11x < emptyD_M11 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M11Empty.den

    M11InnerHole = HOLES M11i INNER

    M11BigHole = SIZE M11InnerHole BY - excludeHoleSize/2
    M11ExcHole = ((M11InnerHole OUTSIDE M11BigHole) NOT M11i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK11  = (SIZE DM11EXCL BY (dm2DMEXCL + grid)) OR MIM11_x // DM11 to DM11EXCL
    FRAMEA11 = SIZE M11i BY (dm2M11 + grid) // DM11 to metal
    FRAMEB11 = SIZE (WITH WIDTH M11i > wideM11) BY (dm2WM11 + grid)
    FRAMEC11 = SIZE DUM11 BY (dm2DM11 + grid)   // DM11 to existed dummy metal 0.6um
    FRAME11Pre = ((FRAMEA11 OR FRAMEB11) OR FRAMEC11) OR M11ExcHole
    FRAME11INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm11_s2m11_INDDMY + grid)
    FRAME11 = ((FRAME11Pre OR FRAME11INDDMY) OR BLOCK11) OR NFILL
    
    OPENM11 = PUSH ((minOPENM11 OR emptyOPENM11) AND CHIP)
    FILL11 = OPENM11 NOT FRAME11
    FILLW11pre = SIZE FILL11 BY - (Wdm2M11 + grid)
    FILLW11 = WITH WIDTH FILLW11pre >= WdmW_M11
    M11FW = RECTANGLES WdmW_M11 WdmL_M11 WdmS_M11 OFFSET WdmO_M11 INSIDE OF LAYER FILLW11
    M11FW_EXP = SIZE M11FW BY (WdmS_M11 /2 + grid) OVERUNDER //merge the gaps
    FILLM11pre = FILL11 NOT (SIZE M11FW_EXP BY (MdmS_M11 + grid))
    FILLM11 = WITH WIDTH FILLM11pre >= MdmW_M11
    M11F1 = RECTANGLES MdmW_M11 MdmL_M11 MdmS_M11 OFFSET MdmO_M11 INSIDE OF LAYER FILLM11
    M11R1pre = FILLM11pre NOT (SIZE M11F1 BY (dmS_M11 + grid))
    M11R1 = WITH WIDTH M11R1pre >= dmW_M11

    M11F2 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 OFFSET dmO_M11 INSIDE OF LAYER M11R1
    M11R2pre = M11R1 NOT (SIZE M11F2 BY (dmS_M11 + grid))
    M11R2 = WITH WIDTH M11R2pre >= dmW_M11

    M11F3 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 OFFSET dmO_M11 INSIDE OF LAYER M11R2
    M11R3pre = M11R2 NOT (SIZE M11F3 BY (dmS_M11 + grid))
    M11R3 = WITH WIDTH M11R3pre >= dmW_M11

    M11F4 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 INSIDE OF LAYER M11R3

    M11F = (((M11F1 OR M11F2) OR M11F3) OR M11F4) OR M11FW
    FM11 = M11F NOT INTERACT (EXT M11F < dmS_M11 ABUT SINGULAR REGION)

    maxOPENM11 = DENSITY M11x FM11 > maxD_M11 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M11Max.den

    FM11F = FM11 OUTSIDE maxOPENM11

    // DMr_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M11 = DENSITY M11x FM11F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M11Min.den

    RM11EXC = SIZE FM11F BY (Odm2DM11 + grid)
    // do not fill DMy_S over CTMDMY
    D25M11pM = (((PUSH D25M11) NOT FRAME11) NOT RM11EXC) AND CHIP
    D25M11pM_1 = WITH WIDTH D25M11pM >= OdmW_M11

    RM11p1 = RECTANGLES OdmW_M11 OdmL_M11 OdmS_M11 INSIDE OF LAYER D25M11pM_1
    D25M11pM_2 = D25M11pM_1 NOT (SIZE RM11p1 BY (OdmS_M11 + grid))
    RM11p2 = RECTANGLES OdmL_M11 OdmW_M11 OdmS_M11 INSIDE OF LAYER D25M11pM_2

    RM11A = ((RM11p1 OR RM11p2) OUTSIDE RM11EXC) OUTSIDE FRAME11
    RM11  = RM11A NOT INTERACT (EXT RM11A < OdmS_M11 ABUT SINGULAR REGION)

    DM11F = FM11F OR RM11

    FRAME11_INDDMYA = SIZE M11i BY (dm11_s2m11_INDDMY + grid)
    FRAME11_INDDMYB = SIZE DUM11 BY (dm11_s_INDDMY + grid)
    FRAME11_INDDMYC = SIZE DM11F BY dm11_s_INDDMY
    FRAME11_INDDMY  = ((((FRAME11Pre OR BLOCK11) OR FRAME11_INDDMYA) OR FRAME11_INDDMYB) OR FRAME11_INDDMYC) OR NFILL
    FILL11_INDDMY   = ooINDDMY NOT FRAME11_INDDMY
    DM11F_INDDMY    = RECTANGLES dm11_w_INDDMY dm11_l_INDDMY dm11_s_INDDMY INSIDE OF LAYER FILL11_INDDMY

#IFDEF FILL_indDM11
    FILL11_INDDMY_HD = (SIZE INDDMY_HD BY -(dm11_s_INDDMY_HD + grid)) NOT FRAME11_INDDMY
    DM11F_INDDMY_HD  = RECTANGLES dm11_w_INDDMY_HD dm11_l_INDDMY_HD dm11_s_INDDMY_HD INSIDE OF LAYER FILL11_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 5K_THICK_Myz_M11

    minOPENM11 = DENSITY M11x < minD_M11 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M11Min.den
    emptyOPENM11 = DENSITY M11x < emptyD_M11 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M11Empty.den

    M11InnerHole = HOLES M11i INNER

    M11BigHole = SIZE M11InnerHole BY - excludeHoleSize/2
    M11ExcHole = ((M11InnerHole OUTSIDE M11BigHole) NOT M11i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK11 = (SIZE DM11EXCL BY (dm2DMEXCL + grid)) OR MIM11_x // DM11 to DM11EXCL
    FRAMEA11 = SIZE M11i BY (dm2M11 + grid) // DM11 to metal
    FRAMEB11 = SIZE (WITH WIDTH M11i > wideM11) BY (dm2WM11 + grid)
    FRAMEC11 = SIZE DUM11 BY (dm2DM11 + grid)   // DM11 to existed dummy metal 0.6um
    FRAME11Pre = ((FRAMEA11 OR FRAMEB11) OR FRAMEC11) OR M11ExcHole
    FRAME11INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm11_s2m11_INDDMY + grid)
    FRAME11 = ((FRAME11Pre OR FRAME11INDDMY) OR BLOCK11) OR NFILL
    
    OPENM11 = PUSH ((minOPENM11 OR emptyOPENM11) AND CHIP)
    FILL11 = OPENM11 NOT FRAME11
    FILLW11pre = SIZE FILL11 BY - (Wdm2M11 + grid)
    FILLW11 = WITH WIDTH FILLW11pre >= WdmW_M11
    M11FW = RECTANGLES WdmW_M11 WdmL_M11 WdmS_M11 OFFSET WdmO_M11 INSIDE OF LAYER FILLW11
    M11FW_EXP = SIZE M11FW BY (WdmS_M11 /2 + grid) OVERUNDER //merge the gaps
    FILLM11pre = FILL11 NOT (SIZE M11FW_EXP BY (MdmS_M11 + grid))
    FILLM11 = WITH WIDTH FILLM11pre >= MdmW_M11
    M11F1 = RECTANGLES MdmW_M11 MdmL_M11 MdmS_M11 OFFSET MdmO_M11 INSIDE OF LAYER FILLM11
    M11R1pre = FILLM11pre NOT (SIZE M11F1 BY (dmS_M11 + grid))
    M11R1 = WITH WIDTH M11R1pre >= dmW_M11

    M11F2 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 OFFSET dmO_M11 INSIDE OF LAYER M11R1
    M11R2pre = M11R1 NOT (SIZE M11F2 BY (dmS_M11 + grid))
    M11R2 = WITH WIDTH M11R2pre >= dmW_M11

    M11F3 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 OFFSET dmO_M11 INSIDE OF LAYER M11R2
    M11R3pre = M11R2 NOT (SIZE M11F3 BY (dmS_M11 + grid))
    M11R3 = WITH WIDTH M11R3pre >= dmW_M11

    M11F4 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 INSIDE OF LAYER M11R3

