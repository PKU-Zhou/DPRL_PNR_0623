    M11InnerHole = HOLES M11i INNER

    M11BigHole = SIZE M11InnerHole BY - excludeHoleSize/2
    M11ExcHole = ((M11InnerHole OUTSIDE M11BigHole) NOT M11i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK11 = (SIZE DM11EXCL BY (dm2DMEXCL + grid)) OR  MIM11_x // DM11 to DM11EXCL
    FRAMEA11 = SIZE M11i BY (dm2M11 + grid) // DM11 to metal
    FRAMEB11 = SIZE (WITH WIDTH M11i > wideM11) BY (dm2WM11 + grid)
    FRAMEC11 = SIZE DUM11 BY (dm2DM11 + grid)   // DM11 to existed dummy metal 0.6um
    FRAME11Pre = ((FRAMEA11 OR FRAMEB11) OR FRAMEC11) OR M11ExcHole
    FRAME11INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm11_s2m11_INDDMY + grid)
    FRAME11 = ((FRAME11Pre OR FRAME11INDDMY) OR BLOCK11) OR NFILL
    
    OPENM11 = PUSH ((minOPENM11 OR emptyOPENM11) AND CHIP)
    FILL11 = OPENM11 NOT FRAME11
    FILLW11pre = SIZE FILL11 BY - (Wdm2M11 + grid)
    FILLW11 = WITH WIDTH FILLW11pre >= WdmW_M11
    M11FW = RECTANGLES WdmW_M11 WdmL_M11 WdmS_M11 OFFSET WdmO_M11 INSIDE OF LAYER FILLW11
    M11FW_EXP = SIZE M11FW BY (WdmS_M11 /2 + grid) OVERUNDER //merge the gaps
    FILLM11pre = FILL11 NOT (SIZE M11FW_EXP BY (MdmS_M11 + grid))
    FILLM11 = WITH WIDTH FILLM11pre >= MdmW_M11
    M11F1 = RECTANGLES MdmW_M11 MdmL_M11 MdmS_M11 OFFSET MdmO_M11 INSIDE OF LAYER FILLM11
    M11R1pre = FILLM11pre NOT (SIZE M11F1 BY (dmS_M11 + grid))
    M11R1 = WITH WIDTH M11R1pre >= dmW_M11

    M11F2 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 OFFSET dmO_M11 INSIDE OF LAYER M11R1
    M11R2pre = M11R1 NOT (SIZE M11F2 BY (dmS_M11 + grid))
    M11R2 = WITH WIDTH M11R2pre >= dmW_M11

    M11F3 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 OFFSET dmO_M11 INSIDE OF LAYER M11R2
    M11R3pre = M11R2 NOT (SIZE M11F3 BY (dmS_M11 + grid))
    M11R3 = WITH WIDTH M11R3pre >= dmW_M11

    M11F4 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 INSIDE OF LAYER M11R3

    M11F = (((M11F1 OR M11F2) OR M11F3) OR M11F4) OR M11FW
    FM11 = M11F NOT INTERACT (EXT M11F < dmS_M11 ABUT SINGULAR REGION)

    maxOPENM11 = DENSITY M11x FM11 > maxD_M11 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M11Max.den

    FM11F = FM11 OUTSIDE maxOPENM11

    D25M11 = DENSITY M11x FM11F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M11Min.den

    RM11EXC = SIZE FM11F BY (Odm2DM11 + grid)
    D25M11pM = (((PUSH D25M11) NOT FRAME11) NOT RM11EXC) AND CHIP
    D25M11pM_1 = WITH WIDTH D25M11pM >= OdmW_M11

    RM11p1 = RECTANGLES OdmW_M11 OdmL_M11 OdmS_M11 INSIDE OF LAYER D25M11pM_1
    D25M11pM_2 = D25M11pM_1 NOT (SIZE RM11p1 BY (OdmS_M11 + grid))
    RM11p2 = RECTANGLES OdmL_M11 OdmW_M11 OdmS_M11 INSIDE OF LAYER D25M11pM_2

    RM11A = ((RM11p1 OR RM11p2) OUTSIDE RM11EXC) OUTSIDE FRAME11
    RM11  = RM11A NOT INTERACT (EXT RM11A < OdmS_M11 ABUT SINGULAR REGION)

    DM11F = FM11F OR RM11

    FRAME11_INDDMYA = SIZE M11i BY (dm11_s2m11_INDDMY + grid)
    FRAME11_INDDMYB = SIZE DUM11 BY (dm11_s_INDDMY + grid)
    FRAME11_INDDMYC = SIZE DM11F BY dm11_s_INDDMY
    FRAME11_INDDMY  = ((((FRAME11Pre OR BLOCK11) OR FRAME11_INDDMYA) OR FRAME11_INDDMYB) OR FRAME11_INDDMYC) OR NFILL
    FILL11_INDDMY   = ooINDDMY NOT FRAME11_INDDMY
    DM11F_INDDMY    = RECTANGLES dm11_w_INDDMY dm11_l_INDDMY dm11_s_INDDMY INSIDE OF LAYER FILL11_INDDMY

#IFDEF FILL_indDM11
    FILL11_INDDMY_HD = (SIZE INDDMY_HD BY -(dm11_s_INDDMY_HD + grid)) NOT FRAME11_INDDMY
    DM11F_INDDMY_HD  = RECTANGLES dm11_w_INDDMY_HD dm11_l_INDDMY_HD dm11_s_INDDMY_HD INSIDE OF LAYER FILL11_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M11

    D30M11 = DENSITY M11x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M11.den30
    D40M11 = DENSITY M11x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M11.den40
    D50M11 = DENSITY M11x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M11.den50
    emptyM11 = DENSITY M11x < emptyD_M11 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M11.den_empty

    M11InnerHole = HOLES M11i INNER

    M11BigHole = SIZE M11InnerHole BY - excludeHoleSize/2
    M11ExcHole = ((M11InnerHole OUTSIDE M11BigHole) NOT M11i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK11 = (SIZE DM11EXCL BY (dm2DMEXCL + grid)) OR MIM11_x

    FRAMEA11 = (SIZE M11i BY (DM11_301 + grid)) OR (SIZE (EXPAND EDGE (M11i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA11OPC = SIZE M11i BY (DM11_OPC + grid)
    FRAMEA11OPCDV33 = SIZE (M11i INTERACT M11_HVN_330Vx) BY (M11_S_1_1_a + grid)
    FRAMEA11OPCDV5 = SIZE (M11i INTERACT M11_HVN_500Vx) BY (M11_S_9_a + grid)
    FRAMEA11OPC45 = SIZE (EXPAND EDGE (M11i ANGLE == 45) OUTSIDE BY DM11_OPC_45 EXTEND BY DM11_OPC_45_E) BY grid
    FRAMEA11OPC45DV = SIZE (EXPAND EDGE ((M11i INTERACT M11_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM11_OPC_45 EXTEND BY DM11_OPC_45_E) BY grid

    FRAMEB11 = SIZE (WITH WIDTH M11i > wideM11) BY (dm2WM11 + grid)
    FRAMEC11 = SIZE DUM11 BY (dm2DM11 + grid)
    FRAMED11 = SIZE (WITH WIDTH M11i > wideM11_small) BY (dm2WM11_small + grid)
    FRAMEC11OPC = SIZE DUM11 BY (Odm2DM11 + grid)
    FRAME11Pre = ((FRAMEA11 OR FRAMEB11) OR (FRAMEC11 OR FRAMED11)) OR M11ExcHole
    FRAME11PreOPC = (((((((FRAMEA11OPC OR FRAMEA11OPCDV33) OR FRAMEA11OPCDV5) OR FRAMEC11OPC) OR M11ExcHole) OR FRAMEA11OPC45) OR FRAMEA11OPC45DV) OR FRAMEB11) OR FRAMED11
    FRAME11INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm11_s2m11_INDDMY + grid)

    FRAME11OPC = ((FRAME11PreOPC OR FRAME11INDDMY) OR BLOCK11) OR NFILLOPC

    FRAME11 = ((FRAME11Pre OR FRAME11INDDMY) OR BLOCK11) OR NFILL

    //****************************************************************************

    D30M11p = (PUSH D30M11) NOT FRAME11
    O30M11pre = D30M11p AND CHIP
    FD21M11s = COPY FRAME11

    O30M11preA = SIZE O30M11pre BY -DM11_303
    O30M11preB = O30M11preA WITH WIDTH >= WM11_303

    // 1st big
    F303M11 = RECTANGLES WM11_303 LM11_303 SM11_303 OFFSET OM11_303 INSIDE OF LAYER O30M11preB

    F303M11_EXP = SIZE F303M11 BY ( SM11_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M11preF1 = O30M11pre NOT (SIZE F303M11_EXP BY SM11_302)
    O30M11preF  = (SNAP (SIZE O30M11preF1 BY -grid) 5) AND O30M11preF1

    B30M11s = FD21M11s OR (SIZE F303M11_EXP BY (SM11_302+grid))
    O30M11 = O30M11preF NOT B30M11s

    // 3rd, middle
    F302M11 = RECTANGLES WM11_302 LM11_302 SM11_302 OFFSET OM11_302 INSIDE OF LAYER O30M11
    F302M11s = (SIZE F302M11 BY (SM11_301 + grid)) OR B30M11s
    R302M11pre = O30M11 NOT F302M11s
    R302M11 = WITH WIDTH R302M11pre >= WM11_301

    // 4th, small
    F3012M11 = RECTANGLES WM11_301 LM11_301 SM11_301 OFFSET OM11_301 INSIDE OF LAYER R302M11
    F3012M11s = (SIZE F3012M11 BY (SM11_301 + grid)) OR F302M11s
    R3012M11pre = R302M11pre NOT F3012M11s
    R3012M11 = WITH WIDTH R3012M11pre >= WM11_301

    // 5th, non-stagger small
    F301M11 = RECTANGLES WM11_301 LM11_301 SM11_301 INSIDE OF LAYER R3012M11 //MAINTAIN SPACING
    F301M11s = (SIZE F301M11 BY (SM11_301 + grid)) OR F3012M11s

    F30M11 = ((F302M11 OR F3012M11) OR F301M11) OR F303M11
    O40M11pre = (((PUSH D40M11) NOT FRAME11) NOT F301M11s) AND CHIP


    O40M11preA = SIZE O40M11pre BY -DM11_403
    O40M11preB = O40M11preA WITH WIDTH >= WM11_403

    // 1st big
    F403M11 = RECTANGLES WM11_403 LM11_403 SM11_403 OFFSET OM11_403 INSIDE OF LAYER O40M11preB

    F403M11_EXP = SIZE F403M11 BY ( SM11_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M11preF1 = O40M11pre NOT (SIZE F403M11_EXP BY SM11_402)
    O40M11preF  = (SNAP (SIZE O40M11preF1 BY -grid) 5) AND O40M11preF1

    B40M11s = F301M11s OR (SIZE F403M11_EXP BY (SM11_402+grid))
    O40M11 = O40M11preF NOT B40M11s

    // 3rd, middle
    F402M11 = RECTANGLES WM11_402 LM11_402 SM11_402 OFFSET OM11_402 INSIDE OF LAYER O40M11
    F402M11s = (SIZE F402M11 BY (SM11_401 + grid)) OR B40M11s
    R402M11pre = O40M11 NOT F402M11s
    R402M11 = WITH WIDTH R402M11pre >= WM11_401

    // 4th, small
    F4012M11 = RECTANGLES WM11_401 LM11_401 SM11_401 OFFSET OM11_401 INSIDE OF LAYER R402M11
    F4012M11s = (SIZE F4012M11 BY (SM11_401 + grid)) OR F402M11s
    R4012M11pre = R402M11pre NOT F4012M11s
    R4012M11 = WITH WIDTH R4012M11pre >= WM11_401

    // 5th, non-stagger small
    F401M11 = RECTANGLES WM11_401 LM11_401 SM11_401 INSIDE OF LAYER R4012M11 //MAINTAIN SPACING
    F401M11s = (SIZE F401M11 BY (SM11_401 + grid)) OR F4012M11s

    F40M11 = ((F402M11 OR F4012M11) OR F401M11) OR F403M11
    O50M11pre = (((PUSH (D50M11 OR emptyM11)) NOT FRAME11) NOT F401M11s) AND CHIP


    O50M11preA = SIZE O50M11pre BY -DM11_503
    O50M11preB = O50M11preA WITH WIDTH >= WM11_503

    // 1st big
    F503M11 = RECTANGLES WM11_503 LM11_503 SM11_503 OFFSET OM11_503 INSIDE OF LAYER O50M11preB

    F503M11_EXP = SIZE F503M11 BY ( SM11_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M11preF1 = O50M11pre NOT (SIZE F503M11_EXP BY SM11_502)
    O50M11preF  = (SNAP (SIZE O50M11preF1 BY -grid) 5) AND O50M11preF1

    B50M11s = F401M11s OR (SIZE F503M11_EXP BY (SM11_502+grid))
    O50M11 = O50M11preF NOT B50M11s

    // 3rd, middle
    F502M11 = RECTANGLES WM11_502 LM11_502 SM11_502 OFFSET OM11_502 INSIDE OF LAYER O50M11
    F502M11s = (SIZE F502M11 BY (SM11_501 + grid)) OR B50M11s
    R502M11pre = O50M11 NOT F502M11s
    R502M11 = WITH WIDTH R502M11pre >= WM11_501

    // 4th, small
    F5012M11 = RECTANGLES WM11_501 LM11_501 SM11_501 OFFSET OM11_501 INSIDE OF LAYER R502M11
    F5012M11s = (SIZE F5012M11 BY (SM11_501 + grid)) OR F502M11s
    R5012M11pre = R502M11pre NOT F5012M11s
    R5012M11 = WITH WIDTH R5012M11pre >= WM11_501

    // 5th, non-stagger small
    F501M11 = RECTANGLES WM11_501 LM11_501 SM11_501 INSIDE OF LAYER R5012M11 //MAINTAIN SPACING
    F501M11s = (SIZE F501M11 BY (SM11_501 + grid)) OR F5012M11s

    F50M11 = ((F502M11 OR F5012M11) OR F501M11) OR F503M11

//****************************************************************************

    exceedM11 = DENSITY M11x F30M11 F40M11 F50M11 > maxD_M11 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M11.den_exceed

    removeM11R = ((PUSH (exceedM11 AND (D50M11 OR emptyM11))) NOT FRAME11) AND CHIP
    removeM11P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM11R

    F30M11x = F30M11 NOT INTERACT removeM11P
    F40M11x = F40M11 NOT INTERACT removeM11P
    F50M11x = F50M11 NOT INTERACT removeM11P
    FM11xA  = (F30M11x OR F40M11x) OR F50M11x
    FM11x   = FM11xA NOT INTERACT (EXT FM11xA < DM11_S_1 ABUT SINGULAR REGION)

    ALLM11x = M11x OR FM11x
    lackM11 = DENSITY ALLM11x CHIP < DM11_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M11.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM11x)/AREA(CHIP) ]

    WDM11EXC = DUM11 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM11EXC = (SIZE FM11x BY Odm2DM11) OR (SIZE (((F303M11_EXP OR F403M11_EXP) OR F503M11_EXP) OR WDM11EXC) BY 1.5)

    lackM11pRM = ((((PUSH lackM11) NOT RM11EXC) NOT FRAME11OPC) NOT exceedM11) AND CHIP
    lackM11pRM_1 = WITH WIDTH lackM11pRM >= SM11_OPC

    RM11p1 = RECTANGLES WM11_OPC LM11_OPC WSM11_OPC LSM11_OPC INSIDE OF LAYER lackM11pRM_1
    lackM11pRM_2 = lackM11pRM_1 NOT (SIZE RM11p1 BY SM11_OPC)
    RM11p2 = RECTANGLES LM11_OPC WM11_OPC LSM11_OPC WSM11_OPC INSIDE OF LAYER lackM11pRM_2

    ODM11A = ((RM11p1 OR RM11p2) OUTSIDE RM11EXC) OUTSIDE FRAME11OPC
    ODM11F = ODM11A NOT INTERACT (EXT ODM11A < SM11_OPC ABUT SINGULAR REGION)

    DM11F = COPY FM11x

    FRAME11_INDDMYA = SIZE M11i BY (dm11_s2m11_INDDMY + grid)
    FRAME11_INDDMYB = SIZE DUM11 BY (dm11_s_INDDMY + grid)
    FRAME11_INDDMYC = SIZE DM11F BY dm11_s_INDDMY
    FRAME11_INDDMYD = SIZE ODM11F BY dm11_s2m11_INDDMY
    FRAME11_INDDMY  = (((((FRAME11Pre OR BLOCK11) OR FRAME11_INDDMYA) OR FRAME11_INDDMYB) OR FRAME11_INDDMYC) OR FRAME11_INDDMYD) OR NFILL
    FILL11_INDDMY   = ooINDDMY NOT FRAME11_INDDMY
    DM11F_INDDMY    = RECTANGLES dm11_w_INDDMY dm11_l_INDDMY dm11_s_INDDMY INSIDE OF LAYER FILL11_INDDMY


#IFDEF FILL_indDM11
    FILL11_INDDMY_HD = (SIZE INDDMY_HD BY -(dm11_s_INDDMY_HD + grid)) NOT FRAME11_INDDMY
    DM11F_INDDMY_HD  = RECTANGLES dm11_w_INDDMY_HD dm11_l_INDDMY_HD dm11_s_INDDMY_HD INSIDE OF LAYER FILL11_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M11

    minOPENM11 = DENSITY M11x < minD_M11 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M11Min.den
    emptyOPENM11 = DENSITY M11x < emptyD_M11 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M11Empty.den

    M11InnerHole = HOLES M11i INNER

    M11BigHole = SIZE M11InnerHole BY - excludeHoleSize/2
    M11ExcHole = ((M11InnerHole OUTSIDE M11BigHole) NOT M11i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK11 = (SIZE DM11EXCL BY (dm2DMEXCL + grid)) OR MIM11_x // DM11 to DM11EXCL
    FRAMEA11 = SIZE M11i BY (dm2M11 + grid) // DM11 to metal
    FRAMEB11 = SIZE (WITH WIDTH M11i > wideM11) BY (dm2WM11 + grid)
    FRAMEC11 = SIZE DUM11 BY (dm2DM11 + grid)   // DM11 to existed dummy metal 0.6um
    FRAME11Pre = ((FRAMEA11 OR FRAMEB11) OR FRAMEC11) OR M11ExcHole
    FRAME11INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm11_s2m11_INDDMY + grid)
    FRAME11 = ((FRAME11Pre OR FRAME11INDDMY) OR BLOCK11) OR NFILL
    
    OPENM11 = PUSH ((minOPENM11 OR emptyOPENM11) AND CHIP)
    FILL11 = OPENM11 NOT FRAME11
    FILLW11pre = SIZE FILL11 BY - (Wdm2M11 + grid)
    FILLW11 = WITH WIDTH FILLW11pre >= WdmW_M11
    M11FW = RECTANGLES WdmW_M11 WdmL_M11 WdmS_M11 OFFSET WdmO_M11 INSIDE OF LAYER FILLW11
    M11FW_EXP = SIZE M11FW BY (WdmS_M11 /2 + grid) OVERUNDER //merge the gaps
    FILLM11pre = FILL11 NOT (SIZE M11FW_EXP BY (MdmS_M11 + grid))
    FILLM11 = WITH WIDTH FILLM11pre >= MdmW_M11
    M11F1 = RECTANGLES MdmW_M11 MdmL_M11 MdmS_M11 OFFSET MdmO_M11 INSIDE OF LAYER FILLM11
    M11R1pre = FILLM11pre NOT (SIZE M11F1 BY (dmS_M11 + grid))
    M11R1 = WITH WIDTH M11R1pre >= dmW_M11

    M11F2 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 OFFSET dmO_M11 INSIDE OF LAYER M11R1
    M11R2pre = M11R1 NOT (SIZE M11F2 BY (dmS_M11 + grid))
    M11R2 = WITH WIDTH M11R2pre >= dmW_M11

    M11F3 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 OFFSET dmO_M11 INSIDE OF LAYER M11R2
    M11R3pre = M11R2 NOT (SIZE M11F3 BY (dmS_M11 + grid))
    M11R3 = WITH WIDTH M11R3pre >= dmW_M11

    M11F4 = RECTANGLES dmW_M11 dmL_M11 dmS_M11 INSIDE OF LAYER M11R3

    M11F = (((M11F1 OR M11F2) OR M11F3) OR M11F4) OR M11FW
    FM11 = M11F NOT INTERACT (EXT M11F < dmS_M11 ABUT SINGULAR REGION)

    maxOPENM11 = DENSITY M11x FM11 > maxD_M11 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M11Max.den

    FM11F = FM11 OUTSIDE maxOPENM11

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M11 = DENSITY M11x FM11F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M11Min.den

    RM11EXC = SIZE FM11F BY (Odm2DM11 + grid)
    // do not fill DMz_S over CTMDMY
    D25M11pM = (((PUSH D25M11) NOT FRAME11) NOT RM11EXC) AND CHIP
    D25M11pM_1 = WITH WIDTH D25M11pM >= OdmW_M11

    RM11p1 = RECTANGLES OdmW_M11 OdmL_M11 OdmS_M11 INSIDE OF LAYER D25M11pM_1
    D25M11pM_2 = D25M11pM_1 NOT (SIZE RM11p1 BY (OdmS_M11 + grid))
    RM11p2 = RECTANGLES OdmL_M11 OdmW_M11 OdmS_M11 INSIDE OF LAYER D25M11pM_2

    RM11A = ((RM11p1 OR RM11p2) OUTSIDE RM11EXC) OUTSIDE FRAME11
    RM11  = RM11A NOT INTERACT (EXT RM11A < OdmS_M11 ABUT SINGULAR REGION)

    DM11F = FM11F OR RM11

    FRAME11_INDDMYA = SIZE M11i BY (dm11_s2m11_INDDMY + grid)
    FRAME11_INDDMYB = SIZE DUM11 BY (dm11_s_INDDMY + grid)
    FRAME11_INDDMYC = SIZE DM11F BY dm11_s_INDDMY
    FRAME11_INDDMY  = ((((FRAME11Pre OR BLOCK11) OR FRAME11_INDDMYA) OR FRAME11_INDDMYB) OR FRAME11_INDDMYC) OR NFILL
    FILL11_INDDMY   = ooINDDMY NOT FRAME11_INDDMY
    DM11F_INDDMY    = RECTANGLES dm11_w_INDDMY dm11_l_INDDMY dm11_s_INDDMY INSIDE OF LAYER FILL11_INDDMY

#IFDEF FILL_indDM11
    FILL11_INDDMY_HD = (SIZE INDDMY_HD BY -(dm11_s_INDDMY_HD + grid)) NOT FRAME11_INDDMY
    DM11F_INDDMY_HD  = RECTANGLES dm11_w_INDDMY_HD dm11_l_INDDMY_HD dm11_s_INDDMY_HD INSIDE OF LAYER FILL11_INDDMY_HD
#ENDIF	

#ELSE



    D30M11 = DENSITY M11x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M11.den30
    D40M11 = DENSITY M11x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M11.den40
    D50M11 = DENSITY M11x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M11.den50
    emptyM11 = DENSITY M11x < emptyD_M11 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M11.den_empty

    M11InnerHole = HOLES M11i INNER
    xM11_DTCD = COPY EMPTY

    M11BigHole = SIZE M11InnerHole BY - excludeHoleSize/2
    M11ExcHole = ((M11InnerHole OUTSIDE M11BigHole) NOT M11i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK11 = (SIZE DM11EXCL BY (dm2DMEXCL + grid)) OR MIM11_x

    FRAMEA11 = (SIZE M11i BY (DM11_301 + grid)) OR (SIZE (EXPAND EDGE (M11i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA11OPC = SIZE M11i BY (DM11_OPC + grid)
    FRAMEA11OPCwide = SIZE (M11i WITH WIDTH > DM11_OPC_wide_w) BY (DM11_OPC_wide + grid)
    FRAMEA11OPC45 = SIZE (EXPAND EDGE (M11i ANGLE == 45) OUTSIDE BY DM11_OPC_45 EXTEND BY DM11_OPC_45_E) BY grid
    FRAMEA11OPC45DV = SIZE (EXPAND EDGE ((M11i INTERACT M11_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM11_OPC_45 EXTEND BY DM11_OPC_45_E) BY grid
    FRAMEA11OPC_M11_S_14_wide = SIZE (M11i WITH WIDTH > M11_S_14_wide_w) BY (M11_S_14_wide + grid)
    FRAMEA11OPC_M11_S_17_wide = SIZE (M11i WITH WIDTH > M11_S_17_wide_w) BY (M11_S_17_wide + grid)
    FRAMEA11OPC_M11_S_20_wide = SIZE (M11i WITH WIDTH > M11_S_20_wide_w) BY (M11_S_20_wide + grid)
    FRAMEA11OPC_M11_S_23_wide = SIZE (M11i WITH WIDTH > M11_S_23_wide_w) BY (M11_S_23_wide + grid)
    FRAMEA11OPC_M11_S_33_VIA10   = SIZE VIA10_HV_5V_CHK	BY (M11_S_33 + grid)
    FRAMEA11OPC_M11_S_33b_VIA10DV   = SIZE (VIA10i INTERACT (M10_HVN_330Vx OR M11_HVN_330Vx))	BY (M11_S_33b + grid)
    FRAMEA11OPC_M11_S_33_VIA11    = SIZE VIA11_HV_5V_CHK	BY (M11_S_33 + grid)
    FRAMEA11OPC_M11_S_33b_VIA11DV    = SIZE (VIA11i INTERACT (M11_HVN_330Vx OR M12_HVN_330Vx))	BY (M11_S_33b + grid)
    FRAMEA11OPC_M11_S_37_VIA10_b = SIZE VIA10i_55V		BY (M11_S_37 + grid)
    FRAMEA11OPC_M11_S_37a_VIA10_bDV = SIZE (VIA10i INTERACT (M10_HVN_500Vx OR M11_HVN_500Vx))		BY (M11_S_37a + grid)
    FRAMEA11OPC_M11_S_37_VIA11_b  = SIZE VIA11i_55V			BY (M11_S_37 + grid)
    FRAMEA11OPC_M11_S_37a_VIA11_bDV  = SIZE (VIA11i INTERACT (M11_HVN_500Vx OR M12_HVN_500Vx))		BY (M11_S_37a + grid)
    FRAMEA11OPC_M11_S_37_VIA10   = SIZE VIA10i_65V		BY (M11_S_37 + grid)
	FRAMEA11OPC_M11_S_37_VIA11    = SIZE VIA11i_65V			BY (M11_S_37 + grid)

    FRAMEHVD11 = SIZE  M11i_65V  BY (M11_S_38 + grid)
    FRAMEHVD11_55V = SIZE  M11i_55V  BY (M11_S_38 + grid)
    FRAMEHVD11_55VDV = SIZE  (M11i INTERACT M11_HVN_500Vx)  BY (M11_S_38a + grid)
    FRAMEB11 = SIZE (WITH WIDTH M11i > wideM11) BY (dm2WM11 + grid)
    FRAMEC11 = SIZE DUM11 BY (dm2DM11 + grid)
    FRAMED11 = SIZE (WITH WIDTH M11i > wideM11_small) BY (dm2WM11_small + grid)
    FRAMEC11OPC = SIZE DUM11 BY (Odm2DM11 + grid)
    FRAME11Pre = ((FRAMEA11 OR FRAMEB11) OR (FRAMEC11 OR FRAMED11)) OR M11ExcHole
    FRAME11PreOPC = (((((((((((((((((((((FRAMEA11OPC OR FRAMEC11OPC) OR M11ExcHole) OR FRAMEA11OPCwide) OR FRAMEA11OPC45) OR FRAMEA11OPC45DV) OR FRAMEA11OPC_M11_S_14_wide) OR FRAMEA11OPC_M11_S_17_wide) OR FRAMEA11OPC_M11_S_20_wide) OR FRAMEA11OPC_M11_S_23_wide) OR FRAMEA11OPC_M11_S_33_VIA10) OR FRAMEA11OPC_M11_S_33b_VIA10DV) OR FRAMEA11OPC_M11_S_33_VIA11) OR FRAMEA11OPC_M11_S_33b_VIA11DV) OR FRAMEHVD11) OR FRAMEA11OPC_M11_S_37_VIA10) OR FRAMEA11OPC_M11_S_37_VIA10_b) OR FRAMEA11OPC_M11_S_37a_VIA10_bDV) OR FRAMEA11OPC_M11_S_37_VIA11) OR FRAMEA11OPC_M11_S_37_VIA11_b) OR FRAMEA11OPC_M11_S_37a_VIA11_bDV) OR FRAMEHVD11_55V) OR FRAMEHVD11_55VDV


    FRAME11INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm11_s2m11_INDDMY + grid)
    FRAME11OPC = (((FRAME11PreOPC OR FRAME11INDDMY) OR xM11_DTCD) OR BLOCK11) OR NFILLOPC_x

    FRAME11 = (((FRAME11Pre OR FRAME11INDDMY) OR xM11_DTCD) OR BLOCK11) OR NFILL_x

    D30M11p = (PUSH D30M11) NOT FRAME11
    O30M11pre = D30M11p AND CHIP
    FD21M11s = COPY FRAME11

    O30M11preA = SIZE O30M11pre BY -DM11_303
    O30M11preB = O30M11preA WITH WIDTH >= WM11_303

    // 1st big
    F303M11 = RECTANGLES WM11_303 LM11_303 SM11_303 OFFSET OM11_303 INSIDE OF LAYER O30M11preB
    F303M11_SLOT = RECTANGLES WM11_303_SLOT LM11_303_SLOT SM11_303_SLOT INSIDE OF LAYER F303M11

    F303M11_EXP = SIZE F303M11_SLOT BY ( SM11_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M11preF1 = O30M11pre NOT (SIZE F303M11_EXP BY SM11_302)
    O30M11preF  = (SNAP (SIZE O30M11preF1 BY -grid) 5) AND O30M11preF1

    B30M11s = FD21M11s OR (SIZE F303M11_EXP BY (SM11_302+grid))
    O30M11 = O30M11preF NOT B30M11s

    // 3rd, middle
    F302M11 = RECTANGLES WM11_302 LM11_302 SM11_302 OFFSET OM11_302 INSIDE OF LAYER O30M11
    F302M11s = (SIZE F302M11 BY (SM11_301 + grid)) OR B30M11s
    R302M11pre = O30M11 NOT F302M11s
    R302M11 = WITH WIDTH R302M11pre >= WM11_301

    // 4th, small
    F3012M11 = RECTANGLES WM11_301 LM11_301 SM11_301 OFFSET OM11_301 INSIDE OF LAYER R302M11
    F3012M11s = (SIZE F3012M11 BY (SM11_301 + grid)) OR F302M11s
    R3012M11pre = R302M11pre NOT F3012M11s
    R3012M11 = WITH WIDTH R3012M11pre >= WM11_301

    // 5th, non-stagger small
    F301M11 = RECTANGLES WM11_301 LM11_301 SM11_301 INSIDE OF LAYER R3012M11 //MAINTAIN SPACING
    F301M11s = (SIZE F301M11 BY (SM11_301 + grid)) OR F3012M11s

    F30M11 = ((F302M11 OR F3012M11) OR F301M11) OR F303M11_SLOT
    O40M11pre = (((PUSH D40M11) NOT FRAME11) NOT F301M11s) AND CHIP


    O40M11preA = SIZE O40M11pre BY -DM11_403
    O40M11preB = O40M11preA WITH WIDTH >= WM11_403

    // 1st big
    F403M11 = RECTANGLES WM11_403 LM11_403 SM11_403 OFFSET OM11_403 INSIDE OF LAYER O40M11preB
    F403M11_SLOT = RECTANGLES WM11_403_SLOT LM11_403_SLOT SM11_403_SLOT INSIDE OF LAYER F403M11

    F403M11_EXP = SIZE F403M11_SLOT BY ( SM11_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M11preF1 = O40M11pre NOT (SIZE F403M11_EXP BY SM11_402)
    O40M11preF  = (SNAP (SIZE O40M11preF1 BY -grid) 5) AND O40M11preF1

    B40M11s = F301M11s OR (SIZE F403M11_EXP BY (SM11_402+grid))
    O40M11 = O40M11preF NOT B40M11s

    // 3rd, middle
    F402M11 = RECTANGLES WM11_402 LM11_402 SM11_402 OFFSET OM11_402 INSIDE OF LAYER O40M11
    F402M11s = (SIZE F402M11 BY (SM11_401 + grid)) OR B40M11s
    R402M11pre = O40M11 NOT F402M11s
    R402M11 = WITH WIDTH R402M11pre >= WM11_401

    // 4th, small
    F4012M11 = RECTANGLES WM11_401 LM11_401 SM11_401 OFFSET OM11_401 INSIDE OF LAYER R402M11
    F4012M11s = (SIZE F4012M11 BY (SM11_401 + grid)) OR F402M11s
    R4012M11pre = R402M11pre NOT F4012M11s
    R4012M11 = WITH WIDTH R4012M11pre >= WM11_401

    // 5th, non-stagger small
    F401M11 = RECTANGLES WM11_401 LM11_401 SM11_401 INSIDE OF LAYER R4012M11 //MAINTAIN SPACING
    F401M11s = (SIZE F401M11 BY (SM11_401 + grid)) OR F4012M11s

    F40M11 = ((F402M11 OR F4012M11) OR F401M11) OR F403M11_SLOT
    O50M11pre = (((PUSH (D50M11 OR emptyM11)) NOT FRAME11) NOT F401M11s) AND CHIP


    O50M11preA = SIZE O50M11pre BY -DM11_503
    O50M11preB = O50M11preA WITH WIDTH >= WM11_503

    // 1st big
    F503M11 = RECTANGLES WM11_503 LM11_503 SM11_503 OFFSET OM11_503 INSIDE OF LAYER O50M11preB
    F503M11_SLOT = RECTANGLES WM11_503_SLOT LM11_503_SLOT SM11_503_SLOT INSIDE OF LAYER F503M11

    F503M11_EXP = SIZE F503M11_SLOT BY ( SM11_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M11preF1 = O50M11pre NOT (SIZE F503M11_EXP BY SM11_502)
    O50M11preF  = (SNAP (SIZE O50M11preF1 BY -grid) 5) AND O50M11preF1

    B50M11s = F401M11s OR (SIZE F503M11_EXP BY (SM11_502+grid))
    O50M11 = O50M11preF NOT B50M11s

    // 3rd, middle
    F502M11 = RECTANGLES WM11_502 LM11_502 SM11_502 OFFSET OM11_502 INSIDE OF LAYER O50M11
    F502M11s = (SIZE F502M11 BY (SM11_501 + grid)) OR B50M11s
    R502M11pre = O50M11 NOT F502M11s
    R502M11 = WITH WIDTH R502M11pre >= WM11_501

    // 4th, small
    F5012M11 = RECTANGLES WM11_501 LM11_501 SM11_501 OFFSET OM11_501 INSIDE OF LAYER R502M11
    F5012M11s = (SIZE F5012M11 BY (SM11_501 + grid)) OR F502M11s
    R5012M11pre = R502M11pre NOT F5012M11s
    R5012M11 = WITH WIDTH R5012M11pre >= WM11_501

    // 5th, non-stagger small
    F501M11 = RECTANGLES WM11_501 LM11_501 SM11_501 INSIDE OF LAYER R5012M11 //MAINTAIN SPACING
    F501M11s = (SIZE F501M11 BY (SM11_501 + grid)) OR F5012M11s

    F50M11 = ((F502M11 OR F5012M11) OR F501M11) OR F503M11_SLOT

    exceedM11 = DENSITY M11x F30M11 F40M11 F50M11 > maxD_M11 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M11.den_exceed

    removeM11R = ((PUSH (exceedM11 AND (D50M11 OR emptyM11))) NOT FRAME11) AND CHIP
    removeM11P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM11R

    F30M11x = F30M11 NOT INTERACT removeM11P
    F40M11x = F40M11 NOT INTERACT removeM11P
    F50M11x = F50M11 NOT INTERACT removeM11P
    FM11xA  = (F30M11x OR F40M11x) OR F50M11x
    FM11x   = FM11xA NOT INTERACT (EXT FM11xA < DM11_S_1 ABUT SINGULAR REGION)

    ALLM11x = M11x OR FM11x
    lackM11 = DENSITY ALLM11x CHIP < DM11_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M11.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM11x)/AREA(CHIP) ]

    WDM11EXC = DUM11 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM11EXC = (SIZE FM11x BY Odm2DM11) OR (SIZE (((F303M11_EXP OR F403M11_EXP) OR F503M11_EXP) OR WDM11EXC) BY 1.5)

    lackM11pRM = ((((PUSH lackM11) NOT RM11EXC) NOT FRAME11OPC) NOT exceedM11) AND CHIP
    lackM11pRM_1 = WITH WIDTH lackM11pRM >= SM11_OPC

    RM11p1 = RECTANGLES WM11_OPC LM11_OPC WSM11_OPC LSM11_OPC INSIDE OF LAYER lackM11pRM_1
    lackM11pRM_2 = lackM11pRM_1 NOT (SIZE RM11p1 BY SM11_OPC)
    RM11p2 = RECTANGLES LM11_OPC WM11_OPC LSM11_OPC WSM11_OPC INSIDE OF LAYER lackM11pRM_2

    ODM11A = ((RM11p1 OR RM11p2) OUTSIDE RM11EXC) OUTSIDE FRAME11OPC
    ODM11F_pre = ODM11A NOT INTERACT (EXT ODM11A < SM11_OPC ABUT SINGULAR REGION)

// M11.S.14 ~ M11.S.16
M11_S_14_CHK_REGION = M11i OR ODM11F_pre
// Find Wide Metal
Wide_M11_S_14_CHK_REGION = ENCLOSE RECTANGLE (M11_S_14_CHK_REGION NOT WITH WIDTH <= M11_S_14_W1B) M11_S_14_W1B+GRID M11_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M11_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M11_S_14_CHK_REGION == 0
Wide_M11_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M11_S_14_CHK_REGION == 90

// Find Wide Metal Space
M11_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M11_S_14_CHK_REGION_EDGE_H M11_S_14_CHK_REGION < M11_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M11_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M11_S_14_CHK_REGION_EDGE_V M11_S_14_CHK_REGION < M11_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M11_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M11_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M11_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M11_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M11_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M11_S_14_CHK_REGION_OPC_REGION_pre1_H M11_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M11_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M11_S_14_L1B
M11_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M11_S_14_CHK_REGION_OPC_REGION_pre1_V M11_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M11_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M11_S_14_L1B

M11_S_14_OPC_REGION = M11_S_14_CHK_REGION_OPC_REGION_pre2_H OR M11_S_14_CHK_REGION_OPC_REGION_pre2_V

// M11.S.17 ~ M11.S.19
M11_S_17_CHK_REGION = M11i OR ODM11F_pre
// Find Wide Metal
Wide_M11_S_17_CHK_REGION = ENCLOSE RECTANGLE (M11_S_17_CHK_REGION NOT WITH WIDTH <= M11_S_17_W1B) M11_S_17_W1B+GRID M11_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M11_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M11_S_17_CHK_REGION == 0
Wide_M11_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M11_S_17_CHK_REGION == 90

// Find Wide Metal Space
M11_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M11_S_17_CHK_REGION_EDGE_H M11_S_17_CHK_REGION < M11_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M11_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M11_S_17_CHK_REGION_EDGE_V M11_S_17_CHK_REGION < M11_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M11_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M11_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M11_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M11_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M11_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M11_S_17_CHK_REGION_OPC_REGION_pre1_H M11_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M11_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M11_S_17_L1B
M11_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M11_S_17_CHK_REGION_OPC_REGION_pre1_V M11_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M11_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M11_S_17_L1B

M11_S_17_OPC_REGION = M11_S_17_CHK_REGION_OPC_REGION_pre2_H OR M11_S_17_CHK_REGION_OPC_REGION_pre2_V

// M11.S.20 ~ M11.S.22
M11_S_20_CHK_REGION = M11i OR ODM11F_pre
// Find Wide Metal
Wide_M11_S_20_CHK_REGION = ENCLOSE RECTANGLE (M11_S_20_CHK_REGION NOT WITH WIDTH <= M11_S_20_W1B) M11_S_20_W1B+GRID M11_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M11_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M11_S_20_CHK_REGION == 0
Wide_M11_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M11_S_20_CHK_REGION == 90

// Find Wide Metal Space
M11_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M11_S_20_CHK_REGION_EDGE_H M11_S_20_CHK_REGION < M11_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M11_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M11_S_20_CHK_REGION_EDGE_V M11_S_20_CHK_REGION < M11_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M11_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M11_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M11_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M11_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M11_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M11_S_20_CHK_REGION_OPC_REGION_pre1_H M11_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M11_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M11_S_20_L1B
M11_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M11_S_20_CHK_REGION_OPC_REGION_pre1_V M11_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M11_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M11_S_20_L1B

M11_S_20_OPC_REGION = M11_S_20_CHK_REGION_OPC_REGION_pre2_H OR M11_S_20_CHK_REGION_OPC_REGION_pre2_V

// M11.S.23 ~ M11.S.25
M11_S_23_CHK_REGION = M11i OR ODM11F_pre
// Find Wide Metal
Wide_M11_S_23_CHK_REGION = ENCLOSE RECTANGLE (M11_S_23_CHK_REGION NOT WITH WIDTH <= M11_S_23_W1B) M11_S_23_W1B+GRID M11_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M11_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M11_S_23_CHK_REGION == 0
Wide_M11_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M11_S_23_CHK_REGION == 90

// Find Wide Metal Space
M11_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M11_S_23_CHK_REGION_EDGE_H M11_S_23_CHK_REGION < M11_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M11_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M11_S_23_CHK_REGION_EDGE_V M11_S_23_CHK_REGION < M11_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M11_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M11_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M11_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M11_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M11_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M11_S_23_CHK_REGION_OPC_REGION_pre1_H M11_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M11_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M11_S_23_L1B
M11_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M11_S_23_CHK_REGION_OPC_REGION_pre1_V M11_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M11_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M11_S_23_L1B

M11_S_23_OPC_REGION = M11_S_23_CHK_REGION_OPC_REGION_pre2_H OR M11_S_23_CHK_REGION_OPC_REGION_pre2_V

// M11.S.27
M11_S_27_CHK_REGION = M11i OR ODM11F_pre
// Find Wide Metal
Wide_M11_S_27_CHK_REGION = ENCLOSE RECTANGLE (M11_S_27_CHK_REGION NOT WITH WIDTH <= M11_S_27_W1B) M11_S_27_W1B+GRID M11_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M11_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M11_S_27_CHK_REGION == 0
Wide_M11_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M11_S_27_CHK_REGION == 90

// Find Wide Metal Space
M11_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M11_S_27_CHK_REGION_EDGE_H M11_S_27_CHK_REGION < M11_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M11_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M11_S_27_CHK_REGION_EDGE_V M11_S_27_CHK_REGION < M11_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M11_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M11_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M11_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M11_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M11_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M11_S_27_CHK_REGION_OPC_REGION_pre1_H M11_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M11_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M11_S_27_L1B
M11_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M11_S_27_CHK_REGION_OPC_REGION_pre1_V M11_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M11_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M11_S_27_L1B

M11_S_27_OPC_REGION = M11_S_27_CHK_REGION_OPC_REGION_pre2_H OR M11_S_27_CHK_REGION_OPC_REGION_pre2_V

M11_WMJ_OPC_REGION = (((M11_S_14_OPC_REGION OR M11_S_17_OPC_REGION) OR M11_S_20_OPC_REGION) OR M11_S_23_OPC_REGION) OR M11_S_27_OPC_REGION

    ODM11F = ODM11F_pre NOT INTERACT M11_WMJ_OPC_REGION

    DM11F = COPY FM11x

    FRAME11_INDDMYA = SIZE M11i BY (dm11_s2m11_INDDMY + grid)
    FRAME11_INDDMYB = SIZE DUM11 BY (dm11_s_INDDMY + grid)
    FRAME11_INDDMYC = SIZE DM11F BY dm11_s_INDDMY
    FRAME11_INDDMYD = SIZE ODM11F BY dm11_s2m11_INDDMY

    FRAME11_INDDMY  = ((((((FRAME11Pre OR xM11_DTCD) OR BLOCK11) OR FRAME11_INDDMYA) OR FRAME11_INDDMYB) OR FRAME11_INDDMYC) OR FRAME11_INDDMYD) OR NFILL_x
    FILL11_INDDMY   = ooINDDMY NOT FRAME11_INDDMY
    DM11F_INDDMY    = RECTANGLES dm11_w_INDDMY dm11_l_INDDMY dm11_s_INDDMY INSIDE OF LAYER FILL11_INDDMY

#IFDEF FILL_indDM11
    FILL11_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm11_s_INDDMY_HD + grid)) NOT FRAME11_INDDMY
    DM11F_INDDMY_HD_pre  = RECTANGLES dm11_w_INDDMY_HD dm11_l_INDDMY_HD dm11_s_INDDMY_HD INSIDE OF LAYER FILL11_INDDMY_HD

    FILL11_INDDMY_MD = (SIZE INDDMY_MD BY -(dm11_s_INDDMY_MD + grid)) NOT (FRAME11_INDDMY OR INDDMY_HD)
