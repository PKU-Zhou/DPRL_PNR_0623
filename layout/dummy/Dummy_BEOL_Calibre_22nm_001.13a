#ELSE
#IFDEF 9K_THICK_Mz_M3
#ELSE
#IFDEF 5K_THICK_Myz_M3
#ELSE
#IFDEF 2_6K_THICK_Mxy_M3
#ELSE
#IFDEF 2K_THICK_My_M3
#ELSE




#IFDEF FILL_DM3
DM3F_FOR_DVIA3F_REGION = ((DM3F OR DUM3) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM3F_FOR_DVIA3F_REGION = (DUM3 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

#IFDEF FILL_DM4
DM4F_FOR_DVIA3F_REGION = ((DM4F OR DUM4) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM4F_FOR_DVIA3F_REGION = (DUM4 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

// Find DVIA3 fillable regions.  Consider enclosure to lower DM3, enclosure to upper DM4, DVIA3 size.

VARIABLE DM3_F_4_REGION_DVIA3_SHORTENED_LENGTH DVIA3_EN_2 - DVIA3_EN_1

#IFDEF VERTICAL_DM3
DM3_F_4_REGION_DVIA3_spec_B_pre = RECTANGLE DM3F_FOR_DVIA3F_REGION == WM3_303_SLOT BY == LM3_303_SLOT
DM3_F_4_REGION_DVIA3_spec_B     = DM3_F_4_REGION_DVIA3_spec_B_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA3_spec_B_pre == WM3_303_SLOT) INSIDE BY DM3_F_4_REGION_DVIA3_SHORTENED_LENGTH)

DM3_F_4_REGION_DVIA3_spec_M_pre = RECTANGLE DM3F_FOR_DVIA3F_REGION == WM3_302 BY == LM3_302
DM3_F_4_REGION_DVIA3_spec_M     = DM3_F_4_REGION_DVIA3_spec_M_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA3_spec_M_pre == WM3_302) INSIDE BY DM3_F_4_REGION_DVIA3_SHORTENED_LENGTH)

DM3_F_4_REGION_DVIA3_spec_S_pre = RECTANGLE DM3F_FOR_DVIA3F_REGION == WM3_301 BY == LM3_301
DM3_F_4_REGION_DVIA3_spec_S     = DM3_F_4_REGION_DVIA3_spec_S_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA3_spec_S_pre == WM3_301) INSIDE BY DM3_F_4_REGION_DVIA3_SHORTENED_LENGTH)
#ELSE
DM3_F_4_REGION_DVIA3_spec_B_pre = RECTANGLE DM3F_FOR_DVIA3F_REGION == LM3_303_SLOT BY == WM3_303_SLOT
DM3_F_4_REGION_DVIA3_spec_B     = DM3_F_4_REGION_DVIA3_spec_B_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA3_spec_B_pre == LM3_303_SLOT) INSIDE BY DM3_F_4_REGION_DVIA3_SHORTENED_LENGTH)

DM3_F_4_REGION_DVIA3_spec_M_pre = RECTANGLE DM3F_FOR_DVIA3F_REGION == LM3_302 BY == WM3_302
DM3_F_4_REGION_DVIA3_spec_M     = DM3_F_4_REGION_DVIA3_spec_M_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA3_spec_M_pre == LM3_302) INSIDE BY DM3_F_4_REGION_DVIA3_SHORTENED_LENGTH)

DM3_F_4_REGION_DVIA3_spec_S_pre = RECTANGLE DM3F_FOR_DVIA3F_REGION == LM3_301 BY == WM3_301
DM3_F_4_REGION_DVIA3_spec_S     = DM3_F_4_REGION_DVIA3_spec_S_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA3_spec_S_pre == LM3_301) INSIDE BY DM3_F_4_REGION_DVIA3_SHORTENED_LENGTH)
#ENDIF
DM3_F_4_REGION_DVIA3_square_pre = RECTANGLE DM3F_FOR_DVIA3F_REGION ASPECT == 1
DM3_F_4_REGION_DVIA3_square     = SIZE DM3_F_4_REGION_DVIA3_square_pre BY -DM3_F_4_REGION_DVIA3_SHORTENED_LENGTH

DM3F_FOR_DVIA3F_REGION_4parts = (DM3_F_4_REGION_DVIA3_spec_B OR DM3_F_4_REGION_DVIA3_spec_M) OR (DM3_F_4_REGION_DVIA3_spec_S OR DM3_F_4_REGION_DVIA3_square)
DM3F_FOR_DVIA3F_REGION_remainder_pre_not = (DM3_F_4_REGION_DVIA3_spec_B_pre OR DM3_F_4_REGION_DVIA3_spec_M_pre) OR (DM3_F_4_REGION_DVIA3_spec_S_pre OR DM3_F_4_REGION_DVIA3_square_pre)
DM3F_FOR_DVIA3F_REGION_remainder = DM3F_FOR_DVIA3F_REGION NOT DM3F_FOR_DVIA3F_REGION_remainder_pre_not

    DM3F_FOR_DVIA3F_REGION_remainder_EDGE = LENGTH DM3F_FOR_DVIA3F_REGION_remainder > 0
    DM3F_FOR_DVIA3F_REGION_remainder_PROP = DFM PROPERTY DM3F_FOR_DVIA3F_REGION_remainder DM3F_FOR_DVIA3F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM3F_FOR_DVIA3F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM3F_FOR_DVIA3F_REGION_remainder_EDGE)) ]
    DM3F_FOR_DVIA3F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM3F_FOR_DVIA3F_REGION_remainder_EDGE DM3F_FOR_DVIA3F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM3F_FOR_DVIA3F_REGION_remainder_EDGE) - PROPERTY(DM3F_FOR_DVIA3F_REGION_remainder_PROP, DM3F_FOR_DVIA3F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM3F_FOR_DVIA3F_REGION2 = DM3F_FOR_DVIA3F_REGION_remainder NOT (EXPAND EDGE DM3F_FOR_DVIA3F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM3_F_4_REGION_DVIA3_SHORTENED_LENGTH)


VARIABLE DM4_F_4_REGION_DVIA3_SHORTENED_LENGTH DM4_EN_3 - DM4_EN_2

#IFDEF VERTICAL_DM4
DM4_F_4_REGION_DVIA3_spec_B_pre = RECTANGLE DM4F_FOR_DVIA3F_REGION == WM4_303_SLOT BY == LM4_303_SLOT
DM4_F_4_REGION_DVIA3_spec_B     = DM4_F_4_REGION_DVIA3_spec_B_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA3_spec_B_pre == WM4_303_SLOT) INSIDE BY DM4_F_4_REGION_DVIA3_SHORTENED_LENGTH)

DM4_F_4_REGION_DVIA3_spec_M_pre = RECTANGLE DM4F_FOR_DVIA3F_REGION == WM4_302 BY == LM4_302
DM4_F_4_REGION_DVIA3_spec_M     = DM4_F_4_REGION_DVIA3_spec_M_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA3_spec_M_pre == WM4_302) INSIDE BY DM4_F_4_REGION_DVIA3_SHORTENED_LENGTH)

DM4_F_4_REGION_DVIA3_spec_S_pre = RECTANGLE DM4F_FOR_DVIA3F_REGION == WM4_301 BY == LM4_301
DM4_F_4_REGION_DVIA3_spec_S     = DM4_F_4_REGION_DVIA3_spec_S_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA3_spec_S_pre == WM4_301) INSIDE BY DM4_F_4_REGION_DVIA3_SHORTENED_LENGTH)
#ELSE
DM4_F_4_REGION_DVIA3_spec_B_pre = RECTANGLE DM4F_FOR_DVIA3F_REGION == LM4_303_SLOT BY == WM4_303_SLOT
DM4_F_4_REGION_DVIA3_spec_B     = DM4_F_4_REGION_DVIA3_spec_B_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA3_spec_B_pre == LM4_303_SLOT) INSIDE BY DM4_F_4_REGION_DVIA3_SHORTENED_LENGTH)

DM4_F_4_REGION_DVIA3_spec_M_pre = RECTANGLE DM4F_FOR_DVIA3F_REGION == LM4_302 BY == WM4_302
DM4_F_4_REGION_DVIA3_spec_M     = DM4_F_4_REGION_DVIA3_spec_M_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA3_spec_M_pre == LM4_302) INSIDE BY DM4_F_4_REGION_DVIA3_SHORTENED_LENGTH)

DM4_F_4_REGION_DVIA3_spec_S_pre = RECTANGLE DM4F_FOR_DVIA3F_REGION == LM4_301 BY == WM4_301
DM4_F_4_REGION_DVIA3_spec_S     = DM4_F_4_REGION_DVIA3_spec_S_pre NOT (EXPAND EDGE (LENGTH DM4_F_4_REGION_DVIA3_spec_S_pre == LM4_301) INSIDE BY DM4_F_4_REGION_DVIA3_SHORTENED_LENGTH)
#ENDIF

DM4_F_4_REGION_DVIA3_square_pre = RECTANGLE DM4F_FOR_DVIA3F_REGION ASPECT == 1
DM4_F_4_REGION_DVIA3_square     = SIZE DM4_F_4_REGION_DVIA3_square_pre BY -DM4_F_4_REGION_DVIA3_SHORTENED_LENGTH

DM4F_FOR_DVIA3F_REGION_4parts = (DM4_F_4_REGION_DVIA3_spec_B OR DM4_F_4_REGION_DVIA3_spec_M) OR (DM4_F_4_REGION_DVIA3_spec_S OR DM4_F_4_REGION_DVIA3_square)
DM4F_FOR_DVIA3F_REGION_remainder_pre_not = (DM4_F_4_REGION_DVIA3_spec_B_pre OR DM4_F_4_REGION_DVIA3_spec_M_pre) OR (DM4_F_4_REGION_DVIA3_spec_S_pre OR DM4_F_4_REGION_DVIA3_square_pre)
DM4F_FOR_DVIA3F_REGION_remainder = DM4F_FOR_DVIA3F_REGION NOT DM4F_FOR_DVIA3F_REGION_remainder_pre_not

    DM4F_FOR_DVIA3F_REGION_remainder_EDGE = LENGTH DM4F_FOR_DVIA3F_REGION_remainder > 0
    DM4F_FOR_DVIA3F_REGION_remainder_PROP = DFM PROPERTY DM4F_FOR_DVIA3F_REGION_remainder DM4F_FOR_DVIA3F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM4F_FOR_DVIA3F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM4F_FOR_DVIA3F_REGION_remainder_EDGE)) ]
    DM4F_FOR_DVIA3F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM4F_FOR_DVIA3F_REGION_remainder_EDGE DM4F_FOR_DVIA3F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM4F_FOR_DVIA3F_REGION_remainder_EDGE) - PROPERTY(DM4F_FOR_DVIA3F_REGION_remainder_PROP, DM4F_FOR_DVIA3F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM4F_FOR_DVIA3F_REGION2 = DM4F_FOR_DVIA3F_REGION_remainder NOT (EXPAND EDGE DM4F_FOR_DVIA3F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM4_F_4_REGION_DVIA3_SHORTENED_LENGTH)

DVIA3F_BASE_REGION = (((((SIZE (DM3F_FOR_DVIA3F_REGION2 OR DM3F_FOR_DVIA3F_REGION_4parts) BY -DVIA3_EN_1) AND (SIZE (DM4F_FOR_DVIA3F_REGION2 OR DM4F_FOR_DVIA3F_REGION_4parts) BY -DM4_EN_2)) WITH WIDTH >= DVIA3_W_1) NOT (SIZE DVIA3EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA3i BY (DVIA3_S_1 + grid))) NOT (SIZE VIA3i BY (DVIA3_S_2 + grid))




// Merge DVIA3 fillable regions, and find DVIA3 seeds by maintaining spacing DVIA3_S_1.
DVIA3F_SEED_REGION_1 = (((SIZE DVIA3F_BASE_REGION BY DVIA3F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA3EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA3i BY (DVIA3_S_1 + grid))) NOT (SIZE VIA3i BY (DVIA3_S_2 + grid))
DVIA3F_SEED_1 = RECTANGLES DVIA3_W_1 DVIA3_W_1 DVIA3_S_1 INSIDE OF LAYER DVIA3F_SEED_REGION_1

// Find DVIA3 in the DVIA3 fillable and spacing-maintained regions.
DVIA3F_REGION_1 = (DVIA3F_BASE_REGION INTERACT DVIA3F_SEED_1) NOT TOUCH DVIA3F_SEED_1
DVIA3F_pre1_1_pre1 = RECTANGLES DVIA3_W_1 DVIA3_W_1 DVIA3_S_1 INSIDE OF LAYER DVIA3F_REGION_1

// post-DRC
DVIA3F_pre1_1_pre2 = DVIA3F_pre1_1_pre1 NOT INTERACT (EXT DVIA3F_pre1_1_pre1 < DVIA3_S_1 ABUT SINGULAR REGION)
DVIA3F_pre1_1_pre3 = DVIA3F_pre1_1_pre2 NOT INTERACT (EXT DVIA3F_pre1_1_pre2 DUVIA3i < DVIA3_S_1 ABUT SINGULAR REGION)
DVIA3F_pre1_1_pre4 = DVIA3F_pre1_1_pre3 NOT INTERACT (EXT DVIA3F_pre1_1_pre3 VIA3i < DVIA3_S_2 ABUT SINGULAR REGION)
DVIA3F_pre1_1_pre5 = DVIA3F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA3F_pre1_1_pre4 DM3F_FOR_DVIA3F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA3_EN_2 OPPOSITE 0 DVIA3_EN_2 OPPOSITE)
DVIA3F_pre1_1      = DVIA3F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA3F_pre1_1_pre5 DM4F_FOR_DVIA3F_REGION ABUT < 90 SINGULAR GOOD 0 DM4_EN_3 OPPOSITE 0 DM4_EN_3 OPPOSITE)

// Merge DVIA3 fillable regions, and find DVIA3 seeds by maintaining spacing DVIA3_S_1.
DVIA3F_SEED_REGION_2 = (((SIZE (DVIA3F_BASE_REGION NOT INTERACT (SIZE DVIA3F_pre1_1 BY DVIA3_S_1)) BY DVIA3F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA3EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA3i BY (DVIA3_S_1 + grid))) NOT (SIZE VIA3i BY (DVIA3_S_2 + grid))
DVIA3F_SEED_2 = RECTANGLES DVIA3_W_1 DVIA3_W_1 DVIA3_S_1 INSIDE OF LAYER DVIA3F_SEED_REGION_2

// Find DVIA3 in the DVIA3 fillable and spacing-maintained regions.
DVIA3F_REGION_2 = (DVIA3F_BASE_REGION INTERACT DVIA3F_SEED_2) NOT TOUCH DVIA3F_SEED_2
DVIA3F_pre1_2 = RECTANGLES DVIA3_W_1 DVIA3_W_1 DVIA3_S_1 INSIDE OF LAYER DVIA3F_REGION_2

// post-DRC
DVIA3F_pre1 = DVIA3F_pre1_1 OR DVIA3F_pre1_2
DVIA3F_pre2 = DVIA3F_pre1 NOT INTERACT (EXT DVIA3F_pre1 < DVIA3_S_1 ABUT SINGULAR REGION)
DVIA3F_pre3 = DVIA3F_pre2 NOT INTERACT (EXT DVIA3F_pre2 DUVIA3i < DVIA3_S_1 ABUT SINGULAR REGION)
DVIA3F_pre4 = DVIA3F_pre3 NOT INTERACT (EXT DVIA3F_pre3 VIA3i < DVIA3_S_2 ABUT SINGULAR REGION)
DVIA3F_pre5 = DVIA3F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA3F_pre4 DM3F_FOR_DVIA3F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA3_EN_2 OPPOSITE 0 DVIA3_EN_2 OPPOSITE)
DVIA3F      = DVIA3F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA3F_pre5 DM4F_FOR_DVIA3F_REGION ABUT < 90 SINGULAR GOOD 0 DM4_EN_3 OPPOSITE 0 DM4_EN_3 OPPOSITE)

#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF


#IFDEF 34K_THICK_Mu_M5
