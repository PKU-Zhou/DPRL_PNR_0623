    BLOCK6 = (SIZE DM6EXCL BY (dm2DMEXCL + grid)) OR  MIM6_x // DM6 to DM6EXCL
    FRAMEA6 = SIZE M6i BY (dm2M6 + grid) // DM6 to metal
    FRAMEB6 = SIZE (WITH WIDTH M6i > wideM6) BY (dm2WM6 + grid)
    FRAMEC6 = SIZE DUM6 BY (dm2DM6 + grid)   // DM6 to existed dummy metal 0.6um
    FRAME6Pre = ((FRAMEA6 OR FRAMEB6) OR FRAMEC6) OR M6ExcHole
    FRAME6INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm6_s2m6_INDDMY + grid)
    FRAME6 = ((FRAME6Pre OR FRAME6INDDMY) OR BLOCK6) OR NFILL
    
    OPENM6 = PUSH ((minOPENM6 OR emptyOPENM6) AND CHIP)
    FILL6 = OPENM6 NOT FRAME6
    FILLW6pre = SIZE FILL6 BY - (Wdm2M6 + grid)
    FILLW6 = WITH WIDTH FILLW6pre >= WdmW_M6
    M6FW = RECTANGLES WdmW_M6 WdmL_M6 WdmS_M6 OFFSET WdmO_M6 INSIDE OF LAYER FILLW6
    M6FW_EXP = SIZE M6FW BY (WdmS_M6 /2 + grid) OVERUNDER //merge the gaps
    FILLM6pre = FILL6 NOT (SIZE M6FW_EXP BY (MdmS_M6 + grid))
    FILLM6 = WITH WIDTH FILLM6pre >= MdmW_M6
    M6F1 = RECTANGLES MdmW_M6 MdmL_M6 MdmS_M6 OFFSET MdmO_M6 INSIDE OF LAYER FILLM6
    M6R1pre = FILLM6pre NOT (SIZE M6F1 BY (dmS_M6 + grid))
    M6R1 = WITH WIDTH M6R1pre >= dmW_M6

    M6F2 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 OFFSET dmO_M6 INSIDE OF LAYER M6R1
    M6R2pre = M6R1 NOT (SIZE M6F2 BY (dmS_M6 + grid))
    M6R2 = WITH WIDTH M6R2pre >= dmW_M6

    M6F3 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 OFFSET dmO_M6 INSIDE OF LAYER M6R2
    M6R3pre = M6R2 NOT (SIZE M6F3 BY (dmS_M6 + grid))
    M6R3 = WITH WIDTH M6R3pre >= dmW_M6

    M6F4 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 INSIDE OF LAYER M6R3

    M6F = (((M6F1 OR M6F2) OR M6F3) OR M6F4) OR M6FW
    FM6 = M6F NOT INTERACT (EXT M6F < dmS_M6 ABUT SINGULAR REGION)

    maxOPENM6 = DENSITY M6x FM6 > maxD_M6 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M6Max.den

    FM6F = FM6 OUTSIDE maxOPENM6

    D25M6 = DENSITY M6x FM6F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M6Min.den

    RM6EXC = SIZE FM6F BY (Odm2DM6 + grid)
    D25M6pM = (((PUSH D25M6) NOT FRAME6) NOT RM6EXC) AND CHIP
    D25M6pM_1 = WITH WIDTH D25M6pM >= OdmW_M6

    RM6p1 = RECTANGLES OdmW_M6 OdmL_M6 OdmS_M6 INSIDE OF LAYER D25M6pM_1
    D25M6pM_2 = D25M6pM_1 NOT (SIZE RM6p1 BY (OdmS_M6 + grid))
    RM6p2 = RECTANGLES OdmL_M6 OdmW_M6 OdmS_M6 INSIDE OF LAYER D25M6pM_2

    RM6A = ((RM6p1 OR RM6p2) OUTSIDE RM6EXC) OUTSIDE FRAME6
    RM6  = RM6A NOT INTERACT (EXT RM6A < OdmS_M6 ABUT SINGULAR REGION)

    DM6F = FM6F OR RM6

    FRAME6_INDDMYA = SIZE M6i BY (dm6_s2m6_INDDMY + grid)
    FRAME6_INDDMYB = SIZE DUM6 BY (dm6_s_INDDMY + grid)
    FRAME6_INDDMYC = SIZE DM6F BY dm6_s_INDDMY
    FRAME6_INDDMY  = ((((FRAME6Pre OR BLOCK6) OR FRAME6_INDDMYA) OR FRAME6_INDDMYB) OR FRAME6_INDDMYC) OR NFILL
    FILL6_INDDMY   = ooINDDMY NOT FRAME6_INDDMY
    DM6F_INDDMY    = RECTANGLES dm6_w_INDDMY dm6_l_INDDMY dm6_s_INDDMY INSIDE OF LAYER FILL6_INDDMY

#IFDEF FILL_indDM6
    FILL6_INDDMY_HD = (SIZE INDDMY_HD BY -(dm6_s_INDDMY_HD + grid)) NOT FRAME6_INDDMY
    DM6F_INDDMY_HD  = RECTANGLES dm6_w_INDDMY_HD dm6_l_INDDMY_HD dm6_s_INDDMY_HD INSIDE OF LAYER FILL6_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M6

    D30M6 = DENSITY M6x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M6.den30
    D40M6 = DENSITY M6x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M6.den40
    D50M6 = DENSITY M6x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M6.den50
    emptyM6 = DENSITY M6x < emptyD_M6 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M6.den_empty

    M6InnerHole = HOLES M6i INNER

    M6BigHole = SIZE M6InnerHole BY - excludeHoleSize/2
    M6ExcHole = ((M6InnerHole OUTSIDE M6BigHole) NOT M6i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK6 = (SIZE DM6EXCL BY (dm2DMEXCL + grid)) OR MIM6_x

    FRAMEA6 = (SIZE M6i BY (DM6_301 + grid)) OR (SIZE (EXPAND EDGE (M6i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA6OPC = SIZE M6i BY (DM6_OPC + grid)
    FRAMEA6OPCDV33 = SIZE (M6i INTERACT M6_HVN_330Vx) BY (M6_S_1_1_a + grid)
    FRAMEA6OPCDV5 = SIZE (M6i INTERACT M6_HVN_500Vx) BY (M6_S_9_a + grid)
    FRAMEA6OPC45 = SIZE (EXPAND EDGE (M6i ANGLE == 45) OUTSIDE BY DM6_OPC_45 EXTEND BY DM6_OPC_45_E) BY grid
    FRAMEA6OPC45DV = SIZE (EXPAND EDGE ((M6i INTERACT M6_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM6_OPC_45 EXTEND BY DM6_OPC_45_E) BY grid

    FRAMEB6 = SIZE (WITH WIDTH M6i > wideM6) BY (dm2WM6 + grid)
    FRAMEC6 = SIZE DUM6 BY (dm2DM6 + grid)
    FRAMED6 = SIZE (WITH WIDTH M6i > wideM6_small) BY (dm2WM6_small + grid)
    FRAMEC6OPC = SIZE DUM6 BY (Odm2DM6 + grid)
    FRAME6Pre = ((FRAMEA6 OR FRAMEB6) OR (FRAMEC6 OR FRAMED6)) OR M6ExcHole
    FRAME6PreOPC = (((((((FRAMEA6OPC OR FRAMEA6OPCDV33) OR FRAMEA6OPCDV5) OR FRAMEC6OPC) OR M6ExcHole) OR FRAMEA6OPC45) OR FRAMEA6OPC45DV) OR FRAMEB6) OR FRAMED6
    FRAME6INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm6_s2m6_INDDMY + grid)

    FRAME6OPC = ((FRAME6PreOPC OR FRAME6INDDMY) OR BLOCK6) OR NFILLOPC

    FRAME6 = ((FRAME6Pre OR FRAME6INDDMY) OR BLOCK6) OR NFILL

    //****************************************************************************

    D30M6p = (PUSH D30M6) NOT FRAME6
    O30M6pre = D30M6p AND CHIP
    FD21M6s = COPY FRAME6

    O30M6preA = SIZE O30M6pre BY -DM6_303
    O30M6preB = O30M6preA WITH WIDTH >= WM6_303

    // 1st big
    F303M6 = RECTANGLES WM6_303 LM6_303 SM6_303 OFFSET OM6_303 INSIDE OF LAYER O30M6preB

    F303M6_EXP = SIZE F303M6 BY ( SM6_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M6preF1 = O30M6pre NOT (SIZE F303M6_EXP BY SM6_302)
    O30M6preF  = (SNAP (SIZE O30M6preF1 BY -grid) 5) AND O30M6preF1

    B30M6s = FD21M6s OR (SIZE F303M6_EXP BY (SM6_302+grid))
    O30M6 = O30M6preF NOT B30M6s

    // 3rd, middle
    F302M6 = RECTANGLES WM6_302 LM6_302 SM6_302 OFFSET OM6_302 INSIDE OF LAYER O30M6
    F302M6s = (SIZE F302M6 BY (SM6_301 + grid)) OR B30M6s
    R302M6pre = O30M6 NOT F302M6s
    R302M6 = WITH WIDTH R302M6pre >= WM6_301

    // 4th, small
    F3012M6 = RECTANGLES WM6_301 LM6_301 SM6_301 OFFSET OM6_301 INSIDE OF LAYER R302M6
    F3012M6s = (SIZE F3012M6 BY (SM6_301 + grid)) OR F302M6s
    R3012M6pre = R302M6pre NOT F3012M6s
    R3012M6 = WITH WIDTH R3012M6pre >= WM6_301

    // 5th, non-stagger small
    F301M6 = RECTANGLES WM6_301 LM6_301 SM6_301 INSIDE OF LAYER R3012M6 //MAINTAIN SPACING
    F301M6s = (SIZE F301M6 BY (SM6_301 + grid)) OR F3012M6s

    F30M6 = ((F302M6 OR F3012M6) OR F301M6) OR F303M6
    O40M6pre = (((PUSH D40M6) NOT FRAME6) NOT F301M6s) AND CHIP


    O40M6preA = SIZE O40M6pre BY -DM6_403
    O40M6preB = O40M6preA WITH WIDTH >= WM6_403

    // 1st big
    F403M6 = RECTANGLES WM6_403 LM6_403 SM6_403 OFFSET OM6_403 INSIDE OF LAYER O40M6preB

    F403M6_EXP = SIZE F403M6 BY ( SM6_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M6preF1 = O40M6pre NOT (SIZE F403M6_EXP BY SM6_402)
    O40M6preF  = (SNAP (SIZE O40M6preF1 BY -grid) 5) AND O40M6preF1

    B40M6s = F301M6s OR (SIZE F403M6_EXP BY (SM6_402+grid))
    O40M6 = O40M6preF NOT B40M6s

    // 3rd, middle
    F402M6 = RECTANGLES WM6_402 LM6_402 SM6_402 OFFSET OM6_402 INSIDE OF LAYER O40M6
    F402M6s = (SIZE F402M6 BY (SM6_401 + grid)) OR B40M6s
    R402M6pre = O40M6 NOT F402M6s
    R402M6 = WITH WIDTH R402M6pre >= WM6_401

    // 4th, small
    F4012M6 = RECTANGLES WM6_401 LM6_401 SM6_401 OFFSET OM6_401 INSIDE OF LAYER R402M6
    F4012M6s = (SIZE F4012M6 BY (SM6_401 + grid)) OR F402M6s
    R4012M6pre = R402M6pre NOT F4012M6s
    R4012M6 = WITH WIDTH R4012M6pre >= WM6_401

    // 5th, non-stagger small
    F401M6 = RECTANGLES WM6_401 LM6_401 SM6_401 INSIDE OF LAYER R4012M6 //MAINTAIN SPACING
    F401M6s = (SIZE F401M6 BY (SM6_401 + grid)) OR F4012M6s

    F40M6 = ((F402M6 OR F4012M6) OR F401M6) OR F403M6
    O50M6pre = (((PUSH (D50M6 OR emptyM6)) NOT FRAME6) NOT F401M6s) AND CHIP


    O50M6preA = SIZE O50M6pre BY -DM6_503
    O50M6preB = O50M6preA WITH WIDTH >= WM6_503

    // 1st big
    F503M6 = RECTANGLES WM6_503 LM6_503 SM6_503 OFFSET OM6_503 INSIDE OF LAYER O50M6preB

    F503M6_EXP = SIZE F503M6 BY ( SM6_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M6preF1 = O50M6pre NOT (SIZE F503M6_EXP BY SM6_502)
    O50M6preF  = (SNAP (SIZE O50M6preF1 BY -grid) 5) AND O50M6preF1

    B50M6s = F401M6s OR (SIZE F503M6_EXP BY (SM6_502+grid))
    O50M6 = O50M6preF NOT B50M6s

    // 3rd, middle
    F502M6 = RECTANGLES WM6_502 LM6_502 SM6_502 OFFSET OM6_502 INSIDE OF LAYER O50M6
    F502M6s = (SIZE F502M6 BY (SM6_501 + grid)) OR B50M6s
    R502M6pre = O50M6 NOT F502M6s
    R502M6 = WITH WIDTH R502M6pre >= WM6_501

    // 4th, small
    F5012M6 = RECTANGLES WM6_501 LM6_501 SM6_501 OFFSET OM6_501 INSIDE OF LAYER R502M6
    F5012M6s = (SIZE F5012M6 BY (SM6_501 + grid)) OR F502M6s
    R5012M6pre = R502M6pre NOT F5012M6s
    R5012M6 = WITH WIDTH R5012M6pre >= WM6_501

    // 5th, non-stagger small
    F501M6 = RECTANGLES WM6_501 LM6_501 SM6_501 INSIDE OF LAYER R5012M6 //MAINTAIN SPACING
    F501M6s = (SIZE F501M6 BY (SM6_501 + grid)) OR F5012M6s

    F50M6 = ((F502M6 OR F5012M6) OR F501M6) OR F503M6

//****************************************************************************

    exceedM6 = DENSITY M6x F30M6 F40M6 F50M6 > maxD_M6 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M6.den_exceed

    removeM6R = ((PUSH (exceedM6 AND (D50M6 OR emptyM6))) NOT FRAME6) AND CHIP
    removeM6P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM6R

    F30M6x = F30M6 NOT INTERACT removeM6P
    F40M6x = F40M6 NOT INTERACT removeM6P
    F50M6x = F50M6 NOT INTERACT removeM6P
    FM6xA  = (F30M6x OR F40M6x) OR F50M6x
    FM6x   = FM6xA NOT INTERACT (EXT FM6xA < DM6_S_1 ABUT SINGULAR REGION)

    ALLM6x = M6x OR FM6x
    lackM6 = DENSITY ALLM6x CHIP < DM6_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M6.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM6x)/AREA(CHIP) ]

    WDM6EXC = DUM6 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM6EXC = (SIZE FM6x BY Odm2DM6) OR (SIZE (((F303M6_EXP OR F403M6_EXP) OR F503M6_EXP) OR WDM6EXC) BY 1.5)

    lackM6pRM = ((((PUSH lackM6) NOT RM6EXC) NOT FRAME6OPC) NOT exceedM6) AND CHIP
    lackM6pRM_1 = WITH WIDTH lackM6pRM >= SM6_OPC

    RM6p1 = RECTANGLES WM6_OPC LM6_OPC WSM6_OPC LSM6_OPC INSIDE OF LAYER lackM6pRM_1
    lackM6pRM_2 = lackM6pRM_1 NOT (SIZE RM6p1 BY SM6_OPC)
    RM6p2 = RECTANGLES LM6_OPC WM6_OPC LSM6_OPC WSM6_OPC INSIDE OF LAYER lackM6pRM_2

    ODM6A = ((RM6p1 OR RM6p2) OUTSIDE RM6EXC) OUTSIDE FRAME6OPC
    ODM6F = ODM6A NOT INTERACT (EXT ODM6A < SM6_OPC ABUT SINGULAR REGION)

    DM6F = COPY FM6x

    FRAME6_INDDMYA = SIZE M6i BY (dm6_s2m6_INDDMY + grid)
    FRAME6_INDDMYB = SIZE DUM6 BY (dm6_s_INDDMY + grid)
    FRAME6_INDDMYC = SIZE DM6F BY dm6_s_INDDMY
    FRAME6_INDDMYD = SIZE ODM6F BY dm6_s2m6_INDDMY
    FRAME6_INDDMY  = (((((FRAME6Pre OR BLOCK6) OR FRAME6_INDDMYA) OR FRAME6_INDDMYB) OR FRAME6_INDDMYC) OR FRAME6_INDDMYD) OR NFILL
    FILL6_INDDMY   = ooINDDMY NOT FRAME6_INDDMY
    DM6F_INDDMY    = RECTANGLES dm6_w_INDDMY dm6_l_INDDMY dm6_s_INDDMY INSIDE OF LAYER FILL6_INDDMY


#IFDEF FILL_indDM6
    FILL6_INDDMY_HD = (SIZE INDDMY_HD BY -(dm6_s_INDDMY_HD + grid)) NOT FRAME6_INDDMY
    DM6F_INDDMY_HD  = RECTANGLES dm6_w_INDDMY_HD dm6_l_INDDMY_HD dm6_s_INDDMY_HD INSIDE OF LAYER FILL6_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M6

    minOPENM6 = DENSITY M6x < minD_M6 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M6Min.den
    emptyOPENM6 = DENSITY M6x < emptyD_M6 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M6Empty.den

    M6InnerHole = HOLES M6i INNER

    M6BigHole = SIZE M6InnerHole BY - excludeHoleSize/2
    M6ExcHole = ((M6InnerHole OUTSIDE M6BigHole) NOT M6i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK6 = (SIZE DM6EXCL BY (dm2DMEXCL + grid)) OR MIM6_x // DM6 to DM6EXCL
    FRAMEA6 = SIZE M6i BY (dm2M6 + grid) // DM6 to metal
    FRAMEB6 = SIZE (WITH WIDTH M6i > wideM6) BY (dm2WM6 + grid)
    FRAMEC6 = SIZE DUM6 BY (dm2DM6 + grid)   // DM6 to existed dummy metal 0.6um
    FRAME6Pre = ((FRAMEA6 OR FRAMEB6) OR FRAMEC6) OR M6ExcHole
    FRAME6INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm6_s2m6_INDDMY + grid)
    FRAME6 = ((FRAME6Pre OR FRAME6INDDMY) OR BLOCK6) OR NFILL
    
    OPENM6 = PUSH ((minOPENM6 OR emptyOPENM6) AND CHIP)
    FILL6 = OPENM6 NOT FRAME6
    FILLW6pre = SIZE FILL6 BY - (Wdm2M6 + grid)
    FILLW6 = WITH WIDTH FILLW6pre >= WdmW_M6
    M6FW = RECTANGLES WdmW_M6 WdmL_M6 WdmS_M6 OFFSET WdmO_M6 INSIDE OF LAYER FILLW6
    M6FW_EXP = SIZE M6FW BY (WdmS_M6 /2 + grid) OVERUNDER //merge the gaps
    FILLM6pre = FILL6 NOT (SIZE M6FW_EXP BY (MdmS_M6 + grid))
    FILLM6 = WITH WIDTH FILLM6pre >= MdmW_M6
    M6F1 = RECTANGLES MdmW_M6 MdmL_M6 MdmS_M6 OFFSET MdmO_M6 INSIDE OF LAYER FILLM6
    M6R1pre = FILLM6pre NOT (SIZE M6F1 BY (dmS_M6 + grid))
    M6R1 = WITH WIDTH M6R1pre >= dmW_M6

    M6F2 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 OFFSET dmO_M6 INSIDE OF LAYER M6R1
    M6R2pre = M6R1 NOT (SIZE M6F2 BY (dmS_M6 + grid))
    M6R2 = WITH WIDTH M6R2pre >= dmW_M6

    M6F3 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 OFFSET dmO_M6 INSIDE OF LAYER M6R2
    M6R3pre = M6R2 NOT (SIZE M6F3 BY (dmS_M6 + grid))
    M6R3 = WITH WIDTH M6R3pre >= dmW_M6

    M6F4 = RECTANGLES dmW_M6 dmL_M6 dmS_M6 INSIDE OF LAYER M6R3

    M6F = (((M6F1 OR M6F2) OR M6F3) OR M6F4) OR M6FW
    FM6 = M6F NOT INTERACT (EXT M6F < dmS_M6 ABUT SINGULAR REGION)

    maxOPENM6 = DENSITY M6x FM6 > maxD_M6 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M6Max.den

    FM6F = FM6 OUTSIDE maxOPENM6

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M6 = DENSITY M6x FM6F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M6Min.den

    RM6EXC = SIZE FM6F BY (Odm2DM6 + grid)
    // do not fill DMz_S over CTMDMY
    D25M6pM = (((PUSH D25M6) NOT FRAME6) NOT RM6EXC) AND CHIP
    D25M6pM_1 = WITH WIDTH D25M6pM >= OdmW_M6

    RM6p1 = RECTANGLES OdmW_M6 OdmL_M6 OdmS_M6 INSIDE OF LAYER D25M6pM_1
    D25M6pM_2 = D25M6pM_1 NOT (SIZE RM6p1 BY (OdmS_M6 + grid))
    RM6p2 = RECTANGLES OdmL_M6 OdmW_M6 OdmS_M6 INSIDE OF LAYER D25M6pM_2

    RM6A = ((RM6p1 OR RM6p2) OUTSIDE RM6EXC) OUTSIDE FRAME6
    RM6  = RM6A NOT INTERACT (EXT RM6A < OdmS_M6 ABUT SINGULAR REGION)

    DM6F = FM6F OR RM6

    FRAME6_INDDMYA = SIZE M6i BY (dm6_s2m6_INDDMY + grid)
    FRAME6_INDDMYB = SIZE DUM6 BY (dm6_s_INDDMY + grid)
    FRAME6_INDDMYC = SIZE DM6F BY dm6_s_INDDMY
    FRAME6_INDDMY  = ((((FRAME6Pre OR BLOCK6) OR FRAME6_INDDMYA) OR FRAME6_INDDMYB) OR FRAME6_INDDMYC) OR NFILL
    FILL6_INDDMY   = ooINDDMY NOT FRAME6_INDDMY
    DM6F_INDDMY    = RECTANGLES dm6_w_INDDMY dm6_l_INDDMY dm6_s_INDDMY INSIDE OF LAYER FILL6_INDDMY

#IFDEF FILL_indDM6
    FILL6_INDDMY_HD = (SIZE INDDMY_HD BY -(dm6_s_INDDMY_HD + grid)) NOT FRAME6_INDDMY
    DM6F_INDDMY_HD  = RECTANGLES dm6_w_INDDMY_HD dm6_l_INDDMY_HD dm6_s_INDDMY_HD INSIDE OF LAYER FILL6_INDDMY_HD
#ENDIF	

#ELSE



    D30M6 = DENSITY M6x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M6.den30
    D40M6 = DENSITY M6x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M6.den40
    D50M6 = DENSITY M6x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M6.den50
    emptyM6 = DENSITY M6x < emptyD_M6 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M6.den_empty

    M6InnerHole = HOLES M6i INNER
#IFDEF FILL_M6_DTCD
    VARIABLE M6_DTCD2Chip      2.5  //
    VARIABLE M6_DTCD2LOGO      10   //
    VARIABLE M6_DTCD2MOMDMY    0    // 
    VARIABLE M6_DTCD2LOWMEDN   0    //
    VARIABLE M6_DTCD2POFUSE    0    //
    VARIABLE M6_DTCD2DM6EXCL   0    //
    VARIABLE M6_DTCD2DM6CB2   0    //
    VARIABLE M6_DTCD2M6        2.63  // CB2.S.2
    VARIABLE M6_DTCD2DM6       1.5  // DMx.S.2
    VARIABLE M6_DTCD2TCDDMY_M6 150  // for idu measurement
    VARIABLE M6_DTCD2CTMDMY_7 0.112  // MIM.VIAz.S.5
    VARIABLE M6_DTCD2ICOVL     8
	M6_DTCDxChip        = CHIP NOT (SIZE CHIP BY -(M6_DTCD2Chip + grid))
    M6_DTCDxLOGO        = SIZE LOGO               BY (M6_DTCD2LOGO      + grid)
    M6_DTCDxMOMDMY      = SIZE MOMDMY             BY (M6_DTCD2MOMDMY    + grid)
    M6_DTCDxLOWMEDN     = SIZE LOWMEDN            BY (M6_DTCD2LOWMEDN   + grid)
    M6_DTCDxPOFUSE      = SIZE (FUSELINK AND POi) BY (M6_DTCD2POFUSE    + grid)
    M6_DTCDxDM6EXCL     = SIZE DM6EXCL            BY (M6_DTCD2DM6EXCL   + grid)
    M6_DTCDxDM6CB2      = SIZE CB2i               BY (M6_DTCD2DM6CB2    + grid)
    M6_DTCDxM6          = SIZE M6i                BY (M6_DTCD2M6        + grid)
    M6_DTCDxDM6         = SIZE DUM6               BY (M6_DTCD2DM6       + grid)
    M6_DTCDxTCDDMY_M6   = SIZE TCDDMY_M6          BY (M6_DTCD2TCDDMY_M6 + grid)
    M6_DTCDxTCDDMY_FM6  = SIZE TCDDMY_FM6         BY (M6_DTCD2TCDDMY_M6 + grid)
    M6_DTCDxTCDDMY_FDM6 = SIZE TCDDMY_FDM6        BY (M6_DTCD2TCDDMY_M6 + grid)
    M6_DTCDxICOVL       = SIZE ICOVL              BY (M6_DTCD2ICOVL     + grid)
    M6_DTCDxCTMDMY_7   = SIZE CTMDMY_7          BY (M6_DTCD2CTMDMY_7  + grid)

    M6_DTCDx = (((((((((((((M6_DTCDxChip OR M6_DTCDxLOGO) OR M6_DTCDxLOWMEDN) OR M6_DTCDxPOFUSE) OR M6_DTCDxDM6EXCL) OR M6_DTCDxM6) OR M6_DTCDxDM6) OR M6_DTCDxTCDDMY_M6) OR M6_DTCDxTCDDMY_FM6) OR M6_DTCDxTCDDMY_FDM6) OR FRAME6INDDMY) OR M6_DTCDxMOMDMY) OR M6_DTCDxDM6CB2) OR M6_DTCDxCTMDMY_7) OR M6_DTCDxICOVL
    M6_DTCDo = CHIP NOT M6_DTCDx

