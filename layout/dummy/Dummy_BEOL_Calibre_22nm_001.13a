#IFDEF FILL_DM6
DM6F_FOR_DVIA6F_REGION = ((DM6F OR DUM6) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM6F_FOR_DVIA6F_REGION = (DUM6 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

#IFDEF FILL_DM7
DM7F_FOR_DVIA6F_REGION = ((DM7F OR DUM7) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM7F_FOR_DVIA6F_REGION = (DUM7 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

// Find DVIA6 fillable regions.  Consider enclosure to lower DM6, enclosure to upper DM7, DVIA6 size.

VARIABLE DM6_F_4_REGION_DVIA6_SHORTENED_LENGTH DVIA6_EN_2 - DVIA6_EN_1

#IFDEF VERTICAL_DM6
DM6_F_4_REGION_DVIA6_spec_B_pre = RECTANGLE DM6F_FOR_DVIA6F_REGION == WM6_303_SLOT BY == LM6_303_SLOT
DM6_F_4_REGION_DVIA6_spec_B     = DM6_F_4_REGION_DVIA6_spec_B_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA6_spec_B_pre == WM6_303_SLOT) INSIDE BY DM6_F_4_REGION_DVIA6_SHORTENED_LENGTH)

DM6_F_4_REGION_DVIA6_spec_M_pre = RECTANGLE DM6F_FOR_DVIA6F_REGION == WM6_302 BY == LM6_302
DM6_F_4_REGION_DVIA6_spec_M     = DM6_F_4_REGION_DVIA6_spec_M_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA6_spec_M_pre == WM6_302) INSIDE BY DM6_F_4_REGION_DVIA6_SHORTENED_LENGTH)

DM6_F_4_REGION_DVIA6_spec_S_pre = RECTANGLE DM6F_FOR_DVIA6F_REGION == WM6_301 BY == LM6_301
DM6_F_4_REGION_DVIA6_spec_S     = DM6_F_4_REGION_DVIA6_spec_S_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA6_spec_S_pre == WM6_301) INSIDE BY DM6_F_4_REGION_DVIA6_SHORTENED_LENGTH)
#ELSE
DM6_F_4_REGION_DVIA6_spec_B_pre = RECTANGLE DM6F_FOR_DVIA6F_REGION == LM6_303_SLOT BY == WM6_303_SLOT
DM6_F_4_REGION_DVIA6_spec_B     = DM6_F_4_REGION_DVIA6_spec_B_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA6_spec_B_pre == LM6_303_SLOT) INSIDE BY DM6_F_4_REGION_DVIA6_SHORTENED_LENGTH)

DM6_F_4_REGION_DVIA6_spec_M_pre = RECTANGLE DM6F_FOR_DVIA6F_REGION == LM6_302 BY == WM6_302
DM6_F_4_REGION_DVIA6_spec_M     = DM6_F_4_REGION_DVIA6_spec_M_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA6_spec_M_pre == LM6_302) INSIDE BY DM6_F_4_REGION_DVIA6_SHORTENED_LENGTH)

DM6_F_4_REGION_DVIA6_spec_S_pre = RECTANGLE DM6F_FOR_DVIA6F_REGION == LM6_301 BY == WM6_301
DM6_F_4_REGION_DVIA6_spec_S     = DM6_F_4_REGION_DVIA6_spec_S_pre NOT (EXPAND EDGE (LENGTH DM6_F_4_REGION_DVIA6_spec_S_pre == LM6_301) INSIDE BY DM6_F_4_REGION_DVIA6_SHORTENED_LENGTH)
#ENDIF
DM6_F_4_REGION_DVIA6_square_pre = RECTANGLE DM6F_FOR_DVIA6F_REGION ASPECT == 1
DM6_F_4_REGION_DVIA6_square     = SIZE DM6_F_4_REGION_DVIA6_square_pre BY -DM6_F_4_REGION_DVIA6_SHORTENED_LENGTH

DM6F_FOR_DVIA6F_REGION_4parts = (DM6_F_4_REGION_DVIA6_spec_B OR DM6_F_4_REGION_DVIA6_spec_M) OR (DM6_F_4_REGION_DVIA6_spec_S OR DM6_F_4_REGION_DVIA6_square)
DM6F_FOR_DVIA6F_REGION_remainder_pre_not = (DM6_F_4_REGION_DVIA6_spec_B_pre OR DM6_F_4_REGION_DVIA6_spec_M_pre) OR (DM6_F_4_REGION_DVIA6_spec_S_pre OR DM6_F_4_REGION_DVIA6_square_pre)
DM6F_FOR_DVIA6F_REGION_remainder = DM6F_FOR_DVIA6F_REGION NOT DM6F_FOR_DVIA6F_REGION_remainder_pre_not

    DM6F_FOR_DVIA6F_REGION_remainder_EDGE = LENGTH DM6F_FOR_DVIA6F_REGION_remainder > 0
    DM6F_FOR_DVIA6F_REGION_remainder_PROP = DFM PROPERTY DM6F_FOR_DVIA6F_REGION_remainder DM6F_FOR_DVIA6F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM6F_FOR_DVIA6F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM6F_FOR_DVIA6F_REGION_remainder_EDGE)) ]
    DM6F_FOR_DVIA6F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM6F_FOR_DVIA6F_REGION_remainder_EDGE DM6F_FOR_DVIA6F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM6F_FOR_DVIA6F_REGION_remainder_EDGE) - PROPERTY(DM6F_FOR_DVIA6F_REGION_remainder_PROP, DM6F_FOR_DVIA6F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM6F_FOR_DVIA6F_REGION2 = DM6F_FOR_DVIA6F_REGION_remainder NOT (EXPAND EDGE DM6F_FOR_DVIA6F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM6_F_4_REGION_DVIA6_SHORTENED_LENGTH)


VARIABLE DM7_F_4_REGION_DVIA6_SHORTENED_LENGTH DM7_EN_3 - DM7_EN_2

#IFDEF VERTICAL_DM7
DM7_F_4_REGION_DVIA6_spec_B_pre = RECTANGLE DM7F_FOR_DVIA6F_REGION == WM7_303_SLOT BY == LM7_303_SLOT
DM7_F_4_REGION_DVIA6_spec_B     = DM7_F_4_REGION_DVIA6_spec_B_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA6_spec_B_pre == WM7_303_SLOT) INSIDE BY DM7_F_4_REGION_DVIA6_SHORTENED_LENGTH)

DM7_F_4_REGION_DVIA6_spec_M_pre = RECTANGLE DM7F_FOR_DVIA6F_REGION == WM7_302 BY == LM7_302
DM7_F_4_REGION_DVIA6_spec_M     = DM7_F_4_REGION_DVIA6_spec_M_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA6_spec_M_pre == WM7_302) INSIDE BY DM7_F_4_REGION_DVIA6_SHORTENED_LENGTH)

DM7_F_4_REGION_DVIA6_spec_S_pre = RECTANGLE DM7F_FOR_DVIA6F_REGION == WM7_301 BY == LM7_301
DM7_F_4_REGION_DVIA6_spec_S     = DM7_F_4_REGION_DVIA6_spec_S_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA6_spec_S_pre == WM7_301) INSIDE BY DM7_F_4_REGION_DVIA6_SHORTENED_LENGTH)
#ELSE
DM7_F_4_REGION_DVIA6_spec_B_pre = RECTANGLE DM7F_FOR_DVIA6F_REGION == LM7_303_SLOT BY == WM7_303_SLOT
DM7_F_4_REGION_DVIA6_spec_B     = DM7_F_4_REGION_DVIA6_spec_B_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA6_spec_B_pre == LM7_303_SLOT) INSIDE BY DM7_F_4_REGION_DVIA6_SHORTENED_LENGTH)

DM7_F_4_REGION_DVIA6_spec_M_pre = RECTANGLE DM7F_FOR_DVIA6F_REGION == LM7_302 BY == WM7_302
DM7_F_4_REGION_DVIA6_spec_M     = DM7_F_4_REGION_DVIA6_spec_M_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA6_spec_M_pre == LM7_302) INSIDE BY DM7_F_4_REGION_DVIA6_SHORTENED_LENGTH)

DM7_F_4_REGION_DVIA6_spec_S_pre = RECTANGLE DM7F_FOR_DVIA6F_REGION == LM7_301 BY == WM7_301
DM7_F_4_REGION_DVIA6_spec_S     = DM7_F_4_REGION_DVIA6_spec_S_pre NOT (EXPAND EDGE (LENGTH DM7_F_4_REGION_DVIA6_spec_S_pre == LM7_301) INSIDE BY DM7_F_4_REGION_DVIA6_SHORTENED_LENGTH)
#ENDIF

DM7_F_4_REGION_DVIA6_square_pre = RECTANGLE DM7F_FOR_DVIA6F_REGION ASPECT == 1
DM7_F_4_REGION_DVIA6_square     = SIZE DM7_F_4_REGION_DVIA6_square_pre BY -DM7_F_4_REGION_DVIA6_SHORTENED_LENGTH

DM7F_FOR_DVIA6F_REGION_4parts = (DM7_F_4_REGION_DVIA6_spec_B OR DM7_F_4_REGION_DVIA6_spec_M) OR (DM7_F_4_REGION_DVIA6_spec_S OR DM7_F_4_REGION_DVIA6_square)
DM7F_FOR_DVIA6F_REGION_remainder_pre_not = (DM7_F_4_REGION_DVIA6_spec_B_pre OR DM7_F_4_REGION_DVIA6_spec_M_pre) OR (DM7_F_4_REGION_DVIA6_spec_S_pre OR DM7_F_4_REGION_DVIA6_square_pre)
DM7F_FOR_DVIA6F_REGION_remainder = DM7F_FOR_DVIA6F_REGION NOT DM7F_FOR_DVIA6F_REGION_remainder_pre_not

    DM7F_FOR_DVIA6F_REGION_remainder_EDGE = LENGTH DM7F_FOR_DVIA6F_REGION_remainder > 0
    DM7F_FOR_DVIA6F_REGION_remainder_PROP = DFM PROPERTY DM7F_FOR_DVIA6F_REGION_remainder DM7F_FOR_DVIA6F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM7F_FOR_DVIA6F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM7F_FOR_DVIA6F_REGION_remainder_EDGE)) ]
    DM7F_FOR_DVIA6F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM7F_FOR_DVIA6F_REGION_remainder_EDGE DM7F_FOR_DVIA6F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM7F_FOR_DVIA6F_REGION_remainder_EDGE) - PROPERTY(DM7F_FOR_DVIA6F_REGION_remainder_PROP, DM7F_FOR_DVIA6F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM7F_FOR_DVIA6F_REGION2 = DM7F_FOR_DVIA6F_REGION_remainder NOT (EXPAND EDGE DM7F_FOR_DVIA6F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM7_F_4_REGION_DVIA6_SHORTENED_LENGTH)

DVIA6F_BASE_REGION = (((((SIZE (DM6F_FOR_DVIA6F_REGION2 OR DM6F_FOR_DVIA6F_REGION_4parts) BY -DVIA6_EN_1) AND (SIZE (DM7F_FOR_DVIA6F_REGION2 OR DM7F_FOR_DVIA6F_REGION_4parts) BY -DM7_EN_2)) WITH WIDTH >= DVIA6_W_1) NOT (SIZE DVIA6EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA6i BY (DVIA6_S_1 + grid))) NOT (SIZE VIA6i BY (DVIA6_S_2 + grid))




// Merge DVIA6 fillable regions, and find DVIA6 seeds by maintaining spacing DVIA6_S_1.
DVIA6F_SEED_REGION_1 = (((SIZE DVIA6F_BASE_REGION BY DVIA6F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA6EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA6i BY (DVIA6_S_1 + grid))) NOT (SIZE VIA6i BY (DVIA6_S_2 + grid))
DVIA6F_SEED_1 = RECTANGLES DVIA6_W_1 DVIA6_W_1 DVIA6_S_1 INSIDE OF LAYER DVIA6F_SEED_REGION_1

// Find DVIA6 in the DVIA6 fillable and spacing-maintained regions.
DVIA6F_REGION_1 = (DVIA6F_BASE_REGION INTERACT DVIA6F_SEED_1) NOT TOUCH DVIA6F_SEED_1
DVIA6F_pre1_1_pre1 = RECTANGLES DVIA6_W_1 DVIA6_W_1 DVIA6_S_1 INSIDE OF LAYER DVIA6F_REGION_1

// post-DRC
DVIA6F_pre1_1_pre2 = DVIA6F_pre1_1_pre1 NOT INTERACT (EXT DVIA6F_pre1_1_pre1 < DVIA6_S_1 ABUT SINGULAR REGION)
DVIA6F_pre1_1_pre3 = DVIA6F_pre1_1_pre2 NOT INTERACT (EXT DVIA6F_pre1_1_pre2 DUVIA6i < DVIA6_S_1 ABUT SINGULAR REGION)
DVIA6F_pre1_1_pre4 = DVIA6F_pre1_1_pre3 NOT INTERACT (EXT DVIA6F_pre1_1_pre3 VIA6i < DVIA6_S_2 ABUT SINGULAR REGION)
DVIA6F_pre1_1_pre5 = DVIA6F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA6F_pre1_1_pre4 DM6F_FOR_DVIA6F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA6_EN_2 OPPOSITE 0 DVIA6_EN_2 OPPOSITE)
DVIA6F_pre1_1      = DVIA6F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA6F_pre1_1_pre5 DM7F_FOR_DVIA6F_REGION ABUT < 90 SINGULAR GOOD 0 DM7_EN_3 OPPOSITE 0 DM7_EN_3 OPPOSITE)

// Merge DVIA6 fillable regions, and find DVIA6 seeds by maintaining spacing DVIA6_S_1.
DVIA6F_SEED_REGION_2 = (((SIZE (DVIA6F_BASE_REGION NOT INTERACT (SIZE DVIA6F_pre1_1 BY DVIA6_S_1)) BY DVIA6F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA6EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA6i BY (DVIA6_S_1 + grid))) NOT (SIZE VIA6i BY (DVIA6_S_2 + grid))
DVIA6F_SEED_2 = RECTANGLES DVIA6_W_1 DVIA6_W_1 DVIA6_S_1 INSIDE OF LAYER DVIA6F_SEED_REGION_2

// Find DVIA6 in the DVIA6 fillable and spacing-maintained regions.
DVIA6F_REGION_2 = (DVIA6F_BASE_REGION INTERACT DVIA6F_SEED_2) NOT TOUCH DVIA6F_SEED_2
DVIA6F_pre1_2 = RECTANGLES DVIA6_W_1 DVIA6_W_1 DVIA6_S_1 INSIDE OF LAYER DVIA6F_REGION_2

// post-DRC
DVIA6F_pre1 = DVIA6F_pre1_1 OR DVIA6F_pre1_2
DVIA6F_pre2 = DVIA6F_pre1 NOT INTERACT (EXT DVIA6F_pre1 < DVIA6_S_1 ABUT SINGULAR REGION)
DVIA6F_pre3 = DVIA6F_pre2 NOT INTERACT (EXT DVIA6F_pre2 DUVIA6i < DVIA6_S_1 ABUT SINGULAR REGION)
DVIA6F_pre4 = DVIA6F_pre3 NOT INTERACT (EXT DVIA6F_pre3 VIA6i < DVIA6_S_2 ABUT SINGULAR REGION)
DVIA6F_pre5 = DVIA6F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA6F_pre4 DM6F_FOR_DVIA6F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA6_EN_2 OPPOSITE 0 DVIA6_EN_2 OPPOSITE)
DVIA6F      = DVIA6F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA6F_pre5 DM7F_FOR_DVIA6F_REGION ABUT < 90 SINGULAR GOOD 0 DM7_EN_3 OPPOSITE 0 DM7_EN_3 OPPOSITE)

#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF


