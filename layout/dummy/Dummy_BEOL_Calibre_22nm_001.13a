    R4012M6 = WITH WIDTH R4012M6pre >= WM6_401

    // 5th, non-stagger small
    F401M6 = RECTANGLES WM6_401 LM6_401 SM6_401 INSIDE OF LAYER R4012M6 //MAINTAIN SPACING
    F401M6s = (SIZE F401M6 BY (SM6_401 + grid)) OR F4012M6s

    F40M6 = ((F402M6 OR F4012M6) OR F401M6) OR F403M6_SLOT
    O50M6pre = (((PUSH (D50M6 OR emptyM6)) NOT FRAME6) NOT F401M6s) AND CHIP


    O50M6preA = SIZE O50M6pre BY -DM6_503
    O50M6preB = O50M6preA WITH WIDTH >= WM6_503

    // 1st big
    F503M6 = RECTANGLES WM6_503 LM6_503 SM6_503 OFFSET OM6_503 INSIDE OF LAYER O50M6preB
    F503M6_SLOT = RECTANGLES WM6_503_SLOT LM6_503_SLOT SM6_503_SLOT INSIDE OF LAYER F503M6

    F503M6_EXP = SIZE F503M6_SLOT BY ( SM6_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M6preF1 = O50M6pre NOT (SIZE F503M6_EXP BY SM6_502)
    O50M6preF  = (SNAP (SIZE O50M6preF1 BY -grid) 5) AND O50M6preF1

    B50M6s = F401M6s OR (SIZE F503M6_EXP BY (SM6_502+grid))
    O50M6 = O50M6preF NOT B50M6s

    // 3rd, middle
    F502M6 = RECTANGLES WM6_502 LM6_502 SM6_502 OFFSET OM6_502 INSIDE OF LAYER O50M6
    F502M6s = (SIZE F502M6 BY (SM6_501 + grid)) OR B50M6s
    R502M6pre = O50M6 NOT F502M6s
    R502M6 = WITH WIDTH R502M6pre >= WM6_501

    // 4th, small
    F5012M6 = RECTANGLES WM6_501 LM6_501 SM6_501 OFFSET OM6_501 INSIDE OF LAYER R502M6
    F5012M6s = (SIZE F5012M6 BY (SM6_501 + grid)) OR F502M6s
    R5012M6pre = R502M6pre NOT F5012M6s
    R5012M6 = WITH WIDTH R5012M6pre >= WM6_501

    // 5th, non-stagger small
    F501M6 = RECTANGLES WM6_501 LM6_501 SM6_501 INSIDE OF LAYER R5012M6 //MAINTAIN SPACING
    F501M6s = (SIZE F501M6 BY (SM6_501 + grid)) OR F5012M6s

    F50M6 = ((F502M6 OR F5012M6) OR F501M6) OR F503M6_SLOT

    exceedM6 = DENSITY M6x F30M6 F40M6 F50M6 > maxD_M6 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M6.den_exceed

    removeM6R = ((PUSH (exceedM6 AND (D50M6 OR emptyM6))) NOT FRAME6) AND CHIP
    removeM6P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM6R

    F30M6x = F30M6 NOT INTERACT removeM6P
    F40M6x = F40M6 NOT INTERACT removeM6P
    F50M6x = F50M6 NOT INTERACT removeM6P
    FM6xA  = (F30M6x OR F40M6x) OR F50M6x
    FM6x   = FM6xA NOT INTERACT (EXT FM6xA < DM6_S_1 ABUT SINGULAR REGION)

    ALLM6x = M6x OR FM6x
    lackM6 = DENSITY ALLM6x CHIP < DM6_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M6.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM6x)/AREA(CHIP) ]

    WDM6EXC = DUM6 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM6EXC = (SIZE FM6x BY Odm2DM6) OR (SIZE (((F303M6_EXP OR F403M6_EXP) OR F503M6_EXP) OR WDM6EXC) BY 1.5)

    lackM6pRM = ((((PUSH lackM6) NOT RM6EXC) NOT FRAME6OPC) NOT exceedM6) AND CHIP
    lackM6pRM_1 = WITH WIDTH lackM6pRM >= SM6_OPC

    RM6p1 = RECTANGLES WM6_OPC LM6_OPC WSM6_OPC LSM6_OPC INSIDE OF LAYER lackM6pRM_1
    lackM6pRM_2 = lackM6pRM_1 NOT (SIZE RM6p1 BY SM6_OPC)
    RM6p2 = RECTANGLES LM6_OPC WM6_OPC LSM6_OPC WSM6_OPC INSIDE OF LAYER lackM6pRM_2

    ODM6A = ((RM6p1 OR RM6p2) OUTSIDE RM6EXC) OUTSIDE FRAME6OPC
    ODM6F_pre = ODM6A NOT INTERACT (EXT ODM6A < SM6_OPC ABUT SINGULAR REGION)

// M6.S.14 ~ M6.S.16
M6_S_14_CHK_REGION = M6i OR ODM6F_pre
// Find Wide Metal
Wide_M6_S_14_CHK_REGION = ENCLOSE RECTANGLE (M6_S_14_CHK_REGION NOT WITH WIDTH <= M6_S_14_W1B) M6_S_14_W1B+GRID M6_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M6_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M6_S_14_CHK_REGION == 0
Wide_M6_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M6_S_14_CHK_REGION == 90

// Find Wide Metal Space
M6_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M6_S_14_CHK_REGION_EDGE_H M6_S_14_CHK_REGION < M6_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M6_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M6_S_14_CHK_REGION_EDGE_V M6_S_14_CHK_REGION < M6_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M6_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M6_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M6_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M6_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M6_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M6_S_14_CHK_REGION_OPC_REGION_pre1_H M6_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M6_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M6_S_14_L1B
M6_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M6_S_14_CHK_REGION_OPC_REGION_pre1_V M6_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M6_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M6_S_14_L1B

M6_S_14_OPC_REGION = M6_S_14_CHK_REGION_OPC_REGION_pre2_H OR M6_S_14_CHK_REGION_OPC_REGION_pre2_V

// M6.S.17 ~ M6.S.19
M6_S_17_CHK_REGION = M6i OR ODM6F_pre
// Find Wide Metal
Wide_M6_S_17_CHK_REGION = ENCLOSE RECTANGLE (M6_S_17_CHK_REGION NOT WITH WIDTH <= M6_S_17_W1B) M6_S_17_W1B+GRID M6_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M6_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M6_S_17_CHK_REGION == 0
Wide_M6_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M6_S_17_CHK_REGION == 90

// Find Wide Metal Space
M6_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M6_S_17_CHK_REGION_EDGE_H M6_S_17_CHK_REGION < M6_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M6_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M6_S_17_CHK_REGION_EDGE_V M6_S_17_CHK_REGION < M6_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M6_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M6_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M6_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M6_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M6_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M6_S_17_CHK_REGION_OPC_REGION_pre1_H M6_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M6_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M6_S_17_L1B
M6_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M6_S_17_CHK_REGION_OPC_REGION_pre1_V M6_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M6_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M6_S_17_L1B

M6_S_17_OPC_REGION = M6_S_17_CHK_REGION_OPC_REGION_pre2_H OR M6_S_17_CHK_REGION_OPC_REGION_pre2_V

// M6.S.20 ~ M6.S.22
M6_S_20_CHK_REGION = M6i OR ODM6F_pre
// Find Wide Metal
Wide_M6_S_20_CHK_REGION = ENCLOSE RECTANGLE (M6_S_20_CHK_REGION NOT WITH WIDTH <= M6_S_20_W1B) M6_S_20_W1B+GRID M6_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M6_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M6_S_20_CHK_REGION == 0
Wide_M6_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M6_S_20_CHK_REGION == 90

// Find Wide Metal Space
M6_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M6_S_20_CHK_REGION_EDGE_H M6_S_20_CHK_REGION < M6_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M6_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M6_S_20_CHK_REGION_EDGE_V M6_S_20_CHK_REGION < M6_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M6_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M6_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M6_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M6_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M6_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M6_S_20_CHK_REGION_OPC_REGION_pre1_H M6_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M6_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M6_S_20_L1B
M6_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M6_S_20_CHK_REGION_OPC_REGION_pre1_V M6_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M6_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M6_S_20_L1B

M6_S_20_OPC_REGION = M6_S_20_CHK_REGION_OPC_REGION_pre2_H OR M6_S_20_CHK_REGION_OPC_REGION_pre2_V

// M6.S.23 ~ M6.S.25
M6_S_23_CHK_REGION = M6i OR ODM6F_pre
// Find Wide Metal
Wide_M6_S_23_CHK_REGION = ENCLOSE RECTANGLE (M6_S_23_CHK_REGION NOT WITH WIDTH <= M6_S_23_W1B) M6_S_23_W1B+GRID M6_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M6_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M6_S_23_CHK_REGION == 0
Wide_M6_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M6_S_23_CHK_REGION == 90

// Find Wide Metal Space
M6_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M6_S_23_CHK_REGION_EDGE_H M6_S_23_CHK_REGION < M6_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M6_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M6_S_23_CHK_REGION_EDGE_V M6_S_23_CHK_REGION < M6_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M6_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M6_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M6_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M6_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M6_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M6_S_23_CHK_REGION_OPC_REGION_pre1_H M6_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M6_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M6_S_23_L1B
M6_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M6_S_23_CHK_REGION_OPC_REGION_pre1_V M6_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M6_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M6_S_23_L1B

M6_S_23_OPC_REGION = M6_S_23_CHK_REGION_OPC_REGION_pre2_H OR M6_S_23_CHK_REGION_OPC_REGION_pre2_V

// M6.S.27
M6_S_27_CHK_REGION = M6i OR ODM6F_pre
// Find Wide Metal
Wide_M6_S_27_CHK_REGION = ENCLOSE RECTANGLE (M6_S_27_CHK_REGION NOT WITH WIDTH <= M6_S_27_W1B) M6_S_27_W1B+GRID M6_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M6_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M6_S_27_CHK_REGION == 0
Wide_M6_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M6_S_27_CHK_REGION == 90

// Find Wide Metal Space
M6_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M6_S_27_CHK_REGION_EDGE_H M6_S_27_CHK_REGION < M6_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M6_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M6_S_27_CHK_REGION_EDGE_V M6_S_27_CHK_REGION < M6_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M6_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M6_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M6_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M6_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M6_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M6_S_27_CHK_REGION_OPC_REGION_pre1_H M6_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M6_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M6_S_27_L1B
M6_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M6_S_27_CHK_REGION_OPC_REGION_pre1_V M6_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M6_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M6_S_27_L1B

M6_S_27_OPC_REGION = M6_S_27_CHK_REGION_OPC_REGION_pre2_H OR M6_S_27_CHK_REGION_OPC_REGION_pre2_V

M6_WMJ_OPC_REGION = (((M6_S_14_OPC_REGION OR M6_S_17_OPC_REGION) OR M6_S_20_OPC_REGION) OR M6_S_23_OPC_REGION) OR M6_S_27_OPC_REGION

    ODM6F = ODM6F_pre NOT INTERACT M6_WMJ_OPC_REGION

    DM6F = COPY FM6x

    FRAME6_INDDMYA = SIZE M6i BY (dm6_s2m6_INDDMY + grid)
    FRAME6_INDDMYB = SIZE DUM6 BY (dm6_s_INDDMY + grid)
    FRAME6_INDDMYC = SIZE DM6F BY dm6_s_INDDMY
    FRAME6_INDDMYD = SIZE ODM6F BY dm6_s2m6_INDDMY

    FRAME6_INDDMY  = ((((((FRAME6Pre OR xM6_DTCD) OR BLOCK6) OR FRAME6_INDDMYA) OR FRAME6_INDDMYB) OR FRAME6_INDDMYC) OR FRAME6_INDDMYD) OR NFILL_x
    FILL6_INDDMY   = ooINDDMY NOT FRAME6_INDDMY
    DM6F_INDDMY    = RECTANGLES dm6_w_INDDMY dm6_l_INDDMY dm6_s_INDDMY INSIDE OF LAYER FILL6_INDDMY

#IFDEF FILL_indDM6
    FILL6_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm6_s_INDDMY_HD + grid)) NOT FRAME6_INDDMY
    DM6F_INDDMY_HD_pre  = RECTANGLES dm6_w_INDDMY_HD dm6_l_INDDMY_HD dm6_s_INDDMY_HD INSIDE OF LAYER FILL6_INDDMY_HD

    FILL6_INDDMY_MD = (SIZE INDDMY_MD BY -(dm6_s_INDDMY_MD + grid)) NOT (FRAME6_INDDMY OR INDDMY_HD)
    DM6F_INDDMY_MD  = RECTANGLES dm6_w_INDDMY_MD dm6_l_INDDMY_MD dm6_s_INDDMY_MD INSIDE OF LAYER FILL6_INDDMY_MD

    DM6F_INDDMY_HD = DM6F_INDDMY_HD_pre OR DM6F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#IFDEF FILL_DM7


#IFDEF 34K_THICK_Mu_M7

    minOPENM7 = DENSITY M7x < minD_M7 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M7Min.den
    emptyOPENM7 = DENSITY M7x < emptyD_M7 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M7Empty.den

    M7InnerHole = HOLES M7i INNER

    M7BigHole = SIZE M7InnerHole BY - excludeHoleSize/2
    M7ExcHole = ((M7InnerHole OUTSIDE M7BigHole) NOT M7i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK7    = (SIZE DM7EXCL BY (dm2DMEXCL + grid)) OR MIM7_x
    FRAMEA7   = SIZE M7i BY (dm2M7 + grid) // DM7 to metal
    FRAMEB7   = SIZE (WITH WIDTH M7i > wideM7) BY (dm2WM7 + grid)
    FRAMEC7   = SIZE DUM7 BY (dm2DM7 + grid)
    FRAME7Pre = ((FRAMEA7 OR FRAMEB7) OR FRAMEC7) OR M7ExcHole
    FRAME7INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm7_s2m7_INDDMY + grid)
    FRAME7 = ((FRAME7Pre OR FRAME7INDDMY) OR BLOCK7) OR NFILL
    
    OPENM7 = PUSH ((minOPENM7 OR emptyOPENM7) AND CHIP)
    FILL7 = OPENM7 NOT FRAME7
    FILLW7pre = SIZE FILL7 BY - (Wdm2M7 + grid)
    FILLW7 = WITH WIDTH FILLW7pre >= WdmW_M7
    M7FW = RECTANGLES WdmW_M7 WdmL_M7 WdmS_M7 OFFSET WdmO_M7 INSIDE OF LAYER FILLW7
    M7FW_EXP = SIZE M7FW BY (WdmS_M7 /2 + grid) OVERUNDER   // merge the gaps
    FILLM7pre = FILL7 NOT (SIZE M7FW_EXP BY (MdmS_M7 + grid))
    FILLM7 = WITH WIDTH FILLM7pre >= MdmW_M7
    M7F1 = RECTANGLES MdmW_M7 MdmL_M7 MdmS_M7 OFFSET MdmO_M7 INSIDE OF LAYER FILLM7
    M7R1pre = FILLM7pre NOT (SIZE M7F1 BY (dmS_M7 + grid))
    M7R1 = WITH WIDTH M7R1pre >= dmW_M7

    M7F2 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 OFFSET dmO_M7 INSIDE OF LAYER M7R1
    M7R2pre = M7R1 NOT (SIZE M7F2 BY (dmS_M7 + grid))
    M7R2 = WITH WIDTH M7R2pre >= dmW_M7

    M7F3 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 OFFSET dmO_M7 INSIDE OF LAYER M7R2
    M7R3pre = M7R2 NOT (SIZE M7F3 BY (dmS_M7 + grid))
    M7R3 = WITH WIDTH M7R3pre >= dmW_M7

    M7F4 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 INSIDE OF LAYER M7R3

    M7F = (((M7F1 OR M7F2) OR M7F3) OR M7F4) OR M7FW
    FM7 = M7F NOT INTERACT (EXT M7F < dmS_M7 ABUT SINGULAR REGION)

    maxOPENM7 = DENSITY M7x FM7 > maxD_M7 WINDOW WindowSizeu*2 STEP WindowStepu*2
                INSIDE OF LAYER bulk BACKUP // PRINT M7Max.den

    DM7F = FM7 OUTSIDE maxOPENM7

    FRAME7_INDDMYA = SIZE M7i BY (dm7_s2m7_INDDMY + grid)
    FRAME7_INDDMYB = SIZE DUM7 BY (dm7_s_INDDMY + grid)
    FRAME7_INDDMYC = SIZE DM7F BY dm7_s_INDDMY
    FRAME7_INDDMY  = ((((FRAME7Pre OR BLOCK7) OR FRAME7_INDDMYA) OR FRAME7_INDDMYB) OR FRAME7_INDDMYC) OR NFILL
    FILL7_INDDMY   = ooINDDMY NOT FRAME7_INDDMY
    DM7F_INDDMY    = RECTANGLES dm7_w_INDDMY dm7_l_INDDMY dm7_s_INDDMY INSIDE OF LAYER FILL7_INDDMY
#IFDEF FILL_indDM7
    FILL7_INDDMY_HD = (SIZE INDDMY_HD BY -(dm7_s_INDDMY_HD + grid)) NOT FRAME7_INDDMY
    DM7F_INDDMY_HD  = RECTANGLES dm7_w_INDDMY_HD dm7_l_INDDMY_HD dm7_s_INDDMY_HD INSIDE OF LAYER FILL7_INDDMY_HD
#ENDIF	
	
#ELSE


#IFDEF 12K_THICK_Mr_M7

    minOPENM7 = DENSITY M7x < minD_M7 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M7Min.den
    emptyOPENM7 = DENSITY M7x < emptyD_M7 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M7Empty.den

    M7InnerHole = HOLES M7i INNER

    M7BigHole = SIZE M7InnerHole BY - excludeHoleSize/2
    M7ExcHole = ((M7InnerHole OUTSIDE M7BigHole) NOT M7i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK7  = (SIZE DM7EXCL BY (dm2DMEXCL + grid)) OR MIM7_x // DM7 to DM7EXCL
    FRAMEA7 = SIZE M7i BY (dm2M7 + grid) // DM7 to metal
    FRAMEB7 = SIZE (WITH WIDTH M7i > wideM7) BY (dm2WM7 + grid)
    FRAMEC7 = SIZE DUM7 BY (dm2DM7 + grid)   // DM7 to existed dummy metal 0.6um
    FRAME7Pre = ((FRAMEA7 OR FRAMEB7) OR FRAMEC7) OR M7ExcHole
    FRAME7INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm7_s2m7_INDDMY + grid)
    FRAME7 = ((FRAME7Pre OR FRAME7INDDMY) OR BLOCK7) OR NFILL
    
    OPENM7 = PUSH ((minOPENM7 OR emptyOPENM7) AND CHIP)
    FILL7 = OPENM7 NOT FRAME7
    FILLW7pre = SIZE FILL7 BY - (Wdm2M7 + grid)
    FILLW7 = WITH WIDTH FILLW7pre >= WdmW_M7
    M7FW = RECTANGLES WdmW_M7 WdmL_M7 WdmS_M7 OFFSET WdmO_M7 INSIDE OF LAYER FILLW7
    M7FW_EXP = SIZE M7FW BY (WdmS_M7 /2 + grid) OVERUNDER //merge the gaps
    FILLM7pre = FILL7 NOT (SIZE M7FW_EXP BY (MdmS_M7 + grid))
    FILLM7 = WITH WIDTH FILLM7pre >= MdmW_M7
    M7F1 = RECTANGLES MdmW_M7 MdmL_M7 MdmS_M7 OFFSET MdmO_M7 INSIDE OF LAYER FILLM7
    M7R1pre = FILLM7pre NOT (SIZE M7F1 BY (dmS_M7 + grid))
    M7R1 = WITH WIDTH M7R1pre >= dmW_M7

    M7F2 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 OFFSET dmO_M7 INSIDE OF LAYER M7R1
    M7R2pre = M7R1 NOT (SIZE M7F2 BY (dmS_M7 + grid))
    M7R2 = WITH WIDTH M7R2pre >= dmW_M7

    M7F3 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 OFFSET dmO_M7 INSIDE OF LAYER M7R2
    M7R3pre = M7R2 NOT (SIZE M7F3 BY (dmS_M7 + grid))
    M7R3 = WITH WIDTH M7R3pre >= dmW_M7

    M7F4 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 INSIDE OF LAYER M7R3

    M7F = (((M7F1 OR M7F2) OR M7F3) OR M7F4) OR M7FW
    FM7 = M7F NOT INTERACT (EXT M7F < dmS_M7 ABUT SINGULAR REGION)

    maxOPENM7 = DENSITY M7x FM7 > maxD_M7 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M7Max.den

    FM7F = FM7 OUTSIDE maxOPENM7

    // DMr_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M7 = DENSITY M7x FM7F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M7Min.den

    RM7EXC = SIZE FM7F BY (Odm2DM7 + grid)
    // do not fill DMy_S over CTMDMY
    D25M7pM = (((PUSH D25M7) NOT FRAME7) NOT RM7EXC) AND CHIP
    D25M7pM_1 = WITH WIDTH D25M7pM >= OdmW_M7

    RM7p1 = RECTANGLES OdmW_M7 OdmL_M7 OdmS_M7 INSIDE OF LAYER D25M7pM_1
    D25M7pM_2 = D25M7pM_1 NOT (SIZE RM7p1 BY (OdmS_M7 + grid))
    RM7p2 = RECTANGLES OdmL_M7 OdmW_M7 OdmS_M7 INSIDE OF LAYER D25M7pM_2

    RM7A = ((RM7p1 OR RM7p2) OUTSIDE RM7EXC) OUTSIDE FRAME7
    RM7  = RM7A NOT INTERACT (EXT RM7A < OdmS_M7 ABUT SINGULAR REGION)

    DM7F = FM7F OR RM7

    FRAME7_INDDMYA = SIZE M7i BY (dm7_s2m7_INDDMY + grid)
    FRAME7_INDDMYB = SIZE DUM7 BY (dm7_s_INDDMY + grid)
    FRAME7_INDDMYC = SIZE DM7F BY dm7_s_INDDMY
    FRAME7_INDDMY  = ((((FRAME7Pre OR BLOCK7) OR FRAME7_INDDMYA) OR FRAME7_INDDMYB) OR FRAME7_INDDMYC) OR NFILL
    FILL7_INDDMY   = ooINDDMY NOT FRAME7_INDDMY
    DM7F_INDDMY    = RECTANGLES dm7_w_INDDMY dm7_l_INDDMY dm7_s_INDDMY INSIDE OF LAYER FILL7_INDDMY

#IFDEF FILL_indDM7
    FILL7_INDDMY_HD = (SIZE INDDMY_HD BY -(dm7_s_INDDMY_HD + grid)) NOT FRAME7_INDDMY
    DM7F_INDDMY_HD  = RECTANGLES dm7_w_INDDMY_HD dm7_l_INDDMY_HD dm7_s_INDDMY_HD INSIDE OF LAYER FILL7_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 5K_THICK_Myz_M7

    minOPENM7 = DENSITY M7x < minD_M7 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M7Min.den
    emptyOPENM7 = DENSITY M7x < emptyD_M7 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M7Empty.den

    M7InnerHole = HOLES M7i INNER

    M7BigHole = SIZE M7InnerHole BY - excludeHoleSize/2
    M7ExcHole = ((M7InnerHole OUTSIDE M7BigHole) NOT M7i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK7 = (SIZE DM7EXCL BY (dm2DMEXCL + grid)) OR MIM7_x // DM7 to DM7EXCL
    FRAMEA7 = SIZE M7i BY (dm2M7 + grid) // DM7 to metal
    FRAMEB7 = SIZE (WITH WIDTH M7i > wideM7) BY (dm2WM7 + grid)
    FRAMEC7 = SIZE DUM7 BY (dm2DM7 + grid)   // DM7 to existed dummy metal 0.6um
    FRAME7Pre = ((FRAMEA7 OR FRAMEB7) OR FRAMEC7) OR M7ExcHole
    FRAME7INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm7_s2m7_INDDMY + grid)
    FRAME7 = ((FRAME7Pre OR FRAME7INDDMY) OR BLOCK7) OR NFILL
    
    OPENM7 = PUSH ((minOPENM7 OR emptyOPENM7) AND CHIP)
    FILL7 = OPENM7 NOT FRAME7
    FILLW7pre = SIZE FILL7 BY - (Wdm2M7 + grid)
    FILLW7 = WITH WIDTH FILLW7pre >= WdmW_M7
    M7FW = RECTANGLES WdmW_M7 WdmL_M7 WdmS_M7 OFFSET WdmO_M7 INSIDE OF LAYER FILLW7
    M7FW_EXP = SIZE M7FW BY (WdmS_M7 /2 + grid) OVERUNDER //merge the gaps
    FILLM7pre = FILL7 NOT (SIZE M7FW_EXP BY (MdmS_M7 + grid))
    FILLM7 = WITH WIDTH FILLM7pre >= MdmW_M7
    M7F1 = RECTANGLES MdmW_M7 MdmL_M7 MdmS_M7 OFFSET MdmO_M7 INSIDE OF LAYER FILLM7
    M7R1pre = FILLM7pre NOT (SIZE M7F1 BY (dmS_M7 + grid))
    M7R1 = WITH WIDTH M7R1pre >= dmW_M7

    M7F2 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 OFFSET dmO_M7 INSIDE OF LAYER M7R1
    M7R2pre = M7R1 NOT (SIZE M7F2 BY (dmS_M7 + grid))
    M7R2 = WITH WIDTH M7R2pre >= dmW_M7

    M7F3 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 OFFSET dmO_M7 INSIDE OF LAYER M7R2
    M7R3pre = M7R2 NOT (SIZE M7F3 BY (dmS_M7 + grid))
    M7R3 = WITH WIDTH M7R3pre >= dmW_M7

    M7F4 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 INSIDE OF LAYER M7R3

    M7F = (((M7F1 OR M7F2) OR M7F3) OR M7F4) OR M7FW
    FM7 = M7F NOT INTERACT (EXT M7F < dmS_M7 ABUT SINGULAR REGION)

    maxOPENM7 = DENSITY M7x FM7 > maxD_M7 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M7Max.den

    FM7F = FM7 OUTSIDE maxOPENM7

    // DMy_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M7 = DENSITY M7x FM7F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M7Min.den

    RM7EXC = SIZE FM7F BY (Odm2DM7 + grid)
    // do not fill DMy_S over CTMDMY
    D25M7pM = (((PUSH D25M7) NOT FRAME7) NOT RM7EXC) AND CHIP
    D25M7pM_1 = WITH WIDTH D25M7pM >= OdmW_M7

    RM7p1 = RECTANGLES OdmW_M7 OdmL_M7 OdmS_M7 INSIDE OF LAYER D25M7pM_1
    D25M7pM_2 = D25M7pM_1 NOT (SIZE RM7p1 BY (OdmS_M7 + grid))
    RM7p2 = RECTANGLES OdmL_M7 OdmW_M7 OdmS_M7 INSIDE OF LAYER D25M7pM_2

    RM7A = ((RM7p1 OR RM7p2) OUTSIDE RM7EXC) OUTSIDE FRAME7
    RM7  = RM7A NOT INTERACT (EXT RM7A < OdmS_M7 ABUT SINGULAR REGION)

    DM7F = FM7F OR RM7

    FRAME7_INDDMYA = SIZE M7i BY (dm7_s2m7_INDDMY + grid)
    FRAME7_INDDMYB = SIZE DUM7 BY (dm7_s_INDDMY + grid)
    FRAME7_INDDMYC = SIZE DM7F BY dm7_s_INDDMY
    FRAME7_INDDMY  = ((((FRAME7Pre OR BLOCK7) OR FRAME7_INDDMYA) OR FRAME7_INDDMYB) OR FRAME7_INDDMYC) OR NFILL
    FILL7_INDDMY   = ooINDDMY NOT FRAME7_INDDMY
    DM7F_INDDMY    = RECTANGLES dm7_w_INDDMY dm7_l_INDDMY dm7_s_INDDMY INSIDE OF LAYER FILL7_INDDMY


#IFDEF FILL_indDM7
    FILL7_INDDMY_HD = (SIZE INDDMY_HD BY -(dm7_s_INDDMY_HD + grid)) NOT FRAME7_INDDMY
    DM7F_INDDMY_HD  = RECTANGLES dm7_w_INDDMY_HD dm7_l_INDDMY_HD dm7_s_INDDMY_HD INSIDE OF LAYER FILL7_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2_6K_THICK_Mxy_M7

    minOPENM7 = DENSITY M7x < minD_M7 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M7Min.den
    emptyOPENM7 = DENSITY M7x < emptyD_M7 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M7Empty.den

    M7InnerHole = HOLES M7i INNER

    M7BigHole = SIZE M7InnerHole BY - excludeHoleSize/2
    M7ExcHole = ((M7InnerHole OUTSIDE M7BigHole) NOT M7i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK7 = (SIZE DM7EXCL BY (dm2DMEXCL + grid)) OR  MIM7_x // DM7 to DM7EXCL
    FRAMEA7 = SIZE M7i BY (dm2M7 + grid) // DM7 to metal
    FRAMEB7 = SIZE (WITH WIDTH M7i > wideM7) BY (dm2WM7 + grid)
    FRAMEC7 = SIZE DUM7 BY (dm2DM7 + grid)   // DM7 to existed dummy metal 0.6um
    FRAME7Pre = ((FRAMEA7 OR FRAMEB7) OR FRAMEC7) OR M7ExcHole
    FRAME7INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm7_s2m7_INDDMY + grid)
    FRAME7 = ((FRAME7Pre OR FRAME7INDDMY) OR BLOCK7) OR NFILL
    
    OPENM7 = PUSH ((minOPENM7 OR emptyOPENM7) AND CHIP)
    FILL7 = OPENM7 NOT FRAME7
    FILLW7pre = SIZE FILL7 BY - (Wdm2M7 + grid)
    FILLW7 = WITH WIDTH FILLW7pre >= WdmW_M7
    M7FW = RECTANGLES WdmW_M7 WdmL_M7 WdmS_M7 OFFSET WdmO_M7 INSIDE OF LAYER FILLW7
    M7FW_EXP = SIZE M7FW BY (WdmS_M7 /2 + grid) OVERUNDER //merge the gaps
    FILLM7pre = FILL7 NOT (SIZE M7FW_EXP BY (MdmS_M7 + grid))
    FILLM7 = WITH WIDTH FILLM7pre >= MdmW_M7
    M7F1 = RECTANGLES MdmW_M7 MdmL_M7 MdmS_M7 OFFSET MdmO_M7 INSIDE OF LAYER FILLM7
    M7R1pre = FILLM7pre NOT (SIZE M7F1 BY (dmS_M7 + grid))
    M7R1 = WITH WIDTH M7R1pre >= dmW_M7

    M7F2 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 OFFSET dmO_M7 INSIDE OF LAYER M7R1
    M7R2pre = M7R1 NOT (SIZE M7F2 BY (dmS_M7 + grid))
    M7R2 = WITH WIDTH M7R2pre >= dmW_M7

    M7F3 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 OFFSET dmO_M7 INSIDE OF LAYER M7R2
    M7R3pre = M7R2 NOT (SIZE M7F3 BY (dmS_M7 + grid))
    M7R3 = WITH WIDTH M7R3pre >= dmW_M7

    M7F4 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 INSIDE OF LAYER M7R3

    M7F = (((M7F1 OR M7F2) OR M7F3) OR M7F4) OR M7FW
    FM7 = M7F NOT INTERACT (EXT M7F < dmS_M7 ABUT SINGULAR REGION)

    maxOPENM7 = DENSITY M7x FM7 > maxD_M7 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M7Max.den

    FM7F = FM7 OUTSIDE maxOPENM7

    D25M7 = DENSITY M7x FM7F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M7Min.den

    RM7EXC = SIZE FM7F BY (Odm2DM7 + grid)
    D25M7pM = (((PUSH D25M7) NOT FRAME7) NOT RM7EXC) AND CHIP
    D25M7pM_1 = WITH WIDTH D25M7pM >= OdmW_M7

    RM7p1 = RECTANGLES OdmW_M7 OdmL_M7 OdmS_M7 INSIDE OF LAYER D25M7pM_1
    D25M7pM_2 = D25M7pM_1 NOT (SIZE RM7p1 BY (OdmS_M7 + grid))
    RM7p2 = RECTANGLES OdmL_M7 OdmW_M7 OdmS_M7 INSIDE OF LAYER D25M7pM_2

    RM7A = ((RM7p1 OR RM7p2) OUTSIDE RM7EXC) OUTSIDE FRAME7
    RM7  = RM7A NOT INTERACT (EXT RM7A < OdmS_M7 ABUT SINGULAR REGION)

    DM7F = FM7F OR RM7

    FRAME7_INDDMYA = SIZE M7i BY (dm7_s2m7_INDDMY + grid)
    FRAME7_INDDMYB = SIZE DUM7 BY (dm7_s_INDDMY + grid)
    FRAME7_INDDMYC = SIZE DM7F BY dm7_s_INDDMY
    FRAME7_INDDMY  = ((((FRAME7Pre OR BLOCK7) OR FRAME7_INDDMYA) OR FRAME7_INDDMYB) OR FRAME7_INDDMYC) OR NFILL
    FILL7_INDDMY   = ooINDDMY NOT FRAME7_INDDMY
    DM7F_INDDMY    = RECTANGLES dm7_w_INDDMY dm7_l_INDDMY dm7_s_INDDMY INSIDE OF LAYER FILL7_INDDMY

#IFDEF FILL_indDM7
    FILL7_INDDMY_HD = (SIZE INDDMY_HD BY -(dm7_s_INDDMY_HD + grid)) NOT FRAME7_INDDMY
    DM7F_INDDMY_HD  = RECTANGLES dm7_w_INDDMY_HD dm7_l_INDDMY_HD dm7_s_INDDMY_HD INSIDE OF LAYER FILL7_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M7

    D30M7 = DENSITY M7x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M7.den30
    D40M7 = DENSITY M7x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M7.den40
    D50M7 = DENSITY M7x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M7.den50
    emptyM7 = DENSITY M7x < emptyD_M7 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M7.den_empty

    M7InnerHole = HOLES M7i INNER

    M7BigHole = SIZE M7InnerHole BY - excludeHoleSize/2
    M7ExcHole = ((M7InnerHole OUTSIDE M7BigHole) NOT M7i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK7 = (SIZE DM7EXCL BY (dm2DMEXCL + grid)) OR MIM7_x

    FRAMEA7 = (SIZE M7i BY (DM7_301 + grid)) OR (SIZE (EXPAND EDGE (M7i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA7OPC = SIZE M7i BY (DM7_OPC + grid)
    FRAMEA7OPCDV33 = SIZE (M7i INTERACT M7_HVN_330Vx) BY (M7_S_1_1_a + grid)
    FRAMEA7OPCDV5 = SIZE (M7i INTERACT M7_HVN_500Vx) BY (M7_S_9_a + grid)
    FRAMEA7OPC45 = SIZE (EXPAND EDGE (M7i ANGLE == 45) OUTSIDE BY DM7_OPC_45 EXTEND BY DM7_OPC_45_E) BY grid
    FRAMEA7OPC45DV = SIZE (EXPAND EDGE ((M7i INTERACT M7_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM7_OPC_45 EXTEND BY DM7_OPC_45_E) BY grid

    FRAMEB7 = SIZE (WITH WIDTH M7i > wideM7) BY (dm2WM7 + grid)
    FRAMEC7 = SIZE DUM7 BY (dm2DM7 + grid)
    FRAMED7 = SIZE (WITH WIDTH M7i > wideM7_small) BY (dm2WM7_small + grid)
    FRAMEC7OPC = SIZE DUM7 BY (Odm2DM7 + grid)
    FRAME7Pre = ((FRAMEA7 OR FRAMEB7) OR (FRAMEC7 OR FRAMED7)) OR M7ExcHole
    FRAME7PreOPC = (((((((FRAMEA7OPC OR FRAMEA7OPCDV33) OR FRAMEA7OPCDV5) OR FRAMEC7OPC) OR M7ExcHole) OR FRAMEA7OPC45) OR FRAMEA7OPC45DV) OR FRAMEB7) OR FRAMED7
    FRAME7INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm7_s2m7_INDDMY + grid)

    FRAME7OPC = ((FRAME7PreOPC OR FRAME7INDDMY) OR BLOCK7) OR NFILLOPC

    FRAME7 = ((FRAME7Pre OR FRAME7INDDMY) OR BLOCK7) OR NFILL

    //****************************************************************************

    D30M7p = (PUSH D30M7) NOT FRAME7
    O30M7pre = D30M7p AND CHIP
    FD21M7s = COPY FRAME7

    O30M7preA = SIZE O30M7pre BY -DM7_303
    O30M7preB = O30M7preA WITH WIDTH >= WM7_303

    // 1st big
    F303M7 = RECTANGLES WM7_303 LM7_303 SM7_303 OFFSET OM7_303 INSIDE OF LAYER O30M7preB

    F303M7_EXP = SIZE F303M7 BY ( SM7_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M7preF1 = O30M7pre NOT (SIZE F303M7_EXP BY SM7_302)
    O30M7preF  = (SNAP (SIZE O30M7preF1 BY -grid) 5) AND O30M7preF1

    B30M7s = FD21M7s OR (SIZE F303M7_EXP BY (SM7_302+grid))
    O30M7 = O30M7preF NOT B30M7s

    // 3rd, middle
    F302M7 = RECTANGLES WM7_302 LM7_302 SM7_302 OFFSET OM7_302 INSIDE OF LAYER O30M7
    F302M7s = (SIZE F302M7 BY (SM7_301 + grid)) OR B30M7s
    R302M7pre = O30M7 NOT F302M7s
    R302M7 = WITH WIDTH R302M7pre >= WM7_301

    // 4th, small
    F3012M7 = RECTANGLES WM7_301 LM7_301 SM7_301 OFFSET OM7_301 INSIDE OF LAYER R302M7
    F3012M7s = (SIZE F3012M7 BY (SM7_301 + grid)) OR F302M7s
    R3012M7pre = R302M7pre NOT F3012M7s
    R3012M7 = WITH WIDTH R3012M7pre >= WM7_301

    // 5th, non-stagger small
    F301M7 = RECTANGLES WM7_301 LM7_301 SM7_301 INSIDE OF LAYER R3012M7 //MAINTAIN SPACING
    F301M7s = (SIZE F301M7 BY (SM7_301 + grid)) OR F3012M7s

    F30M7 = ((F302M7 OR F3012M7) OR F301M7) OR F303M7
    O40M7pre = (((PUSH D40M7) NOT FRAME7) NOT F301M7s) AND CHIP


    O40M7preA = SIZE O40M7pre BY -DM7_403
    O40M7preB = O40M7preA WITH WIDTH >= WM7_403

    // 1st big
    F403M7 = RECTANGLES WM7_403 LM7_403 SM7_403 OFFSET OM7_403 INSIDE OF LAYER O40M7preB

    F403M7_EXP = SIZE F403M7 BY ( SM7_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M7preF1 = O40M7pre NOT (SIZE F403M7_EXP BY SM7_402)
    O40M7preF  = (SNAP (SIZE O40M7preF1 BY -grid) 5) AND O40M7preF1

    B40M7s = F301M7s OR (SIZE F403M7_EXP BY (SM7_402+grid))
    O40M7 = O40M7preF NOT B40M7s

    // 3rd, middle
    F402M7 = RECTANGLES WM7_402 LM7_402 SM7_402 OFFSET OM7_402 INSIDE OF LAYER O40M7
    F402M7s = (SIZE F402M7 BY (SM7_401 + grid)) OR B40M7s
    R402M7pre = O40M7 NOT F402M7s
    R402M7 = WITH WIDTH R402M7pre >= WM7_401

    // 4th, small
    F4012M7 = RECTANGLES WM7_401 LM7_401 SM7_401 OFFSET OM7_401 INSIDE OF LAYER R402M7
    F4012M7s = (SIZE F4012M7 BY (SM7_401 + grid)) OR F402M7s
    R4012M7pre = R402M7pre NOT F4012M7s
    R4012M7 = WITH WIDTH R4012M7pre >= WM7_401

    // 5th, non-stagger small
    F401M7 = RECTANGLES WM7_401 LM7_401 SM7_401 INSIDE OF LAYER R4012M7 //MAINTAIN SPACING
    F401M7s = (SIZE F401M7 BY (SM7_401 + grid)) OR F4012M7s

    F40M7 = ((F402M7 OR F4012M7) OR F401M7) OR F403M7
    O50M7pre = (((PUSH (D50M7 OR emptyM7)) NOT FRAME7) NOT F401M7s) AND CHIP


    O50M7preA = SIZE O50M7pre BY -DM7_503
    O50M7preB = O50M7preA WITH WIDTH >= WM7_503

    // 1st big
    F503M7 = RECTANGLES WM7_503 LM7_503 SM7_503 OFFSET OM7_503 INSIDE OF LAYER O50M7preB

    F503M7_EXP = SIZE F503M7 BY ( SM7_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M7preF1 = O50M7pre NOT (SIZE F503M7_EXP BY SM7_502)
    O50M7preF  = (SNAP (SIZE O50M7preF1 BY -grid) 5) AND O50M7preF1

    B50M7s = F401M7s OR (SIZE F503M7_EXP BY (SM7_502+grid))
    O50M7 = O50M7preF NOT B50M7s

    // 3rd, middle
    F502M7 = RECTANGLES WM7_502 LM7_502 SM7_502 OFFSET OM7_502 INSIDE OF LAYER O50M7
    F502M7s = (SIZE F502M7 BY (SM7_501 + grid)) OR B50M7s
    R502M7pre = O50M7 NOT F502M7s
    R502M7 = WITH WIDTH R502M7pre >= WM7_501

    // 4th, small
    F5012M7 = RECTANGLES WM7_501 LM7_501 SM7_501 OFFSET OM7_501 INSIDE OF LAYER R502M7
    F5012M7s = (SIZE F5012M7 BY (SM7_501 + grid)) OR F502M7s
    R5012M7pre = R502M7pre NOT F5012M7s
    R5012M7 = WITH WIDTH R5012M7pre >= WM7_501

    // 5th, non-stagger small
    F501M7 = RECTANGLES WM7_501 LM7_501 SM7_501 INSIDE OF LAYER R5012M7 //MAINTAIN SPACING
    F501M7s = (SIZE F501M7 BY (SM7_501 + grid)) OR F5012M7s

    F50M7 = ((F502M7 OR F5012M7) OR F501M7) OR F503M7

//****************************************************************************

    exceedM7 = DENSITY M7x F30M7 F40M7 F50M7 > maxD_M7 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M7.den_exceed

    removeM7R = ((PUSH (exceedM7 AND (D50M7 OR emptyM7))) NOT FRAME7) AND CHIP
    removeM7P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM7R

    F30M7x = F30M7 NOT INTERACT removeM7P
    F40M7x = F40M7 NOT INTERACT removeM7P
    F50M7x = F50M7 NOT INTERACT removeM7P
    FM7xA  = (F30M7x OR F40M7x) OR F50M7x
    FM7x   = FM7xA NOT INTERACT (EXT FM7xA < DM7_S_1 ABUT SINGULAR REGION)

    ALLM7x = M7x OR FM7x
    lackM7 = DENSITY ALLM7x CHIP < DM7_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M7.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM7x)/AREA(CHIP) ]

    WDM7EXC = DUM7 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM7EXC = (SIZE FM7x BY Odm2DM7) OR (SIZE (((F303M7_EXP OR F403M7_EXP) OR F503M7_EXP) OR WDM7EXC) BY 1.5)

    lackM7pRM = ((((PUSH lackM7) NOT RM7EXC) NOT FRAME7OPC) NOT exceedM7) AND CHIP
    lackM7pRM_1 = WITH WIDTH lackM7pRM >= SM7_OPC

    RM7p1 = RECTANGLES WM7_OPC LM7_OPC WSM7_OPC LSM7_OPC INSIDE OF LAYER lackM7pRM_1
    lackM7pRM_2 = lackM7pRM_1 NOT (SIZE RM7p1 BY SM7_OPC)
    RM7p2 = RECTANGLES LM7_OPC WM7_OPC LSM7_OPC WSM7_OPC INSIDE OF LAYER lackM7pRM_2

    ODM7A = ((RM7p1 OR RM7p2) OUTSIDE RM7EXC) OUTSIDE FRAME7OPC
    ODM7F = ODM7A NOT INTERACT (EXT ODM7A < SM7_OPC ABUT SINGULAR REGION)

    DM7F = COPY FM7x

    FRAME7_INDDMYA = SIZE M7i BY (dm7_s2m7_INDDMY + grid)
    FRAME7_INDDMYB = SIZE DUM7 BY (dm7_s_INDDMY + grid)
    FRAME7_INDDMYC = SIZE DM7F BY dm7_s_INDDMY
    FRAME7_INDDMYD = SIZE ODM7F BY dm7_s2m7_INDDMY
    FRAME7_INDDMY  = (((((FRAME7Pre OR BLOCK7) OR FRAME7_INDDMYA) OR FRAME7_INDDMYB) OR FRAME7_INDDMYC) OR FRAME7_INDDMYD) OR NFILL
    FILL7_INDDMY   = ooINDDMY NOT FRAME7_INDDMY
    DM7F_INDDMY    = RECTANGLES dm7_w_INDDMY dm7_l_INDDMY dm7_s_INDDMY INSIDE OF LAYER FILL7_INDDMY


#IFDEF FILL_indDM7
    FILL7_INDDMY_HD = (SIZE INDDMY_HD BY -(dm7_s_INDDMY_HD + grid)) NOT FRAME7_INDDMY
    DM7F_INDDMY_HD  = RECTANGLES dm7_w_INDDMY_HD dm7_l_INDDMY_HD dm7_s_INDDMY_HD INSIDE OF LAYER FILL7_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M7

    minOPENM7 = DENSITY M7x < minD_M7 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M7Min.den
    emptyOPENM7 = DENSITY M7x < emptyD_M7 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M7Empty.den

    M7InnerHole = HOLES M7i INNER

    M7BigHole = SIZE M7InnerHole BY - excludeHoleSize/2
    M7ExcHole = ((M7InnerHole OUTSIDE M7BigHole) NOT M7i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK7 = (SIZE DM7EXCL BY (dm2DMEXCL + grid)) OR MIM7_x // DM7 to DM7EXCL
    FRAMEA7 = SIZE M7i BY (dm2M7 + grid) // DM7 to metal
    FRAMEB7 = SIZE (WITH WIDTH M7i > wideM7) BY (dm2WM7 + grid)
    FRAMEC7 = SIZE DUM7 BY (dm2DM7 + grid)   // DM7 to existed dummy metal 0.6um
    FRAME7Pre = ((FRAMEA7 OR FRAMEB7) OR FRAMEC7) OR M7ExcHole
    FRAME7INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm7_s2m7_INDDMY + grid)
    FRAME7 = ((FRAME7Pre OR FRAME7INDDMY) OR BLOCK7) OR NFILL
    
    OPENM7 = PUSH ((minOPENM7 OR emptyOPENM7) AND CHIP)
    FILL7 = OPENM7 NOT FRAME7
    FILLW7pre = SIZE FILL7 BY - (Wdm2M7 + grid)
    FILLW7 = WITH WIDTH FILLW7pre >= WdmW_M7
    M7FW = RECTANGLES WdmW_M7 WdmL_M7 WdmS_M7 OFFSET WdmO_M7 INSIDE OF LAYER FILLW7
    M7FW_EXP = SIZE M7FW BY (WdmS_M7 /2 + grid) OVERUNDER //merge the gaps
    FILLM7pre = FILL7 NOT (SIZE M7FW_EXP BY (MdmS_M7 + grid))
    FILLM7 = WITH WIDTH FILLM7pre >= MdmW_M7
    M7F1 = RECTANGLES MdmW_M7 MdmL_M7 MdmS_M7 OFFSET MdmO_M7 INSIDE OF LAYER FILLM7
    M7R1pre = FILLM7pre NOT (SIZE M7F1 BY (dmS_M7 + grid))
    M7R1 = WITH WIDTH M7R1pre >= dmW_M7

    M7F2 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 OFFSET dmO_M7 INSIDE OF LAYER M7R1
    M7R2pre = M7R1 NOT (SIZE M7F2 BY (dmS_M7 + grid))
    M7R2 = WITH WIDTH M7R2pre >= dmW_M7

    M7F3 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 OFFSET dmO_M7 INSIDE OF LAYER M7R2
    M7R3pre = M7R2 NOT (SIZE M7F3 BY (dmS_M7 + grid))
    M7R3 = WITH WIDTH M7R3pre >= dmW_M7

    M7F4 = RECTANGLES dmW_M7 dmL_M7 dmS_M7 INSIDE OF LAYER M7R3

    M7F = (((M7F1 OR M7F2) OR M7F3) OR M7F4) OR M7FW
    FM7 = M7F NOT INTERACT (EXT M7F < dmS_M7 ABUT SINGULAR REGION)

    maxOPENM7 = DENSITY M7x FM7 > maxD_M7 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M7Max.den

    FM7F = FM7 OUTSIDE maxOPENM7

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M7 = DENSITY M7x FM7F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M7Min.den

    RM7EXC = SIZE FM7F BY (Odm2DM7 + grid)
    // do not fill DMz_S over CTMDMY
    D25M7pM = (((PUSH D25M7) NOT FRAME7) NOT RM7EXC) AND CHIP
    D25M7pM_1 = WITH WIDTH D25M7pM >= OdmW_M7

    RM7p1 = RECTANGLES OdmW_M7 OdmL_M7 OdmS_M7 INSIDE OF LAYER D25M7pM_1
    D25M7pM_2 = D25M7pM_1 NOT (SIZE RM7p1 BY (OdmS_M7 + grid))
    RM7p2 = RECTANGLES OdmL_M7 OdmW_M7 OdmS_M7 INSIDE OF LAYER D25M7pM_2

    RM7A = ((RM7p1 OR RM7p2) OUTSIDE RM7EXC) OUTSIDE FRAME7
    RM7  = RM7A NOT INTERACT (EXT RM7A < OdmS_M7 ABUT SINGULAR REGION)

    DM7F = FM7F OR RM7

    FRAME7_INDDMYA = SIZE M7i BY (dm7_s2m7_INDDMY + grid)
    FRAME7_INDDMYB = SIZE DUM7 BY (dm7_s_INDDMY + grid)
    FRAME7_INDDMYC = SIZE DM7F BY dm7_s_INDDMY
    FRAME7_INDDMY  = ((((FRAME7Pre OR BLOCK7) OR FRAME7_INDDMYA) OR FRAME7_INDDMYB) OR FRAME7_INDDMYC) OR NFILL
    FILL7_INDDMY   = ooINDDMY NOT FRAME7_INDDMY
    DM7F_INDDMY    = RECTANGLES dm7_w_INDDMY dm7_l_INDDMY dm7_s_INDDMY INSIDE OF LAYER FILL7_INDDMY

#IFDEF FILL_indDM7
    FILL7_INDDMY_HD = (SIZE INDDMY_HD BY -(dm7_s_INDDMY_HD + grid)) NOT FRAME7_INDDMY
    DM7F_INDDMY_HD  = RECTANGLES dm7_w_INDDMY_HD dm7_l_INDDMY_HD dm7_s_INDDMY_HD INSIDE OF LAYER FILL7_INDDMY_HD
#ENDIF	

#ELSE



    D30M7 = DENSITY M7x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M7.den30
    D40M7 = DENSITY M7x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M7.den40
    D50M7 = DENSITY M7x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M7.den50
    emptyM7 = DENSITY M7x < emptyD_M7 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M7.den_empty

    M7InnerHole = HOLES M7i INNER
#IFDEF FILL_M7_DTCD
    VARIABLE M7_DTCD2Chip      2.5  //
    VARIABLE M7_DTCD2LOGO      10   //
    VARIABLE M7_DTCD2MOMDMY    0    // 
    VARIABLE M7_DTCD2LOWMEDN   0    //
    VARIABLE M7_DTCD2POFUSE    0    //
    VARIABLE M7_DTCD2DM7EXCL   0    //
    VARIABLE M7_DTCD2DM7CB2   0    //
    VARIABLE M7_DTCD2M7        2.63  // CB2.S.2
    VARIABLE M7_DTCD2DM7       1.5  // DMx.S.2
    VARIABLE M7_DTCD2TCDDMY_M7 150  // for idu measurement
    VARIABLE M7_DTCD2CTMDMY_8 0.112  // MIM.VIAz.S.5
    VARIABLE M7_DTCD2ICOVL     8
	M7_DTCDxChip        = CHIP NOT (SIZE CHIP BY -(M7_DTCD2Chip + grid))
    M7_DTCDxLOGO        = SIZE LOGO               BY (M7_DTCD2LOGO      + grid)
    M7_DTCDxMOMDMY      = SIZE MOMDMY             BY (M7_DTCD2MOMDMY    + grid)
    M7_DTCDxLOWMEDN     = SIZE LOWMEDN            BY (M7_DTCD2LOWMEDN   + grid)
    M7_DTCDxPOFUSE      = SIZE (FUSELINK AND POi) BY (M7_DTCD2POFUSE    + grid)
    M7_DTCDxDM7EXCL     = SIZE DM7EXCL            BY (M7_DTCD2DM7EXCL   + grid)
    M7_DTCDxDM7CB2      = SIZE CB2i               BY (M7_DTCD2DM7CB2    + grid)
    M7_DTCDxM7          = SIZE M7i                BY (M7_DTCD2M7        + grid)
    M7_DTCDxDM7         = SIZE DUM7               BY (M7_DTCD2DM7       + grid)
    M7_DTCDxTCDDMY_M7   = SIZE TCDDMY_M7          BY (M7_DTCD2TCDDMY_M7 + grid)
    M7_DTCDxTCDDMY_FM7  = SIZE TCDDMY_FM7         BY (M7_DTCD2TCDDMY_M7 + grid)
    M7_DTCDxTCDDMY_FDM7 = SIZE TCDDMY_FDM7        BY (M7_DTCD2TCDDMY_M7 + grid)
    M7_DTCDxICOVL       = SIZE ICOVL              BY (M7_DTCD2ICOVL     + grid)
    M7_DTCDxCTMDMY_8   = SIZE CTMDMY_8          BY (M7_DTCD2CTMDMY_8  + grid)

    M7_DTCDx = (((((((((((((M7_DTCDxChip OR M7_DTCDxLOGO) OR M7_DTCDxLOWMEDN) OR M7_DTCDxPOFUSE) OR M7_DTCDxDM7EXCL) OR M7_DTCDxM7) OR M7_DTCDxDM7) OR M7_DTCDxTCDDMY_M7) OR M7_DTCDxTCDDMY_FM7) OR M7_DTCDxTCDDMY_FDM7) OR FRAME7INDDMY) OR M7_DTCDxMOMDMY) OR M7_DTCDxDM7CB2) OR M7_DTCDxCTMDMY_8) OR M7_DTCDxICOVL
    M7_DTCDo = CHIP NOT M7_DTCDx

    VARIABLE TCD_M7_W      4
    VARIABLE TCD_M7_L      4
    VARIABLE M7_DTCD_S     400
    VARIABLE M7_DTCD_MIN_S 150
    VARIABLE D2M7_DTCD     0.6

    M7_DTCD_pre = RECTANGLES TCD_M7_W TCD_M7_L M7_DTCD_S INSIDE OF LAYER M7_DTCDo
    TCD_M7 = M7_DTCD_pre NOT INTERACT (EXT M7_DTCD_pre < M7_DTCD_MIN_S ABUT SINGULAR REGION)

TCD_M7_165_97_1 = SHRINK TCD_M7 LEFT BY 0 BOTTOM BY 0 RIGHT BY (TCD_M7_W-4) TOP BY (TCD_M7_L-4)
TCD_M7_150_7_1 = SHRINK TCD_M7 LEFT BY 0 BOTTOM BY 0 RIGHT BY (TCD_M7_W-4) TOP BY (TCD_M7_L-4)
