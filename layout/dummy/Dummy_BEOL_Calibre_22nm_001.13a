DV_NSD_55 = DV_NSD_device NOT OUTSIDE DV_VOL_55  
DV_NSD_65 = DV_NSD_device NOT OUTSIDE DV_VOL_65  

DV_VAR_core = DV_VAR_device OUTSIDE OD2
DV_VAR_18   = DV_VAR_device NOT OUTSIDE OD18i
DV_VAR_25   = DV_VAR_device NOT OUTSIDE OD25i

PSTP_00 = PSTPi NOT INSIDE RWi

