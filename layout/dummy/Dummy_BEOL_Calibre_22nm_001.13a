TCD_M2_32_0 = OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR (OR TCD_M2_32_0_1 TCD_M2_32_0_2) TCD_M2_32_0_3) TCD_M2_32_0_4) TCD_M2_32_0_5) TCD_M2_32_0_6) TCD_M2_32_0_7) TCD_M2_32_0_8) TCD_M2_32_0_9) TCD_M2_32_0_10) TCD_M2_32_0_11) TCD_M2_32_0_12) TCD_M2_32_0_13) TCD_M2_32_0_14) TCD_M2_32_0_15) TCD_M2_32_0_16) TCD_M2_32_0_17) TCD_M2_32_0_18) TCD_M2_32_0_19) TCD_M2_32_0_20) TCD_M2_32_0_21) TCD_M2_32_0_22) TCD_M2_32_0_23) TCD_M2_32_0_24) TCD_M2_32_0_25) TCD_M2_32_0_26) TCD_M2_32_0_27) TCD_M2_32_0_28) TCD_M2_32_0_29) TCD_M2_32_0_30) TCD_M2_32_0_31) TCD_M2_32_0_32) TCD_M2_32_0_33) TCD_M2_32_0_34) TCD_M2_32_0_35) TCD_M2_32_0_36) TCD_M2_32_0_37) TCD_M2_32_0_38) TCD_M2_32_0_39) TCD_M2_32_0_40) TCD_M2_32_0_41) TCD_M2_32_0_42) TCD_M2_32_0_43) TCD_M2_32_0_44) TCD_M2_32_0_45) TCD_M2_32_0_46) TCD_M2_32_0_47) TCD_M2_32_0_48) TCD_M2_32_0_49) TCD_M2_32_0_50) TCD_M2_32_0_51) TCD_M2_32_0_52) TCD_M2_32_0_53) TCD_M2_32_0_54) TCD_M2_32_0_55) TCD_M2_32_0_56) TCD_M2_32_0_57

    xM2_DTCD = SIZE TCD_M2 BY D2M2_DTCD
#ELSE
    xM2_DTCD = COPY EMPTY
#ENDIF

    M2BigHole = SIZE M2InnerHole BY - excludeHoleSize/2
    M2ExcHole = ((M2InnerHole OUTSIDE M2BigHole) NOT M2i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK2 = (SIZE DM2EXCL BY (dm2DMEXCL + grid)) OR MIM2_x

    FRAMEA2 = (SIZE M2i BY (DM2_301 + grid)) OR (SIZE (EXPAND EDGE (M2i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA2OPC = SIZE M2i BY (DM2_OPC + grid)
    FRAMEA2OPCwide = SIZE (M2i WITH WIDTH > DM2_OPC_wide_w) BY (DM2_OPC_wide + grid)
    FRAMEA2OPC45 = SIZE (EXPAND EDGE (M2i ANGLE == 45) OUTSIDE BY DM2_OPC_45 EXTEND BY DM2_OPC_45_E) BY grid
    FRAMEA2OPC45DV = SIZE (EXPAND EDGE ((M2i INTERACT M2_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM2_OPC_45 EXTEND BY DM2_OPC_45_E) BY grid
    FRAMEA2OPC_M2_S_14_wide = SIZE (M2i WITH WIDTH > M2_S_14_wide_w) BY (M2_S_14_wide + grid)
    FRAMEA2OPC_M2_S_17_wide = SIZE (M2i WITH WIDTH > M2_S_17_wide_w) BY (M2_S_17_wide + grid)
    FRAMEA2OPC_M2_S_20_wide = SIZE (M2i WITH WIDTH > M2_S_20_wide_w) BY (M2_S_20_wide + grid)
    FRAMEA2OPC_M2_S_23_wide = SIZE (M2i WITH WIDTH > M2_S_23_wide_w) BY (M2_S_23_wide + grid)
    FRAMEA2OPC_M2_S_33_VIA1   = SIZE VIA1_HV_5V_CHK	BY (M2_S_33 + grid)
    FRAMEA2OPC_M2_S_33b_VIA1DV   = SIZE (VIA1i INTERACT (M1_HVN_330Vx OR M2_HVN_330Vx))	BY (M2_S_33b + grid)
    FRAMEA2OPC_M2_S_33_VIA2    = SIZE VIA2_HV_5V_CHK	BY (M2_S_33 + grid)
    FRAMEA2OPC_M2_S_33b_VIA2DV    = SIZE (VIA2i INTERACT (M2_HVN_330Vx OR M3_HVN_330Vx))	BY (M2_S_33b + grid)
    FRAMEA2OPC_M2_S_37_VIA1_b = SIZE VIA1i_55V		BY (M2_S_37 + grid)
    FRAMEA2OPC_M2_S_37a_VIA1_bDV = SIZE (VIA1i INTERACT (M1_HVN_500Vx OR M2_HVN_500Vx))		BY (M2_S_37a + grid)
    FRAMEA2OPC_M2_S_37_VIA2_b  = SIZE VIA2i_55V			BY (M2_S_37 + grid)
    FRAMEA2OPC_M2_S_37a_VIA2_bDV  = SIZE (VIA2i INTERACT (M2_HVN_500Vx OR M3_HVN_500Vx))		BY (M2_S_37a + grid)
    FRAMEA2OPC_M2_S_37_VIA1   = SIZE VIA1i_65V		BY (M2_S_37 + grid)
	FRAMEA2OPC_M2_S_37_VIA2    = SIZE VIA2i_65V			BY (M2_S_37 + grid)

    FRAMEHVD2 = SIZE  M2i_65V  BY (M2_S_38 + grid)
    FRAMEHVD2_55V = SIZE  M2i_55V  BY (M2_S_38 + grid)
    FRAMEHVD2_55VDV = SIZE  (M2i INTERACT M2_HVN_500Vx)  BY (M2_S_38a + grid)
    FRAMEB2 = SIZE (WITH WIDTH M2i > wideM2) BY (dm2WM2 + grid)
    FRAMEC2 = SIZE DUM2 BY (dm2DM2 + grid)
    FRAMED2 = SIZE (WITH WIDTH M2i > wideM2_small) BY (dm2WM2_small + grid)
    FRAMEC2OPC = SIZE DUM2 BY (Odm2DM2 + grid)
    FRAME2Pre = ((FRAMEA2 OR FRAMEB2) OR (FRAMEC2 OR FRAMED2)) OR M2ExcHole
    FRAME2PreOPC = (((((((((((((((((((((FRAMEA2OPC OR FRAMEC2OPC) OR M2ExcHole) OR FRAMEA2OPCwide) OR FRAMEA2OPC45) OR FRAMEA2OPC45DV) OR FRAMEA2OPC_M2_S_14_wide) OR FRAMEA2OPC_M2_S_17_wide) OR FRAMEA2OPC_M2_S_20_wide) OR FRAMEA2OPC_M2_S_23_wide) OR FRAMEA2OPC_M2_S_33_VIA1) OR FRAMEA2OPC_M2_S_33b_VIA1DV) OR FRAMEA2OPC_M2_S_33_VIA2) OR FRAMEA2OPC_M2_S_33b_VIA2DV) OR FRAMEHVD2) OR FRAMEA2OPC_M2_S_37_VIA1) OR FRAMEA2OPC_M2_S_37_VIA1_b) OR FRAMEA2OPC_M2_S_37a_VIA1_bDV) OR FRAMEA2OPC_M2_S_37_VIA2) OR FRAMEA2OPC_M2_S_37_VIA2_b) OR FRAMEA2OPC_M2_S_37a_VIA2_bDV) OR FRAMEHVD2_55V) OR FRAMEHVD2_55VDV


    FRAME2INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm2_s2m2_INDDMY + grid)
    FRAME2OPC = (((FRAME2PreOPC OR FRAME2INDDMY) OR xM2_DTCD) OR BLOCK2) OR NFILLOPC_x

    FRAME2 = (((FRAME2Pre OR FRAME2INDDMY) OR xM2_DTCD) OR BLOCK2) OR NFILL_x

    D30M2p = (PUSH D30M2) NOT FRAME2
    O30M2pre = D30M2p AND CHIP
    FD21M2s = COPY FRAME2

    O30M2preA = SIZE O30M2pre BY -DM2_303
    O30M2preB = O30M2preA WITH WIDTH >= WM2_303

    // 1st big
    F303M2 = RECTANGLES WM2_303 LM2_303 SM2_303 OFFSET OM2_303 INSIDE OF LAYER O30M2preB
    F303M2_SLOT = RECTANGLES WM2_303_SLOT LM2_303_SLOT SM2_303_SLOT INSIDE OF LAYER F303M2

    F303M2_EXP = SIZE F303M2_SLOT BY ( SM2_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M2preF1 = O30M2pre NOT (SIZE F303M2_EXP BY SM2_302)
    O30M2preF  = (SNAP (SIZE O30M2preF1 BY -grid) 5) AND O30M2preF1

    B30M2s = FD21M2s OR (SIZE F303M2_EXP BY (SM2_302+grid))
    O30M2 = O30M2preF NOT B30M2s

    // 3rd, middle
    F302M2 = RECTANGLES WM2_302 LM2_302 SM2_302 OFFSET OM2_302 INSIDE OF LAYER O30M2
    F302M2s = (SIZE F302M2 BY (SM2_301 + grid)) OR B30M2s
    R302M2pre = O30M2 NOT F302M2s
    R302M2 = WITH WIDTH R302M2pre >= WM2_301

    // 4th, small
    F3012M2 = RECTANGLES WM2_301 LM2_301 SM2_301 OFFSET OM2_301 INSIDE OF LAYER R302M2
    F3012M2s = (SIZE F3012M2 BY (SM2_301 + grid)) OR F302M2s
    R3012M2pre = R302M2pre NOT F3012M2s
    R3012M2 = WITH WIDTH R3012M2pre >= WM2_301

    // 5th, non-stagger small
    F301M2 = RECTANGLES WM2_301 LM2_301 SM2_301 INSIDE OF LAYER R3012M2 //MAINTAIN SPACING
    F301M2s = (SIZE F301M2 BY (SM2_301 + grid)) OR F3012M2s

    F30M2 = ((F302M2 OR F3012M2) OR F301M2) OR F303M2_SLOT
    O40M2pre = (((PUSH D40M2) NOT FRAME2) NOT F301M2s) AND CHIP


    O40M2preA = SIZE O40M2pre BY -DM2_403
    O40M2preB = O40M2preA WITH WIDTH >= WM2_403

    // 1st big
    F403M2 = RECTANGLES WM2_403 LM2_403 SM2_403 OFFSET OM2_403 INSIDE OF LAYER O40M2preB
    F403M2_SLOT = RECTANGLES WM2_403_SLOT LM2_403_SLOT SM2_403_SLOT INSIDE OF LAYER F403M2

    F403M2_EXP = SIZE F403M2_SLOT BY ( SM2_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M2preF1 = O40M2pre NOT (SIZE F403M2_EXP BY SM2_402)
    O40M2preF  = (SNAP (SIZE O40M2preF1 BY -grid) 5) AND O40M2preF1

    B40M2s = F301M2s OR (SIZE F403M2_EXP BY (SM2_402+grid))
    O40M2 = O40M2preF NOT B40M2s

    // 3rd, middle
    F402M2 = RECTANGLES WM2_402 LM2_402 SM2_402 OFFSET OM2_402 INSIDE OF LAYER O40M2
    F402M2s = (SIZE F402M2 BY (SM2_401 + grid)) OR B40M2s
    R402M2pre = O40M2 NOT F402M2s
    R402M2 = WITH WIDTH R402M2pre >= WM2_401

    // 4th, small
    F4012M2 = RECTANGLES WM2_401 LM2_401 SM2_401 OFFSET OM2_401 INSIDE OF LAYER R402M2
    F4012M2s = (SIZE F4012M2 BY (SM2_401 + grid)) OR F402M2s
    R4012M2pre = R402M2pre NOT F4012M2s
    R4012M2 = WITH WIDTH R4012M2pre >= WM2_401

    // 5th, non-stagger small
    F401M2 = RECTANGLES WM2_401 LM2_401 SM2_401 INSIDE OF LAYER R4012M2 //MAINTAIN SPACING
    F401M2s = (SIZE F401M2 BY (SM2_401 + grid)) OR F4012M2s

    F40M2 = ((F402M2 OR F4012M2) OR F401M2) OR F403M2_SLOT
    O50M2pre = (((PUSH (D50M2 OR emptyM2)) NOT FRAME2) NOT F401M2s) AND CHIP


    O50M2preA = SIZE O50M2pre BY -DM2_503
    O50M2preB = O50M2preA WITH WIDTH >= WM2_503

    // 1st big
    F503M2 = RECTANGLES WM2_503 LM2_503 SM2_503 OFFSET OM2_503 INSIDE OF LAYER O50M2preB
    F503M2_SLOT = RECTANGLES WM2_503_SLOT LM2_503_SLOT SM2_503_SLOT INSIDE OF LAYER F503M2

    F503M2_EXP = SIZE F503M2_SLOT BY ( SM2_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M2preF1 = O50M2pre NOT (SIZE F503M2_EXP BY SM2_502)
    O50M2preF  = (SNAP (SIZE O50M2preF1 BY -grid) 5) AND O50M2preF1

    B50M2s = F401M2s OR (SIZE F503M2_EXP BY (SM2_502+grid))
    O50M2 = O50M2preF NOT B50M2s

    // 3rd, middle
    F502M2 = RECTANGLES WM2_502 LM2_502 SM2_502 OFFSET OM2_502 INSIDE OF LAYER O50M2
    F502M2s = (SIZE F502M2 BY (SM2_501 + grid)) OR B50M2s
    R502M2pre = O50M2 NOT F502M2s
    R502M2 = WITH WIDTH R502M2pre >= WM2_501

    // 4th, small
    F5012M2 = RECTANGLES WM2_501 LM2_501 SM2_501 OFFSET OM2_501 INSIDE OF LAYER R502M2
    F5012M2s = (SIZE F5012M2 BY (SM2_501 + grid)) OR F502M2s
    R5012M2pre = R502M2pre NOT F5012M2s
    R5012M2 = WITH WIDTH R5012M2pre >= WM2_501

    // 5th, non-stagger small
    F501M2 = RECTANGLES WM2_501 LM2_501 SM2_501 INSIDE OF LAYER R5012M2 //MAINTAIN SPACING
    F501M2s = (SIZE F501M2 BY (SM2_501 + grid)) OR F5012M2s

    F50M2 = ((F502M2 OR F5012M2) OR F501M2) OR F503M2_SLOT

    exceedM2 = DENSITY M2x F30M2 F40M2 F50M2 > maxD_M2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M2.den_exceed

    removeM2R = ((PUSH (exceedM2 AND (D50M2 OR emptyM2))) NOT FRAME2) AND CHIP
    removeM2P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM2R

    F30M2x = F30M2 NOT INTERACT removeM2P
    F40M2x = F40M2 NOT INTERACT removeM2P
    F50M2x = F50M2 NOT INTERACT removeM2P
    FM2xA  = (F30M2x OR F40M2x) OR F50M2x
    FM2x   = FM2xA NOT INTERACT (EXT FM2xA < DM2_S_1 ABUT SINGULAR REGION)

    ALLM2x = M2x OR FM2x
    lackM2 = DENSITY ALLM2x CHIP < DM2_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M2.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM2x)/AREA(CHIP) ]

    WDM2EXC = DUM2 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM2EXC = (SIZE FM2x BY Odm2DM2) OR (SIZE (((F303M2_EXP OR F403M2_EXP) OR F503M2_EXP) OR WDM2EXC) BY 1.5)

    lackM2pRM = ((((PUSH lackM2) NOT RM2EXC) NOT FRAME2OPC) NOT exceedM2) AND CHIP
    lackM2pRM_1 = WITH WIDTH lackM2pRM >= SM2_OPC

    RM2p1 = RECTANGLES WM2_OPC LM2_OPC WSM2_OPC LSM2_OPC INSIDE OF LAYER lackM2pRM_1
    lackM2pRM_2 = lackM2pRM_1 NOT (SIZE RM2p1 BY SM2_OPC)
    RM2p2 = RECTANGLES LM2_OPC WM2_OPC LSM2_OPC WSM2_OPC INSIDE OF LAYER lackM2pRM_2

    ODM2A = ((RM2p1 OR RM2p2) OUTSIDE RM2EXC) OUTSIDE FRAME2OPC
    ODM2F_pre = ODM2A NOT INTERACT (EXT ODM2A < SM2_OPC ABUT SINGULAR REGION)

// M2.S.14 ~ M2.S.16
M2_S_14_CHK_REGION = M2i OR ODM2F_pre
// Find Wide Metal
Wide_M2_S_14_CHK_REGION = ENCLOSE RECTANGLE (M2_S_14_CHK_REGION NOT WITH WIDTH <= M2_S_14_W1B) M2_S_14_W1B+GRID M2_S_14_L1B+GRID ORTHOGONAL ONLY

Wide_M2_S_14_CHK_REGION_EDGE_H = ANGLE Wide_M2_S_14_CHK_REGION == 0
Wide_M2_S_14_CHK_REGION_EDGE_V = ANGLE Wide_M2_S_14_CHK_REGION == 90

// Find Wide Metal Space
M2_S_14_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M2_S_14_CHK_REGION_EDGE_H M2_S_14_CHK_REGION < M2_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M2_S_14_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M2_S_14_CHK_REGION_EDGE_V M2_S_14_CHK_REGION < M2_S_14_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M2_S_14_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M2_S_14_CHK_REGION_OPC_REGION_pre1_H == 0
M2_S_14_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M2_S_14_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M2_S_14_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M2_S_14_CHK_REGION_OPC_REGION_pre1_H M2_S_14_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M2_S_14_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M2_S_14_L1B
M2_S_14_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M2_S_14_CHK_REGION_OPC_REGION_pre1_V M2_S_14_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M2_S_14_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M2_S_14_L1B

M2_S_14_OPC_REGION = M2_S_14_CHK_REGION_OPC_REGION_pre2_H OR M2_S_14_CHK_REGION_OPC_REGION_pre2_V

// M2.S.17 ~ M2.S.19
M2_S_17_CHK_REGION = M2i OR ODM2F_pre
// Find Wide Metal
Wide_M2_S_17_CHK_REGION = ENCLOSE RECTANGLE (M2_S_17_CHK_REGION NOT WITH WIDTH <= M2_S_17_W1B) M2_S_17_W1B+GRID M2_S_17_L1B+GRID ORTHOGONAL ONLY

Wide_M2_S_17_CHK_REGION_EDGE_H = ANGLE Wide_M2_S_17_CHK_REGION == 0
Wide_M2_S_17_CHK_REGION_EDGE_V = ANGLE Wide_M2_S_17_CHK_REGION == 90

// Find Wide Metal Space
M2_S_17_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M2_S_17_CHK_REGION_EDGE_H M2_S_17_CHK_REGION < M2_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M2_S_17_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M2_S_17_CHK_REGION_EDGE_V M2_S_17_CHK_REGION < M2_S_17_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M2_S_17_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M2_S_17_CHK_REGION_OPC_REGION_pre1_H == 0
M2_S_17_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M2_S_17_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M2_S_17_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M2_S_17_CHK_REGION_OPC_REGION_pre1_H M2_S_17_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M2_S_17_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M2_S_17_L1B
M2_S_17_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M2_S_17_CHK_REGION_OPC_REGION_pre1_V M2_S_17_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M2_S_17_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M2_S_17_L1B

M2_S_17_OPC_REGION = M2_S_17_CHK_REGION_OPC_REGION_pre2_H OR M2_S_17_CHK_REGION_OPC_REGION_pre2_V

// M2.S.20 ~ M2.S.22
M2_S_20_CHK_REGION = M2i OR ODM2F_pre
// Find Wide Metal
Wide_M2_S_20_CHK_REGION = ENCLOSE RECTANGLE (M2_S_20_CHK_REGION NOT WITH WIDTH <= M2_S_20_W1B) M2_S_20_W1B+GRID M2_S_20_L1B+GRID ORTHOGONAL ONLY

Wide_M2_S_20_CHK_REGION_EDGE_H = ANGLE Wide_M2_S_20_CHK_REGION == 0
Wide_M2_S_20_CHK_REGION_EDGE_V = ANGLE Wide_M2_S_20_CHK_REGION == 90

// Find Wide Metal Space
M2_S_20_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M2_S_20_CHK_REGION_EDGE_H M2_S_20_CHK_REGION < M2_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M2_S_20_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M2_S_20_CHK_REGION_EDGE_V M2_S_20_CHK_REGION < M2_S_20_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M2_S_20_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M2_S_20_CHK_REGION_OPC_REGION_pre1_H == 0
M2_S_20_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M2_S_20_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M2_S_20_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M2_S_20_CHK_REGION_OPC_REGION_pre1_H M2_S_20_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M2_S_20_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M2_S_20_L1B
M2_S_20_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M2_S_20_CHK_REGION_OPC_REGION_pre1_V M2_S_20_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M2_S_20_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M2_S_20_L1B

M2_S_20_OPC_REGION = M2_S_20_CHK_REGION_OPC_REGION_pre2_H OR M2_S_20_CHK_REGION_OPC_REGION_pre2_V

// M2.S.23 ~ M2.S.25
M2_S_23_CHK_REGION = M2i OR ODM2F_pre
// Find Wide Metal
Wide_M2_S_23_CHK_REGION = ENCLOSE RECTANGLE (M2_S_23_CHK_REGION NOT WITH WIDTH <= M2_S_23_W1B) M2_S_23_W1B+GRID M2_S_23_L1B+GRID ORTHOGONAL ONLY

Wide_M2_S_23_CHK_REGION_EDGE_H = ANGLE Wide_M2_S_23_CHK_REGION == 0
Wide_M2_S_23_CHK_REGION_EDGE_V = ANGLE Wide_M2_S_23_CHK_REGION == 90

// Find Wide Metal Space
M2_S_23_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M2_S_23_CHK_REGION_EDGE_H M2_S_23_CHK_REGION < M2_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M2_S_23_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M2_S_23_CHK_REGION_EDGE_V M2_S_23_CHK_REGION < M2_S_23_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M2_S_23_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M2_S_23_CHK_REGION_OPC_REGION_pre1_H == 0
M2_S_23_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M2_S_23_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M2_S_23_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M2_S_23_CHK_REGION_OPC_REGION_pre1_H M2_S_23_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M2_S_23_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M2_S_23_L1B
M2_S_23_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M2_S_23_CHK_REGION_OPC_REGION_pre1_V M2_S_23_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M2_S_23_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M2_S_23_L1B

M2_S_23_OPC_REGION = M2_S_23_CHK_REGION_OPC_REGION_pre2_H OR M2_S_23_CHK_REGION_OPC_REGION_pre2_V

// M2.S.27
M2_S_27_CHK_REGION = M2i OR ODM2F_pre
// Find Wide Metal
Wide_M2_S_27_CHK_REGION = ENCLOSE RECTANGLE (M2_S_27_CHK_REGION NOT WITH WIDTH <= M2_S_27_W1B) M2_S_27_W1B+GRID M2_S_27_L1B+GRID ORTHOGONAL ONLY

Wide_M2_S_27_CHK_REGION_EDGE_H = ANGLE Wide_M2_S_27_CHK_REGION == 0
Wide_M2_S_27_CHK_REGION_EDGE_V = ANGLE Wide_M2_S_27_CHK_REGION == 90

// Find Wide Metal Space
M2_S_27_CHK_REGION_OPC_REGION_pre1_H = EXT Wide_M2_S_27_CHK_REGION_EDGE_H M2_S_27_CHK_REGION < M2_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL
M2_S_27_CHK_REGION_OPC_REGION_pre1_V = EXT Wide_M2_S_27_CHK_REGION_EDGE_V M2_S_27_CHK_REGION < M2_S_27_S1B ABUT < 90 OPPOSITE REGION MEASURE ALL

// Find Wide Metal Edge
M2_S_27_CHK_REGION_OPC_EDGE_pre1_H = ANGLE M2_S_27_CHK_REGION_OPC_REGION_pre1_H == 0
M2_S_27_CHK_REGION_OPC_EDGE_pre1_V = ANGLE M2_S_27_CHK_REGION_OPC_REGION_pre1_V == 90

// Find Wide Metal OPC Region
M2_S_27_CHK_REGION_OPC_REGION_pre2_H = DFM PROPERTY M2_S_27_CHK_REGION_OPC_REGION_pre1_H M2_S_27_CHK_REGION_OPC_EDGE_pre1_H OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M2_S_27_CHK_REGION_OPC_EDGE_pre1_H)] > 2*M2_S_27_L1B
M2_S_27_CHK_REGION_OPC_REGION_pre2_V = DFM PROPERTY M2_S_27_CHK_REGION_OPC_REGION_pre1_V M2_S_27_CHK_REGION_OPC_EDGE_pre1_V OVERLAP ABUT ALSO MULTI
                                   [-= LENGTH(M2_S_27_CHK_REGION_OPC_EDGE_pre1_V)] > 2*M2_S_27_L1B

M2_S_27_OPC_REGION = M2_S_27_CHK_REGION_OPC_REGION_pre2_H OR M2_S_27_CHK_REGION_OPC_REGION_pre2_V

M2_WMJ_OPC_REGION = (((M2_S_14_OPC_REGION OR M2_S_17_OPC_REGION) OR M2_S_20_OPC_REGION) OR M2_S_23_OPC_REGION) OR M2_S_27_OPC_REGION

    ODM2F = ODM2F_pre NOT INTERACT M2_WMJ_OPC_REGION

    DM2F = COPY FM2x

    FRAME2_INDDMYA = SIZE M2i BY (dm2_s2m2_INDDMY + grid)
    FRAME2_INDDMYB = SIZE DUM2 BY (dm2_s_INDDMY + grid)
    FRAME2_INDDMYC = SIZE DM2F BY dm2_s_INDDMY
    FRAME2_INDDMYD = SIZE ODM2F BY dm2_s2m2_INDDMY

    FRAME2_INDDMY  = ((((((FRAME2Pre OR xM2_DTCD) OR BLOCK2) OR FRAME2_INDDMYA) OR FRAME2_INDDMYB) OR FRAME2_INDDMYC) OR FRAME2_INDDMYD) OR NFILL_x
    FILL2_INDDMY   = ooINDDMY NOT FRAME2_INDDMY
    DM2F_INDDMY    = RECTANGLES dm2_w_INDDMY dm2_l_INDDMY dm2_s_INDDMY INSIDE OF LAYER FILL2_INDDMY

#IFDEF FILL_indDM2
    FILL2_INDDMY_HD     = (SIZE INDDMY_HD BY -(dm2_s_INDDMY_HD + grid)) NOT FRAME2_INDDMY
    DM2F_INDDMY_HD_pre  = RECTANGLES dm2_w_INDDMY_HD dm2_l_INDDMY_HD dm2_s_INDDMY_HD INSIDE OF LAYER FILL2_INDDMY_HD

    FILL2_INDDMY_MD = (SIZE INDDMY_MD BY -(dm2_s_INDDMY_MD + grid)) NOT (FRAME2_INDDMY OR INDDMY_HD)
    DM2F_INDDMY_MD  = RECTANGLES dm2_w_INDDMY_MD dm2_l_INDDMY_MD dm2_s_INDDMY_MD INSIDE OF LAYER FILL2_INDDMY_MD

    DM2F_INDDMY_HD = DM2F_INDDMY_HD_pre OR DM2F_INDDMY_MD
#ENDIF	


#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#IFDEF FILL_DM3


#IFDEF 34K_THICK_Mu_M3

    minOPENM3 = DENSITY M3x < minD_M3 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M3Min.den
    emptyOPENM3 = DENSITY M3x < emptyD_M3 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M3Empty.den

    M3InnerHole = HOLES M3i INNER

    M3BigHole = SIZE M3InnerHole BY - excludeHoleSize/2
    M3ExcHole = ((M3InnerHole OUTSIDE M3BigHole) NOT M3i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK3    = (SIZE DM3EXCL BY (dm2DMEXCL + grid)) OR MIM3_x
    FRAMEA3   = SIZE M3i BY (dm2M3 + grid) // DM3 to metal
    FRAMEB3   = SIZE (WITH WIDTH M3i > wideM3) BY (dm2WM3 + grid)
    FRAMEC3   = SIZE DUM3 BY (dm2DM3 + grid)
    FRAME3Pre = ((FRAMEA3 OR FRAMEB3) OR FRAMEC3) OR M3ExcHole
    FRAME3INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm3_s2m3_INDDMY + grid)
    FRAME3 = ((FRAME3Pre OR FRAME3INDDMY) OR BLOCK3) OR NFILL
    
    OPENM3 = PUSH ((minOPENM3 OR emptyOPENM3) AND CHIP)
    FILL3 = OPENM3 NOT FRAME3
    FILLW3pre = SIZE FILL3 BY - (Wdm2M3 + grid)
    FILLW3 = WITH WIDTH FILLW3pre >= WdmW_M3
    M3FW = RECTANGLES WdmW_M3 WdmL_M3 WdmS_M3 OFFSET WdmO_M3 INSIDE OF LAYER FILLW3
    M3FW_EXP = SIZE M3FW BY (WdmS_M3 /2 + grid) OVERUNDER   // merge the gaps
    FILLM3pre = FILL3 NOT (SIZE M3FW_EXP BY (MdmS_M3 + grid))
    FILLM3 = WITH WIDTH FILLM3pre >= MdmW_M3
    M3F1 = RECTANGLES MdmW_M3 MdmL_M3 MdmS_M3 OFFSET MdmO_M3 INSIDE OF LAYER FILLM3
    M3R1pre = FILLM3pre NOT (SIZE M3F1 BY (dmS_M3 + grid))
    M3R1 = WITH WIDTH M3R1pre >= dmW_M3

    M3F2 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 OFFSET dmO_M3 INSIDE OF LAYER M3R1
    M3R2pre = M3R1 NOT (SIZE M3F2 BY (dmS_M3 + grid))
    M3R2 = WITH WIDTH M3R2pre >= dmW_M3

    M3F3 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 OFFSET dmO_M3 INSIDE OF LAYER M3R2
    M3R3pre = M3R2 NOT (SIZE M3F3 BY (dmS_M3 + grid))
    M3R3 = WITH WIDTH M3R3pre >= dmW_M3

    M3F4 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 INSIDE OF LAYER M3R3

    M3F = (((M3F1 OR M3F2) OR M3F3) OR M3F4) OR M3FW
    FM3 = M3F NOT INTERACT (EXT M3F < dmS_M3 ABUT SINGULAR REGION)

    maxOPENM3 = DENSITY M3x FM3 > maxD_M3 WINDOW WindowSizeu*2 STEP WindowStepu*2
                INSIDE OF LAYER bulk BACKUP // PRINT M3Max.den

    DM3F = FM3 OUTSIDE maxOPENM3

    FRAME3_INDDMYA = SIZE M3i BY (dm3_s2m3_INDDMY + grid)
    FRAME3_INDDMYB = SIZE DUM3 BY (dm3_s_INDDMY + grid)
    FRAME3_INDDMYC = SIZE DM3F BY dm3_s_INDDMY
    FRAME3_INDDMY  = ((((FRAME3Pre OR BLOCK3) OR FRAME3_INDDMYA) OR FRAME3_INDDMYB) OR FRAME3_INDDMYC) OR NFILL
    FILL3_INDDMY   = ooINDDMY NOT FRAME3_INDDMY
    DM3F_INDDMY    = RECTANGLES dm3_w_INDDMY dm3_l_INDDMY dm3_s_INDDMY INSIDE OF LAYER FILL3_INDDMY
#IFDEF FILL_indDM3
    FILL3_INDDMY_HD = (SIZE INDDMY_HD BY -(dm3_s_INDDMY_HD + grid)) NOT FRAME3_INDDMY
    DM3F_INDDMY_HD  = RECTANGLES dm3_w_INDDMY_HD dm3_l_INDDMY_HD dm3_s_INDDMY_HD INSIDE OF LAYER FILL3_INDDMY_HD
#ENDIF	
	
#ELSE


#IFDEF 12K_THICK_Mr_M3

    minOPENM3 = DENSITY M3x < minD_M3 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M3Min.den
    emptyOPENM3 = DENSITY M3x < emptyD_M3 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M3Empty.den

    M3InnerHole = HOLES M3i INNER

    M3BigHole = SIZE M3InnerHole BY - excludeHoleSize/2
    M3ExcHole = ((M3InnerHole OUTSIDE M3BigHole) NOT M3i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK3  = (SIZE DM3EXCL BY (dm2DMEXCL + grid)) OR MIM3_x // DM3 to DM3EXCL
    FRAMEA3 = SIZE M3i BY (dm2M3 + grid) // DM3 to metal
    FRAMEB3 = SIZE (WITH WIDTH M3i > wideM3) BY (dm2WM3 + grid)
    FRAMEC3 = SIZE DUM3 BY (dm2DM3 + grid)   // DM3 to existed dummy metal 0.6um
    FRAME3Pre = ((FRAMEA3 OR FRAMEB3) OR FRAMEC3) OR M3ExcHole
    FRAME3INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm3_s2m3_INDDMY + grid)
    FRAME3 = ((FRAME3Pre OR FRAME3INDDMY) OR BLOCK3) OR NFILL
    
    OPENM3 = PUSH ((minOPENM3 OR emptyOPENM3) AND CHIP)
    FILL3 = OPENM3 NOT FRAME3
    FILLW3pre = SIZE FILL3 BY - (Wdm2M3 + grid)
    FILLW3 = WITH WIDTH FILLW3pre >= WdmW_M3
    M3FW = RECTANGLES WdmW_M3 WdmL_M3 WdmS_M3 OFFSET WdmO_M3 INSIDE OF LAYER FILLW3
    M3FW_EXP = SIZE M3FW BY (WdmS_M3 /2 + grid) OVERUNDER //merge the gaps
    FILLM3pre = FILL3 NOT (SIZE M3FW_EXP BY (MdmS_M3 + grid))
    FILLM3 = WITH WIDTH FILLM3pre >= MdmW_M3
    M3F1 = RECTANGLES MdmW_M3 MdmL_M3 MdmS_M3 OFFSET MdmO_M3 INSIDE OF LAYER FILLM3
    M3R1pre = FILLM3pre NOT (SIZE M3F1 BY (dmS_M3 + grid))
    M3R1 = WITH WIDTH M3R1pre >= dmW_M3

    M3F2 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 OFFSET dmO_M3 INSIDE OF LAYER M3R1
    M3R2pre = M3R1 NOT (SIZE M3F2 BY (dmS_M3 + grid))
    M3R2 = WITH WIDTH M3R2pre >= dmW_M3

    M3F3 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 OFFSET dmO_M3 INSIDE OF LAYER M3R2
    M3R3pre = M3R2 NOT (SIZE M3F3 BY (dmS_M3 + grid))
    M3R3 = WITH WIDTH M3R3pre >= dmW_M3

    M3F4 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 INSIDE OF LAYER M3R3

    M3F = (((M3F1 OR M3F2) OR M3F3) OR M3F4) OR M3FW
    FM3 = M3F NOT INTERACT (EXT M3F < dmS_M3 ABUT SINGULAR REGION)

    maxOPENM3 = DENSITY M3x FM3 > maxD_M3 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M3Max.den

    FM3F = FM3 OUTSIDE maxOPENM3

    // DMr_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M3 = DENSITY M3x FM3F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M3Min.den

    RM3EXC = SIZE FM3F BY (Odm2DM3 + grid)
    // do not fill DMy_S over CTMDMY
    D25M3pM = (((PUSH D25M3) NOT FRAME3) NOT RM3EXC) AND CHIP
    D25M3pM_1 = WITH WIDTH D25M3pM >= OdmW_M3

    RM3p1 = RECTANGLES OdmW_M3 OdmL_M3 OdmS_M3 INSIDE OF LAYER D25M3pM_1
    D25M3pM_2 = D25M3pM_1 NOT (SIZE RM3p1 BY (OdmS_M3 + grid))
    RM3p2 = RECTANGLES OdmL_M3 OdmW_M3 OdmS_M3 INSIDE OF LAYER D25M3pM_2

    RM3A = ((RM3p1 OR RM3p2) OUTSIDE RM3EXC) OUTSIDE FRAME3
    RM3  = RM3A NOT INTERACT (EXT RM3A < OdmS_M3 ABUT SINGULAR REGION)

    DM3F = FM3F OR RM3

    FRAME3_INDDMYA = SIZE M3i BY (dm3_s2m3_INDDMY + grid)
    FRAME3_INDDMYB = SIZE DUM3 BY (dm3_s_INDDMY + grid)
    FRAME3_INDDMYC = SIZE DM3F BY dm3_s_INDDMY
    FRAME3_INDDMY  = ((((FRAME3Pre OR BLOCK3) OR FRAME3_INDDMYA) OR FRAME3_INDDMYB) OR FRAME3_INDDMYC) OR NFILL
    FILL3_INDDMY   = ooINDDMY NOT FRAME3_INDDMY
    DM3F_INDDMY    = RECTANGLES dm3_w_INDDMY dm3_l_INDDMY dm3_s_INDDMY INSIDE OF LAYER FILL3_INDDMY

#IFDEF FILL_indDM3
    FILL3_INDDMY_HD = (SIZE INDDMY_HD BY -(dm3_s_INDDMY_HD + grid)) NOT FRAME3_INDDMY
    DM3F_INDDMY_HD  = RECTANGLES dm3_w_INDDMY_HD dm3_l_INDDMY_HD dm3_s_INDDMY_HD INSIDE OF LAYER FILL3_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 5K_THICK_Myz_M3

    minOPENM3 = DENSITY M3x < minD_M3 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M3Min.den
    emptyOPENM3 = DENSITY M3x < emptyD_M3 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M3Empty.den

    M3InnerHole = HOLES M3i INNER

    M3BigHole = SIZE M3InnerHole BY - excludeHoleSize/2
    M3ExcHole = ((M3InnerHole OUTSIDE M3BigHole) NOT M3i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK3 = (SIZE DM3EXCL BY (dm2DMEXCL + grid)) OR MIM3_x // DM3 to DM3EXCL
    FRAMEA3 = SIZE M3i BY (dm2M3 + grid) // DM3 to metal
    FRAMEB3 = SIZE (WITH WIDTH M3i > wideM3) BY (dm2WM3 + grid)
    FRAMEC3 = SIZE DUM3 BY (dm2DM3 + grid)   // DM3 to existed dummy metal 0.6um
    FRAME3Pre = ((FRAMEA3 OR FRAMEB3) OR FRAMEC3) OR M3ExcHole
    FRAME3INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm3_s2m3_INDDMY + grid)
    FRAME3 = ((FRAME3Pre OR FRAME3INDDMY) OR BLOCK3) OR NFILL
    
    OPENM3 = PUSH ((minOPENM3 OR emptyOPENM3) AND CHIP)
    FILL3 = OPENM3 NOT FRAME3
    FILLW3pre = SIZE FILL3 BY - (Wdm2M3 + grid)
    FILLW3 = WITH WIDTH FILLW3pre >= WdmW_M3
    M3FW = RECTANGLES WdmW_M3 WdmL_M3 WdmS_M3 OFFSET WdmO_M3 INSIDE OF LAYER FILLW3
    M3FW_EXP = SIZE M3FW BY (WdmS_M3 /2 + grid) OVERUNDER //merge the gaps
    FILLM3pre = FILL3 NOT (SIZE M3FW_EXP BY (MdmS_M3 + grid))
    FILLM3 = WITH WIDTH FILLM3pre >= MdmW_M3
    M3F1 = RECTANGLES MdmW_M3 MdmL_M3 MdmS_M3 OFFSET MdmO_M3 INSIDE OF LAYER FILLM3
    M3R1pre = FILLM3pre NOT (SIZE M3F1 BY (dmS_M3 + grid))
    M3R1 = WITH WIDTH M3R1pre >= dmW_M3

    M3F2 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 OFFSET dmO_M3 INSIDE OF LAYER M3R1
    M3R2pre = M3R1 NOT (SIZE M3F2 BY (dmS_M3 + grid))
    M3R2 = WITH WIDTH M3R2pre >= dmW_M3

    M3F3 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 OFFSET dmO_M3 INSIDE OF LAYER M3R2
    M3R3pre = M3R2 NOT (SIZE M3F3 BY (dmS_M3 + grid))
    M3R3 = WITH WIDTH M3R3pre >= dmW_M3

    M3F4 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 INSIDE OF LAYER M3R3

    M3F = (((M3F1 OR M3F2) OR M3F3) OR M3F4) OR M3FW
    FM3 = M3F NOT INTERACT (EXT M3F < dmS_M3 ABUT SINGULAR REGION)

    maxOPENM3 = DENSITY M3x FM3 > maxD_M3 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M3Max.den

    FM3F = FM3 OUTSIDE maxOPENM3

    // DMy_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M3 = DENSITY M3x FM3F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M3Min.den

    RM3EXC = SIZE FM3F BY (Odm2DM3 + grid)
    // do not fill DMy_S over CTMDMY
    D25M3pM = (((PUSH D25M3) NOT FRAME3) NOT RM3EXC) AND CHIP
    D25M3pM_1 = WITH WIDTH D25M3pM >= OdmW_M3

    RM3p1 = RECTANGLES OdmW_M3 OdmL_M3 OdmS_M3 INSIDE OF LAYER D25M3pM_1
    D25M3pM_2 = D25M3pM_1 NOT (SIZE RM3p1 BY (OdmS_M3 + grid))
    RM3p2 = RECTANGLES OdmL_M3 OdmW_M3 OdmS_M3 INSIDE OF LAYER D25M3pM_2

    RM3A = ((RM3p1 OR RM3p2) OUTSIDE RM3EXC) OUTSIDE FRAME3
    RM3  = RM3A NOT INTERACT (EXT RM3A < OdmS_M3 ABUT SINGULAR REGION)

    DM3F = FM3F OR RM3

    FRAME3_INDDMYA = SIZE M3i BY (dm3_s2m3_INDDMY + grid)
    FRAME3_INDDMYB = SIZE DUM3 BY (dm3_s_INDDMY + grid)
    FRAME3_INDDMYC = SIZE DM3F BY dm3_s_INDDMY
    FRAME3_INDDMY  = ((((FRAME3Pre OR BLOCK3) OR FRAME3_INDDMYA) OR FRAME3_INDDMYB) OR FRAME3_INDDMYC) OR NFILL
    FILL3_INDDMY   = ooINDDMY NOT FRAME3_INDDMY
    DM3F_INDDMY    = RECTANGLES dm3_w_INDDMY dm3_l_INDDMY dm3_s_INDDMY INSIDE OF LAYER FILL3_INDDMY


#IFDEF FILL_indDM3
    FILL3_INDDMY_HD = (SIZE INDDMY_HD BY -(dm3_s_INDDMY_HD + grid)) NOT FRAME3_INDDMY
    DM3F_INDDMY_HD  = RECTANGLES dm3_w_INDDMY_HD dm3_l_INDDMY_HD dm3_s_INDDMY_HD INSIDE OF LAYER FILL3_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2_6K_THICK_Mxy_M3

    minOPENM3 = DENSITY M3x < minD_M3 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M3Min.den
    emptyOPENM3 = DENSITY M3x < emptyD_M3 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M3Empty.den

    M3InnerHole = HOLES M3i INNER

    M3BigHole = SIZE M3InnerHole BY - excludeHoleSize/2
    M3ExcHole = ((M3InnerHole OUTSIDE M3BigHole) NOT M3i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK3 = (SIZE DM3EXCL BY (dm2DMEXCL + grid)) OR  MIM3_x // DM3 to DM3EXCL
    FRAMEA3 = SIZE M3i BY (dm2M3 + grid) // DM3 to metal
    FRAMEB3 = SIZE (WITH WIDTH M3i > wideM3) BY (dm2WM3 + grid)
    FRAMEC3 = SIZE DUM3 BY (dm2DM3 + grid)   // DM3 to existed dummy metal 0.6um
    FRAME3Pre = ((FRAMEA3 OR FRAMEB3) OR FRAMEC3) OR M3ExcHole
    FRAME3INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm3_s2m3_INDDMY + grid)
    FRAME3 = ((FRAME3Pre OR FRAME3INDDMY) OR BLOCK3) OR NFILL
    
    OPENM3 = PUSH ((minOPENM3 OR emptyOPENM3) AND CHIP)
    FILL3 = OPENM3 NOT FRAME3
    FILLW3pre = SIZE FILL3 BY - (Wdm2M3 + grid)
    FILLW3 = WITH WIDTH FILLW3pre >= WdmW_M3
    M3FW = RECTANGLES WdmW_M3 WdmL_M3 WdmS_M3 OFFSET WdmO_M3 INSIDE OF LAYER FILLW3
    M3FW_EXP = SIZE M3FW BY (WdmS_M3 /2 + grid) OVERUNDER //merge the gaps
    FILLM3pre = FILL3 NOT (SIZE M3FW_EXP BY (MdmS_M3 + grid))
    FILLM3 = WITH WIDTH FILLM3pre >= MdmW_M3
    M3F1 = RECTANGLES MdmW_M3 MdmL_M3 MdmS_M3 OFFSET MdmO_M3 INSIDE OF LAYER FILLM3
    M3R1pre = FILLM3pre NOT (SIZE M3F1 BY (dmS_M3 + grid))
    M3R1 = WITH WIDTH M3R1pre >= dmW_M3

    M3F2 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 OFFSET dmO_M3 INSIDE OF LAYER M3R1
    M3R2pre = M3R1 NOT (SIZE M3F2 BY (dmS_M3 + grid))
    M3R2 = WITH WIDTH M3R2pre >= dmW_M3

    M3F3 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 OFFSET dmO_M3 INSIDE OF LAYER M3R2
    M3R3pre = M3R2 NOT (SIZE M3F3 BY (dmS_M3 + grid))
    M3R3 = WITH WIDTH M3R3pre >= dmW_M3

    M3F4 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 INSIDE OF LAYER M3R3

    M3F = (((M3F1 OR M3F2) OR M3F3) OR M3F4) OR M3FW
    FM3 = M3F NOT INTERACT (EXT M3F < dmS_M3 ABUT SINGULAR REGION)

    maxOPENM3 = DENSITY M3x FM3 > maxD_M3 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M3Max.den

    FM3F = FM3 OUTSIDE maxOPENM3

    D25M3 = DENSITY M3x FM3F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M3Min.den

    RM3EXC = SIZE FM3F BY (Odm2DM3 + grid)
    D25M3pM = (((PUSH D25M3) NOT FRAME3) NOT RM3EXC) AND CHIP
    D25M3pM_1 = WITH WIDTH D25M3pM >= OdmW_M3

    RM3p1 = RECTANGLES OdmW_M3 OdmL_M3 OdmS_M3 INSIDE OF LAYER D25M3pM_1
    D25M3pM_2 = D25M3pM_1 NOT (SIZE RM3p1 BY (OdmS_M3 + grid))
    RM3p2 = RECTANGLES OdmL_M3 OdmW_M3 OdmS_M3 INSIDE OF LAYER D25M3pM_2

    RM3A = ((RM3p1 OR RM3p2) OUTSIDE RM3EXC) OUTSIDE FRAME3
    RM3  = RM3A NOT INTERACT (EXT RM3A < OdmS_M3 ABUT SINGULAR REGION)

    DM3F = FM3F OR RM3

    FRAME3_INDDMYA = SIZE M3i BY (dm3_s2m3_INDDMY + grid)
    FRAME3_INDDMYB = SIZE DUM3 BY (dm3_s_INDDMY + grid)
    FRAME3_INDDMYC = SIZE DM3F BY dm3_s_INDDMY
    FRAME3_INDDMY  = ((((FRAME3Pre OR BLOCK3) OR FRAME3_INDDMYA) OR FRAME3_INDDMYB) OR FRAME3_INDDMYC) OR NFILL
    FILL3_INDDMY   = ooINDDMY NOT FRAME3_INDDMY
    DM3F_INDDMY    = RECTANGLES dm3_w_INDDMY dm3_l_INDDMY dm3_s_INDDMY INSIDE OF LAYER FILL3_INDDMY

#IFDEF FILL_indDM3
    FILL3_INDDMY_HD = (SIZE INDDMY_HD BY -(dm3_s_INDDMY_HD + grid)) NOT FRAME3_INDDMY
    DM3F_INDDMY_HD  = RECTANGLES dm3_w_INDDMY_HD dm3_l_INDDMY_HD dm3_s_INDDMY_HD INSIDE OF LAYER FILL3_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M3

    D30M3 = DENSITY M3x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M3.den30
    D40M3 = DENSITY M3x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M3.den40
    D50M3 = DENSITY M3x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M3.den50
    emptyM3 = DENSITY M3x < emptyD_M3 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M3.den_empty

    M3InnerHole = HOLES M3i INNER

    M3BigHole = SIZE M3InnerHole BY - excludeHoleSize/2
    M3ExcHole = ((M3InnerHole OUTSIDE M3BigHole) NOT M3i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK3 = (SIZE DM3EXCL BY (dm2DMEXCL + grid)) OR MIM3_x

    FRAMEA3 = (SIZE M3i BY (DM3_301 + grid)) OR (SIZE (EXPAND EDGE (M3i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA3OPC = SIZE M3i BY (DM3_OPC + grid)
    FRAMEA3OPCDV33 = SIZE (M3i INTERACT M3_HVN_330Vx) BY (M3_S_1_1_a + grid)
    FRAMEA3OPCDV5 = SIZE (M3i INTERACT M3_HVN_500Vx) BY (M3_S_9_a + grid)
    FRAMEA3OPC45 = SIZE (EXPAND EDGE (M3i ANGLE == 45) OUTSIDE BY DM3_OPC_45 EXTEND BY DM3_OPC_45_E) BY grid
    FRAMEA3OPC45DV = SIZE (EXPAND EDGE ((M3i INTERACT M3_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM3_OPC_45 EXTEND BY DM3_OPC_45_E) BY grid

    FRAMEB3 = SIZE (WITH WIDTH M3i > wideM3) BY (dm2WM3 + grid)
    FRAMEC3 = SIZE DUM3 BY (dm2DM3 + grid)
    FRAMED3 = SIZE (WITH WIDTH M3i > wideM3_small) BY (dm2WM3_small + grid)
    FRAMEC3OPC = SIZE DUM3 BY (Odm2DM3 + grid)
    FRAME3Pre = ((FRAMEA3 OR FRAMEB3) OR (FRAMEC3 OR FRAMED3)) OR M3ExcHole
    FRAME3PreOPC = (((((((FRAMEA3OPC OR FRAMEA3OPCDV33) OR FRAMEA3OPCDV5) OR FRAMEC3OPC) OR M3ExcHole) OR FRAMEA3OPC45) OR FRAMEA3OPC45DV) OR FRAMEB3) OR FRAMED3
    FRAME3INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm3_s2m3_INDDMY + grid)

    FRAME3OPC = ((FRAME3PreOPC OR FRAME3INDDMY) OR BLOCK3) OR NFILLOPC

    FRAME3 = ((FRAME3Pre OR FRAME3INDDMY) OR BLOCK3) OR NFILL

    //****************************************************************************

    D30M3p = (PUSH D30M3) NOT FRAME3
    O30M3pre = D30M3p AND CHIP
    FD21M3s = COPY FRAME3

    O30M3preA = SIZE O30M3pre BY -DM3_303
    O30M3preB = O30M3preA WITH WIDTH >= WM3_303

    // 1st big
    F303M3 = RECTANGLES WM3_303 LM3_303 SM3_303 OFFSET OM3_303 INSIDE OF LAYER O30M3preB

    F303M3_EXP = SIZE F303M3 BY ( SM3_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M3preF1 = O30M3pre NOT (SIZE F303M3_EXP BY SM3_302)
    O30M3preF  = (SNAP (SIZE O30M3preF1 BY -grid) 5) AND O30M3preF1

    B30M3s = FD21M3s OR (SIZE F303M3_EXP BY (SM3_302+grid))
    O30M3 = O30M3preF NOT B30M3s

    // 3rd, middle
    F302M3 = RECTANGLES WM3_302 LM3_302 SM3_302 OFFSET OM3_302 INSIDE OF LAYER O30M3
    F302M3s = (SIZE F302M3 BY (SM3_301 + grid)) OR B30M3s
    R302M3pre = O30M3 NOT F302M3s
    R302M3 = WITH WIDTH R302M3pre >= WM3_301

    // 4th, small
    F3012M3 = RECTANGLES WM3_301 LM3_301 SM3_301 OFFSET OM3_301 INSIDE OF LAYER R302M3
    F3012M3s = (SIZE F3012M3 BY (SM3_301 + grid)) OR F302M3s
    R3012M3pre = R302M3pre NOT F3012M3s
    R3012M3 = WITH WIDTH R3012M3pre >= WM3_301

    // 5th, non-stagger small
    F301M3 = RECTANGLES WM3_301 LM3_301 SM3_301 INSIDE OF LAYER R3012M3 //MAINTAIN SPACING
    F301M3s = (SIZE F301M3 BY (SM3_301 + grid)) OR F3012M3s

    F30M3 = ((F302M3 OR F3012M3) OR F301M3) OR F303M3
    O40M3pre = (((PUSH D40M3) NOT FRAME3) NOT F301M3s) AND CHIP


    O40M3preA = SIZE O40M3pre BY -DM3_403
    O40M3preB = O40M3preA WITH WIDTH >= WM3_403

    // 1st big
    F403M3 = RECTANGLES WM3_403 LM3_403 SM3_403 OFFSET OM3_403 INSIDE OF LAYER O40M3preB

    F403M3_EXP = SIZE F403M3 BY ( SM3_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M3preF1 = O40M3pre NOT (SIZE F403M3_EXP BY SM3_402)
    O40M3preF  = (SNAP (SIZE O40M3preF1 BY -grid) 5) AND O40M3preF1

    B40M3s = F301M3s OR (SIZE F403M3_EXP BY (SM3_402+grid))
    O40M3 = O40M3preF NOT B40M3s

    // 3rd, middle
    F402M3 = RECTANGLES WM3_402 LM3_402 SM3_402 OFFSET OM3_402 INSIDE OF LAYER O40M3
    F402M3s = (SIZE F402M3 BY (SM3_401 + grid)) OR B40M3s
    R402M3pre = O40M3 NOT F402M3s
    R402M3 = WITH WIDTH R402M3pre >= WM3_401

    // 4th, small
    F4012M3 = RECTANGLES WM3_401 LM3_401 SM3_401 OFFSET OM3_401 INSIDE OF LAYER R402M3
    F4012M3s = (SIZE F4012M3 BY (SM3_401 + grid)) OR F402M3s
    R4012M3pre = R402M3pre NOT F4012M3s
    R4012M3 = WITH WIDTH R4012M3pre >= WM3_401

    // 5th, non-stagger small
    F401M3 = RECTANGLES WM3_401 LM3_401 SM3_401 INSIDE OF LAYER R4012M3 //MAINTAIN SPACING
    F401M3s = (SIZE F401M3 BY (SM3_401 + grid)) OR F4012M3s

    F40M3 = ((F402M3 OR F4012M3) OR F401M3) OR F403M3
    O50M3pre = (((PUSH (D50M3 OR emptyM3)) NOT FRAME3) NOT F401M3s) AND CHIP


    O50M3preA = SIZE O50M3pre BY -DM3_503
    O50M3preB = O50M3preA WITH WIDTH >= WM3_503

    // 1st big
    F503M3 = RECTANGLES WM3_503 LM3_503 SM3_503 OFFSET OM3_503 INSIDE OF LAYER O50M3preB

    F503M3_EXP = SIZE F503M3 BY ( SM3_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M3preF1 = O50M3pre NOT (SIZE F503M3_EXP BY SM3_502)
    O50M3preF  = (SNAP (SIZE O50M3preF1 BY -grid) 5) AND O50M3preF1

    B50M3s = F401M3s OR (SIZE F503M3_EXP BY (SM3_502+grid))
    O50M3 = O50M3preF NOT B50M3s

    // 3rd, middle
    F502M3 = RECTANGLES WM3_502 LM3_502 SM3_502 OFFSET OM3_502 INSIDE OF LAYER O50M3
    F502M3s = (SIZE F502M3 BY (SM3_501 + grid)) OR B50M3s
    R502M3pre = O50M3 NOT F502M3s
    R502M3 = WITH WIDTH R502M3pre >= WM3_501

    // 4th, small
    F5012M3 = RECTANGLES WM3_501 LM3_501 SM3_501 OFFSET OM3_501 INSIDE OF LAYER R502M3
    F5012M3s = (SIZE F5012M3 BY (SM3_501 + grid)) OR F502M3s
    R5012M3pre = R502M3pre NOT F5012M3s
    R5012M3 = WITH WIDTH R5012M3pre >= WM3_501

    // 5th, non-stagger small
    F501M3 = RECTANGLES WM3_501 LM3_501 SM3_501 INSIDE OF LAYER R5012M3 //MAINTAIN SPACING
    F501M3s = (SIZE F501M3 BY (SM3_501 + grid)) OR F5012M3s

    F50M3 = ((F502M3 OR F5012M3) OR F501M3) OR F503M3

//****************************************************************************

    exceedM3 = DENSITY M3x F30M3 F40M3 F50M3 > maxD_M3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M3.den_exceed

    removeM3R = ((PUSH (exceedM3 AND (D50M3 OR emptyM3))) NOT FRAME3) AND CHIP
    removeM3P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM3R

    F30M3x = F30M3 NOT INTERACT removeM3P
    F40M3x = F40M3 NOT INTERACT removeM3P
    F50M3x = F50M3 NOT INTERACT removeM3P
    FM3xA  = (F30M3x OR F40M3x) OR F50M3x
    FM3x   = FM3xA NOT INTERACT (EXT FM3xA < DM3_S_1 ABUT SINGULAR REGION)

    ALLM3x = M3x OR FM3x
    lackM3 = DENSITY ALLM3x CHIP < DM3_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M3.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM3x)/AREA(CHIP) ]

    WDM3EXC = DUM3 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM3EXC = (SIZE FM3x BY Odm2DM3) OR (SIZE (((F303M3_EXP OR F403M3_EXP) OR F503M3_EXP) OR WDM3EXC) BY 1.5)

    lackM3pRM = ((((PUSH lackM3) NOT RM3EXC) NOT FRAME3OPC) NOT exceedM3) AND CHIP
    lackM3pRM_1 = WITH WIDTH lackM3pRM >= SM3_OPC

    RM3p1 = RECTANGLES WM3_OPC LM3_OPC WSM3_OPC LSM3_OPC INSIDE OF LAYER lackM3pRM_1
    lackM3pRM_2 = lackM3pRM_1 NOT (SIZE RM3p1 BY SM3_OPC)
    RM3p2 = RECTANGLES LM3_OPC WM3_OPC LSM3_OPC WSM3_OPC INSIDE OF LAYER lackM3pRM_2

    ODM3A = ((RM3p1 OR RM3p2) OUTSIDE RM3EXC) OUTSIDE FRAME3OPC
    ODM3F = ODM3A NOT INTERACT (EXT ODM3A < SM3_OPC ABUT SINGULAR REGION)

    DM3F = COPY FM3x

    FRAME3_INDDMYA = SIZE M3i BY (dm3_s2m3_INDDMY + grid)
    FRAME3_INDDMYB = SIZE DUM3 BY (dm3_s_INDDMY + grid)
    FRAME3_INDDMYC = SIZE DM3F BY dm3_s_INDDMY
    FRAME3_INDDMYD = SIZE ODM3F BY dm3_s2m3_INDDMY
    FRAME3_INDDMY  = (((((FRAME3Pre OR BLOCK3) OR FRAME3_INDDMYA) OR FRAME3_INDDMYB) OR FRAME3_INDDMYC) OR FRAME3_INDDMYD) OR NFILL
    FILL3_INDDMY   = ooINDDMY NOT FRAME3_INDDMY
    DM3F_INDDMY    = RECTANGLES dm3_w_INDDMY dm3_l_INDDMY dm3_s_INDDMY INSIDE OF LAYER FILL3_INDDMY


#IFDEF FILL_indDM3
    FILL3_INDDMY_HD = (SIZE INDDMY_HD BY -(dm3_s_INDDMY_HD + grid)) NOT FRAME3_INDDMY
    DM3F_INDDMY_HD  = RECTANGLES dm3_w_INDDMY_HD dm3_l_INDDMY_HD dm3_s_INDDMY_HD INSIDE OF LAYER FILL3_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M3

    minOPENM3 = DENSITY M3x < minD_M3 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M3Min.den
    emptyOPENM3 = DENSITY M3x < emptyD_M3 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M3Empty.den

    M3InnerHole = HOLES M3i INNER

    M3BigHole = SIZE M3InnerHole BY - excludeHoleSize/2
    M3ExcHole = ((M3InnerHole OUTSIDE M3BigHole) NOT M3i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK3 = (SIZE DM3EXCL BY (dm2DMEXCL + grid)) OR MIM3_x // DM3 to DM3EXCL
    FRAMEA3 = SIZE M3i BY (dm2M3 + grid) // DM3 to metal
    FRAMEB3 = SIZE (WITH WIDTH M3i > wideM3) BY (dm2WM3 + grid)
    FRAMEC3 = SIZE DUM3 BY (dm2DM3 + grid)   // DM3 to existed dummy metal 0.6um
    FRAME3Pre = ((FRAMEA3 OR FRAMEB3) OR FRAMEC3) OR M3ExcHole
    FRAME3INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm3_s2m3_INDDMY + grid)
    FRAME3 = ((FRAME3Pre OR FRAME3INDDMY) OR BLOCK3) OR NFILL
    
    OPENM3 = PUSH ((minOPENM3 OR emptyOPENM3) AND CHIP)
    FILL3 = OPENM3 NOT FRAME3
    FILLW3pre = SIZE FILL3 BY - (Wdm2M3 + grid)
    FILLW3 = WITH WIDTH FILLW3pre >= WdmW_M3
    M3FW = RECTANGLES WdmW_M3 WdmL_M3 WdmS_M3 OFFSET WdmO_M3 INSIDE OF LAYER FILLW3
    M3FW_EXP = SIZE M3FW BY (WdmS_M3 /2 + grid) OVERUNDER //merge the gaps
    FILLM3pre = FILL3 NOT (SIZE M3FW_EXP BY (MdmS_M3 + grid))
    FILLM3 = WITH WIDTH FILLM3pre >= MdmW_M3
    M3F1 = RECTANGLES MdmW_M3 MdmL_M3 MdmS_M3 OFFSET MdmO_M3 INSIDE OF LAYER FILLM3
    M3R1pre = FILLM3pre NOT (SIZE M3F1 BY (dmS_M3 + grid))
    M3R1 = WITH WIDTH M3R1pre >= dmW_M3

    M3F2 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 OFFSET dmO_M3 INSIDE OF LAYER M3R1
    M3R2pre = M3R1 NOT (SIZE M3F2 BY (dmS_M3 + grid))
    M3R2 = WITH WIDTH M3R2pre >= dmW_M3

    M3F3 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 OFFSET dmO_M3 INSIDE OF LAYER M3R2
    M3R3pre = M3R2 NOT (SIZE M3F3 BY (dmS_M3 + grid))
    M3R3 = WITH WIDTH M3R3pre >= dmW_M3

    M3F4 = RECTANGLES dmW_M3 dmL_M3 dmS_M3 INSIDE OF LAYER M3R3

    M3F = (((M3F1 OR M3F2) OR M3F3) OR M3F4) OR M3FW
    FM3 = M3F NOT INTERACT (EXT M3F < dmS_M3 ABUT SINGULAR REGION)

    maxOPENM3 = DENSITY M3x FM3 > maxD_M3 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M3Max.den

    FM3F = FM3 OUTSIDE maxOPENM3

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M3 = DENSITY M3x FM3F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M3Min.den

    RM3EXC = SIZE FM3F BY (Odm2DM3 + grid)
    // do not fill DMz_S over CTMDMY
    D25M3pM = (((PUSH D25M3) NOT FRAME3) NOT RM3EXC) AND CHIP
    D25M3pM_1 = WITH WIDTH D25M3pM >= OdmW_M3

    RM3p1 = RECTANGLES OdmW_M3 OdmL_M3 OdmS_M3 INSIDE OF LAYER D25M3pM_1
    D25M3pM_2 = D25M3pM_1 NOT (SIZE RM3p1 BY (OdmS_M3 + grid))
    RM3p2 = RECTANGLES OdmL_M3 OdmW_M3 OdmS_M3 INSIDE OF LAYER D25M3pM_2

    RM3A = ((RM3p1 OR RM3p2) OUTSIDE RM3EXC) OUTSIDE FRAME3
    RM3  = RM3A NOT INTERACT (EXT RM3A < OdmS_M3 ABUT SINGULAR REGION)

    DM3F = FM3F OR RM3

    FRAME3_INDDMYA = SIZE M3i BY (dm3_s2m3_INDDMY + grid)
    FRAME3_INDDMYB = SIZE DUM3 BY (dm3_s_INDDMY + grid)
    FRAME3_INDDMYC = SIZE DM3F BY dm3_s_INDDMY
    FRAME3_INDDMY  = ((((FRAME3Pre OR BLOCK3) OR FRAME3_INDDMYA) OR FRAME3_INDDMYB) OR FRAME3_INDDMYC) OR NFILL
    FILL3_INDDMY   = ooINDDMY NOT FRAME3_INDDMY
    DM3F_INDDMY    = RECTANGLES dm3_w_INDDMY dm3_l_INDDMY dm3_s_INDDMY INSIDE OF LAYER FILL3_INDDMY

#IFDEF FILL_indDM3
    FILL3_INDDMY_HD = (SIZE INDDMY_HD BY -(dm3_s_INDDMY_HD + grid)) NOT FRAME3_INDDMY
    DM3F_INDDMY_HD  = RECTANGLES dm3_w_INDDMY_HD dm3_l_INDDMY_HD dm3_s_INDDMY_HD INSIDE OF LAYER FILL3_INDDMY_HD
#ENDIF	

#ELSE



    D30M3 = DENSITY M3x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M3.den30
    D40M3 = DENSITY M3x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M3.den40
    D50M3 = DENSITY M3x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M3.den50
    emptyM3 = DENSITY M3x < emptyD_M3 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M3.den_empty

    M3InnerHole = HOLES M3i INNER
#IFDEF FILL_M3_DTCD
    VARIABLE M3_DTCD2Chip      2.5  //
    VARIABLE M3_DTCD2LOGO      10   //
    VARIABLE M3_DTCD2MOMDMY    0    // 
    VARIABLE M3_DTCD2LOWMEDN   0    //
    VARIABLE M3_DTCD2POFUSE    0    //
    VARIABLE M3_DTCD2DM3EXCL   0    //
    VARIABLE M3_DTCD2DM3CB2   0    //
    VARIABLE M3_DTCD2M3        2.63  // CB2.S.2
    VARIABLE M3_DTCD2DM3       1.5  // DMx.S.2
    VARIABLE M3_DTCD2TCDDMY_M3 150  // for idu measurement
    VARIABLE M3_DTCD2CTMDMY_4 0.112  // MIM.VIAz.S.5
    VARIABLE M3_DTCD2ICOVL     8
	M3_DTCDxChip        = CHIP NOT (SIZE CHIP BY -(M3_DTCD2Chip + grid))
    M3_DTCDxLOGO        = SIZE LOGO               BY (M3_DTCD2LOGO      + grid)
    M3_DTCDxMOMDMY      = SIZE MOMDMY             BY (M3_DTCD2MOMDMY    + grid)
    M3_DTCDxLOWMEDN     = SIZE LOWMEDN            BY (M3_DTCD2LOWMEDN   + grid)
    M3_DTCDxPOFUSE      = SIZE (FUSELINK AND POi) BY (M3_DTCD2POFUSE    + grid)
    M3_DTCDxDM3EXCL     = SIZE DM3EXCL            BY (M3_DTCD2DM3EXCL   + grid)
    M3_DTCDxDM3CB2      = SIZE CB2i               BY (M3_DTCD2DM3CB2    + grid)
    M3_DTCDxM3          = SIZE M3i                BY (M3_DTCD2M3        + grid)
    M3_DTCDxDM3         = SIZE DUM3               BY (M3_DTCD2DM3       + grid)
    M3_DTCDxTCDDMY_M3   = SIZE TCDDMY_M3          BY (M3_DTCD2TCDDMY_M3 + grid)
    M3_DTCDxTCDDMY_FM3  = SIZE TCDDMY_FM3         BY (M3_DTCD2TCDDMY_M3 + grid)
    M3_DTCDxTCDDMY_FDM3 = SIZE TCDDMY_FDM3        BY (M3_DTCD2TCDDMY_M3 + grid)
    M3_DTCDxICOVL       = SIZE ICOVL              BY (M3_DTCD2ICOVL     + grid)
    M3_DTCDxCTMDMY_4   = SIZE CTMDMY_4          BY (M3_DTCD2CTMDMY_4  + grid)

    M3_DTCDx = (((((((((((((M3_DTCDxChip OR M3_DTCDxLOGO) OR M3_DTCDxLOWMEDN) OR M3_DTCDxPOFUSE) OR M3_DTCDxDM3EXCL) OR M3_DTCDxM3) OR M3_DTCDxDM3) OR M3_DTCDxTCDDMY_M3) OR M3_DTCDxTCDDMY_FM3) OR M3_DTCDxTCDDMY_FDM3) OR FRAME3INDDMY) OR M3_DTCDxMOMDMY) OR M3_DTCDxDM3CB2) OR M3_DTCDxCTMDMY_4) OR M3_DTCDxICOVL
    M3_DTCDo = CHIP NOT M3_DTCDx

    VARIABLE TCD_M3_W      4
    VARIABLE TCD_M3_L      4
    VARIABLE M3_DTCD_S     400
    VARIABLE M3_DTCD_MIN_S 150
    VARIABLE D2M3_DTCD     0.6

    M3_DTCD_pre = RECTANGLES TCD_M3_W TCD_M3_L M3_DTCD_S INSIDE OF LAYER M3_DTCDo
    TCD_M3 = M3_DTCD_pre NOT INTERACT (EXT M3_DTCD_pre < M3_DTCD_MIN_S ABUT SINGULAR REGION)

TCD_M3_165_93_1 = SHRINK TCD_M3 LEFT BY 0 BOTTOM BY 0 RIGHT BY (TCD_M3_W-4) TOP BY (TCD_M3_L-4)
