#IFDEF 34K_THICK_Mu_M2
#ELSE
#IFDEF 12K_THICK_Mr_M2
#ELSE
#IFDEF 9K_THICK_Mz_M2
#ELSE
#IFDEF 5K_THICK_Myz_M2
#ELSE
#IFDEF 2_6K_THICK_Mxy_M2
#ELSE
#IFDEF 2K_THICK_My_M2
#ELSE




#IFDEF FILL_DM2
DM2F_FOR_DVIA2F_REGION = ((DM2F OR DUM2) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM2F_FOR_DVIA2F_REGION = (DUM2 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

#IFDEF FILL_DM3
DM3F_FOR_DVIA2F_REGION = ((DM3F OR DUM3) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM3F_FOR_DVIA2F_REGION = (DUM3 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

// Find DVIA2 fillable regions.  Consider enclosure to lower DM2, enclosure to upper DM3, DVIA2 size.

VARIABLE DM2_F_4_REGION_DVIA2_SHORTENED_LENGTH DVIA2_EN_2 - DVIA2_EN_1

#IFDEF VERTICAL_DM2
DM2_F_4_REGION_DVIA2_spec_B_pre = RECTANGLE DM2F_FOR_DVIA2F_REGION == WM2_303_SLOT BY == LM2_303_SLOT
DM2_F_4_REGION_DVIA2_spec_B     = DM2_F_4_REGION_DVIA2_spec_B_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA2_spec_B_pre == WM2_303_SLOT) INSIDE BY DM2_F_4_REGION_DVIA2_SHORTENED_LENGTH)

DM2_F_4_REGION_DVIA2_spec_M_pre = RECTANGLE DM2F_FOR_DVIA2F_REGION == WM2_302 BY == LM2_302
DM2_F_4_REGION_DVIA2_spec_M     = DM2_F_4_REGION_DVIA2_spec_M_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA2_spec_M_pre == WM2_302) INSIDE BY DM2_F_4_REGION_DVIA2_SHORTENED_LENGTH)

DM2_F_4_REGION_DVIA2_spec_S_pre = RECTANGLE DM2F_FOR_DVIA2F_REGION == WM2_301 BY == LM2_301
DM2_F_4_REGION_DVIA2_spec_S     = DM2_F_4_REGION_DVIA2_spec_S_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA2_spec_S_pre == WM2_301) INSIDE BY DM2_F_4_REGION_DVIA2_SHORTENED_LENGTH)
#ELSE
DM2_F_4_REGION_DVIA2_spec_B_pre = RECTANGLE DM2F_FOR_DVIA2F_REGION == LM2_303_SLOT BY == WM2_303_SLOT
DM2_F_4_REGION_DVIA2_spec_B     = DM2_F_4_REGION_DVIA2_spec_B_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA2_spec_B_pre == LM2_303_SLOT) INSIDE BY DM2_F_4_REGION_DVIA2_SHORTENED_LENGTH)

DM2_F_4_REGION_DVIA2_spec_M_pre = RECTANGLE DM2F_FOR_DVIA2F_REGION == LM2_302 BY == WM2_302
DM2_F_4_REGION_DVIA2_spec_M     = DM2_F_4_REGION_DVIA2_spec_M_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA2_spec_M_pre == LM2_302) INSIDE BY DM2_F_4_REGION_DVIA2_SHORTENED_LENGTH)

DM2_F_4_REGION_DVIA2_spec_S_pre = RECTANGLE DM2F_FOR_DVIA2F_REGION == LM2_301 BY == WM2_301
DM2_F_4_REGION_DVIA2_spec_S     = DM2_F_4_REGION_DVIA2_spec_S_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA2_spec_S_pre == LM2_301) INSIDE BY DM2_F_4_REGION_DVIA2_SHORTENED_LENGTH)
#ENDIF
DM2_F_4_REGION_DVIA2_square_pre = RECTANGLE DM2F_FOR_DVIA2F_REGION ASPECT == 1
DM2_F_4_REGION_DVIA2_square     = SIZE DM2_F_4_REGION_DVIA2_square_pre BY -DM2_F_4_REGION_DVIA2_SHORTENED_LENGTH

DM2F_FOR_DVIA2F_REGION_4parts = (DM2_F_4_REGION_DVIA2_spec_B OR DM2_F_4_REGION_DVIA2_spec_M) OR (DM2_F_4_REGION_DVIA2_spec_S OR DM2_F_4_REGION_DVIA2_square)
DM2F_FOR_DVIA2F_REGION_remainder_pre_not = (DM2_F_4_REGION_DVIA2_spec_B_pre OR DM2_F_4_REGION_DVIA2_spec_M_pre) OR (DM2_F_4_REGION_DVIA2_spec_S_pre OR DM2_F_4_REGION_DVIA2_square_pre)
DM2F_FOR_DVIA2F_REGION_remainder = DM2F_FOR_DVIA2F_REGION NOT DM2F_FOR_DVIA2F_REGION_remainder_pre_not

    DM2F_FOR_DVIA2F_REGION_remainder_EDGE = LENGTH DM2F_FOR_DVIA2F_REGION_remainder > 0
    DM2F_FOR_DVIA2F_REGION_remainder_PROP = DFM PROPERTY DM2F_FOR_DVIA2F_REGION_remainder DM2F_FOR_DVIA2F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM2F_FOR_DVIA2F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM2F_FOR_DVIA2F_REGION_remainder_EDGE)) ]
    DM2F_FOR_DVIA2F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM2F_FOR_DVIA2F_REGION_remainder_EDGE DM2F_FOR_DVIA2F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM2F_FOR_DVIA2F_REGION_remainder_EDGE) - PROPERTY(DM2F_FOR_DVIA2F_REGION_remainder_PROP, DM2F_FOR_DVIA2F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM2F_FOR_DVIA2F_REGION2 = DM2F_FOR_DVIA2F_REGION_remainder NOT (EXPAND EDGE DM2F_FOR_DVIA2F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM2_F_4_REGION_DVIA2_SHORTENED_LENGTH)


VARIABLE DM3_F_4_REGION_DVIA2_SHORTENED_LENGTH DM3_EN_3 - DM3_EN_2

#IFDEF VERTICAL_DM3
DM3_F_4_REGION_DVIA2_spec_B_pre = RECTANGLE DM3F_FOR_DVIA2F_REGION == WM3_303_SLOT BY == LM3_303_SLOT
DM3_F_4_REGION_DVIA2_spec_B     = DM3_F_4_REGION_DVIA2_spec_B_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA2_spec_B_pre == WM3_303_SLOT) INSIDE BY DM3_F_4_REGION_DVIA2_SHORTENED_LENGTH)

DM3_F_4_REGION_DVIA2_spec_M_pre = RECTANGLE DM3F_FOR_DVIA2F_REGION == WM3_302 BY == LM3_302
DM3_F_4_REGION_DVIA2_spec_M     = DM3_F_4_REGION_DVIA2_spec_M_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA2_spec_M_pre == WM3_302) INSIDE BY DM3_F_4_REGION_DVIA2_SHORTENED_LENGTH)

DM3_F_4_REGION_DVIA2_spec_S_pre = RECTANGLE DM3F_FOR_DVIA2F_REGION == WM3_301 BY == LM3_301
DM3_F_4_REGION_DVIA2_spec_S     = DM3_F_4_REGION_DVIA2_spec_S_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA2_spec_S_pre == WM3_301) INSIDE BY DM3_F_4_REGION_DVIA2_SHORTENED_LENGTH)
#ELSE
DM3_F_4_REGION_DVIA2_spec_B_pre = RECTANGLE DM3F_FOR_DVIA2F_REGION == LM3_303_SLOT BY == WM3_303_SLOT
DM3_F_4_REGION_DVIA2_spec_B     = DM3_F_4_REGION_DVIA2_spec_B_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA2_spec_B_pre == LM3_303_SLOT) INSIDE BY DM3_F_4_REGION_DVIA2_SHORTENED_LENGTH)

DM3_F_4_REGION_DVIA2_spec_M_pre = RECTANGLE DM3F_FOR_DVIA2F_REGION == LM3_302 BY == WM3_302
DM3_F_4_REGION_DVIA2_spec_M     = DM3_F_4_REGION_DVIA2_spec_M_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA2_spec_M_pre == LM3_302) INSIDE BY DM3_F_4_REGION_DVIA2_SHORTENED_LENGTH)

DM3_F_4_REGION_DVIA2_spec_S_pre = RECTANGLE DM3F_FOR_DVIA2F_REGION == LM3_301 BY == WM3_301
DM3_F_4_REGION_DVIA2_spec_S     = DM3_F_4_REGION_DVIA2_spec_S_pre NOT (EXPAND EDGE (LENGTH DM3_F_4_REGION_DVIA2_spec_S_pre == LM3_301) INSIDE BY DM3_F_4_REGION_DVIA2_SHORTENED_LENGTH)
#ENDIF

DM3_F_4_REGION_DVIA2_square_pre = RECTANGLE DM3F_FOR_DVIA2F_REGION ASPECT == 1
DM3_F_4_REGION_DVIA2_square     = SIZE DM3_F_4_REGION_DVIA2_square_pre BY -DM3_F_4_REGION_DVIA2_SHORTENED_LENGTH

DM3F_FOR_DVIA2F_REGION_4parts = (DM3_F_4_REGION_DVIA2_spec_B OR DM3_F_4_REGION_DVIA2_spec_M) OR (DM3_F_4_REGION_DVIA2_spec_S OR DM3_F_4_REGION_DVIA2_square)
DM3F_FOR_DVIA2F_REGION_remainder_pre_not = (DM3_F_4_REGION_DVIA2_spec_B_pre OR DM3_F_4_REGION_DVIA2_spec_M_pre) OR (DM3_F_4_REGION_DVIA2_spec_S_pre OR DM3_F_4_REGION_DVIA2_square_pre)
DM3F_FOR_DVIA2F_REGION_remainder = DM3F_FOR_DVIA2F_REGION NOT DM3F_FOR_DVIA2F_REGION_remainder_pre_not

    DM3F_FOR_DVIA2F_REGION_remainder_EDGE = LENGTH DM3F_FOR_DVIA2F_REGION_remainder > 0
    DM3F_FOR_DVIA2F_REGION_remainder_PROP = DFM PROPERTY DM3F_FOR_DVIA2F_REGION_remainder DM3F_FOR_DVIA2F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM3F_FOR_DVIA2F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM3F_FOR_DVIA2F_REGION_remainder_EDGE)) ]
    DM3F_FOR_DVIA2F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM3F_FOR_DVIA2F_REGION_remainder_EDGE DM3F_FOR_DVIA2F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM3F_FOR_DVIA2F_REGION_remainder_EDGE) - PROPERTY(DM3F_FOR_DVIA2F_REGION_remainder_PROP, DM3F_FOR_DVIA2F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM3F_FOR_DVIA2F_REGION2 = DM3F_FOR_DVIA2F_REGION_remainder NOT (EXPAND EDGE DM3F_FOR_DVIA2F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM3_F_4_REGION_DVIA2_SHORTENED_LENGTH)

DVIA2F_BASE_REGION = (((((SIZE (DM2F_FOR_DVIA2F_REGION2 OR DM2F_FOR_DVIA2F_REGION_4parts) BY -DVIA2_EN_1) AND (SIZE (DM3F_FOR_DVIA2F_REGION2 OR DM3F_FOR_DVIA2F_REGION_4parts) BY -DM3_EN_2)) WITH WIDTH >= DVIA2_W_1) NOT (SIZE DVIA2EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA2i BY (DVIA2_S_1 + grid))) NOT (SIZE VIA2i BY (DVIA2_S_2 + grid))




// Merge DVIA2 fillable regions, and find DVIA2 seeds by maintaining spacing DVIA2_S_1.
DVIA2F_SEED_REGION_1 = (((SIZE DVIA2F_BASE_REGION BY DVIA2F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA2EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA2i BY (DVIA2_S_1 + grid))) NOT (SIZE VIA2i BY (DVIA2_S_2 + grid))
DVIA2F_SEED_1 = RECTANGLES DVIA2_W_1 DVIA2_W_1 DVIA2_S_1 INSIDE OF LAYER DVIA2F_SEED_REGION_1

// Find DVIA2 in the DVIA2 fillable and spacing-maintained regions.
DVIA2F_REGION_1 = (DVIA2F_BASE_REGION INTERACT DVIA2F_SEED_1) NOT TOUCH DVIA2F_SEED_1
DVIA2F_pre1_1_pre1 = RECTANGLES DVIA2_W_1 DVIA2_W_1 DVIA2_S_1 INSIDE OF LAYER DVIA2F_REGION_1

// post-DRC
DVIA2F_pre1_1_pre2 = DVIA2F_pre1_1_pre1 NOT INTERACT (EXT DVIA2F_pre1_1_pre1 < DVIA2_S_1 ABUT SINGULAR REGION)
DVIA2F_pre1_1_pre3 = DVIA2F_pre1_1_pre2 NOT INTERACT (EXT DVIA2F_pre1_1_pre2 DUVIA2i < DVIA2_S_1 ABUT SINGULAR REGION)
DVIA2F_pre1_1_pre4 = DVIA2F_pre1_1_pre3 NOT INTERACT (EXT DVIA2F_pre1_1_pre3 VIA2i < DVIA2_S_2 ABUT SINGULAR REGION)
DVIA2F_pre1_1_pre5 = DVIA2F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA2F_pre1_1_pre4 DM2F_FOR_DVIA2F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA2_EN_2 OPPOSITE 0 DVIA2_EN_2 OPPOSITE)
DVIA2F_pre1_1      = DVIA2F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA2F_pre1_1_pre5 DM3F_FOR_DVIA2F_REGION ABUT < 90 SINGULAR GOOD 0 DM3_EN_3 OPPOSITE 0 DM3_EN_3 OPPOSITE)

// Merge DVIA2 fillable regions, and find DVIA2 seeds by maintaining spacing DVIA2_S_1.
DVIA2F_SEED_REGION_2 = (((SIZE (DVIA2F_BASE_REGION NOT INTERACT (SIZE DVIA2F_pre1_1 BY DVIA2_S_1)) BY DVIA2F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA2EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA2i BY (DVIA2_S_1 + grid))) NOT (SIZE VIA2i BY (DVIA2_S_2 + grid))
DVIA2F_SEED_2 = RECTANGLES DVIA2_W_1 DVIA2_W_1 DVIA2_S_1 INSIDE OF LAYER DVIA2F_SEED_REGION_2

// Find DVIA2 in the DVIA2 fillable and spacing-maintained regions.
DVIA2F_REGION_2 = (DVIA2F_BASE_REGION INTERACT DVIA2F_SEED_2) NOT TOUCH DVIA2F_SEED_2
DVIA2F_pre1_2 = RECTANGLES DVIA2_W_1 DVIA2_W_1 DVIA2_S_1 INSIDE OF LAYER DVIA2F_REGION_2

// post-DRC
DVIA2F_pre1 = DVIA2F_pre1_1 OR DVIA2F_pre1_2
DVIA2F_pre2 = DVIA2F_pre1 NOT INTERACT (EXT DVIA2F_pre1 < DVIA2_S_1 ABUT SINGULAR REGION)
DVIA2F_pre3 = DVIA2F_pre2 NOT INTERACT (EXT DVIA2F_pre2 DUVIA2i < DVIA2_S_1 ABUT SINGULAR REGION)
DVIA2F_pre4 = DVIA2F_pre3 NOT INTERACT (EXT DVIA2F_pre3 VIA2i < DVIA2_S_2 ABUT SINGULAR REGION)
DVIA2F_pre5 = DVIA2F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA2F_pre4 DM2F_FOR_DVIA2F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA2_EN_2 OPPOSITE 0 DVIA2_EN_2 OPPOSITE)
DVIA2F      = DVIA2F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA2F_pre5 DM3F_FOR_DVIA2F_REGION ABUT < 90 SINGULAR GOOD 0 DM3_EN_3 OPPOSITE 0 DM3_EN_3 OPPOSITE)

#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
