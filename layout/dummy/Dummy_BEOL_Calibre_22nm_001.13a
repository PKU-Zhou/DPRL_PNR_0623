DM10_F_4_REGION_DVIA10_spec_S     = DM10_F_4_REGION_DVIA10_spec_S_pre NOT (EXPAND EDGE (LENGTH DM10_F_4_REGION_DVIA10_spec_S_pre == LM10_301) INSIDE BY DM10_F_4_REGION_DVIA10_SHORTENED_LENGTH)
#ENDIF
DM10_F_4_REGION_DVIA10_square_pre = RECTANGLE DM10F_FOR_DVIA10F_REGION ASPECT == 1
DM10_F_4_REGION_DVIA10_square     = SIZE DM10_F_4_REGION_DVIA10_square_pre BY -DM10_F_4_REGION_DVIA10_SHORTENED_LENGTH

DM10F_FOR_DVIA10F_REGION_4parts = (DM10_F_4_REGION_DVIA10_spec_B OR DM10_F_4_REGION_DVIA10_spec_M) OR (DM10_F_4_REGION_DVIA10_spec_S OR DM10_F_4_REGION_DVIA10_square)
DM10F_FOR_DVIA10F_REGION_remainder_pre_not = (DM10_F_4_REGION_DVIA10_spec_B_pre OR DM10_F_4_REGION_DVIA10_spec_M_pre) OR (DM10_F_4_REGION_DVIA10_spec_S_pre OR DM10_F_4_REGION_DVIA10_square_pre)
DM10F_FOR_DVIA10F_REGION_remainder = DM10F_FOR_DVIA10F_REGION NOT DM10F_FOR_DVIA10F_REGION_remainder_pre_not

    DM10F_FOR_DVIA10F_REGION_remainder_EDGE = LENGTH DM10F_FOR_DVIA10F_REGION_remainder > 0
    DM10F_FOR_DVIA10F_REGION_remainder_PROP = DFM PROPERTY DM10F_FOR_DVIA10F_REGION_remainder DM10F_FOR_DVIA10F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM10F_FOR_DVIA10F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM10F_FOR_DVIA10F_REGION_remainder_EDGE)) ]
    DM10F_FOR_DVIA10F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM10F_FOR_DVIA10F_REGION_remainder_EDGE DM10F_FOR_DVIA10F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM10F_FOR_DVIA10F_REGION_remainder_EDGE) - PROPERTY(DM10F_FOR_DVIA10F_REGION_remainder_PROP, DM10F_FOR_DVIA10F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM10F_FOR_DVIA10F_REGION2 = DM10F_FOR_DVIA10F_REGION_remainder NOT (EXPAND EDGE DM10F_FOR_DVIA10F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM10_F_4_REGION_DVIA10_SHORTENED_LENGTH)


VARIABLE DM11_F_4_REGION_DVIA10_SHORTENED_LENGTH DM11_EN_3 - DM11_EN_2

#IFDEF VERTICAL_DM11
DM11_F_4_REGION_DVIA10_spec_B_pre = RECTANGLE DM11F_FOR_DVIA10F_REGION == WM11_303_SLOT BY == LM11_303_SLOT
DM11_F_4_REGION_DVIA10_spec_B     = DM11_F_4_REGION_DVIA10_spec_B_pre NOT (EXPAND EDGE (LENGTH DM11_F_4_REGION_DVIA10_spec_B_pre == WM11_303_SLOT) INSIDE BY DM11_F_4_REGION_DVIA10_SHORTENED_LENGTH)

DM11_F_4_REGION_DVIA10_spec_M_pre = RECTANGLE DM11F_FOR_DVIA10F_REGION == WM11_302 BY == LM11_302
DM11_F_4_REGION_DVIA10_spec_M     = DM11_F_4_REGION_DVIA10_spec_M_pre NOT (EXPAND EDGE (LENGTH DM11_F_4_REGION_DVIA10_spec_M_pre == WM11_302) INSIDE BY DM11_F_4_REGION_DVIA10_SHORTENED_LENGTH)

DM11_F_4_REGION_DVIA10_spec_S_pre = RECTANGLE DM11F_FOR_DVIA10F_REGION == WM11_301 BY == LM11_301
DM11_F_4_REGION_DVIA10_spec_S     = DM11_F_4_REGION_DVIA10_spec_S_pre NOT (EXPAND EDGE (LENGTH DM11_F_4_REGION_DVIA10_spec_S_pre == WM11_301) INSIDE BY DM11_F_4_REGION_DVIA10_SHORTENED_LENGTH)
#ELSE
DM11_F_4_REGION_DVIA10_spec_B_pre = RECTANGLE DM11F_FOR_DVIA10F_REGION == LM11_303_SLOT BY == WM11_303_SLOT
DM11_F_4_REGION_DVIA10_spec_B     = DM11_F_4_REGION_DVIA10_spec_B_pre NOT (EXPAND EDGE (LENGTH DM11_F_4_REGION_DVIA10_spec_B_pre == LM11_303_SLOT) INSIDE BY DM11_F_4_REGION_DVIA10_SHORTENED_LENGTH)

DM11_F_4_REGION_DVIA10_spec_M_pre = RECTANGLE DM11F_FOR_DVIA10F_REGION == LM11_302 BY == WM11_302
DM11_F_4_REGION_DVIA10_spec_M     = DM11_F_4_REGION_DVIA10_spec_M_pre NOT (EXPAND EDGE (LENGTH DM11_F_4_REGION_DVIA10_spec_M_pre == LM11_302) INSIDE BY DM11_F_4_REGION_DVIA10_SHORTENED_LENGTH)

DM11_F_4_REGION_DVIA10_spec_S_pre = RECTANGLE DM11F_FOR_DVIA10F_REGION == LM11_301 BY == WM11_301
DM11_F_4_REGION_DVIA10_spec_S     = DM11_F_4_REGION_DVIA10_spec_S_pre NOT (EXPAND EDGE (LENGTH DM11_F_4_REGION_DVIA10_spec_S_pre == LM11_301) INSIDE BY DM11_F_4_REGION_DVIA10_SHORTENED_LENGTH)
#ENDIF

DM11_F_4_REGION_DVIA10_square_pre = RECTANGLE DM11F_FOR_DVIA10F_REGION ASPECT == 1
DM11_F_4_REGION_DVIA10_square     = SIZE DM11_F_4_REGION_DVIA10_square_pre BY -DM11_F_4_REGION_DVIA10_SHORTENED_LENGTH

DM11F_FOR_DVIA10F_REGION_4parts = (DM11_F_4_REGION_DVIA10_spec_B OR DM11_F_4_REGION_DVIA10_spec_M) OR (DM11_F_4_REGION_DVIA10_spec_S OR DM11_F_4_REGION_DVIA10_square)
DM11F_FOR_DVIA10F_REGION_remainder_pre_not = (DM11_F_4_REGION_DVIA10_spec_B_pre OR DM11_F_4_REGION_DVIA10_spec_M_pre) OR (DM11_F_4_REGION_DVIA10_spec_S_pre OR DM11_F_4_REGION_DVIA10_square_pre)
DM11F_FOR_DVIA10F_REGION_remainder = DM11F_FOR_DVIA10F_REGION NOT DM11F_FOR_DVIA10F_REGION_remainder_pre_not

    DM11F_FOR_DVIA10F_REGION_remainder_EDGE = LENGTH DM11F_FOR_DVIA10F_REGION_remainder > 0
    DM11F_FOR_DVIA10F_REGION_remainder_PROP = DFM PROPERTY DM11F_FOR_DVIA10F_REGION_remainder DM11F_FOR_DVIA10F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM11F_FOR_DVIA10F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM11F_FOR_DVIA10F_REGION_remainder_EDGE)) ]
    DM11F_FOR_DVIA10F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM11F_FOR_DVIA10F_REGION_remainder_EDGE DM11F_FOR_DVIA10F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM11F_FOR_DVIA10F_REGION_remainder_EDGE) - PROPERTY(DM11F_FOR_DVIA10F_REGION_remainder_PROP, DM11F_FOR_DVIA10F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM11F_FOR_DVIA10F_REGION2 = DM11F_FOR_DVIA10F_REGION_remainder NOT (EXPAND EDGE DM11F_FOR_DVIA10F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM11_F_4_REGION_DVIA10_SHORTENED_LENGTH)

DVIA10F_BASE_REGION = (((((SIZE (DM10F_FOR_DVIA10F_REGION2 OR DM10F_FOR_DVIA10F_REGION_4parts) BY -DVIA10_EN_1) AND (SIZE (DM11F_FOR_DVIA10F_REGION2 OR DM11F_FOR_DVIA10F_REGION_4parts) BY -DM11_EN_2)) WITH WIDTH >= DVIA10_W_1) NOT (SIZE DVIA10EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA10i BY (DVIA10_S_1 + grid))) NOT (SIZE VIA10i BY (DVIA10_S_2 + grid))




// Merge DVIA10 fillable regions, and find DVIA10 seeds by maintaining spacing DVIA10_S_1.
DVIA10F_SEED_REGION_1 = (((SIZE DVIA10F_BASE_REGION BY DVIA10F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA10EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA10i BY (DVIA10_S_1 + grid))) NOT (SIZE VIA10i BY (DVIA10_S_2 + grid))
DVIA10F_SEED_1 = RECTANGLES DVIA10_W_1 DVIA10_W_1 DVIA10_S_1 INSIDE OF LAYER DVIA10F_SEED_REGION_1

// Find DVIA10 in the DVIA10 fillable and spacing-maintained regions.
DVIA10F_REGION_1 = (DVIA10F_BASE_REGION INTERACT DVIA10F_SEED_1) NOT TOUCH DVIA10F_SEED_1
DVIA10F_pre1_1_pre1 = RECTANGLES DVIA10_W_1 DVIA10_W_1 DVIA10_S_1 INSIDE OF LAYER DVIA10F_REGION_1

// post-DRC
DVIA10F_pre1_1_pre2 = DVIA10F_pre1_1_pre1 NOT INTERACT (EXT DVIA10F_pre1_1_pre1 < DVIA10_S_1 ABUT SINGULAR REGION)
DVIA10F_pre1_1_pre3 = DVIA10F_pre1_1_pre2 NOT INTERACT (EXT DVIA10F_pre1_1_pre2 DUVIA10i < DVIA10_S_1 ABUT SINGULAR REGION)
DVIA10F_pre1_1_pre4 = DVIA10F_pre1_1_pre3 NOT INTERACT (EXT DVIA10F_pre1_1_pre3 VIA10i < DVIA10_S_2 ABUT SINGULAR REGION)
DVIA10F_pre1_1_pre5 = DVIA10F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA10F_pre1_1_pre4 DM10F_FOR_DVIA10F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA10_EN_2 OPPOSITE 0 DVIA10_EN_2 OPPOSITE)
DVIA10F_pre1_1      = DVIA10F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA10F_pre1_1_pre5 DM11F_FOR_DVIA10F_REGION ABUT < 90 SINGULAR GOOD 0 DM11_EN_3 OPPOSITE 0 DM11_EN_3 OPPOSITE)

// Merge DVIA10 fillable regions, and find DVIA10 seeds by maintaining spacing DVIA10_S_1.
DVIA10F_SEED_REGION_2 = (((SIZE (DVIA10F_BASE_REGION NOT INTERACT (SIZE DVIA10F_pre1_1 BY DVIA10_S_1)) BY DVIA10F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA10EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA10i BY (DVIA10_S_1 + grid))) NOT (SIZE VIA10i BY (DVIA10_S_2 + grid))
DVIA10F_SEED_2 = RECTANGLES DVIA10_W_1 DVIA10_W_1 DVIA10_S_1 INSIDE OF LAYER DVIA10F_SEED_REGION_2

// Find DVIA10 in the DVIA10 fillable and spacing-maintained regions.
DVIA10F_REGION_2 = (DVIA10F_BASE_REGION INTERACT DVIA10F_SEED_2) NOT TOUCH DVIA10F_SEED_2
DVIA10F_pre1_2 = RECTANGLES DVIA10_W_1 DVIA10_W_1 DVIA10_S_1 INSIDE OF LAYER DVIA10F_REGION_2

// post-DRC
DVIA10F_pre1 = DVIA10F_pre1_1 OR DVIA10F_pre1_2
DVIA10F_pre2 = DVIA10F_pre1 NOT INTERACT (EXT DVIA10F_pre1 < DVIA10_S_1 ABUT SINGULAR REGION)
DVIA10F_pre3 = DVIA10F_pre2 NOT INTERACT (EXT DVIA10F_pre2 DUVIA10i < DVIA10_S_1 ABUT SINGULAR REGION)
DVIA10F_pre4 = DVIA10F_pre3 NOT INTERACT (EXT DVIA10F_pre3 VIA10i < DVIA10_S_2 ABUT SINGULAR REGION)
DVIA10F_pre5 = DVIA10F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA10F_pre4 DM10F_FOR_DVIA10F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA10_EN_2 OPPOSITE 0 DVIA10_EN_2 OPPOSITE)
DVIA10F      = DVIA10F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA10F_pre5 DM11F_FOR_DVIA10F_REGION ABUT < 90 SINGULAR GOOD 0 DM11_EN_3 OPPOSITE 0 DM11_EN_3 OPPOSITE)

#ENDIF
#ENDIF
#ENDIF
