#ELSE
#IFDEF 2K_THICK_My_M2
#ELSE
#IFDEF 34K_THICK_Mu_M1
#ELSE
#IFDEF 12K_THICK_Mr_M1
#ELSE
#IFDEF 9K_THICK_Mz_M1
#ELSE
#IFDEF 5K_THICK_Myz_M1
#ELSE
#IFDEF 2_6K_THICK_Mxy_M1
#ELSE
#IFDEF 2K_THICK_My_M1
#ELSE




#IFDEF FILL_DM1
DM1F_FOR_DVIA1F_REGION = ((DM1F OR DUM1) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM1F_FOR_DVIA1F_REGION = (DUM1 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

#IFDEF FILL_DM2
DM2F_FOR_DVIA1F_REGION = ((DM2F OR DUM2) AND CHIP) NOT INDDMYx_BEOL
#ELSE
DM2F_FOR_DVIA1F_REGION = (DUM2 AND CHIP) NOT INDDMYx_BEOL
#ENDIF

// Find DVIA1 fillable regions.  Consider enclosure to lower DM1, enclosure to upper DM2, DVIA1 size.

VARIABLE DM1_F_4_REGION_DVIA1_SHORTENED_LENGTH DVIA1_EN_2 - DVIA1_EN_1

#IFDEF VERTICAL_DM1
DM1_F_4_REGION_DVIA1_spec_B_pre = RECTANGLE DM1F_FOR_DVIA1F_REGION == WM1_303_SLOT BY == LM1_303_SLOT
DM1_F_4_REGION_DVIA1_spec_B     = DM1_F_4_REGION_DVIA1_spec_B_pre NOT (EXPAND EDGE (LENGTH DM1_F_4_REGION_DVIA1_spec_B_pre == WM1_303_SLOT) INSIDE BY DM1_F_4_REGION_DVIA1_SHORTENED_LENGTH)

DM1_F_4_REGION_DVIA1_spec_M_pre = RECTANGLE DM1F_FOR_DVIA1F_REGION == WM1_302 BY == LM1_302
DM1_F_4_REGION_DVIA1_spec_M     = DM1_F_4_REGION_DVIA1_spec_M_pre NOT (EXPAND EDGE (LENGTH DM1_F_4_REGION_DVIA1_spec_M_pre == WM1_302) INSIDE BY DM1_F_4_REGION_DVIA1_SHORTENED_LENGTH)

DM1_F_4_REGION_DVIA1_spec_S_pre = RECTANGLE DM1F_FOR_DVIA1F_REGION == WM1_301 BY == LM1_301
DM1_F_4_REGION_DVIA1_spec_S     = DM1_F_4_REGION_DVIA1_spec_S_pre NOT (EXPAND EDGE (LENGTH DM1_F_4_REGION_DVIA1_spec_S_pre == WM1_301) INSIDE BY DM1_F_4_REGION_DVIA1_SHORTENED_LENGTH)
#ELSE
DM1_F_4_REGION_DVIA1_spec_B_pre = RECTANGLE DM1F_FOR_DVIA1F_REGION == LM1_303_SLOT BY == WM1_303_SLOT
DM1_F_4_REGION_DVIA1_spec_B     = DM1_F_4_REGION_DVIA1_spec_B_pre NOT (EXPAND EDGE (LENGTH DM1_F_4_REGION_DVIA1_spec_B_pre == LM1_303_SLOT) INSIDE BY DM1_F_4_REGION_DVIA1_SHORTENED_LENGTH)

DM1_F_4_REGION_DVIA1_spec_M_pre = RECTANGLE DM1F_FOR_DVIA1F_REGION == LM1_302 BY == WM1_302
DM1_F_4_REGION_DVIA1_spec_M     = DM1_F_4_REGION_DVIA1_spec_M_pre NOT (EXPAND EDGE (LENGTH DM1_F_4_REGION_DVIA1_spec_M_pre == LM1_302) INSIDE BY DM1_F_4_REGION_DVIA1_SHORTENED_LENGTH)

DM1_F_4_REGION_DVIA1_spec_S_pre = RECTANGLE DM1F_FOR_DVIA1F_REGION == LM1_301 BY == WM1_301
DM1_F_4_REGION_DVIA1_spec_S     = DM1_F_4_REGION_DVIA1_spec_S_pre NOT (EXPAND EDGE (LENGTH DM1_F_4_REGION_DVIA1_spec_S_pre == LM1_301) INSIDE BY DM1_F_4_REGION_DVIA1_SHORTENED_LENGTH)
#ENDIF
DM1_F_4_REGION_DVIA1_square_pre = RECTANGLE DM1F_FOR_DVIA1F_REGION ASPECT == 1
DM1_F_4_REGION_DVIA1_square     = SIZE DM1_F_4_REGION_DVIA1_square_pre BY -DM1_F_4_REGION_DVIA1_SHORTENED_LENGTH

DM1F_FOR_DVIA1F_REGION_4parts = (DM1_F_4_REGION_DVIA1_spec_B OR DM1_F_4_REGION_DVIA1_spec_M) OR (DM1_F_4_REGION_DVIA1_spec_S OR DM1_F_4_REGION_DVIA1_square)
DM1F_FOR_DVIA1F_REGION_remainder_pre_not = (DM1_F_4_REGION_DVIA1_spec_B_pre OR DM1_F_4_REGION_DVIA1_spec_M_pre) OR (DM1_F_4_REGION_DVIA1_spec_S_pre OR DM1_F_4_REGION_DVIA1_square_pre)
DM1F_FOR_DVIA1F_REGION_remainder = DM1F_FOR_DVIA1F_REGION NOT DM1F_FOR_DVIA1F_REGION_remainder_pre_not

    DM1F_FOR_DVIA1F_REGION_remainder_EDGE = LENGTH DM1F_FOR_DVIA1F_REGION_remainder > 0
    DM1F_FOR_DVIA1F_REGION_remainder_PROP = DFM PROPERTY DM1F_FOR_DVIA1F_REGION_remainder DM1F_FOR_DVIA1F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM1F_FOR_DVIA1F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM1F_FOR_DVIA1F_REGION_remainder_EDGE)) ]
    DM1F_FOR_DVIA1F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM1F_FOR_DVIA1F_REGION_remainder_EDGE DM1F_FOR_DVIA1F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM1F_FOR_DVIA1F_REGION_remainder_EDGE) - PROPERTY(DM1F_FOR_DVIA1F_REGION_remainder_PROP, DM1F_FOR_DVIA1F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM1F_FOR_DVIA1F_REGION2 = DM1F_FOR_DVIA1F_REGION_remainder NOT (EXPAND EDGE DM1F_FOR_DVIA1F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM1_F_4_REGION_DVIA1_SHORTENED_LENGTH)


VARIABLE DM2_F_4_REGION_DVIA1_SHORTENED_LENGTH DM2_EN_3 - DM2_EN_2

#IFDEF VERTICAL_DM2
DM2_F_4_REGION_DVIA1_spec_B_pre = RECTANGLE DM2F_FOR_DVIA1F_REGION == WM2_303_SLOT BY == LM2_303_SLOT
DM2_F_4_REGION_DVIA1_spec_B     = DM2_F_4_REGION_DVIA1_spec_B_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA1_spec_B_pre == WM2_303_SLOT) INSIDE BY DM2_F_4_REGION_DVIA1_SHORTENED_LENGTH)

DM2_F_4_REGION_DVIA1_spec_M_pre = RECTANGLE DM2F_FOR_DVIA1F_REGION == WM2_302 BY == LM2_302
DM2_F_4_REGION_DVIA1_spec_M     = DM2_F_4_REGION_DVIA1_spec_M_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA1_spec_M_pre == WM2_302) INSIDE BY DM2_F_4_REGION_DVIA1_SHORTENED_LENGTH)

DM2_F_4_REGION_DVIA1_spec_S_pre = RECTANGLE DM2F_FOR_DVIA1F_REGION == WM2_301 BY == LM2_301
DM2_F_4_REGION_DVIA1_spec_S     = DM2_F_4_REGION_DVIA1_spec_S_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA1_spec_S_pre == WM2_301) INSIDE BY DM2_F_4_REGION_DVIA1_SHORTENED_LENGTH)
#ELSE
DM2_F_4_REGION_DVIA1_spec_B_pre = RECTANGLE DM2F_FOR_DVIA1F_REGION == LM2_303_SLOT BY == WM2_303_SLOT
DM2_F_4_REGION_DVIA1_spec_B     = DM2_F_4_REGION_DVIA1_spec_B_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA1_spec_B_pre == LM2_303_SLOT) INSIDE BY DM2_F_4_REGION_DVIA1_SHORTENED_LENGTH)

DM2_F_4_REGION_DVIA1_spec_M_pre = RECTANGLE DM2F_FOR_DVIA1F_REGION == LM2_302 BY == WM2_302
DM2_F_4_REGION_DVIA1_spec_M     = DM2_F_4_REGION_DVIA1_spec_M_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA1_spec_M_pre == LM2_302) INSIDE BY DM2_F_4_REGION_DVIA1_SHORTENED_LENGTH)

DM2_F_4_REGION_DVIA1_spec_S_pre = RECTANGLE DM2F_FOR_DVIA1F_REGION == LM2_301 BY == WM2_301
DM2_F_4_REGION_DVIA1_spec_S     = DM2_F_4_REGION_DVIA1_spec_S_pre NOT (EXPAND EDGE (LENGTH DM2_F_4_REGION_DVIA1_spec_S_pre == LM2_301) INSIDE BY DM2_F_4_REGION_DVIA1_SHORTENED_LENGTH)
#ENDIF

DM2_F_4_REGION_DVIA1_square_pre = RECTANGLE DM2F_FOR_DVIA1F_REGION ASPECT == 1
DM2_F_4_REGION_DVIA1_square     = SIZE DM2_F_4_REGION_DVIA1_square_pre BY -DM2_F_4_REGION_DVIA1_SHORTENED_LENGTH

DM2F_FOR_DVIA1F_REGION_4parts = (DM2_F_4_REGION_DVIA1_spec_B OR DM2_F_4_REGION_DVIA1_spec_M) OR (DM2_F_4_REGION_DVIA1_spec_S OR DM2_F_4_REGION_DVIA1_square)
DM2F_FOR_DVIA1F_REGION_remainder_pre_not = (DM2_F_4_REGION_DVIA1_spec_B_pre OR DM2_F_4_REGION_DVIA1_spec_M_pre) OR (DM2_F_4_REGION_DVIA1_spec_S_pre OR DM2_F_4_REGION_DVIA1_square_pre)
DM2F_FOR_DVIA1F_REGION_remainder = DM2F_FOR_DVIA1F_REGION NOT DM2F_FOR_DVIA1F_REGION_remainder_pre_not

    DM2F_FOR_DVIA1F_REGION_remainder_EDGE = LENGTH DM2F_FOR_DVIA1F_REGION_remainder > 0
    DM2F_FOR_DVIA1F_REGION_remainder_PROP = DFM PROPERTY DM2F_FOR_DVIA1F_REGION_remainder DM2F_FOR_DVIA1F_REGION_remainder_EDGE OVERLAP ABUT ALSO MULTI
        [ DM2F_FOR_DVIA1F_REGION_remainder_EDGE_MAX_LEN = MAX(LENGTH(DM2F_FOR_DVIA1F_REGION_remainder_EDGE)) ]
    DM2F_FOR_DVIA1F_REGION_remainder_NON_LONGEST_EDGE = DFM PROPERTY DM2F_FOR_DVIA1F_REGION_remainder_EDGE DM2F_FOR_DVIA1F_REGION_remainder_PROP OVERLAP ABUT ALSO MULTI
        [ -= LENGTH(DM2F_FOR_DVIA1F_REGION_remainder_EDGE) - PROPERTY(DM2F_FOR_DVIA1F_REGION_remainder_PROP, DM2F_FOR_DVIA1F_REGION_remainder_EDGE_MAX_LEN) ] < 0
    DM2F_FOR_DVIA1F_REGION2 = DM2F_FOR_DVIA1F_REGION_remainder NOT (EXPAND EDGE DM2F_FOR_DVIA1F_REGION_remainder_NON_LONGEST_EDGE INSIDE BY DM2_F_4_REGION_DVIA1_SHORTENED_LENGTH)

DVIA1F_BASE_REGION = (((((SIZE (DM1F_FOR_DVIA1F_REGION2 OR DM1F_FOR_DVIA1F_REGION_4parts) BY -DVIA1_EN_1) AND (SIZE (DM2F_FOR_DVIA1F_REGION2 OR DM2F_FOR_DVIA1F_REGION_4parts) BY -DM2_EN_2)) WITH WIDTH >= DVIA1_W_1) NOT (SIZE DVIA1EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA1i BY (DVIA1_S_1 + grid))) NOT (SIZE VIA1i BY (DVIA1_S_2 + grid))




// Merge DVIA1 fillable regions, and find DVIA1 seeds by maintaining spacing DVIA1_S_1.
DVIA1F_SEED_REGION_1 = (((SIZE DVIA1F_BASE_REGION BY DVIA1F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA1EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA1i BY (DVIA1_S_1 + grid))) NOT (SIZE VIA1i BY (DVIA1_S_2 + grid))
DVIA1F_SEED_1 = RECTANGLES DVIA1_W_1 DVIA1_W_1 DVIA1_S_1 INSIDE OF LAYER DVIA1F_SEED_REGION_1

// Find DVIA1 in the DVIA1 fillable and spacing-maintained regions.
DVIA1F_REGION_1 = (DVIA1F_BASE_REGION INTERACT DVIA1F_SEED_1) NOT TOUCH DVIA1F_SEED_1
DVIA1F_pre1_1_pre1 = RECTANGLES DVIA1_W_1 DVIA1_W_1 DVIA1_S_1 INSIDE OF LAYER DVIA1F_REGION_1

// post-DRC
DVIA1F_pre1_1_pre2 = DVIA1F_pre1_1_pre1 NOT INTERACT (EXT DVIA1F_pre1_1_pre1 < DVIA1_S_1 ABUT SINGULAR REGION)
DVIA1F_pre1_1_pre3 = DVIA1F_pre1_1_pre2 NOT INTERACT (EXT DVIA1F_pre1_1_pre2 DUVIA1i < DVIA1_S_1 ABUT SINGULAR REGION)
DVIA1F_pre1_1_pre4 = DVIA1F_pre1_1_pre3 NOT INTERACT (EXT DVIA1F_pre1_1_pre3 VIA1i < DVIA1_S_2 ABUT SINGULAR REGION)
DVIA1F_pre1_1_pre5 = DVIA1F_pre1_1_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA1F_pre1_1_pre4 DM1F_FOR_DVIA1F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA1_EN_2 OPPOSITE 0 DVIA1_EN_2 OPPOSITE)
DVIA1F_pre1_1      = DVIA1F_pre1_1_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA1F_pre1_1_pre5 DM2F_FOR_DVIA1F_REGION ABUT < 90 SINGULAR GOOD 0 DM2_EN_3 OPPOSITE 0 DM2_EN_3 OPPOSITE)

// Merge DVIA1 fillable regions, and find DVIA1 seeds by maintaining spacing DVIA1_S_1.
DVIA1F_SEED_REGION_2 = (((SIZE (DVIA1F_BASE_REGION NOT INTERACT (SIZE DVIA1F_pre1_1 BY DVIA1_S_1)) BY DVIA1F_BASE_S/2 OVERUNDER) NOT (SIZE DVIA1EXCL BY (dm2DVIAEXCL + grid))) NOT (SIZE DUVIA1i BY (DVIA1_S_1 + grid))) NOT (SIZE VIA1i BY (DVIA1_S_2 + grid))
DVIA1F_SEED_2 = RECTANGLES DVIA1_W_1 DVIA1_W_1 DVIA1_S_1 INSIDE OF LAYER DVIA1F_SEED_REGION_2

// Find DVIA1 in the DVIA1 fillable and spacing-maintained regions.
DVIA1F_REGION_2 = (DVIA1F_BASE_REGION INTERACT DVIA1F_SEED_2) NOT TOUCH DVIA1F_SEED_2
DVIA1F_pre1_2 = RECTANGLES DVIA1_W_1 DVIA1_W_1 DVIA1_S_1 INSIDE OF LAYER DVIA1F_REGION_2

// post-DRC
DVIA1F_pre1 = DVIA1F_pre1_1 OR DVIA1F_pre1_2
DVIA1F_pre2 = DVIA1F_pre1 NOT INTERACT (EXT DVIA1F_pre1 < DVIA1_S_1 ABUT SINGULAR REGION)
DVIA1F_pre3 = DVIA1F_pre2 NOT INTERACT (EXT DVIA1F_pre2 DUVIA1i < DVIA1_S_1 ABUT SINGULAR REGION)
DVIA1F_pre4 = DVIA1F_pre3 NOT INTERACT (EXT DVIA1F_pre3 VIA1i < DVIA1_S_2 ABUT SINGULAR REGION)
DVIA1F_pre5 = DVIA1F_pre4 NOT INTERACT (RECTANGLE ENCLOSURE DVIA1F_pre4 DM1F_FOR_DVIA1F_REGION ABUT < 90 SINGULAR GOOD 0 DVIA1_EN_2 OPPOSITE 0 DVIA1_EN_2 OPPOSITE)
DVIA1F      = DVIA1F_pre5 NOT INTERACT (RECTANGLE ENCLOSURE DVIA1F_pre5 DM2F_FOR_DVIA1F_REGION ABUT < 90 SINGULAR GOOD 0 DM2_EN_3 OPPOSITE 0 DM2_EN_3 OPPOSITE)

#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF
#ENDIF


#IFDEF 34K_THICK_Mu_M3
