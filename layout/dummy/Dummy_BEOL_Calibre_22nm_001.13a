DM8_F_4_REGION_DVIA8_spec_S     = DM8_F_4_REGION_DVIA8_spec_S_pre NOT (EXPAND EDGE (LENGTH DM8_F_4_REGION_DVIA8_spec_S_pre == LM8_301) INSIDE BY DM8_F_4_REGION_DVIA8_SHORTENED_LENGTH)
