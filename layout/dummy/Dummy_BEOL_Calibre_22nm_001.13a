//***********************************************************************************************************
// begin generation process : filling pattern
//***********************************************************************************************************

#IFDEF FILL_DM1


#IFDEF 34K_THICK_Mu_M1

    minOPENM1 = DENSITY M1x < minD_M1 WINDOW WindowSizeu STEP WindowStepu
                INSIDE OF LAYER bulk BACKUP // PRINT M1Min.den
    emptyOPENM1 = DENSITY M1x < emptyD_M1 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M1Empty.den

    M1InnerHole = HOLES M1i INNER

    M1BigHole = SIZE M1InnerHole BY - excludeHoleSize/2
    M1ExcHole = ((M1InnerHole OUTSIDE M1BigHole) NOT M1i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY) 
    BLOCK1    = (SIZE DM1EXCL BY (dm2DMEXCL + grid)) OR MIM1_x
    FRAMEA1   = SIZE M1i BY (dm2M1 + grid) // DM1 to metal
    FRAMEB1   = SIZE (WITH WIDTH M1i > wideM1) BY (dm2WM1 + grid)
    FRAMEC1   = SIZE DUM1 BY (dm2DM1 + grid)
    FRAME1Pre = ((FRAMEA1 OR FRAMEB1) OR FRAMEC1) OR M1ExcHole
    FRAME1INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm1_s2m1_INDDMY + grid)
    FRAME1 = ((FRAME1Pre OR FRAME1INDDMY) OR BLOCK1) OR NFILL
    
    OPENM1 = PUSH ((minOPENM1 OR emptyOPENM1) AND CHIP)
    FILL1 = OPENM1 NOT FRAME1
    FILLW1pre = SIZE FILL1 BY - (Wdm2M1 + grid)
    FILLW1 = WITH WIDTH FILLW1pre >= WdmW_M1
    M1FW = RECTANGLES WdmW_M1 WdmL_M1 WdmS_M1 OFFSET WdmO_M1 INSIDE OF LAYER FILLW1
    M1FW_EXP = SIZE M1FW BY (WdmS_M1 /2 + grid) OVERUNDER   // merge the gaps
    FILLM1pre = FILL1 NOT (SIZE M1FW_EXP BY (MdmS_M1 + grid))
    FILLM1 = WITH WIDTH FILLM1pre >= MdmW_M1
    M1F1 = RECTANGLES MdmW_M1 MdmL_M1 MdmS_M1 OFFSET MdmO_M1 INSIDE OF LAYER FILLM1
    M1R1pre = FILLM1pre NOT (SIZE M1F1 BY (dmS_M1 + grid))
    M1R1 = WITH WIDTH M1R1pre >= dmW_M1

    M1F2 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 OFFSET dmO_M1 INSIDE OF LAYER M1R1
    M1R2pre = M1R1 NOT (SIZE M1F2 BY (dmS_M1 + grid))
    M1R2 = WITH WIDTH M1R2pre >= dmW_M1

    M1F3 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 OFFSET dmO_M1 INSIDE OF LAYER M1R2
    M1R3pre = M1R2 NOT (SIZE M1F3 BY (dmS_M1 + grid))
    M1R3 = WITH WIDTH M1R3pre >= dmW_M1

    M1F4 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 INSIDE OF LAYER M1R3

    M1F = (((M1F1 OR M1F2) OR M1F3) OR M1F4) OR M1FW
    FM1 = M1F NOT INTERACT (EXT M1F < dmS_M1 ABUT SINGULAR REGION)

    maxOPENM1 = DENSITY M1x FM1 > maxD_M1 WINDOW WindowSizeu*2 STEP WindowStepu*2
                INSIDE OF LAYER bulk BACKUP // PRINT M1Max.den

    DM1F = FM1 OUTSIDE maxOPENM1

    FRAME1_INDDMYA = SIZE M1i BY (dm1_s2m1_INDDMY + grid)
    FRAME1_INDDMYB = SIZE DUM1 BY (dm1_s_INDDMY + grid)
    FRAME1_INDDMYC = SIZE DM1F BY dm1_s_INDDMY
    FRAME1_INDDMY  = ((((FRAME1Pre OR BLOCK1) OR FRAME1_INDDMYA) OR FRAME1_INDDMYB) OR FRAME1_INDDMYC) OR NFILL
    FILL1_INDDMY   = ooINDDMY NOT FRAME1_INDDMY
    DM1F_INDDMY    = RECTANGLES dm1_w_INDDMY dm1_l_INDDMY dm1_s_INDDMY INSIDE OF LAYER FILL1_INDDMY
#IFDEF FILL_indDM1
    FILL1_INDDMY_HD = (SIZE INDDMY_HD BY -(dm1_s_INDDMY_HD + grid)) NOT FRAME1_INDDMY
    DM1F_INDDMY_HD  = RECTANGLES dm1_w_INDDMY_HD dm1_l_INDDMY_HD dm1_s_INDDMY_HD INSIDE OF LAYER FILL1_INDDMY_HD
#ENDIF	
	
#ELSE


#IFDEF 12K_THICK_Mr_M1

    minOPENM1 = DENSITY M1x < minD_M1 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M1Min.den
    emptyOPENM1 = DENSITY M1x < emptyD_M1 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M1Empty.den

    M1InnerHole = HOLES M1i INNER

    M1BigHole = SIZE M1InnerHole BY - excludeHoleSize/2
    M1ExcHole = ((M1InnerHole OUTSIDE M1BigHole) NOT M1i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK1  = (SIZE DM1EXCL BY (dm2DMEXCL + grid)) OR MIM1_x // DM1 to DM1EXCL
    FRAMEA1 = SIZE M1i BY (dm2M1 + grid) // DM1 to metal
    FRAMEB1 = SIZE (WITH WIDTH M1i > wideM1) BY (dm2WM1 + grid)
    FRAMEC1 = SIZE DUM1 BY (dm2DM1 + grid)   // DM1 to existed dummy metal 0.6um
    FRAME1Pre = ((FRAMEA1 OR FRAMEB1) OR FRAMEC1) OR M1ExcHole
    FRAME1INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm1_s2m1_INDDMY + grid)
    FRAME1 = ((FRAME1Pre OR FRAME1INDDMY) OR BLOCK1) OR NFILL
    
    OPENM1 = PUSH ((minOPENM1 OR emptyOPENM1) AND CHIP)
    FILL1 = OPENM1 NOT FRAME1
    FILLW1pre = SIZE FILL1 BY - (Wdm2M1 + grid)
    FILLW1 = WITH WIDTH FILLW1pre >= WdmW_M1
    M1FW = RECTANGLES WdmW_M1 WdmL_M1 WdmS_M1 OFFSET WdmO_M1 INSIDE OF LAYER FILLW1
    M1FW_EXP = SIZE M1FW BY (WdmS_M1 /2 + grid) OVERUNDER //merge the gaps
    FILLM1pre = FILL1 NOT (SIZE M1FW_EXP BY (MdmS_M1 + grid))
    FILLM1 = WITH WIDTH FILLM1pre >= MdmW_M1
    M1F1 = RECTANGLES MdmW_M1 MdmL_M1 MdmS_M1 OFFSET MdmO_M1 INSIDE OF LAYER FILLM1
    M1R1pre = FILLM1pre NOT (SIZE M1F1 BY (dmS_M1 + grid))
    M1R1 = WITH WIDTH M1R1pre >= dmW_M1

    M1F2 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 OFFSET dmO_M1 INSIDE OF LAYER M1R1
    M1R2pre = M1R1 NOT (SIZE M1F2 BY (dmS_M1 + grid))
    M1R2 = WITH WIDTH M1R2pre >= dmW_M1

    M1F3 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 OFFSET dmO_M1 INSIDE OF LAYER M1R2
    M1R3pre = M1R2 NOT (SIZE M1F3 BY (dmS_M1 + grid))
    M1R3 = WITH WIDTH M1R3pre >= dmW_M1

    M1F4 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 INSIDE OF LAYER M1R3

    M1F = (((M1F1 OR M1F2) OR M1F3) OR M1F4) OR M1FW
    FM1 = M1F NOT INTERACT (EXT M1F < dmS_M1 ABUT SINGULAR REGION)

    maxOPENM1 = DENSITY M1x FM1 > maxD_M1 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M1Max.den

    FM1F = FM1 OUTSIDE maxOPENM1

    // DMr_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M1 = DENSITY M1x FM1F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M1Min.den

    RM1EXC = SIZE FM1F BY (Odm2DM1 + grid)
    // do not fill DMy_S over CTMDMY
    D25M1pM = (((PUSH D25M1) NOT FRAME1) NOT RM1EXC) AND CHIP
    D25M1pM_1 = WITH WIDTH D25M1pM >= OdmW_M1

    RM1p1 = RECTANGLES OdmW_M1 OdmL_M1 OdmS_M1 INSIDE OF LAYER D25M1pM_1
    D25M1pM_2 = D25M1pM_1 NOT (SIZE RM1p1 BY (OdmS_M1 + grid))
    RM1p2 = RECTANGLES OdmL_M1 OdmW_M1 OdmS_M1 INSIDE OF LAYER D25M1pM_2

    RM1A = ((RM1p1 OR RM1p2) OUTSIDE RM1EXC) OUTSIDE FRAME1
    RM1  = RM1A NOT INTERACT (EXT RM1A < OdmS_M1 ABUT SINGULAR REGION)

    DM1F = FM1F OR RM1

    FRAME1_INDDMYA = SIZE M1i BY (dm1_s2m1_INDDMY + grid)
    FRAME1_INDDMYB = SIZE DUM1 BY (dm1_s_INDDMY + grid)
    FRAME1_INDDMYC = SIZE DM1F BY dm1_s_INDDMY
    FRAME1_INDDMY  = ((((FRAME1Pre OR BLOCK1) OR FRAME1_INDDMYA) OR FRAME1_INDDMYB) OR FRAME1_INDDMYC) OR NFILL
    FILL1_INDDMY   = ooINDDMY NOT FRAME1_INDDMY
    DM1F_INDDMY    = RECTANGLES dm1_w_INDDMY dm1_l_INDDMY dm1_s_INDDMY INSIDE OF LAYER FILL1_INDDMY

#IFDEF FILL_indDM1
    FILL1_INDDMY_HD = (SIZE INDDMY_HD BY -(dm1_s_INDDMY_HD + grid)) NOT FRAME1_INDDMY
    DM1F_INDDMY_HD  = RECTANGLES dm1_w_INDDMY_HD dm1_l_INDDMY_HD dm1_s_INDDMY_HD INSIDE OF LAYER FILL1_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 5K_THICK_Myz_M1

    minOPENM1 = DENSITY M1x < minD_M1 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M1Min.den
    emptyOPENM1 = DENSITY M1x < emptyD_M1 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M1Empty.den

    M1InnerHole = HOLES M1i INNER

    M1BigHole = SIZE M1InnerHole BY - excludeHoleSize/2
    M1ExcHole = ((M1InnerHole OUTSIDE M1BigHole) NOT M1i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK1 = (SIZE DM1EXCL BY (dm2DMEXCL + grid)) OR MIM1_x // DM1 to DM1EXCL
    FRAMEA1 = SIZE M1i BY (dm2M1 + grid) // DM1 to metal
    FRAMEB1 = SIZE (WITH WIDTH M1i > wideM1) BY (dm2WM1 + grid)
    FRAMEC1 = SIZE DUM1 BY (dm2DM1 + grid)   // DM1 to existed dummy metal 0.6um
    FRAME1Pre = ((FRAMEA1 OR FRAMEB1) OR FRAMEC1) OR M1ExcHole
    FRAME1INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm1_s2m1_INDDMY + grid)
    FRAME1 = ((FRAME1Pre OR FRAME1INDDMY) OR BLOCK1) OR NFILL
    
    OPENM1 = PUSH ((minOPENM1 OR emptyOPENM1) AND CHIP)
    FILL1 = OPENM1 NOT FRAME1
    FILLW1pre = SIZE FILL1 BY - (Wdm2M1 + grid)
    FILLW1 = WITH WIDTH FILLW1pre >= WdmW_M1
    M1FW = RECTANGLES WdmW_M1 WdmL_M1 WdmS_M1 OFFSET WdmO_M1 INSIDE OF LAYER FILLW1
    M1FW_EXP = SIZE M1FW BY (WdmS_M1 /2 + grid) OVERUNDER //merge the gaps
    FILLM1pre = FILL1 NOT (SIZE M1FW_EXP BY (MdmS_M1 + grid))
    FILLM1 = WITH WIDTH FILLM1pre >= MdmW_M1
    M1F1 = RECTANGLES MdmW_M1 MdmL_M1 MdmS_M1 OFFSET MdmO_M1 INSIDE OF LAYER FILLM1
    M1R1pre = FILLM1pre NOT (SIZE M1F1 BY (dmS_M1 + grid))
    M1R1 = WITH WIDTH M1R1pre >= dmW_M1

    M1F2 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 OFFSET dmO_M1 INSIDE OF LAYER M1R1
    M1R2pre = M1R1 NOT (SIZE M1F2 BY (dmS_M1 + grid))
    M1R2 = WITH WIDTH M1R2pre >= dmW_M1

    M1F3 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 OFFSET dmO_M1 INSIDE OF LAYER M1R2
    M1R3pre = M1R2 NOT (SIZE M1F3 BY (dmS_M1 + grid))
    M1R3 = WITH WIDTH M1R3pre >= dmW_M1

    M1F4 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 INSIDE OF LAYER M1R3

    M1F = (((M1F1 OR M1F2) OR M1F3) OR M1F4) OR M1FW
    FM1 = M1F NOT INTERACT (EXT M1F < dmS_M1 ABUT SINGULAR REGION)

    maxOPENM1 = DENSITY M1x FM1 > maxD_M1 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M1Max.den

    FM1F = FM1 OUTSIDE maxOPENM1

    // DMy_S is to enhance the fill in the region of density < 20%, rule value = 10%
    D25M1 = DENSITY M1x FM1F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M1Min.den

    RM1EXC = SIZE FM1F BY (Odm2DM1 + grid)
    // do not fill DMy_S over CTMDMY
    D25M1pM = (((PUSH D25M1) NOT FRAME1) NOT RM1EXC) AND CHIP
    D25M1pM_1 = WITH WIDTH D25M1pM >= OdmW_M1

    RM1p1 = RECTANGLES OdmW_M1 OdmL_M1 OdmS_M1 INSIDE OF LAYER D25M1pM_1
    D25M1pM_2 = D25M1pM_1 NOT (SIZE RM1p1 BY (OdmS_M1 + grid))
    RM1p2 = RECTANGLES OdmL_M1 OdmW_M1 OdmS_M1 INSIDE OF LAYER D25M1pM_2

    RM1A = ((RM1p1 OR RM1p2) OUTSIDE RM1EXC) OUTSIDE FRAME1
    RM1  = RM1A NOT INTERACT (EXT RM1A < OdmS_M1 ABUT SINGULAR REGION)

    DM1F = FM1F OR RM1

    FRAME1_INDDMYA = SIZE M1i BY (dm1_s2m1_INDDMY + grid)
    FRAME1_INDDMYB = SIZE DUM1 BY (dm1_s_INDDMY + grid)
    FRAME1_INDDMYC = SIZE DM1F BY dm1_s_INDDMY
    FRAME1_INDDMY  = ((((FRAME1Pre OR BLOCK1) OR FRAME1_INDDMYA) OR FRAME1_INDDMYB) OR FRAME1_INDDMYC) OR NFILL
    FILL1_INDDMY   = ooINDDMY NOT FRAME1_INDDMY
    DM1F_INDDMY    = RECTANGLES dm1_w_INDDMY dm1_l_INDDMY dm1_s_INDDMY INSIDE OF LAYER FILL1_INDDMY


#IFDEF FILL_indDM1
    FILL1_INDDMY_HD = (SIZE INDDMY_HD BY -(dm1_s_INDDMY_HD + grid)) NOT FRAME1_INDDMY
    DM1F_INDDMY_HD  = RECTANGLES dm1_w_INDDMY_HD dm1_l_INDDMY_HD dm1_s_INDDMY_HD INSIDE OF LAYER FILL1_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2_6K_THICK_Mxy_M1

    minOPENM1 = DENSITY M1x < minD_M1 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M1Min.den
    emptyOPENM1 = DENSITY M1x < emptyD_M1 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M1Empty.den

    M1InnerHole = HOLES M1i INNER

    M1BigHole = SIZE M1InnerHole BY - excludeHoleSize/2
    M1ExcHole = ((M1InnerHole OUTSIDE M1BigHole) NOT M1i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK1 = (SIZE DM1EXCL BY (dm2DMEXCL + grid)) OR  MIM1_x // DM1 to DM1EXCL
    FRAMEA1 = SIZE M1i BY (dm2M1 + grid) // DM1 to metal
    FRAMEB1 = SIZE (WITH WIDTH M1i > wideM1) BY (dm2WM1 + grid)
    FRAMEC1 = SIZE DUM1 BY (dm2DM1 + grid)   // DM1 to existed dummy metal 0.6um
    FRAME1Pre = ((FRAMEA1 OR FRAMEB1) OR FRAMEC1) OR M1ExcHole
    FRAME1INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm1_s2m1_INDDMY + grid)
    FRAME1 = ((FRAME1Pre OR FRAME1INDDMY) OR BLOCK1) OR NFILL
    
    OPENM1 = PUSH ((minOPENM1 OR emptyOPENM1) AND CHIP)
    FILL1 = OPENM1 NOT FRAME1
    FILLW1pre = SIZE FILL1 BY - (Wdm2M1 + grid)
    FILLW1 = WITH WIDTH FILLW1pre >= WdmW_M1
    M1FW = RECTANGLES WdmW_M1 WdmL_M1 WdmS_M1 OFFSET WdmO_M1 INSIDE OF LAYER FILLW1
    M1FW_EXP = SIZE M1FW BY (WdmS_M1 /2 + grid) OVERUNDER //merge the gaps
    FILLM1pre = FILL1 NOT (SIZE M1FW_EXP BY (MdmS_M1 + grid))
    FILLM1 = WITH WIDTH FILLM1pre >= MdmW_M1
    M1F1 = RECTANGLES MdmW_M1 MdmL_M1 MdmS_M1 OFFSET MdmO_M1 INSIDE OF LAYER FILLM1
    M1R1pre = FILLM1pre NOT (SIZE M1F1 BY (dmS_M1 + grid))
    M1R1 = WITH WIDTH M1R1pre >= dmW_M1

    M1F2 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 OFFSET dmO_M1 INSIDE OF LAYER M1R1
    M1R2pre = M1R1 NOT (SIZE M1F2 BY (dmS_M1 + grid))
    M1R2 = WITH WIDTH M1R2pre >= dmW_M1

    M1F3 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 OFFSET dmO_M1 INSIDE OF LAYER M1R2
    M1R3pre = M1R2 NOT (SIZE M1F3 BY (dmS_M1 + grid))
    M1R3 = WITH WIDTH M1R3pre >= dmW_M1

    M1F4 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 INSIDE OF LAYER M1R3

    M1F = (((M1F1 OR M1F2) OR M1F3) OR M1F4) OR M1FW
    FM1 = M1F NOT INTERACT (EXT M1F < dmS_M1 ABUT SINGULAR REGION)

    maxOPENM1 = DENSITY M1x FM1 > maxD_M1 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M1Max.den

    FM1F = FM1 OUTSIDE maxOPENM1

    D25M1 = DENSITY M1x FM1F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M1Min.den

    RM1EXC = SIZE FM1F BY (Odm2DM1 + grid)
    D25M1pM = (((PUSH D25M1) NOT FRAME1) NOT RM1EXC) AND CHIP
    D25M1pM_1 = WITH WIDTH D25M1pM >= OdmW_M1

    RM1p1 = RECTANGLES OdmW_M1 OdmL_M1 OdmS_M1 INSIDE OF LAYER D25M1pM_1
    D25M1pM_2 = D25M1pM_1 NOT (SIZE RM1p1 BY (OdmS_M1 + grid))
    RM1p2 = RECTANGLES OdmL_M1 OdmW_M1 OdmS_M1 INSIDE OF LAYER D25M1pM_2

    RM1A = ((RM1p1 OR RM1p2) OUTSIDE RM1EXC) OUTSIDE FRAME1
    RM1  = RM1A NOT INTERACT (EXT RM1A < OdmS_M1 ABUT SINGULAR REGION)

    DM1F = FM1F OR RM1

    FRAME1_INDDMYA = SIZE M1i BY (dm1_s2m1_INDDMY + grid)
    FRAME1_INDDMYB = SIZE DUM1 BY (dm1_s_INDDMY + grid)
    FRAME1_INDDMYC = SIZE DM1F BY dm1_s_INDDMY
    FRAME1_INDDMY  = ((((FRAME1Pre OR BLOCK1) OR FRAME1_INDDMYA) OR FRAME1_INDDMYB) OR FRAME1_INDDMYC) OR NFILL
    FILL1_INDDMY   = ooINDDMY NOT FRAME1_INDDMY
    DM1F_INDDMY    = RECTANGLES dm1_w_INDDMY dm1_l_INDDMY dm1_s_INDDMY INSIDE OF LAYER FILL1_INDDMY

#IFDEF FILL_indDM1
    FILL1_INDDMY_HD = (SIZE INDDMY_HD BY -(dm1_s_INDDMY_HD + grid)) NOT FRAME1_INDDMY
    DM1F_INDDMY_HD  = RECTANGLES dm1_w_INDDMY_HD dm1_l_INDDMY_HD dm1_s_INDDMY_HD INSIDE OF LAYER FILL1_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 2K_THICK_My_M1

    D30M1 = DENSITY M1x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M1.den30
    D40M1 = DENSITY M1x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M1.den40
    D50M1 = DENSITY M1x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M1.den50
    emptyM1 = DENSITY M1x < emptyD_M1 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M1.den_empty

    M1InnerHole = HOLES M1i INNER

    M1BigHole = SIZE M1InnerHole BY - excludeHoleSize/2
    M1ExcHole = ((M1InnerHole OUTSIDE M1BigHole) NOT M1i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)

    BLOCK1 = (SIZE DM1EXCL BY (dm2DMEXCL + grid)) OR MIM1_x

    FRAMEA1 = (SIZE M1i BY (DM1_301 + grid)) OR (SIZE (EXPAND EDGE (M1i ANGLE == 45) OUTSIDE BY dm2bentMetal EXTEND BY dm2bentMn_E) BY grid)

    FRAMEA1OPC = SIZE M1i BY (DM1_OPC + grid)
    FRAMEA1OPCDV33 = SIZE (M1i INTERACT M1_HVN_330Vx) BY (M1_S_1_1_a + grid)
    FRAMEA1OPCDV5 = SIZE (M1i INTERACT M1_HVN_500Vx) BY (M1_S_9_a + grid)
    FRAMEA1OPC45 = SIZE (EXPAND EDGE (M1i ANGLE == 45) OUTSIDE BY DM1_OPC_45 EXTEND BY DM1_OPC_45_E) BY grid
    FRAMEA1OPC45DV = SIZE (EXPAND EDGE ((M1i INTERACT M1_HVN_500Vx) ANGLE == 45) OUTSIDE BY DM1_OPC_45 EXTEND BY DM1_OPC_45_E) BY grid

    FRAMEB1 = SIZE (WITH WIDTH M1i > wideM1) BY (dm2WM1 + grid)
    FRAMEC1 = SIZE DUM1 BY (dm2DM1 + grid)
    FRAMED1 = SIZE (WITH WIDTH M1i > wideM1_small) BY (dm2WM1_small + grid)
    FRAMEC1OPC = SIZE DUM1 BY (Odm2DM1 + grid)
    FRAME1Pre = ((FRAMEA1 OR FRAMEB1) OR (FRAMEC1 OR FRAMED1)) OR M1ExcHole
    FRAME1PreOPC = (((((((FRAMEA1OPC OR FRAMEA1OPCDV33) OR FRAMEA1OPCDV5) OR FRAMEC1OPC) OR M1ExcHole) OR FRAMEA1OPC45) OR FRAMEA1OPC45DV) OR FRAMEB1) OR FRAMED1
    FRAME1INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm1_s2m1_INDDMY + grid)

    FRAME1OPC = (((FRAME1PreOPC OR FRAME1INDDMY) OR BLOCK1) OR NFILLOPC) OR FUSELINKx

    FRAME1 = (((FRAME1Pre OR FRAME1INDDMY) OR BLOCK1) OR NFILL) OR FUSELINKx

    //****************************************************************************

    D30M1p = (PUSH D30M1) NOT FRAME1
    O30M1pre = D30M1p AND CHIP
    FD21M1s = COPY FRAME1

    O30M1preA = SIZE O30M1pre BY -DM1_303
    O30M1preB = O30M1preA WITH WIDTH >= WM1_303

    // 1st big
    F303M1 = RECTANGLES WM1_303 LM1_303 SM1_303 OFFSET OM1_303 INSIDE OF LAYER O30M1preB

    F303M1_EXP = SIZE F303M1 BY ( SM1_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M1preF1 = O30M1pre NOT (SIZE F303M1_EXP BY SM1_302)
    O30M1preF  = (SNAP (SIZE O30M1preF1 BY -grid) 5) AND O30M1preF1

    B30M1s = FD21M1s OR (SIZE F303M1_EXP BY (SM1_302+grid))
    O30M1 = O30M1preF NOT B30M1s

    // 3rd, middle
    F302M1 = RECTANGLES WM1_302 LM1_302 SM1_302 OFFSET OM1_302 INSIDE OF LAYER O30M1
    F302M1s = (SIZE F302M1 BY (SM1_301 + grid)) OR B30M1s
    R302M1pre = O30M1 NOT F302M1s
    R302M1 = WITH WIDTH R302M1pre >= WM1_301

    // 4th, small
    F3012M1 = RECTANGLES WM1_301 LM1_301 SM1_301 OFFSET OM1_301 INSIDE OF LAYER R302M1
    F3012M1s = (SIZE F3012M1 BY (SM1_301 + grid)) OR F302M1s
    R3012M1pre = R302M1pre NOT F3012M1s
    R3012M1 = WITH WIDTH R3012M1pre >= WM1_301

    // 5th, non-stagger small
    F301M1 = RECTANGLES WM1_301 LM1_301 SM1_301 INSIDE OF LAYER R3012M1 //MAINTAIN SPACING
    F301M1s = (SIZE F301M1 BY (SM1_301 + grid)) OR F3012M1s

    F30M1 = ((F302M1 OR F3012M1) OR F301M1) OR F303M1
    O40M1pre = (((PUSH D40M1) NOT FRAME1) NOT F301M1s) AND CHIP


    O40M1preA = SIZE O40M1pre BY -DM1_403
    O40M1preB = O40M1preA WITH WIDTH >= WM1_403

    // 1st big
    F403M1 = RECTANGLES WM1_403 LM1_403 SM1_403 OFFSET OM1_403 INSIDE OF LAYER O40M1preB

    F403M1_EXP = SIZE F403M1 BY ( SM1_403 / 2 + grid ) OVERUNDER   // merge the gaps
    O40M1preF1 = O40M1pre NOT (SIZE F403M1_EXP BY SM1_402)
    O40M1preF  = (SNAP (SIZE O40M1preF1 BY -grid) 5) AND O40M1preF1

    B40M1s = F301M1s OR (SIZE F403M1_EXP BY (SM1_402+grid))
    O40M1 = O40M1preF NOT B40M1s

    // 3rd, middle
    F402M1 = RECTANGLES WM1_402 LM1_402 SM1_402 OFFSET OM1_402 INSIDE OF LAYER O40M1
    F402M1s = (SIZE F402M1 BY (SM1_401 + grid)) OR B40M1s
    R402M1pre = O40M1 NOT F402M1s
    R402M1 = WITH WIDTH R402M1pre >= WM1_401

    // 4th, small
    F4012M1 = RECTANGLES WM1_401 LM1_401 SM1_401 OFFSET OM1_401 INSIDE OF LAYER R402M1
    F4012M1s = (SIZE F4012M1 BY (SM1_401 + grid)) OR F402M1s
    R4012M1pre = R402M1pre NOT F4012M1s
    R4012M1 = WITH WIDTH R4012M1pre >= WM1_401

    // 5th, non-stagger small
    F401M1 = RECTANGLES WM1_401 LM1_401 SM1_401 INSIDE OF LAYER R4012M1 //MAINTAIN SPACING
    F401M1s = (SIZE F401M1 BY (SM1_401 + grid)) OR F4012M1s

    F40M1 = ((F402M1 OR F4012M1) OR F401M1) OR F403M1
    O50M1pre = (((PUSH (D50M1 OR emptyM1)) NOT FRAME1) NOT F401M1s) AND CHIP


    O50M1preA = SIZE O50M1pre BY -DM1_503
    O50M1preB = O50M1preA WITH WIDTH >= WM1_503

    // 1st big
    F503M1 = RECTANGLES WM1_503 LM1_503 SM1_503 OFFSET OM1_503 INSIDE OF LAYER O50M1preB

    F503M1_EXP = SIZE F503M1 BY ( SM1_503 / 2 + grid ) OVERUNDER   // merge the gaps
    O50M1preF1 = O50M1pre NOT (SIZE F503M1_EXP BY SM1_502)
    O50M1preF  = (SNAP (SIZE O50M1preF1 BY -grid) 5) AND O50M1preF1

    B50M1s = F401M1s OR (SIZE F503M1_EXP BY (SM1_502+grid))
    O50M1 = O50M1preF NOT B50M1s

    // 3rd, middle
    F502M1 = RECTANGLES WM1_502 LM1_502 SM1_502 OFFSET OM1_502 INSIDE OF LAYER O50M1
    F502M1s = (SIZE F502M1 BY (SM1_501 + grid)) OR B50M1s
    R502M1pre = O50M1 NOT F502M1s
    R502M1 = WITH WIDTH R502M1pre >= WM1_501

    // 4th, small
    F5012M1 = RECTANGLES WM1_501 LM1_501 SM1_501 OFFSET OM1_501 INSIDE OF LAYER R502M1
    F5012M1s = (SIZE F5012M1 BY (SM1_501 + grid)) OR F502M1s
    R5012M1pre = R502M1pre NOT F5012M1s
    R5012M1 = WITH WIDTH R5012M1pre >= WM1_501

    // 5th, non-stagger small
    F501M1 = RECTANGLES WM1_501 LM1_501 SM1_501 INSIDE OF LAYER R5012M1 //MAINTAIN SPACING
    F501M1s = (SIZE F501M1 BY (SM1_501 + grid)) OR F5012M1s

    F50M1 = ((F502M1 OR F5012M1) OR F501M1) OR F503M1

//****************************************************************************

    exceedM1 = DENSITY M1x F30M1 F40M1 F50M1 > maxD_M1 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M1.den_exceed

    removeM1R = ((PUSH (exceedM1 AND (D50M1 OR emptyM1))) NOT FRAME1) AND CHIP
    removeM1P = RECTANGLES 0.4 0.4 3.6 INSIDE OF LAYER removeM1R

    F30M1x = F30M1 NOT INTERACT removeM1P
    F40M1x = F40M1 NOT INTERACT removeM1P
    F50M1x = F50M1 NOT INTERACT removeM1P
    FM1xA  = (F30M1x OR F40M1x) OR F50M1x
    FM1x   = FM1xA NOT INTERACT (EXT FM1xA < DM1_S_1 ABUT SINGULAR REGION)

    ALLM1x = M1x OR FM1x
    lackM1 = DENSITY ALLM1x CHIP < DM1_OPC_DN WINDOW WindowSize STEP WindowStep BACKUP // PRINT M1.den_lack
             INSIDE OF LAYER bulk [ AREA(ALLM1x)/AREA(CHIP) ]

    WDM1EXC = DUM1 WITH WIDTH > 1 // existed wide dummy Metal(1umx1um) exclude region for DMx.S.2.
    RM1EXC = (SIZE FM1x BY Odm2DM1) OR (SIZE (((F303M1_EXP OR F403M1_EXP) OR F503M1_EXP) OR WDM1EXC) BY 1.5)

    lackM1pRM = ((((PUSH lackM1) NOT RM1EXC) NOT FRAME1OPC) NOT exceedM1) AND CHIP
    lackM1pRM_1 = WITH WIDTH lackM1pRM >= SM1_OPC

    RM1p1 = RECTANGLES WM1_OPC LM1_OPC WSM1_OPC LSM1_OPC INSIDE OF LAYER lackM1pRM_1
    lackM1pRM_2 = lackM1pRM_1 NOT (SIZE RM1p1 BY SM1_OPC)
    RM1p2 = RECTANGLES LM1_OPC WM1_OPC LSM1_OPC WSM1_OPC INSIDE OF LAYER lackM1pRM_2

    ODM1A = ((RM1p1 OR RM1p2) OUTSIDE RM1EXC) OUTSIDE FRAME1OPC
    ODM1F = ODM1A NOT INTERACT (EXT ODM1A < SM1_OPC ABUT SINGULAR REGION)

    DM1F = COPY FM1x

    FRAME1_INDDMYA = SIZE M1i BY (dm1_s2m1_INDDMY + grid)
    FRAME1_INDDMYB = SIZE DUM1 BY (dm1_s_INDDMY + grid)
    FRAME1_INDDMYC = SIZE DM1F BY dm1_s_INDDMY
    FRAME1_INDDMYD = SIZE ODM1F BY dm1_s2m1_INDDMY
    FRAME1_INDDMY  = ((((((FRAME1Pre OR BLOCK1) OR FRAME1_INDDMYA) OR FRAME1_INDDMYB) OR FRAME1_INDDMYC) OR FRAME1_INDDMYD) OR NFILL) OR FUSELINKx
    FILL1_INDDMY   = ooINDDMY NOT FRAME1_INDDMY
    DM1F_INDDMY    = RECTANGLES dm1_w_INDDMY dm1_l_INDDMY dm1_s_INDDMY INSIDE OF LAYER FILL1_INDDMY


#IFDEF FILL_indDM1
    FILL1_INDDMY_HD = (SIZE INDDMY_HD BY -(dm1_s_INDDMY_HD + grid)) NOT FRAME1_INDDMY
    DM1F_INDDMY_HD  = RECTANGLES dm1_w_INDDMY_HD dm1_l_INDDMY_HD dm1_s_INDDMY_HD INSIDE OF LAYER FILL1_INDDMY_HD
#ENDIF	

#ELSE


#IFDEF 9K_THICK_Mz_M1

    minOPENM1 = DENSITY M1x < minD_M1 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M1Min.den
    emptyOPENM1 = DENSITY M1x < emptyD_M1 WINDOW emptyWindowSize STEP emptyWindowStep
                  INSIDE OF LAYER bulk BACKUP // PRINT M1Empty.den

    M1InnerHole = HOLES M1i INNER

    M1BigHole = SIZE M1InnerHole BY - excludeHoleSize/2
    M1ExcHole = ((M1InnerHole OUTSIDE M1BigHole) NOT M1i) INTERACT ((CBi OR CB2Wi) NOT INTERACT WBDMY)
    BLOCK1 = (SIZE DM1EXCL BY (dm2DMEXCL + grid)) OR MIM1_x // DM1 to DM1EXCL
    FRAMEA1 = SIZE M1i BY (dm2M1 + grid) // DM1 to metal
    FRAMEB1 = SIZE (WITH WIDTH M1i > wideM1) BY (dm2WM1 + grid)
    FRAMEC1 = SIZE DUM1 BY (dm2DM1 + grid)   // DM1 to existed dummy metal 0.6um
    FRAME1Pre = ((FRAMEA1 OR FRAMEB1) OR FRAMEC1) OR M1ExcHole
    FRAME1INDDMY = SIZE INDDMY_all BY (IND_S_1_1 + dm1_s2m1_INDDMY + grid)
    FRAME1 = ((FRAME1Pre OR FRAME1INDDMY) OR BLOCK1) OR NFILL
    
    OPENM1 = PUSH ((minOPENM1 OR emptyOPENM1) AND CHIP)
    FILL1 = OPENM1 NOT FRAME1
    FILLW1pre = SIZE FILL1 BY - (Wdm2M1 + grid)
    FILLW1 = WITH WIDTH FILLW1pre >= WdmW_M1
    M1FW = RECTANGLES WdmW_M1 WdmL_M1 WdmS_M1 OFFSET WdmO_M1 INSIDE OF LAYER FILLW1
    M1FW_EXP = SIZE M1FW BY (WdmS_M1 /2 + grid) OVERUNDER //merge the gaps
    FILLM1pre = FILL1 NOT (SIZE M1FW_EXP BY (MdmS_M1 + grid))
    FILLM1 = WITH WIDTH FILLM1pre >= MdmW_M1
    M1F1 = RECTANGLES MdmW_M1 MdmL_M1 MdmS_M1 OFFSET MdmO_M1 INSIDE OF LAYER FILLM1
    M1R1pre = FILLM1pre NOT (SIZE M1F1 BY (dmS_M1 + grid))
    M1R1 = WITH WIDTH M1R1pre >= dmW_M1

    M1F2 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 OFFSET dmO_M1 INSIDE OF LAYER M1R1
    M1R2pre = M1R1 NOT (SIZE M1F2 BY (dmS_M1 + grid))
    M1R2 = WITH WIDTH M1R2pre >= dmW_M1

    M1F3 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 OFFSET dmO_M1 INSIDE OF LAYER M1R2
    M1R3pre = M1R2 NOT (SIZE M1F3 BY (dmS_M1 + grid))
    M1R3 = WITH WIDTH M1R3pre >= dmW_M1

    M1F4 = RECTANGLES dmW_M1 dmL_M1 dmS_M1 INSIDE OF LAYER M1R3

    M1F = (((M1F1 OR M1F2) OR M1F3) OR M1F4) OR M1FW
    FM1 = M1F NOT INTERACT (EXT M1F < dmS_M1 ABUT SINGULAR REGION)

    maxOPENM1 = DENSITY M1x FM1 > maxD_M1 WINDOW WindowSize STEP WindowStep
                INSIDE OF LAYER bulk BACKUP // PRINT M1Max.den

    FM1F = FM1 OUTSIDE maxOPENM1

    // DMz_S to enhance the fill in the region of density < 20%, rule value = 10%
    D25M1 = DENSITY M1x FM1F < 0.2 WINDOW WindowSize STEP WindowStep
            INSIDE OF LAYER bulk BACKUP // PRINT M1Min.den

    RM1EXC = SIZE FM1F BY (Odm2DM1 + grid)
    // do not fill DMz_S over CTMDMY
    D25M1pM = (((PUSH D25M1) NOT FRAME1) NOT RM1EXC) AND CHIP
    D25M1pM_1 = WITH WIDTH D25M1pM >= OdmW_M1

    RM1p1 = RECTANGLES OdmW_M1 OdmL_M1 OdmS_M1 INSIDE OF LAYER D25M1pM_1
    D25M1pM_2 = D25M1pM_1 NOT (SIZE RM1p1 BY (OdmS_M1 + grid))
    RM1p2 = RECTANGLES OdmL_M1 OdmW_M1 OdmS_M1 INSIDE OF LAYER D25M1pM_2

    RM1A = ((RM1p1 OR RM1p2) OUTSIDE RM1EXC) OUTSIDE FRAME1
    RM1  = RM1A NOT INTERACT (EXT RM1A < OdmS_M1 ABUT SINGULAR REGION)

    DM1F = FM1F OR RM1

    FRAME1_INDDMYA = SIZE M1i BY (dm1_s2m1_INDDMY + grid)
    FRAME1_INDDMYB = SIZE DUM1 BY (dm1_s_INDDMY + grid)
    FRAME1_INDDMYC = SIZE DM1F BY dm1_s_INDDMY
    FRAME1_INDDMY  = ((((FRAME1Pre OR BLOCK1) OR FRAME1_INDDMYA) OR FRAME1_INDDMYB) OR FRAME1_INDDMYC) OR NFILL
    FILL1_INDDMY   = ooINDDMY NOT FRAME1_INDDMY
    DM1F_INDDMY    = RECTANGLES dm1_w_INDDMY dm1_l_INDDMY dm1_s_INDDMY INSIDE OF LAYER FILL1_INDDMY

#IFDEF FILL_indDM1
    FILL1_INDDMY_HD = (SIZE INDDMY_HD BY -(dm1_s_INDDMY_HD + grid)) NOT FRAME1_INDDMY
    DM1F_INDDMY_HD  = RECTANGLES dm1_w_INDDMY_HD dm1_l_INDDMY_HD dm1_s_INDDMY_HD INSIDE OF LAYER FILL1_INDDMY_HD
#ENDIF	

#ELSE



    D30M1 = DENSITY M1x <= 0.2 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M1.den30
    D40M1 = DENSITY M1x <= 0.3 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M1.den40
    D50M1 = DENSITY M1x <= 0.5 WINDOW WindowSize STEP WindowStep
               INSIDE OF LAYER bulk BACKUP // PRINT M1.den50
    emptyM1 = DENSITY M1x < emptyD_M1 WINDOW emptyWindowSize STEP emptyWindowStep
              INSIDE OF LAYER bulk BACKUP // PRINT M1.den_empty

    M1InnerHole = HOLES M1i INNER
#IFDEF FILL_M1_DTCD
    VARIABLE M1_DTCD2Chip      2.5  //
    VARIABLE M1_DTCD2LOGO      10   //
    VARIABLE M1_DTCD2MOMDMY    0    // 
    VARIABLE M1_DTCD2LOWMEDN   0    //
    VARIABLE M1_DTCD2POFUSE    0    //
    VARIABLE M1_DTCD2DM1EXCL   0    //
    VARIABLE M1_DTCD2DM1CB2   0    //
    VARIABLE M1_DTCD2M1        2.63  // CB2.S.2
    VARIABLE M1_DTCD2DM1       1.5  // DMx.S.2
    VARIABLE M1_DTCD2TCDDMY_M1 150  // for idu measurement
    VARIABLE M1_DTCD2CTMDMY_2 0.112  // MIM.VIAz.S.5
    VARIABLE M1_DTCD2ICOVL     8
	M1_DTCDxChip        = CHIP NOT (SIZE CHIP BY -(M1_DTCD2Chip + grid))
    M1_DTCDxLOGO        = SIZE LOGO               BY (M1_DTCD2LOGO      + grid)
    M1_DTCDxMOMDMY      = SIZE MOMDMY             BY (M1_DTCD2MOMDMY    + grid)
    M1_DTCDxLOWMEDN     = SIZE LOWMEDN            BY (M1_DTCD2LOWMEDN   + grid)
    M1_DTCDxPOFUSE      = SIZE (FUSELINK AND POi) BY (M1_DTCD2POFUSE    + grid)
    M1_DTCDxDM1EXCL     = SIZE DM1EXCL            BY (M1_DTCD2DM1EXCL   + grid)
    M1_DTCDxDM1CB2      = SIZE CB2i               BY (M1_DTCD2DM1CB2    + grid)
    M1_DTCDxM1          = SIZE M1i                BY (M1_DTCD2M1        + grid)
    M1_DTCDxDM1         = SIZE DUM1               BY (M1_DTCD2DM1       + grid)
    M1_DTCDxTCDDMY_M1   = SIZE TCDDMY_M1          BY (M1_DTCD2TCDDMY_M1 + grid)
    M1_DTCDxTCDDMY_FM1  = SIZE TCDDMY_FM1         BY (M1_DTCD2TCDDMY_M1 + grid)
    M1_DTCDxTCDDMY_FDM1 = SIZE TCDDMY_FDM1        BY (M1_DTCD2TCDDMY_M1 + grid)
    M1_DTCDxICOVL       = SIZE ICOVL              BY (M1_DTCD2ICOVL     + grid)
    M1_DTCDxCTMDMY_2   = SIZE CTMDMY_2          BY (M1_DTCD2CTMDMY_2  + grid)

    M1_DTCDx = (((((((((((((M1_DTCDxChip OR M1_DTCDxLOGO) OR M1_DTCDxLOWMEDN) OR M1_DTCDxPOFUSE) OR M1_DTCDxDM1EXCL) OR M1_DTCDxM1) OR M1_DTCDxDM1) OR M1_DTCDxTCDDMY_M1) OR M1_DTCDxTCDDMY_FM1) OR M1_DTCDxTCDDMY_FDM1) OR FRAME1INDDMY) OR M1_DTCDxMOMDMY) OR M1_DTCDxDM1CB2) OR M1_DTCDxCTMDMY_2) OR M1_DTCDxICOVL
    M1_DTCDo = CHIP NOT M1_DTCDx

    VARIABLE TCD_M1_W      4
    VARIABLE TCD_M1_L      4
    VARIABLE M1_DTCD_S     400
    VARIABLE M1_DTCD_MIN_S 150
    VARIABLE D2M1_DTCD     0.6

    M1_DTCD_pre = RECTANGLES TCD_M1_W TCD_M1_L M1_DTCD_S INSIDE OF LAYER M1_DTCDo
    TCD_M1 = M1_DTCD_pre NOT INTERACT (EXT M1_DTCD_pre < M1_DTCD_MIN_S ABUT SINGULAR REGION)

TCD_M1_165_91_1 = SHRINK TCD_M1 LEFT BY 0 BOTTOM BY 0 RIGHT BY (TCD_M1_W-4) TOP BY (TCD_M1_L-4)
TCD_M1_150_1_1 = SHRINK TCD_M1 LEFT BY 0 BOTTOM BY 0 RIGHT BY (TCD_M1_W-4) TOP BY (TCD_M1_L-4)
TCD_M1_31_0_1 = SHRINK TCD_M1 LEFT BY 3.275 BOTTOM BY 0.09 RIGHT BY (TCD_M1_W-3.775) TOP BY (TCD_M1_L-0.59)
TCD_M1_31_0_2 = SHRINK TCD_M1 LEFT BY 0.225 BOTTOM BY 0.09 RIGHT BY (TCD_M1_W-0.725) TOP BY (TCD_M1_L-0.59)
TCD_M1_31_0_3 = SHRINK TCD_M1 LEFT BY 0.225 BOTTOM BY 0.7 RIGHT BY (TCD_M1_W-0.425) TOP BY (TCD_M1_L-3.3)
TCD_M1_31_0_4 = SHRINK TCD_M1 LEFT BY 0.525 BOTTOM BY 0.7 RIGHT BY (TCD_M1_W-0.575) TOP BY (TCD_M1_L-3.3)
TCD_M1_31_0_5 = SHRINK TCD_M1 LEFT BY 0.725 BOTTOM BY 0.7 RIGHT BY (TCD_M1_W-0.775) TOP BY (TCD_M1_L-3.3)
TCD_M1_31_0_6 = SHRINK TCD_M1 LEFT BY 0.625 BOTTOM BY 0.7 RIGHT BY (TCD_M1_W-0.675) TOP BY (TCD_M1_L-3.3)
TCD_M1_31_0_7 = SHRINK TCD_M1 LEFT BY 0.875 BOTTOM BY 0.7 RIGHT BY (TCD_M1_W-1.075) TOP BY (TCD_M1_L-3.3)
TCD_M1_31_0_8 = SHRINK TCD_M1 LEFT BY 1.175 BOTTOM BY 0.7 RIGHT BY (TCD_M1_W-1.225) TOP BY (TCD_M1_L-3.3)
