    FD21M4s = COPY FRAME4

    O30M4preA = SIZE O30M4pre BY -DM4_303
    O30M4preB = O30M4preA WITH WIDTH >= WM4_303

    // 1st big
    F303M4 = RECTANGLES WM4_303 LM4_303 SM4_303 OFFSET OM4_303 INSIDE OF LAYER O30M4preB
    F303M4_SLOT = RECTANGLES WM4_303_SLOT LM4_303_SLOT SM4_303_SLOT INSIDE OF LAYER F303M4

    F303M4_EXP = SIZE F303M4_SLOT BY ( SM4_303 / 2 + grid ) OVERUNDER   // merge the gaps
    O30M4preF1 = O30M4pre NOT (SIZE F303M4_EXP BY SM4_302)
    O30M4preF  = (SNAP (SIZE O30M4preF1 BY -grid) 5) AND O30M4preF1

    B30M4s = FD21M4s OR (SIZE F303M4_EXP BY (SM4_302+grid))
    O30M4 = O30M4preF NOT B30M4s

    // 3rd, middle
