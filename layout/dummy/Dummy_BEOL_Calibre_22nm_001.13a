    // 1st big
    F303M8 = RECTANGLES WM8_303 LM8_303 SM8_303 OFFSET OM8_303 INSIDE OF LAYER O30M8preB
    F303M8_SLOT = RECTANGLES WM8_303_SLOT LM8_303_SLOT SM8_303_SLOT INSIDE OF LAYER F303M8

    F303M8_EXP = SIZE F303M8_SLOT BY ( SM8_303 / 2 + grid ) OVERUNDER   // merge the gaps
