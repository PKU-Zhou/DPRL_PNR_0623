                CO_ODB_H_union_5 = CO_ODB_H_union_4 OR CO_ODB_H_5

        CO_ODB_H = COPY CO_ODB_H_union_5


IO_ODB_pre = IO_ODB_V OR IO_ODB_H
    IO_ODB = IO_ODB_pre NOT INTERACT (EXT IO_ODB_pre < SR_DOD_S_12 ABUT SINGULAR REGION)

CO_ODB_pre = CO_ODB_V OR CO_ODB_H
    CO_ODB = CO_ODB_pre NOT INTERACT (EXT CO_ODB_pre < SR_DOD_S_1 ABUT SINGULAR REGION)

ODB_pre = IO_ODB OR CO_ODB
    ODB = ODB_pre NOT INTERACT (EXT ODB_pre < SR_DOD_S_1 ABUT SINGULAR REGION)

