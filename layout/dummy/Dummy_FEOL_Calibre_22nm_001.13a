            CO_ODB_V_5 = RECTANGLES CO_ODB_W CO_ODB_L CO_ODB_W_S CO_ODB_L_S OFFSET CO_ODB_W_O CO_ODB_L_O INSIDE OF LAYER CO_ODB_V1o_5
                CO_ODB_V_union_5 = CO_ODB_V_union_4 OR CO_ODB_V_5

        CO_ODB_V = COPY CO_ODB_V_union_5


