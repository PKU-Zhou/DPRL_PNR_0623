            IO_POB_V_1 = RECTANGLES IO_POB_W IO_POB_L IO_POB_W_S IO_POB_L_S OFFSET IO_POB_W_O IO_POB_L_O INSIDE OF LAYER IO_POB_Vo_1
                IO_POB_V_union_1 = COPY IO_POB_V_1

                IO_POB_Vo_2 = (IO_POB_Vo_1 NOT (SIZE IO_POB_V_union_1 BY IO_POB_L_S)) WITH WIDTH >= IO_POB_W
            IO_POB_V_2 = RECTANGLES IO_POB_W IO_POB_L IO_POB_W_S IO_POB_L_S OFFSET IO_POB_W_O IO_POB_L_O INSIDE OF LAYER IO_POB_Vo_2
                IO_POB_V_union_2 = IO_POB_V_union_1 OR IO_POB_V_2

                IO_POB_Vo_3 = (IO_POB_Vo_2 NOT (SIZE IO_POB_V_union_2 BY IO_POB_L_S)) WITH WIDTH >= IO_POB_W
            IO_POB_V_3 = RECTANGLES IO_POB_W IO_POB_L IO_POB_W_S IO_POB_L_S OFFSET IO_POB_W_O IO_POB_L_O INSIDE OF LAYER IO_POB_Vo_3
                IO_POB_V_union_3 = IO_POB_V_union_2 OR IO_POB_V_3

        IO_POB_V = COPY IO_POB_V_union_3


IO_POB_H1o = IO_POB_Ho NOT (SIZE IO_POB_V BY IO_POB_L_S)
                IO_POB_H1o_1 = IO_POB_H1o WITH WIDTH >= IO_POB_W
            IO_POB_H_1 = RECTANGLES IO_POB_L IO_POB_W IO_POB_L_S IO_POB_W_S OFFSET IO_POB_L_O IO_POB_W_O INSIDE OF LAYER IO_POB_H1o_1
                IO_POB_H_union_1 = COPY IO_POB_H_1

                IO_POB_H1o_2 = (IO_POB_H1o_1 NOT (SIZE IO_POB_H_union_1 BY IO_POB_L_S)) WITH WIDTH >= IO_POB_W
            IO_POB_H_2 = RECTANGLES IO_POB_L IO_POB_W IO_POB_L_S IO_POB_W_S OFFSET IO_POB_L_O IO_POB_W_O INSIDE OF LAYER IO_POB_H1o_2
                IO_POB_H_union_2 = IO_POB_H_union_1 OR IO_POB_H_2

                IO_POB_H1o_3 = (IO_POB_H1o_2 NOT (SIZE IO_POB_H_union_2 BY IO_POB_L_S)) WITH WIDTH >= IO_POB_W
            IO_POB_H_3 = RECTANGLES IO_POB_L IO_POB_W IO_POB_L_S IO_POB_W_S OFFSET IO_POB_L_O IO_POB_W_O INSIDE OF LAYER IO_POB_H1o_3
                IO_POB_H_union_3 = IO_POB_H_union_2 OR IO_POB_H_3

        IO_POB_H = COPY IO_POB_H_union_3


CO_POB_V1o = CO_POB_Vo NOT (SIZE (IO_POB_V OR IO_POB_H) BY IO_POB_L_S)
                CO_POB_V1o_1 = CO_POB_V1o WITH WIDTH >= CO_POB_W
            CO_POB_V_1 = RECTANGLES CO_POB_W CO_POB_L CO_POB_W_S CO_POB_L_S OFFSET CO_POB_W_O CO_POB_L_O INSIDE OF LAYER CO_POB_V1o_1
                CO_POB_V_union_1 = COPY CO_POB_V_1

                CO_POB_V1o_2 = (CO_POB_V1o_1 NOT (SIZE CO_POB_V_union_1 BY CO_POB_L_S)) WITH WIDTH >= CO_POB_W
            CO_POB_V_2 = RECTANGLES CO_POB_W CO_POB_L CO_POB_W_S CO_POB_L_S OFFSET CO_POB_W_O CO_POB_L_O INSIDE OF LAYER CO_POB_V1o_2
                CO_POB_V_union_2 = CO_POB_V_union_1 OR CO_POB_V_2

                CO_POB_V1o_3 = (CO_POB_V1o_2 NOT (SIZE CO_POB_V_union_2 BY CO_POB_L_S)) WITH WIDTH >= CO_POB_W
            CO_POB_V_3 = RECTANGLES CO_POB_W CO_POB_L CO_POB_W_S CO_POB_L_S OFFSET CO_POB_W_O CO_POB_L_O INSIDE OF LAYER CO_POB_V1o_3
                CO_POB_V_union_3 = CO_POB_V_union_2 OR CO_POB_V_3

                CO_POB_V1o_4 = (CO_POB_V1o_3 NOT (SIZE CO_POB_V_union_3 BY CO_POB_L_S)) WITH WIDTH >= CO_POB_W
            CO_POB_V_4 = RECTANGLES CO_POB_W CO_POB_L CO_POB_W_S CO_POB_L_S OFFSET CO_POB_W_O CO_POB_L_O INSIDE OF LAYER CO_POB_V1o_4
                CO_POB_V_union_4 = CO_POB_V_union_3 OR CO_POB_V_4

                CO_POB_V1o_5 = (CO_POB_V1o_4 NOT (SIZE CO_POB_V_union_4 BY CO_POB_L_S)) WITH WIDTH >= CO_POB_W
            CO_POB_V_5 = RECTANGLES CO_POB_W CO_POB_L CO_POB_W_S CO_POB_L_S OFFSET CO_POB_W_O CO_POB_L_O INSIDE OF LAYER CO_POB_V1o_5
                CO_POB_V_union_5 = CO_POB_V_union_4 OR CO_POB_V_5

        CO_POB_V = COPY CO_POB_V_union_5


CO_POB_H1o = CO_POB_Ho NOT (SIZE ((IO_POB_V OR IO_POB_H) OR CO_POB_V) BY IO_POB_L_S)
                CO_POB_H1o_1 = CO_POB_H1o WITH WIDTH >= CO_POB_W
            CO_POB_H_1 = RECTANGLES CO_POB_L CO_POB_W CO_POB_L_S CO_POB_W_S OFFSET CO_POB_L_O CO_POB_W_O INSIDE OF LAYER CO_POB_H1o_1
                CO_POB_H_union_1 = COPY CO_POB_H_1

                CO_POB_H1o_2 = (CO_POB_H1o_1 NOT (SIZE CO_POB_H_union_1 BY CO_POB_L_S)) WITH WIDTH >= CO_POB_W
            CO_POB_H_2 = RECTANGLES CO_POB_L CO_POB_W CO_POB_L_S CO_POB_W_S OFFSET CO_POB_L_O CO_POB_W_O INSIDE OF LAYER CO_POB_H1o_2
                CO_POB_H_union_2 = CO_POB_H_union_1 OR CO_POB_H_2

                CO_POB_H1o_3 = (CO_POB_H1o_2 NOT (SIZE CO_POB_H_union_2 BY CO_POB_L_S)) WITH WIDTH >= CO_POB_W
            CO_POB_H_3 = RECTANGLES CO_POB_L CO_POB_W CO_POB_L_S CO_POB_W_S OFFSET CO_POB_L_O CO_POB_W_O INSIDE OF LAYER CO_POB_H1o_3
                CO_POB_H_union_3 = CO_POB_H_union_2 OR CO_POB_H_3

                CO_POB_H1o_4 = (CO_POB_H1o_3 NOT (SIZE CO_POB_H_union_3 BY CO_POB_L_S)) WITH WIDTH >= CO_POB_W
            CO_POB_H_4 = RECTANGLES CO_POB_L CO_POB_W CO_POB_L_S CO_POB_W_S OFFSET CO_POB_L_O CO_POB_W_O INSIDE OF LAYER CO_POB_H1o_4
                CO_POB_H_union_4 = CO_POB_H_union_3 OR CO_POB_H_4

                CO_POB_H1o_5 = (CO_POB_H1o_4 NOT (SIZE CO_POB_H_union_4 BY CO_POB_L_S)) WITH WIDTH >= CO_POB_W
            CO_POB_H_5 = RECTANGLES CO_POB_L CO_POB_W CO_POB_L_S CO_POB_W_S OFFSET CO_POB_L_O CO_POB_W_O INSIDE OF LAYER CO_POB_H1o_5
                CO_POB_H_union_5 = CO_POB_H_union_4 OR CO_POB_H_5

        CO_POB_H = COPY CO_POB_H_union_5


POB_pre = ((IO_POB_V OR IO_POB_H) OR CO_POB_V) OR CO_POB_H
    POB_ori = POB_pre NOT INTERACT (EXT POB_pre < SR_DPO_S_1 ABUT SINGULAR REGION)
POB_pre_rpo = POB_ori AND RPOi
POB_ori_rpo = EXT POB_pre_rpo < PO_S_21 ABUT SINGULAR REGION
POB = POB_ori NOT INTERACT POB_ori_rpo
xPOB = SIZE POB BY NEXT_S3
#ELSE
POB = COPY EMPTY
xPOB = COPY EMPTY
#ENDIF


#IFDEF FILL_SRDOD_SRDPO
POSx = SIZE ALL_POLY BY POS_S
POSo = (((((((((CHIP NOT POSx) NOT SRDPOx) NOT xPRO) NOT xMOS) NOT xTCD) NOT xSTD) NOT xCEL) NOT xODB) NOT xPOB) NOT GATE_SRDPO_W4x
                POSo_1 = POSo WITH WIDTH >= POS_W
            POS_pre_1 = RECTANGLES POS_W POS_W POS_S POS_S OFFSET POS_O POS_O INSIDE OF LAYER POSo_1
                POS_pre_union_1 = COPY POS_pre_1

                POSo_2 = (POSo_1 NOT (SIZE POS_pre_union_1 BY POS_S)) WITH WIDTH >= POS_W
            POS_pre_2 = RECTANGLES POS_W POS_W POS_S POS_S OFFSET POS_O POS_O INSIDE OF LAYER POSo_2
                POS_pre_union_2 = POS_pre_union_1 OR POS_pre_2

                POSo_3 = (POSo_2 NOT (SIZE POS_pre_union_2 BY POS_S)) WITH WIDTH >= POS_W
            POS_pre_3 = RECTANGLES POS_W POS_W POS_S POS_S OFFSET POS_O POS_O INSIDE OF LAYER POSo_3
                POS_pre_union_3 = POS_pre_union_2 OR POS_pre_3

        POS_pre = COPY POS_pre_union_3

    POS = POS_pre NOT INTERACT (EXT POS_pre < POS_S ABUT SINGULAR REGION)
xPOS = SIZE POS BY NEXT_S3
#ELSE
POS = COPY EMPTY
xPOS = COPY EMPTY
#ENDIF


#IFDEF FILL_SRDOD_SRDPO
POH1x = SIZE ALL_POLY BY POH1_S
POH1o = ((((((((((CHIP NOT POH1x) NOT SRDPOx) NOT xPRO) NOT xMOS) NOT xTCD) NOT xSTD) NOT xCEL) NOT xODB) NOT xPOB) NOT GATE_SRDPO_W4x) NOT xPOS
                POH1o_1 = POH1o WITH WIDTH >= POH1_L
            POH1_pre_1 = RECTANGLES POH1_W POH1_L POH1_S POH1_S OFFSET POH1_O POH1_O INSIDE OF LAYER POH1o_1
                POH1_pre_union_1 = COPY POH1_pre_1

                POH1o_2 = (POH1o_1 NOT (SIZE POH1_pre_union_1 BY POH1_S)) WITH WIDTH >= POH1_L
            POH1_pre_2 = RECTANGLES POH1_W POH1_L POH1_S POH1_S OFFSET POH1_O POH1_O INSIDE OF LAYER POH1o_2
                POH1_pre_union_2 = POH1_pre_union_1 OR POH1_pre_2

                POH1o_3 = (POH1o_2 NOT (SIZE POH1_pre_union_2 BY POH1_S)) WITH WIDTH >= POH1_L
            POH1_pre_3 = RECTANGLES POH1_W POH1_L POH1_S POH1_S OFFSET POH1_O POH1_O INSIDE OF LAYER POH1o_3
                POH1_pre_union_3 = POH1_pre_union_2 OR POH1_pre_3

        POH1_pre = COPY POH1_pre_union_3

    POH1 = POH1_pre NOT INTERACT (EXT POH1_pre < POH1_S ABUT SINGULAR REGION)
xPOH1 = SIZE POH1 BY NEXT_S3
#ELSE
POH1 = COPY EMPTY
xPOH1 = COPY EMPTY
#ENDIF


#IFDEF FILL_SRDOD_SRDPO
POH2x = SIZE ALL_POLY BY POH2_S
POH2o = (((((((((((CHIP NOT POH2x) NOT SRDPOx) NOT xPRO) NOT xMOS) NOT xTCD) NOT xSTD) NOT xCEL) NOT xODB) NOT xPOB) NOT GATE_SRDPO_W4x) NOT xPOS) NOT xPOH1
                POH2o_1 = POH2o WITH WIDTH >= POH2_L
            POH2_pre_1 = RECTANGLES POH2_W POH2_L POH2_S POH2_S OFFSET POH2_O POH2_O INSIDE OF LAYER POH2o_1
                POH2_pre_union_1 = COPY POH2_pre_1

                POH2o_2 = (POH2o_1 NOT (SIZE POH2_pre_union_1 BY POH2_S)) WITH WIDTH >= POH2_L
            POH2_pre_2 = RECTANGLES POH2_W POH2_L POH2_S POH2_S OFFSET POH2_O POH2_O INSIDE OF LAYER POH2o_2
                POH2_pre_union_2 = POH2_pre_union_1 OR POH2_pre_2

                POH2o_3 = (POH2o_2 NOT (SIZE POH2_pre_union_2 BY POH2_S)) WITH WIDTH >= POH2_L
            POH2_pre_3 = RECTANGLES POH2_W POH2_L POH2_S POH2_S OFFSET POH2_O POH2_O INSIDE OF LAYER POH2o_3
                POH2_pre_union_3 = POH2_pre_union_2 OR POH2_pre_3

        POH2_pre = COPY POH2_pre_union_3

    POH2 = POH2_pre NOT INTERACT (EXT POH2_pre < POH2_S ABUT SINGULAR REGION)
xPOH2 = SIZE POH2 BY NEXT_S3
#ELSE
POH2 = COPY EMPTY
xPOH2 = COPY EMPTY
#ENDIF



PO_DN_CHK1 = (((((((ALL_POLY OR MOS_SRDPO) OR STD_DPO) OR CEL_SRDPO) OR POB) OR POS) OR POH1) OR POH2) NOT HPDPO
PO_GATE_SEN = ((((((GATE INTERACT SENDMY) NOT LOGO) NOT VARi) NOT CAPDMY) NOT DECAPDMY) NOT TCDDMY) NOT (SRAMDMY AND RODMY)
PO_DENSITY_HIGH1 = DENSITY PO_DN_CHK1 > PO_DN_11 INSIDE OF LAYER bulk_pre WINDOW PO_DN_11_W STEP PO_DN_11_S BACKUP
PO_DN_11_Region1 = (SIZE PO_GATE_SEN BY (PO_DN_11_W + PO_DN_11_S2)) AND PO_DENSITY_HIGH1
PO_A_3_Region1 = DENSITY PO_DN_CHK1 > PO_A_3 WINDOW PO_A_3_W STEP PO_A_3_S INSIDE OF LAYER (SIZE (AREA PO_DN_CHK1 > PO_A_3_A) BY PO_A_3_G) BACKUP
PO_DN_4_1_Region1 = DENSITY PO_DN_CHK1 > PO_DN_4_1_buf WINDOW PO_DN_4_1_W STEP PO_DN_4_1_S INSIDE OF LAYER bulk_pre BACKUP
PO_DN_16_CHK1 = ((PO_DN_CHK1 NOT CPO) AND PMET) NOT (RHPO AND RPOi)
PO_DN_16_Region1 = DENSITY PO_DN_16_CHK1 > PO_DN_16_buf INSIDE OF LAYER MATCHING_S10 WINDOW PO_DN_16_W STEP PO_DN_16_S BACKUP
PO_R_28_CHK1 = (PO_DN_CHK1 NOT CPO) NOT (RHPO AND RPOi)
PO_R_28_Region1x = DENSITY PO_R_28_CHK1 >= PO_R_28_DN_buf INSIDE OF LAYER MATCHING_S10 WINDOW PO_R_28_W1 PO_R_28_W2 STEP PO_R_28_S1 PO_R_28_S2 BACKUP
PO_R_28_Region1y = DENSITY PO_R_28_CHK1 >= PO_R_28_DN_buf INSIDE OF LAYER MATCHING_S10 WINDOW PO_R_28_W2 PO_R_28_W1 STEP PO_R_28_S2 PO_R_28_S1 BACKUP
PO_R_28_Region1 = ENCLOSE RECTANGLE (OR PO_R_28_Region1x PO_R_28_Region1y) 0.001 PO_R_28+0.001 ORTHOGONAL ONLY
PO_A_4_CHK1 = ((PO_DN_CHK1 NOT CPO) AND PMET) NOT (RHPO AND RPOi)
PO_A_4_Region1a = DENSITY PO_A_4_CHK1 >= PO_A_4_DN_buf INSIDE OF LAYER bulk_pre WINDOW PO_A_4_W STEP PO_A_4_S BACKUP
PO_A_4_Region1 = AREA PO_A_4_Region1a > PO_A_4
PO_A_5_CHK1 = ((PO_DN_CHK1 NOT CPO) AND PMET) NOT (RHPO AND RPOi)
PO_A_5_Region1a = DENSITY PO_A_5_CHK1 >= PO_A_5_DN_buf INSIDE OF LAYER bulk_pre WINDOW PO_A_5_W STEP PO_A_5_S BACKUP
PO_A_5_Region1 = AREA PO_A_5_Region1a > PO_A_5
PO_DN_CHK_Region1 = ((((((PO_A_3_Region1 OR PO_DN_4_1_Region1) OR PO_DN_11_Region1) OR PO_DN_16_Region1) OR PO_R_28_Region1) OR PO_A_4_Region1) OR PO_A_5_Region1) NOT HPDPO
PO_Removed_Seed = RECTANGLES PO_Removed_Seed_W PO_Removed_Seed_W PO_Removed_Seed_S PO_Removed_Seed_S OFFSET PO_Removed_Seed_O PO_Removed_Seed_O INSIDE OF LAYER PO_DN_CHK_Region1
MOS_SRDPO_after_PO_DN_CHK1 = MOS_SRDPO NOT INTERACT (MOS_boundary INTERACT PO_Removed_Seed)
STD_DPO_after_PO_DN_CHK1   = STD_DPO   NOT INTERACT (STD_boundary INTERACT PO_Removed_Seed)
CEL_SRDPO_after_PO_DN_CHK1 = CEL_SRDPO NOT INTERACT PO_Removed_Seed
POB_after_PO_DN_CHK1       = POB       NOT INTERACT PO_Removed_Seed
POS_after_PO_DN_CHK1       = POS       NOT INTERACT PO_Removed_Seed
POH1_after_PO_DN_CHK1	   = POH1      NOT INTERACT PO_Removed_Seed
POH2_after_PO_DN_CHK1	   = POH2      NOT INTERACT PO_Removed_Seed

PO_DN_CHK2 = (((((((ALL_POLY OR MOS_SRDPO_after_PO_DN_CHK1) OR STD_DPO_after_PO_DN_CHK1) OR CEL_SRDPO_after_PO_DN_CHK1) OR POB_after_PO_DN_CHK1) OR POS_after_PO_DN_CHK1) OR POH1_after_PO_DN_CHK1) OR POH2_after_PO_DN_CHK1) NOT HPDPO
PO_DENSITY_HIGH2 = DENSITY PO_DN_CHK2 > PO_DN_11 INSIDE OF LAYER bulk_pre WINDOW PO_DN_11_W STEP PO_DN_11_S BACKUP
PO_DN_11_Region2 = (SIZE PO_GATE_SEN BY (PO_DN_11_W + PO_DN_11_S2)) AND PO_DENSITY_HIGH2
PO_A_3_Region2 = DENSITY PO_DN_CHK2 > PO_A_3 WINDOW PO_A_3_W STEP PO_A_3_S INSIDE OF LAYER (SIZE (AREA PO_DN_CHK2 > PO_A_3_A) BY PO_A_3_G) BACKUP
PO_DN_4_1_Region2 = DENSITY PO_DN_CHK2 > PO_DN_4_1_buf WINDOW PO_DN_4_1_W STEP PO_DN_4_1_S INSIDE OF LAYER bulk_pre BACKUP
PO_DN_16_CHK2 = ((PO_DN_CHK2 NOT CPO) AND PMET) NOT (RHPO AND RPOi)
PO_DN_16_Region2 = DENSITY PO_DN_16_CHK2 > PO_DN_16_buf INSIDE OF LAYER MATCHING_S10 WINDOW PO_DN_16_W STEP PO_DN_16_S BACKUP
PO_R_28_CHK2 = (PO_DN_CHK2 NOT CPO) NOT (RHPO AND RPOi)
PO_R_28_Region2x = DENSITY PO_R_28_CHK2 >= PO_R_28_DN_buf INSIDE OF LAYER MATCHING_S10 WINDOW PO_R_28_W1 PO_R_28_W2 STEP PO_R_28_S1 PO_R_28_S2 BACKUP
PO_R_28_Region2y = DENSITY PO_R_28_CHK2 >= PO_R_28_DN_buf INSIDE OF LAYER MATCHING_S10 WINDOW PO_R_28_W2 PO_R_28_W1 STEP PO_R_28_S2 PO_R_28_S1 BACKUP
PO_R_28_Region2 = ENCLOSE RECTANGLE (OR PO_R_28_Region2x PO_R_28_Region2y) 0.001 PO_R_28+0.001 ORTHOGONAL ONLY
PO_A_4_CHK2 = ((PO_DN_CHK2 NOT CPO) AND PMET) NOT (RHPO AND RPOi)
PO_A_4_Region2a = DENSITY PO_A_4_CHK2 >= PO_A_4_DN_buf INSIDE OF LAYER bulk_pre WINDOW PO_A_4_W STEP PO_A_4_S BACKUP
PO_A_4_Region2 = AREA PO_A_4_Region2a > PO_A_4
PO_A_5_CHK2 = ((PO_DN_CHK2 NOT CPO) AND PMET) NOT (RHPO AND RPOi)
PO_A_5_Region2a = DENSITY PO_A_5_CHK2 >= PO_A_5_DN_buf INSIDE OF LAYER bulk_pre WINDOW PO_A_5_W STEP PO_A_5_S BACKUP
PO_A_5_Region2 = AREA PO_A_5_Region2a > PO_A_5
PO_DN_CHK_Region2 = ((((((PO_A_3_Region2 OR PO_DN_4_1_Region2) OR PO_DN_11_Region2) OR PO_DN_16_Region2) OR PO_R_28_Region2) OR PO_A_4_Region2) OR PO_A_5_Region2) NOT HPDPO
MOS_SRDPO_after_PO_DN_CHK2 = MOS_SRDPO_after_PO_DN_CHK1 NOT INTERACT (MOS_boundary INTERACT PO_DN_CHK_Region2)
STD_DPO_after_PO_DN_CHK2   = STD_DPO_after_PO_DN_CHK1   NOT INTERACT (STD_boundary INTERACT PO_DN_CHK_Region2)
CEL_SRDPO_after_PO_DN_CHK2 = CEL_SRDPO_after_PO_DN_CHK1 NOT INTERACT PO_DN_CHK_Region2
POB_after_PO_DN_CHK2       = POB_after_PO_DN_CHK1       NOT INTERACT PO_DN_CHK_Region2
POS_after_PO_DN_CHK2       = POS_after_PO_DN_CHK1       NOT INTERACT PO_DN_CHK_Region2
POH1_after_PO_DN_CHK2	   = POH1_after_PO_DN_CHK1		NOT INTERACT PO_DN_CHK_Region2
POH2_after_PO_DN_CHK2	   = POH2_after_PO_DN_CHK1		NOT INTERACT PO_DN_CHK_Region2

#IFDEF COMBINE_DODPO_DMVIA
#ENDIF

VARIABLE IND_OD_SIZE  1
VARIABLE IND_PO_SIZE  0.9
VARIABLE IND_space    0.05
VARIABLE IND_block    1.95
#IFDEF InsideINDDMY_HD_MD
INDDMYx_ori = SIZE INDDMY  BY (D2INDDMY  + grid) 
INDDMYx = (((((((((((DODx_ind OR DPOx_ind) OR xPRO) OR xMOS) OR xTCD) OR xSTD) OR xCEL) OR xODB) OR xPOB) OR xPOS) OR xPOH1) OR xPOH2) OR INDDMYx_ori
INDDMYo = SIZE (INDDMY_MD OR INDDMY_HD) BY -IND_block
IND = RECTANGLES IND_block IND_block IND_space INSIDE OF LAYER INDDMYo

IND_6_1_1 = SHRINK IND LEFT BY 0.95 BOTTOM BY 0.95 RIGHT BY (IND_block-1.95) TOP BY (IND_block-1.95)
IND_17_1_1 = SHRINK IND LEFT BY 0 BOTTOM BY 0 RIGHT BY (IND_block-0.9) TOP BY (IND_block-0.9)
IND_17_1 = COPY IND_17_1_1
IND_6_1 = COPY IND_6_1_1
IND_17_1_outside = IND_17_1 OUTSIDE INDDMYx
IND_6_1_outside  = IND_6_1  OUTSIDE INDDMYx
#ENDIF

#IFDEF FILL_SRDOD_SRDPO
ALL_SRDOD_pre = ((PRO_SRDOD OR MOS_SRDOD) OR CEL_SRDOD) OR ODB
    ALL_SRDOD = ALL_SRDOD_pre NOT INTERACT (EXT ALL_SRDOD_pre < SR_DOD_S_1 ABUT SINGULAR REGION)
GEN_SRDOD { COPY ALL_SRDOD }
DRC CHECK MAP GEN_SRDOD 6 7
#IFDEF USE_AREF
AREF SRDOD_1 0.31 0.3 2
AREF SRDOD_2 CO_CEL_SRDOD_W CO_CEL_SRDOD_L 2
#ELSE
#IFDEF USE_AUTOREF
AUTOREF PRE_FIX
#ENDIF
#ENDIF

ALL_SRDPO_pre = ((((MOS_SRDPO_after_PO_DN_CHK2 OR CEL_SRDPO_after_PO_DN_CHK2) OR POB_after_PO_DN_CHK2) OR POS_after_PO_DN_CHK2) OR POH1_after_PO_DN_CHK2) OR POH2_after_PO_DN_CHK2
    ALL_SRDPO = ALL_SRDPO_pre NOT INTERACT (EXT ALL_SRDPO_pre < SR_DPO_S_1 ABUT SINGULAR REGION)
GEN_SRDPO { COPY ALL_SRDPO }
DRC CHECK MAP GEN_SRDPO 17 7
#IFDEF USE_AREF
AREF SRDPO_1 0.03 0.46 2
AREF SRDPO_2 CO_CEL_SRDPO_W CO_CEL_SRDPO_L 2
