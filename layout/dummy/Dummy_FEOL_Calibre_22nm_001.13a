VARIABLE TCD2VTUHP            0.065 // VTUH_P.S.2
VARIABLE TCD2EHVT_N           0.065 // EHVT_N.S.2
VARIABLE TCD2EHVT_P           0.065 // EHVT_P.S.2
VARIABLE TCD2BJTDMY           0.065 // NP.R.1
VARIABLE TCD2NWDMY            0.6   // SR_DOD.S.8
VARIABLE TCD2RH               0.16  // RH_OD.S.4/RH_PO.S.3
VARIABLE TCD2DIODMY           0     //
VARIABLE TCD2SRESD            0.21  // SR_ESD.S.1
VARIABLE TCD2VAR              0.13  // VAR.S.1
VARIABLE TCD2INDDMY           1.2   // SR_DOD.S.10
VARIABLE TCD2ODBLK            0     //
VARIABLE TCD2POBLK            0     //
VARIABLE TCD2VTULN            0.065 // VTUL_N.S.5
VARIABLE TCD2VTULP            0.065 // VTUL_P.S.5
VARIABLE TCD2MOMDMY           0     //
VARIABLE TCD2POFUSE           1     //
VARIABLE TCD2LOGO             0     //
VARIABLE TCD2TCDDMY           150   // for idu measurement
VARIABLE TCD2ICOVL            15     // ICOVL.S.3
VARIABLE TCD2NWLVT            1     // NW.S.3/4
VARIABLE TCD2SRAMDMY          0.115 // SRAM.S.2
VARIABLE TCD2PMET             0.04  // PMET.S.3
VARIABLE TCD2GB1_5            0     //
VARIABLE TCD2GB_D2            0     //
VARIABLE TCD2SRAMDMY_WLD6            0     //
VARIABLE TCD2GATED            0     //
VARIABLE TCD2POC              0     //
VARIABLE TCD2FTCDBLK          0     //

TCDxChip         = CHIP NOT (SIZE CHIP BY -(TCD2Chip + grid))
TCDxDNW          = (SIZE DNWi BY (TCD2DNW_edge_outside + grid)) NOT (SIZE DNWi BY -(TCD2DNW_edge_inside + grid))
TCDxNW           = SIZE NWi                   BY (TCD2NW           + grid)
TCDxOD           = SIZE ODi                   BY (TCD2OD           + grid)
TCDxOD_in_BJTDMY = SIZE (ODi INTERACT BJTDMY) BY (TCD2OD_in_BJTDMY + grid)
TCDxOD_in_RH     = SIZE (ODi INTERACT RH    ) BY (TCD2OD_in_RH     + grid)
TCDxDOD          = SIZE DOD                   BY (TCD2DOD          + grid)
TCDxSRDOD        = SIZE SRDOD                 BY (TCD2SRDOD        + grid)
TCDxNTN          = SIZE NTNi                  BY (TCD2NTN          + grid)
TCDxVTZ_N        = SIZE VTZ_N                 BY (TCD2VTZ_N        + grid)
TCDxVTLN         = SIZE VTLNi                 BY (TCD2VTLN         + grid)
TCDxVTLP         = SIZE VTLPi                 BY (TCD2VTLP         + grid)
TCDxOD2          = SIZE OD2                   BY (TCD2OD2          + grid)
TCDxPO           = SIZE POi                   BY (TCD2PO           + grid)
TCDxDPO          = SIZE DPO                   BY (TCD2DPO          + grid)
TCDxSRDPO        = SIZE SRDPO                 BY (TCD2SRDPO        + grid)
TCDxCPO          = SIZE CPO                   BY (TCD2CPO          + grid)
TCDxmVTL         = SIZE mVTLi                 BY (TCD2mVTL         + grid)
TCDxPP           = SIZE PPi                   BY (TCD2PP           + grid)
TCDxNP           = SIZE NPi                   BY (TCD2NP           + grid)
TCDxRPO          = SIZE RPOi                  BY (TCD2RPO          + grid)
TCDxSRM          = SIZE SRM                   BY (TCD2SRM          + grid)
TCDxVTHN         = SIZE VTHNi                 BY (TCD2VTHN         + grid)
TCDxVTHP         = SIZE VTHPi                 BY (TCD2VTHP         + grid)
TCDxCHVT_N       = SIZE CHVT_N                BY (TCD2CHVT_N       + grid)
TCDxVTLNIO       = SIZE VTLNIOi               BY (TCD2VTLNIO       + grid)
TCDxVTUHN        = SIZE VTUHNi                BY (TCD2VTUHN        + grid)
TCDxVTUHP        = SIZE VTUHPi                BY (TCD2VTUHP        + grid)
TCDxEHVT_N       = SIZE EHVT_N                BY (TCD2EHVT_N       + grid)
TCDxEHVT_P       = SIZE EHVT_P                BY (TCD2EHVT_P       + grid)
TCDxBJTDMY       = SIZE BJTDMY                BY (TCD2BJTDMY       + grid)
TCDxNWDMY        = SIZE NWDMY                 BY (TCD2NWDMY        + grid)
TCDxRH           = SIZE RH                    BY (TCD2RH           + grid)
TCDxDIODMY       = SIZE DIODMY                BY (TCD2DIODMY       + grid)
TCDxSRESD        = SIZE SRESD                 BY (TCD2SRESD        + grid)
TCDxVAR          = SIZE VARi                  BY (TCD2VAR          + grid)
TCDxINDDMY       = SIZE INDDMY_all            BY (TCD2INDDMY       + grid)
TCDxODBLK        = SIZE ODBLK                 BY (TCD2ODBLK        + grid)
TCDxPOBLK        = SIZE POBLK                 BY (TCD2POBLK        + grid)
TCDxVTULN        = SIZE VTULNi                BY (TCD2VTULN        + grid)
TCDxVTULP        = SIZE VTULPi                BY (TCD2VTULP        + grid)
TCDxMOMDMY       = SIZE MOMDMY                BY (TCD2MOMDMY       + grid)
TCDxPOFUSE       = SIZE POFUSE                BY (TCD2POFUSE       + grid)
TCDxLOGO         = SIZE LOGO                  BY (TCD2LOGO         + grid)
TCDxTCDDMY       = SIZE TCDDMY                BY (TCD2TCDDMY       + grid)
TCDxICOVL        = SIZE ICOVL                 BY (TCD2ICOVL        + grid)
TCDxNWLVT        = SIZE NWLVTi                BY (TCD2NWLVT        + grid)
TCDxSRAMDMY      = SIZE SRAMDMY               BY (TCD2SRAMDMY      + grid)
TCDxPMET         = SIZE PMET                  BY (TCD2PMET         + grid)
TCDxGB1_5        = SIZE GB1_5                 BY (TCD2GB1_5        + grid)
TCDxGB_D2        = SIZE GB_D2                 BY (TCD2GB_D2        + grid)
TCDxSRAMDMY_WLD6        = SIZE SRAMDMY_WLD6                 BY (TCD2SRAMDMY_WLD6        + grid)
TCDxGATED        = SIZE GATED                 BY (TCD2GATED        + grid)
TCDxPOC          = SIZE POC                   BY (TCD2POC          + grid)
TCDxFTCDBLK      = SIZE FTCDBLK               BY (TCD2FTCDBLK      + grid)

TCDx = (((((((((((((((((((((((((((((((((((((((((((((((((((((TCDxChip OR TCDxDNW) OR TCDxNW) OR TCDxOD) OR TCDxOD_in_BJTDMY) OR TCDxOD_in_RH) OR TCDxDOD) OR TCDxSRDOD) OR TCDxNTN) OR TCDxVTZ_N) OR TCDxVTLN) OR TCDxVTLP) OR TCDxOD2) OR TCDxPO) OR TCDxDPO) OR TCDxSRDPO) OR TCDxCPO) OR TCDxmVTL) OR TCDxPP) OR TCDxNP) OR TCDxRPO) OR TCDxSRM) OR TCDxVTHN) OR TCDxVTHP) OR TCDxCHVT_N) OR TCDxVTLNIO) OR TCDxVTUHN) OR TCDxVTUHP) OR TCDxEHVT_N) OR TCDxEHVT_P) OR TCDxBJTDMY) OR TCDxNWDMY) OR TCDxRH) OR TCDxDIODMY) OR TCDxSRESD) OR TCDxVAR) OR TCDxINDDMY) OR TCDxODBLK) OR TCDxPOBLK) OR TCDxVTULN) OR TCDxVTULP) OR TCDxMOMDMY) OR TCDxPOFUSE) OR TCDxLOGO) OR TCDxTCDDMY) OR TCDxICOVL) OR TCDxNWLVT) OR TCDxSRAMDMY) OR TCDxPMET) OR TCDxGB1_5) OR TCDxGB_D2) OR TCDxGATED) OR TCDxPOC) OR TCDxFTCDBLK) OR TCDxSRAMDMY_WLD6

TCDo = (((CHIP NOT MOS_ROUNDo) NOT TCDx) NOT xPRO) NOT xMOS

VARIABLE TCD_H_W 9
