#ELSE
STD_DOD = COPY EMPTY
STD_DPO = COPY EMPTY
STD_PP = COPY EMPTY
STD_boundary = COPY EMPTY
xSTD = COPY EMPTY
#ENDIF


#IFDEF FILL_SRDOD_SRDPO
CELo_pre = (((((CHIP NOT SRDODx) NOT SRDPOx) NOT xPRO) NOT xMOS) NOT xTCD) NOT xSTD
IOhigh_CEL_o = CELo_pre AND HPDPO
                IOhigh_CEL_o_1 = IOhigh_CEL_o WITH WIDTH >= IOhigh_CEL_W
            IOhigh_CEL_1 = RECTANGLES IOhigh_CEL_W IOhigh_CEL_L IOhigh_CEL_W_S IOhigh_CEL_L_S OFFSET IOhigh_CEL_W_O IOhigh_CEL_L_O INSIDE OF LAYER IOhigh_CEL_o_1
                IOhigh_CEL_union_1 = COPY IOhigh_CEL_1

                IOhigh_CEL_o_2 = (IOhigh_CEL_o_1 NOT (SIZE IOhigh_CEL_union_1 BY IOhigh_CEL_L_S)) WITH WIDTH >= IOhigh_CEL_W
            IOhigh_CEL_2 = RECTANGLES IOhigh_CEL_W IOhigh_CEL_L IOhigh_CEL_W_S IOhigh_CEL_L_S OFFSET IOhigh_CEL_W_O IOhigh_CEL_L_O INSIDE OF LAYER IOhigh_CEL_o_2
                IOhigh_CEL_union_2 = IOhigh_CEL_union_1 OR IOhigh_CEL_2

                IOhigh_CEL_o_3 = (IOhigh_CEL_o_2 NOT (SIZE IOhigh_CEL_union_2 BY IOhigh_CEL_L_S)) WITH WIDTH >= IOhigh_CEL_W
            IOhigh_CEL_3 = RECTANGLES IOhigh_CEL_W IOhigh_CEL_L IOhigh_CEL_W_S IOhigh_CEL_L_S OFFSET IOhigh_CEL_W_O IOhigh_CEL_L_O INSIDE OF LAYER IOhigh_CEL_o_3
                IOhigh_CEL_union_3 = IOhigh_CEL_union_2 OR IOhigh_CEL_3

        IOhigh_CEL = COPY IOhigh_CEL_union_3

IOhigh_CEL_SRDOD = SHRINK IOhigh_CEL LEFT  BY IOhigh_CEL_SRDOD_W_SHRINK
IOhigh_CEL_SRDPO = SHRINK IOhigh_CEL RIGHT BY IOhigh_CEL_SRDPO_W_SHRINK

CELo = CELo_pre NOT (SIZE IOhigh_CEL BY IO_CEL_L_S)

CEL_Vo = (CELo INTERACT POR7_GATE_V) OR (CELo NOT INTERACT (POR7_GATE_V OR POR7_GATE_H))
CEL_Ho = (CELo NOT CEL_Vo) INTERACT POR7_GATE_H
IO_CEL_Vo = CEL_Vo AND OD2
IO_CEL_Ho = CEL_Ho AND OD2
CO_CEL_Vo = CEL_Vo NOT OD2
CO_CEL_Ho = CEL_Ho NOT OD2
                IO_CEL_Vo_1 = IO_CEL_Vo WITH WIDTH >= IO_CEL_W
            IO_CEL_V_1 = RECTANGLES IO_CEL_W IO_CEL_L IO_CEL_W_S IO_CEL_L_S OFFSET IO_CEL_W_O IO_CEL_L_O INSIDE OF LAYER IO_CEL_Vo_1
                IO_CEL_V_union_1 = COPY IO_CEL_V_1

                IO_CEL_Vo_2 = (IO_CEL_Vo_1 NOT (SIZE IO_CEL_V_union_1 BY IO_CEL_L_S)) WITH WIDTH >= IO_CEL_W
            IO_CEL_V_2 = RECTANGLES IO_CEL_W IO_CEL_L IO_CEL_W_S IO_CEL_L_S OFFSET IO_CEL_W_O IO_CEL_L_O INSIDE OF LAYER IO_CEL_Vo_2
                IO_CEL_V_union_2 = IO_CEL_V_union_1 OR IO_CEL_V_2

                IO_CEL_Vo_3 = (IO_CEL_Vo_2 NOT (SIZE IO_CEL_V_union_2 BY IO_CEL_L_S)) WITH WIDTH >= IO_CEL_W
            IO_CEL_V_3 = RECTANGLES IO_CEL_W IO_CEL_L IO_CEL_W_S IO_CEL_L_S OFFSET IO_CEL_W_O IO_CEL_L_O INSIDE OF LAYER IO_CEL_Vo_3
                IO_CEL_V_union_3 = IO_CEL_V_union_2 OR IO_CEL_V_3

        IO_CEL_V = COPY IO_CEL_V_union_3

IO_CEL_SRDOD_V = SHRINK IO_CEL_V LEFT BY IO_CEL_SRDOD_W_SHRINK
IO_CEL_SRDPO_V = SHRINK IO_CEL_V RIGHT BY IO_CEL_SRDPO_W_SHRINK

IO_CEL_H1o = IO_CEL_Ho NOT (SIZE IO_CEL_V BY IO_CEL_L_S)
                IO_CEL_H1o_1 = IO_CEL_H1o WITH WIDTH >= IO_CEL_W
            IO_CEL_H_1 = RECTANGLES IO_CEL_L IO_CEL_W IO_CEL_L_S IO_CEL_W_S OFFSET IO_CEL_L_O IO_CEL_W_O INSIDE OF LAYER IO_CEL_H1o_1
                IO_CEL_H_union_1 = COPY IO_CEL_H_1

                IO_CEL_H1o_2 = (IO_CEL_H1o_1 NOT (SIZE IO_CEL_H_union_1 BY IO_CEL_L_S)) WITH WIDTH >= IO_CEL_W
            IO_CEL_H_2 = RECTANGLES IO_CEL_L IO_CEL_W IO_CEL_L_S IO_CEL_W_S OFFSET IO_CEL_L_O IO_CEL_W_O INSIDE OF LAYER IO_CEL_H1o_2
                IO_CEL_H_union_2 = IO_CEL_H_union_1 OR IO_CEL_H_2

                IO_CEL_H1o_3 = (IO_CEL_H1o_2 NOT (SIZE IO_CEL_H_union_2 BY IO_CEL_L_S)) WITH WIDTH >= IO_CEL_W
            IO_CEL_H_3 = RECTANGLES IO_CEL_L IO_CEL_W IO_CEL_L_S IO_CEL_W_S OFFSET IO_CEL_L_O IO_CEL_W_O INSIDE OF LAYER IO_CEL_H1o_3
                IO_CEL_H_union_3 = IO_CEL_H_union_2 OR IO_CEL_H_3

        IO_CEL_H = COPY IO_CEL_H_union_3

IO_CEL_SRDOD_H = SHRINK IO_CEL_H BOTTOM BY IO_CEL_SRDOD_W_SHRINK
IO_CEL_SRDPO_H = SHRINK IO_CEL_H TOP BY IO_CEL_SRDPO_W_SHRINK

CO_CEL_V1o = CO_CEL_Vo NOT (SIZE (IO_CEL_V OR IO_CEL_H) BY IO_CEL_L_S)
                CO_CEL_V1o_1 = CO_CEL_V1o WITH WIDTH >= CO_CEL_W
            CO_CEL_V_1 = RECTANGLES CO_CEL_W CO_CEL_L CO_CEL_W_S CO_CEL_L_S OFFSET CO_CEL_W_O CO_CEL_L_O INSIDE OF LAYER CO_CEL_V1o_1
                CO_CEL_V_union_1 = COPY CO_CEL_V_1

                CO_CEL_V1o_2 = (CO_CEL_V1o_1 NOT (SIZE CO_CEL_V_union_1 BY CO_CEL_L_S)) WITH WIDTH >= CO_CEL_W
            CO_CEL_V_2 = RECTANGLES CO_CEL_W CO_CEL_L CO_CEL_W_S CO_CEL_L_S OFFSET CO_CEL_W_O CO_CEL_L_O INSIDE OF LAYER CO_CEL_V1o_2
                CO_CEL_V_union_2 = CO_CEL_V_union_1 OR CO_CEL_V_2

                CO_CEL_V1o_3 = (CO_CEL_V1o_2 NOT (SIZE CO_CEL_V_union_2 BY CO_CEL_L_S)) WITH WIDTH >= CO_CEL_W
            CO_CEL_V_3 = RECTANGLES CO_CEL_W CO_CEL_L CO_CEL_W_S CO_CEL_L_S OFFSET CO_CEL_W_O CO_CEL_L_O INSIDE OF LAYER CO_CEL_V1o_3
                CO_CEL_V_union_3 = CO_CEL_V_union_2 OR CO_CEL_V_3

                CO_CEL_V1o_4 = (CO_CEL_V1o_3 NOT (SIZE CO_CEL_V_union_3 BY CO_CEL_L_S)) WITH WIDTH >= CO_CEL_W
            CO_CEL_V_4 = RECTANGLES CO_CEL_W CO_CEL_L CO_CEL_W_S CO_CEL_L_S OFFSET CO_CEL_W_O CO_CEL_L_O INSIDE OF LAYER CO_CEL_V1o_4
                CO_CEL_V_union_4 = CO_CEL_V_union_3 OR CO_CEL_V_4

                CO_CEL_V1o_5 = (CO_CEL_V1o_4 NOT (SIZE CO_CEL_V_union_4 BY CO_CEL_L_S)) WITH WIDTH >= CO_CEL_W
            CO_CEL_V_5 = RECTANGLES CO_CEL_W CO_CEL_L CO_CEL_W_S CO_CEL_L_S OFFSET CO_CEL_W_O CO_CEL_L_O INSIDE OF LAYER CO_CEL_V1o_5
                CO_CEL_V_union_5 = CO_CEL_V_union_4 OR CO_CEL_V_5

        CO_CEL_V = COPY CO_CEL_V_union_5

CO_CEL_SRDOD_V = SHRINK CO_CEL_V LEFT BY CO_CEL_SRDOD_W_SHRINK
CO_CEL_SRDPO_V = SHRINK CO_CEL_V RIGHT BY CO_CEL_SRDPO_W_SHRINK

CO_CEL_H1o = CO_CEL_Ho NOT (SIZE ((IO_CEL_V OR IO_CEL_H) OR CO_CEL_V) BY IO_CEL_L_S)
                CO_CEL_H1o_1 = CO_CEL_H1o WITH WIDTH >= CO_CEL_W
            CO_CEL_H_1 = RECTANGLES CO_CEL_L CO_CEL_W CO_CEL_L_S CO_CEL_W_S OFFSET CO_CEL_L_O CO_CEL_W_O INSIDE OF LAYER CO_CEL_H1o_1
                CO_CEL_H_union_1 = COPY CO_CEL_H_1

                CO_CEL_H1o_2 = (CO_CEL_H1o_1 NOT (SIZE CO_CEL_H_union_1 BY CO_CEL_L_S)) WITH WIDTH >= CO_CEL_W
            CO_CEL_H_2 = RECTANGLES CO_CEL_L CO_CEL_W CO_CEL_L_S CO_CEL_W_S OFFSET CO_CEL_L_O CO_CEL_W_O INSIDE OF LAYER CO_CEL_H1o_2
                CO_CEL_H_union_2 = CO_CEL_H_union_1 OR CO_CEL_H_2

                CO_CEL_H1o_3 = (CO_CEL_H1o_2 NOT (SIZE CO_CEL_H_union_2 BY CO_CEL_L_S)) WITH WIDTH >= CO_CEL_W
            CO_CEL_H_3 = RECTANGLES CO_CEL_L CO_CEL_W CO_CEL_L_S CO_CEL_W_S OFFSET CO_CEL_L_O CO_CEL_W_O INSIDE OF LAYER CO_CEL_H1o_3
                CO_CEL_H_union_3 = CO_CEL_H_union_2 OR CO_CEL_H_3

                CO_CEL_H1o_4 = (CO_CEL_H1o_3 NOT (SIZE CO_CEL_H_union_3 BY CO_CEL_L_S)) WITH WIDTH >= CO_CEL_W
            CO_CEL_H_4 = RECTANGLES CO_CEL_L CO_CEL_W CO_CEL_L_S CO_CEL_W_S OFFSET CO_CEL_L_O CO_CEL_W_O INSIDE OF LAYER CO_CEL_H1o_4
                CO_CEL_H_union_4 = CO_CEL_H_union_3 OR CO_CEL_H_4

                CO_CEL_H1o_5 = (CO_CEL_H1o_4 NOT (SIZE CO_CEL_H_union_4 BY CO_CEL_L_S)) WITH WIDTH >= CO_CEL_W
            CO_CEL_H_5 = RECTANGLES CO_CEL_L CO_CEL_W CO_CEL_L_S CO_CEL_W_S OFFSET CO_CEL_L_O CO_CEL_W_O INSIDE OF LAYER CO_CEL_H1o_5
                CO_CEL_H_union_5 = CO_CEL_H_union_4 OR CO_CEL_H_5

        CO_CEL_H = COPY CO_CEL_H_union_5

CO_CEL_SRDOD_H = SHRINK CO_CEL_H BOTTOM BY CO_CEL_SRDOD_W_SHRINK
CO_CEL_SRDPO_H = SHRINK CO_CEL_H TOP BY CO_CEL_SRDPO_W_SHRINK

IO_CEL_SRDOD_pre = (IO_CEL_SRDOD_V OR IO_CEL_SRDOD_H) OR IOhigh_CEL_SRDOD
    IO_CEL_SRDOD = IO_CEL_SRDOD_pre NOT INTERACT (EXT IO_CEL_SRDOD_pre < SR_DOD_S_12 ABUT SINGULAR REGION)

CO_CEL_SRDOD_pre = CO_CEL_SRDOD_V OR CO_CEL_SRDOD_H
    CO_CEL_SRDOD = CO_CEL_SRDOD_pre NOT INTERACT (EXT CO_CEL_SRDOD_pre < SR_DOD_S_1 ABUT SINGULAR REGION)

CEL_SRDOD_pre = IO_CEL_SRDOD OR CO_CEL_SRDOD
    CEL_SRDOD = CEL_SRDOD_pre NOT INTERACT (EXT CEL_SRDOD_pre < SR_DOD_S_1 ABUT SINGULAR REGION)

CEL_SRDPO_pre = (((IO_CEL_SRDPO_V OR IO_CEL_SRDPO_H) OR CO_CEL_SRDPO_V) OR CO_CEL_SRDPO_H) OR IOhigh_CEL_SRDPO
    CEL_SRDPO_pre1 = CEL_SRDPO_pre NOT INTERACT (EXT CEL_SRDPO_pre < SR_DPO_S_1 ABUT SINGULAR REGION)

CEL_SRDPO = CEL_SRDPO_pre1 NOT INTERACT (EXT CEL_SRDPO_pre1 CEL_SRDOD < SR_DOD_S_3 ABUT SINGULAR REGION)

xCEL = SIZE ((((IO_CEL_V OR IO_CEL_H) OR CO_CEL_V) OR CO_CEL_H) OR IOhigh_CEL) BY NEXT_S3
#ELSE
CEL_SRDOD = COPY EMPTY
CEL_SRDPO = COPY EMPTY
xCEL = COPY EMPTY
#ENDIF


#IFDEF FILL_SRDOD_SRDPO
ODBo = (((((CHIP NOT SRDODx) NOT xPRO) NOT xMOS) NOT xTCD) NOT xSTD) NOT xCEL
ODB_Vo = (ODBo INTERACT POR7_GATE_V) OR (ODBo NOT INTERACT (POR7_GATE_V OR POR7_GATE_H))
