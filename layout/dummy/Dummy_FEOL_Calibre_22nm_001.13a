VAR	= COPY VARi
NW55 = COPY NW55i
NW65 = COPY NW65i
PO55 = COPY PO55i
PO65 = COPY PO65i
ILP1i = (POi NOT RPO_RPDMY) NOT (CPO OR CPO_SRM) // Interconnect poly not CPO
DNW_NWi = NWi INTERACT DNWi
RWi = ((HOLES DNW_NWi) NOT DNW_NWi) INSIDE DNWi
NWEL = COPY NWi
BULKx        = SIZE CHIP BY 1.0
PWELi        = BULKx NOT NWi
NWRiT = (NWi INTERACT NWDMY) NOT NWDMY // NWR terminal  
CB1i = CBi OR CBDi
OD12    = COPY OD12i
OD15    = COPY OD15i
OD18    = COPY OD18i
OD25    = COPY OD25i
OD33    = COPY OD33i
RPO_RPDMY    = RPOi OR RPDMY		// resistor marker layers
NONWRi = NWi NOT INTERACT NWDMY 
NPODi = NPi AND ODi
PPODi = PPi AND ODi
NACTi = NPODi NOT NWi
PACTi = PPODi AND NWi
NSDi  = NACTi NOT POi		// NMOS source/drain
NSDc  = NSDi NOT RPO_RPDMY	// NMOS source/drain for connection
PSDi  = PACTi NOT POi		// PMOS source/drain
PSDc  = PSDi NOT RPO_RPDMY	// PMOS source/drain for connection
ODc = (NSDc OR PSDc) OR (PSTPi OR NSTPi)
NSTPi = NPODi AND NONWRi        // Break the connection at NWR  
PSTPi = PPODi NOT NWi

CONNECT NWEL DNWi    
CONNECT NWi DNWi 
CONNECT NSTPi NWi                 
CONNECT NSTPi PSDc   
CONNECT PSTPi RWi  
CONNECT PSTPi PWELi     
CONNECT PSTPi NSDc   
CONNECT NSDc ODc  
CONNECT PSDc ODc     
CONNECT PSTPi ODc     
CONNECT NSTPi ODc     
CONNECT GATE ILP1i




