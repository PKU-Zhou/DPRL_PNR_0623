            IO_ODB_V_3 = RECTANGLES IO_ODB_W IO_ODB_L IO_ODB_W_S IO_ODB_L_S OFFSET IO_ODB_W_O IO_ODB_L_O INSIDE OF LAYER IO_ODB_Vo_3
                IO_ODB_V_union_3 = IO_ODB_V_union_2 OR IO_ODB_V_3

        IO_ODB_V = COPY IO_ODB_V_union_3


IO_ODB_H1o = IO_ODB_Ho NOT (SIZE IO_ODB_V BY IO_ODB_L_S)
                IO_ODB_H1o_1 = IO_ODB_H1o WITH WIDTH >= IO_ODB_W
            IO_ODB_H_1 = RECTANGLES IO_ODB_L IO_ODB_W IO_ODB_L_S IO_ODB_W_S OFFSET IO_ODB_L_O IO_ODB_W_O INSIDE OF LAYER IO_ODB_H1o_1
                IO_ODB_H_union_1 = COPY IO_ODB_H_1

                IO_ODB_H1o_2 = (IO_ODB_H1o_1 NOT (SIZE IO_ODB_H_union_1 BY IO_ODB_L_S)) WITH WIDTH >= IO_ODB_W
            IO_ODB_H_2 = RECTANGLES IO_ODB_L IO_ODB_W IO_ODB_L_S IO_ODB_W_S OFFSET IO_ODB_L_O IO_ODB_W_O INSIDE OF LAYER IO_ODB_H1o_2
                IO_ODB_H_union_2 = IO_ODB_H_union_1 OR IO_ODB_H_2

                IO_ODB_H1o_3 = (IO_ODB_H1o_2 NOT (SIZE IO_ODB_H_union_2 BY IO_ODB_L_S)) WITH WIDTH >= IO_ODB_W
            IO_ODB_H_3 = RECTANGLES IO_ODB_L IO_ODB_W IO_ODB_L_S IO_ODB_W_S OFFSET IO_ODB_L_O IO_ODB_W_O INSIDE OF LAYER IO_ODB_H1o_3
