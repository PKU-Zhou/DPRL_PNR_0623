#IFDEF FILL_SRDOD_SRDPO
POBo = ((((((CHIP NOT SRDPOx) NOT xPRO) NOT xMOS) NOT xTCD) NOT xSTD) NOT xCEL) NOT xODB
POB_Vo = (POBo INTERACT POR7_GATE_V) OR (POBo NOT INTERACT (POR7_GATE_V OR POR7_GATE_H))
POB_Ho = (POBo NOT POB_Vo) INTERACT POR7_GATE_H
