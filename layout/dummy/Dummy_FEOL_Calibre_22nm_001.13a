// begin pre-generation process : find open area
// *********************************************
#IFDEF UseprBoundary
  bulk_pre = COPY prBoundary
#ELSE
#IFDEF ChipWindowUsed
  POLYGON xLB yLB xRT yRT ChipWindow
  bulk_pre = PUSH ChipWindow
#ELSE
  bulk_ext = EXTENT MT_LAYERS
  bulk_pre = PUSH bulk_ext
#ENDIF
#ENDIF

#IFDEF WithSealring
  bulk = SIZE bulk_pre BY -(SRwidth + grid)
#ELSE
  bulk = COPY bulk_pre
#ENDIF

#IFDEF dmOnCorner
  CHIP = COPY bulk
#ELSE
// for seal-ring and chip corner excluding regions.
  EMPTY_AREA = INT bulk < CSR_R_1 ABUT==90 REGION INTERSECTING ONLY
  CHIP = bulk NOT EMPTY_AREA
#ENDIF

VARIABLE grid    0.005
VARIABLE CSR_R_1 74
VARIABLE SRwidth 24.0      // width of sealring including CDU and isolation regions



VARIABLE NEXT_S1 0.5    // DPO.S.3
VARIABLE NEXT_S2 0.15
VARIABLE NEXT_S3 0.16   // PO.S.21


VARIABLE MOS_ROUND_RANGE 4
VARIABLE MOS_OD_MERGE_SPACE 0.15
