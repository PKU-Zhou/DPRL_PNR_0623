VARIABLE PO_S_36_S    0.06
VARIABLE PO_S_36A     0.18

// post-remove for high poly density (PO.A.3, PO.DN.4.1)
// PO.A.3 : maximum poly local density [window 10um*10um, stepping 5um] inside {poly [area > 3um^2] SIZING 5um} <= 0.5
VARIABLE PO_A_3   0.5
VARIABLE PO_A_3_A 3
VARIABLE PO_A_3_G 5
VARIABLE PO_A_3_W 10
VARIABLE PO_A_3_S 5

// PO.DN.4.1 : maximum poly local density [window 10um*10um, stepping 5um] <= 0.65
VARIABLE PO_DN_4_1   0.65
VARIABLE PO_DN_4_1_buf   PO_DN_4_1 - 0.01  //1% buffer
VARIABLE PO_DN_4_1_W 10
VARIABLE PO_DN_4_1_S 5

// PO.DN.11 : "Sensitive GATE" interact the region of {(PO local density >45%) SIZING 5um} is not allow 
VARIABLE PO_DN_11      0.45
VARIABLE PO_DN_11_W    20
VARIABLE PO_DN_11_S    10
VARIABLE PO_DN_11_L    0.04
VARIABLE PO_DN_11_S2   5

// PO.DN.16 : Maximum {{{{{PO OR SR_DPO} OR DPO} NOT CPO} AND PMET} NOT {RH_PO AND RPO}} local density in {{{MATCHING OR ANARRAY_H} OR ANARRAY_M} SIZING 10um} <= 0.50
VARIABLE PO_DN_16		0.5
VARIABLE PO_DN_16_buf  PO_DN_16 - 0.01		// 1% buffer
VARIABLE PO_DN_16_W    10
VARIABLE PO_DN_16_S    5

// PO.R.28 :   Maximum width or length of high {{{{PO OR SR_DPO} OR DPO} NOT CPO} NOT {RH_PO AND RPO}} density region >= 65% in {{{MATCHING OR ANARRAY_H} OR ANARRAY_M} SIZING 10 um}, by checking window 3 um x 10 um, stepping 1.5 um x 5 um, and 10 um x 3 um, stepping 5 um x 1.5 um respectively. <= 60
VARIABLE PO_R_28_DN		0.65
VARIABLE PO_R_28		60
VARIABLE PO_R_28_DN_buf	PO_R_28_DN - 0.01 	// 1% buffer
VARIABLE PO_R_28_W1		3
VARIABLE PO_R_28_W2		10
VARIABLE PO_R_28_S1		1.5
VARIABLE PO_R_28_S2		5

// PO.A.4 : Maximum area of High_PMET_DN_region1 as 50% <= {{{{{PO OR SR_DPO} OR DPO} NOT CPO} AND PMET} NOT {RH_PO AND RPO}} density < 55% by window 20 um x 20 um, stepping 10 um <= 500000
// PO.A.5 : Maximum area of High_PMET_DN_region2 as 55% <= {{{{{PO OR SR_DPO} OR DPO} NOT CPO} AND PMET} NOT {RH_PO AND RPO}} density       by window 20 um x 20 um, stepping 10 um <= 300000
// PO.A.6 : Maximum area of High_PMET_DN_region3 as 50% <= {{{{{PO OR SR_DPO} OR DPO} NOT CPO} AND PMET} NOT {RH_PO AND RPO}} density       by window 20 um x 20 um, stepping 10 um <= 1000000
VARIABLE PO_A_4			500000
VARIABLE PO_A_4_DN		0.50				// 50%
VARIABLE PO_A_4_DN_buf	PO_A_4_DN - 0.01 	// 1% buffer
VARIABLE PO_A_4_W		20
VARIABLE PO_A_4_S		10

VARIABLE PO_A_5			300000
VARIABLE PO_A_5_DN		0.55				// 55%
VARIABLE PO_A_5_DN_buf	PO_A_5_DN - 0.01 	// 1% buffer
VARIABLE PO_A_5_W		20
VARIABLE PO_A_5_S		10

// poly removed criteria
VARIABLE PO_Removed_Seed_W 0.075
VARIABLE PO_Removed_Seed_S 2.195
VARIABLE PO_Removed_Seed_O 0.015



xCHIP    = CHIP NOT (SIZE CHIP BY -(D2CHIP + grid))
xBJTDMY  = SIZE BJTDMY  BY (D2BJTDMY  + grid)
xSRESD   = SIZE SRESD   BY (D2SRESD   + grid)
xINDDMY  = SIZE INDDMY_all  BY (D2INDDMY  + grid)
xPOFUSE  = SIZE POFUSE  BY (D2POFUSE  + grid)
xTCDDMY  = SIZE TCDDMY  BY (D2TCDDMY  + grid)
xSRAMDMY = SIZE SRAMDMY BY (D2SRAMDMY + grid)
xGB      = SIZE GB      BY (D2GB      + grid)
xICOVL   = SIZE ICOVL   BY (D2ICOVL   + grid)
x     = (((((((xCHIP OR xBJTDMY) OR xSRESD) OR xINDDMY) OR xPOFUSE) OR xTCDDMY) OR xSRAMDMY) OR xGB) OR xICOVL
x_ind = ((((((xCHIP OR xBJTDMY) OR xSRESD) OR xPOFUSE) OR xTCDDMY) OR xSRAMDMY) OR xGB) OR xICOVL

SRDODxNW     = (SIZE NWi    BY (SRDOD2NW     + grid)) NOT (SIZE NWi    BY -(SRDOD2NW     + grid))
SRDODxOD     =  SIZE ODi    BY (SRDOD2OD     + grid)
SRDODxOD45   =  SIZE (EXPAND EDGE (ANGLE ODi == 45) OUTSIDE BY SRDOD2OD45) BY grid
SRDODxDOD    =  SIZE DOD    BY (SRDOD2DOD    + grid)
SRDODxSRDOD  =  SIZE SRDOD  BY (SRDOD2SRDOD  + grid)
SRDODxNTN    =  SIZE NTNi   BY (SRDOD2NTN    + grid)
SRDODxOD2    = (SIZE OD2    BY (SRDOD2OD2    + grid)) NOT (SIZE OD2    BY -(SRDOD2OD2    + grid))
SRDODxPO     =  SIZE POi    BY (SRDOD2PO     + grid)
SRDODxDPO    =  SIZE DPO    BY (SRDOD2DPO    + grid)
SRDODxSRDPO  =  SIZE SRDPO  BY (SRDOD2SRDPO  + grid)
SRDODxPP     = (SIZE PPi    BY (SRDOD2PP     + grid)) NOT (SIZE PPi    BY -(SRDOD2PP     + grid))
SRDODxRPO    = (SIZE RPOi   BY (SRDOD2RPO    + grid)) NOT (SIZE RPOi   BY -(SRDOD2RPO    + grid))
SRDODxNWDMY  =  SIZE NWDMY  BY (SRDOD2NWDMY  + grid)
SRDODxRHOD   = (SIZE RHOD   BY (SRDOD2RHOD   + grid)) NOT (SIZE RHOD   BY -(SRDOD2RHOD   + grid))
SRDODxRHPO   = (SIZE RHPO   BY (SRDOD2RHPO   + grid)) NOT (SIZE RHPO   BY -(SRDOD2RHPO   + grid))
SRDODxDIODMY = (SIZE DIODMY BY (SRDOD2DIODMY + grid)) NOT (SIZE DIODMY BY -(SRDOD2DIODMY + grid))
SRDODxVAR    = (SIZE VARi   BY (SRDOD2VAR    + grid)) NOT (SIZE VARi   BY -(SRDOD2VAR    + grid))
SRDODxODBLK  =  SIZE ODBLK  BY (SRDOD2ODBLK  + grid)
SRDODxOD_HG  = (SIZE OD_HG  BY (SRDOD2OD_HG  + grid)) NOT (SIZE OD_HG  BY -(SRDOD2OD_HG  + grid))
SRDODxICOVL  =  SIZE ICOVL  BY (SRDOD2ICOVL  + grid)
SRDODxHVD    =  SIZE (POi INTERACT (OR HVD_N HVD_P HVD_65)) BY (SRDOD2HVD + grid)
SRDODxHVDnp  =  SIZE (OR HVD_N HVD_P HVD_65) BY (SRDOD2HVDnp + grid)
SRDODxNW55	 = (SIZE (NWi INTERACT NW55i) BY (SRDOD2NW55 + grid)) NOT (SIZE (NWi INTERACT NW55i) BY -(SRDOD2NW55 + grid))
SRDODxNW65	 = (SIZE (NWi INTERACT NW65i) BY (SRDOD2NW65 + grid)) NOT (SIZE (NWi INTERACT NW65i) BY -(SRDOD2NW65 + grid))
SRDODxPO55	 =  SIZE ((RHPO AND POi) INTERACT PO55i)  BY (SRDOD2PO55  + grid)
SRDODxPO65	 =  SIZE ((RHPO AND POi) INTERACT PO65i)  BY (SRDOD2PO65  + grid)
SRDODxPODV3d3 = SIZE (((POi NOT CPO) INTERACT COi) INTERACT PO_HVN_330Vx) BY (SRDOD2PODV33 + grid)
SRDODxNWDV5   = (SIZE (NWi INTERACT NW_HVN_500Vx) BY (SRDOD2NWDV5 + grid)) NOT (SIZE (NWi INTERACT NW_HVN_500Vx) BY -(SRDOD2NWDV5 + grid))
SRDODx = ((((((((((((((((((((((x OR SRDODxNW) OR SRDODxOD) OR SRDODxOD45) OR SRDODxDOD) OR SRDODxSRDOD) OR SRDODxNTN) OR SRDODxOD2) OR SRDODxPO) OR SRDODxDPO) OR SRDODxSRDPO) OR SRDODxPP) OR SRDODxRPO) OR SRDODxNWDMY) OR SRDODxRHOD) OR SRDODxRHPO) OR SRDODxDIODMY) OR SRDODxVAR) OR SRDODxODBLK) OR SRDODxOD_HG) OR SRDODxICOVL) OR SRDODxHVD) OR SRDODxHVDnp) OR (OR SRDODxNW55 SRDODxNW65 SRDODxPO55 SRDODxPO65 SRDODxPODV3d3 SRDODxNWDV5)

DODxNW     = (SIZE NWi    BY (DOD2NW     + grid)) NOT (SIZE NWi    BY -(DOD2NW     + grid))
DODxOD     =  SIZE ODi    BY (DOD2OD     + grid)
DODxDOD    =  SIZE DOD    BY (DOD2DOD    + grid)
DODxSRDOD  =  SIZE SRDOD  BY (DOD2SRDOD  + grid)
DODxOD2    = (SIZE OD2    BY (DOD2OD2    + grid)) NOT (SIZE OD2    BY -(DOD2OD2    + grid))
DODxPO     =  SIZE POi    BY (DOD2PO     + grid)
DODxDPO    =  SIZE DPO    BY (DOD2DPO    + grid)
DODxSRDPO  =  SIZE SRDPO  BY (DOD2SRDPO  + grid)
DODxPP     = (SIZE PPi    BY (DOD2PP     + grid)) NOT (SIZE PPi    BY -(DOD2PP     + grid))
DODxRPO    = (SIZE RPOi   BY (DOD2RPO    + grid)) NOT (SIZE RPOi   BY -(DOD2RPO    + grid))
DODxNWDMY  =  SIZE NWDMY  BY (DOD2NWDMY  + grid)
DODxRHOD   = (SIZE RHOD   BY (DOD2RHOD   + grid)) NOT (SIZE RHOD   BY -(DOD2RHOD   + grid))
DODxRHPO   = (SIZE RHPO   BY (DOD2RHPO   + grid)) NOT (SIZE RHPO   BY -(DOD2RHPO   + grid))
DODxDIODMY =  SIZE DIODMY BY (DOD2DIODMY + grid)
DODxVAR    = (SIZE VARi   BY (DOD2VAR    + grid)) NOT (SIZE VARi   BY -(DOD2VAR    + grid))
DODxODBLK  =  SIZE ODBLK  BY (DOD2ODBLK  + grid)
DODxOD_HG  = (SIZE OD_HG  BY (DOD2OD_HG  + grid)) NOT (SIZE OD_HG  BY -(DOD2OD_HG  + grid))
DODxICOVL  =  SIZE ICOVL  BY (DOD2ICOVL  + grid)
DODxHVDnp  =  SIZE (OR HVD_N HVD_P HVD_65)  BY (DOD2HVDnp  + grid)
DODxNW55   =  (SIZE (NWi INTERACT NW55i) BY (DOD2NW55 + grid)) NOT (SIZE (NWi INTERACT NW55i) BY -(DOD2NW55 + grid))
DODxNW65   =  (SIZE (NWi INTERACT NW65i) BY (DOD2NW65 + grid)) NOT (SIZE (NWi INTERACT NW65i) BY -(DOD2NW65 + grid))
DODxPO55   =  SIZE ((RHPO AND POi) INTERACT PO55i)  BY (DOD2PO55  + grid)
DODxPO65   =  SIZE ((RHPO AND POi) INTERACT PO65i)  BY (DOD2PO65  + grid)
DODxNWDV5  = (SIZE (NWi INTERACT NW_HVN_500Vx) BY (DOD2NWDV5 + grid)) NOT (SIZE (NWi INTERACT NW_HVN_500Vx) BY -(DOD2NWDV5 + grid))
DODx = (((((((((((((((((((x OR DODxNW) OR DODxOD) OR DODxDOD) OR DODxSRDOD) OR DODxOD2) OR DODxPO) OR DODxDPO) OR DODxSRDPO) OR DODxPP) OR DODxRPO) OR DODxNWDMY) OR DODxRHOD) OR DODxRHPO) OR DODxDIODMY) OR DODxVAR) OR DODxODBLK) OR DODxOD_HG) OR DODxICOVL) OR DODxHVDnp) OR (OR DODxNW55 DODxNW65 DODxPO55 DODxPO65 DODxNWDV5)
#IFDEF InsideINDDMY_HD_MD
DODx_ind = ((((((((((((((((((x_ind OR DODxNW) OR DODxOD) OR DODxDOD) OR DODxSRDOD) OR DODxOD2) OR DODxPO) OR DODxDPO) OR DODxSRDPO) OR DODxPP) OR DODxRPO) OR DODxNWDMY) OR DODxRHOD) OR DODxRHPO) OR DODxDIODMY) OR DODxVAR) OR DODxODBLK) OR DODxOD_HG) OR DODxICOVL) OR DODxHVDnp
#ENDIF

SRDPOxVAR_IO    =  SIZE ((GATE INTERACT VARi) INTERACT OD2)     BY (PO_S_36_S + PO_S_36A + grid)
SRDPOxVAR_CO    =  SIZE ((GATE INTERACT VARi) NOT INTERACT OD2) BY (PO_S_35_S + PO_S_35A + grid)
SRDPOxOD        =  SIZE ODi              BY (SRDPO2OD          + grid)
SRDPOxDOD       =  SIZE DOD              BY (SRDPO2DOD         + grid)
SRDPOxSRDOD     =  SIZE SRDOD            BY (SRDPO2SRDOD       + grid)
SRDPOxPO        =  SIZE POi              BY (SRDPO2PO          + grid)
SRDPOxPO_RPO    =  SIZE (POi AND RPOi)   BY (SRDPO2PO_RPO      + grid)
SRDPOxDPO       =  SIZE DPO              BY (SRDPO2DPO         + grid)
SRDPOxSRDPO     =  SIZE SRDPO            BY (SRDPO2SRDPO       + grid)
SRDPOxSRDPO_RPO =  SIZE (SRDPO AND RPOi) BY (SRDPO2SRDPO_RPO   + grid)
SRDPOxCPO       =  SIZE CPO              BY (SRDPO2CPO         + grid)
SRDPOxRPO       = (SIZE RPOi             BY (SRDPO2RPO         + grid)) NOT (SIZE RPOi   BY -(SRDPO2RPO        + grid))
SRDPOxRHOD      =  SIZE RHOD             BY (SRDPO2RHOD        + grid)
SRDPOxRHPO      =  SIZE RHPO             BY (SRDPO2RHPO        + grid)
SRDPOxDIODMY    = (SIZE DIODMY           BY (SRDPO2DIODMY      + grid)) NOT (SIZE DIODMY BY -(SRDPO2DIODMY     + grid))
SRDPOxVAR       = (SIZE VARi             BY (SRDPO2VAR         + grid)) NOT (SIZE VARi   BY -(SRDPO2VAR        + grid))
SRDPOxPOBLK     =  SIZE POBLK            BY (SRDPO2POBLK       + grid)
SRDPOxICOVL     =  SIZE ICOVL            BY (SRDPO2ICOVL       + grid)
SRDPOxPMET      = (SIZE PMET             BY (SRDPO2PMEToutside + grid)) NOT (SIZE PMET   BY -(SRDPO2PMETinside + grid))
SRDPOxHVDnp     =  SIZE (OR HVD_N HVD_P HVD_65)  BY (SRDPO2HVD  + grid)
SRDPOxPO55      =  SIZE ((RHPO AND POi) INTERACT PO55i)  BY (SRDPO2PO55  + grid)
SRDPOxPO65		=  SIZE ((RHPO AND POi) INTERACT PO65i)  BY (SRDPO2PO65  + grid)
SRDPOxNW55		=  (SIZE (NWi INTERACT NW55i) BY (SRDPO2NW55 + grid*4)) NOT (SIZE (NWi INTERACT NW55i) BY -(SRDPO2NW55 + grid*4))
SRDPOxNW65		=  (SIZE (NWi INTERACT NW65i) BY (SRDPO2NW65 + grid*4)) NOT (SIZE (NWi INTERACT NW65i) BY -(SRDPO2NW65 + grid*4))
SRDPOx = ((((((((((((((((((((x OR SRDPOxOD) OR SRDPOxDOD) OR SRDPOxSRDOD) OR SRDPOxPO) OR SRDPOxPO_RPO) OR SRDPOxDPO) OR SRDPOxSRDPO) OR SRDPOxSRDPO_RPO) OR SRDPOxCPO) OR SRDPOxRPO) OR SRDPOxRHOD) OR SRDPOxRHPO) OR SRDPOxDIODMY) OR SRDPOxVAR) OR SRDPOxPOBLK) OR SRDPOxICOVL) OR SRDPOxPMET) OR SRDPOxVAR_IO) OR SRDPOxVAR_CO) OR SRDPOxHVDnp) OR (OR SRDPOxPO55 SRDPOxPO65 SRDPOxNW55 SRDPOxNW65)

DPOxOD      =  SIZE ODi            BY (DPO2OD          + grid)
DPOxDOD     =  SIZE DOD            BY (DPO2DOD         + grid)
DPOxSRDOD   =  SIZE SRDOD          BY (DPO2SRDOD       + grid)
DPOxPO      =  SIZE POi            BY (DPO2PO          + grid)
DPOxDPO     =  SIZE DPO            BY (DPO2DPO         + grid)
DPOxDPO_RPO =  SIZE (DPO AND RPOi) BY (DPO2DPO_RPO     + grid)
DPOxSRDPO   =  SIZE SRDPO          BY (DPO2SRDPO       + grid)
DPOxCPO     =  SIZE CPO            BY (DPO2CPO         + grid)
DPOxRPO     = (SIZE RPOi           BY (DPO2RPO         + grid)) NOT (SIZE RPOi   BY -(DPO2RPO        + grid))
DPOxRHOD    = (SIZE RHOD           BY (DPO2RHOD        + grid)) NOT (SIZE RHOD   BY -(DPO2RHOD       + grid))
DPOxRHPO    = (SIZE RHPO           BY (DPO2RHPO        + grid)) NOT (SIZE RHPO   BY -(DPO2RHPO       + grid))
DPOxDIODMY  = (SIZE DIODMY         BY (DPO2DIODMY      + grid)) NOT (SIZE DIODMY BY -(DPO2DIODMY     + grid))
DPOxVAR     = (SIZE VARi           BY (DPO2VAR         + grid)) NOT (SIZE VARi   BY -(DPO2VAR        + grid))
DPOxPOBLK   =  SIZE POBLK          BY (DPO2POBLK       + grid)
DPOxICOVL   =  SIZE ICOVL          BY (DPO2ICOVL       + grid)
DPOxPMET    = (SIZE PMET           BY (DPO2PMEToutside + grid)) NOT (SIZE PMET   BY -(DPO2PMETinside + grid))
DPOxHVDnp   =  SIZE (OR HVD_N HVD_P HVD_65)  BY (DPO2HVD  + grid)
DPOxPO55	=  SIZE ((RHPO AND POi) INTERACT PO55i)  BY (DPO2PO55  + grid)
DPOxPO65	=  SIZE ((RHPO AND POi) INTERACT PO65i)  BY (DPO2PO65  + grid)
DPOxNW55	= (SIZE (NWi INTERACT NW55i) BY (DPO2NW55 + grid)) NOT (SIZE (NWi INTERACT NW55i) BY -(DPO2NW55 + grid))
DPOxNW65	= (SIZE (NWi INTERACT NW65i) BY (DPO2NW65 + grid)) NOT (SIZE (NWi INTERACT NW65i) BY -(DPO2NW65 + grid))
DPOx = (((((((((((((((((x OR DPOxOD) OR DPOxDOD) OR DPOxSRDOD) OR DPOxPO) OR DPOxDPO) OR DPOxDPO_RPO) OR DPOxSRDPO) OR DPOxCPO) OR DPOxRPO) OR DPOxRHOD) OR DPOxRHPO) OR DPOxDIODMY) OR DPOxVAR) OR DPOxPOBLK) OR DPOxICOVL) OR DPOxPMET) OR DPOxHVDnp) OR (OR DPOxPO55 DPOxPO65 DPOxNW55 DPOxNW65)
#IFDEF InsideINDDMY_HD_MD
DPOx_ind = ((((((((((((((((x_ind OR DPOxOD) OR DPOxDOD) OR DPOxSRDOD) OR DPOxPO) OR DPOxDPO) OR DPOxDPO_RPO) OR DPOxSRDPO) OR DPOxCPO) OR DPOxRPO) OR DPOxRHOD) OR DPOxRHPO) OR DPOxDIODMY) OR DPOxVAR) OR DPOxPOBLK) OR DPOxICOVL) OR DPOxPMET) OR DPOxHVDnp
#ENDIF

PPxPP = SIZE PPi BY (PP2PP + grid)
ICOVLxPP = SIZE ICOVL BY (ICOVL2PP + grid)
PPx = PPxPP OR ICOVLxPP
NPxNP = SIZE NPi BY (NP2NP + grid)
ICOVLxNP = SIZE ICOVL BY (ICOVL2NP + grid)
NPx = NPxNP OR ICOVLxNP
GATE_SRDPO_W4 = (GATE INTERACT OD2) SIZE BY (SR_DPO_W_4_S + grid)
GATE_SRDPO_W4x = GATE_SRDPO_W4 AND (SRESD OR SDI)


GATEi = ODi AND POi
SD    = ODi NOT POi
FPO   = POi NOT ODi
GATE  = (GATEi TOUCH SD == 2) TOUCH FPO == 2

NPOD = ODi AND NPi
PPOD = ODi AND PPi
NACT = NPOD NOT NWi   // NMOS device active diffusion
PACT = PPOD AND NWi   // PMOS device active diffusion
DACT = NACT OR PACT   // NMOS/PMOS device active diffusion


#IFDEF FILL_SRDOD_SRDPO
GATE_L = GATE COIN INSIDE EDGE ODi
GATE_V = GATE WITH EDGE (ANGLE GATE_L ==  0)
GATE_H = GATE WITH EDGE (ANGLE GATE_L == 90)

MOS_OD = (DACT INTERACT GATE) NOT INTERACT (SRAMDMY OR TCDDMY)

MOS_OD_V = MOS_OD INTERACT GATE_V
MOS_OD_H = (MOS_OD INTERACT GATE_H) NOT INTERACT GATE_V

MOS_OD_EDGE_X      = (ANGLE MOS_OD_V == 0) OR EDGE (ANGLE MOS_OD_H == 90)
MOS_OD_EDGE_X_OD2  = MOS_OD_EDGE_X INSIDE EDGE OD2
MOS_OD_EDGE_X_CO = MOS_OD_EDGE_X NOT INSIDE EDGE OD2

MOS_OD_EDGE_Y      = (ANGLE MOS_OD_H == 0) OR EDGE (ANGLE MOS_OD_V == 90)

OPC_PO_FIELD = OPC_PO NOT INTERACT ODi

MOS_OD_EDGE_X_good_OD2 = EXT [MOS_OD_EDGE_X_OD2] ALL_OD < IO_PRO_SRDOD_F1_S+IO_PRO_SRDOD_F1_W+SR_DOD_S_6 OPPOSITE
MOS_OD_EDGE_X_good_CO = EXT [MOS_OD_EDGE_X_CO] ALL_OD < CO_PRO_SRDOD_F1_S+CO_PRO_SRDOD_F1_W+SR_DOD_S_5 OPPOSITE
MOS_OD_EDGE_X_good = MOS_OD_EDGE_X_good_OD2 OR EDGE MOS_OD_EDGE_X_good_CO
MOS_OD_EDGE_X_bad  = MOS_OD_EDGE_X NOT COIN INSIDE EDGE MOS_OD_EDGE_X_good

//consider MOS with short po endcap and large OD length
MOS_OD_EDGE_X_bad_CO = MOS_OD_EDGE_X_bad NOT INSIDE EDGE OD2
MOS_OD_EDGE_X_bad_IO = MOS_OD_EDGE_X_bad INSIDE EDGE OD2

SRDOD_bar_W_1_CO_pre1 = ENC MOS_OD_EDGE_X_bad_CO POi <= CO_PRO_SRDOD_F1_S - SRDOD2PO OPPOSITE REGION
SRDOD_bar_W_1_CO_pre2 = (MOS_OD_EDGE_X_bad_CO COIN INSIDE EDGE GATE_L) NOT COIN OUTSIDE EDGE SRDOD_bar_W_1_CO_pre1
SRDOD_bar_W_1_CO_pre3 = (LENGTH (MOS_OD_EDGE_X_bad_CO NOT COIN INSIDE EDGE SRDOD_bar_W_1_CO_pre2) >= CO_PRO_SRDOD_F1_MIN_L) TOUCH INSIDE EDGE GATE_L
SRDOD_bar_W_1_CO_pre4 = (EXPAND EDGE SRDOD_bar_W_1_CO_pre3 OUTSIDE BY CO_PRO_SRDOD_F1_S+CO_PRO_SRDOD_F1_W) NOT (EXPAND EDGE SRDOD_bar_W_1_CO_pre3 OUTSIDE BY CO_PRO_SRDOD_F1_S)
SRDOD_bar_W_1_CO_t1 = ((SRDOD_bar_W_1_CO_pre4 NOT SRDODx) AND CHIP) WITH WIDTH >= CO_PRO_SRDOD_F1_W
SRDOD_bar_W_1_CO_t2 = ((RECTANGLE (EXTENTS ((EXT SRDOD_bar_W_1_CO_t1 < SR_DOD_S_5 ABUT<90 SINGULAR REGION) OR SRDOD_bar_W_1_CO_t1))) OUTSIDE SRDODx) ENCLOSE RECTANGLE CO_PRO_SRDOD_F1_W CO_PRO_SRDOD_F1_MIN_L ORTHOGONAL ONLY
SRDOD_bar_W_1_CO = SRDOD_bar_W_1_CO_t2 NOT INTERACT (EXT SRDOD_bar_W_1_CO_t2 < SR_DOD_S_5 ABUT<90 SINGULAR REGION)

SRDOD_bar_W_1_IO_pre1 = ENC MOS_OD_EDGE_X_bad_IO POi <= IO_PRO_SRDOD_F1_S - SRDOD2PO OPPOSITE REGION
SRDOD_bar_W_1_IO_pre2 = (MOS_OD_EDGE_X_bad_IO COIN INSIDE EDGE GATE_L) NOT COIN OUTSIDE EDGE SRDOD_bar_W_1_IO_pre1
SRDOD_bar_W_1_IO_pre3 = (LENGTH (MOS_OD_EDGE_X_bad_IO NOT COIN INSIDE EDGE SRDOD_bar_W_1_IO_pre2) >= IO_PRO_SRDOD_F1_MIN_L) TOUCH INSIDE EDGE GATE_L
SRDOD_bar_W_1_IO_pre4 = (EXPAND EDGE SRDOD_bar_W_1_IO_pre3 OUTSIDE BY IO_PRO_SRDOD_F1_S+IO_PRO_SRDOD_F1_W) NOT (EXPAND EDGE SRDOD_bar_W_1_IO_pre3 OUTSIDE BY IO_PRO_SRDOD_F1_S)
SRDOD_bar_W_1_IO_t1 = ((SRDOD_bar_W_1_IO_pre4 NOT SRDODx) AND CHIP) WITH WIDTH >= IO_PRO_SRDOD_F1_W
SRDOD_bar_W_1_IO_t2 = ((RECTANGLE (EXTENTS ((EXT SRDOD_bar_W_1_IO_t1 < SR_DOD_S_6 ABUT<90 SINGULAR REGION) OR SRDOD_bar_W_1_IO_t1))) OUTSIDE SRDODx) ENCLOSE RECTANGLE IO_PRO_SRDOD_F1_W IO_PRO_SRDOD_F1_MIN_L ORTHOGONAL ONLY
SRDOD_bar_W_1_IO = SRDOD_bar_W_1_IO_t2 NOT INTERACT (EXT SRDOD_bar_W_1_IO_t2 < SR_DOD_S_6 ABUT<90 SINGULAR REGION)

SRDOD_bar_W_1 = SRDOD_bar_W_1_CO OR SRDOD_bar_W_1_IO

//blocking region
SRDOD_BLOCK_F1 = SRDODx OR (SIZE SRDOD_bar_W_1 BY SR_DOD_S_1)

//find OD edges which still need to insert SRDOD bar in W-direction
MOS_OD_EDGE_X_good1_CO = EXT [MOS_OD_EDGE_X_bad_CO] SRDOD_bar_W_1_CO < CO_PRO_SRDOD_F1_S+CO_PRO_SRDOD_F1_W+SR_DOD_S_5 OPPOSITE
MOS_OD_EDGE_X_bad1_CO  = MOS_OD_EDGE_X_bad_CO NOT COIN INSIDE EDGE MOS_OD_EDGE_X_good1_CO
MOS_OD_EDGE_X_good1_IO = EXT [MOS_OD_EDGE_X_bad_IO] SRDOD_bar_W_1_IO < IO_PRO_SRDOD_F1_S+IO_PRO_SRDOD_F1_W+SR_DOD_S_6 OPPOSITE
MOS_OD_EDGE_X_bad1_IO  = MOS_OD_EDGE_X_bad_IO NOT COIN INSIDE EDGE MOS_OD_EDGE_X_good1_IO

MOS_OD_EDGE_X_bad1 = MOS_OD_EDGE_X_bad1_CO OR EDGE MOS_OD_EDGE_X_bad1_IO

//consider MOS with long po endcap and short OD length
MOS_OD_EXTENTS = (EXTENTS ((EXT MOS_OD_EDGE_Y <= MOS_OD_MERGE_SPACE OPPOSITE REGION) OR MOS_OD)) WITH EDGE MOS_OD_EDGE_X_bad1
MOS_OD_EXTENTS_EDGE_X = MOS_OD_EXTENTS TOUCH INSIDE EDGE MOS_OD_EDGE_X_bad1
POi_ENDCAP_X = (EXPAND EDGE MOS_OD_EXTENTS_EDGE_X OUTSIDE BY MAX_PO_ENDCAP) AND POi
MOS_PO_ENDCAP_EXTENTS = EXTENTS (MOS_OD_EXTENTS OR (POi_ENDCAP_X INTERACT MOS_OD_EXTENTS))

MOS_OD_EXTENTS_EDGE_X_CO = MOS_OD_EXTENTS_EDGE_X NOT INSIDE EDGE OD2
MOS_OD_EXTENTS_EDGE_X_IO = MOS_OD_EXTENTS_EDGE_X INSIDE EDGE OD2

MOS_PO_ENDCAP_EXTENTS_B_CO = ((EXPAND EDGE MOS_OD_EXTENTS_EDGE_X_CO OUTSIDE BY CO_PRO_SRDOD_F1_S) OR (EXPAND EDGE (MOS_PO_ENDCAP_EXTENTS NOT TOUCH INSIDE EDGE MOS_OD_EDGE_Y) OUTSIDE BY SRDOD2PO)) OR MOS_PO_ENDCAP_EXTENTS
MOS_PO_ENDCAP_EXTENTS_B_CO_edge_x = ENC MOS_OD_EDGE_X_bad1_CO [MOS_PO_ENDCAP_EXTENTS_B_CO] <= MAX_PO_ENDCAP+SRDOD2PO OPPOSITE EXCLUDE SHIELDED 4
MOS_PO_ENDCAP_EXTENTS_B_CO_edge = MOS_PO_ENDCAP_EXTENTS_B_CO TOUCH INSIDE EDGE MOS_PO_ENDCAP_EXTENTS_B_CO_edge_x
MOS_PO_ENDCAP_EXTENTS_B_CO_edge_short = LENGTH MOS_PO_ENDCAP_EXTENTS_B_CO_edge < CO_PRO_SRDOD_F1_MIN_L
MOS_PO_ENDCAP_EXTENTS_B_CO_edge_long  = LENGTH MOS_PO_ENDCAP_EXTENTS_B_CO_edge >= CO_PRO_SRDOD_F1_MIN_L
SRDOD_F1_pre1_CO = EXPAND EDGE MOS_PO_ENDCAP_EXTENTS_B_CO_edge_short OUTSIDE BY CO_PRO_SRDOD_F1_W EXTEND BY SRDOD_W_Short_EX
SRDOD_F1_pre2_CO = EXPAND EDGE MOS_PO_ENDCAP_EXTENTS_B_CO_edge_long  OUTSIDE BY CO_PRO_SRDOD_F1_W
SRDOD_F1_pre_CO = SRDOD_F1_pre1_CO OR SRDOD_F1_pre2_CO
SRDOD_bar_W_2_CO_t1 = ((SRDOD_F1_pre_CO NOT SRDOD_BLOCK_F1) AND CHIP) WITH WIDTH >= CO_PRO_SRDOD_F1_W
SRDOD_bar_W_2_CO_t2 = ((RECTANGLE (EXTENTS ((EXT SRDOD_bar_W_2_CO_t1 < SR_DOD_S_5 ABUT<90 SINGULAR REGION) OR SRDOD_bar_W_2_CO_t1))) OUTSIDE SRDOD_BLOCK_F1) ENCLOSE RECTANGLE CO_PRO_SRDOD_F1_W CO_PRO_SRDOD_F1_MIN_L ORTHOGONAL ONLY
SRDOD_bar_W_2_CO = SRDOD_bar_W_2_CO_t2 NOT INTERACT (EXT SRDOD_bar_W_2_CO_t2 < SR_DOD_S_5 ABUT<90 SINGULAR REGION)

MOS_PO_ENDCAP_EXTENTS_B_IO = ((EXPAND EDGE MOS_OD_EXTENTS_EDGE_X_IO OUTSIDE BY IO_PRO_SRDOD_F1_S) OR (EXPAND EDGE (MOS_PO_ENDCAP_EXTENTS NOT TOUCH INSIDE EDGE MOS_OD_EDGE_Y) OUTSIDE BY SRDOD2PO)) OR MOS_PO_ENDCAP_EXTENTS
MOS_PO_ENDCAP_EXTENTS_B_IO_edge_x = ENC MOS_OD_EDGE_X_bad1_IO [MOS_PO_ENDCAP_EXTENTS_B_IO] <= MAX_PO_ENDCAP+SRDOD2PO OPPOSITE EXCLUDE SHIELDED 4
MOS_PO_ENDCAP_EXTENTS_B_IO_edge = MOS_PO_ENDCAP_EXTENTS_B_IO TOUCH INSIDE EDGE MOS_PO_ENDCAP_EXTENTS_B_IO_edge_x
MOS_PO_ENDCAP_EXTENTS_B_IO_edge_short = LENGTH MOS_PO_ENDCAP_EXTENTS_B_IO_edge < IO_PRO_SRDOD_F1_MIN_L
MOS_PO_ENDCAP_EXTENTS_B_IO_edge_long  = LENGTH MOS_PO_ENDCAP_EXTENTS_B_IO_edge >= IO_PRO_SRDOD_F1_MIN_L
SRDOD_F1_pre1_IO = EXPAND EDGE MOS_PO_ENDCAP_EXTENTS_B_IO_edge_short OUTSIDE BY IO_PRO_SRDOD_F1_W EXTEND BY SRDOD_W_Short_EX
SRDOD_F1_pre2_IO = EXPAND EDGE MOS_PO_ENDCAP_EXTENTS_B_IO_edge_long  OUTSIDE BY IO_PRO_SRDOD_F1_W
SRDOD_F1_pre_IO = SRDOD_F1_pre1_IO OR SRDOD_F1_pre2_IO
SRDOD_bar_W_2_IO_t1 = ((SRDOD_F1_pre_IO NOT SRDOD_BLOCK_F1) AND CHIP) WITH WIDTH >= IO_PRO_SRDOD_F1_W
SRDOD_bar_W_2_IO_t2 = ((RECTANGLE (EXTENTS ((EXT SRDOD_bar_W_2_IO_t1 < SR_DOD_S_6 ABUT<90 SINGULAR REGION) OR SRDOD_bar_W_2_IO_t1))) OUTSIDE SRDOD_BLOCK_F1) ENCLOSE RECTANGLE IO_PRO_SRDOD_F1_W IO_PRO_SRDOD_F1_MIN_L ORTHOGONAL ONLY
SRDOD_bar_W_2_IO = SRDOD_bar_W_2_IO_t2 NOT INTERACT (EXT SRDOD_bar_W_2_IO_t2 < SR_DOD_S_6 ABUT<90 SINGULAR REGION)

SRDOD_bar_W_2 = SRDOD_bar_W_2_CO OR SRDOD_bar_W_2_IO

PRO_SRDOD_pre0 = SRDOD_bar_W_1 OR SRDOD_bar_W_2
PRO_SRDOD_pre = PRO_SRDOD_pre0 NOT INTERACT (((EXT PRO_SRDOD_pre0 < 0.08 ABUT< 90 SINGULAR REGION) OR (EXT (PRO_SRDOD_pre0 INTERACT OD2) PRO_SRDOD_pre0 < 0.15 ABUT< 90 SINGULAR REGION)) OR (EXT (PRO_SRDOD_pre0 INTERACT OD2) (PRO_SRDOD_pre0 OR ALL_OD) < 0.15 ABUT< 90 SINGULAR REGION))
PRO_SRDOD_long = ENCLOSE RECTANGLE PRO_SRDOD_pre grid 2.005
PRO_SRDOD_long_line_end  = LENGTH PRO_SRDOD_long <= SR_DOD_L_1
PRO_SRDOD_long_side_wall = LENGTH PRO_SRDOD_long > SR_DOD_L_1
PRO_SRDOD_long_line_end_b = EXPAND EDGE PRO_SRDOD_long_line_end INSIDE BY 0.6
PRO_SRDOD_long_cut_region = (PRO_SRDOD_long INTERACT PRO_SRDOD_long_line_end_b) NOT PRO_SRDOD_long_line_end_b
PRO_SRDOD_long_side_wall_h = ANGLE PRO_SRDOD_long_side_wall == 0
PRO_SRDOD_long_side_wall_v = ANGLE PRO_SRDOD_long_side_wall == 90
PRO_SRDOD_long_cut_region_h = PRO_SRDOD_long_cut_region WITH EDGE PRO_SRDOD_long_side_wall_h
PRO_SRDOD_long_cut_region_v = PRO_SRDOD_long_cut_region WITH EDGE PRO_SRDOD_long_side_wall_v
PRO_SRDOD_long_cut_pre1 = RECTANGLES 0.04 0.15 1.25 INSIDE OF LAYER PRO_SRDOD_long_cut_region_v
PRO_SRDOD_long_cut_pre2 = RECTANGLES 0.15 0.04 1.25 INSIDE OF LAYER PRO_SRDOD_long_cut_region_h
PRO_SRDOD_long_cut_pre = PRO_SRDOD_long_cut_pre1 OR PRO_SRDOD_long_cut_pre2
PRO_SRDOD_long_cut = (ENC PRO_SRDOD_long_cut_pre PRO_SRDOD_long_side_wall < SR_DOD_L_1 OPPOSITE REGION) OR PRO_SRDOD_long_cut_pre
PRO_SRDOD = (WITH WIDTH (RECTANGLE (ENCLOSE RECTANGLE (PRO_SRDOD_pre NOT PRO_SRDOD_long_cut) 0.05 0.6 ORTHOGONAL ONLY)) <= SR_DOD_W_2) AND CHIP
xPRO = SIZE PRO_SRDOD BY NEXT_S1
#ELSE
PRO_SRDOD = COPY EMPTY
xPRO = COPY EMPTY
#ENDIF


POR7_GATE   = GATE NOT INSIDE (((((OD2 OR CSRDMY) OR POFUSE) OR BJTDMY) OR DIODMY) OR LOGO)
POR7_GATE_W = POR7_GATE COIN INSIDE EDGE ODi
POR7_GATE_V = CHIP INTERACT (EXPAND EDGE (ANGLE POR7_GATE_W ==  0) INSIDE BY GRID)
POR7_GATE_H = CHIP INTERACT (EXPAND EDGE (ANGLE POR7_GATE_W == 90) INSIDE BY GRID)

MOS_OD_ALL = (DACT INTERACT GATE) NOT INTERACT TCDDMY
MOS_ROUNDo = (SIZE (SIZE MOS_OD_ALL BY MOS_ROUND_RANGE) BY MOS_W_S/2 OVERUNDER) AND CHIP


#IFDEF FILL_SRDOD_SRDPO
MOSo = (((((MOS_ROUNDo NOT OD2) NOT RPOi) NOT SRDODx) NOT SRDPOx) NOT xPRO) NOT SRAMDMY_WLD6
MOS_Vo = (MOSo INTERACT POR7_GATE_V) OR (MOSo NOT INTERACT (POR7_GATE_V OR POR7_GATE_H))
MOS_Ho = (MOSo NOT MOS_Vo) INTERACT POR7_GATE_H
                MOS_Vo_1 = MOS_Vo WITH WIDTH >= MOS_W
            MOS_pre_1 = RECTANGLES MOS_W MOS_L MOS_W_S MOS_L_S OFFSET MOS_W_O MOS_L_O INSIDE OF LAYER MOS_Vo_1
                MOS_pre_union_1 = COPY MOS_pre_1

                MOS_Vo_2 = (MOS_Vo_1 NOT (SIZE MOS_pre_union_1 BY MOS_W_S)) WITH WIDTH >= MOS_W
            MOS_pre_2 = RECTANGLES MOS_W MOS_L MOS_W_S MOS_L_S OFFSET MOS_W_O MOS_L_O INSIDE OF LAYER MOS_Vo_2
                MOS_pre_union_2 = MOS_pre_union_1 OR MOS_pre_2

                MOS_Vo_3 = (MOS_Vo_2 NOT (SIZE MOS_pre_union_2 BY MOS_W_S)) WITH WIDTH >= MOS_W
            MOS_pre_3 = RECTANGLES MOS_W MOS_L MOS_W_S MOS_L_S OFFSET MOS_W_O MOS_L_O INSIDE OF LAYER MOS_Vo_3
                MOS_pre_union_3 = MOS_pre_union_2 OR MOS_pre_3

        MOS_pre = COPY MOS_pre_union_3

    MOS_pre2 = MOS_pre NOT INTERACT (EXT MOS_pre < SR_DPO_S_1 ABUT SINGULAR REGION)
MOS = MOS_pre2 NOT INTERACT (EXT (LENGTH MOS_pre2 == MOS_L) < SR_DPO_S_5 REGION) 

MOS_6_7_1 = SHRINK MOS LEFT BY 0.055 BOTTOM BY 0.08 RIGHT BY (MOS_W-0.365) TOP BY (MOS_L-0.38)
MOS_17_7_1 = SHRINK MOS LEFT BY 0 BOTTOM BY 0 RIGHT BY (MOS_W-0.03) TOP BY (MOS_L-0.46)
MOS_17_7_2 = SHRINK MOS LEFT BY 0.13 BOTTOM BY 0 RIGHT BY (MOS_W-0.16) TOP BY (MOS_L-0.46)
MOS_17_7_3 = SHRINK MOS LEFT BY 0.26 BOTTOM BY 0 RIGHT BY (MOS_W-0.29) TOP BY (MOS_L-0.46)
MOS_17_7_4 = SHRINK MOS LEFT BY 0.39 BOTTOM BY 0 RIGHT BY (MOS_W-0.42) TOP BY (MOS_L-0.46)
MOS_17_7 = OR (OR (OR MOS_17_7_1 MOS_17_7_2) MOS_17_7_3) MOS_17_7_4
MOS_6_7 = COPY MOS_6_7_1
MOS_H1o = MOS_Ho NOT (SIZE MOS BY MOS_W_S)
                MOS_H1o_1 = MOS_H1o WITH WIDTH >= MOS_W
            MOS_R90_pre_1 = RECTANGLES MOS_L MOS_W MOS_L_S MOS_W_S OFFSET MOS_L_O MOS_W_O INSIDE OF LAYER MOS_H1o_1
                MOS_R90_pre_union_1 = COPY MOS_R90_pre_1

                MOS_H1o_2 = (MOS_H1o_1 NOT (SIZE MOS_R90_pre_union_1 BY MOS_W_S)) WITH WIDTH >= MOS_W
            MOS_R90_pre_2 = RECTANGLES MOS_L MOS_W MOS_L_S MOS_W_S OFFSET MOS_L_O MOS_W_O INSIDE OF LAYER MOS_H1o_2
                MOS_R90_pre_union_2 = MOS_R90_pre_union_1 OR MOS_R90_pre_2

                MOS_H1o_3 = (MOS_H1o_2 NOT (SIZE MOS_R90_pre_union_2 BY MOS_W_S)) WITH WIDTH >= MOS_W
            MOS_R90_pre_3 = RECTANGLES MOS_L MOS_W MOS_L_S MOS_W_S OFFSET MOS_L_O MOS_W_O INSIDE OF LAYER MOS_H1o_3
                MOS_R90_pre_union_3 = MOS_R90_pre_union_2 OR MOS_R90_pre_3

        MOS_R90_pre = COPY MOS_R90_pre_union_3

    MOS_R90_pre2 = MOS_R90_pre NOT INTERACT (EXT MOS_R90_pre < SR_DPO_S_1 ABUT SINGULAR REGION)
MOS_R90 = MOS_R90_pre2 NOT INTERACT (EXT (LENGTH MOS_R90_pre2 == MOS_L) < SR_DPO_S_5 REGION) 

MOS_R90_6_7_1 = SHRINK MOS_R90 LEFT BY 0.08 BOTTOM BY (MOS_W-0.365) RIGHT BY (MOS_L-0.38) TOP BY 0.055
MOS_R90_17_7_1 = SHRINK MOS_R90 LEFT BY 0 BOTTOM BY (MOS_W-0.03) RIGHT BY (MOS_L-0.46) TOP BY 0
MOS_R90_17_7_2 = SHRINK MOS_R90 LEFT BY 0 BOTTOM BY (MOS_W-0.16) RIGHT BY (MOS_L-0.46) TOP BY 0.13
MOS_R90_17_7_3 = SHRINK MOS_R90 LEFT BY 0 BOTTOM BY (MOS_W-0.29) RIGHT BY (MOS_L-0.46) TOP BY 0.26
MOS_R90_17_7_4 = SHRINK MOS_R90 LEFT BY 0 BOTTOM BY (MOS_W-0.42) RIGHT BY (MOS_L-0.46) TOP BY 0.39
MOS_R90_17_7 = OR (OR (OR MOS_R90_17_7_1 MOS_R90_17_7_2) MOS_R90_17_7_3) MOS_R90_17_7_4
MOS_R90_6_7 = COPY MOS_R90_6_7_1

MOS_SRDOD = MOS_6_7 OR MOS_R90_6_7
MOS_SRDPO = MOS_17_7 OR MOS_R90_17_7
MOS_boundary = MOS OR MOS_R90
xMOS = SIZE MOS_boundary BY NEXT_S2
#ELSE
MOS_SRDOD = COPY EMPTY
MOS_SRDPO = COPY EMPTY
MOS_boundary = COPY EMPTY
xMOS = COPY EMPTY
#ENDIF


#IFDEF FILL_TCD_PATTERN
VARIABLE TCD2Chip             0.6   //
VARIABLE TCD2DNW_edge_inside  0.465 // DNW.EN.1
VARIABLE TCD2DNW_edge_outside 2.5   // DNW.S.2
