            CO_ODB_V_3 = RECTANGLES CO_ODB_W CO_ODB_L CO_ODB_W_S CO_ODB_L_S OFFSET CO_ODB_W_O CO_ODB_L_O INSIDE OF LAYER CO_ODB_V1o_3
                CO_ODB_V_union_3 = CO_ODB_V_union_2 OR CO_ODB_V_3

                CO_ODB_V1o_4 = (CO_ODB_V1o_3 NOT (SIZE CO_ODB_V_union_3 BY CO_ODB_L_S)) WITH WIDTH >= CO_ODB_W
            CO_ODB_V_4 = RECTANGLES CO_ODB_W CO_ODB_L CO_ODB_W_S CO_ODB_L_S OFFSET CO_ODB_W_O CO_ODB_L_O INSIDE OF LAYER CO_ODB_V1o_4
                CO_ODB_V_union_4 = CO_ODB_V_union_3 OR CO_ODB_V_4

