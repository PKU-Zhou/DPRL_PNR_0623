AREF SRDPO_6 POH1_W POH1_L 2
AREF SRDPO_7 POH2_W POH2_L 2
#ELSE
#IFDEF USE_AUTOREF
AUTOREF PRE_FIX
#ENDIF
#ENDIF
#ENDIF


