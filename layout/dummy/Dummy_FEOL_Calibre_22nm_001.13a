                CO_ODB_V1o_1 = CO_ODB_V1o WITH WIDTH >= CO_ODB_W
            CO_ODB_V_1 = RECTANGLES CO_ODB_W CO_ODB_L CO_ODB_W_S CO_ODB_L_S OFFSET CO_ODB_W_O CO_ODB_L_O INSIDE OF LAYER CO_ODB_V1o_1
