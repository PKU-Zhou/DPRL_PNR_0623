   M8_CHK1 = M8 INTERACT (NET AREA RATIO M9 VIA8 SD IMD_M8_M8_A > A_R_8_3_2_A ACCUMULATE ACC_M8_M8_A [!AREA(SD)*(AREA(M9)+AREA(VIA8))])
