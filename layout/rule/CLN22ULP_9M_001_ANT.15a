TFR_CON_5 = TFR AND TFRDUMMY_5

TFR_CON_6 = TFR AND TFRDUMMY_6

TFR_CON_7 = TFR AND TFRDUMMY_7

TFR_CON_8 = TFR AND TFRDUMMY_8

TFR_CON_9 = TFR AND TFRDUMMY_9


LAYOUT TOP LAYER M1i VIA1i
LAYOUT TOP LAYER M2i VIA2i
LAYOUT TOP LAYER M3i VIA3i
LAYOUT TOP LAYER M4i VIA4i
LAYOUT TOP LAYER M5i VIA5i
LAYOUT TOP LAYER M6i VIA6i
LAYOUT TOP LAYER M7i VIA7i
LAYOUT TOP LAYER M8i VIA8i
LAYOUT TOP LAYER M9i APi RVi CBi CBDi































POLYc    = POi NOT (CPO OR CPO_SRM)
GATE     = ODi AND POi
GATE_N_IO   = (GATE AND NPi) INSIDE OD2
GATE_P_IO   = (GATE AND PPi) INSIDE OD2
SD       = ODi NOT (POi OR SRDPO)
CO_PO    = COi AND POi
GATE_VIA = COPY GATE
OD2      = ((OD18i OR OD25i) OR OD33i) OR OD15i
HV_GATE  = GATE AND OD2
HV18_GATE = GATE AND (OD18i OR OD15i)
HV25_GATE = GATE AND OD25i
CO   = COPY COi
M1   = COPY M1i 
VIA1 = COPY VIA1i


M2   = COPY M2i 
VIA2 = COPY VIA2i


M3   = COPY M3i 
VIA3 = COPY VIA3i


M4   = COPY M4i 
VIA4_TFR = VIA4i INSIDE TFR_CON_5
VIA4 = VIA4i NOT VIA4_TFR



M5   = COPY M5i 
VIA5_TFR = VIA5i INSIDE TFR_CON_6
VIA5 = VIA5i NOT VIA5_TFR



M6   = COPY M6i 
VIA6_TFR = VIA6i INSIDE TFR_CON_7
VIA6 = VIA6i NOT VIA6_TFR



M7   = COPY M7i 
V7CAP = VIA7i INSIDE CTMDMY_8
V7CAP_CBM_CTM = V7CAP INSIDE CBM_F
VIA7_TFR = VIA7i INSIDE TFR_CON_8
VIA7 = (VIA7i NOT V7CAP_CBM_CTM) NOT VIA7_TFR
V7CAP_CBM = V7CAP_CBM_CTM NOT INSIDE CTM_F
V7CAP_CTM = V7CAP_CBM_CTM INSIDE CTM_F


M8   = COPY M8i 
V8CAP = VIA8i INSIDE CTMDMY_9
V8CAP_CBM_CTM = V8CAP INSIDE CBM_F
VIA8_TFR = VIA8i INSIDE TFR_CON_9
VIA8 = (VIA8i NOT V8CAP_CBM_CTM) NOT VIA8_TFR
V8CAP_CBM = V8CAP_CBM_CTM NOT INSIDE CTM_F
V8CAP_CTM = V8CAP_CBM_CTM INSIDE CTM_F


M9   = COPY M9i 

RV   = COPY RVi
CB   = COPY CBi  
CBD  = COPY CBDi  
AP   = COPY APi
CTM_F = CTM NOT CTM_O
CBM_F = CBM NOT CBM_O
CTM8  = CTM_F INSIDE CTMDMY_8
CBM8  = CBM_F INSIDE CTMDMY_8
CTM9  = CTM_F INSIDE CTMDMY_9
CBM9  = CBM_F INSIDE CTMDMY_9
TFR   = COPY TFRi
//POLY CHECKS
//===========
// A.R.0 is checked by related rules
CONNECT GATE HV_GATE HV18_GATE HV25_GATE GATE_VIA GATE_N_IO GATE_P_IO POLYc

A.R.1:POLY { @ Drawn ratio of the poly top area excluded CPO (PO NOT CPO) to the ACTIVE poly GATE area that is connected directly to it <= 250 
  NET AREA RATIO POLYc GATE > 250
      [
        !!AREA(GATE) * ( AREA(POLYc)/AREA(GATE) )
      ] RDB A.R.1.POLY.rep POLYc GATE BY LAYER
}
// POLY thickness is 800A
A.R.2:POLY { @ Drawn ratio of the poly sidewall area excluded CPO (PO NOT CPO) to the ACTIVE poly GATE area that is connected directly to it <= 500 
  NET AREA RATIO POLYc GATE > 500
      [
        !!AREA(GATE) * ( PERIMETER(POLYc)*0.08/AREA(GATE) )
      ] RDB A.R.2.POLY.rep POLYc GATE BY LAYER
}
//CO CHECKS
//=========
CONNECT CO_PO POLYc
A.R.3:CO { @ Drawn ratio of the poly contact area to the ACTIVE poly GATE area that is connected directly to it <= 10 
  NET AREA RATIO POLYc CO_PO GATE > 10   // error highlight on POLY
      [
        !!AREA(GATE) * !!AREA(POLYc) *      
        AREA(CO_PO)/AREA(GATE)
      ] RDB A.R.3.CO.rep CO_PO GATE BY LAYER
}
/// CO Spiking rules ///
//M1 CHECKS
//=========

CONNECT M1 POLYc SD BY CO
CONNECT VIA1 M1

M1_DIO = NET AREA SD >= DIO_AREA
M1_DIO_R12 = NET AREA SD >= DIO_AREA_R12
//'A.R.6' is checked by A.R.6__A.R.8:M1
//'A.R.8' is checked by A.R.6__A.R.8:M1
A.R.6__A.R.8:M1 { @ Ratio of cumulative metal top area (from M1 to M10) to an ACTIVE poly GATE area [1.8V I/O in OD2/ except 1.8V I/O in OD2/ NOT in OD2] <= 1000/5000/5000 
                 @ (M1 area / gate area) <= OD area * 456 + 43000 (with protection OD)
  NET AREA RATIO M1 M1_DIO HV18_GATE GATE > 0  
       [
         !!AREA(M1) * !!AREA(GATE) *
       (!AREA(M1_DIO) * (!!AREA(HV18_GATE)*(AREA(M1)/AREA(GATE)-1000) +
                         !AREA(HV18_GATE)*(AREA(M1)/AREA(GATE)-5000)) +
        !!AREA(M1_DIO) * ( AREA(M1)/AREA(GATE)-AREA(M1_DIO)*456-43000 ))     
       ] RDB A.R.6_A.R.8.M1.rep M1 M1_DIO HV18_GATE GATE BY LAYER
}
//GATE_Area1_260K = NET AREA GATE > 1.0E3 <= 260.0E3
A.R.6.1:M1 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD25, 1.0E3 um2 < Gate area <= 2.6E5 um2] <= 3.3E6 x (GATE area)(-1.2) 
 GATE_Area1_260K = NET AREA GATE > 1.0E3 <= 260.0E3
 GATES = NET AREA RATIO GATE_Area1_260K  M1 M1_DIO HV25_GATE GATE > 0
     [ !!AREA(M1) *!!AREA(GATE) * !!AREA(GATE_Area1_260K)*!!AREA(HV25_GATE)*!AREA(M1_DIO) ] 

 NET AREA RATIO M1 M1_DIO GATE_Area1_260K GATES > 0 
    [
      !!AREA(M1) * !!AREA(GATES) * 
      (AREA(M1)/AREA(GATES)-3.3E6*(AREA(GATES)^-1.2))
       
    ] RDB A.R.6.1.M1.rep M1 M1_DIO GATE_Area1_260K GATES BY LAYER
}

A.R.6.2:M1 { @ Maximum cumulative I/O gate [in OD25] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 2.6E5 
  NET AREA RATIO HV25_GATE M1 M1_DIO GATE  > 2.6E5 
   [!!AREA(M1) * !!AREA(GATE) * !AREA(M1_DIO) *AREA(HV25_GATE)] 
  RDB A.R.6.2.M1.rep M1 M1_DIO GATE HV25_GATE BY LAYER
}

A.R.6.3:M1 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD18, 1.0E3 um2 < Gate area <= 1.0E6 um2] <= 7.1E5 x (GATE area)(-0.93) 
  GATE_Area_1E6 = NET AREA GATE > 1.0E3 <= 1.0E6
  GATES = NET AREA RATIO  GATE_Area_1E6 GATE  M1 M1_DIO HV18_GATE  > 0 
        [ !!AREA(M1) *!!AREA(GATE) * !AREA(M1_DIO) *!!AREA(HV18_GATE)*!!AREA(GATE_Area_1E6)]
 NET AREA RATIO  M1 GATES > 0  
       [
         !!AREA(M1) * !!AREA(GATES)*(AREA(M1)/AREA(GATES)-7.1E5*(AREA(GATES)^-0.93))
              ] RDB A.R.6.3.M1.rep M1 GATES BY LAYER
}
A.R.6.4:M1 { @ Maximum I/O gate [in OD18] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 1.0E6 
  NET AREA RATIO HV18_GATE M1 M1_DIO GATE > 1E6 
   [!!AREA(M1) * !!AREA(GATE) * !AREA(M1_DIO) *AREA(HV18_GATE)]
  RDB A.R.6.4.M1.rep M1_DIO HV18_GATE GATE M1 BY LAYER
}


// A.R.6.a is checked by 'A.R.6'

ACC_M1 = NET AREA RATIO M1 GATE >= 0 ACCUMULATE
//VIA1 CHECKS
//===========

A.R.4__A.R.7:VIA1 {  @ Single-layer drawn ratio of a via area to the ACTIVE poly GATE area that is connected directly to it <= 20 
                   @ (VIA1 area / gate area) <= OD area * 210 + 900 (with protection OD)
  NET AREA RATIO M1 VIA1 M1_DIO GATE_VIA > 0
       [
       !!AREA(M1) * !!AREA(VIA1) * 
           (!!AREA(M1_DIO) * ( AREA(VIA1)/AREA(GATE_VIA)-AREA(M1_DIO)*210-900 ) +
         !AREA(M1_DIO) * ( AREA(VIA1)/AREA(GATE_VIA)-20 ) )
       ] RDB A.R.4_A.R.7.VIA1.rep VIA1 M1_DIO GATE_VIA BY LAYER
}



ACC_VIA1 = NET AREA RATIO VIA1 GATE_VIA >= 0 ACCUMULATE
// 'VIAx.R.12' is checked by VIA1.R.12

VIA1.R.12 { @ Maximum area ratio of M1 to upper VIA1 in the same net [connects to gate with area > 10700 um2, and doesn't connect to OD]. This rule is checked by the DRC command files in ANTENNA_DRC directory <=  350000
   NET AREA RATIO M1 VIA1 GATE M1_DIO > 350000
   [!AREA(M1_DIO)*!~(AREA(GATE)-10700)*(AREA(M1)/AREA(VIA1))]  
   RDB VIA1.R.12.rep M1 VIA1 BY LAYER
}

// 'VIAx.R.12.1' is checked by VIA1.R.12.1

VIA1.R.12.1 { @ Maximum area ratio of I/O NMOS gate to single layer VIA1 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  650000
  NET AREA RATIO VIA1 GATE_N_IO M1_DIO_R12 > 650000
       [
       !AREA(M1_DIO_R12) * (AREA(GATE_N_IO)/AREA(VIA1))
       ] RDB VIA1.R.12.1.rep VIA1 GATE_N_IO BY LAYER
}

// 'VIAx.R.12.2' is checked by VIA1.R.12.2

VIA1.R.12.2 { @ Maximum area ratio of I/O PMOS gate to single layer VIA1 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  2500000
  NET AREA RATIO VIA1 GATE_P_IO M1_DIO_R12 > 2500000
       [
       !AREA(M1_DIO_R12) * (AREA(GATE_P_IO)/AREA(VIA1))
       ] RDB VIA1.R.12.2.rep VIA1 GATE_P_IO BY LAYER
}


IMD_M1_M1_A =  NET AREA RATIO M1 SD > 0 [!AREA(SD)]
CONNECT IMD_M1_M1_A M1
ACC_M1_M1_A = NET AREA RATIO M1 SD IMD_M1_M1_A > 0 ACCUMULATE [AREA(M1)]
A.R.8.3:M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
  M1_CHK1 = NET AREA RATIO M1 SD IMD_M1_M1_A > A_R_8_3_A ACCUMULATE [ !AREA(SD)*AREA(M1)] 

  E = EXT [M1_CHK1] M1_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
  NET AREA RATIO M1 SD M1_CHK2 > A_R_8_3_A ACCUMULATE [ !!AREA(M1_CHK2)*!AREA(SD)*AREA(M1)] RDB ONLY A.R.8.3:M1.rep M1 BY LAYER 
}
A.R.8.3.1:M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
  M1_CHK1 = NET AREA RATIO M1 SD IMD_M1_M1_A > A_R_8_3_1_A ACCUMULATE [ !AREA(SD)*AREA(M1)] 

  E = EXT [M1_CHK1] M1_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
  NET AREA RATIO M1 SD M1_CHK2 > A_R_8_3_1_A ACCUMULATE [ !!AREA(M1_CHK2)*!AREA(SD)*AREA(M1)] RDB ONLY A.R.8.3.1:M1.rep M1 BY LAYER 
}
A.R.8.3.2:M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
  M1_CHK1 = NET AREA RATIO M1 SD IMD_M1_M1_A > A_R_8_3_2_A ACCUMULATE [ !AREA(SD)*AREA(M1)] 

  E = EXT [M1_CHK1] M1_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
  NET AREA RATIO M1 SD M1_CHK2 > A_R_8_3_2_A ACCUMULATE [ !!AREA(M1_CHK2)*!AREA(SD)*AREA(M1)] RDB ONLY A.R.8.3.2:M1.rep M1 BY LAYER 
}


//M2 CHECKS
//=========
CONNECT M2 M1   BY VIA1
CONNECT VIA2 M2


M2_DIO = NET AREA SD >= DIO_AREA
M2_DIO_R12 = NET AREA SD >= DIO_AREA_R12
A.R.6__A.R.8:M2 { @ Ratio of cumulative metal top area (from M1 to M10) to an ACTIVE poly GATE area [1.8V I/O in OD2/ except 1.8V I/O in OD2/ NOT in OD2] <= 1000/5000/5000 
                 @ (cumulative M1~M2 area / gate area) <= OD area * 456 + 43000 (with protection OD)
  NET AREA RATIO M2 M1 M2_DIO HV18_GATE GATE > 0  ACCUMULATE ACC_M1
       [
         !!AREA(M2) * !!AREA(M1) * !!AREA(GATE) *
       (!AREA(M2_DIO) * (!!AREA(HV18_GATE)*(AREA(M2)/AREA(GATE)-1000) +
                         !AREA(HV18_GATE)*(AREA(M2)/AREA(GATE)-5000)) +
        !!AREA(M2_DIO) * ( AREA(M2)/AREA(GATE)-AREA(M2_DIO)*456-43000 )) - (!AREA(M2)+!AREA(GATE)) * LargeNumber    
       ] RDB A.R.6_A.R.8.M2.rep M2 M1 M2_DIO HV18_GATE GATE BY LAYER
}
// A.R.6 is checked by A.R.6__A.R.8:M2
// A.R.8 is checked by A.R.6__A.R.8:M2
A.R.6.1:M2 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD25, 1.0E3 um2 < Gate area <= 2.6E5 um2] <= 3.3E6 x (GATE area)(-1.2) 
 GATE_Area1_260K = NET AREA GATE > 1.0E3 <= 260.0E3
 GATES = NET AREA RATIO GATE_Area1_260K GATE M2 M2_DIO HV25_GATE  > 0
     [ !!AREA(M2) *!!AREA(GATE) * ~~AREA(GATE_Area1_260K)*!!AREA(HV25_GATE)*!AREA(M2_DIO) ] 

 NET AREA RATIO M2 M1 M2_DIO GATE_Area1_260K GATES > 0 ACCUMULATE ACC_M1
    [
      !!AREA(M2) * !!AREA(M1) * !!AREA(GATES) *!AREA(M2_DIO)* 
      (AREA(M2)/AREA(GATES)-3.3E6*(AREA(GATES)^-1.2))
       
    ] RDB A.R.6.1.M2.rep M2 M1 M2_DIO  GATES BY LAYER
}
A.R.6.2:M2 { @ Maximum cumulative I/O gate [in OD25] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 2.6E5 
  NET AREA RATIO HV25_GATE M2 M2_DIO   > 2.6E5 
   [!!AREA(M2)  * !AREA(M2_DIO) *AREA(HV25_GATE)] 
  RDB A.R.6.2.M2.rep  M2_DIO  HV25_GATE 
}
A.R.6.3:M2 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD18, 1.0E3 um2 < Gate area <= 1.0E6 um2] <= 7.1E5 x (GATE area)(-0.93) 
  GATE_Area_1E6 = NET AREA GATE > 1.0E3 <= 1.0E6
  GATES = NET AREA RATIO GATE GATE_Area_1E6   M2 M2_DIO HV18_GATE  > 0 
        [ !!AREA(M2) *!!AREA(GATE) * !AREA(M2_DIO) *!!AREA(HV18_GATE)*!!AREA(GATE_Area_1E6)]
 NET AREA RATIO  M2 M1 GATES > 0 ACCUMULATE ACC_M1 
       [
         !!AREA(M2) * !!AREA(M1) * !!AREA(GATES)*(AREA(M2)/AREA(GATES)-7.1E5*(AREA(GATES)^-0.93))
              ] RDB A.R.6.3.M2.rep M2 M1 GATES BY LAYER
}
A.R.6.4:M2 { @ Maximum I/O gate [in OD18] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 1.0E6 
  NET AREA RATIO HV18_GATE M2 M2_DIO  > 1E6 
   [!!AREA(M2)  * !AREA(M2_DIO) *AREA(HV18_GATE)]
  RDB A.R.6.4.M2.rep M2_DIO HV18_GATE 
}
// A.R.6.a is checked by 'A.R.6'

ACC_M2 = NET AREA RATIO M2 GATE >= 0 ACCUMULATE ACC_M1
//VIA2 CHECKS
//===========

A.R.4:VIA2 {  @ Single-layer drawn ratio of a via area to the ACTIVE poly GATE area that is connected directly to it <= 20 
  NET AREA RATIO VIA2 GATE_VIA M2_DIO > 20
      [
        !AREA(M2_DIO) * !!AREA(VIA2) * !!AREA(GATE_VIA) * ( AREA(VIA2)/AREA(GATE_VIA) )
      ] RDB A.R.4.VIA2.rep VIA2 GATE_VIA M2_DIO BY LAYER
}

A.R.7:VIA2 { @ Drawn ratio of cumulative via area (from VIA1 to VIA9) to the ACTIVE poly GATE area with a protection OD <= OD area x 210 + 900 
  NET AREA RATIO VIA2 VIA1 M2_DIO GATE_VIA > 0 ACCUMULATE ACC_VIA1 
       [
         !!AREA(VIA2) * !!AREA(VIA1) * !!AREA(M2_DIO) *
       ( AREA(VIA2)/AREA(GATE_VIA)-AREA(M2_DIO)*210-900 ) 
       - (!AREA(VIA2)+!AREA(M2_DIO)) * LargeNumber      
       ] RDB A.R.7.VIA2.rep VIA2 VIA1 M2_DIO GATE_VIA BY LAYER
}
A.R.9:VIA2 { @ Ratio of cumulative via area (from VIA1 to VIA9) to an ACTIVE poly GATE area [in OD2/ NOT in OD2] <= 50/NA 
  NET AREA RATIO VIA2 VIA1 HV_GATE M2_DIO GATE_VIA > 0 ACCUMULATE ACC_VIA1 
      [
        !AREA(M2_DIO) * !!AREA(VIA2) * !!AREA(VIA1) * !!AREA(GATE_VIA) * !!AREA(HV_GATE) * ( AREA(VIA2)/AREA(GATE_VIA) - 50 )
        - (!!AREA(M2_DIO)+!AREA(VIA2)+!AREA(GATE_VIA)+!AREA(HV_GATE)) * LargeNumber
      ] RDB A.R.9.VIA2.rep VIA2 VIA1 GATE_VIA BY LAYER
}

ACC_VIA2 = NET AREA RATIO VIA2 GATE_VIA >= 0 ACCUMULATE ACC_VIA1

// 'VIAx.R.12' is checked by VIA2.R.12

VIA2.R.12 { @ Maximum area ratio of M2 to upper VIA2 in the same net [connects to gate with area > 10700 um2, and doesn't connect to OD]. This rule is checked by the DRC command files in ANTENNA_DRC directory <=  350000
   NET AREA RATIO M2 VIA2 GATE M2_DIO > 350000
   [!AREA(M2_DIO)*!~(AREA(GATE)-10700)*(AREA(M2)/AREA(VIA2))]  
   RDB VIA2.R.12.rep M2 VIA2 BY LAYER
}

// 'VIAx.R.12.1' is checked by VIA2.R.12.1

VIA2.R.12.1 { @ Maximum area ratio of I/O NMOS gate to single layer VIA2 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  650000
  NET AREA RATIO VIA2 GATE_N_IO M2_DIO_R12 > 650000
       [
       !AREA(M2_DIO_R12) * (AREA(GATE_N_IO)/AREA(VIA2))
       ] RDB VIA2.R.12.1.rep VIA2 GATE_N_IO BY LAYER
}

// 'VIAx.R.12.2' is checked by VIA2.R.12.2

VIA2.R.12.2 { @ Maximum area ratio of I/O PMOS gate to single layer VIA2 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  2500000
  NET AREA RATIO VIA2 GATE_P_IO M2_DIO_R12 > 2500000
       [
       !AREA(M2_DIO_R12) * (AREA(GATE_P_IO)/AREA(VIA2))
       ] RDB VIA2.R.12.2.rep VIA2 GATE_P_IO BY LAYER
}

IMD_M2_M2_A =  NET AREA RATIO M2 SD > 0 [!AREA(SD)]
CONNECT IMD_M2_M2_A M2
ACC_M2_M2_A = NET AREA RATIO M2 SD IMD_M2_M2_A > 0 ACCUMULATE [AREA(M2)]
A.R.8.3:M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
  M2_CHK1 = NET AREA RATIO M2 SD IMD_M2_M2_A > A_R_8_3_A ACCUMULATE [ !AREA(SD)*AREA(M2)] 

  E = EXT [M2_CHK1] M2_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
  NET AREA RATIO M2 SD M2_CHK2 > A_R_8_3_A ACCUMULATE [ !!AREA(M2_CHK2)*!AREA(SD)*AREA(M2)] RDB ONLY A.R.8.3:M2.rep M2 BY LAYER 
}
A.R.8.3.1:M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
  M2_CHK1 = NET AREA RATIO M2 SD IMD_M2_M2_A > A_R_8_3_1_A ACCUMULATE [ !AREA(SD)*AREA(M2)] 

  E = EXT [M2_CHK1] M2_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
  NET AREA RATIO M2 SD M2_CHK2 > A_R_8_3_1_A ACCUMULATE [ !!AREA(M2_CHK2)*!AREA(SD)*AREA(M2)] RDB ONLY A.R.8.3.1:M2.rep M2 BY LAYER 
}
A.R.8.3.2:M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
  M2_CHK1 = NET AREA RATIO M2 SD IMD_M2_M2_A > A_R_8_3_2_A ACCUMULATE [ !AREA(SD)*AREA(M2)] 

  E = EXT [M2_CHK1] M2_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
  NET AREA RATIO M2 SD M2_CHK2 > A_R_8_3_2_A ACCUMULATE [ !!AREA(M2_CHK2)*!AREA(SD)*AREA(M2)] RDB ONLY A.R.8.3.2:M2.rep M2 BY LAYER 
}

ACC_M2_M1_A = NET AREA RATIO M2 VIA1 SD IMD_M1_M1_A > 0 ACCUMULATE ACC_M1_M1_A [!AREA(SD)*(AREA(M2)+AREA(VIA1))]
A.R.8.3:M2_M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
   M1_CHK1 = M1 INTERACT (NET AREA RATIO M2 VIA1 SD IMD_M1_M1_A > A_R_8_3_A ACCUMULATE ACC_M1_M1_A [!AREA(SD)*(AREA(M2)+AREA(VIA1))])
   M1_CHK3 = NET AREA RATIO M1_CHK1 M2 > 0

   E = EXT [M1_CHK3] M1_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
   NET AREA RATIO M2 VIA1 SD M1_CHK2 > A_R_8_3_A ACCUMULATE ACC_M1_M1_A [!!AREA(M1_CHK2)*!AREA(SD)*(AREA(M2)+AREA(VIA1))] RDB ONLY A.R.8.3:M2_M1.rep M2 VIA1 M1_CHK2 BY LAYER
}
A.R.8.3.1:M2_M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
   M1_CHK1 = M1 INTERACT (NET AREA RATIO M2 VIA1 SD IMD_M1_M1_A > A_R_8_3_1_A ACCUMULATE ACC_M1_M1_A [!AREA(SD)*(AREA(M2)+AREA(VIA1))])
   M1_CHK3 = NET AREA RATIO M1_CHK1 M2 > 0

   E = EXT [M1_CHK3] M1_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
   NET AREA RATIO M2 VIA1 SD M1_CHK2 > A_R_8_3_1_A ACCUMULATE ACC_M1_M1_A [!!AREA(M1_CHK2)*!AREA(SD)*(AREA(M2)+AREA(VIA1))] RDB ONLY A.R.8.3.1:M2_M1.rep M2 VIA1 M1_CHK2 BY LAYER
}
A.R.8.3.2:M2_M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
   M1_CHK1 = M1 INTERACT (NET AREA RATIO M2 VIA1 SD IMD_M1_M1_A > A_R_8_3_2_A ACCUMULATE ACC_M1_M1_A [!AREA(SD)*(AREA(M2)+AREA(VIA1))])
   M1_CHK3 = NET AREA RATIO M1_CHK1 M2 > 0

   E = EXT [M1_CHK3] M1_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
   NET AREA RATIO M2 VIA1 SD M1_CHK2 > A_R_8_3_2_A ACCUMULATE ACC_M1_M1_A [!!AREA(M1_CHK2)*!AREA(SD)*(AREA(M2)+AREA(VIA1))] RDB ONLY A.R.8.3.2:M2_M1.rep M2 VIA1 M1_CHK2 BY LAYER
}



//M3 CHECKS
//=========
CONNECT M3 M2   BY VIA2
CONNECT VIA3 M3


M3_DIO = NET AREA SD >= DIO_AREA
M3_DIO_R12 = NET AREA SD >= DIO_AREA_R12
A.R.6__A.R.8:M3 { @ Ratio of cumulative metal top area (from M1 to M10) to an ACTIVE poly GATE area [1.8V I/O in OD2/ except 1.8V I/O in OD2/ NOT in OD2] <= 1000/5000/5000 
                 @ (cumulative M1~M3 area / gate area) <= OD area * 456 + 43000 (with protection OD)
  NET AREA RATIO M3 M2 M1 M3_DIO HV18_GATE GATE > 0  ACCUMULATE ACC_M2 ACC_M1
       [
         !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATE) *
       (!AREA(M3_DIO) * (!!AREA(HV18_GATE)*(AREA(M3)/AREA(GATE)-1000) +
                         !AREA(HV18_GATE)*(AREA(M3)/AREA(GATE)-5000)) +
        !!AREA(M3_DIO) * ( AREA(M3)/AREA(GATE)-AREA(M3_DIO)*456-43000 )) - (!AREA(M3)+!AREA(GATE)) * LargeNumber    
       ] RDB A.R.6_A.R.8.M3.rep M3 M2 M1 M3_DIO HV18_GATE GATE BY LAYER
}
// A.R.6 is checked by A.R.6__A.R.8:M3
// A.R.8 is checked by A.R.6__A.R.8:M3
A.R.6.1:M3 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD25, 1.0E3 um2 < Gate area <= 2.6E5 um2] <= 3.3E6 x (GATE area)(-1.2) 
 GATE_Area1_260K = NET AREA GATE > 1.0E3 <= 260.0E3
 GATES = NET AREA RATIO GATE_Area1_260K GATE M3 M3_DIO HV25_GATE  > 0
     [ !!AREA(M3) *!!AREA(GATE) * ~~AREA(GATE_Area1_260K)*!!AREA(HV25_GATE)*!AREA(M3_DIO) ] 

 NET AREA RATIO M3 M2 M1 M3_DIO GATE_Area1_260K GATES > 0 ACCUMULATE ACC_M2 ACC_M1
    [
      !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATES) *!AREA(M3_DIO)* 
      (AREA(M3)/AREA(GATES)-3.3E6*(AREA(GATES)^-1.2))
       
    ] RDB A.R.6.1.M3.rep M3 M2 M1 M3_DIO  GATES BY LAYER
}
A.R.6.2:M3 { @ Maximum cumulative I/O gate [in OD25] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 2.6E5 
  NET AREA RATIO HV25_GATE M3 M3_DIO   > 2.6E5 
   [!!AREA(M3)  * !AREA(M3_DIO) *AREA(HV25_GATE)] 
  RDB A.R.6.2.M3.rep  M3_DIO  HV25_GATE 
}
A.R.6.3:M3 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD18, 1.0E3 um2 < Gate area <= 1.0E6 um2] <= 7.1E5 x (GATE area)(-0.93) 
  GATE_Area_1E6 = NET AREA GATE > 1.0E3 <= 1.0E6
  GATES = NET AREA RATIO GATE GATE_Area_1E6   M3 M3_DIO HV18_GATE  > 0 
        [ !!AREA(M3) *!!AREA(GATE) * !AREA(M3_DIO) *!!AREA(HV18_GATE)*!!AREA(GATE_Area_1E6)]
 NET AREA RATIO  M3 M2 M1 GATES > 0 ACCUMULATE ACC_M2 ACC_M1 
       [
         !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATES)*(AREA(M3)/AREA(GATES)-7.1E5*(AREA(GATES)^-0.93))
              ] RDB A.R.6.3.M3.rep M3 M2 M1 GATES BY LAYER
}
A.R.6.4:M3 { @ Maximum I/O gate [in OD18] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 1.0E6 
  NET AREA RATIO HV18_GATE M3 M3_DIO  > 1E6 
   [!!AREA(M3)  * !AREA(M3_DIO) *AREA(HV18_GATE)]
  RDB A.R.6.4.M3.rep M3_DIO HV18_GATE 
}
// A.R.6.a is checked by 'A.R.6'

ACC_M3 = NET AREA RATIO M3 GATE >= 0 ACCUMULATE ACC_M2
//VIA3 CHECKS
//===========

A.R.4:VIA3 {  @ Single-layer drawn ratio of a via area to the ACTIVE poly GATE area that is connected directly to it <= 20 
  NET AREA RATIO VIA3 GATE_VIA M3_DIO > 20
      [
        !AREA(M3_DIO) * !!AREA(VIA3) * !!AREA(GATE_VIA) * ( AREA(VIA3)/AREA(GATE_VIA) )
      ] RDB A.R.4.VIA3.rep VIA3 GATE_VIA M3_DIO BY LAYER
}

A.R.7:VIA3 { @ Drawn ratio of cumulative via area (from VIA1 to VIA9) to the ACTIVE poly GATE area with a protection OD <= OD area x 210 + 900 
  NET AREA RATIO VIA3 VIA2 VIA1 M3_DIO GATE_VIA > 0 ACCUMULATE ACC_VIA2 ACC_VIA1 
       [
         !!AREA(VIA3) * !!AREA(VIA2) * !!AREA(VIA1) * !!AREA(M3_DIO) *
       ( AREA(VIA3)/AREA(GATE_VIA)-AREA(M3_DIO)*210-900 ) 
       - (!AREA(VIA3)+!AREA(M3_DIO)) * LargeNumber      
       ] RDB A.R.7.VIA3.rep VIA3 VIA2 VIA1 M3_DIO GATE_VIA BY LAYER
}
A.R.9:VIA3 { @ Ratio of cumulative via area (from VIA1 to VIA9) to an ACTIVE poly GATE area [in OD2/ NOT in OD2] <= 50/NA 
  NET AREA RATIO VIA3 VIA2 VIA1 HV_GATE M3_DIO GATE_VIA > 0 ACCUMULATE ACC_VIA2 ACC_VIA1 
      [
        !AREA(M3_DIO) * !!AREA(VIA3) * !!AREA(VIA2) * !!AREA(VIA1) * !!AREA(GATE_VIA) * !!AREA(HV_GATE) * ( AREA(VIA3)/AREA(GATE_VIA) - 50 )
        - (!!AREA(M3_DIO)+!AREA(VIA3)+!AREA(GATE_VIA)+!AREA(HV_GATE)) * LargeNumber
      ] RDB A.R.9.VIA3.rep VIA3 VIA2 VIA1 GATE_VIA BY LAYER
}

ACC_VIA3 = NET AREA RATIO VIA3 GATE_VIA >= 0 ACCUMULATE ACC_VIA2

// 'VIAx.R.12' is checked by VIA3.R.12

VIA3.R.12 { @ Maximum area ratio of M3 to upper VIA3 in the same net [connects to gate with area > 10700 um2, and doesn't connect to OD]. This rule is checked by the DRC command files in ANTENNA_DRC directory <=  350000
   NET AREA RATIO M3 VIA3 GATE M3_DIO > 350000
   [!AREA(M3_DIO)*!~(AREA(GATE)-10700)*(AREA(M3)/AREA(VIA3))]  
   RDB VIA3.R.12.rep M3 VIA3 BY LAYER
}

// 'VIAx.R.12.1' is checked by VIA3.R.12.1

VIA3.R.12.1 { @ Maximum area ratio of I/O NMOS gate to single layer VIA3 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  650000
  NET AREA RATIO VIA3 GATE_N_IO M3_DIO_R12 > 650000
       [
       !AREA(M3_DIO_R12) * (AREA(GATE_N_IO)/AREA(VIA3))
       ] RDB VIA3.R.12.1.rep VIA3 GATE_N_IO BY LAYER
}

// 'VIAx.R.12.2' is checked by VIA3.R.12.2

VIA3.R.12.2 { @ Maximum area ratio of I/O PMOS gate to single layer VIA3 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  2500000
  NET AREA RATIO VIA3 GATE_P_IO M3_DIO_R12 > 2500000
       [
       !AREA(M3_DIO_R12) * (AREA(GATE_P_IO)/AREA(VIA3))
       ] RDB VIA3.R.12.2.rep VIA3 GATE_P_IO BY LAYER
}

IMD_M3_M3_A =  NET AREA RATIO M3 SD > 0 [!AREA(SD)]
CONNECT IMD_M3_M3_A M3
ACC_M3_M3_A = NET AREA RATIO M3 SD IMD_M3_M3_A > 0 ACCUMULATE [AREA(M3)]
A.R.8.3:M3 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M3_wi_DIO = NET AREA RATIO M3 SD > 0 [!!AREA(SD)]
  M3_CHK1 = NET AREA RATIO M3 SD IMD_M3_M3_A > A_R_8_3_A ACCUMULATE [ !AREA(SD)*AREA(M3)] 

  E = EXT [M3_CHK1] M3_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M3_CHK2 = M3 INTERACT (M3 WITH EDGE E)
  NET AREA RATIO M3 SD M3_CHK2 > A_R_8_3_A ACCUMULATE [ !!AREA(M3_CHK2)*!AREA(SD)*AREA(M3)] RDB ONLY A.R.8.3:M3.rep M3 BY LAYER 
}
A.R.8.3.1:M3 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M3_wi_DIO = NET AREA RATIO M3 SD > 0 [!!AREA(SD)]
  M3_CHK1 = NET AREA RATIO M3 SD IMD_M3_M3_A > A_R_8_3_1_A ACCUMULATE [ !AREA(SD)*AREA(M3)] 

  E = EXT [M3_CHK1] M3_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M3_CHK2 = M3 INTERACT (M3 WITH EDGE E)
  NET AREA RATIO M3 SD M3_CHK2 > A_R_8_3_1_A ACCUMULATE [ !!AREA(M3_CHK2)*!AREA(SD)*AREA(M3)] RDB ONLY A.R.8.3.1:M3.rep M3 BY LAYER 
}
A.R.8.3.2:M3 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M3_wi_DIO = NET AREA RATIO M3 SD > 0 [!!AREA(SD)]
  M3_CHK1 = NET AREA RATIO M3 SD IMD_M3_M3_A > A_R_8_3_2_A ACCUMULATE [ !AREA(SD)*AREA(M3)] 

  E = EXT [M3_CHK1] M3_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M3_CHK2 = M3 INTERACT (M3 WITH EDGE E)
  NET AREA RATIO M3 SD M3_CHK2 > A_R_8_3_2_A ACCUMULATE [ !!AREA(M3_CHK2)*!AREA(SD)*AREA(M3)] RDB ONLY A.R.8.3.2:M3.rep M3 BY LAYER 
}

ACC_M3_M2_A = NET AREA RATIO M3 VIA2 SD IMD_M2_M2_A > 0 ACCUMULATE ACC_M2_M2_A [!AREA(SD)*(AREA(M3)+AREA(VIA2))]
A.R.8.3:M3_M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
   M2_CHK1 = M2 INTERACT (NET AREA RATIO M3 VIA2 SD IMD_M2_M2_A > A_R_8_3_A ACCUMULATE ACC_M2_M2_A [!AREA(SD)*(AREA(M3)+AREA(VIA2))])
   M2_CHK3 = NET AREA RATIO M2_CHK1 M3 > 0

   E = EXT [M2_CHK3] M2_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
   NET AREA RATIO M3 VIA2 SD M2_CHK2 > A_R_8_3_A ACCUMULATE ACC_M2_M2_A [!!AREA(M2_CHK2)*!AREA(SD)*(AREA(M3)+AREA(VIA2))] RDB ONLY A.R.8.3:M3_M2.rep M3 VIA2 M2_CHK2 BY LAYER
}
A.R.8.3.1:M3_M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
   M2_CHK1 = M2 INTERACT (NET AREA RATIO M3 VIA2 SD IMD_M2_M2_A > A_R_8_3_1_A ACCUMULATE ACC_M2_M2_A [!AREA(SD)*(AREA(M3)+AREA(VIA2))])
   M2_CHK3 = NET AREA RATIO M2_CHK1 M3 > 0

   E = EXT [M2_CHK3] M2_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
   NET AREA RATIO M3 VIA2 SD M2_CHK2 > A_R_8_3_1_A ACCUMULATE ACC_M2_M2_A [!!AREA(M2_CHK2)*!AREA(SD)*(AREA(M3)+AREA(VIA2))] RDB ONLY A.R.8.3.1:M3_M2.rep M3 VIA2 M2_CHK2 BY LAYER
}
A.R.8.3.2:M3_M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
   M2_CHK1 = M2 INTERACT (NET AREA RATIO M3 VIA2 SD IMD_M2_M2_A > A_R_8_3_2_A ACCUMULATE ACC_M2_M2_A [!AREA(SD)*(AREA(M3)+AREA(VIA2))])
   M2_CHK3 = NET AREA RATIO M2_CHK1 M3 > 0

   E = EXT [M2_CHK3] M2_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
   NET AREA RATIO M3 VIA2 SD M2_CHK2 > A_R_8_3_2_A ACCUMULATE ACC_M2_M2_A [!!AREA(M2_CHK2)*!AREA(SD)*(AREA(M3)+AREA(VIA2))] RDB ONLY A.R.8.3.2:M3_M2.rep M3 VIA2 M2_CHK2 BY LAYER
}

ACC_M3_M1_A = NET AREA RATIO M3 VIA2 SD IMD_M1_M1_A > 0 ACCUMULATE ACC_M2_M1_A [!AREA(SD)*(AREA(M3)+AREA(VIA2))]
A.R.8.3:M3_M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
   M1_CHK1 = M1 INTERACT (NET AREA RATIO M3 VIA2 SD IMD_M1_M1_A > A_R_8_3_A ACCUMULATE ACC_M2_M1_A [!AREA(SD)*(AREA(M3)+AREA(VIA2))])
   M1_CHK3 = NET AREA RATIO M1_CHK1 M3 > 0

   E = EXT [M1_CHK3] M1_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
   NET AREA RATIO M3 VIA2 SD M1_CHK2 > A_R_8_3_A ACCUMULATE ACC_M2_M1_A [!!AREA(M1_CHK2)*!AREA(SD)*(AREA(M3)+AREA(VIA2))] RDB ONLY A.R.8.3:M3_M1.rep M3 VIA2 M1_CHK2 BY LAYER
}
A.R.8.3.1:M3_M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
   M1_CHK1 = M1 INTERACT (NET AREA RATIO M3 VIA2 SD IMD_M1_M1_A > A_R_8_3_1_A ACCUMULATE ACC_M2_M1_A [!AREA(SD)*(AREA(M3)+AREA(VIA2))])
   M1_CHK3 = NET AREA RATIO M1_CHK1 M3 > 0

   E = EXT [M1_CHK3] M1_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
   NET AREA RATIO M3 VIA2 SD M1_CHK2 > A_R_8_3_1_A ACCUMULATE ACC_M2_M1_A [!!AREA(M1_CHK2)*!AREA(SD)*(AREA(M3)+AREA(VIA2))] RDB ONLY A.R.8.3.1:M3_M1.rep M3 VIA2 M1_CHK2 BY LAYER
}
A.R.8.3.2:M3_M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
   M1_CHK1 = M1 INTERACT (NET AREA RATIO M3 VIA2 SD IMD_M1_M1_A > A_R_8_3_2_A ACCUMULATE ACC_M2_M1_A [!AREA(SD)*(AREA(M3)+AREA(VIA2))])
   M1_CHK3 = NET AREA RATIO M1_CHK1 M3 > 0

   E = EXT [M1_CHK3] M1_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
   NET AREA RATIO M3 VIA2 SD M1_CHK2 > A_R_8_3_2_A ACCUMULATE ACC_M2_M1_A [!!AREA(M1_CHK2)*!AREA(SD)*(AREA(M3)+AREA(VIA2))] RDB ONLY A.R.8.3.2:M3_M1.rep M3 VIA2 M1_CHK2 BY LAYER
}




//M4 CHECKS
//=========
CONNECT M4 M3   BY VIA3
CONNECT VIA4 M4


M4_DIO = NET AREA SD >= DIO_AREA
M4_DIO_R12 = NET AREA SD >= DIO_AREA_R12
A.R.6__A.R.8:M4 { @ Ratio of cumulative metal top area (from M1 to M10) to an ACTIVE poly GATE area [1.8V I/O in OD2/ except 1.8V I/O in OD2/ NOT in OD2] <= 1000/5000/5000 
                 @ (cumulative M1~M4 area / gate area) <= OD area * 456 + 43000 (with protection OD)
  NET AREA RATIO M4 M3 M2 M1 M4_DIO HV18_GATE GATE > 0  ACCUMULATE ACC_M3 ACC_M2 ACC_M1
       [
         !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATE) *
       (!AREA(M4_DIO) * (!!AREA(HV18_GATE)*(AREA(M4)/AREA(GATE)-1000) +
                         !AREA(HV18_GATE)*(AREA(M4)/AREA(GATE)-5000)) +
        !!AREA(M4_DIO) * ( AREA(M4)/AREA(GATE)-AREA(M4_DIO)*456-43000 )) - (!AREA(M4)+!AREA(GATE)) * LargeNumber    
       ] RDB A.R.6_A.R.8.M4.rep M4 M3 M2 M1 M4_DIO HV18_GATE GATE BY LAYER
}
// A.R.6 is checked by A.R.6__A.R.8:M4
// A.R.8 is checked by A.R.6__A.R.8:M4
A.R.6.1:M4 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD25, 1.0E3 um2 < Gate area <= 2.6E5 um2] <= 3.3E6 x (GATE area)(-1.2) 
 GATE_Area1_260K = NET AREA GATE > 1.0E3 <= 260.0E3
 GATES = NET AREA RATIO GATE_Area1_260K GATE M4 M4_DIO HV25_GATE  > 0
     [ !!AREA(M4) *!!AREA(GATE) * ~~AREA(GATE_Area1_260K)*!!AREA(HV25_GATE)*!AREA(M4_DIO) ] 

 NET AREA RATIO M4 M3 M2 M1 M4_DIO GATE_Area1_260K GATES > 0 ACCUMULATE ACC_M3 ACC_M2 ACC_M1
    [
      !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATES) *!AREA(M4_DIO)* 
      (AREA(M4)/AREA(GATES)-3.3E6*(AREA(GATES)^-1.2))
       
    ] RDB A.R.6.1.M4.rep M4 M3 M2 M1 M4_DIO  GATES BY LAYER
}
A.R.6.2:M4 { @ Maximum cumulative I/O gate [in OD25] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 2.6E5 
  NET AREA RATIO HV25_GATE M4 M4_DIO   > 2.6E5 
   [!!AREA(M4)  * !AREA(M4_DIO) *AREA(HV25_GATE)] 
  RDB A.R.6.2.M4.rep  M4_DIO  HV25_GATE 
}
A.R.6.3:M4 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD18, 1.0E3 um2 < Gate area <= 1.0E6 um2] <= 7.1E5 x (GATE area)(-0.93) 
  GATE_Area_1E6 = NET AREA GATE > 1.0E3 <= 1.0E6
  GATES = NET AREA RATIO GATE GATE_Area_1E6   M4 M4_DIO HV18_GATE  > 0 
        [ !!AREA(M4) *!!AREA(GATE) * !AREA(M4_DIO) *!!AREA(HV18_GATE)*!!AREA(GATE_Area_1E6)]
 NET AREA RATIO  M4 M3 M2 M1 GATES > 0 ACCUMULATE ACC_M3 ACC_M2 ACC_M1 
       [
         !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATES)*(AREA(M4)/AREA(GATES)-7.1E5*(AREA(GATES)^-0.93))
              ] RDB A.R.6.3.M4.rep M4 M3 M2 M1 GATES BY LAYER
}
A.R.6.4:M4 { @ Maximum I/O gate [in OD18] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 1.0E6 
  NET AREA RATIO HV18_GATE M4 M4_DIO  > 1E6 
   [!!AREA(M4)  * !AREA(M4_DIO) *AREA(HV18_GATE)]
  RDB A.R.6.4.M4.rep M4_DIO HV18_GATE 
}
// A.R.6.a is checked by 'A.R.6'

ACC_M4 = NET AREA RATIO M4 GATE >= 0 ACCUMULATE ACC_M3
//VIA4 CHECKS
//===========

A.R.4:VIA4 {  @ Single-layer drawn ratio of a via area to the ACTIVE poly GATE area that is connected directly to it <= 20 
  NET AREA RATIO VIA4 GATE_VIA M4_DIO > 20
      [
        !AREA(M4_DIO) * !!AREA(VIA4) * !!AREA(GATE_VIA) * ( AREA(VIA4)/AREA(GATE_VIA) )
      ] RDB A.R.4.VIA4.rep VIA4 GATE_VIA M4_DIO BY LAYER
}

A.R.7:VIA4 { @ Drawn ratio of cumulative via area (from VIA1 to VIA9) to the ACTIVE poly GATE area with a protection OD <= OD area x 210 + 900 
  NET AREA RATIO VIA4 VIA3 VIA2 VIA1 M4_DIO GATE_VIA > 0 ACCUMULATE ACC_VIA3 ACC_VIA2 ACC_VIA1 
       [
         !!AREA(VIA4) * !!AREA(VIA3) * !!AREA(VIA2) * !!AREA(VIA1) * !!AREA(M4_DIO) *
       ( AREA(VIA4)/AREA(GATE_VIA)-AREA(M4_DIO)*210-900 ) 
       - (!AREA(VIA4)+!AREA(M4_DIO)) * LargeNumber      
       ] RDB A.R.7.VIA4.rep VIA4 VIA3 VIA2 VIA1 M4_DIO GATE_VIA BY LAYER
}
A.R.9:VIA4 { @ Ratio of cumulative via area (from VIA1 to VIA9) to an ACTIVE poly GATE area [in OD2/ NOT in OD2] <= 50/NA 
  NET AREA RATIO VIA4 VIA3 VIA2 VIA1 HV_GATE M4_DIO GATE_VIA > 0 ACCUMULATE ACC_VIA3 ACC_VIA2 ACC_VIA1 
      [
        !AREA(M4_DIO) * !!AREA(VIA4) * !!AREA(VIA3) * !!AREA(VIA2) * !!AREA(VIA1) * !!AREA(GATE_VIA) * !!AREA(HV_GATE) * ( AREA(VIA4)/AREA(GATE_VIA) - 50 )
        - (!!AREA(M4_DIO)+!AREA(VIA4)+!AREA(GATE_VIA)+!AREA(HV_GATE)) * LargeNumber
      ] RDB A.R.9.VIA4.rep VIA4 VIA3 VIA2 VIA1 GATE_VIA BY LAYER
}

ACC_VIA4 = NET AREA RATIO VIA4 GATE_VIA >= 0 ACCUMULATE ACC_VIA3

// 'VIAx.R.12' is checked by VIA4.R.12

VIA4.R.12 { @ Maximum area ratio of M4 to upper VIA4 in the same net [connects to gate with area > 10700 um2, and doesn't connect to OD]. This rule is checked by the DRC command files in ANTENNA_DRC directory <=  350000
   NET AREA RATIO M4 VIA4 GATE M4_DIO > 350000
   [!AREA(M4_DIO)*!~(AREA(GATE)-10700)*(AREA(M4)/AREA(VIA4))]  
   RDB VIA4.R.12.rep M4 VIA4 BY LAYER
}

// 'VIAx.R.12.1' is checked by VIA4.R.12.1

VIA4.R.12.1 { @ Maximum area ratio of I/O NMOS gate to single layer VIA4 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  650000
  NET AREA RATIO VIA4 GATE_N_IO M4_DIO_R12 > 650000
       [
       !AREA(M4_DIO_R12) * (AREA(GATE_N_IO)/AREA(VIA4))
       ] RDB VIA4.R.12.1.rep VIA4 GATE_N_IO BY LAYER
}

// 'VIAx.R.12.2' is checked by VIA4.R.12.2

VIA4.R.12.2 { @ Maximum area ratio of I/O PMOS gate to single layer VIA4 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  2500000
  NET AREA RATIO VIA4 GATE_P_IO M4_DIO_R12 > 2500000
       [
       !AREA(M4_DIO_R12) * (AREA(GATE_P_IO)/AREA(VIA4))
       ] RDB VIA4.R.12.2.rep VIA4 GATE_P_IO BY LAYER
}

IMD_M4_M4_A =  NET AREA RATIO M4 SD > 0 [!AREA(SD)]
CONNECT IMD_M4_M4_A M4
ACC_M4_M4_A = NET AREA RATIO M4 SD IMD_M4_M4_A > 0 ACCUMULATE [AREA(M4)]
A.R.8.3:M4 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M4_wi_DIO = NET AREA RATIO M4 SD > 0 [!!AREA(SD)]
  M4_CHK1 = NET AREA RATIO M4 SD IMD_M4_M4_A > A_R_8_3_A ACCUMULATE [ !AREA(SD)*AREA(M4)] 

  E = EXT [M4_CHK1] M4_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M4_CHK2 = M4 INTERACT (M4 WITH EDGE E)
  NET AREA RATIO M4 SD M4_CHK2 > A_R_8_3_A ACCUMULATE [ !!AREA(M4_CHK2)*!AREA(SD)*AREA(M4)] RDB ONLY A.R.8.3:M4.rep M4 BY LAYER 
}
A.R.8.3.1:M4 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M4_wi_DIO = NET AREA RATIO M4 SD > 0 [!!AREA(SD)]
  M4_CHK1 = NET AREA RATIO M4 SD IMD_M4_M4_A > A_R_8_3_1_A ACCUMULATE [ !AREA(SD)*AREA(M4)] 

  E = EXT [M4_CHK1] M4_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M4_CHK2 = M4 INTERACT (M4 WITH EDGE E)
  NET AREA RATIO M4 SD M4_CHK2 > A_R_8_3_1_A ACCUMULATE [ !!AREA(M4_CHK2)*!AREA(SD)*AREA(M4)] RDB ONLY A.R.8.3.1:M4.rep M4 BY LAYER 
}
A.R.8.3.2:M4 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M4_wi_DIO = NET AREA RATIO M4 SD > 0 [!!AREA(SD)]
  M4_CHK1 = NET AREA RATIO M4 SD IMD_M4_M4_A > A_R_8_3_2_A ACCUMULATE [ !AREA(SD)*AREA(M4)] 

  E = EXT [M4_CHK1] M4_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M4_CHK2 = M4 INTERACT (M4 WITH EDGE E)
  NET AREA RATIO M4 SD M4_CHK2 > A_R_8_3_2_A ACCUMULATE [ !!AREA(M4_CHK2)*!AREA(SD)*AREA(M4)] RDB ONLY A.R.8.3.2:M4.rep M4 BY LAYER 
}

ACC_M4_M3_A = NET AREA RATIO M4 VIA3 SD IMD_M3_M3_A > 0 ACCUMULATE ACC_M3_M3_A [!AREA(SD)*(AREA(M4)+AREA(VIA3))]
A.R.8.3:M4_M3 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M3_wi_DIO = NET AREA RATIO M3 SD > 0 [!!AREA(SD)]
   M3_CHK1 = M3 INTERACT (NET AREA RATIO M4 VIA3 SD IMD_M3_M3_A > A_R_8_3_A ACCUMULATE ACC_M3_M3_A [!AREA(SD)*(AREA(M4)+AREA(VIA3))])
   M3_CHK3 = NET AREA RATIO M3_CHK1 M4 > 0

   E = EXT [M3_CHK3] M3_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M3_CHK2 = M3 INTERACT (M3 WITH EDGE E)
   NET AREA RATIO M4 VIA3 SD M3_CHK2 > A_R_8_3_A ACCUMULATE ACC_M3_M3_A [!!AREA(M3_CHK2)*!AREA(SD)*(AREA(M4)+AREA(VIA3))] RDB ONLY A.R.8.3:M4_M3.rep M4 VIA3 M3_CHK2 BY LAYER
}
A.R.8.3.1:M4_M3 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M3_wi_DIO = NET AREA RATIO M3 SD > 0 [!!AREA(SD)]
   M3_CHK1 = M3 INTERACT (NET AREA RATIO M4 VIA3 SD IMD_M3_M3_A > A_R_8_3_1_A ACCUMULATE ACC_M3_M3_A [!AREA(SD)*(AREA(M4)+AREA(VIA3))])
   M3_CHK3 = NET AREA RATIO M3_CHK1 M4 > 0

   E = EXT [M3_CHK3] M3_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
