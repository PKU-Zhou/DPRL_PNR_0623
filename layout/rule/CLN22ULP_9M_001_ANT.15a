  E = EXT [M9_CHK1] M9_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M9_CHK2 = M9 INTERACT (M9 WITH EDGE E)
  NET AREA RATIO M9 SD M9_CHK2 > A_R_8_3_1_A ACCUMULATE [ !!AREA(M9_CHK2)*!AREA(SD)*AREA(M9)] RDB ONLY A.R.8.3.1:M9.rep M9 BY LAYER 
}
A.R.8.3.2:M9 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M9_wi_DIO = NET AREA RATIO M9 SD > 0 [!!AREA(SD)]
  M9_CHK1 = NET AREA RATIO M9 SD IMD_M9_M9_A > A_R_8_3_2_A ACCUMULATE [ !AREA(SD)*AREA(M9)] 

  E = EXT [M9_CHK1] M9_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M9_CHK2 = M9 INTERACT (M9 WITH EDGE E)
  NET AREA RATIO M9 SD M9_CHK2 > A_R_8_3_2_A ACCUMULATE [ !!AREA(M9_CHK2)*!AREA(SD)*AREA(M9)] RDB ONLY A.R.8.3.2:M9.rep M9 BY LAYER 
}








ACC_M9_M8_A = NET AREA RATIO M9 VIA8 SD IMD_M8_M8_A > 0 ACCUMULATE ACC_M8_M8_A [!AREA(SD)*(AREA(M9)+AREA(VIA8))]
