// RULE VALUE VARIABLE
//====================
VARIABLE DNW_R_7_1 	 5.0E6
VARIABLE DNW_R_7_1_A 1.0E7

DISCONNECT

CHIP			= EXTENT
BULK    		= SIZE CHIP BY 1.0
PWi     		= BULK NOT NWi
EMPTYi  		= CHIP NOT BULK // for DRC coding

// Derived layer
NPOD 			= NPi AND ODi
PPOD 			= PPi AND ODi
NACT 			= NPOD NOT NWi
PACT 			= PPOD AND NWi
PSTP 			= PPOD NOT NWi

NW_IN_DNW 		= NWi INTERACT DNWi
PW_OUT_DNW		= PWi NOT DNWi

NACT_CORE       = NACT NOT INTERACT OD2
PACT_CORE       = PACT NOT INTERACT OD2
PSTP_CORE		= PSTP NOT INTERACT OD2

PSTP_SD_NDNW 		= (PSTP NOT POLYc) OUTSIDE DNWi
PACT_CORE_DNW		= (PACT_CORE NOT POLYc) INSIDE NW_IN_DNW
PACT_DNW		= (PACT NOT POLYc) INSIDE NW_IN_DNW

NMOS_GATE_CORE_NDNW	= (NACT_CORE AND POLYc) INSIDE PW_OUT_DNW
PVAR_GATE_CORE_NDNW	= (PSTP_CORE AND POLYc) INSIDE PW_OUT_DNW

PACT_DNW_R_8_pre	= EMPTYi OR PACT_DNW
B_PATH_GATE_pre 		= EMPTYi OR (NMOS_GATE_CORE_NDNW OR PVAR_GATE_CORE_NDNW)




POLY_R_8_pre    = EMPTYi OR POLYc







CTM8_R_8_pre  = EMPTYi OR CTM8
CBM8_R_8_pre  = EMPTYi OR CBM8
V7CAP_CTM_R_8_pre    = EMPTYi OR V7CAP_CTM
V7CAP_CBM_R_8_pre    = EMPTYi OR V7CAP_CBM


CTM9_R_8_pre  = EMPTYi OR CTM9
CBM9_R_8_pre  = EMPTYi OR CBM9
V8CAP_CTM_R_8_pre    = EMPTYi OR V8CAP_CTM
V8CAP_CBM_R_8_pre    = EMPTYi OR V8CAP_CBM

M1_R_8_pre     = EMPTYi OR M1

M2_R_8_pre     = EMPTYi OR M2

M3_R_8_pre     = EMPTYi OR M3

M4_R_8_pre     = EMPTYi OR M4

M5_R_8_pre     = EMPTYi OR M5
TFR_R_8_pre_CON_5 = TFR_R_8_pre AND TFRDUMMY_5

M6_R_8_pre     = EMPTYi OR M6
TFR_R_8_pre_CON_6 = TFR_R_8_pre AND TFRDUMMY_6

M7_R_8_pre     = EMPTYi OR M7
TFR_R_8_pre_CON_7 = TFR_R_8_pre AND TFRDUMMY_7

M8_R_8_pre     = EMPTYi OR M8
TFR_R_8_pre_CON_8 = TFR_R_8_pre AND TFRDUMMY_8

M9_R_8_pre     = EMPTYi OR M9
TFR_R_8_pre_CON_9 = TFR_R_8_pre AND TFRDUMMY_9

VIA1_R_8_pre     = EMPTYi OR VIA1

VIA2_R_8_pre     = EMPTYi OR VIA2

VIA3_R_8_pre     = EMPTYi OR VIA3

VIA4_R_8_pre     = EMPTYi OR VIA4
VIA4_R_8_pre_TFR    = EMPTYi OR VIA4_TFR

VIA5_R_8_pre     = EMPTYi OR VIA5
VIA5_R_8_pre_TFR    = EMPTYi OR VIA5_TFR

VIA6_R_8_pre     = EMPTYi OR VIA6
VIA6_R_8_pre_TFR    = EMPTYi OR VIA6_TFR

VIA7_R_8_pre     = EMPTYi OR VIA7
VIA7_R_8_pre_TFR    = EMPTYi OR VIA7_TFR

VIA8_R_8_pre     = EMPTYi OR VIA8
VIA8_R_8_pre_TFR    = EMPTYi OR VIA8_TFR

CO_R_8_pre    = EMPTYi OR CO
AP_R_8_pre    = EMPTYi OR AP
RV_R_8_pre    = EMPTYi OR RV
CB_R_8_pre    = EMPTYi OR CB
CBD_R_8_pre    = EMPTYi OR CBD
TFR_R_8_pre    = EMPTYi OR TFR


CONNECT B_PATH_GATE_pre POLY_R_8_pre
CONNECT M1_R_8_pre PACT_DNW_R_8_pre POLY_R_8_pre BY CO_R_8_pre

CONNECT M2_R_8_pre M1_R_8_pre   BY VIA1_R_8_pre


CONNECT M3_R_8_pre M2_R_8_pre   BY VIA2_R_8_pre


CONNECT M4_R_8_pre M3_R_8_pre   BY VIA3_R_8_pre


CONNECT M5_R_8_pre TFR_R_8_pre_CON_5 BY VIA4_R_8_pre_TFR
CONNECT M5_R_8_pre M4_R_8_pre   BY VIA4_R_8_pre


CONNECT M6_R_8_pre TFR_R_8_pre_CON_6 BY VIA5_R_8_pre_TFR
CONNECT M6_R_8_pre M5_R_8_pre   BY VIA5_R_8_pre


CONNECT M7_R_8_pre TFR_R_8_pre_CON_7 BY VIA6_R_8_pre_TFR
CONNECT M7_R_8_pre M6_R_8_pre   BY VIA6_R_8_pre


CONNECT M8_R_8_pre CTM8_R_8_pre BY V7CAP_CTM_R_8_pre
CONNECT M8_R_8_pre CBM8_R_8_pre BY V7CAP_CBM_R_8_pre
CONNECT M8_R_8_pre TFR_R_8_pre_CON_8 BY VIA7_R_8_pre_TFR
CONNECT M8_R_8_pre M7_R_8_pre   BY VIA7_R_8_pre

CONNECT M9_R_8_pre CTM9_R_8_pre BY V8CAP_CTM_R_8_pre
CONNECT M9_R_8_pre CBM9_R_8_pre BY V8CAP_CBM_R_8_pre
CONNECT M9_R_8_pre TFR_R_8_pre_CON_9 BY VIA8_R_8_pre_TFR
CONNECT M9_R_8_pre M8_R_8_pre   BY VIA8_R_8_pre


CONNECT CB_R_8_pre M9_R_8_pre
CONNECT M9_R_8_pre AP_R_8_pre     BY RV_R_8_pre
CONNECT M9_R_8_pre AP_R_8_pre     BY CB_R_8_pre
CONNECT M9_R_8_pre AP_R_8_pre     BY CBD_R_8_pre


TARGET_PACT_DNW_R_8 = NET AREA RATIO PACT_DNW_R_8_pre B_PATH_GATE_pre > 0

BULK_new = SIZE CHIP BY 2.0
EMPTYi_new = CHIP NOT BULK_new // for DRC coding

DNW_R_8 = EMPTYi_new OR (DNWi INTERACT TARGET_PACT_DNW_R_8)
B_PATH_GATE = EMPTYi_new OR (NMOS_GATE_CORE_NDNW OR PVAR_GATE_CORE_NDNW)
PACT_DNW_R_8 = EMPTYi_new OR (PACT_DNW INTERACT TARGET_PACT_DNW_R_8)



POLY_R_8    = EMPTYi_new OR POLYc







CTM8_R_8  = EMPTYi_new OR CTM8
CBM8_R_8  = EMPTYi_new OR CBM8
V7CAP_CTM_R_8    = EMPTYi_new OR V7CAP_CTM
V7CAP_CBM_R_8    = EMPTYi_new OR V7CAP_CBM


CTM9_R_8  = EMPTYi_new OR CTM9
CBM9_R_8  = EMPTYi_new OR CBM9
V8CAP_CTM_R_8    = EMPTYi_new OR V8CAP_CTM
V8CAP_CBM_R_8    = EMPTYi_new OR V8CAP_CBM

M1_R_8     = EMPTYi_new OR M1

M2_R_8     = EMPTYi_new OR M2

M3_R_8     = EMPTYi_new OR M3

M4_R_8     = EMPTYi_new OR M4

M5_R_8     = EMPTYi_new OR M5
TFR_R_8_CON_5 = TFR_R_8 AND TFRDUMMY_5

M6_R_8     = EMPTYi_new OR M6
TFR_R_8_CON_6 = TFR_R_8 AND TFRDUMMY_6

M7_R_8     = EMPTYi_new OR M7
TFR_R_8_CON_7 = TFR_R_8 AND TFRDUMMY_7

M8_R_8     = EMPTYi_new OR M8
TFR_R_8_CON_8 = TFR_R_8 AND TFRDUMMY_8

M9_R_8     = EMPTYi_new OR M9
TFR_R_8_CON_9 = TFR_R_8 AND TFRDUMMY_9

VIA1_R_8     = EMPTYi_new OR VIA1

VIA2_R_8     = EMPTYi_new OR VIA2

VIA3_R_8     = EMPTYi_new OR VIA3

VIA4_R_8     = EMPTYi_new OR VIA4
VIA4_R_8_TFR    = EMPTYi_new OR VIA4_TFR

VIA5_R_8     = EMPTYi_new OR VIA5
VIA5_R_8_TFR    = EMPTYi_new OR VIA5_TFR

VIA6_R_8     = EMPTYi_new OR VIA6
VIA6_R_8_TFR    = EMPTYi_new OR VIA6_TFR

VIA7_R_8     = EMPTYi_new OR VIA7
VIA7_R_8_TFR    = EMPTYi_new OR VIA7_TFR

VIA8_R_8     = EMPTYi_new OR VIA8
VIA8_R_8_TFR    = EMPTYi_new OR VIA8_TFR

CO_R_8    = EMPTYi_new OR CO
AP_R_8    = EMPTYi_new OR AP
RV_R_8    = EMPTYi_new OR RV
CB_R_8    = EMPTYi_new OR CB
CBD_R_8    = EMPTYi_new OR CBD
TFR_R_8    = EMPTYi_new OR TFR


CONNECT PACT_DNW_R_8 DNW_R_8
CONNECT B_PATH_GATE POLY_R_8
CONNECT M1_R_8 PACT_DNW_R_8 POLY_R_8 BY CO_R_8

CONNECT M2_R_8 M1_R_8   BY VIA1_R_8


CONNECT M3_R_8 M2_R_8   BY VIA2_R_8


CONNECT M4_R_8 M3_R_8   BY VIA3_R_8


CONNECT M5_R_8 TFR_R_8_CON_5 BY VIA4_R_8_TFR
CONNECT M5_R_8 M4_R_8   BY VIA4_R_8


CONNECT M6_R_8 TFR_R_8_CON_6 BY VIA5_R_8_TFR
CONNECT M6_R_8 M5_R_8   BY VIA5_R_8


CONNECT M7_R_8 TFR_R_8_CON_7 BY VIA6_R_8_TFR
CONNECT M7_R_8 M6_R_8   BY VIA6_R_8


CONNECT M8_R_8 CTM8_R_8 BY V7CAP_CTM_R_8
CONNECT M8_R_8 CBM8_R_8 BY V7CAP_CBM_R_8
CONNECT M8_R_8 TFR_R_8_CON_8 BY VIA7_R_8_TFR
CONNECT M8_R_8 M7_R_8   BY VIA7_R_8

CONNECT M9_R_8 CTM9_R_8 BY V8CAP_CTM_R_8
CONNECT M9_R_8 CBM9_R_8 BY V8CAP_CBM_R_8
CONNECT M9_R_8 TFR_R_8_CON_9 BY VIA8_R_8_TFR
CONNECT M9_R_8 M8_R_8   BY VIA8_R_8


CONNECT CB_R_8 M9_R_8
CONNECT M9_R_8 AP_R_8     BY RV_R_8
CONNECT M9_R_8 AP_R_8     BY CB_R_8
CONNECT M9_R_8 AP_R_8     BY CBD_R_8

DNW.R.7 { @ Maximum cumulative area ratio of DNW to {(NMOS/P-VAR core gates) OUTSIDE DNW} [connects to {P+ ACTIVE INSIDE {NW INTERACT DNW}}] This rule is checked by the ANTENNA DRC command file <= 5.0E6 
  NET AREA RATIO B_PATH_GATE PACT_DNW_R_8 DNW_R_8 > 5.0E6
       [
       !!AREA(B_PATH_GATE) * !!AREA(PACT_DNW_R_8) * !!AREA(DNW_R_8) * (AREA(DNW_R_8)/AREA(B_PATH_GATE))
       ] RDB DNW.R.7.rep DNW_R_8 B_PATH_GATE BY LAYER
}

DISCONNECT

PSD  = SD AND PACT
NSD  = SD AND NACT
PSD_NSD = PSD OR NSD
NSTP = NPOD AND NWi
STP = NSTP OR PSTP
LV_GATE = GATE NOT (OR OD15i OD18i OD25i OD33i)
DNW_BIG = AREA DNWi >= DNW_R_7_1_A 
NW_IN_DNW_1 = NWi INTERACT DNW_BIG
CB1 = OR RV CB CBD

GATE_DNW_CHARGE_IN  = (LV_GATE INSIDE PWi) OUTSIDE DNWi 
PACT_DNW_CHARGE_OUT_PRE = PSD INSIDE NW_IN_DNW_1



CONNECT GATE_DNW_CHARGE_IN POLYc
CONNECT PACT_DNW_CHARGE_OUT_PRE PSD
CONNECT M1 POLYc PSD NSD STP BY CO
CONNECT PSD_NSD PSD
CONNECT PSD_NSD NSD
CO_DNW_CHARGE_PATH = NET AREA RATIO CO STP == 0

CONNECT M2 M1   BY VIA1

VIA1_DNW_CHARGE_PATH = NET AREA RATIO VIA1 STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M3 M2   BY VIA2

VIA2_DNW_CHARGE_PATH = NET AREA RATIO VIA2 STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M4 M3   BY VIA3

VIA3_DNW_CHARGE_PATH = NET AREA RATIO VIA3 STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M5 TFR_CON_5 BY VIA4_TFR
CONNECT M5 M4   BY VIA4

VIA4_DNW_CHARGE_PATH = NET AREA RATIO VIA4 STP == 0  // avoid discharge path on VDD/VSS network
VIA4_TFR_DNW_CHARGE_PATH = NET AREA RATIO VIA4_TFR STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M6 TFR_CON_6 BY VIA5_TFR
CONNECT M6 M5   BY VIA5

VIA5_DNW_CHARGE_PATH = NET AREA RATIO VIA5 STP == 0  // avoid discharge path on VDD/VSS network
VIA5_TFR_DNW_CHARGE_PATH = NET AREA RATIO VIA5_TFR STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M7 TFR_CON_7 BY VIA6_TFR
CONNECT M7 M6   BY VIA6

VIA6_DNW_CHARGE_PATH = NET AREA RATIO VIA6 STP == 0  // avoid discharge path on VDD/VSS network
VIA6_TFR_DNW_CHARGE_PATH = NET AREA RATIO VIA6_TFR STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M8 CTM8 BY V7CAP_CTM
CONNECT M8 CBM8 BY V7CAP_CBM
CONNECT M8 TFR_CON_8 BY VIA7_TFR
CONNECT M8 M7   BY VIA7
VIA7_DNW_CHARGE_PATH = NET AREA RATIO VIA7 STP == 0  // avoid discharge path on VDD/VSS network
VIA7_TFR_DNW_CHARGE_PATH = NET AREA RATIO VIA7_TFR STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M9 CTM9 BY V8CAP_CTM
CONNECT M9 CBM9 BY V8CAP_CBM
CONNECT M9 TFR_CON_9 BY VIA8_TFR
CONNECT M9 M8   BY VIA8
VIA8_DNW_CHARGE_PATH = NET AREA RATIO VIA8 STP == 0  // avoid discharge path on VDD/VSS network
VIA8_TFR_DNW_CHARGE_PATH = NET AREA RATIO VIA8_TFR STP == 0  // avoid discharge path on VDD/VSS network



CONNECT AP M9 BY CB1



CB1_DNW_CHARGE_PATH = NET AREA RATIO CB1 STP == 0

PACT_DNW_CHARGE_OUT = NET AREA RATIO PACT_DNW_CHARGE_OUT_PRE GATE_DNW_CHARGE_IN > 0 // avoid discharge path by DNW serial connection
OD_DNW_CHARGE_PATH = NET AREA RATIO PSD_NSD GATE_DNW_CHARGE_IN > 0 // keep OD interconnection in discharge path, avoid discharge path by DNW serial connection

DISCONNECT

DNW_DISCHARGE_DIODE = (OD_DNW_CHARGE_PATH NOT PACT_DNW_CHARGE_OUT_PRE) OUTSIDE DNWi
DNW_CHARGE_POOL = DNW_BIG INTERACT (NWi INTERACT PACT_DNW_CHARGE_OUT)

CONNECT NWi DNW_CHARGE_POOL
CONNECT PACT_DNW_CHARGE_OUT NWi
CONNECT GATE_DNW_CHARGE_IN POLYc
CONNECT M1 POLYc OD_DNW_CHARGE_PATH BY CO_DNW_CHARGE_PATH




CONNECT OD_DNW_CHARGE_PATH PACT_DNW_CHARGE_OUT
CONNECT OD_DNW_CHARGE_PATH DNW_DISCHARGE_DIODE

DNW.R.7.1:M1 {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {(NMOS/P-VAR core gates) OUTSIDE DNW} [connects to {P+ ACTIVE INSIDE {NW INTERACT DNW}}, and doesn't connect to STRAP] This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN  PACT_DNW_CHARGE_OUT DNW_CHARGE_POOL DNW_DISCHARGE_DIODE > DNW_R_7_1
       [ !!AREA(PACT_DNW_CHARGE_OUT) * (!!AREA(DNW_DISCHARGE_DIODE)+!AREA(DNW_DISCHARGE_DIODE)) * (AREA(DNW_CHARGE_POOL)/AREA(GATE_DNW_CHARGE_IN)) ]
       RDB DNW.R.7.1.M1.rep GATE_DNW_CHARGE_IN DNW_CHARGE_POOL DNW_DISCHARGE_DIODE BY LAYER
}
CONNECT M2 M1   BY VIA1_DNW_CHARGE_PATH


DNW.R.7.1:M2 {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {(NMOS/P-VAR core gates) OUTSIDE DNW} [connects to {P+ ACTIVE INSIDE {NW INTERACT DNW}}, and doesn't connect to STRAP] This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN M2 PACT_DNW_CHARGE_OUT DNW_CHARGE_POOL DNW_DISCHARGE_DIODE > DNW_R_7_1
       [!!AREA(M2) * !!AREA(PACT_DNW_CHARGE_OUT) * (!!AREA(DNW_DISCHARGE_DIODE)+!AREA(DNW_DISCHARGE_DIODE)) * (AREA(DNW_CHARGE_POOL)/AREA(GATE_DNW_CHARGE_IN)) ]
       RDB DNW.R.7.1.M2.rep GATE_DNW_CHARGE_IN DNW_CHARGE_POOL DNW_DISCHARGE_DIODE BY LAYER
}
CONNECT M3 M2   BY VIA2_DNW_CHARGE_PATH


DNW.R.7.1:M3 {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {(NMOS/P-VAR core gates) OUTSIDE DNW} [connects to {P+ ACTIVE INSIDE {NW INTERACT DNW}}, and doesn't connect to STRAP] This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN M3 PACT_DNW_CHARGE_OUT DNW_CHARGE_POOL DNW_DISCHARGE_DIODE > DNW_R_7_1
       [!!AREA(M3) * !!AREA(PACT_DNW_CHARGE_OUT) * (!!AREA(DNW_DISCHARGE_DIODE)+!AREA(DNW_DISCHARGE_DIODE)) * (AREA(DNW_CHARGE_POOL)/AREA(GATE_DNW_CHARGE_IN)) ]
       RDB DNW.R.7.1.M3.rep GATE_DNW_CHARGE_IN DNW_CHARGE_POOL DNW_DISCHARGE_DIODE BY LAYER
}
CONNECT M4 M3   BY VIA3_DNW_CHARGE_PATH


DNW.R.7.1:M4 {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {(NMOS/P-VAR core gates) OUTSIDE DNW} [connects to {P+ ACTIVE INSIDE {NW INTERACT DNW}}, and doesn't connect to STRAP] This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN M4 PACT_DNW_CHARGE_OUT DNW_CHARGE_POOL DNW_DISCHARGE_DIODE > DNW_R_7_1
       [!!AREA(M4) * !!AREA(PACT_DNW_CHARGE_OUT) * (!!AREA(DNW_DISCHARGE_DIODE)+!AREA(DNW_DISCHARGE_DIODE)) * (AREA(DNW_CHARGE_POOL)/AREA(GATE_DNW_CHARGE_IN)) ]
       RDB DNW.R.7.1.M4.rep GATE_DNW_CHARGE_IN DNW_CHARGE_POOL DNW_DISCHARGE_DIODE BY LAYER
}
CONNECT M5 TFR_CON_5 BY VIA4_TFR_DNW_CHARGE_PATH
CONNECT M5 M4   BY VIA4_DNW_CHARGE_PATH


DNW.R.7.1:M5 {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {(NMOS/P-VAR core gates) OUTSIDE DNW} [connects to {P+ ACTIVE INSIDE {NW INTERACT DNW}}, and doesn't connect to STRAP] This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN M5 PACT_DNW_CHARGE_OUT DNW_CHARGE_POOL DNW_DISCHARGE_DIODE > DNW_R_7_1
       [!!AREA(M5) * !!AREA(PACT_DNW_CHARGE_OUT) * (!!AREA(DNW_DISCHARGE_DIODE)+!AREA(DNW_DISCHARGE_DIODE)) * (AREA(DNW_CHARGE_POOL)/AREA(GATE_DNW_CHARGE_IN)) ]
       RDB DNW.R.7.1.M5.rep GATE_DNW_CHARGE_IN DNW_CHARGE_POOL DNW_DISCHARGE_DIODE BY LAYER
}
CONNECT M6 TFR_CON_6 BY VIA5_TFR_DNW_CHARGE_PATH
CONNECT M6 M5   BY VIA5_DNW_CHARGE_PATH


DNW.R.7.1:M6 {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {(NMOS/P-VAR core gates) OUTSIDE DNW} [connects to {P+ ACTIVE INSIDE {NW INTERACT DNW}}, and doesn't connect to STRAP] This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN M6 PACT_DNW_CHARGE_OUT DNW_CHARGE_POOL DNW_DISCHARGE_DIODE > DNW_R_7_1
       [!!AREA(M6) * !!AREA(PACT_DNW_CHARGE_OUT) * (!!AREA(DNW_DISCHARGE_DIODE)+!AREA(DNW_DISCHARGE_DIODE)) * (AREA(DNW_CHARGE_POOL)/AREA(GATE_DNW_CHARGE_IN)) ]
       RDB DNW.R.7.1.M6.rep GATE_DNW_CHARGE_IN DNW_CHARGE_POOL DNW_DISCHARGE_DIODE BY LAYER
}
CONNECT M7 TFR_CON_7 BY VIA6_TFR_DNW_CHARGE_PATH
CONNECT M7 M6   BY VIA6_DNW_CHARGE_PATH


DNW.R.7.1:M7 {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {(NMOS/P-VAR core gates) OUTSIDE DNW} [connects to {P+ ACTIVE INSIDE {NW INTERACT DNW}}, and doesn't connect to STRAP] This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN M7 PACT_DNW_CHARGE_OUT DNW_CHARGE_POOL DNW_DISCHARGE_DIODE > DNW_R_7_1
       [!!AREA(M7) * !!AREA(PACT_DNW_CHARGE_OUT) * (!!AREA(DNW_DISCHARGE_DIODE)+!AREA(DNW_DISCHARGE_DIODE)) * (AREA(DNW_CHARGE_POOL)/AREA(GATE_DNW_CHARGE_IN)) ]
       RDB DNW.R.7.1.M7.rep GATE_DNW_CHARGE_IN DNW_CHARGE_POOL DNW_DISCHARGE_DIODE BY LAYER
}
CONNECT M8 CTM8 BY V7CAP_CTM
CONNECT M8 CBM8 BY V7CAP_CBM
CONNECT M8 TFR_CON_8 BY VIA7_TFR_DNW_CHARGE_PATH
CONNECT M8 M7   BY VIA7_DNW_CHARGE_PATH

DNW.R.7.1:M8 {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {(NMOS/P-VAR core gates) OUTSIDE DNW} [connects to {P+ ACTIVE INSIDE {NW INTERACT DNW}}, and doesn't connect to STRAP] This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN M8 PACT_DNW_CHARGE_OUT DNW_CHARGE_POOL DNW_DISCHARGE_DIODE > DNW_R_7_1
       [!!AREA(M8) * !!AREA(PACT_DNW_CHARGE_OUT) * (!!AREA(DNW_DISCHARGE_DIODE)+!AREA(DNW_DISCHARGE_DIODE)) * (AREA(DNW_CHARGE_POOL)/AREA(GATE_DNW_CHARGE_IN)) ]
       RDB DNW.R.7.1.M8.rep GATE_DNW_CHARGE_IN DNW_CHARGE_POOL DNW_DISCHARGE_DIODE BY LAYER
}
CONNECT M9 CTM9 BY V8CAP_CTM
CONNECT M9 CBM9 BY V8CAP_CBM
CONNECT M9 TFR_CON_9 BY VIA8_TFR_DNW_CHARGE_PATH
CONNECT M9 M8   BY VIA8_DNW_CHARGE_PATH

DNW.R.7.1:M9 {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {(NMOS/P-VAR core gates) OUTSIDE DNW} [connects to {P+ ACTIVE INSIDE {NW INTERACT DNW}}, and doesn't connect to STRAP] This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN M9 PACT_DNW_CHARGE_OUT DNW_CHARGE_POOL DNW_DISCHARGE_DIODE > DNW_R_7_1
       [!!AREA(M9) * !!AREA(PACT_DNW_CHARGE_OUT) * (!!AREA(DNW_DISCHARGE_DIODE)+!AREA(DNW_DISCHARGE_DIODE)) * (AREA(DNW_CHARGE_POOL)/AREA(GATE_DNW_CHARGE_IN)) ]
       RDB DNW.R.7.1.M9.rep GATE_DNW_CHARGE_IN DNW_CHARGE_POOL DNW_DISCHARGE_DIODE BY LAYER
}
CONNECT AP M9 BY CB1_DNW_CHARGE_PATH
DNW.R.7.1:AP {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {(NMOS/P-VAR core gates) OUTSIDE DNW} [connects to {P+ ACTIVE INSIDE {NW INTERACT DNW}}, and doesn't connect to STRAP] This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN AP PACT_DNW_CHARGE_OUT DNW_CHARGE_POOL DNW_DISCHARGE_DIODE > DNW_R_7_1
       [!!AREA(AP) * !!AREA(PACT_DNW_CHARGE_OUT) * (!!AREA(DNW_DISCHARGE_DIODE)+!AREA(DNW_DISCHARGE_DIODE)) * (AREA(DNW_CHARGE_POOL)/AREA(GATE_DNW_CHARGE_IN)) ]
       RDB DNW.R.7.1.AP.rep GATE_DNW_CHARGE_IN DNW_CHARGE_POOL DNW_DISCHARGE_DIODE BY LAYER
}


DISCONNECT

VARIABLE DNW_R_7_2  	   5.0E6
VARIABLE DNW_R_7_2_A    1.0E7
VARIABLE DNW_R_7_2_B    1.0E3

DNW_BIG_DNWR72 = AREA DNWi >= DNW_R_7_2_A 
NOT_BIG_DNW = DNWi NOT INTERACT DNW_BIG_DNWR72
CHECK_SMALL_DNW = AREA NOT_BIG_DNW <= DNW_R_7_2_B
NW_IN_DNW_DNWR72 = NWi INTERACT DNW_BIG_DNWR72

GATE_DNW_CHARGE_IN_in_DNW  = (LV_GATE INSIDE PWi) INSIDE CHECK_SMALL_DNW 
PACT_DNW_CHARGE_OUT_PRE_DNWR72 = PSD INSIDE NW_IN_DNW_DNWR72



CONNECT GATE_DNW_CHARGE_IN_in_DNW POLYc 
CONNECT PACT_DNW_CHARGE_OUT_PRE_DNWR72 PSD
CONNECT M1 POLYc PSD NSD STP BY CO
CONNECT PSD_NSD PSD
CONNECT PSD_NSD NSD
CO_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO CO STP == 0

CONNECT M2 M1   BY VIA1

VIA1_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA1 STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M3 M2   BY VIA2

VIA2_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA2 STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M4 M3   BY VIA3

VIA3_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA3 STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M5 TFR_CON_5 BY VIA4_TFR
CONNECT M5 M4   BY VIA4

VIA4_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA4 STP == 0  // avoid discharge path on VDD/VSS network
VIA4_TFR_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA4_TFR STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M6 TFR_CON_6 BY VIA5_TFR
CONNECT M6 M5   BY VIA5

VIA5_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA5 STP == 0  // avoid discharge path on VDD/VSS network
VIA5_TFR_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA5_TFR STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M7 TFR_CON_7 BY VIA6_TFR
CONNECT M7 M6   BY VIA6

VIA6_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA6 STP == 0  // avoid discharge path on VDD/VSS network
VIA6_TFR_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA6_TFR STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M8 CTM8 BY V7CAP_CTM
CONNECT M8 CBM8 BY V7CAP_CBM
CONNECT M8 TFR_CON_8 BY VIA7_TFR
CONNECT M8 M7   BY VIA7
VIA7_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA7 STP == 0  // avoid discharge path on VDD/VSS network
VIA7_TFR_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA7_TFR STP == 0  // avoid discharge path on VDD/VSS network


CONNECT M9 CTM9 BY V8CAP_CTM
CONNECT M9 CBM9 BY V8CAP_CBM
CONNECT M9 TFR_CON_9 BY VIA8_TFR
CONNECT M9 M8   BY VIA8
VIA8_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA8 STP == 0  // avoid discharge path on VDD/VSS network
VIA8_TFR_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO VIA8_TFR STP == 0  // avoid discharge path on VDD/VSS network



CONNECT AP M9 BY CB1

CB1_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO CB1 STP == 0

PACT_DNW_CHARGE_OUT_DNWR72 = NET AREA RATIO PACT_DNW_CHARGE_OUT_PRE_DNWR72 GATE_DNW_CHARGE_IN_in_DNW > 0 // avoid discharge path by DNW serial connection
OD_DNW_CHARGE_PATH_DNWR72 = NET AREA RATIO PSD_NSD GATE_DNW_CHARGE_IN_in_DNW > 0 // keep OD interconnection in discharge path, avoid discharge path by DNW serial connection

DISCONNECT

DNW_DISCHARGE_DIODE_DNWR72 = (OD_DNW_CHARGE_PATH_DNWR72 NOT PACT_DNW_CHARGE_OUT_PRE_DNWR72) OUTSIDE DNW_BIG_DNWR72
DNW_CHARGE_POOL_DNWR72 = DNW_BIG_DNWR72 INTERACT (NWi INTERACT PACT_DNW_CHARGE_OUT_DNWR72)

CONNECT NWi DNW_CHARGE_POOL_DNWR72
CONNECT PACT_DNW_CHARGE_OUT_DNWR72 NWi
CONNECT GATE_DNW_CHARGE_IN_in_DNW POLYc 
CONNECT M1 POLYc OD_DNW_CHARGE_PATH_DNWR72 BY CO_DNW_CHARGE_PATH_DNWR72

CONNECT OD_DNW_CHARGE_PATH_DNWR72 PACT_DNW_CHARGE_OUT_DNWR72
CONNECT OD_DNW_CHARGE_PATH_DNWR72 DNW_DISCHARGE_DIODE_DNWR72



DNW.R.7.2:M1 {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {core_NMOS/P-VAR INSIDE DNW [area <= 1E03 um2]} Definition of core_NMOS/P-VAR: 1. NMOS and P-VAR gates do not inside OD2, and 2. Connect to {P+ ACTIVE INSIDE {NW INTERACT DNW [area >= 1E+07 um2]}}, and 3. Do not connect to STRAP This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN_in_DNW  PACT_DNW_CHARGE_OUT_DNWR72 DNW_CHARGE_POOL_DNWR72 DNW_DISCHARGE_DIODE_DNWR72 > DNW_R_7_2
       [ !!AREA(PACT_DNW_CHARGE_OUT_DNWR72) * (!!AREA(DNW_DISCHARGE_DIODE_DNWR72)+!AREA(DNW_DISCHARGE_DIODE_DNWR72)) * (AREA(DNW_CHARGE_POOL_DNWR72)/AREA(GATE_DNW_CHARGE_IN_in_DNW)) ]
       RDB DNW.R.7.2.M1.rep GATE_DNW_CHARGE_IN_in_DNW DNW_CHARGE_POOL_DNWR72 DNW_DISCHARGE_DIODE_DNWR72 BY LAYER
}
CONNECT M2 M1   BY VIA1_DNW_CHARGE_PATH_DNWR72


DNW.R.7.2:M2 {@ Maximum cumulative area ratio of DNW [area >= 1E+07 um2] to {core_NMOS/P-VAR INSIDE DNW [area <= 1E03 um2]} Definition of core_NMOS/P-VAR: 1. NMOS and P-VAR gates do not inside OD2, and 2. Connect to {P+ ACTIVE INSIDE {NW INTERACT DNW [area >= 1E+07 um2]}}, and 3. Do not connect to STRAP This rule is checked by the cumulative connections (from M1 to AP respectively) and the DRC command files in ANTENNA_DRC directory <= 5.0E6 
   NET AREA RATIO GATE_DNW_CHARGE_IN_in_DNW M2 PACT_DNW_CHARGE_OUT_DNWR72 DNW_CHARGE_POOL_DNWR72 DNW_DISCHARGE_DIODE_DNWR72 > DNW_R_7_2
