   M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
   M2_CHK1 = M2 INTERACT (NET AREA RATIO M8 VIA7 SD IMD_M2_M2_A > A_R_8_3_2_A ACCUMULATE ACC_M7_M2_A [!AREA(SD)*(AREA(M8)+AREA(VIA7))])
   M2_CHK3 = NET AREA RATIO M2_CHK1 M8 > 0

   E = EXT [M2_CHK3] M2_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
   NET AREA RATIO M8 VIA7 SD M2_CHK2 > A_R_8_3_2_A ACCUMULATE ACC_M7_M2_A [!!AREA(M2_CHK2)*!AREA(SD)*(AREA(M8)+AREA(VIA7))] RDB ONLY A.R.8.3.2:M8_M2.rep M8 VIA7 M2_CHK2 BY LAYER
}


ACC_M8_M1_A = NET AREA RATIO M8 VIA7 SD IMD_M1_M1_A > 0 ACCUMULATE ACC_M7_M1_A [!AREA(SD)*(AREA(M8)+AREA(VIA7))]
