   M3_CHK1 = M3 INTERACT (NET AREA RATIO M7 VIA6 SD IMD_M3_M3_A > A_R_8_3_1_A ACCUMULATE ACC_M6_M3_A [!AREA(SD)*(AREA(M7)+AREA(VIA6))])
   M3_CHK3 = NET AREA RATIO M3_CHK1 M7 > 0

   E = EXT [M3_CHK3] M3_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M3_CHK2 = M3 INTERACT (M3 WITH EDGE E)
   NET AREA RATIO M7 VIA6 SD M3_CHK2 > A_R_8_3_1_A ACCUMULATE ACC_M6_M3_A [!!AREA(M3_CHK2)*!AREA(SD)*(AREA(M7)+AREA(VIA6))] RDB ONLY A.R.8.3.1:M7_M3.rep M7 VIA6 M3_CHK2 BY LAYER
}
A.R.8.3.2:M7_M3 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M3_wi_DIO = NET AREA RATIO M3 SD > 0 [!!AREA(SD)]
   M3_CHK1 = M3 INTERACT (NET AREA RATIO M7 VIA6 SD IMD_M3_M3_A > A_R_8_3_2_A ACCUMULATE ACC_M6_M3_A [!AREA(SD)*(AREA(M7)+AREA(VIA6))])
   M3_CHK3 = NET AREA RATIO M3_CHK1 M7 > 0

   E = EXT [M3_CHK3] M3_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M3_CHK2 = M3 INTERACT (M3 WITH EDGE E)
   NET AREA RATIO M7 VIA6 SD M3_CHK2 > A_R_8_3_2_A ACCUMULATE ACC_M6_M3_A [!!AREA(M3_CHK2)*!AREA(SD)*(AREA(M7)+AREA(VIA6))] RDB ONLY A.R.8.3.2:M7_M3.rep M7 VIA6 M3_CHK2 BY LAYER
}


ACC_M7_M2_A = NET AREA RATIO M7 VIA6 SD IMD_M2_M2_A > 0 ACCUMULATE ACC_M6_M2_A [!AREA(SD)*(AREA(M7)+AREA(VIA6))]
A.R.8.3:M7_M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
