   NET AREA RATIO M9 VIA8 SD M1_CHK2 > A_R_8_3_2_A ACCUMULATE ACC_M8_M1_A [!!AREA(M1_CHK2)*!AREA(SD)*!!AREA(M9)*(AREA(M9)+AREA(VIA8))] RDB ONLY A.R.8.3.2:M9_M1.rep M9 VIA8 M1_CHK2 BY LAYER
}





//AP CHECKS
//=========
CONNECT AP M9 BY RV
CONNECT AP M9 BY CB
CONNECT AP M9 BY CBD

AP_DIO = NET AREA SD >= DIO_AREA
VARIABLE AP_THICKNESS 2.8 // user value
A.R.11__A.R.13:AP {@ Drawn ratio of AP sidewall area to the ACTIVE poly GATE area that is connected directly to it [in OD2/ NOT in OD2] <= 1000/2000 
                  @ (AP sidewall area / gate area) <= OD area * 8000 + 30000 (with protection OD)
     NET AREA RATIO AP AP_DIO HV_GATE GATE > 0
       [
       !!AREA(AP) * !!AREA(GATE) *
       (!AREA(AP_DIO) * (!!AREA(HV_GATE)*(PERIMETER(AP)*AP_THICKNESS/AREA(GATE)-1000) +
                 !AREA(HV_GATE)*(PERIMETER(AP)*AP_THICKNESS/AREA(GATE)-2000)) +
        !!AREA(AP_DIO) * (PERIMETER(AP)*AP_THICKNESS/AREA(GATE) - AREA(AP_DIO)*8000 - 30000))
         - (!AREA(AP)+!AREA(GATE)) * LargeNumber    
       ] RDB A.R.11_A.R.13.AP.rep AP AP_DIO HV_GATE GATE BY LAYER
}
    AP_PAD = APi INTERACT (OR CB2Fi CB2Wi)
A.R.8.7 { @ Floating_Circuits space to Mn (Mn starts from M1 to AP) [connects to OD] <= 0.10 um is not allowed Definition of Floating_Circuits: 1. The metal net doesn't connect to OD, from M1 to AP, and 2. connect to {AP INTERACT {CB2_FC OR CB2_WB}} This rule is checked from M1 to AP respectively   
  AP_PAD_c = STAMP AP_PAD BY AP
  PAD_wo_DIO = NET AREA RATIO AP_PAD_c SD > 0 [!AREA(SD)]
  M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
  M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
  M3_wi_DIO = NET AREA RATIO M3 SD > 0 [!!AREA(SD)]
  M4_wi_DIO = NET AREA RATIO M4 SD > 0 [!!AREA(SD)]
  M5_wi_DIO = NET AREA RATIO M5 SD > 0 [!!AREA(SD)]
  M6_wi_DIO = NET AREA RATIO M6 SD > 0 [!!AREA(SD)]
  M7_wi_DIO = NET AREA RATIO M7 SD > 0 [!!AREA(SD)]
  M8_wi_DIO = NET AREA RATIO M8 SD > 0 [!!AREA(SD)]
  M9_wi_DIO = NET AREA RATIO M9 SD > 0 [!!AREA(SD)]
  AP_wi_DIO = NET AREA RATIO AP SD > 0 [!!AREA(SD)]
  AP_wo_DIO = NET AREA RATIO AP PAD_wo_DIO > 0
  EXT AP_wo_DIO AP_wi_DIO <= 0.1 ABUT < 90 NOT CONNECTED
  M1_wo_DIO_AP = NET AREA RATIO M1 PAD_wo_DIO > 0 
  EXT M1_wo_DIO_AP M1_wi_DIO <= 0.1 ABUT < 90 NOT CONNECTED  
  M2_wo_DIO_AP = NET AREA RATIO M2 PAD_wo_DIO > 0 
  EXT M2_wo_DIO_AP M2_wi_DIO <= 0.1 ABUT < 90 NOT CONNECTED  
  M3_wo_DIO_AP = NET AREA RATIO M3 PAD_wo_DIO > 0 
  EXT M3_wo_DIO_AP M3_wi_DIO <= 0.1 ABUT < 90 NOT CONNECTED  
  M4_wo_DIO_AP = NET AREA RATIO M4 PAD_wo_DIO > 0 
  EXT M4_wo_DIO_AP M4_wi_DIO <= 0.1 ABUT < 90 NOT CONNECTED  
  M5_wo_DIO_AP = NET AREA RATIO M5 PAD_wo_DIO > 0 
  EXT M5_wo_DIO_AP M5_wi_DIO <= 0.1 ABUT < 90 NOT CONNECTED  
  M6_wo_DIO_AP = NET AREA RATIO M6 PAD_wo_DIO > 0 
  EXT M6_wo_DIO_AP M6_wi_DIO <= 0.1 ABUT < 90 NOT CONNECTED  
  M7_wo_DIO_AP = NET AREA RATIO M7 PAD_wo_DIO > 0 
  EXT M7_wo_DIO_AP M7_wi_DIO <= 0.1 ABUT < 90 NOT CONNECTED  
  M8_wo_DIO_AP = NET AREA RATIO M8 PAD_wo_DIO > 0 
  EXT M8_wo_DIO_AP M8_wi_DIO <= 0.1 ABUT < 90 NOT CONNECTED  
  M9_wo_DIO_AP = NET AREA RATIO M9 PAD_wo_DIO > 0 
  EXT M9_wo_DIO_AP M9_wi_DIO <= 0.1 ABUT < 90 NOT CONNECTED  
}
// 'VIAy.R.12' is checked by 'VIAx.R.12'
// 'VIAy.R.12.1' is checked by 'VIAx.R.12.1'
// 'VIAy.R.12.2' is checked by 'VIAx.R.12.2'


// 'VIAz.R.12' is checked by 'VIAx.R.12'
// 'VIAr.R.12' is checked by 'VIAx.R.12'
// 'VIAr.R.12.1' is checked by 'VIAx.R.12.1'
// 'VIAr.R.12.2' is checked by 'VIAx.R.12.2'
// 'VIAu.R.12' is checked by 'VIAx.R.12'
