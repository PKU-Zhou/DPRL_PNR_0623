}




//M5 CHECKS
//=========
CONNECT M5 TFR_CON_5 BY VIA4_TFR
CONNECT M5 M4   BY VIA4
CONNECT VIA5 M5


M5_DIO = NET AREA SD >= DIO_AREA
M5_DIO_R12 = NET AREA SD >= DIO_AREA_R12
A.R.6__A.R.8:M5 { @ Ratio of cumulative metal top area (from M1 to M10) to an ACTIVE poly GATE area [1.8V I/O in OD2/ except 1.8V I/O in OD2/ NOT in OD2] <= 1000/5000/5000 
                 @ (cumulative M1~M5 area / gate area) <= OD area * 456 + 43000 (with protection OD)
  NET AREA RATIO M5 M4 M3 M2 M1 M5_DIO HV18_GATE GATE > 0  ACCUMULATE ACC_M4 ACC_M3 ACC_M2 ACC_M1
       [
         !!AREA(M5) * !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATE) *
       (!AREA(M5_DIO) * (!!AREA(HV18_GATE)*(AREA(M5)/AREA(GATE)-1000) +
                         !AREA(HV18_GATE)*(AREA(M5)/AREA(GATE)-5000)) +
        !!AREA(M5_DIO) * ( AREA(M5)/AREA(GATE)-AREA(M5_DIO)*456-43000 )) - (!AREA(M5)+!AREA(GATE)) * LargeNumber    
       ] RDB A.R.6_A.R.8.M5.rep M5 M4 M3 M2 M1 M5_DIO HV18_GATE GATE BY LAYER
}
// A.R.6 is checked by A.R.6__A.R.8:M5
// A.R.8 is checked by A.R.6__A.R.8:M5
A.R.6.1:M5 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD25, 1.0E3 um2 < Gate area <= 2.6E5 um2] <= 3.3E6 x (GATE area)(-1.2) 
 GATE_Area1_260K = NET AREA GATE > 1.0E3 <= 260.0E3
 GATES = NET AREA RATIO GATE_Area1_260K GATE M5 M5_DIO HV25_GATE  > 0
     [ !!AREA(M5) *!!AREA(GATE) * ~~AREA(GATE_Area1_260K)*!!AREA(HV25_GATE)*!AREA(M5_DIO) ] 

 NET AREA RATIO M5 M4 M3 M2 M1 M5_DIO GATE_Area1_260K GATES > 0 ACCUMULATE ACC_M4 ACC_M3 ACC_M2 ACC_M1
    [
      !!AREA(M5) * !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATES) *!AREA(M5_DIO)* 
      (AREA(M5)/AREA(GATES)-3.3E6*(AREA(GATES)^-1.2))
       
    ] RDB A.R.6.1.M5.rep M5 M4 M3 M2 M1 M5_DIO  GATES BY LAYER
}
A.R.6.2:M5 { @ Maximum cumulative I/O gate [in OD25] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 2.6E5 
  NET AREA RATIO HV25_GATE M5 M5_DIO   > 2.6E5 
   [!!AREA(M5)  * !AREA(M5_DIO) *AREA(HV25_GATE)] 
  RDB A.R.6.2.M5.rep  M5_DIO  HV25_GATE 
}
A.R.6.3:M5 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD18, 1.0E3 um2 < Gate area <= 1.0E6 um2] <= 7.1E5 x (GATE area)(-0.93) 
  GATE_Area_1E6 = NET AREA GATE > 1.0E3 <= 1.0E6
  GATES = NET AREA RATIO GATE GATE_Area_1E6   M5 M5_DIO HV18_GATE  > 0 
        [ !!AREA(M5) *!!AREA(GATE) * !AREA(M5_DIO) *!!AREA(HV18_GATE)*!!AREA(GATE_Area_1E6)]
 NET AREA RATIO  M5 M4 M3 M2 M1 GATES > 0 ACCUMULATE ACC_M4 ACC_M3 ACC_M2 ACC_M1 
       [
         !!AREA(M5) * !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATES)*(AREA(M5)/AREA(GATES)-7.1E5*(AREA(GATES)^-0.93))
              ] RDB A.R.6.3.M5.rep M5 M4 M3 M2 M1 GATES BY LAYER
}
A.R.6.4:M5 { @ Maximum I/O gate [in OD18] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 1.0E6 
  NET AREA RATIO HV18_GATE M5 M5_DIO  > 1E6 
   [!!AREA(M5)  * !AREA(M5_DIO) *AREA(HV18_GATE)]
  RDB A.R.6.4.M5.rep M5_DIO HV18_GATE 
}
// A.R.6.a is checked by 'A.R.6'

ACC_M5 = NET AREA RATIO M5 GATE >= 0 ACCUMULATE ACC_M4
//VIA5 CHECKS
//===========

A.R.4:VIA5 {  @ Single-layer drawn ratio of a via area to the ACTIVE poly GATE area that is connected directly to it <= 20 
  NET AREA RATIO VIA5 GATE_VIA M5_DIO > 20
      [
        !AREA(M5_DIO) * !!AREA(VIA5) * !!AREA(GATE_VIA) * ( AREA(VIA5)/AREA(GATE_VIA) )
      ] RDB A.R.4.VIA5.rep VIA5 GATE_VIA M5_DIO BY LAYER
}

A.R.7:VIA5 { @ Drawn ratio of cumulative via area (from VIA1 to VIA9) to the ACTIVE poly GATE area with a protection OD <= OD area x 210 + 900 
  NET AREA RATIO VIA5 VIA4 VIA3 VIA2 VIA1 M5_DIO GATE_VIA > 0 ACCUMULATE ACC_VIA4 ACC_VIA3 ACC_VIA2 ACC_VIA1 
       [
         !!AREA(VIA5) * !!AREA(VIA4) * !!AREA(VIA3) * !!AREA(VIA2) * !!AREA(VIA1) * !!AREA(M5_DIO) *
       ( AREA(VIA5)/AREA(GATE_VIA)-AREA(M5_DIO)*210-900 ) 
       - (!AREA(VIA5)+!AREA(M5_DIO)) * LargeNumber      
       ] RDB A.R.7.VIA5.rep VIA5 VIA4 VIA3 VIA2 VIA1 M5_DIO GATE_VIA BY LAYER
}
A.R.9:VIA5 { @ Ratio of cumulative via area (from VIA1 to VIA9) to an ACTIVE poly GATE area [in OD2/ NOT in OD2] <= 50/NA 
  NET AREA RATIO VIA5 VIA4 VIA3 VIA2 VIA1 HV_GATE M5_DIO GATE_VIA > 0 ACCUMULATE ACC_VIA4 ACC_VIA3 ACC_VIA2 ACC_VIA1 
      [
        !AREA(M5_DIO) * !!AREA(VIA5) * !!AREA(VIA4) * !!AREA(VIA3) * !!AREA(VIA2) * !!AREA(VIA1) * !!AREA(GATE_VIA) * !!AREA(HV_GATE) * ( AREA(VIA5)/AREA(GATE_VIA) - 50 )
        - (!!AREA(M5_DIO)+!AREA(VIA5)+!AREA(GATE_VIA)+!AREA(HV_GATE)) * LargeNumber
      ] RDB A.R.9.VIA5.rep VIA5 VIA4 VIA3 VIA2 VIA1 GATE_VIA BY LAYER
}

ACC_VIA5 = NET AREA RATIO VIA5 GATE_VIA >= 0 ACCUMULATE ACC_VIA4

// 'VIAx.R.12' is checked by VIA5.R.12

VIA5.R.12 { @ Maximum area ratio of M5 to upper VIA5 in the same net [connects to gate with area > 10700 um2, and doesn't connect to OD]. This rule is checked by the DRC command files in ANTENNA_DRC directory <=  350000
   NET AREA RATIO M5 VIA5 GATE M5_DIO > 350000
   [!AREA(M5_DIO)*!~(AREA(GATE)-10700)*(AREA(M5)/AREA(VIA5))]  
   RDB VIA5.R.12.rep M5 VIA5 BY LAYER
}

// 'VIAx.R.12.1' is checked by VIA5.R.12.1

VIA5.R.12.1 { @ Maximum area ratio of I/O NMOS gate to single layer VIA5 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  650000
  NET AREA RATIO VIA5 GATE_N_IO M5_DIO_R12 > 650000
       [
       !AREA(M5_DIO_R12) * (AREA(GATE_N_IO)/AREA(VIA5))
       ] RDB VIA5.R.12.1.rep VIA5 GATE_N_IO BY LAYER
}

// 'VIAx.R.12.2' is checked by VIA5.R.12.2

VIA5.R.12.2 { @ Maximum area ratio of I/O PMOS gate to single layer VIA5 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  2500000
  NET AREA RATIO VIA5 GATE_P_IO M5_DIO_R12 > 2500000
       [
       !AREA(M5_DIO_R12) * (AREA(GATE_P_IO)/AREA(VIA5))
       ] RDB VIA5.R.12.2.rep VIA5 GATE_P_IO BY LAYER
}

IMD_M5_M5_A =  NET AREA RATIO M5 SD > 0 [!AREA(SD)]
CONNECT IMD_M5_M5_A M5
ACC_M5_M5_A = NET AREA RATIO M5 SD IMD_M5_M5_A > 0 ACCUMULATE [AREA(M5)]
A.R.8.3:M5 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M5_wi_DIO = NET AREA RATIO M5 SD > 0 [!!AREA(SD)]
  M5_CHK1 = NET AREA RATIO M5 SD IMD_M5_M5_A > A_R_8_3_A ACCUMULATE [ !AREA(SD)*AREA(M5)] 

  E = EXT [M5_CHK1] M5_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M5_CHK2 = M5 INTERACT (M5 WITH EDGE E)
  NET AREA RATIO M5 SD M5_CHK2 > A_R_8_3_A ACCUMULATE [ !!AREA(M5_CHK2)*!AREA(SD)*AREA(M5)] RDB ONLY A.R.8.3:M5.rep M5 BY LAYER 
}
A.R.8.3.1:M5 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M5_wi_DIO = NET AREA RATIO M5 SD > 0 [!!AREA(SD)]
  M5_CHK1 = NET AREA RATIO M5 SD IMD_M5_M5_A > A_R_8_3_1_A ACCUMULATE [ !AREA(SD)*AREA(M5)] 

  E = EXT [M5_CHK1] M5_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M5_CHK2 = M5 INTERACT (M5 WITH EDGE E)
  NET AREA RATIO M5 SD M5_CHK2 > A_R_8_3_1_A ACCUMULATE [ !!AREA(M5_CHK2)*!AREA(SD)*AREA(M5)] RDB ONLY A.R.8.3.1:M5.rep M5 BY LAYER 
}
A.R.8.3.2:M5 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M5_wi_DIO = NET AREA RATIO M5 SD > 0 [!!AREA(SD)]
  M5_CHK1 = NET AREA RATIO M5 SD IMD_M5_M5_A > A_R_8_3_2_A ACCUMULATE [ !AREA(SD)*AREA(M5)] 

  E = EXT [M5_CHK1] M5_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M5_CHK2 = M5 INTERACT (M5 WITH EDGE E)
  NET AREA RATIO M5 SD M5_CHK2 > A_R_8_3_2_A ACCUMULATE [ !!AREA(M5_CHK2)*!AREA(SD)*AREA(M5)] RDB ONLY A.R.8.3.2:M5.rep M5 BY LAYER 
}

ACC_M5_M4_A = NET AREA RATIO M5 VIA4 SD IMD_M4_M4_A > 0 ACCUMULATE ACC_M4_M4_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))]
A.R.8.3:M5_M4 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M4_wi_DIO = NET AREA RATIO M4 SD > 0 [!!AREA(SD)]
   M4_CHK1 = M4 INTERACT (NET AREA RATIO M5 VIA4 SD IMD_M4_M4_A > A_R_8_3_A ACCUMULATE ACC_M4_M4_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))])
   M4_CHK3 = NET AREA RATIO M4_CHK1 M5 > 0

   E = EXT [M4_CHK3] M4_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M4_CHK2 = M4 INTERACT (M4 WITH EDGE E)
   NET AREA RATIO M5 VIA4 SD M4_CHK2 > A_R_8_3_A ACCUMULATE ACC_M4_M4_A [!!AREA(M4_CHK2)*!AREA(SD)*(AREA(M5)+AREA(VIA4))] RDB ONLY A.R.8.3:M5_M4.rep M5 VIA4 M4_CHK2 BY LAYER
}
A.R.8.3.1:M5_M4 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M4_wi_DIO = NET AREA RATIO M4 SD > 0 [!!AREA(SD)]
   M4_CHK1 = M4 INTERACT (NET AREA RATIO M5 VIA4 SD IMD_M4_M4_A > A_R_8_3_1_A ACCUMULATE ACC_M4_M4_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))])
   M4_CHK3 = NET AREA RATIO M4_CHK1 M5 > 0

