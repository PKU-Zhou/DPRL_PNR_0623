   M2_CHK1 = M2 INTERACT (NET AREA RATIO M8 VIA7 SD IMD_M2_M2_A > A_R_8_3_1_A ACCUMULATE ACC_M7_M2_A [!AREA(SD)*(AREA(M8)+AREA(VIA7))])
   M2_CHK3 = NET AREA RATIO M2_CHK1 M8 > 0

   E = EXT [M2_CHK3] M2_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
   COPY E

