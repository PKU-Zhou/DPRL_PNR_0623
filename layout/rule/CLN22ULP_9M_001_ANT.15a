   M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
   M2_CHK1 = M2 INTERACT (NET AREA RATIO M9 VIA8 SD IMD_M2_M2_A > A_R_8_3_A ACCUMULATE ACC_M8_M2_A [!AREA(SD)*(AREA(M9)+AREA(VIA8))])
   M2_CHK3 = NET AREA RATIO M2_CHK1 M9 > 0

   E = EXT [M2_CHK3] M2_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
   NET AREA RATIO M9 VIA8 SD M2_CHK2 > A_R_8_3_A ACCUMULATE ACC_M8_M2_A [!!AREA(M2_CHK2)*!AREA(SD)*!!AREA(M9)*(AREA(M9)+AREA(VIA8))] RDB ONLY A.R.8.3:M9_M2.rep M9 VIA8 M2_CHK2 BY LAYER
}
A.R.8.3.1:M9_M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
   M2_CHK1 = M2 INTERACT (NET AREA RATIO M9 VIA8 SD IMD_M2_M2_A > A_R_8_3_1_A ACCUMULATE ACC_M8_M2_A [!AREA(SD)*(AREA(M9)+AREA(VIA8))])
   M2_CHK3 = NET AREA RATIO M2_CHK1 M9 > 0

   E = EXT [M2_CHK3] M2_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
   NET AREA RATIO M9 VIA8 SD M2_CHK2 > A_R_8_3_1_A ACCUMULATE ACC_M8_M2_A [!!AREA(M2_CHK2)*!AREA(SD)*!!AREA(M9)*(AREA(M9)+AREA(VIA8))] RDB ONLY A.R.8.3.1:M9_M2.rep M9 VIA8 M2_CHK2 BY LAYER
}
A.R.8.3.2:M9_M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
   M2_CHK1 = M2 INTERACT (NET AREA RATIO M9 VIA8 SD IMD_M2_M2_A > A_R_8_3_2_A ACCUMULATE ACC_M8_M2_A [!AREA(SD)*(AREA(M9)+AREA(VIA8))])
   M2_CHK3 = NET AREA RATIO M2_CHK1 M9 > 0

   E = EXT [M2_CHK3] M2_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
   NET AREA RATIO M9 VIA8 SD M2_CHK2 > A_R_8_3_2_A ACCUMULATE ACC_M8_M2_A [!!AREA(M2_CHK2)*!AREA(SD)*!!AREA(M9)*(AREA(M9)+AREA(VIA8))] RDB ONLY A.R.8.3.2:M9_M2.rep M9 VIA8 M2_CHK2 BY LAYER
}


ACC_M9_M1_A = NET AREA RATIO M9 VIA8 SD IMD_M1_M1_A > 0 ACCUMULATE ACC_M8_M1_A [!AREA(SD)*(AREA(M9)+AREA(VIA8))]
A.R.8.3:M9_M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
