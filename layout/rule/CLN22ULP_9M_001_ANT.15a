}


ACC_M5_M2_A = NET AREA RATIO M5 VIA4 SD IMD_M2_M2_A > 0 ACCUMULATE ACC_M4_M2_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))]
A.R.8.3:M5_M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
   M2_CHK1 = M2 INTERACT (NET AREA RATIO M5 VIA4 SD IMD_M2_M2_A > A_R_8_3_A ACCUMULATE ACC_M4_M2_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))])
   M2_CHK3 = NET AREA RATIO M2_CHK1 M5 > 0

   E = EXT [M2_CHK3] M2_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
   NET AREA RATIO M5 VIA4 SD M2_CHK2 > A_R_8_3_A ACCUMULATE ACC_M4_M2_A [!!AREA(M2_CHK2)*!AREA(SD)*(AREA(M5)+AREA(VIA4))] RDB ONLY A.R.8.3:M5_M2.rep M5 VIA4 M2_CHK2 BY LAYER
}
A.R.8.3.1:M5_M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
   M2_CHK1 = M2 INTERACT (NET AREA RATIO M5 VIA4 SD IMD_M2_M2_A > A_R_8_3_1_A ACCUMULATE ACC_M4_M2_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))])
   M2_CHK3 = NET AREA RATIO M2_CHK1 M5 > 0

   E = EXT [M2_CHK3] M2_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
   NET AREA RATIO M5 VIA4 SD M2_CHK2 > A_R_8_3_1_A ACCUMULATE ACC_M4_M2_A [!!AREA(M2_CHK2)*!AREA(SD)*(AREA(M5)+AREA(VIA4))] RDB ONLY A.R.8.3.1:M5_M2.rep M5 VIA4 M2_CHK2 BY LAYER
}
A.R.8.3.2:M5_M2 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M2_wi_DIO = NET AREA RATIO M2 SD > 0 [!!AREA(SD)]
   M2_CHK1 = M2 INTERACT (NET AREA RATIO M5 VIA4 SD IMD_M2_M2_A > A_R_8_3_2_A ACCUMULATE ACC_M4_M2_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))])
   M2_CHK3 = NET AREA RATIO M2_CHK1 M5 > 0

   E = EXT [M2_CHK3] M2_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M2_CHK2 = M2 INTERACT (M2 WITH EDGE E)
   NET AREA RATIO M5 VIA4 SD M2_CHK2 > A_R_8_3_2_A ACCUMULATE ACC_M4_M2_A [!!AREA(M2_CHK2)*!AREA(SD)*(AREA(M5)+AREA(VIA4))] RDB ONLY A.R.8.3.2:M5_M2.rep M5 VIA4 M2_CHK2 BY LAYER
}


ACC_M5_M1_A = NET AREA RATIO M5 VIA4 SD IMD_M1_M1_A > 0 ACCUMULATE ACC_M4_M1_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))]
A.R.8.3:M5_M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
   M1_CHK1 = M1 INTERACT (NET AREA RATIO M5 VIA4 SD IMD_M1_M1_A > A_R_8_3_A ACCUMULATE ACC_M4_M1_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))])
   M1_CHK3 = NET AREA RATIO M1_CHK1 M5 > 0

   E = EXT [M1_CHK3] M1_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
   NET AREA RATIO M5 VIA4 SD M1_CHK2 > A_R_8_3_A ACCUMULATE ACC_M4_M1_A [!!AREA(M1_CHK2)*!AREA(SD)*(AREA(M5)+AREA(VIA4))] RDB ONLY A.R.8.3:M5_M1.rep M5 VIA4 M1_CHK2 BY LAYER
}
A.R.8.3.1:M5_M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
   M1_CHK1 = M1 INTERACT (NET AREA RATIO M5 VIA4 SD IMD_M1_M1_A > A_R_8_3_1_A ACCUMULATE ACC_M4_M1_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))])
   M1_CHK3 = NET AREA RATIO M1_CHK1 M5 > 0

   E = EXT [M1_CHK3] M1_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
   NET AREA RATIO M5 VIA4 SD M1_CHK2 > A_R_8_3_1_A ACCUMULATE ACC_M4_M1_A [!!AREA(M1_CHK2)*!AREA(SD)*(AREA(M5)+AREA(VIA4))] RDB ONLY A.R.8.3.1:M5_M1.rep M5 VIA4 M1_CHK2 BY LAYER
}
A.R.8.3.2:M5_M1 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M1_wi_DIO = NET AREA RATIO M1 SD > 0 [!!AREA(SD)]
   M1_CHK1 = M1 INTERACT (NET AREA RATIO M5 VIA4 SD IMD_M1_M1_A > A_R_8_3_2_A ACCUMULATE ACC_M4_M1_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))])
   M1_CHK3 = NET AREA RATIO M1_CHK1 M5 > 0

   E = EXT [M1_CHK3] M1_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M1_CHK2 = M1 INTERACT (M1 WITH EDGE E)
   NET AREA RATIO M5 VIA4 SD M1_CHK2 > A_R_8_3_2_A ACCUMULATE ACC_M4_M1_A [!!AREA(M1_CHK2)*!AREA(SD)*(AREA(M5)+AREA(VIA4))] RDB ONLY A.R.8.3.2:M5_M1.rep M5 VIA4 M1_CHK2 BY LAYER
}




//M6 CHECKS
//=========
CONNECT M6 TFR_CON_6 BY VIA5_TFR
CONNECT M6 M5   BY VIA5
CONNECT VIA6 M6


M6_DIO = NET AREA SD >= DIO_AREA
M6_DIO_R12 = NET AREA SD >= DIO_AREA_R12
A.R.6__A.R.8:M6 { @ Ratio of cumulative metal top area (from M1 to M10) to an ACTIVE poly GATE area [1.8V I/O in OD2/ except 1.8V I/O in OD2/ NOT in OD2] <= 1000/5000/5000 
                 @ (cumulative M1~M6 area / gate area) <= OD area * 456 + 43000 (with protection OD)
  NET AREA RATIO M6 M5 M4 M3 M2 M1 M6_DIO HV18_GATE GATE > 0  ACCUMULATE ACC_M5 ACC_M4 ACC_M3 ACC_M2 ACC_M1
       [
         !!AREA(M6) * !!AREA(M5) * !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATE) *
       (!AREA(M6_DIO) * (!!AREA(HV18_GATE)*(AREA(M6)/AREA(GATE)-1000) +
                         !AREA(HV18_GATE)*(AREA(M6)/AREA(GATE)-5000)) +
        !!AREA(M6_DIO) * ( AREA(M6)/AREA(GATE)-AREA(M6_DIO)*456-43000 )) - (!AREA(M6)+!AREA(GATE)) * LargeNumber    
       ] RDB A.R.6_A.R.8.M6.rep M6 M5 M4 M3 M2 M1 M6_DIO HV18_GATE GATE BY LAYER
}
// A.R.6 is checked by A.R.6__A.R.8:M6
// A.R.8 is checked by A.R.6__A.R.8:M6
A.R.6.1:M6 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD25, 1.0E3 um2 < Gate area <= 2.6E5 um2] <= 3.3E6 x (GATE area)(-1.2) 
 GATE_Area1_260K = NET AREA GATE > 1.0E3 <= 260.0E3
 GATES = NET AREA RATIO GATE_Area1_260K GATE M6 M6_DIO HV25_GATE  > 0
     [ !!AREA(M6) *!!AREA(GATE) * ~~AREA(GATE_Area1_260K)*!!AREA(HV25_GATE)*!AREA(M6_DIO) ] 

 NET AREA RATIO M6 M5 M4 M3 M2 M1 M6_DIO GATE_Area1_260K GATES > 0 ACCUMULATE ACC_M5 ACC_M4 ACC_M3 ACC_M2 ACC_M1
    [
      !!AREA(M6) * !!AREA(M5) * !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATES) *!AREA(M6_DIO)* 
      (AREA(M6)/AREA(GATES)-3.3E6*(AREA(GATES)^-1.2))
       
    ] RDB A.R.6.1.M6.rep M6 M5 M4 M3 M2 M1 M6_DIO  GATES BY LAYER
}
A.R.6.2:M6 { @ Maximum cumulative I/O gate [in OD25] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 2.6E5 
  NET AREA RATIO HV25_GATE M6 M6_DIO   > 2.6E5 
   [!!AREA(M6)  * !AREA(M6_DIO) *AREA(HV25_GATE)] 
  RDB A.R.6.2.M6.rep  M6_DIO  HV25_GATE 
}
A.R.6.3:M6 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD18, 1.0E3 um2 < Gate area <= 1.0E6 um2] <= 7.1E5 x (GATE area)(-0.93) 
  GATE_Area_1E6 = NET AREA GATE > 1.0E3 <= 1.0E6
  GATES = NET AREA RATIO GATE GATE_Area_1E6   M6 M6_DIO HV18_GATE  > 0 
        [ !!AREA(M6) *!!AREA(GATE) * !AREA(M6_DIO) *!!AREA(HV18_GATE)*!!AREA(GATE_Area_1E6)]
 NET AREA RATIO  M6 M5 M4 M3 M2 M1 GATES > 0 ACCUMULATE ACC_M5 ACC_M4 ACC_M3 ACC_M2 ACC_M1 
       [
         !!AREA(M6) * !!AREA(M5) * !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATES)*(AREA(M6)/AREA(GATES)-7.1E5*(AREA(GATES)^-0.93))
              ] RDB A.R.6.3.M6.rep M6 M5 M4 M3 M2 M1 GATES BY LAYER
}
A.R.6.4:M6 { @ Maximum I/O gate [in OD18] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 1.0E6 
  NET AREA RATIO HV18_GATE M6 M6_DIO  > 1E6 
   [!!AREA(M6)  * !AREA(M6_DIO) *AREA(HV18_GATE)]
  RDB A.R.6.4.M6.rep M6_DIO HV18_GATE 
}
// A.R.6.a is checked by 'A.R.6'

ACC_M6 = NET AREA RATIO M6 GATE >= 0 ACCUMULATE ACC_M5
//VIA6 CHECKS
//===========

A.R.4:VIA6 {  @ Single-layer drawn ratio of a via area to the ACTIVE poly GATE area that is connected directly to it <= 20 
  NET AREA RATIO VIA6 GATE_VIA M6_DIO > 20
      [
        !AREA(M6_DIO) * !!AREA(VIA6) * !!AREA(GATE_VIA) * ( AREA(VIA6)/AREA(GATE_VIA) )
      ] RDB A.R.4.VIA6.rep VIA6 GATE_VIA M6_DIO BY LAYER
}

A.R.7:VIA6 { @ Drawn ratio of cumulative via area (from VIA1 to VIA9) to the ACTIVE poly GATE area with a protection OD <= OD area x 210 + 900 
  NET AREA RATIO VIA6 VIA5 VIA4 VIA3 VIA2 VIA1 M6_DIO GATE_VIA > 0 ACCUMULATE ACC_VIA5 ACC_VIA4 ACC_VIA3 ACC_VIA2 ACC_VIA1 
       [
         !!AREA(VIA6) * !!AREA(VIA5) * !!AREA(VIA4) * !!AREA(VIA3) * !!AREA(VIA2) * !!AREA(VIA1) * !!AREA(M6_DIO) *
       ( AREA(VIA6)/AREA(GATE_VIA)-AREA(M6_DIO)*210-900 ) 
       - (!AREA(VIA6)+!AREA(M6_DIO)) * LargeNumber      
       ] RDB A.R.7.VIA6.rep VIA6 VIA5 VIA4 VIA3 VIA2 VIA1 M6_DIO GATE_VIA BY LAYER
}
A.R.9:VIA6 { @ Ratio of cumulative via area (from VIA1 to VIA9) to an ACTIVE poly GATE area [in OD2/ NOT in OD2] <= 50/NA 
  NET AREA RATIO VIA6 VIA5 VIA4 VIA3 VIA2 VIA1 HV_GATE M6_DIO GATE_VIA > 0 ACCUMULATE ACC_VIA5 ACC_VIA4 ACC_VIA3 ACC_VIA2 ACC_VIA1 
      [
        !AREA(M6_DIO) * !!AREA(VIA6) * !!AREA(VIA5) * !!AREA(VIA4) * !!AREA(VIA3) * !!AREA(VIA2) * !!AREA(VIA1) * !!AREA(GATE_VIA) * !!AREA(HV_GATE) * ( AREA(VIA6)/AREA(GATE_VIA) - 50 )
        - (!!AREA(M6_DIO)+!AREA(VIA6)+!AREA(GATE_VIA)+!AREA(HV_GATE)) * LargeNumber
      ] RDB A.R.9.VIA6.rep VIA6 VIA5 VIA4 VIA3 VIA2 VIA1 GATE_VIA BY LAYER
}

ACC_VIA6 = NET AREA RATIO VIA6 GATE_VIA >= 0 ACCUMULATE ACC_VIA5

// 'VIAx.R.12' is checked by VIA6.R.12

VIA6.R.12 { @ Maximum area ratio of M6 to upper VIA6 in the same net [connects to gate with area > 10700 um2, and doesn't connect to OD]. This rule is checked by the DRC command files in ANTENNA_DRC directory <=  350000
   NET AREA RATIO M6 VIA6 GATE M6_DIO > 350000
   [!AREA(M6_DIO)*!~(AREA(GATE)-10700)*(AREA(M6)/AREA(VIA6))]  
   RDB VIA6.R.12.rep M6 VIA6 BY LAYER
}

// 'VIAx.R.12.1' is checked by VIA6.R.12.1

VIA6.R.12.1 { @ Maximum area ratio of I/O NMOS gate to single layer VIA6 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  650000
  NET AREA RATIO VIA6 GATE_N_IO M6_DIO_R12 > 650000
       [
       !AREA(M6_DIO_R12) * (AREA(GATE_N_IO)/AREA(VIA6))
       ] RDB VIA6.R.12.1.rep VIA6 GATE_N_IO BY LAYER
}

// 'VIAx.R.12.2' is checked by VIA6.R.12.2

VIA6.R.12.2 { @ Maximum area ratio of I/O PMOS gate to single layer VIA6 in the same net, except the protection OD area >= 0.25 um2 This rule is checked by the DRC command files in ANTENNA_DRC directory  <=  2500000
  NET AREA RATIO VIA6 GATE_P_IO M6_DIO_R12 > 2500000
       [
       !AREA(M6_DIO_R12) * (AREA(GATE_P_IO)/AREA(VIA6))
       ] RDB VIA6.R.12.2.rep VIA6 GATE_P_IO BY LAYER
}

IMD_M6_M6_A =  NET AREA RATIO M6 SD > 0 [!AREA(SD)]
CONNECT IMD_M6_M6_A M6
ACC_M6_M6_A = NET AREA RATIO M6 SD IMD_M6_M6_A > 0 ACCUMULATE [AREA(M6)]
A.R.8.3:M6 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M6_wi_DIO = NET AREA RATIO M6 SD > 0 [!!AREA(SD)]
  M6_CHK1 = NET AREA RATIO M6 SD IMD_M6_M6_A > A_R_8_3_A ACCUMULATE [ !AREA(SD)*AREA(M6)] 

  E = EXT [M6_CHK1] M6_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M6_CHK2 = M6 INTERACT (M6 WITH EDGE E)
  NET AREA RATIO M6 SD M6_CHK2 > A_R_8_3_A ACCUMULATE [ !!AREA(M6_CHK2)*!AREA(SD)*AREA(M6)] RDB ONLY A.R.8.3:M6.rep M6 BY LAYER 
}
A.R.8.3.1:M6 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M6_wi_DIO = NET AREA RATIO M6 SD > 0 [!!AREA(SD)]
  M6_CHK1 = NET AREA RATIO M6 SD IMD_M6_M6_A > A_R_8_3_1_A ACCUMULATE [ !AREA(SD)*AREA(M6)] 

  E = EXT [M6_CHK1] M6_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M6_CHK2 = M6 INTERACT (M6 WITH EDGE E)
  NET AREA RATIO M6 SD M6_CHK2 > A_R_8_3_1_A ACCUMULATE [ !!AREA(M6_CHK2)*!AREA(SD)*AREA(M6)] RDB ONLY A.R.8.3.1:M6.rep M6 BY LAYER 
}
A.R.8.3.2:M6 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M6_wi_DIO = NET AREA RATIO M6 SD > 0 [!!AREA(SD)]
  M6_CHK1 = NET AREA RATIO M6 SD IMD_M6_M6_A > A_R_8_3_2_A ACCUMULATE [ !AREA(SD)*AREA(M6)] 

  E = EXT [M6_CHK1] M6_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M6_CHK2 = M6 INTERACT (M6 WITH EDGE E)
  NET AREA RATIO M6 SD M6_CHK2 > A_R_8_3_2_A ACCUMULATE [ !!AREA(M6_CHK2)*!AREA(SD)*AREA(M6)] RDB ONLY A.R.8.3.2:M6.rep M6 BY LAYER 
}

ACC_M6_M5_A = NET AREA RATIO M6 VIA5 SD IMD_M5_M5_A > 0 ACCUMULATE ACC_M5_M5_A [!AREA(SD)*(AREA(M6)+AREA(VIA5))]
A.R.8.3:M6_M5 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M5_wi_DIO = NET AREA RATIO M5 SD > 0 [!!AREA(SD)]
   M5_CHK1 = M5 INTERACT (NET AREA RATIO M6 VIA5 SD IMD_M5_M5_A > A_R_8_3_A ACCUMULATE ACC_M5_M5_A [!AREA(SD)*(AREA(M6)+AREA(VIA5))])
   M5_CHK3 = NET AREA RATIO M5_CHK1 M6 > 0

   E = EXT [M5_CHK3] M5_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M5_CHK2 = M5 INTERACT (M5 WITH EDGE E)
   NET AREA RATIO M6 VIA5 SD M5_CHK2 > A_R_8_3_A ACCUMULATE ACC_M5_M5_A [!!AREA(M5_CHK2)*!AREA(SD)*(AREA(M6)+AREA(VIA5))] RDB ONLY A.R.8.3:M6_M5.rep M6 VIA5 M5_CHK2 BY LAYER
}
A.R.8.3.1:M6_M5 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M5_wi_DIO = NET AREA RATIO M5 SD > 0 [!!AREA(SD)]
   M5_CHK1 = M5 INTERACT (NET AREA RATIO M6 VIA5 SD IMD_M5_M5_A > A_R_8_3_1_A ACCUMULATE ACC_M5_M5_A [!AREA(SD)*(AREA(M6)+AREA(VIA5))])
   M5_CHK3 = NET AREA RATIO M5_CHK1 M6 > 0

   E = EXT [M5_CHK3] M5_wi_DIO >= A_R_8_3_1_S2 < A_R_8_3_1_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M5_CHK2 = M5 INTERACT (M5 WITH EDGE E)
   NET AREA RATIO M6 VIA5 SD M5_CHK2 > A_R_8_3_1_A ACCUMULATE ACC_M5_M5_A [!!AREA(M5_CHK2)*!AREA(SD)*(AREA(M6)+AREA(VIA5))] RDB ONLY A.R.8.3.1:M6_M5.rep M6 VIA5 M5_CHK2 BY LAYER
}
A.R.8.3.2:M6_M5 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M5_wi_DIO = NET AREA RATIO M5 SD > 0 [!!AREA(SD)]
   M5_CHK1 = M5 INTERACT (NET AREA RATIO M6 VIA5 SD IMD_M5_M5_A > A_R_8_3_2_A ACCUMULATE ACC_M5_M5_A [!AREA(SD)*(AREA(M6)+AREA(VIA5))])
   M5_CHK3 = NET AREA RATIO M5_CHK1 M6 > 0

   E = EXT [M5_CHK3] M5_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M5_CHK2 = M5 INTERACT (M5 WITH EDGE E)
   NET AREA RATIO M6 VIA5 SD M5_CHK2 > A_R_8_3_2_A ACCUMULATE ACC_M5_M5_A [!!AREA(M5_CHK2)*!AREA(SD)*(AREA(M6)+AREA(VIA5))] RDB ONLY A.R.8.3.2:M6_M5.rep M6 VIA5 M5_CHK2 BY LAYER
}

