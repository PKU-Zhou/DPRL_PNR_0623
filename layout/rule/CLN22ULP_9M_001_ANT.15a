//M9 CHECKS
//=========
CONNECT M9 CTM9 BY V8CAP_CTM
CONNECT M9 CBM9 BY V8CAP_CBM
CONNECT M9 TFR_CON_9 BY VIA8_TFR
CONNECT M9 M8   BY VIA8


CONNECT RV  M9 
CONNECT CB  M9 
CONNECT CBD M9 
M9_DIO = NET AREA SD >= DIO_AREA
M9_GATE_Area1_260K = NET AREA GATE > 1.0E3 <= 260.0E3
A.R.6:M9 { @ Ratio of cumulative metal top area (from M1 to M10) to an ACTIVE poly GATE area [1.8V I/O in OD2/ except 1.8V I/O in OD2/ NOT in OD2] <= 1000/5000/5000 
  NET AREA RATIO M9 M8 M7 M6 M5 M4 M3 M2 M1 M9_DIO HV18_GATE GATE > 0 ACCUMULATE ACC_M8 ACC_M7 ACC_M6 ACC_M5 ACC_M4 ACC_M3 ACC_M2 ACC_M1 
    [
      !!AREA(M9) * !!AREA(M8) * !!AREA(M7) * !!AREA(M6) * !!AREA(M5) * !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATE) * !AREA(M9_DIO) * 
    (!!AREA(HV18_GATE)*(AREA(M9)/AREA(GATE)-1000) + !AREA(HV18_GATE)*(AREA(M9)/AREA(GATE)-5000))
    - (!AREA(M9)+!AREA(GATE)+!!AREA(M9_DIO)) * LargeNumber      
    ] RDB A.R.6.M9.rep M9 M8 M7 M6 M5 M4 M3 M2 M1 M9_DIO HV18_GATE GATE BY LAYER
}
A.R.6.1:M9 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD25, 1.0E3 um2 < Gate area <= 2.6E5 um2] <= 3.3E6 x (GATE area)(-1.2) 
 GATE_Area1_260K = NET AREA GATE > 1.0E3 <= 260.0E3
 GATES = NET AREA RATIO GATE_Area1_260K GATE M9 M9_DIO HV25_GATE  > 0
     [ !!AREA(M9) *!!AREA(GATE) * ~~AREA(GATE_Area1_260K)*!!AREA(HV25_GATE)*!AREA(M9_DIO) ] 

 NET AREA RATIO M9 M8 M7 M6 M5 M4 M3 M2 M1 M9_DIO GATE_Area1_260K GATES > 0 ACCUMULATE ACC_M8 ACC_M7 ACC_M6 ACC_M5 ACC_M4 ACC_M3 ACC_M2 ACC_M1
    [
      !!AREA(M9) * !!AREA(M8) * !!AREA(M7) * !!AREA(M6) * !!AREA(M5) * !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATES) *!AREA(M9_DIO)* 
      (AREA(M9)/AREA(GATES)-3.3E6*(AREA(GATES)^-1.2))
       
    ] RDB A.R.6.1.M9.rep M9 M8 M7 M6 M5 M4 M3 M2 M1 M9_DIO  GATES BY LAYER
}
A.R.6.2:M9 { @ Maximum cumulative I/O gate [in OD25] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 2.6E5 
  NET AREA RATIO HV25_GATE M9 M9_DIO   > 2.6E5 
   [!!AREA(M9)  * !AREA(M9_DIO) *AREA(HV25_GATE)] 
  RDB A.R.6.2.M9.rep  M9_DIO  HV25_GATE 
}
A.R.6.3:M9 { @ Ratio of the cumulative metal top area (from M1 to top metal) to the cumulatively connected GATE area [I/O in OD18, 1.0E3 um2 < Gate area <= 1.0E6 um2] <= 7.1E5 x (GATE area)(-0.93) 
  GATE_Area_1E6 = NET AREA GATE > 1.0E3 <= 1.0E6
  GATES = NET AREA RATIO GATE GATE_Area_1E6   M9 M9_DIO HV18_GATE  > 0 
        [ !!AREA(M9) *!!AREA(GATE) * !AREA(M9_DIO) *!!AREA(HV18_GATE)*!!AREA(GATE_Area_1E6)]
 NET AREA RATIO  M9 M8 M7 M6 M5 M4 M3 M2 M1 GATES > 0 ACCUMULATE ACC_M8 ACC_M7 ACC_M6 ACC_M5 ACC_M4 ACC_M3 ACC_M2 ACC_M1 
       [
         !!AREA(M9) * !!AREA(M8) * !!AREA(M7) * !!AREA(M6) * !!AREA(M5) * !!AREA(M4) * !!AREA(M3) * !!AREA(M2) * !!AREA(M1) * !!AREA(GATES)*(AREA(M9)/AREA(GATES)-7.1E5*(AREA(GATES)^-0.93))
              ] RDB A.R.6.3.M9.rep M9 M8 M7 M6 M5 M4 M3 M2 M1 GATES BY LAYER
}
A.R.6.4:M9 { @ Maximum I/O gate [in OD18] area in same connection This rule is checked by the cumulative connections (from M1 to top metal respectively) <= 1.0E6 
  NET AREA RATIO HV18_GATE M9 M9_DIO  > 1E6 
   [!!AREA(M9)  * !AREA(M9_DIO) *AREA(HV18_GATE)]
  RDB A.R.6.4.M9.rep M9_DIO HV18_GATE 
}
A.R.8.1:M9 { @ Drawn ratio of last metal top area to the ACTIVE poly GATE with a protection OD <= OD area x 8000 + 50000 
  NET AREA RATIO M9 M9_DIO GATE > 0
    [
      !!AREA(M9_DIO) * ( AREA(M9)/AREA(GATE)-AREA(M9_DIO)*8000-50000 )
    ] RDB A.R.8.1.M9.rep M9 M9_DIO GATE BY LAYER
}

//RV CHECK 
//========

A.R.10__A.R.12:RV { @ Drawn ratio of RV area to the ACTIVE poly GATE area that is connected directly to it [in OD2/ NOT in OD2] <= 20/200 
                   @ (RV area / gate area) <= OD area * 83 + 400 (with protection OD)
  NET AREA RATIO RV M9_DIO HV_GATE GATE_VIA > 0
       [
         !!AREA(RV) * !!AREA(GATE_VIA) *
           (!AREA(M9_DIO) * (!!AREA(HV_GATE)*(AREA(RV)/AREA(GATE_VIA)-20) +
                 !AREA(HV_GATE)*(AREA(RV)/AREA(GATE_VIA)-200)) +
        !!AREA(M9_DIO) * ( AREA(RV)/AREA(GATE_VIA)-AREA(M9_DIO)*83-400 ))
       ] RDB A.R.10_A.R.12.RV.rep RV M9_DIO HV_GATE GATE_VIA BY LAYER
}


IMD_M9_M9_A =  NET AREA RATIO M9 SD > 0 [!AREA(SD)]
CONNECT IMD_M9_M9_A M9
ACC_M9_M9_A = NET AREA RATIO M9 SD IMD_M9_M9_A > 0 ACCUMULATE [AREA(M9)]
A.R.8.3:M9 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.17 um, >= 0.05 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 7.50E+05 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M9_wi_DIO = NET AREA RATIO M9 SD > 0 [!!AREA(SD)]
  M9_CHK1 = NET AREA RATIO M9 SD IMD_M9_M9_A > A_R_8_3_A ACCUMULATE [ !AREA(SD)*AREA(M9)] 

  E = EXT [M9_CHK1] M9_wi_DIO >= A_R_8_3_S2 < A_R_8_3_S1 ABUT < 90 // NOT CONNECTED
  COPY E

  M9_CHK2 = M9 INTERACT (M9 WITH EDGE E)
  NET AREA RATIO M9 SD M9_CHK2 > A_R_8_3_A ACCUMULATE [ !!AREA(M9_CHK2)*!AREA(SD)*AREA(M9)] RDB ONLY A.R.8.3:M9.rep M9 BY LAYER 
}
A.R.8.3.1:M9 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.23 um, >= 0.17 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 1.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
  M9_wi_DIO = NET AREA RATIO M9 SD > 0 [!!AREA(SD)]
