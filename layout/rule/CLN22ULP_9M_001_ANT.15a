}
A.R.8.3.2:M5_M4 { @ Risk_Floating_net space to Mn (from M1 to Mtop) [connects to OD] < 0.5 um, >= 0.23 um is not allowed Definition: 1. Risk_Floating_net: cumulative floating metal and VIA top area [cumulative area > 2.20E+06 um2, from M1 to top metal and VIA1 to top VIA, and doesn't connect to OD] 2. floating metal and VIA: metal and VIA doesn't connect to OD This rule is checked by the cumulative connections (from M1 to top metal and VIA1 to top VIA respectively)   
   M4_wi_DIO = NET AREA RATIO M4 SD > 0 [!!AREA(SD)]
   M4_CHK1 = M4 INTERACT (NET AREA RATIO M5 VIA4 SD IMD_M4_M4_A > A_R_8_3_2_A ACCUMULATE ACC_M4_M4_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))])
   M4_CHK3 = NET AREA RATIO M4_CHK1 M5 > 0

   E = EXT [M4_CHK3] M4_wi_DIO >= A_R_8_3_2_S2 < A_R_8_3_2_S1 ABUT < 90 // NOT CONNECTED
   COPY E

   M4_CHK2 = M4 INTERACT (M4 WITH EDGE E)
   NET AREA RATIO M5 VIA4 SD M4_CHK2 > A_R_8_3_2_A ACCUMULATE ACC_M4_M4_A [!!AREA(M4_CHK2)*!AREA(SD)*(AREA(M5)+AREA(VIA4))] RDB ONLY A.R.8.3.2:M5_M4.rep M5 VIA4 M4_CHK2 BY LAYER
}

ACC_M5_M3_A = NET AREA RATIO M5 VIA4 SD IMD_M3_M3_A > 0 ACCUMULATE ACC_M4_M3_A [!AREA(SD)*(AREA(M5)+AREA(VIA4))]
