/* SWITCH DEFINITION START */
//  OPTION SETUP
//================



// OPTION FOR RULE GROUP
//======================
/* SWITCH DEFINITION END */
// ENVIRONMENT SETUP
//==================
/* SWITCH DEFINITION START */
PRECISION    1000
RESOLUTION      5

LAYOUT SYSTEM GDSII
LAYOUT PATH "GDSFILENAME"
LAYOUT PRIMARY "TOPCELLNAME"

DRC RESULTS DATABASE "DRC_RES.db"
DRC SUMMARY REPORT "DRC.rep"
DRC KEEP EMPTY NO
DRC CHECK TEXT ALL
DRC MAXIMUM RESULTS ALL
DRC INCREMENTAL CONNECT YES
LAYOUT PROCESS BOX RECORD YES
/* SWITCH DEFINITION END */
VARIABLE GRID	0.005
VARIABLE LargeNumber 1000000000 // user value
VARIABLE DIO_AREA 0
VARIABLE DIO_AREA_R12 0.25
VARIABLE A_R_8_3_S1   0.17
VARIABLE A_R_8_3_S2   0.05
