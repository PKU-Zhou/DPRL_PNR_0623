#ENDIF // CU_WIRE
#IFDEF PITCH_47_SINGLE
#DEFINE PITCH_LESS_55
#DEFINE PITCH_LESS_55_SINGLE
#ENDIF
#IFDEF PITCH_52_SINGLE
#DEFINE PITCH_LESS_55
#DEFINE PITCH_LESS_55_SINGLE
#ENDIF

#IFDEF PITCH_47_STAGGER
#DEFINE PITCH_LESS_55
#DEFINE PITCH_LESS_55_STAGGER
#ENDIF
#IFDEF PITCH_52_STAGGER
#DEFINE PITCH_LESS_55
#DEFINE PITCH_LESS_55_STAGGER
#ENDIF


// Passivation Opening Rule For Wire Bond
//=======================================


CB.EN.1 { @ CB enclosure by CB2_WB == 0 um
  CBx XOR CB2
}

#IFDEF PITCH_LESS_55
CB.R.1 { @ for 40um <= pad pitch < 55um, one pair of notches on each pad in CB is requred. the size of notch is 3um*1.5um
#IFDEF PITCH_LESS_55_SINGLE
  (CB_PAD_NON_RAP AND CB_SINGLE) NOT INTERACT notch_CB  == 2
  (CB_PAD_NON_RAP AND CB_SINGLE) NOT INTERACT notch_CB
  NOT RECTANGLE notch_CB == 1.5 BY == 3.0 ORTHOGONAL ONLY
#ENDIF
#IFDEF PITCH_LESS_55_STAGGER
  (CB_PAD_NON_RAP AND CB_STAGGER) NOT INTERACT notch_CB  == 2
  (CB_PAD_NON_RAP AND CB_STAGGER) NOT INTERACT notch_CB
  NOT RECTANGLE notch_CB == 1.5 BY == 3.0 ORTHOGONAL ONLY
#ENDIF
}
#ENDIF






CB_SINGLE_A = CB_SINGLE OR (notch_CB2 INTERACT CB_SINGLE)
CB_STAGGER_A = CB_STAGGER OR (notch_CB2 INTERACT CB_STAGGER)
CB_TRI_TIER_A = CB_TRI_TIER OR (notch_CB2 INTERACT CB_TRI_TIER)

#IFDEF SINGLE_PAD
CB2.W.1:SI { @ CB2 width >= ^CB2_W_1_SI um
  INT CB_SINGLE_A < CB2_W_1_SI ABUT < 90 PARALLEL ONLY REGION
}

CB2.W.2:SI { @ CB2 length (the edge perpendicular to nearby chip edge) >= ^CB2_W_2_SI um
  NOT ENCLOSE RECTANGLE CB_SINGLE 0.001 CB2_W_2_SI ORTHOGONAL ONLY
}

CB2.S.1:SI { @ CB2 space >= ^CB2_S_1_SI um
  EXT CB_SINGLE_A < CB2_S_1_SI ABUT < 90 SINGULAR REGION
}

CB2.P.1:SI { @ CB2 pitch >= ^CB2_P_1_SI um
  EXT CB_CENTER_SI < CB2_P_1_SI - 1 ABUT < 90 REGION
}

// CB2.EN.1.1 is not necessary to check
CB2.EN.1:SI_M8 { @ CB2 enclosure by M8 pad regions >= ^CB2_EN_1 um
  ENC CB_SINGLE_CUP M8 < CB2_EN_1 ABUT <90 SINGULAR REGION
  CB_SINGLE_CUP OUTSIDE EDGE M8
}
CB2.EN.1:SI_M9 { @ CB2 enclosure by M9 pad regions >= ^CB2_EN_1 um
  ENC CB_SINGLE_CUP M9 < CB2_EN_1 ABUT <90 SINGULAR REGION
  CB_SINGLE_CUP OUTSIDE EDGE M9
}

#IFDEF with_AP
CB2.EN.1:SI_AP { @ CB2 enclosure by AP-MD in pad regions >= ^CB2_EN_1 um
  ENC CB_SINGLE AP < CB2_EN_1 ABUT <90 SINGULAR REGION
  CB_SINGLE OUTSIDE EDGE AP
}
#ENDIF
#ENDIF



#IFDEF STAGGER_PAD

CB2.W.1:ST { @ CB2 width >= ^CB2_W_1_ST um
  INT CB_STAGGER_A < CB2_W_1_ST ABUT < 90 PARALLEL ONLY REGION
}

CB2.W.2:ST { @ CB2 length (the edge perpendicular to nearby chip edge) >= ^CB2_W_2_ST um
  NOT ENCLOSE RECTANGLE CB_STAGGER 0.001 CB2_W_2_ST ORTHOGONAL ONLY
}

CB2.S.1:ST { @ CB2 space >= ^CB2_S_1_ST um
  EXT CB_STAGGER_A < CB2_S_1_ST ABUT < 90 SINGULAR REGION
}

CB2.P.1:ST { @ CB2 pitch >= ^CB2_P_1_ST um
  EXT CB_CENTER_ST < CB2_P_1_ST - 1 ABUT < 90 REGION
}


// CB2.EN.1.1 is not necessary to check
CB2.EN.1:ST_M8 { @ CB2 enclosure by M8 pad regions >= ^CB2_EN_1 um
  ENC OUTER_CB_ST_CUP M8 < CB2_EN_1 ABUT < 90 SINGULAR REGION
  OUTER_CB_ST_CUP OUTSIDE EDGE M8
  ENC INNER_CB_ST M8 < CB2_EN_1 ABUT < 90 SINGULAR REGION
  INNER_CB_ST OUTSIDE EDGE M8
}
CB2.EN.1:ST_M9 { @ CB2 enclosure by M9 pad regions >= ^CB2_EN_1 um
  ENC OUTER_CB_ST_CUP M9 < CB2_EN_1 ABUT < 90 SINGULAR REGION
  OUTER_CB_ST_CUP OUTSIDE EDGE M9
  ENC INNER_CB_ST M9 < CB2_EN_1 ABUT < 90 SINGULAR REGION
  INNER_CB_ST OUTSIDE EDGE M9
}

#IFDEF with_AP
CB2.EN.1:ST_AP { @ CB2 enclosure by AP-MD in pad regions >= ^CB2_EN_1 um
  ENC OUTER_CB_ST AP < CB2_EN_1 ABUT < 90 SINGULAR REGION
  OUTER_CB_ST OUTSIDE EDGE AP
  ENC INNER_CB_ST AP < CB2_EN_1 ABUT < 90 SINGULAR REGION
  INNER_CB_ST OUTSIDE EDGE AP
}
#ENDIF
#ENDIF



#IFDEF TRITIER_PAD
CB2.W.1:TR { @ C2B width >= ^CB2_W_1_TR um
  INT CB_TRI_TIER_A < CB2_W_1_TR ABUT < 90 PARALLEL ONLY REGION
}

CB2.W.2:TR { @ CB2 length (the edge perpendicular to nearby chip edge) >= ^CB2_W_2_TR um
  NOT ENCLOSE RECTANGLE CB_TRI_TIER 0.001 CB2_W_2_TR ORTHOGONAL ONLY
}

CB2.S.1:TR { @ CB2 space >= ^CB2_S_1_TR um
  EXT CB_TRI_TIER_A < CB2_S_1_TR ABUT < 90 SINGULAR REGION
}

CB2.P.1:TR { @ CB2 pitch >= ^CB2_P_1_TR um
  EXT CB_CENTER_TR < CB2_P_1_TR - 1 ABUT < 90 REGION
}


// CB2.EN.1.1 is not necessary to check
CB2.EN.1:TR_M8 { @ CB2 enclosure by M8 pad regions >= ^CB2_EN_1 um
  ENC OUTER_CB_TR_CUP M8 < CB2_EN_1 ABUT < 90 SINGULAR REGION
  OUTER_CB_TR_CUP OUTSIDE EDGE M8
  ENC MID_CB_TR M8 < CB2_EN_1 ABUT < 90 SINGULAR REGION
  MID_CB_TR OUTSIDE EDGE M8
  ENC INNER_CB_TR M8 < CB2_EN_1 ABUT < 90 SINGULAR REGION
  INNER_CB_TR OUTSIDE EDGE M8
}
CB2.EN.1:TR_M9 { @ CB2 enclosure by M9 pad regions >= ^CB2_EN_1 um
  ENC OUTER_CB_TR_CUP M9 < CB2_EN_1 ABUT < 90 SINGULAR REGION
  OUTER_CB_TR_CUP OUTSIDE EDGE M9
  ENC MID_CB_TR M9 < CB2_EN_1 ABUT < 90 SINGULAR REGION
  MID_CB_TR OUTSIDE EDGE M9
  ENC INNER_CB_TR M9 < CB2_EN_1 ABUT < 90 SINGULAR REGION
  INNER_CB_TR OUTSIDE EDGE M9
}


#IFDEF with_AP
CB2.EN.1:TR_AP { @ CB2 enclosure by AP-MD in pad regions >= ^CB2_EN_1 um
  ENC OUTER_CB_TR AP < CB2_EN_1 ABUT < 90 SINGULAR REGION
  OUTER_CB_TR OUTSIDE EDGE AP
  ENC MID_CB_TR AP < CB2_EN_1 ABUT < 90 SINGULAR REGION
  MID_CB_TR OUTSIDE EDGE AP
  ENC INNER_CB_TR AP < CB2_EN_1 ABUT < 90 SINGULAR REGION
  INNER_CB_TR OUTSIDE EDGE AP
}
#ENDIF
#ENDIF

// CB2.0 is not necessary to check



VARIABLE  M2_W_3      4.50
VARIABLE  M3_W_3      4.50
VARIABLE  M4_W_3      4.50
VARIABLE  M5_W_3      4.50
VARIABLE  M6_W_3      4.50
VARIABLE  M7_W_3      4.50
VARIABLE  M8_W_3      12
VARIABLE  M9_W_3      12

M2_CHECK = M2 INTERACT CB2_NON_CUP
M2_PAD = WITH WIDTH M2_CHECK > M2_W_3
M3_CHECK = M3 INTERACT CB2_NON_CUP
M3_PAD = WITH WIDTH M3_CHECK > M3_W_3
M4_CHECK = M4 INTERACT CB2_NON_CUP
M4_PAD = WITH WIDTH M4_CHECK > M4_W_3
M5_CHECK = M5 INTERACT CB2_NON_CUP
M5_PAD = WITH WIDTH M5_CHECK > M5_W_3
M6_CHECK = M6 INTERACT CB2_NON_CUP
M6_PAD = WITH WIDTH M6_CHECK > M6_W_3
M7_CHECK = M7 INTERACT CB2_NON_CUP
M7_PAD = WITH WIDTH M7_CHECK > M7_W_3
M8_PAD = WITH WIDTH (M8 INTERACT CB2) > M8_W_3
M9_PAD = WITH WIDTH (M9 INTERACT CB2) > M9_W_3



//CB2.S.2.1 is not necessary to check
CONNECT M2_PAD M2
M2_NOT_SR = M2 NOT INSIDE SEALRING_EXCLUDE

CB2.S.2:M2 { @ space of pad metal (with width > ^M2_W_3 um) and metal >= ^CB2_S_2 um
  EXT M2_PAD M2_NOT_SR < CB2_S_2 REGION NOT CONNECTED
}
CONNECT M3_PAD M3
M3_NOT_SR = M3 NOT INSIDE SEALRING_EXCLUDE

CB2.S.2:M3 { @ space of pad metal (with width > ^M3_W_3 um) and metal >= ^CB2_S_2 um
  EXT M3_PAD M3_NOT_SR < CB2_S_2 REGION NOT CONNECTED
}
CONNECT M4_PAD M4
M4_NOT_SR = M4 NOT INSIDE SEALRING_EXCLUDE

CB2.S.2:M4 { @ space of pad metal (with width > ^M4_W_3 um) and metal >= ^CB2_S_2 um
  EXT M4_PAD M4_NOT_SR < CB2_S_2 REGION NOT CONNECTED
}
CONNECT M5_PAD M5
M5_NOT_SR = M5 NOT INSIDE SEALRING_EXCLUDE

CB2.S.2:M5 { @ space of pad metal (with width > ^M5_W_3 um) and metal >= ^CB2_S_2 um
  EXT M5_PAD M5_NOT_SR < CB2_S_2 REGION NOT CONNECTED
}
CONNECT M6_PAD M6
M6_NOT_SR = M6 NOT INSIDE SEALRING_EXCLUDE

CB2.S.2:M6 { @ space of pad metal (with width > ^M6_W_3 um) and metal >= ^CB2_S_2 um
  EXT M6_PAD M6_NOT_SR < CB2_S_2 REGION NOT CONNECTED
}
CONNECT M7_PAD M7
M7_NOT_SR = M7 NOT INSIDE SEALRING_EXCLUDE

CB2.S.2:M7 { @ space of pad metal (with width > ^M7_W_3 um) and metal >= ^CB2_S_2 um
  EXT M7_PAD M7_NOT_SR < CB2_S_2 REGION NOT CONNECTED
}
CONNECT M8_PAD M8
M8_NOT_SR = M8 NOT INSIDE SEALRING_EXCLUDE

CB2.S.2:M8 { @ space of pad metal (with width > ^M8_W_3 um) and metal >= ^CB2_S_2 um
  EXT M8_PAD M8_NOT_SR < CB2_S_2 REGION NOT CONNECTED
}
CONNECT M9_PAD M9
M9_NOT_SR = M9 NOT INSIDE SEALRING_EXCLUDE

CB2.S.2:M9 { @ space of pad metal (with width > ^M9_W_3 um) and metal >= ^CB2_S_2 um
  EXT M9_PAD M9_NOT_SR < CB2_S_2 REGION NOT CONNECTED
}



AP_PAD_p = WITH WIDTH (AP INTERACT CB2) > AP_W_2
CONNECT AP_PAD_p AP
AP_NOT_SR = AP NOT INSIDE SEALRING_EXCLUDE

CB2.S.2:AP { @ space of AP pad metal and AP >= ^CB2_S_2 um
  EXT AP_PAD_p AP_NOT_SR < CB2_S_2 REGION NOT CONNECTED
}


CB2.S.3 { @ Space of different pad geometries (CB) [(Single to Stagger), (Single to Tri-tier) or (Stagger to Tri-tier)] >= ^CB2_S_3 um
  EXT CB_SINGLE CB_STAGGER < CB2_S_3 ABUT <90 OPPOSITE SINGULAR REGION
  EXT CB_STAGGER CB_TRI_TIER < CB2_S_3 ABUT <90 OPPOSITE SINGULAR REGION
  EXT CB_TRI_TIER CB_SINGLE  < CB2_S_3 ABUT  <90 OPPOSITE SINGULAR REGION
}


// CUP Pad Structure Rule Starts Here.
//===========================================
CUPCB2.EN.3:M9 { @ CB/CB2 enclosure by Mtop >= ^CUPCB2_EN_3 um
  ENC CB2_CUP WBM9 < CUPCB2_EN_3 ABUT <90 SINGULAR REGION
  CB2_CUP OUTSIDE EDGE WBM9
}
#IFDEF with_AP
CUPCB2.EN.3:AP { @ CB/CB2 enclosure by AP-MD >= ^CUPCB2_EN_3 um
  ENC CB2_CUP WBAP < CUPCB2_EN_3 ABUT <90 SINGULAR REGION
  CB2_CUP OUTSIDE EDGE WBAP
}
#ENDIF

//CUPCB2.0 is not necessary to check

//CUPCB2.EN.4.1 is not necessary to check
CUPCB2.EN.4:M8 { @ WBDMY enclosure of Mtop-1 (Mtop) metal pad = 0 um
  WBDMY OUTSIDE EDGE M8
  WBDMY INSIDE EDGE CB2
  WBDMY NOT INTERACT CB2
  VERTEX WBDMY != 8
  w45_edge = ANGLE WBDMY  == 45
  WBDMY WITH EDGE w45_edge   > 4
  WBDMY WITH EDGE w45_edge   < 4
  WBDMY NOT WITH EDGE w45_edge
  m45_edge = M8 TOUCH INSIDE EDGE w45_edge
  m45_edge NOT COIN EDGE w45_edge
  w45_edge NOT COIN EDGE m45_edge
}
CUPCB2.EN.4:M9 { @ WBDMY enclosure of Mtop-1 (Mtop) metal pad = 0 um
  WBDMY OUTSIDE EDGE M9
  WBDMY INSIDE EDGE CB2
  WBDMY NOT INTERACT CB2
  VERTEX WBDMY != 8
  w45_edge = ANGLE WBDMY  == 45
  WBDMY WITH EDGE w45_edge   > 4
  WBDMY WITH EDGE w45_edge   < 4
  WBDMY NOT WITH EDGE w45_edge
  m45_edge = M9 TOUCH INSIDE EDGE w45_edge
  m45_edge NOT COIN EDGE w45_edge
  w45_edge NOT COIN EDGE m45_edge
}


#IFDEF with_AP
CUPCB2.EN.4:AP { @ WBDMY enclosure of AP metal pad = 0 um
  WBDMY OUTSIDE EDGE AP
  w45_edge = ANGLE WBDMY  == 45
  m45_edge = AP TOUCH INSIDE EDGE w45_edge
  m45_edge NOT COIN EDGE w45_edge
  w45_edge NOT COIN EDGE m45_edge
}
#ENDIF

CUPCB2.EN.4:CB2 { @ WBDMY should cover all pad area
  CB2x NOT WBDMY
}

//CUPCB2.R.3.1 is not necessary to check
CUPCB2.R.3 { @ Pad structure must be MT/VIAT/Mtop-1. MT/Mtop-1 must be solid.
             @ For AP-MD process, Al pad is required to be be drawn.
  CB2_CUP NOT WBM9
  CB2_CUP NOT WBM8
  CB2_CUP NOT ENCLOSE WBVIA8
#IFDEF with_AP
  CB2_CUP NOT AP
#ENDIF
}

//CUPCB2.R.7.1 is not necessary to check
CUPCB2.R.7:CB { @ length of octangle pad CB 45 degree turn corners ^CUPCB2_R_7_MIN ~ ^CUPCB2_R_7_MAX um
  VERTEX CB_A_CUP != 8
  s45_edge = ANGLE CB_A_CUP  == 45
  LENGTH s45_edge      < CUPCB2_R_7_MIN
  LENGTH s45_edge      > CUPCB2_R_7_MAX
}


CUPCB2.R.7:CB2 { @ length of octangle pad CB2_WB 45 degree turn corners ^CUPCB2_R_7_MIN ~ ^CUPCB2_R_7_MAX um
  VERTEX CB2_A_CUP != 8
  s45_edge = ANGLE CB2_A_CUP  == 45
  LENGTH s45_edge      < CUPCB2_R_7_MIN
  LENGTH s45_edge      > CUPCB2_R_7_MAX
}
CUPCB2.R.7:M9 { @ length of octangle pad Mtop 45 degree turn corners ^CUPCB2_R_7_MIN ~ ^CUPCB2_R_7_MAX um
  VERTEX WBM9	     != 8
  s45_edgeM9   = ANGLE WBM9  == 45
  LENGTH s45_edgeM9   < CUPCB2_R_7_MIN
  LENGTH s45_edgeM9   > CUPCB2_R_7_MAX
}
CUPCB2.R.7:M8 { @ length of octangle pad Mtop-1 45 degree turn corners ^CUPCB2_R_7_MIN ~ ^CUPCB2_R_7_MAX um
  VERTEX WBM8       != 8
  s45_edgeM8  = ANGLE WBM8 == 45
  LENGTH s45_edgeM8  < CUPCB2_R_7_MIN
  LENGTH s45_edgeM8  > CUPCB2_R_7_MAX
}
#IFDEF with_AP
CUPCB2.R.7:AP { @ length of octangle pad AP-MD 45 degree turn corners ^CUPCB2_R_7_MIN ~ ^CUPCB2_R_7_MAX um
  VERTEX WBAP	     != 8
  s45_edgeAP   = ANGLE WBAP  == 45
  LENGTH s45_edgeAP   < CUPCB2_R_7_MIN
  LENGTH s45_edgeAP   > CUPCB2_R_7_MAX
}
#ENDIF


CUPVIAT.W.1 { @ VIAT width == ^CUPVIAT_W_1 um
  NOT RECTANGLE WBVIA8 == CUPVIAT_W_1 BY == CUPVIAT_W_1 ORTHOGONAL ONLY
}
CUPVIAT.S.1 { @ VIAT space >= ^CUPVIAT_S_1 um
  EXT WBVIA8 < CUPVIAT_S_1 ABUT <90 SINGULAR REGION
}
CUPVIAT.EN.1:M9 { @ VIAT enclosure by MT >=  ^CUPVIAT_EN_1 um
  ENC WBVIA8 WBM9 <  CUPVIAT_EN_1 ABUT <90 SINGULAR REGION
  WBVIA8 NOT WBM9
}
CUPVIAT.EN.1:M8 { @ VIAT enclosure by Mtop-1 >= ^CUPVIAT_EN_1 um
  ENC WBVIA8 WBM8 < CUPVIAT_EN_1 ABUT <90 SINGULAR REGION
  WBVIA8 NOT WBM8
}

CONNECT WBVIA8 CB2_CUP
// CUPMx.DN.1 is not necessary to check
// CUPMx.W.1 is not necessary to check
CUPVIAT.DN.1 { @ Ratio of total exposure VIAT area to CB2 area within CB2 region >= ^CUPVIAT_DN_1
  NET AREA RATIO CB2_CUP WBVIA8 <  CUPVIAT_DN_1
    [
      AREA(WBVIA8)/AREA(CB2_CUP)
    ] RDB CUPVIAT.DN.1.ratio CB2_CUP WBVIA8
}
CUPVIAT.DN.2 { @ Minimum via density over any 10x10um area (checked by stepping in 5um increment) >= ^CUPVIAT_DN_2
  DENSITY WBVIA8 < CUPVIAT_DN_2 INSIDE OF LAYER CB2_CUP WINDOW 10 STEP 5 BACKUP RDB CUPVIAT.DN.2.density
}

#IFDEF with_AP
// RV Layout Rules
//==============================================
IND_EXD = SIZE INDDMY BY 22
RV_CHECK = RV NOT SEALRING_EXCLUDE
RV_NIND = RV_CHECK NOT INSIDE IND_EXD
RV_IND = RV_CHECK INSIDE IND_EXD

RV.W.1 { @ Width (Square) (maximum = minimum) (Not inside seal ring) = ^RV_W_1A um
  NOT RECTANGLE RV_NIND == RV_W_1A BY == RV_W_1A ORTHOGONAL ONLY
  NOT RECTANGLE RV_IND >= (RV_W_1A-TOL_IND) <= (RV_W_1A+TOL_IND) BY >= (RV_W_1A-TOL_IND) <= (RV_W_1A+TOL_IND)
}

RV.S.1 { @ Space >= ^RV_S_1 um
  EXT RV_NIND RV < RV_S_1 ABUT < 90 SINGULAR REGION
  EXT RV_IND RV < RV_S_1-TOL_IND ABUT < 90 SINGULAR REGION
}

RV.S.3 { @ Space to CB2_WB {Overlap is not allowed} >= ^RV_S_3 um
  EXT RV_CHECK CB2x < RV_S_3 ABUT < 90 SINGULAR REGION
  RV_CHECK AND CB2x
}

RV.EN.1 { @ Enclosure by Mtop (Not inside seal ring) >= ^RV_EN_1 um
  ENC RV_NIND M9 < RV_EN_1 ABUT < 90 SINGULAR REGION OUTSIDE ALSO
  ENC RV_IND M9 < RV_EN_1-TOL_IND ABUT < 90 SINGULAR REGION OUTSIDE ALSO
}

RV.R.1 { @ A 45-degree rotated RV is prohibited
  (NOT RECTANGLE RV_CHECK ORTHOGONAL ONLY) NOT INSIDE IND_EXD
}

#ENDIF

#IFDEF with_AP
// AP Layout Rules
//=================
AP_CHECK = AP NOT INTERACT SEALRING_EXCLUDE
AP.W.1.WB { @ Width {Interconnection only} {Not inside SEALRING_ALL {162;2}} >= ^AP_W_1 um
  (INT AP_CHECK < AP_W_1 ABUT < 90 SINGULAR REGION) NOT INSIDE IND_EXD
  (INT AP_CHECK < AP_W_1-TOL_IND ABUT < 90 SINGULAR REGION) NOT OUTSIDE IND_EXD
}
AP.W.2.WB { @ Maximum width [interconnect only] [ not inside CB or CB2_WB] <= ^AP_W_2 um
  A = ((AP NOT CBi) NOT CB2Fi) NOT CB2Wi
  B = SIZE (SIZE A BY 0.995) BY -0.995
  (B WITH WIDTH > AP_W_2) NOT INSIDE IND_EXD
  (B WITH WIDTH > AP_W_2+TOL_IND) NOT OUTSIDE IND_EXD
}

#IFDEF AP_28K_THICKNESS
AP.W.5 { @ AP hole width for 28KA AP should >= ^AP_W_5, except < 100 inner 90-degrees vertex of AP holes [width < ^AP_W_5 um] within window 100 um x 100 um, stepping 50 um	
  AP_HOLE = HOLES AP INNER 
  AP_HOLE_SHOURT_EDGE = LENGTH AP_HOLE < AP_W_5
  GRID_VERTEX = INT AP_HOLE <= 0.01 ABUT >89.5 <90.5 REGION PERPENDICULAR ALSO
  AP_HOLE_SHOURT_EDGE_region = EXPAND EDGE AP_HOLE_SHOURT_EDGE INSIDE BY 0.005
  GRID_VERTEX_check = GRID_VERTEX INTERACT AP_HOLE_SHOURT_EDGE_region
  GRID_EXTENT = EXTENTS GRID_VERTEX_check CENTERS 0.01
  DENSITY GRID_EXTENT >= 100 WINDOW 100 STEP 50 INSIDE OF LAYER CHIP BACKUP RDB AP.W.5.rep 
      [ 1E4 * AREA(GRID_EXTENT) ]
}
#ENDIF // AP_28K_THICKNESS

AP.S.1 { @ Space >= ^AP_S_1 um
         @ Except the following conditions in the same polygon: 1. {{{AP AND {AP_PAD SIZING 2 um}} NOT AP_PAD} INTERACT AP_PAD} 2. Jog <= 1 um in the same polygon 3. AP hole [Width < 2 um] 
		 @ The definition of AP_PAD: AP interact {CB2_WB OR CB2_FC} > 35 um
  AP_PAD = (AP INTERACT (OR CB2Fi CB2Wi)) SIZE BY 35/2 underover
  AP_PAD_1 = SIZE AP_PAD BY 0.005
  A = ((AP AND (SIZE AP_PAD BY 2)) NOT AP_PAD) INTERACT AP_PAD_1
  B = EXT AP < AP_S_1 NOTCH REGION
  C = (EXT A AP_PAD < AP_S_1 REGION) AND B
  C1 = (EXT A < AP_S_1 REGION) AND B
  C2 = (EXT AP_PAD < AP_S_1 REGION) AND B
  D_pre = HOLES AP INNER 
  D = (INT D_pre < 2 REGION) AND B
  E = LENGTH AP <= 0.5* 2.0
  F = (EXT E AP < AP_S_1 REGION) AND B
  G2 = EXPAND EDGE AP_PAD BY 0.005
  WAIVE_REGION = SIZE (OR C C1 C2 G2 D F ) BY 0.005
  ((EXT AP < AP_S_1 SINGULAR REGION) NOT INSIDE IND_EXD) NOT WAIVE_REGION
  ((EXT AP < AP_S_1-TOL_IND SINGULAR REGION) NOT OUTSIDE IND_EXD) NOT WAIVE_REGION
  (EXT AP < AP_S_1 SPACE SINGULAR REGION) NOT INSIDE IND_EXD
  (EXT AP < AP_S_1-TOL_IND SPACE SINGULAR REGION) NOT OUTSIDE IND_EXD
  X = INT APi < 0.1 ABUT < 90 INTERSECTING ONLY REGION
  Y = EXT APi < 0.1 ABUT < 90 INTERSECTING ONLY REGION
  X NOT INTERACT AP_PAD_1
  Y NOT INTERACT AP_PAD_1
}  



AP.S.1.1 { @ space of AP pad metal and AP >= ^AP_S_1_1 um
  EXT AP_PAD_p AP < AP_S_1_1 REGION NOT CONNECTED
}

AP.S.4.WB { @ Space to CB2_WB/PM [overlap is prohibited except bond pad and seal ring] >= ^AP_S_4 um
  CB2_CHECK = (CB2 NOT INTERACT CB_PAD) NOT INTERACT SEALRING_EXCLUDE
  EXT AP_CHECK CB2_CHECK < AP_S_4 ABUT < 90 SINGULAR REGION
  AP_CHECK AND CB2_CHECK
#IFDEF WITH_POLYIMIDE
  PM_CHECK = (PM NOT INTERACT CB_PAD) NOT INTERACT SEALRING_EXCLUDE
  EXT AP_CHECK PM_CHECK < AP_S_4 ABUT < 90 SINGULAR REGION
  AP_CHECK AND PM_CHECK
#ENDIF
}

AP.EN.1 { @ Enclosured of RV (Not inside seal ring) >= ^AP_EN_1 um
  ENC RV_NIND AP < AP_EN_1 ABUT < 90 SINGULAR REGION OUTSIDE ALSO
  ENC RV_IND AP < AP_EN_1-TOL_IND ABUT < 90 SINGULAR REGION OUTSIDE ALSO
}
AP.EN.2 { @ Enclosure of CB2_WB >= ^AP_EN_2 um ; AP must be drawn to cover PAD for AP_RDL
  ENC CB2x AP < AP_EN_2 ABUT < 90 SINGULAR REGION
  CB2x NOT AP
}

#IFDEF FULL_CHIP
AP.DN.1 { @ AP density across full chip >= ^AP_DN_1
  DENSITY AP < AP_DN_1 INSIDE OF LAYER CHIP_EDGE RDB AP.DN.1.density
}

AP.DN.1.1 { @ AP density across full chip <= ^AP_DN_1_1
  DENSITY AP > AP_DN_1_1 INSIDE OF LAYER CHIP_EDGE RDB AP.DN.1.1.density
}
#ENDIF

#ENDIF

// PM Layout Rules
//==============================================
PM_CHECK = PM NOT SEALRING_EXCLUDE
PM.W.1 { @ width of PM (except sealring(162,2)) >= ^PM_W_1 um
  INT PM_CHECK < PM_W_1 ABUT <90 SINGULAR REGION
}
PM.S.1 { @ space of PM, PM space to chip >= ^PM_S_1
  EXT PM_CHECK < PM_S_1 ABUT < 90 SINGULAR REGION
  ENC PM_CHECK CHIP_EDGE < PM_S_1 ABUT < 90 SINGULAR REGION
}
PM.EN.1 { @ PM enclosure of CB/CB2_WB >= ^PM_EN_1
  ENC CB_PAD PM < PM_EN_1 ABUT <90 SINGULAR REGION
  ENC CB2 PM < PM_EN_1 ABUT <90 SINGULAR REGION
#IFDEF WITH_POLYIMIDE
  CB_PAD NOT PM
  CB2 NOT PM
#ENDIF
}
PM.R.1 { @ Polymide layer is required if chip size equal to or larger than ^PM_R_1 mm2
  A = AREA CHIP_EDGE >= PM_R_1*1000000
  A NOT INTERACT PM
}
#IFDEF WITH_POLYIMIDE
PM.R.3 { @ Polyimide is prohibited over outer seal ring and SLDB regions.
         @ It only covers inner seal ring area
         @ (PM drawn pattern must cover outer seal ring and SLDB regions.)
  SEALRING_INNER = SEALRINGi AND (HOLES SEALRINGi)
  A = CHIP_WISR NOT SEALRING_EXCLUDE
  B = (SIZE A BY 6) NOT A
  C = SEALRING_ALL NOT (SEALRING_INNER OR (HOLES SEALRING_INNER INNER EMPTY))
  C NOT PM
  (SEALRING_INNER OR B) AND PM
}
#ENDIF
