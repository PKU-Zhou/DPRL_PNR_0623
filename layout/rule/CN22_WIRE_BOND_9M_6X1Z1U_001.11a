//OPTIONS
//=======
/* SWITCH DEFINITION START */

/* select Redistribution Interconnection */
#DEFINE with_AP           // Turn on to use AP as the redistribution metal after passivation (AP_RDL)

/* select AP Thickness */
#DEFINE AP_28K_THICKNESS     //Turn on for 28K AP-RDL. Fixed for N22 wire bond.

//#DEFINE ChipWindowUsed  // Turn on to specify chip boundary directly by following variables
VARIABLE xLB   0.0        // x-coordinate of left-bottom corner for user defined chip window
VARIABLE yLB   0.0        // y-coordinate of left-bottom corner for user defined chip window
VARIABLE xRT   1000.0     // x-coordinate of right-top corner for user defined chip window
VARIABLE yRT   1000.0     // y-coordinate of right-top corner for user defined chip window


/* select optional layer */
//#DEFINE WITH_POLYIMIDE    // Turn off if process without Polyimide
                          // Polyimide layer is required if chip size equal to or larger than 136.7mm^2

/* select pad pitch and structure */

//#DEFINE PITCH_47_SINGLE  //Turn on to use single in-line pad with pitch >= 47.4um
//#DEFINE PITCH_52_SINGLE  //Turn on to use single in-line pad with pitch >= 52.6um
//#DEFINE PITCH_57_SINGLE  //Turn on to use single in-line pad with pitch >= 57.9um
#DEFINE PITCH_63_SINGLE  //Turn on to use single in-line pad with pitch >= 63.1um



//#DEFINE PITCH_47_STAGGER  //Turn on to use staggered pad with pitch >= 47.4um
//#DEFINE PITCH_52_STAGGER  //Turn on to use staggered pad with pitch >= 52.6um
//#DEFINE PITCH_63_STAGGER  //Turn on to use staggered pad with pitch >= 63.1um
//#DEFINE PITCH_73_STAGGER  //Turn on to use staggered pad with pitch >= 73.6um
//#DEFINE PITCH_84_STAGGER  //Turn on to use staggered pad with pitch >= 84.2um

//#DEFINE PITCH_84_TRITIER  //Turn on to use tri-tier pad with  pitch >= 84.2um


/*Please note that for each pad structure (single_in_line, stagger, or tri_tier) only one kind of pitch can exist.*/


/* select wire type */
#DEFINE CU_WIRE  // Turn on for Copper (Cu) wire; Turn off for Gold (Au) wire

#DEFINE FULL_CHIP  // Turn on for chip





// ENVIRONMENT SETUP
//==================
PRECISION    1000
RESOLUTION      5

LAYOUT SYSTEM GDSII
LAYOUT PATH "GDSFILENAME"
LAYOUT PRIMARY "TOPCELLNAME"
LAYOUT PROCESS BOX RECORD YES

DRC RESULTS DATABASE "DRC_RES.db"
DRC SUMMARY REPORT "DRC.rep"
DRC KEEP EMPTY NO
DRC CHECK TEXT ALL
DRC MAXIMUM RESULTS ALL

FLAG OFFGRID YES
FLAG ACUTE YES
FLAG SKEW YES
FLAG NONSIMPLE YES
FLAG NONSIMPLE PATH YES
/* SWITCH DEFINITION END */
