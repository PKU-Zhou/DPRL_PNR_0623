#IFDEF CU_WIRE
#IFDEF PITCH_47_SINGLE
CU_WIRE_PITCH_OPTION:ERROR1 { @ >=47.4 single in-line is not available for copper wire. Please refer to table 4.4.1.1
  COPY CHIP
}
#ENDIF // PITCH_47_SINGLE
