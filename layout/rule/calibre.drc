  M1_TypeBRS3_prefilter_6 = M1_TypeBRS3_prefilter_4 NOT M1_TypeBRS3_prefilter_5
  M1_TypeBRS3_prefilter_7_1 = M1_TypeBRS3_prefilter_6 INTERACT (M1_TypeBRS3_prefilter_6 AND M1i) > 1
  M1_TypeBRS3_prefilter_7 = (M1_TypeBRS3_prefilter_5_1 INTERACT M1_TypeBRS3_prefilter_7_1) OR M1_TypeBRS3_prefilter_7_1
  M1_TypeBRS3_prefilter_8 = EXTENTS M1_TypeBRS3_prefilter_7
  
  M1_TypeBRS3_prefilter_9 = M1_TypeBRS3_prefilter_3 COIN EDGE (M1_CORNER INTERACT M1_TypeBRS3_prefilter_8)
  M1_TypeBRS3_prefilter_10 = EXT M1_TypeBRS3_prefilter_9 M1_TypeBRS3_prefilter_2 == TypeBRS3_S2 OPPOSITE REGION
  M1_TypeBRS3_prefilter_11 = M1_TypeBRS3_prefilter_10 INTERACT (M1_TypeBRS3_prefilter_10 AND M1i) > 1
  M1_TypeBRS3_prefilter_12 = (EXPAND EDGE M1_TypeBRS3_prefilter_3 OUTSIDE BY GRID) NOT INTERACT M1_TypeBRS3_prefilter_11
  M1_TypeBRS3_prefilter_13 = (EXPAND EDGE (M1_TypeBRS3_prefilter_12 NOT COIN EDGE M1i) OUTSIDE BY GRID) OR M1_TypeBRS3_prefilter_12 
