// Seal-Ring Rule Check
//=====================

SR.R.1 { @ SEALRING layer (CAD layer: 162;0) and SEALRING_DB layer (CAD layer: 162;1) are Must if customers add seal ring by themselves.
         @ 162;0 is used to cover the outer seal ring (2um) and inner seal ring (6um);
         @ 162;1 is used to cover SLDB (3.5um duplicate).
         @ 162;2 is used to cover SEALRING, SLDB, and seal-ring enhanced zone.
         @ SEALRING layer (162;0) , SEALRING_DB layer (162;1), and SEALRING_ALL layer (162;2) must exist.
         @ All the drawing of seal ring and SLDB structures must be inside of SEALRING_ALL (162;2).
	 @ Please follow the CAD layers usage of 162;0, 162;1, and 162;2.
  CHIP_WISR_P4 NOT INTERACT SEALRING_ORI
  CHIP_WISR_P4 NOT INTERACT SEALRING_DB
  CHIP_WISR_P4 NOT INTERACT SEALRING_ALL
  SR_CO_P4 NOT SEALRING_ALL
  (SR_VIA1_P4 OR SR_VIA1_BAR) NOT SEALRING_ALL
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA1_P4
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA1_BAR
  (SR_VIA2_P4 OR SR_VIA2_BAR) NOT SEALRING_ALL
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA2_P4
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA2_BAR
  (SR_VIA3_P4 OR SR_VIA3_BAR) NOT SEALRING_ALL
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA3_P4
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA3_BAR
  (SR_VIA4_P4 OR SR_VIA4_BAR) NOT SEALRING_ALL
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA4_P4
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA4_BAR
  (SR_VIA5_P4 OR SR_VIA5_BAR) NOT SEALRING_ALL
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA5_P4
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA5_BAR
  (SR_VIA6_P4 OR SR_VIA6_BAR) NOT SEALRING_ALL
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA6_P4
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA6_BAR
  (SR_VIA7_P4 OR SR_VIA7_BAR) NOT SEALRING_ALL
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA7_P4
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA7_BAR
  (SR_VIA8_P4 OR SR_VIA8_BAR) NOT SEALRING_ALL
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA8_P4
  (SEALRING_ORI OR SEALRING_DB) NOT INTERACT SR_VIA8_BAR
}

SR.R.4 { @ Please add VIA holes in metal lines of inner and outer seal-ring as many as possible. DRC flags: {SEALRING NOT INTERACT VIAx, VIAy, VIAz, VIAu and VIAr holes respectively}   
  SR_M1_P4 NOT INTERACT SR_VIA1_HOLE
  SR_M2_P4 NOT INTERACT SR_VIA2_HOLE
  SR_M3_P4 NOT INTERACT SR_VIA3_HOLE
  SR_M4_P4 NOT INTERACT SR_VIA4_HOLE
  SR_M5_P4 NOT INTERACT SR_VIA5_HOLE
  SR_M6_P4 NOT INTERACT SR_VIA6_HOLE
  SR_M7_P4 NOT INTERACT SR_VIA7_HOLE
  SR_M8_P4 NOT INTERACT SR_VIA8_HOLE
}


SR.R.7 { @ CO bar and VIA {x,y,z,r,u} bar must be continuous as a ring
  LINE_CO = NOT RECTANGLE SR_CO_P4 == CO_W_1 BY == CO_W_1
  CONVEX EDGE LINE_CO ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH < 20*CO_W_2
	NOT DONUT LINE_CO

  SR_A1 = NOT ENCLOSE RECTANGLE SR_VIA1_P4 VIA1_W_1+GRID VIA1_W_1+GRID
  LINE_VIA1 = (NOT RECTANGLE SR_VIA1_P4 == VIA1_W_1 BY == VIA1_W_1) NOT SR_A1
  CONVEX EDGE LINE_VIA1 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH < 20*VIA1_W_2
	NOT DONUT LINE_VIA1
  SR_A2 = NOT ENCLOSE RECTANGLE SR_VIA2_P4 VIA2_W_1+GRID VIA2_W_1+GRID
  LINE_VIA2 = (NOT RECTANGLE SR_VIA2_P4 == VIA2_W_1 BY == VIA2_W_1) NOT SR_A2
  CONVEX EDGE LINE_VIA2 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH < 20*VIA2_W_2
	NOT DONUT LINE_VIA2
  SR_A3 = NOT ENCLOSE RECTANGLE SR_VIA3_P4 VIA3_W_1+GRID VIA3_W_1+GRID
  LINE_VIA3 = (NOT RECTANGLE SR_VIA3_P4 == VIA3_W_1 BY == VIA3_W_1) NOT SR_A3
  CONVEX EDGE LINE_VIA3 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH < 20*VIA3_W_2
	NOT DONUT LINE_VIA3
  SR_A4 = NOT ENCLOSE RECTANGLE SR_VIA4_P4 VIA4_W_1+GRID VIA4_W_1+GRID
  LINE_VIA4 = (NOT RECTANGLE SR_VIA4_P4 == VIA4_W_1 BY == VIA4_W_1) NOT SR_A4
  CONVEX EDGE LINE_VIA4 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH < 20*VIA4_W_2
	NOT DONUT LINE_VIA4
  SR_A5 = NOT ENCLOSE RECTANGLE SR_VIA5_P4 VIA5_W_1+GRID VIA5_W_1+GRID
  LINE_VIA5 = (NOT RECTANGLE SR_VIA5_P4 == VIA5_W_1 BY == VIA5_W_1) NOT SR_A5
  CONVEX EDGE LINE_VIA5 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH < 20*VIA5_W_2
	NOT DONUT LINE_VIA5
  SR_A6 = NOT ENCLOSE RECTANGLE SR_VIA6_P4 VIA6_W_1+GRID VIA6_W_1+GRID
  LINE_VIA6 = (NOT RECTANGLE SR_VIA6_P4 == VIA6_W_1 BY == VIA6_W_1) NOT SR_A6
  CONVEX EDGE LINE_VIA6 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH < 20*VIA6_W_2
	NOT DONUT LINE_VIA6
  SR_A7 = NOT ENCLOSE RECTANGLE SR_VIA7_P4 VIA7_W_1+GRID VIA7_W_1+GRID
  LINE_VIA7 = (NOT RECTANGLE SR_VIA7_P4 == VIA7_W_1 BY == VIA7_W_1) NOT SR_A7
  CONVEX EDGE LINE_VIA7 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH < 20*VIA7_W_2
	NOT DONUT LINE_VIA7
  SR_A8 = NOT ENCLOSE RECTANGLE SR_VIA8_P4 VIA8_W_1+GRID VIA8_W_1+GRID
  LINE_VIA8 = (NOT RECTANGLE SR_VIA8_P4 == VIA8_W_1 BY == VIA8_W_1) NOT SR_A8
  CONVEX EDGE LINE_VIA8 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH < 20*VIA8_W_2
	NOT DONUT LINE_VIA8

#IFDEF WIRE_BOND
	NOT DONUT (NOT RECTANGLE (CBi INTERACT (OR SEALRING_ALL SEALRING_ORI SEALRING_DB)))
#ELSE
	NOT DONUT (NOT RECTANGLE (CBDi INTERACT (OR SEALRING_ALL SEALRING_ORI SEALRING_DB)))
#ENDIF
#IFDEF WITH_APRDL
	NOT DONUT (NOT RECTANGLE (RVi INTERACT (OR SEALRING_ALL SEALRING_ORI SEALRING_DB)))
#ENDIF
}

SR.R.9 { @ Width of seal-ring enhanced zone (SREZ)= 6 um (layout forbidden area.) Only M1~AP and DMV pattern are allowed in seal-ring enhanced zone region (DMV pattern: metal/via dummy pattern, DOD, & DPO) Each M1~AP patterns in seal-ring enhanced zone region must follow the following conditions: 1. Each M1~Mtop must be connected to seal-ring wall 2. Each AP can only connect to the inner seal-ring wall 3. Each M1~AP overlap SLDB is not allowed   
  ISOR_P4 AND DNWi
  ISOR_P4 AND NWi
  (ISOR_P4 AND POi) NOT INSIDE CDUDMY
  (ISOR_P4 AND ODi) NOT INSIDE CDUDMY
  (ISOR_P4 AND COi) NOT INSIDE CDUDMY
  ISOR_P4 AND RVi  // For AlRDL
  ISOR_P4 AND UBMi
  ISOR_P4 AND CBDi
  ISOR_P4 AND CBi
  ISOR_P4 AND CB2Fi
  ISOR_P4 AND CB2Wi
}
SR.R.9:M1 { @ Width of seal-ring enhanced zone (SREZ)= 6 um (layout forbidden area.) Only M1~AP and DMV pattern are allowed in seal-ring enhanced zone region (DMV pattern: metal/via dummy pattern, DOD, & DPO) Each M1~AP patterns in seal-ring enhanced zone region must follow the following conditions: 1. Each M1~Mtop must be connected to seal-ring wall 2. Each AP can only connect to the inner seal-ring wall 3. Each M1~AP overlap SLDB is not allowed   
  ((M1 NOT INTERACT SEALRING_ORI) CUT ISOR_P4) AND ISOR_P4
  (M1 INTERACT ISOR_P4) AND SEALRING_DB
}
// SR.R.9 is checked by SR.R.9:M1
