RR:RE:VIA6.EN.2__VIA6.EN.3 { @ Recommended enclosure of {M1 OR Mx} [at least two opposite sides] to avoid high Rc.(for square VIA) >= 0.05
                        @ Recommended enclosure of {M1 OR Mx} to avoid high Rc. [all sides] (for square VIA) >= 0.025       
   CHECK_VIA = SQR_VIA6 INTERACT VIA6EN2_VIA6EN3_VIA6       
   X = RECTANGLE ENCLOSURE CHECK_VIA M6 ABUT < 90 SINGULAR GOOD 0 VIA6_EN_2_R OPPOSITE 0 VIA6_EN_2_R OPPOSITE
   ENC X M6 < VIA6_EN_3_R ABUT < 90 SINGULAR REGION
}
// VIA6.EN.2.R and VIA6.EN.3.R are checked by RR:RE:VIA6.EN.2__VIA6.EN.3
#ENDIF
#ENDIF

//RR:RE:VIA1.R.10 is not necessary to check


// M7.EN.0.R is checked by either {M7.EN.1.R/M7.EN.2.R} or M7.EN.3.R
#IFDEF CHECK_M7EN1_
#IFDEF _M7EN1_
M7EN1_VIA6CellIn1 = INSIDE CELL VIA6ii CellsForRRuleRecommended  
M7EN1_VIA6CellOut1 = NOT INSIDE CELL VIA6ii ExclCellsForRRuleRecommended 
M7EN1_VIA6CellIn2 = INSIDE CELL VIA6_VIRT CellsForRRuleRecommended  
M7EN1_VIA6CellOut2 = NOT INSIDE CELL VIA6_VIRT ExclCellsForRRuleRecommended 
M7EN1_VIA6Cell = (M7EN1_VIA6CellIn1 AND M7EN1_VIA6CellOut1) OR (M7EN1_VIA6CellIn2 AND M7EN1_VIA6CellOut2)
M7EN1_VIA6Marker = (VIA6ii OR VIA6_VIRT) AND RRuleRecommended
M7EN1_VIA6 = ((M7EN1_VIA6Cell OR M7EN1_VIA6Marker) NOT Block ) NOT excludeRRuleRecommended


RR:RE:M7.EN.1 { @ Recommended enclosure of VIAx-1 to avoid high Rc. (for square VIA) >= 0.01
   CHECK_VIA = SQR_VIA6 INTERACT M7EN1_VIA6
   ENC CHECK_VIA M7 < M7_EN_1_R ABUT < 90 SINGULAR REGION
}
#ENDIF
#ENDIF

#IFDEF CHECK_M7EN2_M7EN3_
#IFDEF _M7EN2_M7EN3_
M7EN2_M7EN3_VIA6CellIn1 = INSIDE CELL VIA6ii CellsForRRuleRecommended  
M7EN2_M7EN3_VIA6CellOut1 = NOT INSIDE CELL VIA6ii ExclCellsForRRuleRecommended 
M7EN2_M7EN3_VIA6CellIn2 = INSIDE CELL VIA6_VIRT CellsForRRuleRecommended  
M7EN2_M7EN3_VIA6CellOut2 = NOT INSIDE CELL VIA6_VIRT ExclCellsForRRuleRecommended 
M7EN2_M7EN3_VIA6Cell = (M7EN2_M7EN3_VIA6CellIn1 AND M7EN2_M7EN3_VIA6CellOut1) OR (M7EN2_M7EN3_VIA6CellIn2 AND M7EN2_M7EN3_VIA6CellOut2)
M7EN2_M7EN3_VIA6Marker = (VIA6ii OR VIA6_VIRT) AND RRuleRecommended
M7EN2_M7EN3_VIA6 = ((M7EN2_M7EN3_VIA6Cell OR M7EN2_M7EN3_VIA6Marker) NOT Block ) NOT excludeRRuleRecommended


RR:RE:M7.EN.2__M7.EN.3 { @ Recommended M7 enclosure of square VIA6 >= ^M7_EN_3_R, OR at least two opposite sides >= ^M7_EN_2_R um
  CHECK_VIA = SQR_VIA6 INTERACT M7EN2_M7EN3_VIA6      
  A = RECTANGLE ENCLOSURE CHECK_VIA M7 ABUT < 90 SINGULAR GOOD 0 M7_EN_2_R OPPOSITE 0 M7_EN_2_R OPPOSITE
  ENC A M7 < M7_EN_3_R ABUT < 90 SINGULAR REGION
}
// M7.EN.2.R and M7.EN.3.R are checked by RR:RE:M7.EN.2__M7.EN.3
#ENDIF
#ENDIF

#IFDEF CHECK_M7S1_
#IFDEF _M7S1_
M7S1_M7CellIn = INSIDE CELL M7i CellsForRRuleRecommended  
M7S1_M7CellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
M7S1_M7Cell = M7S1_M7CellIn AND M7S1_M7CellOut
M7S1_M7Marker = M7i AND RRuleRecommended
M7S1_M7 = ((M7S1_M7Cell OR M7S1_M7Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:M7.S.1 { @ Recommended space to reduce the short possibility caused by particle >= 0.06 
  ((EXT M7 < M7_S_1_R ABUT < 90 SINGULAR REGION) INTERACT M7S1_M7) NOT INSIDE TCDDMY_BM7 
}
#ENDIF
#ENDIF

#IFDEF CHECK_M7S2_
#IFDEF _M7S2_
M7S2_M7CellIn = INSIDE CELL M7i CellsForRRuleRecommended  
M7S2_M7CellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
M7S2_M7Cell = M7S2_M7CellIn AND M7S2_M7CellOut
M7S2_M7Marker = M7i AND RRuleRecommended
M7S2_M7 = ((( M7S2_M7Cell OR M7S2_M7Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M7.S.2 { @ Recommended space [at least one metal line width > 0.09 um] >= 0.06 
  ((EXT M7_20 M7 < M7_S_2_R OPPOSITE REGION MEASURE ALL) NOT M7) INTERACT M7S2_M7
}
#ENDIF
#ENDIF

#IFDEF CHECK_M7S3_
#IFDEF _M7S3_
M7S3_M7CellIn = INSIDE CELL M7i CellsForRRuleRecommended  
M7S3_M7CellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
M7S3_M7Cell = M7S3_M7CellIn AND M7S3_M7CellOut
M7S3_M7Marker = M7i AND RRuleRecommended
M7S3_M7 = ((( M7S3_M7Cell OR M7S3_M7Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M7.S.3 { @ Recommended space [at least one metal line width > 0.16 um] >= 0.1 
  ((EXT M7_21 M7 < M7_S_3_R OPPOSITE REGION MEASURE ALL) NOT M7) INTERACT M7S3_M7
}

#ENDIF
#ENDIF

#IFDEF CHECK_M7S4_
#IFDEF _M7S4_
M7S4_M7CellIn = INSIDE CELL M7i CellsForRRuleRecommended  
M7S4_M7CellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
M7S4_M7Cell = M7S4_M7CellIn AND M7S4_M7CellOut
M7S4_M7Marker = M7i AND RRuleRecommended
M7S4_M7 = ((( M7S4_M7Cell OR M7S4_M7Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M7.S.4 { @ Recommended space [at least one metal line width > 0.47 um] >= 0.13 
  (((EXT M7_22 M7 < M7_S_4_R OPPOSITE REGION MEASURE ALL) NOT M7) INTERACT M7S4_M7) NOT INSIDE TCDDMY_BM7
}
#ENDIF
#ENDIF

#IFDEF CHECK_M7S5_
#IFDEF _M7S5_
M7S5_M7CellIn = INSIDE CELL M7i CellsForRRuleRecommended  
M7S5_M7CellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
M7S5_M7Cell = M7S5_M7CellIn AND M7S5_M7CellOut
M7S5_M7Marker = M7i AND RRuleRecommended
M7S5_M7 = ((( M7S5_M7Cell OR M7S5_M7Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M7.S.5 { @ Recommended space [at least one metal line width > 0.63 um] >= 0.15 
  ((EXT M7_23 M7 < M7_S_5_R OPPOSITE REGION MEASURE ALL) NOT M7) INTERACT M7S5_M7
}
#ENDIF
#ENDIF

#IFDEF CHECK_M7S6_
#IFDEF _M7S6_
M7S6_M7CellIn = INSIDE CELL M7i CellsForRRuleRecommended  
M7S6_M7CellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
M7S6_M7Cell = M7S6_M7CellIn AND M7S6_M7CellOut
M7S6_M7Marker = M7i AND RRuleRecommended
M7S6_M7 = ((( M7S6_M7Cell OR M7S6_M7Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M7.S.6 { @ Recommended space [at least one metal line width > 1.5 um] >= 0.5 
  ((EXT M7_30 M7 < M7_S_6_R OPPOSITE REGION MEASURE ALL) NOT M7) INTERACT M7S6_M7
}

#ENDIF
#ENDIF

#IFDEF CHECK_M7S13_
#IFDEF _M7S13_
M7S13_M7CellIn = INSIDE CELL M7i CellsForRRuleRecommended  
M7S13_M7CellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
M7S13_M7Cell = M7S13_M7CellIn AND M7S13_M7CellOut
M7S13_M7Marker = M7i AND RRuleRecommended
M7S13_M7 = ((( M7S13_M7Cell OR M7S13_M7Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M7.S.13 { @ Recommended space [at least one metal line width > 0.13 um] >= 0.08 
  ((EXT M7_201 M7 < M7_S_13_R OPPOSITE REGION MEASURE ALL) NOT M7) INTERACT M7S13_M7
}
#ENDIF
#ENDIF


#IFDEF CHECK_M7S37_
#IFDEF _M7S37_
M7S37_M7CellIn = INSIDE CELL M7i CellsForRRuleRecommended  
M7S37_M7CellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
M7S37_M7Cell = M7S37_M7CellIn AND M7S37_M7CellOut
M7S37_M7Marker = M7i AND RRuleRecommended
M7S37_M7 = ((M7S37_M7Cell OR M7S37_M7Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:M7.S.37 { @ Recommended space to Mx jog filled up region (R1A) Definition of Mx jog: Mx with length < 0.12 um (LA1), 2 adjacent edge length < 0.05 um (WA1) and < 0.06 um (WA2) [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex -90 degree outer vertex] >= 0.05 
  L1_pre = CONVEX EDGE M7S37_M7 ANGLE1==90 ANGLE2==270 LENGTH2 < 0.12 WITH LENGTH < 0.05 
  L2_pre = CONVEX EDGE M7S37_M7 ANGLE1==90 ANGLE2==270 LENGTH1 < 0.06 LENGTH2 <0.05 WITH LENGTH < 0.12
  L3_pre = CONVEX EDGE M7S37_M7 ANGLE1==90 ANGLE2==90  LENGTH1 < 0.12 WITH LENGTH < 0.06
  L1_L2_V = EXT L1_pre L2_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
  L2_L3_V = INT L2_pre L3_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
  L2 = (L2_pre TOUCH OUTSIDE EDGE L1_L2_V) TOUCH INSIDE EDGE L2_L3_V  
  L1 = L1_pre TOUCH OUTSIDE EDGE (L1_L2_V WITH EDGE L2) 
  L1_ex = EXPAND EDGE L1 OUTSIDE BY GRID
  L2_ex = EXPAND EDGE L2 OUTSIDE BY GRID
  JOG_FILL = EXTENTS (L1_ex OR L2_ex)
  S = EXT JOG_FILL M7 < 0.05 ABUT>0<90 SINGULAR REGION
  S OR (JOG_FILL INTERACT S)
}
#ENDIF
#ENDIF

#IFDEF CHECK_M7A1_
#IFDEF _M7A1_
M7A1_M7CellIn = INSIDE CELL M7i CellsForRRuleRecommended  
M7A1_M7CellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
M7A1_M7Cell = M7A1_M7CellIn AND M7A1_M7CellOut
M7A1_M7Marker = M7i AND RRuleRecommended
M7A1_M7 = ((M7A1_M7Cell OR M7A1_M7Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:M7.A.1 { @ Recommended area (except DMx_O) >= 0.022 
  (AREA M7A1_M7 < M7_A_1_R) NOT INSIDE TCDDMY_BM7
}
#ENDIF
#ENDIF



#IFDEF CHECK_VIAxR9_
#IFDEF _VIAxR9_
VIA_EXD_STACK = COPY SEALRING_ALL

SINGLE_VIA1 = SQR_VIA1 INTERACT ( (M1i AND M2i) INTERACT VIA1i == 1 ) 
SINGLE_VIA2 = SQR_VIA2 INTERACT ( (M2i AND M3i) INTERACT VIA2i == 1 ) 
SINGLE_VIA3 = SQR_VIA3 INTERACT ( (M3i AND M4i) INTERACT VIA3i == 1 ) 
SINGLE_VIA4 = SQR_VIA4 INTERACT ( (M4i AND M5i) INTERACT VIA4i == 1 ) 
SINGLE_VIA5 = SQR_VIA5 INTERACT ( (M5i AND M6i) INTERACT VIA5i == 1 ) 
SINGLE_VIA6 = SQR_VIA6 INTERACT ( (M6i AND M7i) INTERACT VIA6i == 1 ) 

VIAxR9_V4CellIn1 = INSIDE CELL VIA4ii CellsForRRuleRecommended  
VIAxR9_V4CellOut1 = NOT INSIDE CELL VIA4ii ExclCellsForRRuleRecommended 
VIAxR9_V4CellIn2 = INSIDE CELL VIA4_VIRT CellsForRRuleRecommended  
VIAxR9_V4CellOut2 = NOT INSIDE CELL VIA4_VIRT ExclCellsForRRuleRecommended 
VIAxR9_V4Cell = (VIAxR9_V4CellIn1 AND VIAxR9_V4CellOut1) OR (VIAxR9_V4CellIn2 AND VIAxR9_V4CellOut2)
VIAxR9_V4Marker = (VIA4ii OR VIA4_VIRT) AND RRuleRecommended
VIAxR9_V4 = ((VIAxR9_V4Cell OR VIAxR9_V4Marker) NOT Block ) NOT excludeRRuleRecommended

VIAxR9_STACK_V3V5 = ((SINGLE_VIA3 AND SINGLE_VIA4) AND SINGLE_VIA5) AND VIAxR9_V4

RR:RE:VIAx.R.9:V1V5 { @ Max. 4 stacked square Vias are allowed when only one via for each VIA layer.(VIA1~VIA5 is not allowed)
  ((VIAxR9_STACK_V3V5 AND SINGLE_VIA1) AND SINGLE_VIA2) NOT VIA_EXD_STACK
}
// 'VIAx.R.9.R' is checked by RR:RE:VIAx.R.9:V1V5 
RR:RE:VIAx.R.9:V2V6 { @ Max. 4 stacked square Vias are allowed when only one via for each VIA layer.(VIA2~VIA6 is not allowed)
  ((VIAxR9_STACK_V3V5 AND SINGLE_VIA2) AND SINGLE_VIA6) NOT VIA_EXD_STACK
} 
// 'VIAx.R.9.R' is checked by RR:RE:VIAx.R.9:V2V6 
#ENDIF
#ENDIF









#IFDEF CHECK_MxR4_
#IFDEF _MxR4_
RR:RE:Mx.R.4 {@ Recommended maximum stacked Mx layers of high density area [density > 75% in window 875 um x 875 um, stepping 125 um] <= 4 
  MxR4_M1 = DENSITY M1x > 0.75 WINDOW 875 STEP 125 BACKUP INSIDE OF LAYER CHIPx PRINT Mx.R.4.R.M1.density RDB Mx.R.4.R.M1.RDB.density
  MxR4_M2 = DENSITY M2x > 0.75 WINDOW 875 STEP 125 BACKUP INSIDE OF LAYER CHIPx PRINT Mx.R.4.R.M2.density RDB Mx.R.4.R.M2.RDB.density
  MxR4_M3 = DENSITY M3x > 0.75 WINDOW 875 STEP 125 BACKUP INSIDE OF LAYER CHIPx PRINT Mx.R.4.R.M3.density RDB Mx.R.4.R.M3.RDB.density
  MxR4_M4 = DENSITY M4x > 0.75 WINDOW 875 STEP 125 BACKUP INSIDE OF LAYER CHIPx PRINT Mx.R.4.R.M4.density RDB Mx.R.4.R.M4.RDB.density
  MxR4_M5 = DENSITY M5x > 0.75 WINDOW 875 STEP 125 BACKUP INSIDE OF LAYER CHIPx PRINT Mx.R.4.R.M5.density RDB Mx.R.4.R.M5.RDB.density
  MxR4_M6 = DENSITY M6x > 0.75 WINDOW 875 STEP 125 BACKUP INSIDE OF LAYER CHIPx PRINT Mx.R.4.R.M6.density RDB Mx.R.4.R.M6.RDB.density
  MxR4_M7 = DENSITY M7x > 0.75 WINDOW 875 STEP 125 BACKUP INSIDE OF LAYER CHIPx PRINT Mx.R.4.R.M7.density RDB Mx.R.4.R.M7.RDB.density
  DENSITY MxR4_M1 MxR4_M2 MxR4_M3 MxR4_M4 MxR4_M5 MxR4_M6 MxR4_M7 > 4 WINDOW 875 STEP 125 BACKUP INSIDE OF LAYER CHIPx
          [!!AREA(MxR4_M1)+!!AREA(MxR4_M2)+!!AREA(MxR4_M3)+!!AREA(MxR4_M4)+!!AREA(MxR4_M5)+!!AREA(MxR4_M6)+!!AREA(MxR4_M7)]
}
// 'Mx.R.4.R' is checked by RR:RE:Mx.R.4
#ENDIF
#ENDIF

#IFDEF CHECK_M1DN2_
#IFDEF _M1DN2_
RR:RE:M1.DN.2 { @ Recommended maximum metal density in window 60 um x 60 um, stepping 20 um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 85% 
    EXC = COPY ICOVL
  N = M1x NOT EXC
  D = CHIP NOT EXC 
  A = CHIPx NOT EXC
  X = DENSITY A M1x CHIP N D > M1_DN_2_R WINDOW M1_DN_2_W_R STEP M1_DN_2_S_R BACKUP INSIDE OF LAYER CHIPx PRINT M1.DN.2.R.density RDB M1.DN.2.R.RDB.density
          [~(M1_DN_2_E_R-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M1x)/AREA(CHIP)-M1_DN_2_R)]



   X NOT excludeRRuleRecommended    
}

#ENDIF
#ENDIF

#IFDEF CHECK_M1DN5_
#IFDEF _M1DN5_
#IFDEF CHECK_LOW_DENSITY
RR:RE:M1.DN.5 { @ Recommended minimum metal density in window 20 um x 20 um stepping 20 um. 1. The check doesn't include LOGO, INDDMY, ICOVL, chip corner triangle empty areas and SEALRING_ALL. (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 15% 
  EXC = M1_EXC_LOW OR ICOVL
  N = M1x NOT EXC
  D = CHIP NOT EXC 
  A = CHIP_M1 NOT EXC
  X = DENSITY A M1x CHIP N D < M1_DN_5_R WINDOW M1_DN_5_W_R STEP M1_DN_5_S_R BACKUP INSIDE OF LAYER CHIP_M1 PRINT M1.DN.5.R.density RDB M1.DN.5.R.RDB.density
          [~(AREA(A)-M1_DN_5_E_R)*!!(AREA(A)-M1_DN_5_E_R)+AREA(N)/AREA(D)+!~(AREA(M1x)/AREA(CHIP)-M1_DN_5_R)+!(AREA(M1x)/AREA(CHIP)-M1_DN_5_R)]


  X NOT excludeRRuleRecommended    
}

#ENDIF
#ENDIF
#ENDIF

#IFNDEF FULL_CHIP
#IFDEF CHECK_M1DN6_
#IFDEF _M1DN6_
#IFDEF CHECK_LOW_DENSITY
RR:RE:M1.DN.6 { @ Recommend metal Density >= ^M1_DN_6_R for IP level. Item(A) to Item(C) are recommended.
@ (A) For IP level, recommend metal density [checking window ^M1_DN_6_W_A_R um x ^M1_DN_6_W_A_R um, stepping ^M1_DN_6_S_A_R um] >= ^M1_DN_6_R
@ (B) For IP level, recommend maximum area of merged low density windows [checking window ^M1_DN_6_W_BC_R um x ^M1_DN_6_W_BC_R um, stepping ^M1_DN_6_S_BC_R um, density < ^M1_DN_6_R] <= ^M1_DN_6_A_B_R um2. Merged low density windows width <= ^M1_DN_6_U_R um is excepted.
@ (C) For IP level, recommend maximum area of merged low density windows [checking window ^M1_DN_6_W_BC_R um x ^M1_DN_6_W_BC_R um, stepping ^M1_DN_6_S_BC_R um, density < ^M1_DN_6_R] <= ^M1_DN_6_A_C_R um2
@ 1. The following special regions are excluded
@    Chip corner triangle empty areas if sealring is added by tsmc. 
@    LOWMEDN
@ 2. This rule is applied while the width of (checking window NOT above excluding region) >= ^M1_DN_6_E_A_R um for (A) and >= ^M1_DN_6_E_BC_R um for both (B)/(C) 
  M1_CHECK = M1x NOT (NEW_DEN_EXC OR ICOVL)
  CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
  // Condition-A
  ERR_WIN_A = DENSITY M1_CHECK CHIP_CHECK < M1_DN_6_R WINDOW M1_DN_6_W_A_R STEP M1_DN_6_S_A_R INSIDE OF LAYER CHIP_M1 BACKUP 
	[ AREA(M1_CHECK)/AREA(CHIP_CHECK) ]
  F_A = WITH WIDTH (ERR_WIN_A NOT (NEW_DEN_EXC OR ICOVL)) >= M1_DN_6_E_A_R
  X = DENSITY F_A M1_CHECK CHIP_CHECK < M1_DN_6_R WINDOW M1_DN_6_W_A_R STEP M1_DN_6_S_A_R INSIDE OF LAYER CHIP_M1 BACKUP PRINT M1.DN.6R_A.density
         [ !AREA(F_A)+AREA(M1_CHECK)/AREA(CHIP_CHECK) ]
  X NOT excludeRRuleRecommended	 
  // Condition-B 
  ERR_WIN_B = DENSITY M1_CHECK CHIP_CHECK < M1_DN_6_R WINDOW M1_DN_6_W_BC_R STEP M1_DN_6_S_BC_R INSIDE OF LAYER CHIP_M1 BACKUP 
	[ AREA(M1_CHECK)/AREA(CHIP_CHECK) ]
  F_B = WITH WIDTH (ERR_WIN_B NOT (NEW_DEN_EXC OR ICOVL)) >= M1_DN_6_E_BC_R
  A = DENSITY F_B M1_CHECK CHIP_CHECK < M1_DN_6_R WINDOW M1_DN_6_W_BC_R STEP M1_DN_6_S_BC_R INSIDE OF LAYER CHIP_M1 BACKUP PRINT M1.DN.6R_BC.density
         [ !AREA(F_B)+AREA(M1_CHECK)/AREA(CHIP_CHECK) ]
  B = AREA A > M1_DN_6_A_B_R
  C = SIZE B BY M1_DN_6_U_R/2 UNDEROVER
  (B INTERACT C) NOT excludeRRuleRecommended
  // Condition-C
  (AREA B > M1_DN_6_A_C_R) NOT excludeRRuleRecommended 
}
#ENDIF
#ENDIF
#ENDIF
#ENDIF //FULL_CHIP





#IFDEF CHECK_M2DN2_
#IFDEF _M2DN2_
RR:RE:M2.DN.2 { @ Recommended maximum metal density in window 60 um x 60 um, stepping 20 um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 85% 
    EXC = COPY ICOVL
  N = M2x NOT EXC
  D = CHIP NOT EXC 
  A = CHIPx NOT EXC
  X = DENSITY A M2x CHIP N D > M2_DN_2_R WINDOW M2_DN_2_W_R STEP M2_DN_2_S_R BACKUP INSIDE OF LAYER CHIPx PRINT M2.DN.2.R.density RDB M2.DN.2.R.RDB.density
          [~(M2_DN_2_E_R-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M2x)/AREA(CHIP)-M2_DN_2_R)]



   X NOT excludeRRuleRecommended    
}

#ENDIF
#ENDIF

#IFDEF CHECK_M2DN5_
#IFDEF _M2DN5_
#IFDEF CHECK_LOW_DENSITY
RR:RE:M2.DN.5 { @ Recommended minimum metal density in window 20 um x 20 um stepping 20 um. 1. The check doesn't include LOGO, INDDMY, ICOVL, chip corner triangle empty areas, and SEALRING_ALL. (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 15% 
  EXC = M2_EXC_LOW OR ICOVL
  N = M2x NOT EXC
  D = CHIP NOT EXC 
  A = CHIP_M2 NOT EXC
  X = DENSITY A M2x CHIP N D < M2_DN_5_R WINDOW M2_DN_5_W_R STEP M2_DN_5_S_R BACKUP INSIDE OF LAYER CHIP_M2 PRINT M2.DN.5.R.density RDB M2.DN.5.R.RDB.density
          [~(AREA(A)-M2_DN_5_E_R)*!!(AREA(A)-M2_DN_5_E_R)+AREA(N)/AREA(D)+!~(AREA(M2x)/AREA(CHIP)-M2_DN_5_R)+!(AREA(M2x)/AREA(CHIP)-M2_DN_5_R)]


  X NOT excludeRRuleRecommended    
}


#ENDIF
#ENDIF
#ENDIF

#IFNDEF FULL_CHIP
#IFDEF CHECK_M2DN6_
#IFDEF _M2DN6_
#IFDEF CHECK_LOW_DENSITY
RR:RE:M2.DN.6 { @ Recommend metal Density >= ^M2_DN_6_R for IP level. Item(A) to Item(C) are recommended.
@ (A) For IP level, recommend metal density [checking window ^M2_DN_6_W_A_R um x ^M2_DN_6_W_A_R um, stepping ^M2_DN_6_S_A_R um] >= ^M2_DN_6_R
@ (B) For IP level, recommend maximum area of merged low density windows [checking window ^M2_DN_6_W_BC_R um x ^M2_DN_6_W_BC_R um, stepping ^M2_DN_6_S_BC_R um, density < ^M2_DN_6_R] <= ^M2_DN_6_A_B_R um2. Merged low density windows width <= ^M2_DN_6_U_R um is excepted.
@ (C) For IP level, recommend maximum area of merged low density windows [checking window ^M2_DN_6_W_BC_R um x ^M2_DN_6_W_BC_R um, stepping ^M2_DN_6_S_BC_R um, density < ^M2_DN_6_R] <= ^M2_DN_6_A_C_R um2
@ 1. The following special regions are excluded
@    Chip corner triangle empty areas if sealring is added by tsmc. 
@    LOWMEDN
@ 2. This rule is applied while the width of (checking window NOT above excluding region) >= ^M2_DN_6_E_A_R um for (A) and >= ^M2_DN_6_E_BC_R um for both (B)/(C) 
  M2_CHECK = M2x NOT (NEW_DEN_EXC OR ICOVL)
  CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
  // Condition-A
  ERR_WIN_A = DENSITY M2_CHECK CHIP_CHECK < M2_DN_6_R WINDOW M2_DN_6_W_A_R STEP M2_DN_6_S_A_R INSIDE OF LAYER CHIP_M2 BACKUP 
	[ AREA(M2_CHECK)/AREA(CHIP_CHECK) ]
  F_A = WITH WIDTH (ERR_WIN_A NOT (NEW_DEN_EXC OR ICOVL)) >= M2_DN_6_E_A_R
  X = DENSITY F_A M2_CHECK CHIP_CHECK < M2_DN_6_R WINDOW M2_DN_6_W_A_R STEP M2_DN_6_S_A_R INSIDE OF LAYER CHIP_M2 BACKUP PRINT M2.DN.6R_A.density
         [ !AREA(F_A)+AREA(M2_CHECK)/AREA(CHIP_CHECK) ]
  X NOT excludeRRuleRecommended	 
  // Condition-B 
  ERR_WIN_B = DENSITY M2_CHECK CHIP_CHECK < M2_DN_6_R WINDOW M2_DN_6_W_BC_R STEP M2_DN_6_S_BC_R INSIDE OF LAYER CHIP_M2 BACKUP 
	[ AREA(M2_CHECK)/AREA(CHIP_CHECK) ]
  F_B = WITH WIDTH (ERR_WIN_B NOT (NEW_DEN_EXC OR ICOVL)) >= M2_DN_6_E_BC_R
  A = DENSITY F_B M2_CHECK CHIP_CHECK < M2_DN_6_R WINDOW M2_DN_6_W_BC_R STEP M2_DN_6_S_BC_R INSIDE OF LAYER CHIP_M2 BACKUP PRINT M2.DN.6R_BC.density
         [ !AREA(F_B)+AREA(M2_CHECK)/AREA(CHIP_CHECK) ]
  B = AREA A > M2_DN_6_A_B_R
  C = SIZE B BY M2_DN_6_U_R/2 UNDEROVER
  (B INTERACT C) NOT excludeRRuleRecommended
  // Condition-C
  (AREA B > M2_DN_6_A_C_R) NOT excludeRRuleRecommended 
}
#ENDIF
#ENDIF
#ENDIF
#ENDIF //FULL_CHIP





#IFDEF CHECK_M3DN2_
