#IFDEF DBOC
PADi = CB1i NOT EMPTYi
PADj = CB1j NOT EMPTYi 
PADu = CB1u NOT EMPTYi 
#ELSE
#IFDEF WLCSP
PADi = PM2i NOT EMPTYi
PADj = PM2j NOT EMPTYi
PADu = PM2u NOT EMPTYi
#ELSE
#IFDEF WIRE_BOND
#IFDEF WITH_APRDL
PADi = CB2i NOT EMPTYi
PADj = CB2j NOT EMPTYi
PADu = CB2u NOT EMPTYi
#ELSE
PADi = CB1i NOT EMPTYi
PADj = CB1j NOT EMPTYi
PADu = CB1u NOT EMPTYi
#ENDIF
#ELSE // FLIP_CHIP
PADi = CB2i NOT EMPTYi
PADj = CB2j NOT EMPTYi
PADu = CB2u NOT EMPTYi
#ENDIF
#ENDIF
#ENDIF



GATEu  = STAMP GATEi BY POu
NSDu_g = NSDu INTERACT POu 
PSDu_g = PSDu INTERACT POu 

PSTPix = PSTPi NOT INSIDE RWi
//PSTPix = PSTPi NOT EMPTYi

VOL_12  = OD12i OR OD1812
VOL_15  = (OD15i NOT OD1518) OR OD1815
VOL_18  = (OD18i NOT (OD1815 OR OD1812)) OR (OD1518 OR OD2518)

SD_00_12   = SD NOT (OD2i NOT VOL_12)					// 0V ~1.2V
SD_13_17   = SD NOT ((OD2i NOT VOL_15) OR SD_00_12)			// 1.3V ~1.7V
SD_18_25   = SD AND ((((((((OD18i OR OD25i) OR OD1518) NOT OD2533) NOT OD1815) NOT OD1812) NOT OD2528) NOT HVD) NOT HVD_65)// 1.8V ~2.5V 
SD_33_33   = SD AND ((OD33i OR OD2533) OR OD2528)					// 3.3V ~3.3V 
SD_50      = SD AND HVD
SD_65      = SD AND HVD_65
SD_18_33   = SD_18_25 OR SD_33_33					// 1.8V ~3.3V
SD_12_33   = SD AND ((OD2i NOT (HVD OR HVD_65)) OR VOL_12)
SD_00_11   = SD NOT (OD2i OR OD12i)

GATE_00_12 = STAMP (GATE NOT (OD2i NOT VOL_12)) BY ILP1i
GATE_13_17 = STAMP (GATE NOT ((OD2i NOT VOL_15) OR GATE_00_12)) BY ILP1i
GATE_18_25 = STAMP (GATE AND ((((((OD18i OR OD25i) OR OD1518) NOT OD2533) NOT OD1815) NOT OD1812) NOT OD2528)) BY ILP1i 
GATE_33_33 = STAMP (GATE AND ((OD33i OR OD2533) OR OD2528)) BY ILP1i 
GATE_18_33 = STAMP (GATE AND ((OD2i NOT VOL_15) NOT VOL_12)) BY ILP1i
GATE_12_33 = STAMP (GATE AND ((OD2i NOT (HVD OR HVD_65)) OR VOL_12)) BY ILP1i

GATE_00_11 = STAMP (GATE NOT (OD2i OR OD12i)) BY ILP1i
GATE_12_16 = GATE_12_33 NOT GATE_18_33
PSD_00_12   = STAMP (SD_00_12 INTERACT PSDc == 1 BY NET) BY PSDc
PSD_13_17   = STAMP (SD_13_17 INTERACT PSDc == 1 BY NET) BY PSDc
PSD_18_25   = STAMP (SD_18_25 INTERACT PSDc == 1 BY NET) BY PSDc
PSD_33_33   = STAMP (SD_33_33 INTERACT PSDc == 1 BY NET) BY PSDc
PSD_18_33   = STAMP (SD_18_33 INTERACT PSDc == 1 BY NET) BY PSDc
PSD_12_33   = STAMP (SD_12_33 INTERACT PSDc == 1 BY NET) BY PSDc
PSD_00_11   = STAMP (SD_00_11 INTERACT PSDc == 1 BY NET) BY PSDc
PSD_12_16   = PSD_12_33 NOT PSD_18_33
PSD_50      = STAMP (SD_50 INTERACT PSDc == 1 BY NET) BY PSDc
PSD_65      = STAMP (SD_65 INTERACT PSDc == 1 BY NET) BY PSDc

NSD_00_12   = STAMP (SD_00_12 INTERACT NSDc == 1 BY NET) BY NSDc
NSD_13_17   = STAMP (SD_13_17 INTERACT NSDc == 1 BY NET) BY NSDc
NSD_18_25   = STAMP (SD_18_25 INTERACT NSDc == 1 BY NET) BY NSDc
NSD_33_33   = STAMP (SD_33_33 INTERACT NSDc == 1 BY NET) BY NSDc
NSD_18_33   = STAMP (SD_18_33 INTERACT NSDc == 1 BY NET) BY NSDc
NSD_12_33   = STAMP (SD_12_33 INTERACT NSDc == 1 BY NET) BY NSDc
NSD_00_11   = STAMP (SD_00_11 INTERACT NSDc == 1 BY NET) BY NSDc
NSD_12_16   = NSD_12_33 NOT NSD_18_33
NSD_50      = STAMP (SD_50 INTERACT NSDc == 1 BY NET) BY NSDc
NSD_65      = STAMP (SD_65 INTERACT NSDc == 1 BY NET) BY NSDc

M1_VNV	= STAMP (M1_N0D6N1D2Vi AND M1i) BY M1i
M1_NV	= STAMP (M1_N0D1N0D5Vi AND M1i) BY M1i
M1_LV	= STAMP (M1_0D01D2Vi AND M1i) BY M1i
M1_MLV	= STAMP (M1_1D31D7Vi AND M1i) BY M1i
M1_MV	= STAMP (M1_1D82D5Vi AND M1i) BY M1i
M1_HV	= STAMP (M1_3D3Vi AND M1i) BY M1i
M1_HV_5V = STAMP (M1_5D0Vi AND M1i) BY M1i
M1_HV_65V = STAMP ((M1_6D5Vi OR M1_5D5Vi) AND M1i) BY M1i
M1_HV_1233V = M1i AND M1_1D23D3Vi
M1_LV_0011V = M1i AND M1_0D01D1Vi
M1_MV_1216V = M1i AND M1_1D21D6Vi
M1_HV_1733V = M1i AND M1_1D73D3Vi

M2_VNV	= STAMP (M2_N0D6N1D2Vi AND M2i) BY M2i
M2_NV	= STAMP (M2_N0D1N0D5Vi AND M2i) BY M2i
