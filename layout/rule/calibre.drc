#IFDEF CHECK_COS8_
#IFDEF _COS8_
COS8_ODCellIn = INSIDE CELL ODi CellsForRRuleGuideline  
COS8_ODCellOut = NOT INSIDE CELL ODi ExclCellsForRRuleGuideline 
COS8_ODCell = COS8_ODCellIn AND COS8_ODCellOut
COS8_ODMarker = ODi AND RRuleGuideline
COS8_OD = ((( COS8_ODCell OR COS8_ODMarker ) NOT INSIDE SRAM_EXCLUDE ) OUTSIDE Block) NOT excludeRRuleGuideline

RR:GL:CO.S.8 { @ Recommended to put contacts at both source side and butted well pickup side to avoid high Rs. DRC can flag if the STRAP is butted on source, one of STRAP and source is without CO   
  BUTT_SOUR = SD INTERACT (BUTT_PSTP OR BUTT_NSTP)
  (BUTT_PSTP INTERACT COS8_OD ) NOT INTERACT COi
  (BUTT_NSTP INTERACT COS8_OD ) NOT INTERACT COi
  (BUTT_SOUR INTERACT COS8_OD ) NOT INTERACT COi
}
#ENDIF
#ENDIF
// CO.S.8g is checked by RR:GL:CO.S.8

#IFDEF CHECK_COR6_
