#IFDEF VOLTAGE_RULE_CHECK




DV_SYNC.S.1 { @ Space of POV_sync to OD > 0 
    EXT POV_sync OD < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.S.1.1 { @ Space of POV_sync to {PO NOT {CPO OR CPO_SRM}} > 0 
  A = POLY NOT (CPO OR CPO_SRM)
    EXT POV_sync A < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.S.2:M1 { @ Space of MnV_sync to Mn (n = 1~Mtop) > 0 
    EXT M1V_sync M1i < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.S.2:M2 { @ Space of MnV_sync to Mn (n = 1~Mtop) > 0 
    EXT M2V_sync M2i < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.S.2:M3 { @ Space of MnV_sync to Mn (n = 1~Mtop) > 0 
    EXT M3V_sync M3i < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.S.2:M4 { @ Space of MnV_sync to Mn (n = 1~Mtop) > 0 
    EXT M4V_sync M4i < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.S.2:M5 { @ Space of MnV_sync to Mn (n = 1~Mtop) > 0 
    EXT M5V_sync M5i < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.S.2:M6 { @ Space of MnV_sync to Mn (n = 1~Mtop) > 0 
    EXT M6V_sync M6i < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.S.2:M7 { @ Space of MnV_sync to Mn (n = 1~Mtop) > 0 
    EXT M7V_sync M7i < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.S.2:M8 { @ Space of MnV_sync to Mn (n = 1~Mtop) > 0 
    EXT M8V_sync M8i < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.S.2:M9 { @ Space of MnV_sync to Mn (n = 1~Mtop) > 0 
    EXT M9V_sync M9i < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.S.3 { @ Space of APV_sync to AP > 0 
    EXT APV_sync AP < GRID ABUT < 90 SINGULAR REGION 
}
DV_SYNC.R.1 { @ The number of {OD OR {PO NOT {CPO OR CPO_SRM}}} [interact the same POV_sync] must be >= 2   
    A = OD OR (POLY NOT (CPO OR CPO_SRM))
    POV_sync NOT INTERACT A >= 2
}
DV_SYNC.R.2:M1 { @ The number of Mn [interact the same MnV_sync] must be >= 2 (n = 1~Mtop)   
    M1V_sync NOT INTERACT M1i >= 2
}
DV_SYNC.R.2:M2 { @ The number of Mn [interact the same MnV_sync] must be >= 2 (n = 1~Mtop)   
    M2V_sync NOT INTERACT M2i >= 2
}
DV_SYNC.R.2:M3 { @ The number of Mn [interact the same MnV_sync] must be >= 2 (n = 1~Mtop)   
    M3V_sync NOT INTERACT M3i >= 2
}
DV_SYNC.R.2:M4 { @ The number of Mn [interact the same MnV_sync] must be >= 2 (n = 1~Mtop)   
    M4V_sync NOT INTERACT M4i >= 2
}
DV_SYNC.R.2:M5 { @ The number of Mn [interact the same MnV_sync] must be >= 2 (n = 1~Mtop)   
    M5V_sync NOT INTERACT M5i >= 2
}
DV_SYNC.R.2:M6 { @ The number of Mn [interact the same MnV_sync] must be >= 2 (n = 1~Mtop)   
    M6V_sync NOT INTERACT M6i >= 2
}
DV_SYNC.R.2:M7 { @ The number of Mn [interact the same MnV_sync] must be >= 2 (n = 1~Mtop)   
    M7V_sync NOT INTERACT M7i >= 2
}
DV_SYNC.R.2:M8 { @ The number of Mn [interact the same MnV_sync] must be >= 2 (n = 1~Mtop)   
    M8V_sync NOT INTERACT M8i >= 2
}
DV_SYNC.R.2:M9 { @ The number of Mn [interact the same MnV_sync] must be >= 2 (n = 1~Mtop)   
    M9V_sync NOT INTERACT M9i >= 2
}
DV_SYNC.R.3 { @ The number of AP [interact the same APV_sync] must be >= 2   
    APV_sync NOT INTERACT AP >= 2
}
DV_SYNC.R.4 { @ {POV_sync INTERACT {OD AND {RPO OR RPDMY}}} is not allowed   
    POV_sync INTERACT (OD AND RPO_RPDMY)
}
DV_SYNC.R.5 { @ {POV_sync INTERACT {PO AND {RPO OR RPDMY}}} is not allowed   
    POV_sync INTERACT (POLY AND RPO_RPDMY)
}
DV_SYNC.R.6 { @ {POV_sync INTERACT GATE} is not allowed   
    POV_sync INTERACT GATE
}
DV_SYNC.R.7 { @ {POV_sync INTERACT {PO AND {CPO OR CPO_SRM}}} is not allowed   
    POV_sync INTERACT (POLY AND (CPO OR CPO_SRM))
}
DV_SYNC.R.8 { @ {POV_sync INTERACT {OD INTERACT {NW INTERACT NWDMY}}} is not allowed   
    POV_sync INTERACT (OD INTERACT (NWEL INTERACT NWDMY))
}
// OD Delta V CHECKS
//==================
#IFDEF FULL_CHIP
DV.R.1 { @ Voltage text layer or voltage marker layer must exist in chip level. DRC flags no voltage text layer or voltage marker layer in GDS   

  MERGE (CHIP NOT INTERACT VOLTAGE_TEXT_MARKER)
}
#ENDIF
#IFDEF FRONT_END




VARIABLE  OD_R_2_V 6.500
VARIABLE  OD_R_2 2.500
OD.R.2 { @ Maximum delta V > 6.5V is not allowed DRC searching range of OD space to OD is < 2.5 um   
  err_1 = DFM DV ODc_edge  < OD_R_2 ABUT < 90  NOT CONNECTED  
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > OD_R_2_V   ANNOTATE
  err_1_f =  DFM PROPERTY err_1 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_1, "SECOND_VMAX")]
  [ DELTA_V = property(err_1, "DELTA_V")]
  [ SYNC = property(err_1, "SYNC")]  
  DFM COPY err_1_f
  DFM RDB err_1_f "OD.R.2.rep" NOEMPTY NOPSEUDO

}

VARIABLE  OD_R_2_1_V 5
VARIABLE  OD_R_2_1 2.500
OD.R.2.1 { @ Maximum delta V > 5V is not allowed (Except OD2) DRC searching range of OD space to OD is < 2.5 um   
  err_1 = DFM DV ODc_edge  < OD_R_2_1 ABUT < 90  NOT CONNECTED  
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > OD_R_2_1_V   ANNOTATE
  err_1_f =  DFM PROPERTY err_1 OD2 OVERLAP ABUT ALSO MULTI
  [ -= COUNT(OD2) ] == 0
  [ FIRST_VMIN = property(err_1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_1, "SECOND_VMAX")]
  [ DELTA_V = property(err_1, "DELTA_V")]
  [ SYNC = property(err_1, "SYNC")]  
  DFM COPY err_1_f
  DFM RDB err_1_f "OD.R.2.1.rep" NOEMPTY NOPSEUDO

}



