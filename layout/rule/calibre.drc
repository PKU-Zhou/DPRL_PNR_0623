VARIABLE  CO_R_5_V 6.500
CO.R.5 { @ CO [connects to >= 6.5V net] outside OD2 is not allowed   

    M1_HV_65V_ALL_CO_R_5_pre = DFM PROPERTY M1n NET_PROP_LAYER NODAL MULTI 
    [ AV = FMAX(ABS(property(NET_PROP_LAYER,"Volt_High")), ABS(property(NET_PROP_LAYER,"Volt_Low")))] >= CO_R_5_V
    M1_HV_65V_ALL_CO_R_5 = NET AREA RATIO M1i M1_HV_65V_ALL_CO_R_5_pre  > 0
            err_1a_L1 = (M1_HV_65V_ALL_CO_R_5 AND CO) NOT OD2
    CMACRO VOLTAGE_ANNOTATE_2 err_1a_L1 NET_PROP_LAYER err_1a_L1_V
            DFM COPY err_1a_L1_V
            DFM RDB err_1a_L1_V "CO.R.5.rep" NOEMPTY NOPSEUDO

} 

