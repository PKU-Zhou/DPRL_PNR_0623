#IFDEF CHECK_ODW1_
#IFDEF _ODW1_
ODW1_ODCellIn = INSIDE CELL ODi CellsForRRuleRecommended  
ODW1_ODCellOut = NOT INSIDE CELL ODi ExclCellsForRRuleRecommended 
ODW1_ODCell = ODW1_ODCellIn AND ODW1_ODCellOut
ODW1_ODMarker = ODi AND RRuleRecommended
ODW1_OD = ((( ODW1_ODCell OR ODW1_ODMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:OD.W.1 { @ Recommended minimum interconnect OD width >= 0.065 
  A = (ODW1_OD NOT POi) NOT TCDDMY
  (INT A < OD_W_1_R ABUT < 90 SINGULAR REGION) NOT MOMDMY
}
#ENDIF
#ENDIF

#IFDEF CHECK_ODS1_
#IFDEF _ODS1_
ODS1_ODCellIn = INSIDE CELL ODi CellsForRRuleRecommended  
ODS1_ODCellOut = NOT INSIDE CELL ODi ExclCellsForRRuleRecommended 
ODS1_ODCell = ODS1_ODCellIn AND ODS1_ODCellOut
ODS1_ODMarker = ODi AND RRuleRecommended
ODS1_OD = ((( ODS1_ODCell OR ODS1_ODMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended


RR:RE:OD.S.1 { @ Recommended minimum OD space to reduce the short possibility caused by particle >= 0.08 
  (EXT ODS1_OD < OD_S_1_R ABUT < 90 REGION SINGULAR) NOT INSIDE TCDDMY
}

#ENDIF
#ENDIF

#IFDEF CHECK_ODS8_
#IFDEF _ODS8_
ODS8_POLYCellIn = INSIDE CELL POi CellsForRRuleRecommended  
ODS8_POLYCellOut = NOT INSIDE CELL POi ExclCellsForRRuleRecommended 
ODS8_POLYCell = ODS8_POLYCellIn AND ODS8_POLYCellOut
ODS8_POLYMarker = POi AND RRuleRecommended
ODS8_POLY = ((( ODS8_POLYCell OR ODS8_POLYMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:OD.S.8 { @ Recommended maximum space of LAST GATE [in core device] to {{OD OR SR_DOD} OR DOD} in S/D direction, it's allowed the violation with length ratio < 10% [The length ratio = (violation length) / (the LAST GATE channel width)] [The "violation length" can be shielded by {{PO OR SR_DPO} AND OD}] [DRC only checked the LAST GATE with < 0.5 um OD extension] <= 1.1 
  POLY_CHK = (ODS8_POLY AND OD) NOT INSIDE OD2
  POLY_EDGE = ENC [POLY_CHK] OD < OD_S_8_S_R EXCLUDE SHIELDED 4 OPPOSITE
  GATE_W_LAST = GATE_W TOUCH EDGE POLY_EDGE
  
  GOOD_EDGE_PROJECT_OD = EXT [GATE_W_LAST] ALL_OD <= OD_S_8_R OPPOSITE MEASURE ALL
  GOOD_EDGE_SHIELDED_GATE = EXT [GATE_W_LAST] SRPO_GATE <= PO_S_10 OPPOSITE
  GOOD_EDGE = OR EDGE GOOD_EDGE_PROJECT_OD GOOD_EDGE_SHIELDED_GATE

  BAD_EDGE = DFM PROPERTY GATE_W_LAST GOOD_EDGE OVERLAP ABUT ALSO MULTI
  [ -= LENGTH(GOOD_EDGE) / (LENGTH(GATE_W_LAST))] <= (1-OD_S_8_R_R)
  (BAD_EDGE NOT COIN INSIDE EDGE GOOD_EDGE) NOT INSIDE EDGE TCDDMY
}
#ENDIF
#ENDIF

#IFDEF CHECK_ODS9_
#IFDEF _ODS9_
ODS9_ODCellIn = INSIDE CELL ODi CellsForRRuleRecommended  
ODS9_ODCellOut = NOT INSIDE CELL ODi ExclCellsForRRuleRecommended 
ODS9_ODCell = ODS9_ODCellIn AND ODS9_ODCellOut
ODS9_ODMarker = ODi AND RRuleRecommended
ODS9_OD = ((( ODS9_ODCell OR ODS9_ODMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:OD.S.9 { @ Recommended OD space to {OD INTERACT PO} [channel width <= 0.6 um] in PO ENDCAP direction >= 0.12 
  OD_CHK_CAP_E = (ODS9_OD INTERACT POLY) TOUCH EDGE GATE_L
  OD_CHK_CAP_EC =  OD_CHK_CAP_E TOUCH EDGE (GATE WITH EDGE (LENGTH GATE_W <= OD_S_9_R_W))
  EXT ODS9_OD OD_CHK_CAP_EC < OD_S_9_R ABUT < 90 REGION
}
#ENDIF
#ENDIF

#IFDEF CHECK_ODS20_
#IFDEF _ODS20_
ODS20_ODCellIn = INSIDE CELL ODi CellsForRRuleRecommended  
ODS20_ODCellOut = NOT INSIDE CELL ODi ExclCellsForRRuleRecommended 
ODS20_ODCell = ODS20_ODCellIn AND ODS20_ODCellOut
ODS20_ODMarker = ODi AND RRuleRecommended
ODS20_OD = ((( ODS20_ODCell OR ODS20_ODMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:OD.S.20 { @ Recommended forbidden core "effective device head space" in channel length direction. "Effective device head space region" is defined as space region above gate between {{OD OR DOD} OR SR_DOD} in direction perpendicular to ENDCAP direction. The DRC doesn't flag the region when (1) butting to any OD in ENDCAP direction (2) space to Gate >= 0.3 um or <= 0.08 um in ENDCAP direction (3) width <= 0.1 um in ENDCAP direction = 0.455~1.795 
  OD_CHK = ALL_OD NOT INSIDE (SIZE OD2 BY -OD_S_20_SB_R)    // Check core OD only
  OD_CHK_V = OD_CHK ANGLE == 90
  OD_CHK_H = OD_CHK ANGLE == 0
  
  BAD_SPACE_REGION1_V = EXT OD_CHK OD_CHK_V < OD_S_20_SB_R > OD_S_20_SA_R ABUT < 90 EXCLUDE SHIELDED 4 OPPOSITE SPACE REGION
  OD_CHK_EDGE_L_H = OD_CHK_H TOUCH EDGE (LV_GATE_L TOUCH EDGE ODS20_OD)
  BAD_SPACE_REGION2_V_pre = BAD_SPACE_REGION1_V NOT WITH EDGE OD_CHK_H  
  BAD_SPACE_REGION2_V = BAD_SPACE_REGION2_V_pre WITH WIDTH  > OD_S_20_H_R
  BAD_SPACE_REGION2_effEDGE_V = LENGTH (EXT [BAD_SPACE_REGION2_V] OD_CHK_EDGE_L_H > OD_S_20_SD_R < OD_S_20_SC_R ABUT < 90 OPPOSITE) > OD_S_20_SA_R  
  BAD_SPACE_REGION2_V WITH EDGE BAD_SPACE_REGION2_effEDGE_V

  BAD_SPACE_REGION1_H = EXT OD_CHK OD_CHK_H < OD_S_20_SB_R > OD_S_20_SA_R ABUT < 90 EXCLUDE SHIELDED 4 OPPOSITE SPACE REGION
  OD_CHK_EDGE_L_V = OD_CHK_V TOUCH EDGE (LV_GATE_L TOUCH EDGE ODS20_OD)
  BAD_SPACE_REGION2_H_pre = BAD_SPACE_REGION1_H NOT WITH EDGE (OR EDGE OD_CHK_EDGE_L_V OD_CHK_V)
  BAD_SPACE_REGION2_H = BAD_SPACE_REGION2_H_pre WITH WIDTH > OD_S_20_H_R
  BAD_SPACE_REGION2_effEDGE_H = LENGTH (EXT [BAD_SPACE_REGION2_H] OD_CHK_EDGE_L_V > OD_S_20_SD_R < OD_S_20_SC_R ABUT < 90 OPPOSITE) > OD_S_20_SA_R  
  BAD_SPACE_REGION2_H WITH EDGE BAD_SPACE_REGION2_effEDGE_H  
}
#ENDIF
#ENDIF

#IFDEF CHECK_ODA7_
#IFDEF _ODA7_
RR:RE:OD.A.7 { @ In order to reduce the gap between Si and SPICE for the core MOS, recommended the maximum area of merged {{OD OR SR_DOD} OR DOD} high density windows [checking window 10 um x 10 um, stepping 5 um, density >= 55%] Warming: > 3% offset will be occurred if core MOS is placed near OD.A.7.R violated region. If the offset is adopted, you can bypass this warning <= 40000 
   A = DENSITY ALL_OD >= OD_A_7_R_DN INSIDE OF LAYER CHIPx WINDOW 10 STEP 5 BACKUP PRINT OD.A.7.R.density RDB OD.A.7.R.rep
   MERGE (AREA A > OD_A_7_R)  
}
#ENDIF
#ENDIF

#IFDEF CHECK_DNWEN2_
#IFDEF _DNWEN2_
DNWEN2_DNWCellIn = INSIDE CELL DNWi CellsForRRuleRecommended  
DNWEN2_DNWCellOut = NOT INSIDE CELL DNWi ExclCellsForRRuleRecommended 
DNWEN2_DNWCell = DNWEN2_DNWCellIn AND DNWEN2_DNWCellOut
DNWEN2_DNWMarker = DNWi AND RRuleRecommended
DNWEN2_DNW = ((( DNWEN2_DNWCell OR DNWEN2_DNWMarker ) NOT INSIDE SRAM_EXCLUDE ) OUTSIDE Block) NOT excludeRRuleRecommended

RR:RE:DNW.EN.2 { @ Recommended enclosure by NW for better noise isolation >= 1 
  ENC DNWEN2_DNW NWEL < DNW_EN_2_R ABUT < 90 SINGULAR REGION 
  DNWEN2_DNW OUTSIDE EDGE NWEL
}
#ENDIF
#ENDIF

#IFDEF CHECK_NWRODS3_
#IFDEF _NWRODS3_
NWRODS3_NWCellIn = INSIDE CELL NWii CellsForRRuleRecommended  
NWRODS3_NWCellOut = NOT INSIDE CELL NWii ExclCellsForRRuleRecommended 
NWRODS3_NWCell = NWRODS3_NWCellIn AND NWRODS3_NWCellOut
NWRODS3_NWMarker = NWii AND RRuleRecommended
NWRODS3_NW = ((( NWRODS3_NWCell OR NWRODS3_NWMarker ) NOT INSIDE SRAM_EXCLUDE ) OUTSIDE Block) NOT excludeRRuleRecommended

RR:RE:NWROD.S.3 { @ Recommended RPO space to CO in NW resistor within OD for SPICE simulation accuracy = 0.3 
  A = RPO INSIDE EDGE ( NWRES AND NWRODS3_NW ) 
  B = EXPAND EDGE A OUTSIDE BY NWROD_S_3_R
  B AND COWR 
  B NOT INTERACT COWR
}
#ENDIF
#ENDIF

#IFDEF CHECK_NWRSTIEN2_
#IFDEF _NWRSTIEN2_
NWRSTIEN2_NWCellIn = INSIDE CELL NWii CellsForRRuleRecommended  
NWRSTIEN2_NWCellOut = NOT INSIDE CELL NWii ExclCellsForRRuleRecommended 
NWRSTIEN2_NWCell = NWRSTIEN2_NWCellIn AND NWRSTIEN2_NWCellOut
NWRSTIEN2_NWMarker = NWii AND RRuleRecommended
NWRSTIEN2_NW = ((( NWRSTIEN2_NWCell OR NWRSTIEN2_NWMarker ) NOT INSIDE SRAM_EXCLUDE ) OUTSIDE Block) NOT excludeRRuleRecommended

RR:RE:NWRSTI.EN.2 { @ Recommended OD enclosure of CO in NW resistor under STI for SPICE simulation accuracy = 0.3 
  A = OD INSIDE EDGE ( NWRES_STI AND NWRSTIEN2_NW ) 
  B = EXPAND EDGE A INSIDE BY NWRSTI_EN_2_R
  B NOT INTERACT COWR_STI
}
#ENDIF
#ENDIF

#IFDEF CHECK_SRESDR4_
#IFDEF _SRESDR4_
// 'SR_ESD.R.4.R' is checked by RR:RE:SRESD.R.4
RR:RE:SRESD.R.4 { @ {N/PMOS INTERACT SDI} should be covered by SR_ESD. Without SR_ESD, special SR_ESD rules will not be checked   
  ACT_CHK = DACT INTERACT (GATE_PP OR GATE_NP)
	((OR GATE_PP GATE_NP ACT_CHK) INTERACT SDI) NOT SRESD
}
#ENDIF
#ENDIF

#IFDEF CHECK_POEX1_
#IFDEF _POEX1_
POEX1_ODCellIn = INSIDE CELL ODi CellsForRRuleRecommended  
POEX1_ODCellOut = NOT INSIDE CELL ODi ExclCellsForRRuleRecommended 
POEX1_ODCell = POEX1_ODCellIn AND POEX1_ODCellOut
POEX1_ODMarker = ODi AND RRuleRecommended
POEX1_OD = ((( POEX1_ODCell OR POEX1_ODMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:PO.EX.1 { @ Recommended extension on OD (ENDCAP) to avoid line-end shortening >= 0.1 
  (ENC POEX1_OD POLY < PO_EX_1_R ABUT < 90 OPPOSITE SINGULAR REGION) NOT INSIDE (LOGO OR TCDDMY)
}
#ENDIF
#ENDIF


#IFDEF CHECK_POA3_
#IFDEF _POA3_
POA3_POCellIn = INSIDE CELL POi CellsForRRuleRecommended  
POA3_POCellOut = NOT INSIDE CELL POi ExclCellsForRRuleRecommended 
POA3_POCell = POA3_POCellIn AND POA3_POCellOut
POA3_POMarker = POi AND RRuleRecommended
POA3_PO = ((POA3_POCell OR POA3_POMarker) NOT Block ) NOT excludeRRuleRecommended

POA3_SRDPOCellIn = INSIDE CELL SRDPO CellsForRRuleRecommended  
POA3_SRDPOCellOut = NOT INSIDE CELL SRDPO ExclCellsForRRuleRecommended 
POA3_SRDPOCell = POA3_SRDPOCellIn AND POA3_SRDPOCellOut
POA3_SRDPOMarker = SRDPO AND RRuleRecommended
POA3_SRDPO = ((POA3_SRDPOCell OR POA3_SRDPOMarker) NOT Block ) NOT excludeRRuleRecommended

POA3_DPOCellIn = INSIDE CELL DPO CellsForRRuleRecommended  
POA3_DPOCellOut = NOT INSIDE CELL DPO ExclCellsForRRuleRecommended 
POA3_DPOCell = POA3_DPOCellIn AND POA3_DPOCellOut
POA3_DPOMarker = DPO AND RRuleRecommended
POA3_DPO = ((POA3_DPOCell OR POA3_DPOMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:PO.A.3 { @ Recommended area of {{{PO OR SR_DPO} OR DPO} NOT CPO} This check doesn't include 1. {{{PO OR SR_DPO} INTERACT RPO} AND RH_PO}, {SR_DPO AND RH_OD}, and BJTDMY 2. {{{PO OR SR_DPO} OR DPO} NOT CPO} [width <= 0.035 um] NOT INTERACT "High Density Region" 3. {{{PO OR SR_DPO} OR DPO} NOT CPO} [width = 0.1 um ~ 0.3 um, length <= 30 um] NOT INTERACT "High Density Region" Definition of "High Density Region": Poly density [10 um x 10 um window, stepping 5 um] inside {{{{PO OR SR_DPO} OR DPO} NOT CPO} [(width <= 0.035 um and area > 2 um2) or (width = 0.1 um ~ 0.3 um, length <= 30 um, and area > 2 um2)] SIZING 5 um} is > 50% <= 2 
  PO_A3_EXC = (((SR_POLY INTERACT RPO) AND RHPO) OR (SRDPO AND RHOD)) OR (BJTDMY OR SRAM_WAIVE_N28)
  BIG_PO = AREA (ALL_POLY NOT PO_A3_EXC) > PO_A_3_R

  THIN_BIG_PO = BIG_PO WITH WIDTH <= PO_A_3_W1
  WIDE_SHORT_BIG_PO = NOT ENCLOSE RECTANGLE (BIG_PO WITH WIDTH >= PO_A_3_W2 <= PO_A_3_W3) GRID PO_A_3_L1+GRID
  BIG_PO_PRE = THIN_BIG_PO OR WIDE_SHORT_BIG_PO

  HIGH_DEN_REG_pre0 =DENSITY ALL_POLY CHIP > PO_A_3_DN WINDOW PO_A_3_W STEP 1 BACKUP INSIDE OF LAYER CHIPx
  [ AREA(ALL_POLY)/AREA(CHIP) ]
  DEN_CHK_REG = SIZE (BIG_PO_PRE INTERACT HIGH_DEN_REG_pre0) BY PO_A_3_S2
  PODN_CHK = ALL_POLY AND DEN_CHK_REG
  DEN_CHK_REG_CHK = COPY DEN_CHK_REG
  HIGH_DEN_REG_pre = DENSITY ALL_POLY DEN_CHK_REG_CHK > PO_A_3_DN WINDOW PO_A_3_W STEP 1 INSIDE OF LAYER DEN_CHK_REG BACKUP 
   [!(AREA()-AREA(DEN_CHK_REG_CHK))*AREA(ALL_POLY)/AREA()]
  DEN_CHK_REG2 = DEN_CHK_REG INTERACT HIGH_DEN_REG_pre 
  HIGH_DEN_REG = DENSITY  HIGH_DEN_REG_pre ALL_POLY PODN_CHK DEN_CHK_REG_CHK > PO_A_3_DN WINDOW PO_A_3_W STEP PO_A_3_S INSIDE OF LAYER DEN_CHK_REG2 BACKUP PRINT PO.A.3.R.density RDB PO.A.3.R.RDB.density
  [AREA(PODN_CHK)/AREA(DEN_CHK_REG_CHK)*!~(AREA(ALL_POLY)/AREA()-PO_A_3_DN)*!!AREA(HIGH_DEN_REG_pre)]
  
  GOOD_PO = BIG_PO_PRE NOT INTERACT HIGH_DEN_REG
  (BIG_PO NOT GOOD_PO) INTERACT ((POA3_PO OR POA3_SRDPO) OR POA3_DPO)
}
#ENDIF
#ENDIF

#IFDEF CHECK_LOW_DENSITY

#IFDEF CHECK_PODN3_
#IFDEF _PODN3_
RR:RE:PO.DN.3 { @ Recommended minimum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1. PO.DN.3 rule checks over any 20 um x 20 um area, stepping 10 um. 2. For PO.DN.3 rule, the following regions can be excluded: (1) {Chip corner triangle empty areas SIZING 1 um} if sealring is added by tsmc. (2) {SEALRING_ALL SIZING 1 um} if sealring is added by customer. (3) ICOVL 3. The rule is applied while width of (checking window NOT ((item 2 SIZING 2.5 um) SIZING -2.5 um)) >= 5 um >= 15% ## Minimum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1.PO.DN.3 rules are checked over any 20 um x 20 um area. (Stepping in 10 um increments). 2.For PO.DN.3 rules, the following regions can be excluded: (1) Chip corner stress relief area if seal ring and stress relief pattern added by TSMC. 3.The rule is applied while width of (checking window NOT ((item 2 SIZING 2.5) SIZING -2.5)) >= 5 um. >= 0.1%
  EXC = SEALRING_SIZE_1 OR ICOVL
  N = ALL_POLY NOT EXC
  D = CHIP NOT EXC 
  EXC_M = SIZE EXC BY PO_DN_3_E_R/2 OVERUNDER TRUNCATE PO_DN_3_E_R/2
  A = CHIPx NOT EXC
  B1 = EXC_M NOT WITH EDGE (EXT [EXC_M] < PO_DN_3_E_R*2 SQUARE )
  B = CHIPx NOT (SIZE B1 BY PO_DN_3_E_R-0.001)
  ERR_WIN = DENSITY A B ALL_POLY CHIP N D < PO_DN_3_R WINDOW PO_DN_3_W_R STEP PO_DN_3_S_R BACKUP INSIDE OF LAYER CHIPx 
          [!AREA(B)+~(AREA(A)-PO_DN_3_E_R*PO_DN_3_E_R)*!!(AREA(A)-PO_DN_3_E_R*PO_DN_3_E_R)+AREA(N)/AREA(D)+!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_R)+!(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_R)]
  F = PUSH (WITH WIDTH (ERR_WIN NOT EXC_M) >= PO_DN_3_E_R)
  X = DENSITY A B F ALL_POLY CHIP N D < PO_DN_3_R WINDOW PO_DN_3_W_R STEP PO_DN_3_S_R BACKUP INSIDE OF LAYER CHIPx PRINT PO.DN.3R.density RDB PO.DN.3R.RDB.density
          [!AREA(F)+!AREA(B)+~(AREA(A)-PO_DN_3_E_R*PO_DN_3_E_R)*!!(AREA(A)-PO_DN_3_E_R*PO_DN_3_E_R)+AREA(N)/AREA(D)+!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_R)+!(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_R)]



  X NOT excludeRRuleRecommended
}
#ENDIF
#ENDIF

#IFDEF CHECK_PODN31_
#IFDEF _PODN31_
RR:RE:PO.DN.3.1 { @ Recommended minimum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1.PO.DN.3.1.R rule checks over any 10 um x 10 um area, stepping 5 um. 2. For PO.DN.3.1.R rule, the following regions can be excluded: (1) {Chip corner triangle empty areas SIZING 1 um} if sealring is added by tsmc. (2) {SEALRING_ALL SIZING 1 um} if sealring is added by customer. (3) INDDMY, MOMDMY, BJTDMY, RH_OD, ICOVL and {DIODMY AND OD} 3. The rule is applied while width of (checking window NOT ((item 2 SIZING 1.25 um) SIZING -1.25 um)) >= 2.5 um >= 15% 
  EXC = ((((INDDMY OR MOMDMY) OR BJTDMY) OR RHOD) OR (DIODMY AND OD)) OR (SEALRING_SIZE_1 OR ICOVL)
  N = ALL_POLY NOT EXC
  D = CHIP NOT EXC 
  EXC_M = SIZE EXC BY PO_DN_3_1_E_R/2 OVERUNDER TRUNCATE PO_DN_3_1_E_R/2
  A = CHIPx NOT EXC
  B1 = EXC_M NOT WITH EDGE (EXT [EXC_M] < PO_DN_3_1_E_R*2 SQUARE )
  B = CHIPx NOT (SIZE B1 BY PO_DN_3_1_E_R-0.001)
  ERR_WIN = DENSITY A B ALL_POLY CHIP N D < PO_DN_3_1_R WINDOW PO_DN_3_1_W_R STEP PO_DN_3_1_S_R BACKUP INSIDE OF LAYER CHIPx 
          [!AREA(B)+~(AREA(A)-PO_DN_3_1_E_R*PO_DN_3_1_E_R)*!!(AREA(A)-PO_DN_3_1_E_R*PO_DN_3_1_E_R)+AREA(N)/AREA(D)+!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_1_R)+!(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_1_R)]
  F = PUSH (WITH WIDTH (ERR_WIN NOT EXC_M) >= PO_DN_3_1_E_R)
  X = DENSITY A B F ALL_POLY CHIP N D < PO_DN_3_1_R WINDOW PO_DN_3_1_W_R STEP PO_DN_3_1_S_R BACKUP INSIDE OF LAYER CHIPx PRINT PO.DN.3.1R.density RDB PO.DN.3.1R.RDB.density
          [!AREA(F)+!AREA(B)+~(AREA(A)-PO_DN_3_1_E_R*PO_DN_3_1_E_R)*!!(AREA(A)-PO_DN_3_1_E_R*PO_DN_3_1_E_R)+AREA(N)/AREA(D)+!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_1_R)+!(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_1_R)]



  X NOT excludeRRuleRecommended
}
#ENDIF
#ENDIF

#ENDIF

#IFDEF CHECK_PODN4_
#IFDEF _PODN4_
RR:RE:PO.DN.4 { @ Recommended maximum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1. PO.DN.4.R checks over any 20 um x 20 um area, stepping 10 um. (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 55% 
  EXC = COPY ICOVL
  N = ALL_POLY NOT EXC
  D = CHIP NOT EXC 
  A = CHIPx NOT EXC
  X = DENSITY A ALL_POLY CHIP N D > PO_DN_4_R WINDOW PO_DN_4_W_R STEP PO_DN_4_S_R BACKUP INSIDE OF LAYER CHIPx PRINT PO.DN.4.R.density RDB PO.DN.4.R.RDB.density
          [~(PO_DN_4_E_R-AREA(A))*AREA(N)/AREA(D)*!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_4_R)]


  X NOT excludeRRuleRecommended
}

#ENDIF
#ENDIF



#IFDEF CHECK_PODN41_
#IFDEF _PODN41_
RR:RE:PO.DN.4.1 { @ Maximum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density [window ^PO_DN_4_1_W_R um x ^PO_DN_4_1_W_R um, stepping ^PO_DN_4_1_S_R um] <= ^PO_DN_4_1_R     
  EXC = (RHPO INTERACT RPO) OR ICOVL
  N = ALL_POLY NOT EXC
  D = CHIP NOT EXC 
  A = CHIPx NOT EXC
  X = DENSITY A ALL_POLY CHIP N D > PO_DN_4_1_R WINDOW PO_DN_4_1_W_R STEP PO_DN_4_1_S_R BACKUP INSIDE OF LAYER CHIPx PRINT PO.DN.4.1R.density RDB PO.DN.4.1R.RDB.density
          [~(PO_DN_4_1_E_R-AREA(A))*AREA(N)/AREA(D)*!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_4_1_R)]


  X NOT excludeRRuleRecommended
}

#ENDIF
#ENDIF
#IFDEF CHECK_PODN12_
#IFDEF _PODN12_

PODN12_POCellIn = INSIDE CELL POi CellsForRRuleRecommended  
PODN12_POCellOut = NOT INSIDE CELL POi ExclCellsForRRuleRecommended 
PODN12_POCell = PODN12_POCellIn AND PODN12_POCellOut
PODN12_POMarker = POi AND RRuleRecommended
PODN12_PO = ((( PODN12_POCell OR PODN12_POMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended


RR:RE:PO.DN.12 { @ "Sensitive high R resistor" interact the region of {(PO local density > 45%) SIZING 5 um} is not allowed. The definition of "sensitive high R resistor": {{{{RH_PO AND {RPO AND PO}} AND RPDMY} AND PP} INTERACT SENDMY} The definition of the region (PO local density): 1. {{{PO OR DPO} OR SR_DPO} NOT CPO} local density (window 20 um x 20 um, stepping 10 um) 2. This rule is only applied while the width of {checking window NOT {{"sensitive high R resistor" SIZING 0.3 um} SIZING -0.3 um}} >= 5 um   ## Sensitive high R resistor interact the region of {(PO local density > 45%) SIZING 5 um} is not allowed. The definition of sensitive high R resistor: {{{{RH_PO AND {RPO AND PO}} AND RPDMY} AND PP} INTERACT SENDMY} The definition of the region (PO local density): 1. {{{PO OR DPO} OR SR_DPO} NOT CPO} local density (window 20 um x 20 um, stepping 10 um) 2. This rule is only applied while the width of {checking window NOT {{sensitive high R resistor SIZING 0.3} SIZING -0.3}} >= 5
  A = WITH WIDTH (PO_DENSITY_HIGH_RR NOT (SIZE RES_High_R BY PO_DN_12_S1 OVERUNDER TRUNCATE PO_DN_12_S1)) >= PO_DN_12_W2
  ((RES_High_R INTERACT SENDMY) INTERACT (SIZE (PO_DENSITY_HIGH_RR INTERACT A) BY PO_DN_12_S2)) INTERACT PODN12_PO
}
#ENDIF
#ENDIF

#IFDEF CHECK_PODN14_
#IFDEF _PODN14_

RR:RE:PO.DN.14 {@ The po density difference between any two 20um x 20um neighboring checking windows <= 35%
  EXCEPT =  COPY ICOVL
  ALL_POLY_chk = ALL_POLY NOT EXCEPT
  X = DENSITY ALL_POLY_chk EXCEPT CHIP <=1 WINDOW PO_DN_14_R_W BACKUP GRADIENT > PO_DN_14_R ABSOLUTE CORNER INSIDE OF LAYER CHIPx PRINT PO.DN.14R.density RDB PO.DN.14R.RDB.density
      [ (AREA(ALL_POLY_chk)+AREA(EXCEPT)*PO_DN_14_R_V)/AREA(CHIP) ] 
  X NOT excludeRRuleRecommended
}


#ENDIF
#ENDIF

#IFDEF CHECK_PODN15_
#IFDEF _PODN15_



RR:RE:PO.DN.15 {@ Maximum ratio of PMET poly <= 75% (windows 20um x 20um, stepping 10um) if po local density >= 45 % in this window 
   X = DENSITY ALL_POLY PMET_PO > PO_DN_15_R WINDOW PO_DN_15_R_W STEP PO_DN_15_R_S BACKUP INSIDE OF LAYER CHIP PRINT PO.DN.15R.density RDB PO.DN.15R.RDB.density
       [ AREA(PMET_PO)/AREA(ALL_POLY)*(!~(AREA(ALL_POLY)/AREA()-PO_DN_15_R_P)+!(AREA(ALL_POLY)/AREA()-PO_DN_15_R_P))] 
   X NOT excludeRRuleRecommended  
}


#ENDIF
#ENDIF

#IFDEF CHECK_PODN16_
#IFDEF _PODN16_

RR:RE:PO.DN.16 {@ Maximum {{{{PO OR SR_DPO} OR DPO} NOT CPO} NOT {RH_PO AND RPO}} local density in {{{MATCHING OR ANARRAY_H} OR ANARRAY_M} SIZING 10 um} [window 10 um x 10 um, stepping ^PO_DN_16_S um] <= ^PO_DN_16 
   X = DENSITY MET_PO MATCHING_S10 > PO_DN_16 WINDOW PO_DN_16_W STEP PO_DN_16_S BACKUP INSIDE OF LAYER MATCHING_S10x PRINT PO.DN.16R.density RDB PO.DN.16R.RDB.density
        [!(AREA()-AREA(MATCHING_S10))*AREA(MET_PO)/AREA(MATCHING_S10)]
   X NOT excludeRRuleRecommended      
}


#ENDIF
#ENDIF

#IFDEF CHECK_POR21_
#IFDEF _POR21_
POR21_ODCellIn = INSIDE CELL ODi CellsForRRuleRecommended  
POR21_ODCellOut = NOT INSIDE CELL ODi ExclCellsForRRuleRecommended 
POR21_ODCell = POR21_ODCellIn AND POR21_ODCellOut
POR21_ODMarker = ODi AND RRuleRecommended
POR21_OD = ((( POR21_ODCell OR POR21_ODMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:PO.R.21 { @ Recommend to put dummy gate at the edge of device [channel length <= 0.04 um] on the same OD. The definition of dummy gate is {{PO INTERACT OD} NOT INTERACT CO} or {SR_DPO AND OD}   
  GATE_DUMMY = ((POLY INTERACT OD) NOT INTERACT CO) OR (SRDPO AND OD)
  OD_CHK = POR21_OD WITH EDGE (LENGTH GATE_L <= PO_R_21_L_R)  
  OD_CHK_EDGE = (OD_CHK NOT SR_POLY) INTERACT SR_POLY == 1
  OD_CHK_EDGE NOT INTERACT GATE_DUMMY
}
#ENDIF
#ENDIF

#IFDEF FRONT_END
#IFDEF CHECK_POS50_
#IFDEF _POS50_



#ENDIF
#ENDIF
#ENDIF

#IFDEF CHECK_PMETR1_
#IFDEF _PMETR1_
PMETR1_POCellIn = INSIDE CELL POi CellsForRRuleRecommended  
PMETR1_POCellOut = NOT INSIDE CELL POi ExclCellsForRRuleRecommended 
PMETR1_POCell = PMETR1_POCellIn AND PMETR1_POCellOut
PMETR1_POMarker = POi AND RRuleRecommended
PMETR1_PO = ((( PMETR1_POCell OR PMETR1_POMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:PMET.R.1 { @ Recommended PMET fully cover {Core PMOS GATE SIZING 0.065 um} in PO ENDCAP direction >= 0.065 
  GATE_CORE_P = ((((GATE NOT OD2) AND PP) NOT INSIDE TCDDMY) NOT INSIDE (SRAM_WAIVE_N28 OR ICOVL)) INTERACT PMETR1_PO
  GATE_CORE_P_L = GATE_L COIN INSIDE EDGE GATE_CORE_P    
  (EXPAND EDGE GATE_CORE_P_L BY 0.065) NOT PMET
}

#ENDIF
#ENDIF

#IFDEF CHECK_RHODR4_
#IFDEF _RHODR4_
RHODR4_ODCellIn = INSIDE CELL ODi CellsForRRuleRecommended  
RHODR4_ODCellOut = NOT INSIDE CELL ODi ExclCellsForRRuleRecommended 
RHODR4_ODCell = RHODR4_ODCellIn AND RHODR4_ODCellOut
RHODR4_ODMarker = ODi AND RRuleRecommended
RHODR4_OD = ((( RHODR4_ODCell OR RHODR4_ODMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:RH_OD.R.4 { @ Recommended to use rectangular shape resistor for the SPICE model accuracy. DRC can flag {{RH_OD AND RPO} AND OD} which is not a rectangle   
                 @ DRC will flag {{RH_OD AND RPO} AND OD} which is not rectangle.
  NOT RECTANGLE ((RHODR4_OD AND RHOD) AND RPO)
}
#ENDIF
#ENDIF

#IFDEF CHECK_RHODR9_
#IFDEF _RHODR9_
RHODR9_ODCellIn = INSIDE CELL ODi CellsForRRuleRecommended  
RHODR9_ODCellOut = NOT INSIDE CELL ODi ExclCellsForRRuleRecommended 
RHODR9_ODCell = RHODR9_ODCellIn AND RHODR9_ODCellOut
RHODR9_ODMarker = ODi AND RRuleRecommended
RHODR9_OD = ((( RHODR9_ODCell OR RHODR9_ODMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:RH_OD.R.9 { @ In same RPDMY, either the length of {{OD OR SR_DPO} AND RH_OD} or the length of {{{OD OR SR_DPO} AND RH_OD} AND {RPDMY SIZING 0.16 um}} in length direction of silicided OD resistor must be the same
  SRDPO_RHOD = SRDPO AND RHOD
  OD_RHOD    = OD AND RHOD     
  X = SRDPO_RHOD OR OD_RHOD
  RPDMY_CHECK = RPDMY INTERACT (ODRES_SI INTERACT RHODR9_OD)
  INSIDE_E1 = EXPAND EDGE (X INSIDE EDGE RPDMY_CHECK) INSIDE BY 0.001 EXTEND BY RH_OD_R_9   
  CHECK_EDGEA = X COIN INSIDE EDGE INSIDE_E1 
  CHECK_EDGEB = X TOUCH INSIDE EDGE INSIDE_E1 
  A = DFM PROPERTY RPDMY_CHECK CHECK_EDGEA OVERLAP ABUT ALSO MULTI
  [-= MAX(LENGTH(CHECK_EDGEA)) - MIN(LENGTH(CHECK_EDGEA)) ] != 0
  DFM PROPERTY A CHECK_EDGEB OVERLAP ABUT ALSO MULTI
  [-= MAX(LENGTH(CHECK_EDGEB)) - MIN(LENGTH(CHECK_EDGEB)) ] != 0
}
#ENDIF
#ENDIF

#IFDEF CHECK_RHODR12_
#IFDEF _RHODR12_
RHODR12_ODCellIn = INSIDE CELL ODi CellsForRRuleRecommended  
RHODR12_ODCellOut = NOT INSIDE CELL ODi ExclCellsForRRuleRecommended 
RHODR12_ODCell = RHODR12_ODCellIn AND RHODR12_ODCellOut
RHODR12_ODMarker = ODi AND RRuleRecommended
RHODR12_OD = ((( RHODR12_ODCell OR RHODR12_ODMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:RH_OD.R.12 { @ {RPDMY AND {{OD INTERACT CO} AND RPO}} must be identical to {RH_OD AND {{OD INTERACT CO} AND RPO}}   
    (RPDMY AND ((RHODR12_OD INTERACT CO) AND RPO)) XOR (RHOD AND ((RHODR12_OD INTERACT CO) AND RPO)) 
}
#ENDIF
#ENDIF

#IFDEF CHECK_RHPOR15_
#IFDEF _RHPOR15_
RHPOR15_POCellIn = INSIDE CELL POi CellsForRRuleRecommended  
RHPOR15_POCellOut = NOT INSIDE CELL POi ExclCellsForRRuleRecommended 
RHPOR15_POCell = RHPOR15_POCellIn AND RHPOR15_POCellOut
RHPOR15_POMarker = POi AND RRuleRecommended
RHPOR15_PO = ((( RHPOR15_POCell OR RHPOR15_POMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:RH_PO.R.15 { @ {RPDMY AND {{PO INTERACT CO} AND RPO}} must be identical to {RH_PO AND {{PO INTERACT CO} AND RPO}}   
  (RPDMY AND ((RHPOR15_PO INTERACT CO) AND RPO)) XOR (RHPO AND ((RHPOR15_PO INTERACT CO) AND RPO)) 
}
#ENDIF
#ENDIF

#IFDEF FRONT_END
#IFDEF CHECK_RHPOR16_
#IFDEF _RHPOR16_






#ENDIF
#ENDIF
#ENDIF

#IFDEF CHECK_ESDIMPEN1_
#IFDEF _ESDIMPEN1_
ESDIMPEN1_ODCellIn = INSIDE CELL ODi CellsForRRuleRecommended  
ESDIMPEN1_ODCellOut = NOT INSIDE CELL ODi ExclCellsForRRuleRecommended 
ESDIMPEN1_ODCell = ESDIMPEN1_ODCellIn AND ESDIMPEN1_ODCellOut
ESDIMPEN1_ODMarker = ODi AND RRuleRecommended
ESDIMPEN1_OD = ((( ESDIMPEN1_ODCell OR ESDIMPEN1_ODMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:ESDIMP.EN.1 { @ Recommended {OD NOT PO} enclosure of ESDIMP = 0.4 
  OD_NPO = ESDIMPEN1_OD NOT POLY
  OD_NPO_ESD = SIZE (OD_NPO INTERACT ESDIMP) BY -ESDIMP_EN_1R
  ESDIMP_OD = ESDIMP INTERACT OD_NPO
  XOR OD_NPO_ESD ESDIMP_OD
}
#ENDIF
#ENDIF

#IFDEF CHECK_COEN1_
#IFDEF _COEN1_
COEN1_COCellIn = INSIDE CELL COii CellsForRRuleRecommended  
COEN1_COCellOut = NOT INSIDE CELL COii ExclCellsForRRuleRecommended 
COEN1_COCellIn2 = INSIDE CELL CO_VIRT CellsForRRuleRecommended  
COEN1_COCellOut2 = NOT INSIDE CELL CO_VIRT ExclCellsForRRuleRecommended 
COEN1_COCell = (COEN1_COCellIn AND COEN1_COCellOut) OR (COEN1_COCellIn2 AND COEN1_COCellOut2)
COEN1_COMarker1 = COii AND RRuleRecommended
COEN1_COMarker2 = CO_VIRT AND RRuleRecommended
COEN1_COMarker = OR  COEN1_COMarker1 COEN1_COMarker2
COEN1_CO = ((( COEN1_COCell OR COEN1_COMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:CO.EN.1 { @ Recommended enclosure by OD [channel length > 0.09 um] to avoid high Rc >= 0.015 
  COEN1_OD = OD WITH EDGE (LENGTH GATE_L > CO_EN_1_L_R)
  ENC COEN1_CO COEN1_OD < CO_EN_1_R ABUT < 90 SINGULAR REGION
}

#ENDIF
#ENDIF

#IFDEF CHECK_COEN2_
#IFDEF _COEN2_
COEN2_COCellIn = INSIDE CELL COii CellsForRRuleRecommended  
COEN2_COCellOut = NOT INSIDE CELL COii ExclCellsForRRuleRecommended 
COEN2_COCellIn2 = INSIDE CELL CO_VIRT CellsForRRuleRecommended  
COEN2_COCellOut2 = NOT INSIDE CELL CO_VIRT ExclCellsForRRuleRecommended 
COEN2_COCell = (COEN2_COCellIn AND COEN2_COCellOut) OR (COEN2_COCellIn2 AND COEN2_COCellOut2)
COEN2_COMarker1 = COii AND RRuleRecommended
COEN2_COMarker2 = CO_VIRT AND RRuleRecommended
COEN2_COMarker = OR  COEN2_COMarker1 COEN2_COMarker2
COEN2_CO = ((( COEN2_COCell OR COEN2_COMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:CO.EN.2 { @ Recommended enclosure by OD [at least 2 opposite sides] >= 0.04 
  X = RECTANGLE ENCLOSURE COEN2_CO OD ABUT < 90 SINGULAR GOOD 0 CO_EN_2_R OPPOSITE 0 CO_EN_2_R OPPOSITE
  Y = ENC [X] OD < CO_EN_2_R ABUT < 90 OPPOSITE
  Z = X TOUCH EDGE Y
  INT Z < CO_W_1 ABUT == 90 INTERSECTING ONLY   // adjacent narrow sides
}


#ENDIF
#ENDIF

#IFDEF CHECK_COEN4_
#IFDEF _COEN4_
COEN4_COCellIn = INSIDE CELL COii CellsForRRuleRecommended  
COEN4_COCellOut = NOT INSIDE CELL COii ExclCellsForRRuleRecommended 
COEN4_COCellIn2 = INSIDE CELL CO_VIRT CellsForRRuleRecommended  
COEN4_COCellOut2 = NOT INSIDE CELL CO_VIRT ExclCellsForRRuleRecommended 
COEN4_COCell = (COEN4_COCellIn AND COEN4_COCellOut) OR (COEN4_COCellIn2 AND COEN4_COCellOut2)
COEN4_COMarker1 = COii AND RRuleRecommended
COEN4_COMarker2 = CO_VIRT AND RRuleRecommended
COEN4_COMarker = OR  COEN4_COMarker1 COEN4_COMarker2
COEN4_CO = ((( COEN4_COCell OR COEN4_COMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:CO.EN.4 { @ Recommended enclosure by PO [at least 2 opposite sides] to avoid high Rc >= 0.03 
  X = RECTANGLE ENCLOSURE COEN4_CO POLY ABUT < 90 SINGULAR GOOD 0 CO_EN_4_R OPPOSITE 0 CO_EN_4_R OPPOSITE
  Y = ENC [X] POLY < CO_EN_4_R ABUT < 90 OPPOSITE
  Z = X TOUCH EDGE Y
  INT Z < CO_W_1 ABUT == 90 INTERSECTING ONLY   // adjacent narrow sides
}
#ENDIF
#ENDIF

#IFDEF CHECK_COEN16_
#IFDEF _COEN16_
COEN16_COCellIn = INSIDE CELL COii CellsForRRuleRecommended  
COEN16_COCellOut = NOT INSIDE CELL COii ExclCellsForRRuleRecommended 
COEN16_COCellIn2 = INSIDE CELL CO_VIRT CellsForRRuleRecommended  
COEN16_COCellOut2 = NOT INSIDE CELL CO_VIRT ExclCellsForRRuleRecommended 
COEN16_COCell = (COEN16_COCellIn AND COEN16_COCellOut) OR (COEN16_COCellIn2 AND COEN16_COCellOut2)
COEN16_COMarker1 = COii AND RRuleRecommended
COEN16_COMarker2 = CO_VIRT AND RRuleRecommended
COEN16_COMarker = OR  COEN16_COMarker1 COEN16_COMarker2
COEN16_CO = ((( COEN16_COCell OR COEN16_COMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:CO.EN.16 {@ Recommend inner corner OD enclsoure of CO to avoid leakage {This check doesn't include pick up regions} >= 0.04
   CHECK_CO = COEN16_CO INTERACT DACT
   A = EXT [OD] <= GRID ABUT==90 INTERSECTING ONLY
   B = EXTENTS (EXPAND EDGE A BY GRID)
   C = SIZE B BY CO_EN_16_R-GRID
   (C AND OD) AND CHECK_CO
}
#ENDIF
#ENDIF

#IFDEF CHECK_COR7_
#IFDEF _COR7_
COR7_COCellIn = INSIDE CELL COii CellsForRRuleRecommended  
COR7_COCellOut = NOT INSIDE CELL COii ExclCellsForRRuleRecommended 
COR7_COCellIn2 = INSIDE CELL CO_VIRT CellsForRRuleRecommended  
COR7_COCellOut2 = NOT INSIDE CELL CO_VIRT ExclCellsForRRuleRecommended 
COR7_COCell = (COR7_COCellIn AND COR7_COCellOut) OR (COR7_COCellIn2 AND COR7_COCellOut2)
COR7_COMarker1 = COii AND RRuleRecommended
COR7_COMarker2 = CO_VIRT AND RRuleRecommended
COR7_COMarker = OR  COR7_COMarker1 COR7_COMarker2
COR7_CO = ((( COR7_COCell OR COR7_COMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:CO.R.7 { @ Recommended to add adequate number of effective CO [channel width <= 0.6 um, CO space to GATE <= 0.11 um]. Recommended adequate number of effective CO has the following conditions: (1) Channel width >= 0.1 um and channel width < 0.21 um, recommended adequate number of effective CO = 1; (2) Channel width >= 0.21 um and channel width < 0.43 um, recommended adequate number of effective CO >= 2; (3) Channel width >= 0.43 um and channel width <= 0.6 um, recommended adequate number of effective CO >= 3; Besides, if there is no CO in Source/Drain or no CO connected to Source/Drain by OD, it is allowed   
  SD_CHK        = SD INTERACT (COR7_CO OR DSTP)      
  GATE_W_CHK    = GATE_W COIN OUTSIDE EDGE SD_CHK
  GATE_W_L1   = LENGTH GATE_W_CHK >= CO_R_7_WA_R < CO_R_7_WB_R
  GATE_W_L2   = LENGTH GATE_W_CHK >= CO_R_7_WB_R < CO_R_7_WC_R
  GATE_W_L3   = LENGTH GATE_W_CHK >= CO_R_7_WC_R <= CO_R_7_WD_R
  (EXPAND EDGE GATE_W_L1 OUTSIDE BY CO_R_7_S_R) INTERACT CO < 1
  (EXPAND EDGE GATE_W_L2 OUTSIDE BY CO_R_7_S_R) INTERACT CO < 2
  (EXPAND EDGE GATE_W_L3 OUTSIDE BY CO_R_7_S_R) INTERACT CO < 3    
}
#ENDIF
#ENDIF

#IFDEF CHECK_COR8_
#IFDEF _COR8_
COR8_COCellIn = INSIDE CELL COii CellsForRRuleRecommended  
COR8_COCellOut = NOT INSIDE CELL COii ExclCellsForRRuleRecommended 
COR8_COCellIn2 = INSIDE CELL CO_VIRT CellsForRRuleRecommended  
COR8_COCellOut2 = NOT INSIDE CELL CO_VIRT ExclCellsForRRuleRecommended 
COR8_COCell = (COR8_COCellIn AND COR8_COCellOut) OR (COR8_COCellIn2 AND COR8_COCellOut2)
COR8_COMarker1 = COii AND RRuleRecommended
COR8_COMarker2 = CO_VIRT AND RRuleRecommended
COR8_COMarker = OR  COR8_COMarker1 COR8_COMarker2
COR8_CO = ((( COR8_COCell OR COR8_COMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:CO.R.8 { @ Single CO on S/D of core PMOS is not recommended if OD enclosure of this single CO <= 0.005 in S/D direction: (1) PMOS channel width < 0.21 um, recommended to have no CO on OD edge (e.g. add SR_DPO between GATE and OD edge) (2) 0.21 um <= PMOS channe width <= 0.6 um, recommended to have more than one CO on OD edge (3) PMOS channe width > 0.6 um, need to follow CO.S.13   
   CHECK_OD = (OD INTERACT GATE_PP) NOT INTERACT HV_GATE
   CHECK_OD_EDGE = OD NOT TOUCH INSIDE EDGE GATE_L
   CHECK_CO = COR8_CO INTERACT ((CHECK_OD NOT GATE) INTERACT COR8_CO == 1)
   ENC CHECK_CO CHECK_OD_EDGE <= 0.005 ABUT<90 OPPOSITE REGION
}
#ENDIF
#ENDIF


#IFDEF CHECK_M1W5_
#IFDEF _M1W5_
M1W5_M1CellIn = INSIDE CELL M1i CellsForRRuleRecommended  
M1W5_M1CellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
M1W5_M1Cell = M1W5_M1CellIn AND M1W5_M1CellOut
M1W5_M1Marker = M1i AND RRuleRecommended
M1W5_M1 = ((( M1W5_M1Cell OR M1W5_M1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M1.W.5 { @ Recommended M1 width [spaces to 2 side-wall M1 (S1) = 0.05 um with parallel run length (L1) > 0.16 um, 0.02 um<=line-end enclosure of either one of CO/VIA1 (S2) <= 0.03 um with 0.07 um<= line-end space (S3) <= 0.08 um] >= 0.06 
   U_EDGE    = CONVEX EDGE M1W5_M1 ANGLE1==270 ANGLE2==270 WITH LENGTH < M1_W_5_R+2*M1_W_5_S1_R   
   CHECK_M1  = M1W5_M1 INTERACT (EXPAND EDGE U_EDGE OUTSIDE BY M1_W_5_S3_R)
   LINE_END0 = CONVEX EDGE CHECK_M1 ANGLE1==90 ANGLE2==90 LENGTH1>M1_W_5_L1_R LENGTH2>M1_W_5_L1_R WITH LENGTH < M1_W_5_R 
   CHECK_CO  = (CO INTERACT CHECK_M1) OR (VIA1 INTERACT CHECK_M1)
   LINE_END  = ENC CHECK_CO [LINE_END0] <= M1_W_5_S2_R ABUT<90 OPPOSITE
   S1_E = EXT [LINE_END] U_EDGE <= M1_W_5_S3_R ABUT<90 OPPOSITE 
   S1_U = EXT LINE_END [U_EDGE] <= M1_W_5_S3_R ABUT<90 OPPOSITE 
   U_SHAPE = CHECK_M1 WITH EDGE S1_U
   U_SHAPE_NOTCH = EXT U_SHAPE < M1_W_5_R+2*M1_W_5_S1_R ABUT<90 OPPOSITE REGION NOTCH
   BAR_E1 = ((CHECK_M1 WITH EDGE S1_E) INSIDE EDGE U_SHAPE_NOTCH) NOT TOUCH INSIDE EDGE S1_E 
   BAR_E2 = LENGTH (EXT [BAR_E1] U_SHAPE == M1_W_5_S1_R ABUT<90 OPPOSITE) > M1_W_5_L1_R
   INT BAR_E2 < M1_W_5_R ABUT<90 OPPOSITE REGION 
}
#ENDIF
#ENDIF

#IFDEF CHECK_M1S1_
#IFDEF _M1S1_
M1S1_M1CellIn = INSIDE CELL M1i CellsForRRuleRecommended  
M1S1_M1CellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
M1S1_M1Cell = M1S1_M1CellIn AND M1S1_M1CellOut
M1S1_M1Marker = M1i AND RRuleRecommended
M1S1_M1 = ((( M1S1_M1Cell OR M1S1_M1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M1.S.1 { @ Recommended space to reduce the short possibility caused by particle >= 0.06 
  ((EXT M1 < M1_S_1_R ABUT < 90 SINGULAR REGION) INTERACT M1S1_M1) NOT INSIDE TCDDMY_BM1
}
#ENDIF
#ENDIF

#IFDEF CHECK_M1S2_
#IFDEF _M1S2_
M1S2_M1CellIn = INSIDE CELL M1i CellsForRRuleRecommended  
M1S2_M1CellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
M1S2_M1Cell = M1S2_M1CellIn AND M1S2_M1CellOut
M1S2_M1Marker = M1i AND RRuleRecommended
M1S2_M1 = ((( M1S2_M1Cell OR M1S2_M1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M1.S.2 { @ Recommended space [at least one metal line width > 0.1 um] >= 0.06 
  ((EXT M1_20 M1 < M1_S_2_R OPPOSITE REGION MEASURE ALL) NOT M1) INTERACT M1S2_M1
}
#ENDIF
#ENDIF

#IFDEF CHECK_M1S3_
#IFDEF _M1S3_
M1S3_M1CellIn = INSIDE CELL M1i CellsForRRuleRecommended  
M1S3_M1CellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
M1S3_M1Cell = M1S3_M1CellIn AND M1S3_M1CellOut
M1S3_M1Marker = M1i AND RRuleRecommended
M1S3_M1 = ((( M1S3_M1Cell OR M1S3_M1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M1.S.3 { @ Recommended space [at least one metal line width > 0.18 um] >= 0.1 
  ((EXT M1_21 M1 < M1_S_3_R OPPOSITE REGION MEASURE ALL) NOT M1) INTERACT M1S3_M1
}
#ENDIF
#ENDIF

#IFDEF CHECK_M1S4_
#IFDEF _M1S4_
M1S4_M1CellIn = INSIDE CELL M1i CellsForRRuleRecommended  
M1S4_M1CellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
M1S4_M1Cell = M1S4_M1CellIn AND M1S4_M1CellOut
M1S4_M1Marker = M1i AND RRuleRecommended
M1S4_M1 = ((( M1S4_M1Cell OR M1S4_M1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M1.S.4 { @ Recommended space [at least one metal line width > 0.47 um] >= 0.13 
  (((EXT M1_22 M1 < M1_S_4_R OPPOSITE REGION MEASURE ALL) NOT M1) INTERACT M1S4_M1) NOT INSIDE TCDDMY_BM1
}
#ENDIF
#ENDIF

#IFDEF CHECK_M1S5_
#IFDEF _M1S5_
M1S5_M1CellIn = INSIDE CELL M1i CellsForRRuleRecommended  
M1S5_M1CellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
M1S5_M1Cell = M1S5_M1CellIn AND M1S5_M1CellOut
M1S5_M1Marker = M1i AND RRuleRecommended
M1S5_M1 = ((( M1S5_M1Cell OR M1S5_M1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M1.S.5 { @ Recommended space [at least one metal line width > 0.63 um] >= 0.15 
  ((EXT M1_23 M1 < M1_S_5_R OPPOSITE REGION MEASURE ALL) NOT M1) INTERACT M1S5_M1
}
#ENDIF
#ENDIF

#IFDEF CHECK_M1S6_
#IFDEF _M1S6_
M1S6_M1CellIn = INSIDE CELL M1i CellsForRRuleRecommended  
M1S6_M1CellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
M1S6_M1Cell = M1S6_M1CellIn AND M1S6_M1CellOut
M1S6_M1Marker = M1i AND RRuleRecommended
M1S6_M1 = ((( M1S6_M1Cell OR M1S6_M1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M1.S.6 { @ Recommended space [at least one metal line width > 1.5 um] >= 0.5 
  ((EXT M1_30 M1 < M1_S_6_R OPPOSITE REGION MEASURE ALL) NOT M1) INTERACT M1S6_M1
}
#ENDIF
#ENDIF


#IFDEF CHECK_M1S37_
#IFDEF _M1S37_
M1S37_M1CellIn = INSIDE CELL M1i CellsForRRuleRecommended  
M1S37_M1CellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
M1S37_M1Cell = M1S37_M1CellIn AND M1S37_M1CellOut
M1S37_M1Marker = M1i AND RRuleRecommended
M1S37_M1 = ((M1S37_M1Cell OR M1S37_M1Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:M1.S.37 { @ Recommended space to M1 jog filled up region (R1A) Definition of M1 jog: M1 with length < 0.12 um (LA1), 2 adjacent edge length < 0.05 um (WA1) and < 0.06 um (WA2) [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex -90 degree outer vertex] >= 0.05 
  L1_pre = CONVEX EDGE M1S37_M1 ANGLE1==90 ANGLE2==270 LENGTH2 < 0.12 WITH LENGTH < 0.05 
  L2_pre = CONVEX EDGE M1S37_M1 ANGLE1==90 ANGLE2==270 LENGTH1 < 0.06 LENGTH2 <0.05 WITH LENGTH < 0.12
  L3_pre = CONVEX EDGE M1S37_M1 ANGLE1==90 ANGLE2==90  LENGTH1 < 0.12 WITH LENGTH < 0.06
  L1_L2_V = EXT L1_pre L2_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
  L2_L3_V = INT L2_pre L3_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
  L2 = (L2_pre TOUCH OUTSIDE EDGE L1_L2_V) TOUCH INSIDE EDGE L2_L3_V  
  L1 = L1_pre TOUCH OUTSIDE EDGE (L1_L2_V WITH EDGE L2) 
  L1_ex = EXPAND EDGE L1 OUTSIDE BY GRID
  L2_ex = EXPAND EDGE L2 OUTSIDE BY GRID
  JOG_FILL = EXTENTS (L1_ex OR L2_ex)
  S = EXT JOG_FILL M1 < 0.05 ABUT>0<90 SINGULAR REGION
  S OR (JOG_FILL INTERACT S)
}
#ENDIF
#ENDIF


// M1.EN.0.R is checked by either {M1.EN.1.R/M1.EN.2.R} or M1.EN.6.R

#IFDEF CHECK_M1EN1_
#IFDEF _M1EN1_
M1EN1_COCellIn = INSIDE CELL COii CellsForRRuleRecommended  
M1EN1_COCellOut = NOT INSIDE CELL COii ExclCellsForRRuleRecommended 
M1EN1_COCellIn2 = INSIDE CELL CO_VIRT CellsForRRuleRecommended  
M1EN1_COCellOut2 = NOT INSIDE CELL CO_VIRT ExclCellsForRRuleRecommended 
M1EN1_COCell = (M1EN1_COCellIn AND M1EN1_COCellOut) OR (M1EN1_COCellIn2 AND M1EN1_COCellOut2)
M1EN1_COMarker1 = COii AND RRuleRecommended
M1EN1_COMarker2 = CO_VIRT AND RRuleRecommended
M1EN1_COMarker = OR  M1EN1_COMarker1 M1EN1_COMarker2
M1EN1_CO = ((( M1EN1_COCell OR M1EN1_COMarker ) NOT INSIDE SRAM_EXCLUDE ) OUTSIDE Block) NOT excludeRRuleRecommended

RR:RE:M1.EN.1 { @ Recommended enclosure of CO to avoid high Rc >= 0.01 
  ENC M1EN1_CO M1 < M1_EN_1_R ABUT < 90 SINGULAR REGION
}
#ENDIF
#ENDIF

#IFDEF CHECK_M1EN2_M1EN6_
#IFDEF _M1EN2_M1EN6_
M1EN2_M1EN6_COCellIn = INSIDE CELL COii CellsForRRuleRecommended  
M1EN2_M1EN6_COCellOut = NOT INSIDE CELL COii ExclCellsForRRuleRecommended 
M1EN2_M1EN6_COCellIn2 = INSIDE CELL CO_VIRT CellsForRRuleRecommended  
M1EN2_M1EN6_COCellOut2 = NOT INSIDE CELL CO_VIRT ExclCellsForRRuleRecommended 
M1EN2_M1EN6_COCell = (M1EN2_M1EN6_COCellIn AND M1EN2_M1EN6_COCellOut) OR (M1EN2_M1EN6_COCellIn2 AND M1EN2_M1EN6_COCellOut2)
M1EN2_M1EN6_COMarker1 = COii AND RRuleRecommended
M1EN2_M1EN6_COMarker2 = CO_VIRT AND RRuleRecommended
M1EN2_M1EN6_COMarker = OR  M1EN2_M1EN6_COMarker1 M1EN2_M1EN6_COMarker2
M1EN2_M1EN6_CO = ((( M1EN2_M1EN6_COCell OR M1EN2_M1EN6_COMarker ) NOT INSIDE SRAM_EXCLUDE ) OUTSIDE Block) NOT excludeRRuleRecommended

RR:RE:M1.EN.2__M1.EN.6 { @ Recommended enclosure of CO [at least two opposite sides] to avoid high Rc >= 0.035
                    @ Recommended enclosure of CO to avoid high Rc. [all sides] >= 0.02
  X = RECTANGLE ENCLOSURE M1EN2_M1EN6_CO M1 ABUT < 90 SINGULAR GOOD 0 M1_EN_2_R OPPOSITE 0 M1_EN_2_R OPPOSITE
  ENC X M1 < M1_EN_6_R ABUT < 90 SINGULAR REGION
}
// M1.EN.2.R and M1.EN.6.R are checked by RR:RE:M1.EN.2__M1.EN.6
#ENDIF
#ENDIF

#IFDEF CHECK_M1EN4_
#IFDEF _M1EN4_
M1EN4_COCellIn = INSIDE CELL COii CellsForRRuleRecommended  
M1EN4_COCellOut = NOT INSIDE CELL COii ExclCellsForRRuleRecommended 
M1EN4_COCellIn2 = INSIDE CELL CO_VIRT CellsForRRuleRecommended  
M1EN4_COCellOut2 = NOT INSIDE CELL CO_VIRT ExclCellsForRRuleRecommended 
M1EN4_COCell = (M1EN4_COCellIn AND M1EN4_COCellOut) OR (M1EN4_COCellIn2 AND M1EN4_COCellOut2)
M1EN4_COMarker1 = COii AND RRuleRecommended
M1EN4_COMarker2 = CO_VIRT AND RRuleRecommended
M1EN4_COMarker = OR  M1EN4_COMarker1 M1EN4_COMarker2
M1EN4_CO = ((( M1EN4_COCell OR M1EN4_COMarker ) NOT INSIDE SRAM_EXCLUDE ) OUTSIDE Block) NOT excludeRRuleRecommended

RR:RE:M1.EN.4 { @ Recommended enclosure of CO [M1 width >= 0.08 um, M1 space < 0.06 um] >= 0.015 
  X = M1 WITH WIDTH >= M1_EN_4_R_W
  check_edge = EXT [X] M1 < M1_EN_4_R_S OPPOSITE MEASURE ALL
  ENC M1EN4_CO check_edge < M1_EN_4_R ABUT < 90 REGION
}
#ENDIF
#ENDIF

#IFDEF CHECK_M1A1_
#IFDEF _M1A1_
M1A1_M1CellIn = INSIDE CELL M1i CellsForRRuleRecommended  
M1A1_M1CellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
M1A1_M1Cell = M1A1_M1CellIn AND M1A1_M1CellOut
M1A1_M1Marker = M1i AND RRuleRecommended
M1A1_M1 = ((( M1A1_M1Cell OR M1A1_M1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M1.A.1 { @ Recommended area (except DM1_O) >= 0.022 
  (AREA M1A1_M1 < M1_A_1_R) NOT INSIDE TCDDMY_BM1
}
#ENDIF
#ENDIF

// VIA1.EN.0.R is checked by either {VIA1.EN.1.R/VIA1.EN.2.R} or VIA1.EN.3.R
#IFDEF CHECK_VIA1EN1_
#IFDEF _VIA1EN1_
VIA1EN1_VIA1CellIn1 = INSIDE CELL VIA1ii CellsForRRuleRecommended  
VIA1EN1_VIA1CellOut1 = NOT INSIDE CELL VIA1ii ExclCellsForRRuleRecommended 
VIA1EN1_VIA1CellIn2 = INSIDE CELL VIA1_VIRT CellsForRRuleRecommended  
VIA1EN1_VIA1CellOut2 = NOT INSIDE CELL VIA1_VIRT ExclCellsForRRuleRecommended 
VIA1EN1_VIA1Cell = (VIA1EN1_VIA1CellIn1 AND VIA1EN1_VIA1CellOut1) OR (VIA1EN1_VIA1CellIn2 AND VIA1EN1_VIA1CellOut2)
VIA1EN1_VIA1Marker = (VIA1ii OR VIA1_VIRT) AND RRuleRecommended
VIA1EN1_VIA1 = ((( VIA1EN1_VIA1Cell OR VIA1EN1_VIA1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

// VIAx.EN.1.R is checked by RR:RE:VIA1.EN.1 
RR:RE:VIA1.EN.1 { @ Recommended enclosure by M1 or Mx to avoid high Rc. (for square VIA) >= 0.01 
   CHECK_VIA = SQR_VIA1 INTERACT VIA1EN1_VIA1
   ENC CHECK_VIA M1 < VIA1_EN_1_R ABUT < 90 SINGULAR REGION
}
#ENDIF
#ENDIF

#IFDEF CHECK_VIA1EN2_VIA1EN3_
#IFDEF _VIA1EN2_VIA1EN3_
VIA1EN2_VIA1EN3_VIA1CellIn1 = INSIDE CELL VIA1ii CellsForRRuleRecommended  
VIA1EN2_VIA1EN3_VIA1CellOut1 = NOT INSIDE CELL VIA1ii ExclCellsForRRuleRecommended 
VIA1EN2_VIA1EN3_VIA1CellIn2 = INSIDE CELL VIA1_VIRT CellsForRRuleRecommended  
VIA1EN2_VIA1EN3_VIA1CellOut2 = NOT INSIDE CELL VIA1_VIRT ExclCellsForRRuleRecommended 
VIA1EN2_VIA1EN3_VIA1Cell = (VIA1EN2_VIA1EN3_VIA1CellIn1 AND VIA1EN2_VIA1EN3_VIA1CellOut1) OR (VIA1EN2_VIA1EN3_VIA1CellIn2 AND VIA1EN2_VIA1EN3_VIA1CellOut2)
VIA1EN2_VIA1EN3_VIA1Marker = (VIA1ii OR VIA1_VIRT) AND RRuleRecommended
VIA1EN2_VIA1EN3_VIA1 = ((( VIA1EN2_VIA1EN3_VIA1Cell OR VIA1EN2_VIA1EN3_VIA1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:VIA1.EN.2__VIA1.EN.3 { @ Recommended enclosure of {M1 OR Mx} [at least two opposite sides] to avoid high Rc.(for square VIA) >= 0.05
                        @ Recommended enclosure of {M1 OR Mx} to avoid high Rc. [all sides] (for square VIA) >= 0.025       
   CHECK_VIA = SQR_VIA1 INTERACT VIA1EN2_VIA1EN3_VIA1       
   X = RECTANGLE ENCLOSURE CHECK_VIA M1 ABUT < 90 SINGULAR GOOD 0 VIA1_EN_2_R OPPOSITE 0 VIA1_EN_2_R OPPOSITE
   ENC X M1 < VIA1_EN_3_R ABUT < 90 SINGULAR REGION
}
// VIA1.EN.2.R and VIA1.EN.3.R are checked by RR:RE:VIA1.EN.2__VIA1.EN.3
#ENDIF
#ENDIF

#IFDEF CHECK_VIA1R10_
#IFDEF _VIA1R10_
VIA1R10_VIA1CellIn = INSIDE CELL VIA1ii CellsForRRuleRecommended  
VIA1R10_VIA1CellOut = NOT INSIDE CELL VIA1ii ExclCellsForRRuleRecommended 
VIA1R10_VIA1Cell = VIA1R10_VIA1CellIn AND VIA1R10_VIA1CellOut
VIA1R10_VIA1Marker = VIA1ii AND RRuleRecommended
VIA1R10_VIA1 = ((VIA1R10_VIA1Cell OR VIA1R10_VIA1Marker) NOT Block ) NOT excludeRRuleRecommended

//'VIAx.R.10.R' is checked by RR:RE:VIA1.R.10
RR:RE:VIA1.R.10 { @ Recommended VIAx space to VIAx+1 [different net and parallel run length > 0.02 um] >= 0.06 
  CHECK_VIA =  VIA1ii INTERACT VIA1R10_VIA1   
  X = EXT [CHECK_VIA] VIA2ii < VIA1_R_10_R ABUT < 90 OPPOSITE NOT CONNECTED
  LENGTH X > VIA1_R_10_L_R
}
#ENDIF
#ENDIF

// M2.EN.0.R is checked by either {M2.EN.1.R/M2.EN.2.R} or M2.EN.3.R
#IFDEF CHECK_M2EN1_
#IFDEF _M2EN1_
M2EN1_VIA1CellIn1 = INSIDE CELL VIA1ii CellsForRRuleRecommended  
M2EN1_VIA1CellOut1 = NOT INSIDE CELL VIA1ii ExclCellsForRRuleRecommended 
M2EN1_VIA1CellIn2 = INSIDE CELL VIA1_VIRT CellsForRRuleRecommended  
M2EN1_VIA1CellOut2 = NOT INSIDE CELL VIA1_VIRT ExclCellsForRRuleRecommended 
M2EN1_VIA1Cell = (M2EN1_VIA1CellIn1 AND M2EN1_VIA1CellOut1) OR (M2EN1_VIA1CellIn2 AND M2EN1_VIA1CellOut2)
M2EN1_VIA1Marker = (VIA1ii OR VIA1_VIRT) AND RRuleRecommended
M2EN1_VIA1 = ((( M2EN1_VIA1Cell OR M2EN1_VIA1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended


RR:RE:M2.EN.1 { @ Recommended enclosure of VIAx-1 to avoid high Rc. (for square VIA) >= 0.01
   CHECK_VIA = SQR_VIA1 INTERACT M2EN1_VIA1
   ENC CHECK_VIA M2 < M2_EN_1_R ABUT < 90 SINGULAR REGION
}
#ENDIF
#ENDIF

#IFDEF CHECK_M2EN2_M2EN3_
#IFDEF _M2EN2_M2EN3_
M2EN2_M2EN3_VIA1CellIn1 = INSIDE CELL VIA1ii CellsForRRuleRecommended  
M2EN2_M2EN3_VIA1CellOut1 = NOT INSIDE CELL VIA1ii ExclCellsForRRuleRecommended 
M2EN2_M2EN3_VIA1CellIn2 = INSIDE CELL VIA1_VIRT CellsForRRuleRecommended  
M2EN2_M2EN3_VIA1CellOut2 = NOT INSIDE CELL VIA1_VIRT ExclCellsForRRuleRecommended 
M2EN2_M2EN3_VIA1Cell = (M2EN2_M2EN3_VIA1CellIn1 AND M2EN2_M2EN3_VIA1CellOut1) OR (M2EN2_M2EN3_VIA1CellIn2 AND M2EN2_M2EN3_VIA1CellOut2)
M2EN2_M2EN3_VIA1Marker = (VIA1ii OR VIA1_VIRT) AND RRuleRecommended
M2EN2_M2EN3_VIA1 = ((( M2EN2_M2EN3_VIA1Cell OR M2EN2_M2EN3_VIA1Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended


RR:RE:M2.EN.2__M2.EN.3 { @ Recommended M2 enclosure of square VIA1 >= ^M2_EN_3_R, OR at least two opposite sides >= ^M2_EN_2_R um
  CHECK_VIA = SQR_VIA1 INTERACT M2EN2_M2EN3_VIA1      
  A = RECTANGLE ENCLOSURE CHECK_VIA M2 ABUT < 90 SINGULAR GOOD 0 M2_EN_2_R OPPOSITE 0 M2_EN_2_R OPPOSITE
  ENC A M2 < M2_EN_3_R ABUT < 90 SINGULAR REGION
}
// M2.EN.2.R and M2.EN.3.R are checked by RR:RE:M2.EN.2__M2.EN.3
#ENDIF
#ENDIF

#IFDEF CHECK_M2S1_
#IFDEF _M2S1_
M2S1_M2CellIn = INSIDE CELL M2i CellsForRRuleRecommended  
M2S1_M2CellOut = NOT INSIDE CELL M2i ExclCellsForRRuleRecommended 
M2S1_M2Cell = M2S1_M2CellIn AND M2S1_M2CellOut
M2S1_M2Marker = M2i AND RRuleRecommended
M2S1_M2 = ((M2S1_M2Cell OR M2S1_M2Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:M2.S.1 { @ Recommended space to reduce the short possibility caused by particle >= 0.06 
  ((EXT M2 < M2_S_1_R ABUT < 90 SINGULAR REGION) INTERACT M2S1_M2) NOT INSIDE TCDDMY_BM2 
}
#ENDIF
#ENDIF

#IFDEF CHECK_M2S2_
#IFDEF _M2S2_
M2S2_M2CellIn = INSIDE CELL M2i CellsForRRuleRecommended  
M2S2_M2CellOut = NOT INSIDE CELL M2i ExclCellsForRRuleRecommended 
M2S2_M2Cell = M2S2_M2CellIn AND M2S2_M2CellOut
M2S2_M2Marker = M2i AND RRuleRecommended
M2S2_M2 = ((( M2S2_M2Cell OR M2S2_M2Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M2.S.2 { @ Recommended space [at least one metal line width > 0.09 um] >= 0.06 
  ((EXT M2_20 M2 < M2_S_2_R OPPOSITE REGION MEASURE ALL) NOT M2) INTERACT M2S2_M2
}
