// ICOVL.S.7 is not necessary to check

ICOVL.R.1 { @ ICOVL_B environment need to pass either one of below conditions: 1. {ICOVL_B SIZING 500 um} interact one ICOVL_C or ICOVL_E   
  X1 = (SIZE ICOVL_B BY ICOVL_R_1) INTERACT (ICOVL_C OR ICOVL_E)
  ICOVL_B NOT INTERACT X1
}

ICOVL.R.2 { @ ICOVL_D environment need to pass either one of below conditions: 1. {ICOVL_D SIZING 500 um} interact one ICOVL_C or ICOVL_E   
  X1 = (SIZE ICOVL_D BY ICOVL_R_2) INTERACT (ICOVL_C OR ICOVL_E)
  ICOVL_D NOT INTERACT X1
}


s_TILE_LEFT_V_8   = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_LEFT  INSIDE BY FACTOR 1/8)
e_TILE_LEFT_V_8   = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_LEFT  INSIDE BY FACTOR 7/8) NOT s_TILE_LEFT_V_8)
s_TILE_RIGHT_V_8  = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_RIGHT INSIDE BY FACTOR 1/8)
e_TILE_RIGHT_V_8  = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_RIGHT  INSIDE BY FACTOR 7/8) NOT s_TILE_RIGHT_V_8)
e_TILE_V_X_8      = EXTENT (e_TILE_LEFT_V_8 OR e_TILE_RIGHT_V_8)

s_TILE_TOP_V_8    = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_TOP  INSIDE BY FACTOR 1/8)
e_TILE_TOP_V_8    = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_TOP  INSIDE BY FACTOR 7/8) NOT s_TILE_TOP_V_8)
s_TILE_DOWN_V_8   = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_DOWN  INSIDE BY FACTOR 1/8)
e_TILE_DOWN_V_8   = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_DOWN  INSIDE BY FACTOR 7/8) NOT s_TILE_DOWN_V_8)
e_TILE_V_Y_8      = EXTENT (e_TILE_TOP_V_8 OR e_TILE_DOWN_V_8)

CENTRAL_ZONE      = AND e_TILE_V_X_8 e_TILE_V_Y_8

s_TILE_LEFT_V_2   = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_LEFT  INSIDE BY FACTOR 1/2)
s_TILE_RIGHT_V_2  = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_RIGHT INSIDE BY FACTOR 1/2)
01_TILE_ICOVL     = CHIP_ICOVL AND (EXTENT (s_TILE_LEFT_V_2 OR s_TILE_RIGHT_V_2))
02_TILE_ICOVL     = CHIP_ICOVL NOT 01_TILE_ICOVL


s_TILE_TOP_V_2    = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_TOP  INSIDE BY FACTOR 1/2)
s_TILE_DOWN_V_2   = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_DOWN  INSIDE BY FACTOR 1/2)
03_TILE_ICOVL     = CHIP_ICOVL AND (EXTENT (s_TILE_TOP_V_2 OR s_TILE_DOWN_V_2))
04_TILE_ICOVL     = CHIP_ICOVL NOT 03_TILE_ICOVL

TILE_LT  = 01_TILE_ICOVL AND 03_TILE_ICOVL
TILE_RT  = 01_TILE_ICOVL AND 04_TILE_ICOVL
TILE_LB  = 02_TILE_ICOVL AND 03_TILE_ICOVL
TILE_RB  = 02_TILE_ICOVL AND 04_TILE_ICOVL

TILE_LT_8 = TILE_LT AND CENTRAL_ZONE
TILE_RT_8 = TILE_RT AND CENTRAL_ZONE
TILE_LB_8 = TILE_LB AND CENTRAL_ZONE
TILE_RB_8 = TILE_RB AND CENTRAL_ZONE

ICOVL.R.4 { @ At least 6 respective ICOVL_set must be fully inside Central_Zone for 1X1 die Definition of Central_Zone: 1. Cx and Cy are dimension of (Prime Chip with SEALRING_ALL) = (Prime Chip + 2* 24 um) in H and V respectively 2. Central_Zone = {{(Prime Chip with SEALRING_ALL) SIZING -Cx/8 in horizontal direction} SIZING -Cy/8 in vertical direction}   
  (CENTRAL_ZONE INTERACT CHIP_1x1) NOT ENCLOSE ICOVL_set >= 6
}
ICOVL.R.5 { @ At least 3 respective ICOVL_set for 2X1 die   
  CHIP_2x1 NOT INTERACT ICOVL_set >= 3
}
ICOVL.R.6 { @ At least 2 respective ICOVL_set for 1X2 die or 3X1 die   
  CHIP_1x2 NOT INTERACT ICOVL_set >= 2
  CHIP_3x1 NOT INTERACT ICOVL_set >= 2
}
ICOVL.R.7 { @ At least 1 respective ICOVL_set for 1X3 die or 2X2 die   
  CHIP_1x3 NOT INTERACT ICOVL_set >= 1
  CHIP_2x2 NOT INTERACT ICOVL_set >= 1
}

CHIP_1x1_ICOVL_Virtual_Pre1 = GROW (SHRINK CHIP_1x1 RIGHT BY ICOVL_R_8_0_S1 LEFT BY ICOVL_R_8_0_S1) TOP BY 1
CHIP_1x1_ICOVL_Virtual_Pre2 = CHIP_1x1_ICOVL_Virtual_Pre1 NOT CHIP_1x1
CHIP_1x1_ICOVL_Virtual_Corner = INT (CHIP_1x1 COIN EDGE CHIP_1x1_ICOVL_Virtual_Pre2) CHIP_1x1_ICOVL_Virtual_Pre1 < ICOVL_R_8_0_X ABUT == 90 REGION INTERSECTING ONLY MEASURE ALL
CHIP_1x1_ICOVL_Virtual_Corner_EXT = EXTENTS CHIP_1x1_ICOVL_Virtual_Corner 
CHIP_1x1_ICOVL_Virtual_Pre3 = EXPAND EDGE (ANGLE (CHIP_1x1_ICOVL_Virtual_Corner_EXT NOT COIN EDGE CHIP_1x1) == 0) INSIDE BY ICOVL_R_8_0_X-ICOVL_R_8_0_Y
CHIP_1x1_ICOVL_Virtual = CHIP_1x1_ICOVL_Virtual_Corner_EXT NOT CHIP_1x1_ICOVL_Virtual_Pre3

CHIP_1x2_ICOVL_Virtual_Pre1 = GROW (SHRINK CHIP_1x2 RIGHT BY ICOVL_R_8_0_S1 LEFT BY ICOVL_R_8_0_S1) TOP BY 1
CHIP_1x2_ICOVL_Virtual_Pre2 = CHIP_1x2_ICOVL_Virtual_Pre1 NOT CHIP_1x2
CHIP_1x2_ICOVL_Virtual_Corner = INT (CHIP_1x2 COIN EDGE CHIP_1x2_ICOVL_Virtual_Pre2) CHIP_1x2_ICOVL_Virtual_Pre1 < ICOVL_R_8_0_X ABUT == 90 REGION INTERSECTING ONLY MEASURE ALL
CHIP_1x2_ICOVL_Virtual_Corner_EXT = EXTENTS CHIP_1x2_ICOVL_Virtual_Corner
CHIP_1x2_ICOVL_Virtual_Pre3 = EXPAND EDGE (ANGLE (CHIP_1x2_ICOVL_Virtual_Corner_EXT NOT COIN EDGE CHIP_1x2) == 0) INSIDE BY ICOVL_R_8_0_X-ICOVL_R_8_0_Y
CHIP_1x2_ICOVL_Virtual = CHIP_1x2_ICOVL_Virtual_Corner_EXT NOT CHIP_1x2_ICOVL_Virtual_Pre3

CHIP_2x1_ICOVL_Virtual_Pre1 = GROW (SHRINK CHIP_2x1 RIGHT BY ICOVL_R_8_0_S2 LEFT BY ICOVL_R_8_0_S2) TOP BY 1
CHIP_2x1_ICOVL_Virtual_Pre2 = CHIP_2x1_ICOVL_Virtual_Pre1 NOT CHIP_2x1
CHIP_2x1_ICOVL_Virtual_Corner = INT (CHIP_2x1 COIN EDGE CHIP_2x1_ICOVL_Virtual_Pre2) CHIP_2x1_ICOVL_Virtual_Pre1 < ICOVL_R_8_0_X ABUT == 90 REGION INTERSECTING ONLY MEASURE ALL
CHIP_2x1_ICOVL_Virtual_Corner_EXT = EXTENTS CHIP_2x1_ICOVL_Virtual_Corner
CHIP_2x1_ICOVL_Virtual_Pre3 = EXPAND EDGE (ANGLE (CHIP_2x1_ICOVL_Virtual_Corner_EXT NOT COIN EDGE CHIP_2x1) == 0) INSIDE BY ICOVL_R_8_0_X-ICOVL_R_8_0_Y
CHIP_2x1_ICOVL_Virtual = CHIP_2x1_ICOVL_Virtual_Corner_EXT NOT CHIP_2x1_ICOVL_Virtual_Pre3

CHIP_2x2_ICOVL_Virtual_Pre1 = GROW (SHRINK CHIP_2x2 RIGHT BY ICOVL_R_8_0_S2 LEFT BY ICOVL_R_8_0_S2) TOP BY 1
CHIP_2x2_ICOVL_Virtual_Pre2 = CHIP_2x2_ICOVL_Virtual_Pre1 NOT CHIP_2x2
CHIP_2x2_ICOVL_Virtual_Corner = INT (CHIP_2x2 COIN EDGE CHIP_2x2_ICOVL_Virtual_Pre2) CHIP_2x2_ICOVL_Virtual_Pre1 < ICOVL_R_8_0_X ABUT == 90 REGION INTERSECTING ONLY MEASURE ALL
CHIP_2x2_ICOVL_Virtual_Corner_EXT = EXTENTS CHIP_2x2_ICOVL_Virtual_Corner
CHIP_2x2_ICOVL_Virtual_Pre3 = EXPAND EDGE (ANGLE (CHIP_2x2_ICOVL_Virtual_Corner_EXT NOT COIN EDGE CHIP_2x2) == 0) INSIDE BY ICOVL_R_8_0_X-ICOVL_R_8_0_Y
CHIP_2x2_ICOVL_Virtual = CHIP_2x2_ICOVL_Virtual_Corner_EXT NOT CHIP_2x2_ICOVL_Virtual_Pre3

CHIP_1x3_ICOVL_Virtual_Pre1 = GROW (SHRINK CHIP_1x3 RIGHT BY ICOVL_R_8_0_S1 LEFT BY ICOVL_R_8_0_S1) TOP BY 1
CHIP_1x3_ICOVL_Virtual_Pre2 = CHIP_1x3_ICOVL_Virtual_Pre1 NOT CHIP_1x3
CHIP_1x3_ICOVL_Virtual_Corner = INT (CHIP_1x3 COIN EDGE CHIP_1x3_ICOVL_Virtual_Pre2) CHIP_1x3_ICOVL_Virtual_Pre1 < ICOVL_R_8_0_X ABUT == 90 REGION INTERSECTING ONLY MEASURE ALL
CHIP_1x3_ICOVL_Virtual_Corner_EXT = EXTENTS CHIP_1x3_ICOVL_Virtual_Corner
CHIP_1x3_ICOVL_Virtual_Pre3 = EXPAND EDGE (ANGLE (CHIP_1x3_ICOVL_Virtual_Corner_EXT NOT COIN EDGE CHIP_1x3) == 0) INSIDE BY ICOVL_R_8_0_X-ICOVL_R_8_0_Y
CHIP_1x3_ICOVL_Virtual = CHIP_1x3_ICOVL_Virtual_Corner_EXT NOT CHIP_1x3_ICOVL_Virtual_Pre3

CHIP_3x1_ICOVL_Virtual_Pre1 = GROW (SHRINK CHIP_3x1 RIGHT BY ICOVL_R_8_0_S3 LEFT BY ICOVL_R_8_0_S3) TOP BY 1
CHIP_3x1_ICOVL_Virtual_Pre2 = CHIP_3x1_ICOVL_Virtual_Pre1 NOT CHIP_3x1
CHIP_3x1_ICOVL_Virtual_Corner = INT (CHIP_3x1 COIN EDGE CHIP_3x1_ICOVL_Virtual_Pre2) CHIP_3x1_ICOVL_Virtual_Pre1 < ICOVL_R_8_0_X ABUT == 90 REGION INTERSECTING ONLY MEASURE ALL
CHIP_3x1_ICOVL_Virtual_Corner_EXT = EXTENTS CHIP_3x1_ICOVL_Virtual_Corner
CHIP_3x1_ICOVL_Virtual_Pre3 = EXPAND EDGE (ANGLE (CHIP_3x1_ICOVL_Virtual_Corner_EXT NOT COIN EDGE CHIP_3x1) == 0) INSIDE BY ICOVL_R_8_0_X-ICOVL_R_8_0_Y
CHIP_3x1_ICOVL_Virtual = CHIP_3x1_ICOVL_Virtual_Corner_EXT NOT CHIP_3x1_ICOVL_Virtual_Pre3

// ICOVL.R.8.0 is checked by related rules

ICOVL_A_center  = EXTENTS ICOVL_A  CENTERS 10
ICOVL_B_center  = EXTENTS ICOVL_B  CENTERS 10
ICOVL_C_center  = EXTENTS ICOVL_C  CENTERS 10
ICOVL_E_center  = EXTENTS ICOVL_E  CENTERS 10
ICOVL_D_center  = EXTENTS ICOVL_D  CENTERS 10

ICOVL_center_1 = OR ICOVL_A_center ICOVL_B_center ICOVL_D_center
ICOVL_center_2 = OR ICOVL_A_center ICOVL_C_center ICOVL_E_center


ICOVL.R.8.1 { @ Only one polygon is allowed in Prime Chip by {{ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual} SIZING 6500 um (X2)} for 1X1 or 1X2 or 1X3 or 2X2 die Only one polygon is allowed in Prime Chip by {{ICOVL_A_Center OR ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual} SIZING 6500 um (X2)} for 1X1 or 1X2 or 1X3 or 2X2 die   
  CHIP_1x1 INTERACT (SIZE (ICOVL_center_1 OR CHIP_1x1_ICOVL_Virtual) BY ICOVL_R_8_1) > 1
  CHIP_1x2 INTERACT (SIZE (ICOVL_center_1 OR CHIP_1x2_ICOVL_Virtual) BY ICOVL_R_8_1) > 1
  CHIP_1x3 INTERACT (SIZE (ICOVL_center_1 OR CHIP_1x3_ICOVL_Virtual) BY ICOVL_R_8_1) > 1
  CHIP_2x2 INTERACT (SIZE (ICOVL_center_1 OR CHIP_2x2_ICOVL_Virtual) BY ICOVL_R_8_1) > 1

  CHIP_1x1 INTERACT (SIZE (ICOVL_center_2 OR CHIP_1x1_ICOVL_Virtual) BY ICOVL_R_8_1) > 1
  CHIP_1x2 INTERACT (SIZE (ICOVL_center_2 OR CHIP_1x2_ICOVL_Virtual) BY ICOVL_R_8_1) > 1
  CHIP_1x3 INTERACT (SIZE (ICOVL_center_2 OR CHIP_1x3_ICOVL_Virtual) BY ICOVL_R_8_1) > 1
  CHIP_2x2 INTERACT (SIZE (ICOVL_center_2 OR CHIP_2x2_ICOVL_Virtual) BY ICOVL_R_8_1) > 1
}
ICOVL.R.8.2 { @ Only one polygon is allowed in Prime Chip by {{ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual} SIZING 8000 um (X2)} for 2X1 die or 3X1 die Only one polygon is allowed in Prime Chip by {{ICOVL_A_Center OR ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual} SIZING 8000 um (X2)} for 2X1 die or 3X1 die   
  CHIP_2x1 INTERACT (SIZE (ICOVL_center_1 OR CHIP_2x1_ICOVL_Virtual) BY ICOVL_R_8_2) > 1
  CHIP_3x1 INTERACT (SIZE (ICOVL_center_1 OR CHIP_3x1_ICOVL_Virtual) BY ICOVL_R_8_2) > 1
  CHIP_2x1 INTERACT (SIZE (ICOVL_center_2 OR CHIP_2x1_ICOVL_Virtual) BY ICOVL_R_8_2) > 1
  CHIP_3x1 INTERACT (SIZE (ICOVL_center_2 OR CHIP_3x1_ICOVL_Virtual) BY ICOVL_R_8_2) > 1
}
ICOVL.R.8.3 { @ Maximum {ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual} space of 1X1 die Maximum {ICOVL_A_Center OR ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual} space of 1X1 die DRC check: {{Prime Chip NOT {ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual}} SIZING down/up 8000 um (X4)} {{Prime Chip NOT {ICOVL_A_Center ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual}} SIZING down/up 8000 um (X4)} <= 16000 
  SIZE (CHIP_1x1 NOT (ICOVL_center_1 OR CHIP_1x1_ICOVL_Virtual)) BY ICOVL_R_8_3/2 UNDEROVER
  SIZE (CHIP_1x1 NOT (ICOVL_center_2 OR CHIP_1x1_ICOVL_Virtual)) BY ICOVL_R_8_3/2 UNDEROVER
}
ICOVL.R.8.4 { @ Maximum {ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual} space of 1X2 die or 2X1 die or 2X2 die Maximum {ICOVL_A_Center OR ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual} space of 1X2 die or 2X1 die or 2X2 die DRC check: {{Prime Chip NOT {ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual}} SIZING down/up 6000 um (X4)} {{Prime Chip NOT {ICOVL_A_Center OR ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual}} SIZING down/up 6000 um (X4)} <= 12000 
  SIZE (CHIP_1x2 NOT (ICOVL_center_1 OR CHIP_1x2_ICOVL_Virtual)) BY ICOVL_R_8_4/2 UNDEROVER    
  SIZE (CHIP_2x1 NOT (ICOVL_center_1 OR CHIP_2x1_ICOVL_Virtual)) BY ICOVL_R_8_4/2 UNDEROVER    
  SIZE (CHIP_2x2 NOT (ICOVL_center_1 OR CHIP_2x2_ICOVL_Virtual)) BY ICOVL_R_8_4/2 UNDEROVER
  SIZE (CHIP_1x2 NOT (ICOVL_center_2 OR CHIP_1x2_ICOVL_Virtual)) BY ICOVL_R_8_4/2 UNDEROVER    
  SIZE (CHIP_2x1 NOT (ICOVL_center_2 OR CHIP_2x1_ICOVL_Virtual)) BY ICOVL_R_8_4/2 UNDEROVER    
  SIZE (CHIP_2x2 NOT (ICOVL_center_2 OR CHIP_2x2_ICOVL_Virtual)) BY ICOVL_R_8_4/2 UNDEROVER
}
ICOVL.R.8.5 { @ Maximum {ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual} space of 1X3 die Maximum {ICOVL_A_Center OR ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual} space of 1X3 die DRC check: {{Prime Chip NOT {{ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual} SIZING 11000 um in V direction (X7)}} SIZING down/up 5000 um in H direction (X5)} {{Prime Chip NOT {{ICOVL_A_Center OR ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual} SIZING 11000 um in V direction (X7)}} SIZING down/up 5000 um in H direction (X5)} <= 10000 
  A = GROW (ICOVL_center_1 OR CHIP_1x3_ICOVL_Virtual) TOP BY ICOVL_R_8_5_S BOTTOM BY ICOVL_R_8_5_S
  GROW (SHRINK (CHIP_1x3 NOT A) RIGHT BY ICOVL_R_8_5/2 LEFT BY ICOVL_R_8_5/2) RIGHT BY ICOVL_R_8_5/2 LEFT BY ICOVL_R_8_5/2    
  B = GROW (ICOVL_center_2 OR CHIP_1x3_ICOVL_Virtual) TOP BY ICOVL_R_8_5_S BOTTOM BY ICOVL_R_8_5_S
  GROW (SHRINK (CHIP_1x3 NOT B) RIGHT BY ICOVL_R_8_5/2 LEFT BY ICOVL_R_8_5/2) RIGHT BY ICOVL_R_8_5/2 LEFT BY ICOVL_R_8_5/2    
}
ICOVL.R.8.6 { @ Maximum {ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual} space of 3X1 die Maximum {ICOVL_A_Center OR ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual} space of 3X1 die DRC check: {{Prime Chip NOT {{ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual} SIZING 8600 um in H direction (X8)}} SIZING down/up 6000 um in V direction (X6)} {{Prime Chip NOT {{ICOVL_A_Center OR ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual} SIZING 8600 um in H direction (X8)}} SIZING down/up 6000 um in V direction (X6)} <= 12000 
  A = GROW (ICOVL_center_1 OR CHIP_3x1_ICOVL_Virtual) RIGHT BY ICOVL_R_8_6_S LEFT BY ICOVL_R_8_6_S
  GROW (SHRINK (CHIP_3x1 NOT A) TOP BY ICOVL_R_8_6/2 BOTTOM BY ICOVL_R_8_6/2) TOP BY ICOVL_R_8_6/2 BOTTOM BY ICOVL_R_8_6/2
  B = GROW (ICOVL_center_2 OR CHIP_3x1_ICOVL_Virtual) RIGHT BY ICOVL_R_8_6_S LEFT BY ICOVL_R_8_6_S
  GROW (SHRINK (CHIP_3x1 NOT B) TOP BY ICOVL_R_8_6/2 BOTTOM BY ICOVL_R_8_6/2) TOP BY ICOVL_R_8_6/2 BOTTOM BY ICOVL_R_8_6/2
}
ICOVL.R.8.7 { @ Density of {{{ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual} SIZING 16500 um (X2)} SIZING -15500 um (X3)} for 1X1 die or 3X1 die Density of {{{ICOVL_A_Center OR ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual} SIZING 16500 um (X2)} SIZING -15500 um (X3)} for 1X1 die or 3X1 die >= 25% 
  A1 = SIZE (SIZE (ICOVL_center_1 OR CHIP_1x1_ICOVL_Virtual) BY ICOVL_R_8_7_S1) BY -ICOVL_R_8_7_S2  
  DENSITY A1 < ICOVL_R_8_7 INSIDE OF LAYER CHIP_1x1 PRINT ICOVL.R.8.7.CHIP_1x1.density RDB ICOVL.R.8.7.CHIP_1x1.RDB.density
  A2 = SIZE (SIZE (ICOVL_center_1 OR CHIP_3x1_ICOVL_Virtual) BY ICOVL_R_8_7_S1) BY -ICOVL_R_8_7_S2  
  DENSITY A2 < ICOVL_R_8_7 INSIDE OF LAYER CHIP_3x1 PRINT ICOVL.R.8.7.CHIP_3x1.density RDB ICOVL.R.8.7.CHIP_3x1.RDB.density

  B1 = SIZE (SIZE (ICOVL_center_2 OR CHIP_1x1_ICOVL_Virtual) BY ICOVL_R_8_7_S1) BY -ICOVL_R_8_7_S2  
  DENSITY B1 < ICOVL_R_8_7 INSIDE OF LAYER CHIP_1x1 PRINT ICOVL.R.8.7.CHIP_1x1_2.density  RDB ICOVL.R.8.7.CHIP_1x1.RDB.density
  B2 = SIZE (SIZE (ICOVL_center_2 OR CHIP_3x1_ICOVL_Virtual) BY ICOVL_R_8_7_S1) BY -ICOVL_R_8_7_S2  
  DENSITY B2 < ICOVL_R_8_7 INSIDE OF LAYER CHIP_3x1 PRINT ICOVL.R.8.7.CHIP_3x1_2.density RDB ICOVL.R.8.7.CHIP_3x1.RDB.density
}
ICOVL.R.8.8 { @ Density of {{{ICOVL_A_Center OR ICOVL_B_Center OR ICOVL_D_Center OR ICOVL_virtual} SIZING 13000 um (X2)} SIZING -10000 um (X3)} for 1X2 die or 2X1 die or 2X2 die or 1X3 die Density of {{{ICOVL_A_Center OR ICOVL_C_Center OR ICOVL_E_Center OR ICOVL_virtual} SIZING 13000 um (X2)} SIZING -10000 um (X3)} for 1X2 die or 2X1 die or 2X2 die or 1X3 die >= 25% 
  A1 = SIZE (SIZE (ICOVL_center_1 OR CHIP_1x2_ICOVL_Virtual) BY ICOVL_R_8_8_S1) BY -ICOVL_R_8_8_S2  
  DENSITY A1 < ICOVL_R_8_8 INSIDE OF LAYER CHIP_1x2 PRINT ICOVL.R.8.8.CHIP_1x2.density RDB ICOVL.R.8.8.CHIP_1x2.RDB.density   
  A2 = SIZE (SIZE (ICOVL_center_1 OR CHIP_2x1_ICOVL_Virtual) BY ICOVL_R_8_8_S1) BY -ICOVL_R_8_8_S2  
  DENSITY A2 < ICOVL_R_8_8 INSIDE OF LAYER CHIP_2x1 PRINT ICOVL.R.8.8.CHIP_2x1.density RDB ICOVL.R.8.8.CHIP_2x1.RDB.density    
  A3 = SIZE (SIZE (ICOVL_center_1 OR CHIP_2x2_ICOVL_Virtual) BY ICOVL_R_8_8_S1) BY -ICOVL_R_8_8_S2  
  DENSITY A3 < ICOVL_R_8_8 INSIDE OF LAYER CHIP_2x2 PRINT ICOVL.R.8.8.CHIP_2x2.density RDB ICOVL.R.8.8.CHIP_2x2.RDB.density    
  A4 = SIZE (SIZE (ICOVL_center_1 OR CHIP_1x3_ICOVL_Virtual) BY ICOVL_R_8_8_S1) BY -ICOVL_R_8_8_S2  
  DENSITY A4 < ICOVL_R_8_8 INSIDE OF LAYER CHIP_1x3 PRINT ICOVL.R.8.8.CHIP_1x3.density RDB ICOVL.R.8.8.CHIP_1x3.RDB.density
  
  B1 = SIZE (SIZE (ICOVL_center_2 OR CHIP_1x2_ICOVL_Virtual) BY ICOVL_R_8_8_S1) BY -ICOVL_R_8_8_S2  
  DENSITY B1 < ICOVL_R_8_8 INSIDE OF LAYER CHIP_1x2 PRINT ICOVL.R.8.8.CHIP_1x2_2.density RDB ICOVL.R.8.8.CHIP_1x2.RDB.density    
  B2 = SIZE (SIZE (ICOVL_center_2 OR CHIP_2x1_ICOVL_Virtual) BY ICOVL_R_8_8_S1) BY -ICOVL_R_8_8_S2  
  DENSITY B2 < ICOVL_R_8_8 INSIDE OF LAYER CHIP_2x1 PRINT ICOVL.R.8.8.CHIP_2x1_2.density RDB ICOVL.R.8.8.CHIP_2x1.RDB.density   
  B3 = SIZE (SIZE (ICOVL_center_2 OR CHIP_2x2_ICOVL_Virtual) BY ICOVL_R_8_8_S1) BY -ICOVL_R_8_8_S2  
  DENSITY B3 < ICOVL_R_8_8 INSIDE OF LAYER CHIP_2x2 PRINT ICOVL.R.8.8.CHIP_2x2_2.density RDB ICOVL.R.8.8.CHIP_2x2.RDB.density  
  B4 = SIZE (SIZE (ICOVL_center_2 OR CHIP_1x3_ICOVL_Virtual) BY ICOVL_R_8_8_S1) BY -ICOVL_R_8_8_S2  
  DENSITY B4 < ICOVL_R_8_8 INSIDE OF LAYER CHIP_1x3 PRINT ICOVL.R.8.8.CHIP_1x3_2.density RDB ICOVL.R.8.8.CHIP_1x3.RDB.density
}

ICOVL.R.8.9 { @ Density of ICOVL_set inside each Effective_Quadrant_of_Chip for 1x1 die Definition of Effective_Quadant_of_Chip: 1. Cx and Cy are dimension of (Prime Chip with SEALRING_ALL) = (Prime Chip + 2* 24 um) in H and V respectively 2. Every quadrant of {{(Prime Chip with SEALRING_ALL) SIZING -Cx/8 in horizontal direction} SIZING -Cy/8 in vertical direction} = 100% 
  (TILE_LT_8 INTERACT CHIP_1x1) NOT ENCLOSE ICOVL_set
  (TILE_RT_8 INTERACT CHIP_1x1) NOT ENCLOSE ICOVL_set
  (TILE_LB_8 INTERACT CHIP_1x1) NOT ENCLOSE ICOVL_set
  (TILE_RB_8 INTERACT CHIP_1x1) NOT ENCLOSE ICOVL_set
}

ICOVL.R.8.10 { @ tsmc uses 165;90, 165;100~120, 165;124~129, 165;164~183, 165;190~200, 165;213~254 layers to do pattern replacement.Your chip is not allowed to have these layers   
COPY NOUSE_ICOVL
}

#IFDEF WITH_SEALRING
CHIP_ICOVL = COPY CHIP
#ELSE
CHIP_ICOVL = SIZE CHIP BY 0.024*1000
#ENDIF

SHIFT_CHIPx_LEFT  = SHIFT CHIP_ICOVL BY (-1)  0
SHIFT_CHIPx_RIGHT = SHIFT CHIP_ICOVL BY   1   0
SHIFT_CHIPx_TOP   = SHIFT CHIP_ICOVL BY   0   1
SHIFT_CHIPx_DOWN  = SHIFT CHIP_ICOVL BY   0 (-1)

CHIPx_E_LEFT  = CHIP_ICOVL INSIDE EDGE SHIFT_CHIPx_LEFT
CHIPx_E_RIGHT = CHIP_ICOVL INSIDE EDGE SHIFT_CHIPx_RIGHT
CHIPx_E_TOP   = CHIP_ICOVL INSIDE EDGE SHIFT_CHIPx_TOP
CHIPx_E_DOWN  = CHIP_ICOVL INSIDE EDGE SHIFT_CHIPx_DOWN

CHIPx_REC_LEFT  = EXPAND EDGE CHIPx_E_LEFT  OUTSIDE BY 0.01 INSIDE BY 0.01
CHIPx_REC_RIGHT = EXPAND EDGE CHIPx_E_RIGHT OUTSIDE BY 0.01 INSIDE BY 0.01
CHIPx_REC_TOP   = EXPAND EDGE CHIPx_E_TOP   OUTSIDE BY 0.01 INSIDE BY 0.01
CHIPx_REC_DOWN  = EXPAND EDGE CHIPx_E_DOWN  OUTSIDE BY 0.01 INSIDE BY 0.01

CHIPx_SQR_LEFT  = EXTENTS CHIPx_REC_LEFT  SQUARES
CHIPx_SQR_RIGHT = EXTENTS CHIPx_REC_RIGHT SQUARES
CHIPx_SQR_TOP   = EXTENTS CHIPx_REC_TOP   SQUARES
CHIPx_SQR_DOWN  = EXTENTS CHIPx_REC_DOWN  SQUARES

CHIPx_EDGE_LEFT  = CHIPx_SQR_LEFT  TOUCH INSIDE EDGE CHIPx_E_TOP
CHIPx_EDGE_RIGHT = CHIPx_SQR_RIGHT TOUCH INSIDE EDGE CHIPx_E_TOP
CHIPx_EDGE_TOP   = CHIPx_SQR_TOP   TOUCH INSIDE EDGE CHIPx_E_LEFT
CHIPx_EDGE_DOWN  = CHIPx_SQR_DOWN  TOUCH INSIDE EDGE CHIPx_E_LEFT

s_TILE_LEFT_V  = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_LEFT  INSIDE BY FACTOR EXPAND_3_S)
e_TILE_LEFT_V  = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_LEFT  INSIDE BY FACTOR EXPAND_3_E) NOT s_TILE_LEFT_V)
s_TILE_RIGHT_V = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_RIGHT  INSIDE BY FACTOR EXPAND_3_S)
e_TILE_RIGHT_V = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_RIGHT  INSIDE BY FACTOR EXPAND_3_E) NOT s_TILE_RIGHT_V)
TILE_V_X = EXTENT (e_TILE_LEFT_V OR e_TILE_RIGHT_V)

s_TILE_TOP_V   = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_TOP  INSIDE BY FACTOR EXPAND_6_S)
e_TILE_TOP_V   = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_TOP  INSIDE BY FACTOR EXPAND_6_E) NOT s_TILE_TOP_V)
s_TILE_DOWN_V  = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_DOWN  INSIDE BY FACTOR EXPAND_6_S)
e_TILE_DOWN_V  = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_DOWN  INSIDE BY FACTOR EXPAND_6_E) NOT s_TILE_DOWN_V)
TILE_V_Y = EXTENT (e_TILE_TOP_V OR e_TILE_DOWN_V)

TILE_V = TILE_V_X AND TILE_V_Y

s_TILE_LEFT_H   = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_LEFT  INSIDE BY FACTOR EXPAND_6_S)
e_TILE_LEFT_H   = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_LEFT  INSIDE BY FACTOR EXPAND_6_E) NOT s_TILE_LEFT_H)
s_TILE_RIGHT_H  = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_RIGHT  INSIDE BY FACTOR EXPAND_6_S)
e_TILE_RIGHT_H  = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_RIGHT  INSIDE BY FACTOR EXPAND_6_E) NOT s_TILE_RIGHT_H)
TILE_H_X = EXTENT (e_TILE_LEFT_H OR e_TILE_RIGHT_H)

s_TILE_TOP_H   = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_TOP  INSIDE BY FACTOR EXPAND_3_S)
e_TILE_TOP_H   = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_TOP  INSIDE BY FACTOR EXPAND_3_E) NOT s_TILE_TOP_H)
s_TILE_DOWN_H  = CHIP_ICOVL AND (EXPAND EDGE CHIPx_EDGE_DOWN  INSIDE BY FACTOR EXPAND_3_S)
e_TILE_DOWN_H  = CHIP_ICOVL AND ((EXPAND EDGE CHIPx_EDGE_DOWN  INSIDE BY FACTOR EXPAND_3_E) NOT s_TILE_DOWN_H)
TILE_H_Y = EXTENT (e_TILE_TOP_H OR e_TILE_DOWN_H)

TILE_H = TILE_H_X AND TILE_H_Y
ICOVL_CENTRAL_REGION = TILE_V OR TILE_H

#IFDEF FULL_CHIP

ICOVL.R.9 { @ At least one ICOVL_set must be placed inside Central_Region for 1X1 die in chip level The definition of Central_Region: 1. Cx and Cy are dimension of (Prime Chip with SEALRING_ALL) = (Prime Chip + 2* 24 um) in H and V respectively 2. Find Chip_Center by (Cx/2, Cy/2) 3. Central_Region = {{{Chip_Center SIZING Cx/3 in horizontal direction} SIZING up Cy/6 in vertical direction} OR {{Chip_Center SIZING Cx/6 in horizontal direction} SIZING Cy/3 in vertical direction}}   
  MERGE ((ICOVL_CENTRAL_REGION NOT ENCLOSE ICOVL_set) INTERACT CHIP_1x1)
}
#ENDIF

ICOVL.R.10 { @ {ICOVL_A OR ICOVL_B OR ICOVL_C OR ICOVL_D OR ICOVL_E} and ICOVL must be drawn identically   
ICOVL XOR (OR ICOVL_A ICOVL_B ICOVL_C ICOVL_D ICOVL_E)
}




#IFDEF FULL_CHIP
MFU.R.1 {@ Mask Field Utilization (MFU) is a ratio of mask utilized region which is calculated by (multiple die area + scribe_line area) / (scanner maximum field area) >= 80% 


MFU_RATIO = DFM PROPERTY CHIP_P
   [ DIE_SIZE_X = PROPERTY(CHIP_P,W)]
   [ DIE_SIZE_Y = PROPERTY(CHIP_P,H)]
   [ DIE_COUNT_X = PROPERTY(CHIP_P,Rx)]
   [ DIE_COUNT_Y = PROPERTY(CHIP_P,Ry)]
   [ DIE_COUNT = PROPERTY(CHIP_P,Rx)*PROPERTY(CHIP_P,Ry)]
   [ RATIO = (PROPERTY(CHIP_P,Rx) * (PROPERTY(CHIP_P,W) + WSx) + WSx) * (PROPERTY(CHIP_P,Ry) * (PROPERTY(CHIP_P,H) + WSy) + WSy) / (MASK_X * MASK_Y) ]
   DFM PROPERTY MFU_RATIO [-= PROPERTY(MFU_RATIO,RATIO) ] < MFU_R_1
   DFM RDB MFU_RATIO MFU.R.1.rep NOEMPTY
}
MFU.W.1__MFU.W.1.1 { @ Maximum width of Prime Chip with SEALRING_ALL in horizontal direction	<=	26000-Sx*2
                     @ Maximum width of Prime Chip with SEALRING_ALL	<=	33000-Sy*2  
					 @ Definition of prime chip with sealring: (Prime Chip*0.855 + 2* 21.09 um) or ((Prime Chip + 2* 24)*0.855 um) depend on sealrind added by TSMC or customer
  MFU_CHK = DFM PROPERTY CHIP_P
   [ X = PROPERTY(CHIP_P,W)*1000]
   [ Y = PROPERTY(CHIP_P,H)*1000]
  DFM PROPERTY MFU_CHK [-= PROPERTY(MFU_CHK,X) ] > MFU_W_1
  DFM PROPERTY MFU_CHK [-= PROPERTY(MFU_CHK,Y) ] > MFU_W_1_1
}
#ENDIF 




#IFDEF M1_V1_M2_CHECKS
//DUMMY M1 CHECKS
//==================

DM1.W.1 { @ Width of DMx >=  
  INT DUM1 < DM1_W_1 ABUT < 90 SINGULAR REGION
}
DM1.W.2 { @ Maximum width of {DMx OR DMx_O} (checked by sizing down 1.5 um) <= 3 
  SIZE DUM1 BY DM1_W_2 /2 UNDEROVER
  SIZE DM1_O BY DM1_W_2 /2 UNDEROVER
}
DM1.S.1 { @ DMx space to DMx >=  
  EXT DUM1 < DM1_S_1 ABUT < 90 SINGULAR REGION
}
DM1.S.2 { @ DMx space to Mx (overlap is not allowed) >=  
  DUM1a = DUM1 WITH WIDTH <= 1
  DUM1b = DUM1 WITH WIDTH >  1	
  EXT M1 DUM1a < DM1_S_2A ABUT < 90 SINGULAR REGION
  EXT M1 DUM1b < DM1_S_2B ABUT < 90 SINGULAR REGION
  M1 AND DUM1
}
// 'DMx.S.3.1' is checked by DM1.S.3.1
DM1.S.3.1 { @ DMx space to Mx (overlap is not allowed) [Mx width > 1.5 um and the parallel metal run length > 1.5 um] >= 0.5 
  X = EXT M1Wide_1.5 DUM1 < DM1_S_3_1 OPPOSITE REGION MEASURE ALL
  ENCLOSE RECTANGLE X 0.001 DM1_S_3_1_L+0.001
}


DM1.A.1 { @ Minimum area of DMx >=  
  AREA DUM1 < DM1_A_1 
}
DM1.A.2 { @ Maximum area of {DMx OR DMx_O} <=  
  AREA DUM1 > DM1_A_2 
  AREA DM1_O > DM1_A_2 
}




//'Mx.DN.0' is checked by [M1.DN.2 ~ M1.DN.3]

#IFDEF FULL_CHIP
// 'DM1.R.1' is checked by DM1.R.1
DM1.R.1 { @ DM1 is a must. The DM1 CAD layer must be different from the M1 CAD layer   
  MERGE (CHIP NOT INTERACT DUM1)
}
#ENDIF


