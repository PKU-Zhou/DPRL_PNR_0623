         [ !AREA(F_A)+AREA(M7_CHECK)/AREA(CHIP_CHECK) ]
  X NOT excludeRRuleRecommended	 
  // Condition-B 
  ERR_WIN_B = DENSITY M7_CHECK CHIP_CHECK < M7_DN_6_R WINDOW M7_DN_6_W_BC_R STEP M7_DN_6_S_BC_R INSIDE OF LAYER CHIP_M7 BACKUP 
	[ AREA(M7_CHECK)/AREA(CHIP_CHECK) ]
  F_B = WITH WIDTH (ERR_WIN_B NOT (NEW_DEN_EXC OR ICOVL)) >= M7_DN_6_E_BC_R
  A = DENSITY F_B M7_CHECK CHIP_CHECK < M7_DN_6_R WINDOW M7_DN_6_W_BC_R STEP M7_DN_6_S_BC_R INSIDE OF LAYER CHIP_M7 BACKUP PRINT M7.DN.6R_BC.density
         [ !AREA(F_B)+AREA(M7_CHECK)/AREA(CHIP_CHECK) ]
