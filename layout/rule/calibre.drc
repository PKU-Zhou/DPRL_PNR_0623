  EXT POST_DRIVER_PINJ_NW_18V BESIDE_POST_DRIVER_NMOS_PW_NG < LUP_5_2_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_PINJ_NW_18V BESIDE_POST_DRIVER_NMOS_RW_NG < LUP_5_2_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_PINJ_NWi_18V BESIDE_POST_DRIVER_NMOS_RWi_NG < LUP_5_2_2 ABUT < 90 SINGULAR NOT CONNECTED
