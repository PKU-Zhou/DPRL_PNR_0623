  M6_TypeBRS3_CACB_S45_3 = EXT [M6_TypeBRS3_CACB_S3_7] M6i < TypeBRS3_S5 OPPOSITE EXTENDED GRID
  M6_TypeBRS3_CACB_S45_4 = EXT [M6_TypeBRS3_CACB_S45_2] M6i < TypeBRS3_S4 OPPOSITE
  M6_TypeBRS3_CACB_S45_5 = (EXPAND EDGE (M6_TypeBRS3_CACB_S45_1 COIN EDGE M6_TypeBRS3_CACB_S3_15) INSIDE BY 2*GRID) OR M6_TypeBRS3_CACB_S45_1
  M6_TypeBRS3_CACB_S45_6 = (M6_TypeBRS3_CACB_S45_5 NOT COIN EDGE M6i) NOT COIN EDGE M6_TypeBRS3_CACB_S3_15
  M6_TypeBRS3_CACB_S45_7 = ENC M6i [M6_TypeBRS3_CACB_S45_6] == 2*GRID OPPOSITE
  M6_TypeBRS3_CACB_S45_8 = (EXPAND EDGE M6_TypeBRS3_CACB_S45_7 OUTSIDE BY TypeBRS3_S5-2*GRID) OR M6_TypeBRS3_CACB_S45_5 
  M6_TypeBRS3_CACB_S45_9 = LENGTH M6_TypeBRS3_CACB_S45_8  >= TypeBRS3_S5 <= 2*TypeBRS3_S5
  M6_TypeBRS3_CACB_S45_10_1 = M6_TypeBRS3_CACB_S45_9 TOUCH EDGE M6_TypeBRS3_CACB_S3_15
  M6_TypeBRS3_CACB_S45_10_2 = ENC M6i [M6_TypeBRS3_CACB_S45_10_1] < TypeBRS3_S4 OPPOSITE
  M6_TypeBRS3_CACB_S45_10_3 = M6_TypeBRS3_CACB_S45_10_1 TOUCH EDGE M6_TypeBRS3_CACB_S45_10_2 
  M6_TypeBRS3_CACB_S45_10 = M6_TypeBRS3_CACB_S45_10_1 NOT TOUCH EDGE M6_TypeBRS3_CACB_S45_10_2 
  M6_TypeBRS3_CACB_S45_11 = EXPAND EDGE M6_TypeBRS3_CACB_S45_10 INSIDE BY TypeBRS3_S4
  M6_TypeBRS3_CACB_S45_12 = M6_TypeBRS3_CACB_S45_11 INTERACT (M6_TypeBRS3_CACB_S45_11 AND M6i)
  M6_TypeBRS3_CACB_BOXB_waive = (((M6_TypeBRS3_CACB_S45_5 WITH EDGE M6_TypeBRS3_CACB_S45_3) OR (M6_TypeBRS3_CACB_S45_5 WITH EDGE M6_TypeBRS3_CACB_S45_4)) OR (M6_TypeBRS3_CACB_S45_5 INTERACT M6_TypeBRS3_CACB_S45_12)) OR (M6_TypeBRS3_CACB_S45_5 WITH EDGE M6_TypeBRS3_CACB_S45_10_3)
  
  M6_TypeBRS3_CACB_BOXAC_1 = (EXPAND EDGE (M6i COIN EDGE M6_TypeBRS3_CACB_BOXB_waive) INSIDE BY 2*GRID) OR M6_TypeBRS3_CACB_BOXB_waive
  M6_TypeBRS3_CACB_BOXAC_2 = M6_TypeBRS3_CACB_S6_7 NOT INTERACT M6_TypeBRS3_CACB_BOXAC_1 
  M6_TypeBRS3_CACB_BOXAC_3 = M6_TypeBRS3_CACB_S3_9 COIN EDGE M6_TypeBRS3_CACB_BOXAC_2
  M6_TypeBRS3_CACB_BOXAC_4 = M6_TypeBRS3_CACB_S3_10 COIN EDGE M6_TypeBRS3_CACB_BOXAC_2
  M6_TypeBRS3_CACB_BOXAC_5_1 = EXPAND EDGE M6_TypeBRS3_CACB_BOXAC_3 OUTSIDE BY TypeBRS3_S3
  M6_TypeBRS3_CACB_BOXAC_5 = M6_TypeBRS3_CACB_BOXAC_5_1 WITH EDGE ((M6_TypeBRS3_CACB_BOXAC_5_1 AND M6i) COIN EDGE M6_TypeBRS3_CACB_BOXAC_5_1) == 4
  M6_TypeBRS3_CACB_BOXAC_6_1 = EXPAND EDGE M6_TypeBRS3_CACB_BOXAC_4 OUTSIDE BY TypeBRS3_S3-GRID
  M6_TypeBRS3_CACB_BOXAC_6 = M6_TypeBRS3_CACB_BOXAC_6_1 WITH EDGE ((M6_TypeBRS3_CACB_BOXAC_6_1 AND M6i) COIN EDGE M6_TypeBRS3_CACB_BOXAC_6_1) == 4
  M6_TypeBRS3_CACB_BOXAC_7 = ((M6_TypeBRS3_CACB_BOXAC_2 INTERACT M6_TypeBRS3_CACB_BOXAC_5) INTERACT M6_TypeBRS3_CACB_BOXAC_6) OR (M6_TypeBRS3_CACB_BOXAC_5 OR M6_TypeBRS3_CACB_BOXAC_6)
  M6_TypeBRS3_CACB_BOXAC_8 = (M6_TypeBRS3_CACB_BOXAC_7 AND M6i) COIN EDGE M6_TypeBRS3_CACB_BOXAC_7
  M6_TypeBRS3_CACB_BOXAC_9 = INT [M6_TypeBRS3_CACB_BOXAC_8] <= 4*TypeBRS3_S3+2*TypeBRS3_S6+2*GRID OPPOSITE
  M6_TypeBRS3_CACB_BOXAC_10 = ENCLOSE RECTANGLE (M6_TypeBRS3_CACB_BOXAC_7 WITH EDGE M6_TypeBRS3_CACB_BOXAC_9  == 4) TypeBRS3_S2 2*TypeBRS3_S3
  M6_TypeBRS3_CACB_BOXAC_11 = VERTEX (M6_TypeBRS3_CACB_BOXAC_10 AND M6i) != 4
  M6_TypeBRS3_CACB_BOXAC_12 = M6_TypeBRS3_CACB_BOXAC_10 NOT INTERACT M6_TypeBRS3_CACB_BOXAC_11
  M6_TypeBRS3_CACB_BOXC = M6_TypeBRS3_CACB_BOXAC_2 INSIDE M6_TypeBRS3_CACB_BOXAC_12
  M6_TypeBRS3_CACB_MARK = EXT (M6_TypeBRS3_CACB_BOXC AND M6i) <= Mx_S OPPOSITE REGION
  M6_TypeBRS3_CACB_MARK INTERACT EFPM6S7_M6i
}
#ENDIF
#ENDIF
#IFDEF CHECK_EFPM6EN1_
#IFDEF _EFPM6EN1_
EFPM6EN1_M6iCellIn = INSIDE CELL M6i CellsForRRuleRecommended  
EFPM6EN1_M6iCellOut = NOT INSIDE CELL M6i ExclCellsForRRuleRecommended 
EFPM6EN1_M6iCell = EFPM6EN1_M6iCellIn AND EFPM6EN1_M6iCellOut
EFPM6EN1_M6iMarker = M6i AND RRuleRecommended
EFPM6EN1_M6i = ((EFPM6EN1_M6iCell OR EFPM6EN1_M6iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M6.EN.1 { @ Mx/VIAx-1 recommendation: Recommended Mx_A enclosure VIAx-1 [in {VIAx-1 AND Mx_A} space to Mx (SP3+SE) <= 0.06 um side] Definition of Mx_A: Mx with consecutive edge length (L1) <= 0.12 um, (L2) <= 0.06 um, (L3) >= 0.1 um, L1/L3 edge is between 2 outer vertex. L1/L3 space to adjacent Mx (SP3/SP4) = 0.05 um [parallel run length > 0 from VIAx-1] >= 0.01 
   L1_pre = CONVEX EDGE EFPM6EN1_M6i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L2 LENGTH2>=EFP_Mx_EN_1_L3 WITH LENGTH<=EFP_Mx_EN_1_L1
   L2_pre = CONVEX EDGE EFPM6EN1_M6i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH<=EFP_Mx_EN_1_L2
   L3_pre = CONVEX EDGE EFPM6EN1_M6i ANGLE1==90 ANGLE2>=90 <=270 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH>=EFP_Mx_EN_1_L3
   L1_L2_V = INT L1_pre L2_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1_L3_V = INT L1_pre L3_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1 = (L1_pre TOUCH INSIDE EDGE L1_L2_V) TOUCH INSIDE EDGE L1_L3_V
   L3 = L3_pre TOUCH INSIDE EDGE (L1_L3_V WITH EDGE L1)
   L1_DENSE = EXT [L1] M6 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA5_L1_DENSE = VIA5i TOUCH INSIDE EDGE (ENC [VIA5i] L1_DENSE < EFP_Mx_EN_1_SE ABUT<90 OPPOSITE)
   L3_DENSE = EXT [L3] M6 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA5_L3_DENSE = VIA5i TOUCH INSIDE EDGE (ENC [VIA5i] L3_DENSE <= EFP_Mx_EN_1_L1-VIA5_W_1-VIA5_EN_2 ABUT<90 OPPOSITE)
   X = INT VIA5_L1_DENSE VIA5_L3_DENSE <= GRID ABUT==90 INTERSECTING ONLY REGION
   VIA5i INTERACT X  
}
// EFP.Mx.EN.1.R is checked by RR:RE:EFP.M6.EN.1
#ENDIF
#ENDIF
// EFP.Mx.S.5.R is checked by RR:RE:EFP.M6.S.5
