G.4:ODi { @ Adjacent edges with length less than min. width is not allowed.
  X = LENGTH ODi < OD_W_1
  ShortExp = EXPAND EDGE X BY 0.01
  SmallJog = VERTEX ShortExp > 4
  ODi INSIDE EDGE SmallJog

}
G.4:NWi { @ Adjacent edges with length less than min. width is not allowed.
  X = LENGTH NWi < NW_W_1
  ShortExp = EXPAND EDGE X BY 0.01
  SmallJog = VERTEX ShortExp > 4
  NWi INSIDE EDGE SmallJog

}
G.4:OD2i { @ Adjacent edges with length less than min. width is not allowed.
  X = LENGTH OD2i < OD2_W_1
