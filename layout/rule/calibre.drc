M4S37_M4Marker = M4i AND RRuleRecommended
M4S37_M4 = ((M4S37_M4Cell OR M4S37_M4Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:M4.S.37 { @ Recommended space to Mx jog filled up region (R1A) Definition of Mx jog: Mx with length < 0.12 um (LA1), 2 adjacent edge length < 0.05 um (WA1) and < 0.06 um (WA2) [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex -90 degree outer vertex] >= 0.05 
  L1_pre = CONVEX EDGE M4S37_M4 ANGLE1==90 ANGLE2==270 LENGTH2 < 0.12 WITH LENGTH < 0.05 
  L2_pre = CONVEX EDGE M4S37_M4 ANGLE1==90 ANGLE2==270 LENGTH1 < 0.06 LENGTH2 <0.05 WITH LENGTH < 0.12
  L3_pre = CONVEX EDGE M4S37_M4 ANGLE1==90 ANGLE2==90  LENGTH1 < 0.12 WITH LENGTH < 0.06
  L1_L2_V = EXT L1_pre L2_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
  L2_L3_V = INT L2_pre L3_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
  L2 = (L2_pre TOUCH OUTSIDE EDGE L1_L2_V) TOUCH INSIDE EDGE L2_L3_V  
  L1 = L1_pre TOUCH OUTSIDE EDGE (L1_L2_V WITH EDGE L2) 
  L1_ex = EXPAND EDGE L1 OUTSIDE BY GRID
  L2_ex = EXPAND EDGE L2 OUTSIDE BY GRID
  JOG_FILL = EXTENTS (L1_ex OR L2_ex)
  S = EXT JOG_FILL M4 < 0.05 ABUT>0<90 SINGULAR REGION
  S OR (JOG_FILL INTERACT S)
}
#ENDIF
#ENDIF

