EFPM2S7_M2iMarker = M2i AND RRuleRecommended
EFPM2S7_M2i = ((EFPM2S7_M2iCell OR EFPM2S7_M2iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M2.S.7 { @ Metal bridge recommendation type-3: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3 and Region B4] when neighboring Mx (polygon3/4) with parallel run length > 0 um and there is no other Mx interact Region B1/B2 Definitions: 1. Region B3/B4 = 0.25 um * 0.09 um (L1), generated from vertex CB and CA respectively. 2. L2 = height difference of vertex CA project to vertex CB <= 0.05 um. 3. Region B1/B2 = 0.16 um * 0.115 um, generated from Mx (polygon3/4) line-end with vertex CA and CB respectively >= 0.055 
  M2_TypeBRS3_prefilter_1 = EXT [M2i] == TypeBRS3_S2 ABUT < 90 OPPOSITE
  M2_TypeBRS3_prefilter_2 = M2i TOUCH EDGE M2_TypeBRS3_prefilter_1
  M2_TypeBRS3_prefilter_3 = (M2_CORNER WITH EDGE M2_TypeBRS3_prefilter_2) COIN EDGE M2i
  
  M2_TypeBRS3_prefilter_4_1 = EXT M2_TypeBRS3_prefilter_3 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
  M2_TypeBRS3_prefilter_4_2 = M2i AND M2_TypeBRS3_prefilter_4_1
  M2_TypeBRS3_prefilter_4_3 = EXT [M2_TypeBRS3_prefilter_3] M2_TypeBRS3_prefilter_4_2 <= Mx_S OPPOSITE EXTENDED TypeBRS3_S6
  M2_TypeBRS3_prefilter_4_4 = M2_TypeBRS3_prefilter_3 TOUCH EDGE M2_TypeBRS3_prefilter_4_3 
  M2_TypeBRS3_prefilter_4_5 = EXT [M2_TypeBRS3_prefilter_3] M2_TypeBRS3_prefilter_4_2 > Mx_S+Mx_W <= 2*Mx_S+Mx_W OPPOSITE EXTENDED TypeBRS3_S6
  M2_TypeBRS3_prefilter_4_6 = M2_TypeBRS3_prefilter_4_4 TOUCH EDGE M2_TypeBRS3_prefilter_4_5
  M2_TypeBRS3_prefilter_4 =  EXT M2_TypeBRS3_prefilter_4_6 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
  M2_TypeBRS3_prefilter_5_1 = EXPAND EDGE (M2_TypeBRS3_prefilter_3 COIN EDGE M2_TypeBRS3_prefilter_4) OUTSIDE BY 2*GRID
  M2_TypeBRS3_prefilter_5_2 = INT [M2_TypeBRS3_prefilter_5_1] == GRID OPPOSITE
  M2_TypeBRS3_prefilter_5_3 = EXPAND EDGE M2_TypeBRS3_prefilter_5_2 OUTSIDE BY GRID EXTEND BY GRID
  M2_TypeBRS3_prefilter_5_4 = M2_TypeBRS3_prefilter_5_2 COIN EDGE (M2_TypeBRS3_prefilter_5_3 NOT TOUCH EDGE M2_TypeBRS3_prefilter_3)
  M2_TypeBRS3_prefilter_5_5 = EXPAND EDGE M2_TypeBRS3_prefilter_5_4 OUTSIDE BY GRID
  M2_TypeBRS3_prefilter_5 = M2_TypeBRS3_prefilter_5_1 OR M2_TypeBRS3_prefilter_5_5
  
  M2_TypeBRS3_prefilter_6 = M2_TypeBRS3_prefilter_4 NOT M2_TypeBRS3_prefilter_5
  M2_TypeBRS3_prefilter_7_1 = M2_TypeBRS3_prefilter_6 INTERACT (M2_TypeBRS3_prefilter_6 AND M2i) > 1
  M2_TypeBRS3_prefilter_7 = (M2_TypeBRS3_prefilter_5_1 INTERACT M2_TypeBRS3_prefilter_7_1) OR M2_TypeBRS3_prefilter_7_1
  M2_TypeBRS3_prefilter_8 = EXTENTS M2_TypeBRS3_prefilter_7
  
  M2_TypeBRS3_prefilter_9 = M2_TypeBRS3_prefilter_3 COIN EDGE (M2_CORNER INTERACT M2_TypeBRS3_prefilter_8)
  M2_TypeBRS3_prefilter_10 = EXT M2_TypeBRS3_prefilter_9 M2_TypeBRS3_prefilter_2 == TypeBRS3_S2 OPPOSITE REGION
  M2_TypeBRS3_prefilter_11 = M2_TypeBRS3_prefilter_10 INTERACT (M2_TypeBRS3_prefilter_10 AND M2i) > 1
  M2_TypeBRS3_prefilter_12 = (EXPAND EDGE M2_TypeBRS3_prefilter_3 OUTSIDE BY GRID) NOT INTERACT M2_TypeBRS3_prefilter_11
  M2_TypeBRS3_prefilter_13 = (EXPAND EDGE (M2_TypeBRS3_prefilter_12 NOT COIN EDGE M2i) OUTSIDE BY GRID) OR M2_TypeBRS3_prefilter_12 
  M2_TypeBRS3_prefilter_14 = M2_TypeBRS3_prefilter_11 TOUCH EDGE M2_TypeBRS3_prefilter_13
  M2_TypeBRS3_prefilter_15 = M2_TypeBRS3_prefilter_11 WITH EDGE M2_TypeBRS3_prefilter_14 == 2
  
  M2_TypeBRS3_prefilter_16 = (M2_TypeBRS3_prefilter_11 WITH EDGE (LENGTH (M2_TypeBRS3_prefilter_8 COIN EDGE M2_TypeBRS3_prefilter_11) == TypeBRS3_S2)) NOT M2i
  
  M2_TypeBRS3_CACB_S6_1 = (M2_TypeBRS3_prefilter_8 INTERACT M2_TypeBRS3_prefilter_16 != 6) NOT ENCLOSE M2_TypeBRS3_prefilter_15
  M2_TypeBRS3_CACB_S6_2 = M2_TypeBRS3_CACB_S6_1 WITH WIDTH <= TypeBRS3_S6+GRID
  M2_TypeBRS3_CACB_S6_3 = M2_TypeBRS3_CACB_S6_2 AND M2i
  M2_TypeBRS3_CACB_S6_4 = M2_TypeBRS3_CACB_S6_2 INTERACT M2_TypeBRS3_CACB_S6_3 == 2
  M2_TypeBRS3_CACB_S6_5 = (EXPAND EDGE ((M2_TypeBRS3_CACB_S6_4 AND M2i) COIN EDGE M2i) OUTSIDE BY Mx_S) OR (M2_TypeBRS3_CACB_S6_4 AND M2i)
  M2_TypeBRS3_CACB_S6_6 = M2_TypeBRS3_CACB_S6_4 AND M2_TypeBRS3_CACB_S6_5
  M2_TypeBRS3_CACB_S6_7 = M2_TypeBRS3_CACB_S6_6 WITH EDGE ((M2_TypeBRS3_CACB_S6_6 AND M2i) COIN EDGE M2_TypeBRS3_CACB_S6_6) == 4
  
  M2_TypeBRS3_CACB_S3_1 = LENGTH M2_TypeBRS3_CACB_S6_7 == TypeBRS3_S2
  M2_TypeBRS3_CACB_S3_2 = M2i COIN EDGE M2_TypeBRS3_CACB_S6_7
  M2_TypeBRS3_CACB_S3_3 = LENGTH M2_TypeBRS3_CACB_S3_2 == GRID
  M2_TypeBRS3_CACB_S3_4 = (((M2_CORNER COIN EDGE M2i) NOT COIN EDGE M2_TypeBRS3_CACB_S3_3) NOT COIN EDGE M2_TypeBRS3_CACB_S3_1 ) TOUCH EDGE M2_TypeBRS3_CACB_S6_7
  M2_TypeBRS3_CACB_S3_5 = EXPAND EDGE M2_TypeBRS3_CACB_S3_3 OUTSIDE BY GRID EXTEND BY GRID
  M2_TypeBRS3_CACB_S3_6 = EXPAND EDGE M2_TypeBRS3_CACB_S3_4 OUTSIDE BY GRID EXTEND BY GRID
  
  M2_TypeBRS3_CACB_S3_7 = (((M2_CORNER INTERACT M2_TypeBRS3_CACB_S6_7) NOT INSIDE M2_TypeBRS3_CACB_S6_7) COIN EDGE M2i) NOT COIN EDGE M2_TypeBRS3_CACB_S6_7
  M2_TypeBRS3_CACB_S3_8 = EXPAND EDGE M2_TypeBRS3_CACB_S3_7 OUTSIDE BY GRID EXTEND BY GRID
  M2_TypeBRS3_CACB_S3_9 = M2_TypeBRS3_CACB_S3_1 TOUCH EDGE M2_TypeBRS3_CACB_S3_8
  M2_TypeBRS3_CACB_S3_10 = M2_TypeBRS3_CACB_S3_1 NOT TOUCH EDGE M2_TypeBRS3_CACB_S3_8
  M2_TypeBRS3_CACB_S3_11_1 = EXPAND EDGE M2_TypeBRS3_CACB_S3_9 OUTSIDE BY TypeBRS3_S3
  M2_TypeBRS3_CACB_S3_12_1 = EXPAND EDGE M2_TypeBRS3_CACB_S3_10 OUTSIDE BY TypeBRS3_S3-GRID
  M2_TypeBRS3_CACB_S3_11 = M2_TypeBRS3_CACB_S3_11_1 WITH EDGE ((M2_TypeBRS3_CACB_S3_11_1 AND M2) COIN EDGE M2_TypeBRS3_CACB_S3_11_1) >= 4
  M2_TypeBRS3_CACB_S3_12  = M2_TypeBRS3_CACB_S3_12_1 WITH EDGE ((M2_TypeBRS3_CACB_S3_12_1 AND M2) COIN EDGE M2_TypeBRS3_CACB_S3_12_1) >= 4
  M2_TypeBRS3_CACB_S3_13 = M2_TypeBRS3_CACB_S6_7 OR (M2_TypeBRS3_CACB_S3_11 OR M2_TypeBRS3_CACB_S3_12)
  M2_TypeBRS3_CACB_S3_14 = (M2_TypeBRS3_CACB_S3_13 AND M2i) COIN EDGE M2_TypeBRS3_CACB_S3_13
  M2_TypeBRS3_CACB_S3_15 = ENCLOSE RECTANGLE (M2_TypeBRS3_CACB_S3_13 WITH EDGE M2_TypeBRS3_CACB_S3_14 >= 4) TypeBRS3_S2 2*TypeBRS3_S3
  
  M2_TypeBRS3_CACB_S45_1 = EXPAND EDGE M2_TypeBRS3_CACB_S3_7 OUTSIDE BY 2*GRID 
  M2_TypeBRS3_CACB_S45_2 = M2_TypeBRS3_CACB_S3_15 COIN EDGE M2_TypeBRS3_CACB_S45_1 
  M2_TypeBRS3_CACB_S45_3 = EXT [M2_TypeBRS3_CACB_S3_7] M2i < TypeBRS3_S5 OPPOSITE EXTENDED GRID
  M2_TypeBRS3_CACB_S45_4 = EXT [M2_TypeBRS3_CACB_S45_2] M2i < TypeBRS3_S4 OPPOSITE
  M2_TypeBRS3_CACB_S45_5 = (EXPAND EDGE (M2_TypeBRS3_CACB_S45_1 COIN EDGE M2_TypeBRS3_CACB_S3_15) INSIDE BY 2*GRID) OR M2_TypeBRS3_CACB_S45_1
  M2_TypeBRS3_CACB_S45_6 = (M2_TypeBRS3_CACB_S45_5 NOT COIN EDGE M2i) NOT COIN EDGE M2_TypeBRS3_CACB_S3_15
  M2_TypeBRS3_CACB_S45_7 = ENC M2i [M2_TypeBRS3_CACB_S45_6] == 2*GRID OPPOSITE
  M2_TypeBRS3_CACB_S45_8 = (EXPAND EDGE M2_TypeBRS3_CACB_S45_7 OUTSIDE BY TypeBRS3_S5-2*GRID) OR M2_TypeBRS3_CACB_S45_5 
  M2_TypeBRS3_CACB_S45_9 = LENGTH M2_TypeBRS3_CACB_S45_8  >= TypeBRS3_S5 <= 2*TypeBRS3_S5
  M2_TypeBRS3_CACB_S45_10_1 = M2_TypeBRS3_CACB_S45_9 TOUCH EDGE M2_TypeBRS3_CACB_S3_15
  M2_TypeBRS3_CACB_S45_10_2 = ENC M2i [M2_TypeBRS3_CACB_S45_10_1] < TypeBRS3_S4 OPPOSITE
  M2_TypeBRS3_CACB_S45_10_3 = M2_TypeBRS3_CACB_S45_10_1 TOUCH EDGE M2_TypeBRS3_CACB_S45_10_2 
  M2_TypeBRS3_CACB_S45_10 = M2_TypeBRS3_CACB_S45_10_1 NOT TOUCH EDGE M2_TypeBRS3_CACB_S45_10_2 
  M2_TypeBRS3_CACB_S45_11 = EXPAND EDGE M2_TypeBRS3_CACB_S45_10 INSIDE BY TypeBRS3_S4
  M2_TypeBRS3_CACB_S45_12 = M2_TypeBRS3_CACB_S45_11 INTERACT (M2_TypeBRS3_CACB_S45_11 AND M2i)
  M2_TypeBRS3_CACB_BOXB_waive = (((M2_TypeBRS3_CACB_S45_5 WITH EDGE M2_TypeBRS3_CACB_S45_3) OR (M2_TypeBRS3_CACB_S45_5 WITH EDGE M2_TypeBRS3_CACB_S45_4)) OR (M2_TypeBRS3_CACB_S45_5 INTERACT M2_TypeBRS3_CACB_S45_12)) OR (M2_TypeBRS3_CACB_S45_5 WITH EDGE M2_TypeBRS3_CACB_S45_10_3)
  
  M2_TypeBRS3_CACB_BOXAC_1 = (EXPAND EDGE (M2i COIN EDGE M2_TypeBRS3_CACB_BOXB_waive) INSIDE BY 2*GRID) OR M2_TypeBRS3_CACB_BOXB_waive
  M2_TypeBRS3_CACB_BOXAC_2 = M2_TypeBRS3_CACB_S6_7 NOT INTERACT M2_TypeBRS3_CACB_BOXAC_1 
  M2_TypeBRS3_CACB_BOXAC_3 = M2_TypeBRS3_CACB_S3_9 COIN EDGE M2_TypeBRS3_CACB_BOXAC_2
  M2_TypeBRS3_CACB_BOXAC_4 = M2_TypeBRS3_CACB_S3_10 COIN EDGE M2_TypeBRS3_CACB_BOXAC_2
  M2_TypeBRS3_CACB_BOXAC_5_1 = EXPAND EDGE M2_TypeBRS3_CACB_BOXAC_3 OUTSIDE BY TypeBRS3_S3
  M2_TypeBRS3_CACB_BOXAC_5 = M2_TypeBRS3_CACB_BOXAC_5_1 WITH EDGE ((M2_TypeBRS3_CACB_BOXAC_5_1 AND M2i) COIN EDGE M2_TypeBRS3_CACB_BOXAC_5_1) == 4
  M2_TypeBRS3_CACB_BOXAC_6_1 = EXPAND EDGE M2_TypeBRS3_CACB_BOXAC_4 OUTSIDE BY TypeBRS3_S3-GRID
  M2_TypeBRS3_CACB_BOXAC_6 = M2_TypeBRS3_CACB_BOXAC_6_1 WITH EDGE ((M2_TypeBRS3_CACB_BOXAC_6_1 AND M2i) COIN EDGE M2_TypeBRS3_CACB_BOXAC_6_1) == 4
  M2_TypeBRS3_CACB_BOXAC_7 = ((M2_TypeBRS3_CACB_BOXAC_2 INTERACT M2_TypeBRS3_CACB_BOXAC_5) INTERACT M2_TypeBRS3_CACB_BOXAC_6) OR (M2_TypeBRS3_CACB_BOXAC_5 OR M2_TypeBRS3_CACB_BOXAC_6)
  M2_TypeBRS3_CACB_BOXAC_8 = (M2_TypeBRS3_CACB_BOXAC_7 AND M2i) COIN EDGE M2_TypeBRS3_CACB_BOXAC_7
  M2_TypeBRS3_CACB_BOXAC_9 = INT [M2_TypeBRS3_CACB_BOXAC_8] <= 4*TypeBRS3_S3+2*TypeBRS3_S6+2*GRID OPPOSITE
  M2_TypeBRS3_CACB_BOXAC_10 = ENCLOSE RECTANGLE (M2_TypeBRS3_CACB_BOXAC_7 WITH EDGE M2_TypeBRS3_CACB_BOXAC_9  == 4) TypeBRS3_S2 2*TypeBRS3_S3
  M2_TypeBRS3_CACB_BOXAC_11 = VERTEX (M2_TypeBRS3_CACB_BOXAC_10 AND M2i) != 4
  M2_TypeBRS3_CACB_BOXAC_12 = M2_TypeBRS3_CACB_BOXAC_10 NOT INTERACT M2_TypeBRS3_CACB_BOXAC_11
  M2_TypeBRS3_CACB_BOXC = M2_TypeBRS3_CACB_BOXAC_2 INSIDE M2_TypeBRS3_CACB_BOXAC_12
  M2_TypeBRS3_CACB_MARK = EXT (M2_TypeBRS3_CACB_BOXC AND M2i) <= Mx_S OPPOSITE REGION
  M2_TypeBRS3_CACB_MARK INTERACT EFPM2S7_M2i
}
#ENDIF
#ENDIF
#IFDEF CHECK_EFPM2EN1_
#IFDEF _EFPM2EN1_
EFPM2EN1_M2iCellIn = INSIDE CELL M2i CellsForRRuleRecommended  
EFPM2EN1_M2iCellOut = NOT INSIDE CELL M2i ExclCellsForRRuleRecommended 
EFPM2EN1_M2iCell = EFPM2EN1_M2iCellIn AND EFPM2EN1_M2iCellOut
EFPM2EN1_M2iMarker = M2i AND RRuleRecommended
EFPM2EN1_M2i = ((EFPM2EN1_M2iCell OR EFPM2EN1_M2iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M2.EN.1 { @ Mx/VIAx-1 recommendation: Recommended Mx_A enclosure VIAx-1 [in {VIAx-1 AND Mx_A} space to Mx (SP3+SE) <= 0.06 um side] Definition of Mx_A: Mx with consecutive edge length (L1) <= 0.12 um, (L2) <= 0.06 um, (L3) >= 0.1 um, L1/L3 edge is between 2 outer vertex. L1/L3 space to adjacent Mx (SP3/SP4) = 0.05 um [parallel run length > 0 from VIAx-1] >= 0.01 
   L1_pre = CONVEX EDGE EFPM2EN1_M2i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L2 LENGTH2>=EFP_Mx_EN_1_L3 WITH LENGTH<=EFP_Mx_EN_1_L1
   L2_pre = CONVEX EDGE EFPM2EN1_M2i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH<=EFP_Mx_EN_1_L2
   L3_pre = CONVEX EDGE EFPM2EN1_M2i ANGLE1==90 ANGLE2>=90 <=270 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH>=EFP_Mx_EN_1_L3
   L1_L2_V = INT L1_pre L2_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1_L3_V = INT L1_pre L3_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1 = (L1_pre TOUCH INSIDE EDGE L1_L2_V) TOUCH INSIDE EDGE L1_L3_V
   L3 = L3_pre TOUCH INSIDE EDGE (L1_L3_V WITH EDGE L1)
   L1_DENSE = EXT [L1] M2 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA1_L1_DENSE = VIA1i TOUCH INSIDE EDGE (ENC [VIA1i] L1_DENSE < EFP_Mx_EN_1_SE ABUT<90 OPPOSITE)
   L3_DENSE = EXT [L3] M2 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA1_L3_DENSE = VIA1i TOUCH INSIDE EDGE (ENC [VIA1i] L3_DENSE <= EFP_Mx_EN_1_L1-VIA1_W_1-VIA1_EN_2 ABUT<90 OPPOSITE)
   X = INT VIA1_L1_DENSE VIA1_L3_DENSE <= GRID ABUT==90 INTERSECTING ONLY REGION
   VIA1i INTERACT X  
}
// EFP.Mx.EN.1.R is checked by RR:RE:EFP.M2.EN.1
#ENDIF
#ENDIF
// EFP.Mx.S.5.R is checked by RR:RE:EFP.M2.S.5
// EFP.Mx.S.6.R is checked by RR:RE:EFP.M2.S.6
// EFP.Mx.S.7.R is checked by RR:RE:EFP.M2.S.7

#IFDEF CHECK_EFPM3S2_
#IFDEF _EFPM3S2_
EFPM3S2_M3iCellIn = INSIDE CELL M3i CellsForRRuleRecommended  
EFPM3S2_M3iCellOut = NOT INSIDE CELL M3i ExclCellsForRRuleRecommended 
EFPM3S2_M3iCell = EFPM3S2_M3iCellIn AND EFPM3S2_M3iCellOut
EFPM3S2_M3iMarker = M3i AND RRuleRecommended
EFPM3S2_M3i = ((EFPM3S2_M3iCell OR EFPM3S2_M3iMarker) NOT Block ) NOT excludeRRuleRecommended

// M3 Type Cap
//=============
RR:RE:EFP.M3.S.2 { @ Cap recommendation: Recommended the line-end space at Mx [line width (W2) = 0.05 um, length (L3) >= 0.15 um] in a line-end configuration: If both longer edges of Mx line-end have parallel run length [0.005 um ~ 0.115 um (L2)] to Mx [space to Mx line-end 0.05 um (S1), and both Mxs are part of one polygon] >= 0.115 
  M3_NOTCH_LL = (((EXPAND EDGE M3_L_END_edge INSIDE BY TypeLEH_LL-GRID) AND M3i) WITH EDGE M3_L_END_edge) INTERACT M3_jog_CORNER_waive

  M3_NOTCH_pre = EXT M3i < TypeLEH_NOTCH ABUT < 90 NOTCH OPPOSITE REGION
  M3_NOTCH = (ENCLOSE RECTANGLE M3_NOTCH_pre TypeLEH_NOTCH-3*GRID GRID) INTERACT M3i > 1
  M3_NOTCH_candidate1 = ENCLOSE RECTANGLE (M3i INTERACT M3_NOTCH) TypeLEH_LL Mx_W
  M3_NOTCH_candidate2 = EXT M3_NOTCH_candidate1 <= TypeLEH_S2 ABUT < 90 OPPOSITE REGION
  M3_NOTCH_candidate3 = (M3_L_END_edge TOUCH EDGE M3_NOTCH_candidate2) INSIDE EDGE M3_NOTCH
  M3_NOTCH_candidate4 = EXPAND EDGE M3_NOTCH_candidate3 INSIDE BY GRID
  M3_NOTCH_candidate5 = (VERTEX (SIZE M3_NOTCH_candidate4 BY TypeLEH_marker-GRID INSIDE OF M3_NOTCH_candidate1 STEP Mx_S *0.7) == 4) INTERACT M3_NOTCH
  M3_NOTCH_candidate6 = EXT [M3_NOTCH_candidate5] M3i <= Mx_S+GRID ABUT < 90 OPPOSITE
  M3_NOTCH_candidate7 = INT (M3_NOTCH_candidate5 NOT COIN EDGE M3_NOTCH_candidate6) <= Mx_W ABUT < 90 OPPOSITE REGION
  M3_NOTCH_candidate = (M3_NOTCH_candidate5 INTERACT M3_NOTCH_candidate7) NOT INTERACT M3_NOTCH_LL
  M3_NOTCH_candidate INTERACT EFPM3S2_M3i
}
#ENDIF
#ENDIF
// EFP.Mx.S.2.R is checked by RR:RE:EFP.M3.S.2

#IFDEF CHECK_EFPM3S3_
#IFDEF _EFPM3S3_
EFPM3S3_M3iCellIn = INSIDE CELL M3i CellsForRRuleRecommended  
EFPM3S3_M3iCellOut = NOT INSIDE CELL M3i ExclCellsForRRuleRecommended 
EFPM3S3_M3iCell = EFPM3S3_M3iCellIn AND EFPM3S3_M3iCellOut
EFPM3S3_M3iMarker = M3i AND RRuleRecommended
EFPM3S3_M3i = ((EFPM3S3_M3iCell OR EFPM3S3_M3iMarker) NOT Block ) NOT excludeRRuleRecommended

// M3 Type Hook 
//=============
TypeHook_M3_H2		  = CONVEX EDGE EFPM3S3_M3i ANGLE1==270 ANGLE2==270 WITH LENGTH <= TypeH_LB
TypeHook_M3_H2_corner	  = EXT TypeHook_M3_H2 [M3] < TypeH_LB ABUT==90 
TypeHook_M3_H2_W	  = INT EFPM3S3_M3i (EFPM3S3_M3i TOUCH EDGE TypeHook_M3_H2_corner) <= TypeH_W ABUT<90 REGION
TypeHook_M3_H2_W_out	  = TypeHook_M3_H2_W NOT TOUCH EDGE TypeHook_M3_H2_corner
TypeHook_M3_H2_L_chk	  = TypeHook_M3_H2_corner TOUCH EDGE TypeHook_M3_H2_W 
TypeHook_M3_H2_OC_pre1	  = (CONVEX EDGE EFPM3S3_M3i ANGLE1==270 ANGLE2==90 ) TOUCH EDGE TypeHook_M3_H2_L_chk
TypeHook_M3_H2_OC_pre2	  = EXT [TypeHook_M3_H2_OC_pre1] TypeHook_M3_H2 <= TypeH_LB ABUT==90 
TypeHook_M3_H2_OC	  = TypeHook_M3_H2_OC_pre2 NOT COIN EDGE (INT EFPM3S3_M3i TypeHook_M3_H2_OC_pre2 < DB_GRID ABUT ==90 REGION)
TypeHook_M3_H2_OC_chk	  = EXT [TypeHook_M3_H2_L_chk] TypeHook_M3_H2_OC < TypeH_S2 ABUT<90 OPPOSITE
TypeHook_M3_H2_IC_OClng  = TypeHook_M3_H2 NOT TOUCH EDGE (TypeHook_M3_H2 NOT COIN EDGE TypeHook_M3_H2_OC_chk)
TypeHook_M3_H2_corner_L  = EXT TypeHook_M3_H2_L_chk [TypeHook_M3_H2] < DB_GRID ABUT==90
TypeHook_M3_H2_corner_IC = EXT [TypeHook_M3_H2] <DB_GRID ABUT==90 
TypeHook_M3_H2_corner_IC_OClng = EXT [TypeHook_M3_H2] TypeHook_M3_H2_IC_OClng <DB_GRID ABUT==90 
TypeHook_M3_H2_short	  = LENGTH TypeHook_M3_H2 < TypeH_S2
TypeHook_M3_H2_corner_err = DFM PROPERTY TypeHook_M3_H2 TypeHook_M3_H2_corner_L TypeHook_M3_H2_corner_IC TypeHook_M3_H2_corner_IC_OClng TypeHook_M3_H2_short OVERLAP ABUT ALSO MULTI
				    [ -= COUNT(TypeHook_M3_H2_short)] >0
				    [ -= COUNT(TypeHook_M3_H2_corner_IC)] >0
				    [ -= COUNT(TypeHook_M3_H2_corner_IC_OClng)] >0
				    [ -= COUNT(TypeHook_M3_H2_corner_L)] >1
TypeHook_M3_H2_err	  = (EXPAND EDGE (TypeHook_M3_H2 TOUCH EDGE TypeHook_M3_H2_corner_err) BY 0.001) NOT INSIDE SRAMDMY
TypeHook_M3		  = TypeHook_M3_H2_err NOT INSIDE SRAMDMY
RR:RE:EFP.M3.S.3 { @ Hook recommendation: Recommended space from the edge [length <= 0.065 um (L4) between the edges of line width <= 0.055 um (W3 and W3') and either one of the edges >= 0.15 um (L5)] of Mx pattern [with 3 consecutive 270-270-270 degree inner angles] to opposite edge of the same Mx >= 0.155 
   COPY TypeHook_M3 
}
#ENDIF
#ENDIF
// EFP.Mx.S.3.R is checked by RR:RE:EFP.M3.S.3

#IFDEF CHECK_EFPM3S5_
#IFDEF _EFPM3S5_
EFPM3S5_M3iCellIn = INSIDE CELL M3i CellsForRRuleRecommended  
EFPM3S5_M3iCellOut = NOT INSIDE CELL M3i ExclCellsForRRuleRecommended 
EFPM3S5_M3iCell = EFPM3S5_M3iCellIn AND EFPM3S5_M3iCellOut
EFPM3S5_M3iMarker = M3i AND RRuleRecommended
EFPM3S5_M3i = ((EFPM3S5_M3iCell OR EFPM3S5_M3iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M3.S.5 { @ Metal bridge recommendation type-1: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3] when there is no other Mx cut Region B1/B2 Definitions: 1. Region B3 = 0.25 um * S2, generated from vertex CA/CB. 2. S2 = 2 Mx (polygon3/4) with parallel run length 0 um > S2 >= 0.235 um 3. Region B1/B2 = 0.16 um * 0.23 um, generated from Mx (polygon3/4) metal line-end with vertex CA/CB respectively >= 0.055 
  M3_TypeBRS1_prefilter_1 = EXT [M3i] == TypeBRS1_S2 ABUT < 90 OPPOSITE EXTENDED TypeBRS1_S3+NANO
  M3_TypeBRS1_CORNER_pre_1_1 = M3_CORNER_S1 WITH EDGE M3_TypeBRS1_prefilter_1
  M3_TypeBRS1_CORNER_pre_1_2 = EXT [M3_L_END_edge] M3i < TypeBRS1_S5 OPPOSITE
  M3_TypeBRS1_CORNER_pre_1 = M3_TypeBRS1_CORNER_pre_1_1 NOT WITH EDGE M3_TypeBRS1_CORNER_pre_1_2
  M3_TypeBRS1_CORNER_pre_2 = EXT M3_TypeBRS1_CORNER_pre_1 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION
  M3_TypeBRS1_CORNER_pre_3 = M3_TypeBRS1_CORNER_pre_2 INTERACT (M3_TypeBRS1_CORNER_pre_2 AND M3i) > 1
  M3_TypeBRS1_CORNER_pre_4 = M3_TypeBRS1_CORNER_pre_1 INTERACT M3_TypeBRS1_CORNER_pre_3
  
  M3_TypeBRS1_CACB_S23 = EXT M3_TypeBRS1_CORNER_pre_4 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M3_TypeBRS1_CACB_S23_1_1 = M3_TypeBRS1_CACB_S23 INTERACT M3_CORNER_S1 >= 2
  
  M3_TypeBRS1_CACB_S23_1_2 = INT (M3i AND M3_TypeBRS1_CACB_S23_1_1) == Mx_W OPPOSITE REGION
  M3_TypeBRS1_CACB_S23_1_3 = EXPAND EDGE (M3i COIN INSIDE EDGE M3_TypeBRS1_CACB_S23_1_2) OUTSIDE BY Mx_S
  M3_TypeBRS1_CACB_S23_1_4 = M3_TypeBRS1_CACB_S23_1_2 OR M3_TypeBRS1_CACB_S23_1_3
  M3_TypeBRS1_CACB_S23_1_5 = (EXT (M3_TypeBRS1_CORNER_pre_4 INTERACT M3_TypeBRS1_CACB_S23_1_1) >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION) AND M3_TypeBRS1_CACB_S23_1_4
  M3_TypeBRS1_CACB_S23_1_6 = (M3_TypeBRS1_CORNER_pre_4 INTERACT M3_TypeBRS1_CACB_S23_1_1) INTERACT (SIZE M3_TypeBRS1_CACB_S23_1_5 BY GRID)
  M3_TypeBRS1_CACB_S23_1_7 = EXT M3_TypeBRS1_CACB_S23_1_6 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M3_TypeBRS1_CACB_S23_1 = M3_TypeBRS1_CACB_S23_1_7 INTERACT M3_TypeBRS1_CACB_S23_1_6 >= 2
  
  M3_TypeBRS1_CACB_S23_2 = ((EXPAND EDGE (LENGTH ((SIZE M3_TypeBRS1_CACB_S23_1 BY -NANO) AND M3i) == Mx_W) OUTSIDE BY 2*NANO) OR (M3_TypeBRS1_CACB_S23_1 AND M3i)) AND M3_TypeBRS1_CACB_S23_1
  M3_TypeBRS1_CACB_S23_3 = (M3_TypeBRS1_CACB_S23_2 AND M3_TypeBRS1_CACB_S23_1) COIN EDGE M3_TypeBRS1_CACB_S23_1
  M3_TypeBRS1_CACB_S23_4 = M3_TypeBRS1_CACB_S23_1 INTERACT (M3_TypeBRS1_CACB_S23_1 AND M3i) == 2
  M3_TypeBRS1_CACB_S23_5 = M3_TypeBRS1_CACB_S23_4 WITH EDGE M3_TypeBRS1_CACB_S23_3 == 4
  M3_TypeBRS1_CACB_EDGE1 = M3i TOUCH OUTSIDE EDGE M3_TypeBRS1_CACB_S23_5	//CA and CB EDGE
  M3_TypeBRS1_CACB_EDGE2 = EXPAND EDGE M3_TypeBRS1_CACB_EDGE1 OUTSIDE BY GRID			
  M3_TypeBRS1_CACB_EDGE3_1 = EXT M3_TypeBRS1_CACB_EDGE1 M3i == Mx_S OPPOSITE REGION
  M3_TypeBRS1_CACB_EDGE3_2 = EXT M3_TypeBRS1_CACB_EDGE1 M3_TypeBRS1_CACB_S23_2 == Mx_S OPPOSITE REGION
  M3_TypeBRS1_CACB_EDGE4 = M3_TypeBRS1_CACB_EDGE2 NOT M3_TypeBRS1_CACB_EDGE3_1
  M3_TypeBRS1_CACB_EDGE5 = LENGTH M3_TypeBRS1_CACB_EDGE4 == GRID
  M3_TypeBRS1_CACB_EDGE6 = EXPAND EDGE M3_TypeBRS1_CACB_EDGE5 OUTSIDE BY GRID
  M3_TypeBRS1_CACB_EDGE7 = (M3_TypeBRS1_CACB_EDGE6 TOUCH M3_TypeBRS1_CACB_EDGE3_1) OR (M3_TypeBRS1_CACB_EDGE6 TOUCH M3_TypeBRS1_CACB_EDGE3_2)
  
   
  M3_TypeBRS1_CACB_EDGE8_1 = M3_TypeBRS1_CACB_EDGE7 COIN OUTSIDE EDGE M3_TypeBRS1_CACB_EDGE4
  M3_TypeBRS1_CACB_EDGE8 = M3_TypeBRS1_CACB_EDGE8_1 NOT TOUCH EDGE (EXT [M3_TypeBRS1_CACB_EDGE8_1] M3i < TypeBRS1_S4 OPPOSITE)
  
  M3_TypeBRS1_CACB_EDGE9 = EXPAND EDGE M3_TypeBRS1_CACB_EDGE8 OUTSIDE BY TypeBRS1_S4
  M3_TypeBRS1_CACB_EDGE10 = M3_CORNER TOUCH M3_TypeBRS1_CACB_EDGE4
  
  M3_TypeBRS1_CACB_EDGE11_1 = M3_TypeBRS1_CACB_EDGE9 TOUCH OUTSIDE EDGE M3_TypeBRS1_CACB_EDGE10
  M3_TypeBRS1_CACB_EDGE11 = M3_TypeBRS1_CACB_EDGE11_1 NOT TOUCH EDGE (ENC M3i [M3_TypeBRS1_CACB_EDGE11_1] < TypeBRS1_S5 OPPOSITE)
  
  M3_TypeBRS1_CACB_EDGE12 = ENCLOSE RECTANGLE (EXPAND EDGE M3_TypeBRS1_CACB_EDGE11 INSIDE BY TypeBRS1_S5) TypeBRS1_S4 TypeBRS1_S5
  M3_TypeBRS1_CACB_ERROR1 = M3_TypeBRS1_CACB_EDGE12 AND M3i
  M3_TypeBRS1_CACB_ERROR2 = (ENC M3_TypeBRS1_CACB_ERROR1 [M3_TypeBRS1_CACB_EDGE11] <= TypeBRS1_S5 OPPOSITE) OR EDGE (M3_TypeBRS1_CACB_EDGE11 TOUCH EDGE M3_TypeBRS1_CACB_ERROR1)
  M3_TypeBRS1_CACB_ERROR3 = (M3_TypeBRS1_CACB_EDGE11 NOT TOUCH EDGE M3_TypeBRS1_CACB_ERROR2) TOUCH EDGE M3_TypeBRS1_CACB_EDGE12
  M3_TypeBRS1_CACB_ERROR4 = EXPAND EDGE M3_TypeBRS1_CACB_ERROR3 INSIDE BY TypeBRS1_S5
  M3_TypeBRS1_CACB_ERROR5 = ENCLOSE RECTANGLE (M3_TypeBRS1_CACB_ERROR4 NOT ENCLOSE M3_TypeBRS1_CACB_ERROR1) TypeBRS1_S4 TypeBRS1_S5
  M3_TypeBRS1_MARK1 = EXT M3_TypeBRS1_CACB_ERROR5 > 2*Mx_W+2*Mx_S+4*GRID <= TypeBRS1_S2 OPPOSITE REGION
  M3_TypeBRS1_MARK2 = VERTEX (M3_TypeBRS1_MARK1 AND M3i) != 4
  M3_TypeBRS1_MARK3 = M3_TypeBRS1_MARK1 WITH EDGE (M3_TypeBRS1_MARK1 COIN EDGE (M3_TypeBRS1_MARK1 AND M3i)) == 4
  M3_TypeBRS1_MARK4 = M3_TypeBRS1_MARK3 NOT INTERACT M3_TypeBRS1_MARK2
  M3_TypeBRS1_MARK = (EXT (M3_TypeBRS1_MARK4 AND M3i) <= Mx_S OPPOSITE REGION) INSIDE M3_TypeBRS1_CACB_S23_5
  M3_TypeBRS1_MARK INTERACT EFPM3S5_M3i
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPM3S6_
#IFDEF _EFPM3S6_
EFPM3S6_M3iCellIn = INSIDE CELL M3i CellsForRRuleRecommended  
EFPM3S6_M3iCellOut = NOT INSIDE CELL M3i ExclCellsForRRuleRecommended 
EFPM3S6_M3iCell = EFPM3S6_M3iCellIn AND EFPM3S6_M3iCellOut
EFPM3S6_M3iMarker = M3i AND RRuleRecommended
EFPM3S6_M3i = ((EFPM3S6_M3iCell OR EFPM3S6_M3iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M3.S.6 { @ Metal bridge recommendation type-2: Recommended space of 2 Mx lines (polygon1/2) [polygon2 with width = 0.05 um (W) and length (L3) >= 0.3 um, one side of Region B3 fully abutted polygon1] when there is no Mx cut both Region B2 and Region B4, but has other Mx interact both Region B1 and Region B5 Definitions: 1. Region B1 = 0.05 um * 0.08 um, generated from vertex CA. 2. Region B2 = 0.23 um * 0.075 um, generated from Mx (polygon2) side wall with vertex CA. 3. Region B3 = 0.05 um *(L1+L2). L1 = 0.08 um, L2 = 0.12 um 4. Region B4 = 0.05 um * 0.3 um, generated from Mx (polygon2) line-end. 5. Region B5 = S2*S3, generated from vertex CB. 0 um < S2 (polygon3 vertex CB to polygon1) <= 0.055 um, and -0.1 um <= S3 (parallel run length of polygon2 and polygon1) <= -0.03 um >= 0.055 
  M3_L_END_BRS2_metal_pre = M3i WITH EDGE M3_L_END_edge
  M3_L_END_BRS2_metal_enc = M3_L_END_BRS2_metal_pre AND (EXPAND EDGE M3_L_END_edge INSIDE BY TypeBRS2_LL)
  M3_L_END_BRS2_LL = (((EXPAND EDGE M3_L_END_edge INSIDE BY TypeBRS2_LL-GRID) AND M3i) WITH EDGE M3_L_END_edge) INTERACT M3_jog_CORNER_waive
  M3_L_END_BRS2_metal = (ENCLOSE RECTANGLE M3_L_END_BRS2_metal_enc Mx_W TypeBRS2_LL) NOT INTERACT M3_L_END_BRS2_LL
  M3_L_END_BRS2_L_END_edge = M3_L_END_edge COIN EDGE M3_L_END_BRS2_metal
  
  M3_L_END_BRS2_side_edge_pre = INT [M3i] M3_L_END_BRS2_L_END_edge <= TypeBRS2_S5 ABUT == 90 INTERSECTING ONLY
  M3_L_END_BRS2_dense_side_edge_pre = INT [M3i] M3_L_END_BRS2_L_END_edge <= TypeBRS2_LH ABUT == 90 INTERSECTING ONLY
  M3_L_END_BRS2_iso_side_edge_pre = EXT [M3_L_END_BRS2_side_edge_pre] M3i <= TypeBRS2_S4 ABUT < 90 OPPOSITE
  M3_L_END_BRS2_iso_side_edge_pre1 = LENGTH (M3_L_END_BRS2_side_edge_pre NOT COIN EDGE M3_L_END_BRS2_iso_side_edge_pre) >= TypeBRS2_S5
  M3_L_END_BRS2_iso_side_edge_pre2 = (EXPAND EDGE M3_L_END_BRS2_iso_side_edge_pre1 INSIDE BY GRID) WITH EDGE M3_L_END_BRS2_L_END_edge
  M3_L_END_BRS2_iso_side_edge = LENGTH (M3_L_END_BRS2_iso_side_edge_pre1 COIN EDGE M3_L_END_BRS2_iso_side_edge_pre2) >= TypeBRS2_S5
  M3_L_END_BRS2_L_END_edge_waive = EXT [M3_L_END_BRS2_L_END_edge] M3i < TypeBRS2_S2 ABUT < 90 OPPOSITE
  M3_L_END_REGION_BRS2_dense_edge_pre = EXPAND EDGE M3_L_END_BRS2_L_END_edge INSIDE BY TypeBRS2_LH OUTSIDE BY TypeBRS2_LY
  M3_L_END_REGION_BRS2_dense_edge_pre1 = VERTEX (EXT M3_L_END_REGION_BRS2_dense_edge_pre M3i <= Mx_S ABUT < 90 OPPOSITE REGION) == 4
  M3_L_END_REGION_BRS2_dense_edge = LENGTH (M3_L_END_REGION_BRS2_dense_edge_pre COIN EDGE M3_L_END_REGION_BRS2_dense_edge_pre1) >= TypeBRS2_LH+TypeBRS2_LY
  M3_L_END_REGION_BRS2_dense_iso = INT M3_L_END_BRS2_iso_side_edge M3_L_END_REGION_BRS2_dense_edge <= Mx_W ABUT < 90 OPPOSITE REGION
  M3_L_END_BRS2_iso_dense_side_edge_pre = (M3_L_END_REGION_BRS2_dense_edge_pre TOUCH EDGE M3_L_END_BRS2_iso_side_edge) NOT COIN EDGE M3i
  M3_L_END_BRS2_iso_dense_side_edge_pre1 = EXT [M3_L_END_BRS2_iso_dense_side_edge_pre] M3_CORNER <= Mx_S ABUT < 90 OPPOSITE
  M3_L_END_BRS2_iso_dense_side_edge = EXPAND EDGE (M3_L_END_BRS2_iso_dense_side_edge_pre TOUCH EDGE M3_L_END_BRS2_iso_dense_side_edge_pre1) BY GRID EXTEND BY GRID
  M3_L_END_REGION_BRS2_pre1 = EXPAND EDGE M3_L_END_BRS2_L_END_edge INSIDE BY TypeBRS2_LH-TypeBRS2_LY
  M3_L_END_REGION_BRS2_pre2 = ((M3_L_END_REGION_BRS2_pre1 NOT WITH EDGE M3_L_END_BRS2_L_END_edge_waive) INTERACT M3_L_END_REGION_BRS2_dense_iso) INTERACT M3_L_END_BRS2_iso_dense_side_edge
  M3_L_END_REGION_BRS2_pre3 = M3_L_END_edge COIN EDGE M3_L_END_REGION_BRS2_pre2 
  M3_L_END_REGION_BRS2_pre4 = EXPAND EDGE M3_L_END_REGION_BRS2_pre3 INSIDE BY TypeBRS2_LH-TypeBRS2_LY
  M3_L_END_REGION_BRS2_pre5 = EXPAND EDGE (M3_L_END_REGION_BRS2_pre4 COIN EDGE M3_L_END_REGION_BRS2_dense_edge) OUTSIDE BY Mx_S EXTEND BY TypeBRS2_LY
  M3_L_END_REGION_BRS2_pre6 = M3_L_END_REGION_BRS2_pre5 WITH EDGE (LENGTH (M3_L_END_REGION_BRS2_pre5 COIN EDGE M3i) == TypeBRS2_LH+TypeBRS2_LY)
  
  M3_L_END_REGION_BRS2_pre7 = M3_CORNER INTERACT M3_L_END_REGION_BRS2_pre6 
  M3_L_END_REGION_BRS2_pre8 = M3_L_END_REGION_BRS2_pre7 COIN EDGE M3_L_END_REGION_BRS2_pre6
  M3_L_END_REGION_BRS2_pre9 = (EXPAND EDGE M3_L_END_REGION_BRS2_pre8 INSIDE BY GRID EXTEND BY TypeBRS2_LG_max+GRID) TOUCH EDGE M3_L_END_REGION_BRS2_pre6
  M3_L_END_REGION_BRS2_pre10 = M3i COIN EDGE (EXT [M3_CORNER] M3_L_END_REGION_BRS2_pre9 > Mx_W+Mx_S <= Mx_W+Mx_S+TypeBRS2_S3 ABUT < 90 OPPOSITE MEASURE ALL)
  M3_L_END_REGION_BRS2_pre11 = M3_CORNER WITH EDGE M3_L_END_REGION_BRS2_pre10
  M3_L_END_REGION_BRS2_pre12 = EXT [M3_L_END_REGION_BRS2_pre7] M3_L_END_REGION_BRS2_pre11 > TypeBRS2_LGS_min <= TypeBRS2_LGS_max CORNER TO CORNER 
  M3_L_END_REGION_BRS2_MARK = M3_L_END_REGION_BRS2_pre6 WITH EDGE M3_L_END_REGION_BRS2_pre12
  M3_L_END_REGION_BRS2_MARK INTERACT EFPM3S6_M3i
}
#ENDIF
#ENDIF

