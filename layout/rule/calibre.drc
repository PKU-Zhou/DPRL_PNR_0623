  GOOD_REGION1 = EXT LONG_M4_TCD_050 == BDTCD_S_1 ABUT < 90 OPPOSITE REGION
  GOOD_REGION2 = EXT LONG_M4_TCD_050 LONG_M4_TCD_100 == BDTCD_S_2 ABUT < 90 OPPOSITE REGION
  GOOD_REGION3 = EXT LONG_M4_TCD_050 LONG_M4_TCD_200 == BDTCD_S_2 ABUT < 90 OPPOSITE REGION
  LONG_M4_TCD_050 NOT TOUCH EDGE ((GOOD_REGION1 OR GOOD_REGION2) OR GOOD_REGION3) 
}

