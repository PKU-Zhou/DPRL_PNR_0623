#IFNDEF FULL_CHIP
#IFDEF CHECK_MxDN7_M3_M4_M5_
#IFDEF _MxDN7_M3_M4_M5_
#IFDEF CHECK_LOW_DENSITY
//'Mx.DN.7.R' is checked by RR:RE:Mx.DN.7:M3_M4_M5
RR:RE:Mx.DN.7:M3_M4_M5 { @ It is not recommended to have local density < 5% of all 3 consecutive metal (Mx, Mx+1 and Mx+2) over any 15 um x 15 um (stepping 15 um) for IP level, i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density >= 5%. 1. The metal layers include M1/Mx and dummy metals. 2. The following special regions are excluded: - Chip corner triangle empty areas if sealring is added by tsmc. - LOWMEDN, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area)   
   M3_CHECK = M3x NOT (NEW_DEN_EXC OR ICOVL)
   M4_CHECK = M4x NOT (NEW_DEN_EXC OR ICOVL)
   M5_CHECK = M5x NOT (NEW_DEN_EXC OR ICOVL)
   CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
   X = DENSITY M3_CHECK M4_CHECK M5_CHECK CHIP_CHECK >0 WINDOW M3_DN_7_W_R STEP M3_DN_7_S_R BACKUP INSIDE OF LAYER CHIP_M5
   [ ~(M3_DN_7_E_R-AREA(CHIP_CHECK))*!~(M3_DN_7_R-(AREA(M3_CHECK)/AREA(CHIP_CHECK)))*!~(M3_DN_7_R-(AREA(M4_CHECK)/AREA(CHIP_CHECK)))*!~(M3_DN_7_R-(AREA(M5_CHECK)/AREA(CHIP_CHECK))) ]
   RDB Mx.DN.7R:M3_M4_M5.density
   X NOT excludeRRuleRecommended
}



#ENDIF
#ENDIF
#ENDIF
#ENDIF //FULL_CHIP


#IFDEF CHECK_M6DN2_
#IFDEF _M6DN2_
RR:RE:M6.DN.2 { @ Recommended maximum metal density in window 60 um x 60 um, stepping 20 um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 85% 
    EXC = COPY ICOVL
  N = M6x NOT EXC
  D = CHIP NOT EXC 
  A = CHIPx NOT EXC
  X = DENSITY A M6x CHIP N D > M6_DN_2_R WINDOW M6_DN_2_W_R STEP M6_DN_2_S_R BACKUP INSIDE OF LAYER CHIPx PRINT M6.DN.2.R.density RDB M6.DN.2.R.RDB.density
          [~(M6_DN_2_E_R-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M6x)/AREA(CHIP)-M6_DN_2_R)]



   X NOT excludeRRuleRecommended    
}

#ENDIF
#ENDIF

#IFDEF CHECK_M6DN5_
#IFDEF _M6DN5_
#IFDEF CHECK_LOW_DENSITY
RR:RE:M6.DN.5 { @ Recommended minimum metal density in window 20 um x 20 um stepping 20 um. 1. The check doesn't include LOGO, INDDMY, ICOVL, chip corner triangle empty areas, and SEALRING_ALL. (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 15% 
  EXC = M6_EXC_LOW OR ICOVL
  N = M6x NOT EXC
  D = CHIP NOT EXC 
  A = CHIP_M6 NOT EXC
  X = DENSITY A M6x CHIP N D < M6_DN_5_R WINDOW M6_DN_5_W_R STEP M6_DN_5_S_R BACKUP INSIDE OF LAYER CHIP_M6 PRINT M6.DN.5.R.density RDB M6.DN.5.R.RDB.density
          [~(AREA(A)-M6_DN_5_E_R)*!!(AREA(A)-M6_DN_5_E_R)+AREA(N)/AREA(D)+!~(AREA(M6x)/AREA(CHIP)-M6_DN_5_R)+!(AREA(M6x)/AREA(CHIP)-M6_DN_5_R)]


  X NOT excludeRRuleRecommended    
}


#ENDIF
#ENDIF
#ENDIF

#IFNDEF FULL_CHIP
#IFDEF CHECK_M6DN6_
#IFDEF _M6DN6_
#IFDEF CHECK_LOW_DENSITY
RR:RE:M6.DN.6 { @ Recommend metal Density >= ^M6_DN_6_R for IP level. Item(A) to Item(C) are recommended.
@ (A) For IP level, recommend metal density [checking window ^M6_DN_6_W_A_R um x ^M6_DN_6_W_A_R um, stepping ^M6_DN_6_S_A_R um] >= ^M6_DN_6_R
@ (B) For IP level, recommend maximum area of merged low density windows [checking window ^M6_DN_6_W_BC_R um x ^M6_DN_6_W_BC_R um, stepping ^M6_DN_6_S_BC_R um, density < ^M6_DN_6_R] <= ^M6_DN_6_A_B_R um2. Merged low density windows width <= ^M6_DN_6_U_R um is excepted.
@ (C) For IP level, recommend maximum area of merged low density windows [checking window ^M6_DN_6_W_BC_R um x ^M6_DN_6_W_BC_R um, stepping ^M6_DN_6_S_BC_R um, density < ^M6_DN_6_R] <= ^M6_DN_6_A_C_R um2
@ 1. The following special regions are excluded
@    Chip corner triangle empty areas if sealring is added by tsmc. 
@    LOWMEDN
@ 2. This rule is applied while the width of (checking window NOT above excluding region) >= ^M6_DN_6_E_A_R um for (A) and >= ^M6_DN_6_E_BC_R um for both (B)/(C) 
  M6_CHECK = M6x NOT (NEW_DEN_EXC OR ICOVL)
  CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
  // Condition-A
  ERR_WIN_A = DENSITY M6_CHECK CHIP_CHECK < M6_DN_6_R WINDOW M6_DN_6_W_A_R STEP M6_DN_6_S_A_R INSIDE OF LAYER CHIP_M6 BACKUP 
	[ AREA(M6_CHECK)/AREA(CHIP_CHECK) ]
  F_A = WITH WIDTH (ERR_WIN_A NOT (NEW_DEN_EXC OR ICOVL)) >= M6_DN_6_E_A_R
  X = DENSITY F_A M6_CHECK CHIP_CHECK < M6_DN_6_R WINDOW M6_DN_6_W_A_R STEP M6_DN_6_S_A_R INSIDE OF LAYER CHIP_M6 BACKUP PRINT M6.DN.6R_A.density
         [ !AREA(F_A)+AREA(M6_CHECK)/AREA(CHIP_CHECK) ]
  X NOT excludeRRuleRecommended	 
  // Condition-B 
  ERR_WIN_B = DENSITY M6_CHECK CHIP_CHECK < M6_DN_6_R WINDOW M6_DN_6_W_BC_R STEP M6_DN_6_S_BC_R INSIDE OF LAYER CHIP_M6 BACKUP 
	[ AREA(M6_CHECK)/AREA(CHIP_CHECK) ]
  F_B = WITH WIDTH (ERR_WIN_B NOT (NEW_DEN_EXC OR ICOVL)) >= M6_DN_6_E_BC_R
  A = DENSITY F_B M6_CHECK CHIP_CHECK < M6_DN_6_R WINDOW M6_DN_6_W_BC_R STEP M6_DN_6_S_BC_R INSIDE OF LAYER CHIP_M6 BACKUP PRINT M6.DN.6R_BC.density
         [ !AREA(F_B)+AREA(M6_CHECK)/AREA(CHIP_CHECK) ]
  B = AREA A > M6_DN_6_A_B_R
  C = SIZE B BY M6_DN_6_U_R/2 UNDEROVER
  (B INTERACT C) NOT excludeRRuleRecommended
  // Condition-C
  (AREA B > M6_DN_6_A_C_R) NOT excludeRRuleRecommended 
}
#ENDIF
#ENDIF
#ENDIF
#ENDIF //FULL_CHIP



