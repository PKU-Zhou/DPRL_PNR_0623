M5S4_M5Marker = M5i AND RRuleRecommended
M5S4_M5 = ((( M5S4_M5Cell OR M5S4_M5Marker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleRecommended

RR:RE:M5.S.4 { @ Recommended space [at least one metal line width > 0.47 um] >= 0.13 
  (((EXT M5_22 M5 < M5_S_4_R OPPOSITE REGION MEASURE ALL) NOT M5) INTERACT M5S4_M5) NOT INSIDE TCDDMY_BM5
}
#ENDIF
#ENDIF

#IFDEF CHECK_M5S5_
#IFDEF _M5S5_
M5S5_M5CellIn = INSIDE CELL M5i CellsForRRuleRecommended  
M5S5_M5CellOut = NOT INSIDE CELL M5i ExclCellsForRRuleRecommended 
M5S5_M5Cell = M5S5_M5CellIn AND M5S5_M5CellOut
M5S5_M5Marker = M5i AND RRuleRecommended
