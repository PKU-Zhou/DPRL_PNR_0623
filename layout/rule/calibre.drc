VARIABLE  PO_R_25_V 3.300
PO.R.25 { @ {{PO OR SR_DPO} NOT CPO} [NOT INSIDE OD2] can't apply the voltage > 3.3V   


    PO_3d3V_ALL_PO_R_25_pre = DFM PROPERTY POn NET_PROP_LAYER NODAL MULTI 
    [ AV = FMAX(ABS(property(NET_PROP_LAYER,"Volt_High")), ABS(property(NET_PROP_LAYER,"Volt_Low")))] > PO_R_25_V
    PO_3d3V_ALL_PO_R_25 = NET AREA RATIO ILP1i PO_3d3V_ALL_PO_R_25_pre  > 0
            err_1a_L1 = PO_3d3V_ALL_PO_R_25 NOT INSIDE OD2
    CMACRO VOLTAGE_ANNOTATE_2 err_1a_L1 NET_PROP_LAYER err_1a_L1_V
            DFM COPY err_1a_L1_V
            DFM RDB err_1a_L1_V "PO.R.25.rep" NOEMPTY NOPSEUDO

} 

