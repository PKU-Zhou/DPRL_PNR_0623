RR:RE:EFP.M6.S.6 { @ Metal bridge recommendation type-2: Recommended space of 2 Mx lines (polygon1/2) [polygon2 with width = 0.05 um (W) and length (L3) >= 0.3 um, one side of Region B3 fully abutted polygon1] when there is no Mx cut both Region B2 and Region B4, but has other Mx interact both Region B1 and Region B5 Definitions: 1. Region B1 = 0.05 um * 0.08 um, generated from vertex CA. 2. Region B2 = 0.23 um * 0.075 um, generated from Mx (polygon2) side wall with vertex CA. 3. Region B3 = 0.05 um *(L1+L2). L1 = 0.08 um, L2 = 0.12 um 4. Region B4 = 0.05 um * 0.3 um, generated from Mx (polygon2) line-end. 5. Region B5 = S2*S3, generated from vertex CB. 0 um < S2 (polygon3 vertex CB to polygon1) <= 0.055 um, and -0.1 um <= S3 (parallel run length of polygon2 and polygon1) <= -0.03 um >= 0.055 
  M6_L_END_BRS2_metal_pre = M6i WITH EDGE M6_L_END_edge
  M6_L_END_BRS2_metal_enc = M6_L_END_BRS2_metal_pre AND (EXPAND EDGE M6_L_END_edge INSIDE BY TypeBRS2_LL)
  M6_L_END_BRS2_LL = (((EXPAND EDGE M6_L_END_edge INSIDE BY TypeBRS2_LL-GRID) AND M6i) WITH EDGE M6_L_END_edge) INTERACT M6_jog_CORNER_waive
  M6_L_END_BRS2_metal = (ENCLOSE RECTANGLE M6_L_END_BRS2_metal_enc Mx_W TypeBRS2_LL) NOT INTERACT M6_L_END_BRS2_LL
  M6_L_END_BRS2_L_END_edge = M6_L_END_edge COIN EDGE M6_L_END_BRS2_metal
  
  M6_L_END_BRS2_side_edge_pre = INT [M6i] M6_L_END_BRS2_L_END_edge <= TypeBRS2_S5 ABUT == 90 INTERSECTING ONLY
  M6_L_END_BRS2_dense_side_edge_pre = INT [M6i] M6_L_END_BRS2_L_END_edge <= TypeBRS2_LH ABUT == 90 INTERSECTING ONLY
  M6_L_END_BRS2_iso_side_edge_pre = EXT [M6_L_END_BRS2_side_edge_pre] M6i <= TypeBRS2_S4 ABUT < 90 OPPOSITE
  M6_L_END_BRS2_iso_side_edge_pre1 = LENGTH (M6_L_END_BRS2_side_edge_pre NOT COIN EDGE M6_L_END_BRS2_iso_side_edge_pre) >= TypeBRS2_S5
  M6_L_END_BRS2_iso_side_edge_pre2 = (EXPAND EDGE M6_L_END_BRS2_iso_side_edge_pre1 INSIDE BY GRID) WITH EDGE M6_L_END_BRS2_L_END_edge
  M6_L_END_BRS2_iso_side_edge = LENGTH (M6_L_END_BRS2_iso_side_edge_pre1 COIN EDGE M6_L_END_BRS2_iso_side_edge_pre2) >= TypeBRS2_S5
  M6_L_END_BRS2_L_END_edge_waive = EXT [M6_L_END_BRS2_L_END_edge] M6i < TypeBRS2_S2 ABUT < 90 OPPOSITE
  M6_L_END_REGION_BRS2_dense_edge_pre = EXPAND EDGE M6_L_END_BRS2_L_END_edge INSIDE BY TypeBRS2_LH OUTSIDE BY TypeBRS2_LY
  M6_L_END_REGION_BRS2_dense_edge_pre1 = VERTEX (EXT M6_L_END_REGION_BRS2_dense_edge_pre M6i <= Mx_S ABUT < 90 OPPOSITE REGION) == 4
  M6_L_END_REGION_BRS2_dense_edge = LENGTH (M6_L_END_REGION_BRS2_dense_edge_pre COIN EDGE M6_L_END_REGION_BRS2_dense_edge_pre1) >= TypeBRS2_LH+TypeBRS2_LY
  M6_L_END_REGION_BRS2_dense_iso = INT M6_L_END_BRS2_iso_side_edge M6_L_END_REGION_BRS2_dense_edge <= Mx_W ABUT < 90 OPPOSITE REGION
  M6_L_END_BRS2_iso_dense_side_edge_pre = (M6_L_END_REGION_BRS2_dense_edge_pre TOUCH EDGE M6_L_END_BRS2_iso_side_edge) NOT COIN EDGE M6i
  M6_L_END_BRS2_iso_dense_side_edge_pre1 = EXT [M6_L_END_BRS2_iso_dense_side_edge_pre] M6_CORNER <= Mx_S ABUT < 90 OPPOSITE
  M6_L_END_BRS2_iso_dense_side_edge = EXPAND EDGE (M6_L_END_BRS2_iso_dense_side_edge_pre TOUCH EDGE M6_L_END_BRS2_iso_dense_side_edge_pre1) BY GRID EXTEND BY GRID
  M6_L_END_REGION_BRS2_pre1 = EXPAND EDGE M6_L_END_BRS2_L_END_edge INSIDE BY TypeBRS2_LH-TypeBRS2_LY
  M6_L_END_REGION_BRS2_pre2 = ((M6_L_END_REGION_BRS2_pre1 NOT WITH EDGE M6_L_END_BRS2_L_END_edge_waive) INTERACT M6_L_END_REGION_BRS2_dense_iso) INTERACT M6_L_END_BRS2_iso_dense_side_edge
  M6_L_END_REGION_BRS2_pre3 = M6_L_END_edge COIN EDGE M6_L_END_REGION_BRS2_pre2 
  M6_L_END_REGION_BRS2_pre4 = EXPAND EDGE M6_L_END_REGION_BRS2_pre3 INSIDE BY TypeBRS2_LH-TypeBRS2_LY
  M6_L_END_REGION_BRS2_pre5 = EXPAND EDGE (M6_L_END_REGION_BRS2_pre4 COIN EDGE M6_L_END_REGION_BRS2_dense_edge) OUTSIDE BY Mx_S EXTEND BY TypeBRS2_LY
  M6_L_END_REGION_BRS2_pre6 = M6_L_END_REGION_BRS2_pre5 WITH EDGE (LENGTH (M6_L_END_REGION_BRS2_pre5 COIN EDGE M6i) == TypeBRS2_LH+TypeBRS2_LY)
  
  M6_L_END_REGION_BRS2_pre7 = M6_CORNER INTERACT M6_L_END_REGION_BRS2_pre6 
  M6_L_END_REGION_BRS2_pre8 = M6_L_END_REGION_BRS2_pre7 COIN EDGE M6_L_END_REGION_BRS2_pre6
  M6_L_END_REGION_BRS2_pre9 = (EXPAND EDGE M6_L_END_REGION_BRS2_pre8 INSIDE BY GRID EXTEND BY TypeBRS2_LG_max+GRID) TOUCH EDGE M6_L_END_REGION_BRS2_pre6
  M6_L_END_REGION_BRS2_pre10 = M6i COIN EDGE (EXT [M6_CORNER] M6_L_END_REGION_BRS2_pre9 > Mx_W+Mx_S <= Mx_W+Mx_S+TypeBRS2_S3 ABUT < 90 OPPOSITE MEASURE ALL)
  M6_L_END_REGION_BRS2_pre11 = M6_CORNER WITH EDGE M6_L_END_REGION_BRS2_pre10
  M6_L_END_REGION_BRS2_pre12 = EXT [M6_L_END_REGION_BRS2_pre7] M6_L_END_REGION_BRS2_pre11 > TypeBRS2_LGS_min <= TypeBRS2_LGS_max CORNER TO CORNER 
  M6_L_END_REGION_BRS2_MARK = M6_L_END_REGION_BRS2_pre6 WITH EDGE M6_L_END_REGION_BRS2_pre12
  M6_L_END_REGION_BRS2_MARK INTERACT EFPM6S6_M6i
}
#ENDIF
#ENDIF

