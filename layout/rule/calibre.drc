}
HVN25_65.R.3 { @ HV NMOS with 2 fingers GATE and common HV drain as a unit is must.
   A = ILP1i AND GATE_HVDN25_65
   HVN25_65 INTERACT A > 1 BY NET
   HVNMOS25_65_DRAIN INTERACT GATE_HVDN25_65 == 1
   C = NSDc INTERACT HVNMOS25_65_SOURCE
   D = GATE_HVDN25_65 OR HVNMOS25_65_DRAIN
   D INTERACT C > 1 BY NET
}
HVN25_65.R.4 { @ The finger number, Nf, should be even numbers. Nf means the finger number of the GATE on one OD
   DFM PROPERTY OD_HVDN25_65 GATE_HVDN25_65 OVERLAP MULTI 
   [-= FMOD(COUNT(GATE_HVDN25_65),2)] == 1    
}
HVN25_65.R.5 { @ {(HVN25_65 INTERACT OD) AND PO} must be a rectangle. A concave {(HVN25_65 INTERACT OD) AND PO} is not allowed
   A = (HVN25_65 INTERACT OD) AND POLY
   NOT RECTANGLE A ORTHOGONAL ONLY    
}
HVN25_65.R.6 { @ {{OD OR PO} INTERACT HVN25_65} overlap of NW, DNW, VAR, NT_N, TCDDMY. {OD INTERACT NWDMY}, SRM, ROM, BJTDMY. RH_OD, RH_PO, VTL_N, VTL_P, VTUL_N, VTUL_P, VTH_N, VTH_P, UHVT_N, UHVT_P, EHVT_N, EHVT_P, OD_18, OD25_33, OD25_18, OD18_15, or OD18_12 is not allowed   
   A = OD_HVDN25_65 OR PO_HVDN25_65
   A AND NWEL
   A AND DNW
   A AND VAR
   A AND NTN
   A AND TCDDMY
   A AND (OD INTERACT NWDMY)
   A AND SRM
   A AND ROM
   A AND BJTDMY
   A AND RHOD
   A AND RHPO
   A AND VTLN 
   A AND VTLP 
   A AND VTULN 
   A AND VTULP
   A AND VTHN 
   A AND VTHP
   A AND VTUHN 
   A AND VTUHP
   A AND EHVT_N
   A AND EHVT_P
   A AND OD18
