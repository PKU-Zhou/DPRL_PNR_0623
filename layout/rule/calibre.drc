  EXT POST_DRIVER_PINJ_NW_25V BESIDE_POST_DRIVER_NMOS_PW_NG < LUP_5_3_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_PINJ_NW_25V BESIDE_POST_DRIVER_NMOS_RW_NG < LUP_5_3_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_PINJ_NWi_25V BESIDE_POST_DRIVER_NMOS_RWi_NG < LUP_5_3_2 ABUT < 90 SINGULAR NOT CONNECTED
  EXT POST_DRIVER_NINJ_PW BESIDE_POST_DRIVER_PMOS_NW_25V_NG < LUP_5_3_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_NINJ_RW BESIDE_POST_DRIVER_PMOS_NW_25V_NG < LUP_5_3_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_NINJ_RWi BESIDE_POST_DRIVER_PMOS_NWi_25V_NG < LUP_5_3_2 ABUT < 90 SINGULAR NOT CONNECTED
}

// LUP.5.4.0 is checked by LUP.5.4.1 and LUP.5.4.2

LUP.5.4.1 { @ If all of guard-ring width >= 0.2 um (e.g. width of guard-ring of LUP.1 and LUP.2) >= 4 
  EXT POST_DRIVER_PINJ_NW_33V BESIDE_POST_DRIVER_NMOS_PW < LUP_5_4_1 ABUT < 90 SINGULAR
  EXT POST_DRIVER_PINJ_NW_33V BESIDE_POST_DRIVER_NMOS_RW < LUP_5_4_1 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_PINJ_NWi_33V BESIDE_POST_DRIVER_NMOS_RWi < LUP_5_4_1 ABUT < 90 SINGULAR NOT CONNECTED
  EXT POST_DRIVER_NINJ_PW BESIDE_POST_DRIVER_PMOS_NW_33V < LUP_5_4_1 ABUT < 90 SINGULAR
  EXT POST_DRIVER_NINJ_RW BESIDE_POST_DRIVER_PMOS_NW_33V < LUP_5_4_1 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_NINJ_RWi BESIDE_POST_DRIVER_PMOS_NWi_33V < LUP_5_4_1 ABUT < 90 SINGULAR NOT CONNECTED
}
LUP.5.4.2 { @ If one of guard-ring width < 0.2 um (e.g. width of guard-ring of LUP.1 and LUP.2) >= 8 
  EXT POST_DRIVER_PINJ_NW_33V_NG BESIDE_POST_DRIVER_NMOS_PW < LUP_5_4_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_PINJ_NW_33V_NG BESIDE_POST_DRIVER_NMOS_RW < LUP_5_4_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_PINJ_NWi_33V_NG BESIDE_POST_DRIVER_NMOS_RWi < LUP_5_4_2 ABUT < 90 SINGULAR NOT CONNECTED
  EXT POST_DRIVER_NINJ_PW_NG BESIDE_POST_DRIVER_PMOS_NW_33V < LUP_5_4_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_NINJ_RW_NG BESIDE_POST_DRIVER_PMOS_NW_33V < LUP_5_4_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_NINJ_RWi_NG BESIDE_POST_DRIVER_PMOS_NWi_33V < LUP_5_4_2 ABUT < 90 SINGULAR NOT CONNECTED

  EXT POST_DRIVER_PINJ_NW_33V BESIDE_POST_DRIVER_NMOS_PW_NG < LUP_5_4_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_PINJ_NW_33V BESIDE_POST_DRIVER_NMOS_RW_NG < LUP_5_4_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_PINJ_NWi_33V BESIDE_POST_DRIVER_NMOS_RWi_NG < LUP_5_4_2 ABUT < 90 SINGULAR NOT CONNECTED
  EXT POST_DRIVER_NINJ_PW BESIDE_POST_DRIVER_PMOS_NW_33V_NG < LUP_5_4_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_NINJ_RW BESIDE_POST_DRIVER_PMOS_NW_33V_NG < LUP_5_4_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_NINJ_RWi BESIDE_POST_DRIVER_PMOS_NWi_33V_NG < LUP_5_4_2 ABUT < 90 SINGULAR NOT CONNECTED
}
// LUP.5.7.0 is checked by LUP.5.7.1 and LUP.5.7.2
LUP.5.7.1 { @ If all of guard-ring width >= 0.2 um (e.g. width of guard-ring of LUP.1 and LUP.2) >= 23 
  EXT POST_DRIVER_PINJ_NW_65V BESIDE_POST_DRIVER_NMOS_PW < LUP_5_7_1 ABUT < 90 SINGULAR
  EXT POST_DRIVER_PINJ_NW_65V BESIDE_POST_DRIVER_NMOS_RW < LUP_5_7_1 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_PINJ_NWi_65V BESIDE_POST_DRIVER_NMOS_RWi < LUP_5_7_1 ABUT < 90 SINGULAR NOT CONNECTED
  EXT POST_DRIVER_NINJ_PW BESIDE_POST_DRIVER_PMOS_NW_65V < LUP_5_7_1 ABUT < 90 SINGULAR
  EXT POST_DRIVER_NINJ_RW BESIDE_POST_DRIVER_PMOS_NW_65V < LUP_5_7_1 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_NINJ_RWi BESIDE_POST_DRIVER_PMOS_NWi_65V < LUP_5_7_1 ABUT < 90 SINGULAR NOT CONNECTED
}
LUP.5.7.2 { @ If one of guard-ring width < 0.2 um (e.g. width of guard-ring of LUP.1 and LUP.2) >= 40 
  EXT POST_DRIVER_PINJ_NW_65V_NG BESIDE_POST_DRIVER_NMOS_PW < LUP_5_7_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_PINJ_NW_65V_NG BESIDE_POST_DRIVER_NMOS_RW < LUP_5_7_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_PINJ_NWi_65V_NG BESIDE_POST_DRIVER_NMOS_RWi < LUP_5_7_2 ABUT < 90 SINGULAR NOT CONNECTED
  EXT POST_DRIVER_NINJ_PW_NG BESIDE_POST_DRIVER_PMOS_NW_65V < LUP_5_7_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_NINJ_RW_NG BESIDE_POST_DRIVER_PMOS_NW_65V < LUP_5_7_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_NINJ_RWi_NG BESIDE_POST_DRIVER_PMOS_NWi_65V < LUP_5_7_2 ABUT < 90 SINGULAR NOT CONNECTED

  EXT POST_DRIVER_PINJ_NW_65V BESIDE_POST_DRIVER_NMOS_PW_NG < LUP_5_7_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_PINJ_NW_65V BESIDE_POST_DRIVER_NMOS_RW_NG < LUP_5_7_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_PINJ_NWi_65V BESIDE_POST_DRIVER_NMOS_RWi_NG < LUP_5_7_2 ABUT < 90 SINGULAR NOT CONNECTED
  EXT POST_DRIVER_NINJ_PW BESIDE_POST_DRIVER_PMOS_NW_65V_NG < LUP_5_7_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_NINJ_RW BESIDE_POST_DRIVER_PMOS_NW_65V_NG < LUP_5_7_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_NINJ_RWi BESIDE_POST_DRIVER_PMOS_NWi_65V_NG < LUP_5_7_2 ABUT < 90 SINGULAR NOT CONNECTED
}


CO_PACT = COi OR (PSDc NOT OUTSIDE COi)
NPUi = NSTPi INTERACT CO_PACT
NSTP_OS = SIZE NPUi BY LUP_6 INSIDE OF NWi STEP NW_S_1*0.7 TRUNCATE NW_S_1*0.7
PACT_CHECK = ((PACTi INTERACT COi) INTERACT POi) NOT POi

CO_NACT = COi OR (NSDc NOT OUTSIDE COi)
PPUi = PSTPi INTERACT CO_NACT
PSTP_OS = SIZE PPUi BY LUP_6 INSIDE OF PWELi STEP NW_S_1*0.7 TRUNCATE NW_S_1*0.7
NACT_CHECK = ((NACTi INTERACT COi) INTERACT POi) NOT POi

LUP.6 { @ Any point inside NMOS source/drain space to the nearest PW STRAP in the same PW <= ^LUP_6 um
        @ Any point inside PMOS source/drain space to the nearest NW STRAP in the same NW <= ^LUP_6 um
    PACT_CHECK NOT NSTP_OS
    NACT_CHECK NOT PSTP_OS
}

// LUP.10 is checked by LUP.10__LUP.13
// LUP.13 is checked by LUP.10__LUP.13
#IFDEF ALL_AREA_IO
LUP.10__LUP.13 { @ For Area I/O, within ^LUP_10 um from OD injector,
#ELSE
LUP.10__LUP.13 { @ For Area I/O, within ^LUP_10 um from OD injector (covered by LUPWDMY_2),
#ENDIF
@ Any point inside NMOS source/drain space to the nearest PW STRAP in the same PW <= ^LUP_13 um
@ Any point inside PMOS source/drain space to the nearest NW STRAP in the same NW <= ^LUP_13 um
#IFDEF ALL_AREA_IO
  TRIGGER_SOURCE  = AREA POST_DRIVER_ACT >= LUP_10E2
#ELSE
  TRIGGER_SOURCE  = AREA (POST_DRIVER_ACT NOT OUTSIDE LUPWDMY_2) >= LUP_10E2
#ENDIF

  CORE_LOGIC_NACT = (NACT_CHECK NOT TRIGGER_SOURCE) NOT INSIDE PTAP_guard_ring_hole
  CORE_LOGIC_PACT = (PACT_CHECK NOT TRIGGER_SOURCE) NOT INSIDE NTAP_guard_ring_hole

  NACT_LUP_pre = CORE_LOGIC_NACT NOT OUTSIDE (SIZE TRIGGER_SOURCE BY LUP_10)
  PACT_LUP_pre = CORE_LOGIC_PACT NOT OUTSIDE (SIZE TRIGGER_SOURCE BY LUP_10)
  NACT_LUP = NACT_LUP_pre NOT OUTSIDE ( SIZE (SIZE PACT_LUP_pre BY LUP_10E OVERUNDER) BY LUP_10E BEVEL 2)
  PACT_LUP = PACT_LUP_pre NOT OUTSIDE ( SIZE (SIZE NACT_LUP_pre BY LUP_10E OVERUNDER) BY LUP_10E BEVEL 2)
  
  PSTP_OS = SIZE PPUi BY LUP_13 INSIDE OF PWELi STEP NW_S_1*0.7 TRUNCATE NW_S_1*0.7
  NACT_LUP NOT PSTP_OS

  NSTP_OS = SIZE NPUi BY LUP_13 INSIDE OF NWi STEP NW_S_1*0.7 TRUNCATE NW_S_1*0.7
  PACT_LUP NOT NSTP_OS
}
// LUP.11 is not necessary to check. It is checked in Calibre PERC.
// LUP.12 is not necessary to check. It is checked in Calibre PERC.
LUP.14 { @ For Area I/O, width of picup ring and guard rings for the OD injector >= ^LUP_14
#IFDEF ALL_AREA_IO
  AREA_IO_NACT = COPY POST_DRIVER_NACT 
  AREA_IO_PACT = COPY POST_DRIVER_PACT
#ELSE
  AREA_IO_NACT = POST_DRIVER_NACT NOT OUTSIDE LUPWDMY_2
  AREA_IO_PACT = POST_DRIVER_PACT NOT OUTSIDE LUPWDMY_2
#ENDIF

  AREA_IO_NACT NOT INSIDE PTAP_guard_ring_hole
  AREA_IO_PACT NOT INSIDE NTAP_guard_ring_hole
  PTAP_guard_ring_2nd = ((HOLES PSTPi INNER) INTERACT AREA_IO_PACT) NOT INTERACT NACT
  NTAP_guard_ring_2nd = ((HOLES NSTPi INNER) INTERACT AREA_IO_NACT) NOT INTERACT PACT
  AREA_IO_NACT NOT INSIDE NTAP_guard_ring_2nd
  AREA_IO_PACT NOT INSIDE PTAP_guard_ring_2nd

  PTAP_guard_ring_hole_edge = PSTPi COIN OUTSIDE EDGE (PTAP_guard_ring_hole INTERACT AREA_IO_NACT)
  NTAP_guard_ring_hole_edge = NSTPi COIN OUTSIDE EDGE (NTAP_guard_ring_hole INTERACT AREA_IO_PACT)
  INT PTAP_guard_ring_hole_edge PSTPi < LUP_14 ABUT < 90 REGION
  INT NTAP_guard_ring_hole_edge NSTPi < LUP_14 ABUT < 90 REGION

  PTAP_guard_ring_2nd_edge = PSTPi COIN OUTSIDE EDGE PTAP_guard_ring_2nd
  NTAP_guard_ring_2nd_edge = NSTPi COIN OUTSIDE EDGE NTAP_guard_ring_2nd
  INT PTAP_guard_ring_2nd_edge PSTPi < LUP_14 ABUT < 90 REGION
  INT NTAP_guard_ring_2nd_edge NSTPi < LUP_14 ABUT < 90 REGION
}

// LUP.15 is not necessary to check. It is checked in Calibre PERC.


#IFDEF GUIDELINE_ESD

// I/O ESD Guidance
//==================
PMOSi = (PACTi INTERACT POi) INTERACT COi //Interact CONTi to filter out filler cell.
NMOSi = (NACTi INTERACT POi) INTERACT COi
EPMOS = PMOSi AND SDI
ENMOS = NMOSi AND SDI
EMOS = EPMOS OR ENMOS
PASD = PACT NOT POLY
NASD = NACT NOT POLY
EPSD = SDI AND PASD
ENSD = SDI AND NASD
EGTE = SDI AND GATE
ECO  = (CO AND SDI) AND OD
ESD_GATE_W = GATE_W INSIDE EDGE SDI


// Define ESD Gate Type
//======================
EGTE_FULL_RPO = EGTE INSIDE RPO
EGTE_PART_RPO = EGTE CUT RPO  
EGTE_NO_RPO = EGTE NOT INTERACT RPO

REG_ENMOS = (ENMOS INTERACT EGTE_PART_RPO) NOT INTERACT EGTE_FULL_RPO
REG_EPMOS = (EPMOS INTERACT EGTE_PART_RPO) NOT INTERACT EGTE_FULL_RPO
TOL_ENMOS = (ENMOS INTERACT EGTE_PART_RPO) INTERACT EGTE_FULL_RPO
PCL_ENMOS = ENMOS NOT INTERACT RPO


//REG_EGTE = EGTE AND (REG_ENMOS OR REG_EPMOS)
REG_ENGTE = EGTE AND REG_ENMOS
REG_EPGTE = EGTE AND REG_EPMOS
REG_EGTE = REG_ENGTE OR REG_EPGTE
TOL_EGTE = EGTE AND (TOL_ENMOS OR REG_EPMOS)
PCL_EGTE = EGTE AND PCL_ENMOS
// For ESD.29g and ESD.29.0g
TOL_ENGTE = EGTE AND (TOL_ENMOS OR REG_ENMOS)
TOL_EPGTE = EGTE AND REG_EPMOS
// For ESD.1g
//=============
NSDc_HVMOS = (NSDc INTERACT NMOSi) INTERACT OD2
NSDc_LVMOS = (NSDc INTERACT NMOSi) NOT INTERACT OD2
PSDc_HVMOS = (PSDc INTERACT PMOSi) INTERACT OD2
PSDc_LVMOS = (PSDc INTERACT PMOSi) NOT INTERACT OD2
NSDc_HVMOS_SDI = NSDc_HVMOS INTERACT SDI 
NSDc_LVMOS_SDI = NSDc_LVMOS INTERACT SDI 
PSDc_HVMOS_SDI = PSDc_HVMOS INTERACT SDI 
PSDc_LVMOS_SDI = PSDc_LVMOS INTERACT SDI 

HV_GATEc = STAMP HV_GATE BY ILP1i
LV_GATEc = STAMP LV_GATE BY ILP1i

// For ESD.6g
//=============
CONNECT ENSD NSDu
CONNECT EPSD PSDu
PSTP_real = PSTPu NOT DIODMY
NSTP_real = (NSTPu NOT (NWEL INTERACT DIODMY)) NOT VAR
ENSD_SOURCE_pre = NET AREA RATIO ENSD PSTP_real > 0 [!!AREA(ENSD)*!!AREA(PSTP_real)]
ENSD_DRAIN_pre = NET AREA RATIO ENSD NSTP_real > 0 [!!AREA(ENSD)*!!AREA(NSTP_real)]
EPSD_SOURCE_pre = NET AREA RATIO EPSD NSTP_real > 0 [!!AREA(EPSD)*!!AREA(NSTP_real)]
ENSD_SOURCE = ENSD_SOURCE_pre OR ((ENSD NOT PCL_ENMOS) OUTSIDE RPO)
EPSD_SOURCE = EPSD_SOURCE_pre OR (EPSD OUTSIDE RPO)
ENSD_DRAIN = (ENSD NOT ENSD_SOURCE) NOT INSIDE RPO
EPSD_DRAIN = (EPSD NOT EPSD_SOURCE) NOT INSIDE RPO
ENMOSc = STAMP ENMOS BY ENSD_DRAIN
EPMOSc = STAMP EPMOS BY EPSD_DRAIN


IO_PADi  = (((PADi NOT VDD_PAD) NOT VSS_PAD) NOT VDD_PAD_BY_DUMMY) NOT VSS_PAD_BY_DUMMY
ODRES_US_T = (OD INTERACT ODRES_US) NOT ODRES_US
ODRES_US_Ts = STAMP ODRES_US_T BY COii
PORES_US_T = (POLY INTERACT PORES_US) NOT PORES_US
PORES_US_Ts = STAMP PORES_US_T BY COii

#IFDEF DEFINE_PAD_BY_TEXT
PWR_M1i_BY_TEXT = M1i WITH TEXT VDD_TEXT M1_PIN_TEXT PRIMARY ONLY
GND_M1i_BY_TEXT = M1i WITH TEXT VSS_TEXT M1_PIN_TEXT PRIMARY ONLY
PAD_M1i_BY_TEXT = M1i WITH TEXT PAD_TEXT M1_PIN_TEXT PRIMARY ONLY
PWR_M2i_BY_TEXT = M2i WITH TEXT VDD_TEXT M2_PIN_TEXT PRIMARY ONLY
GND_M2i_BY_TEXT = M2i WITH TEXT VSS_TEXT M2_PIN_TEXT PRIMARY ONLY
PAD_M2i_BY_TEXT = M2i WITH TEXT PAD_TEXT M2_PIN_TEXT PRIMARY ONLY
PWR_M3i_BY_TEXT = M3i WITH TEXT VDD_TEXT M3_PIN_TEXT PRIMARY ONLY
GND_M3i_BY_TEXT = M3i WITH TEXT VSS_TEXT M3_PIN_TEXT PRIMARY ONLY
PAD_M3i_BY_TEXT = M3i WITH TEXT PAD_TEXT M3_PIN_TEXT PRIMARY ONLY
PWR_M4i_BY_TEXT = M4i WITH TEXT VDD_TEXT M4_PIN_TEXT PRIMARY ONLY
GND_M4i_BY_TEXT = M4i WITH TEXT VSS_TEXT M4_PIN_TEXT PRIMARY ONLY
PAD_M4i_BY_TEXT = M4i WITH TEXT PAD_TEXT M4_PIN_TEXT PRIMARY ONLY
PWR_M5i_BY_TEXT = M5i WITH TEXT VDD_TEXT M5_PIN_TEXT PRIMARY ONLY
GND_M5i_BY_TEXT = M5i WITH TEXT VSS_TEXT M5_PIN_TEXT PRIMARY ONLY
PAD_M5i_BY_TEXT = M5i WITH TEXT PAD_TEXT M5_PIN_TEXT PRIMARY ONLY
PWR_M6i_BY_TEXT = M6i WITH TEXT VDD_TEXT M6_PIN_TEXT PRIMARY ONLY
GND_M6i_BY_TEXT = M6i WITH TEXT VSS_TEXT M6_PIN_TEXT PRIMARY ONLY
PAD_M6i_BY_TEXT = M6i WITH TEXT PAD_TEXT M6_PIN_TEXT PRIMARY ONLY
PWR_M7i_BY_TEXT = M7i WITH TEXT VDD_TEXT M7_PIN_TEXT PRIMARY ONLY
GND_M7i_BY_TEXT = M7i WITH TEXT VSS_TEXT M7_PIN_TEXT PRIMARY ONLY
PAD_M7i_BY_TEXT = M7i WITH TEXT PAD_TEXT M7_PIN_TEXT PRIMARY ONLY
PWR_M8i_BY_TEXT = M8i WITH TEXT VDD_TEXT M8_PIN_TEXT PRIMARY ONLY
GND_M8i_BY_TEXT = M8i WITH TEXT VSS_TEXT M8_PIN_TEXT PRIMARY ONLY
PAD_M8i_BY_TEXT = M8i WITH TEXT PAD_TEXT M8_PIN_TEXT PRIMARY ONLY
PWR_M9i_BY_TEXT = M9i WITH TEXT VDD_TEXT M9_PIN_TEXT PRIMARY ONLY
GND_M9i_BY_TEXT = M9i WITH TEXT VSS_TEXT M9_PIN_TEXT PRIMARY ONLY
PAD_M9i_BY_TEXT = M9i WITH TEXT PAD_TEXT M9_PIN_TEXT PRIMARY ONLY
PWR_APi_BY_TEXT = APi WITH TEXT VDD_TEXT AP_PIN_TEXT PRIMARY ONLY
GND_APi_BY_TEXT = APi WITH TEXT VSS_TEXT AP_PIN_TEXT PRIMARY ONLY
PAD_APi_BY_TEXT = APi WITH TEXT PAD_TEXT AP_PIN_TEXT PRIMARY ONLY

ODRES_US_T_IO_PAD_pre = NET AREA RATIO ODRES_US_Ts OVER IO_PADi PAD_M9i_BY_TEXT PAD_M8i_BY_TEXT PAD_M7i_BY_TEXT PAD_M6i_BY_TEXT PAD_M5i_BY_TEXT PAD_M4i_BY_TEXT PAD_M3i_BY_TEXT PAD_M2i_BY_TEXT PAD_M1i_BY_TEXT PAD_APi_BY_TEXT > 0
PORES_US_T_IO_PAD_pre = NET AREA RATIO PORES_US_Ts OVER IO_PADi PAD_M9i_BY_TEXT PAD_M8i_BY_TEXT PAD_M7i_BY_TEXT PAD_M6i_BY_TEXT PAD_M5i_BY_TEXT PAD_M4i_BY_TEXT PAD_M3i_BY_TEXT PAD_M2i_BY_TEXT PAD_M1i_BY_TEXT PAD_APi_BY_TEXT > 0
ODRES_US_T_VDD_VSS_PAD_TEXT = NET AREA RATIO ODRES_US_Ts OVER PWR_M9i_BY_TEXT PWR_M8i_BY_TEXT PWR_M7i_BY_TEXT PWR_M6i_BY_TEXT PWR_M5i_BY_TEXT PWR_M4i_BY_TEXT PWR_M3i_BY_TEXT PWR_M2i_BY_TEXT PWR_M1i_BY_TEXT PWR_APi_BY_TEXT GND_M9i_BY_TEXT GND_M8i_BY_TEXT GND_M7i_BY_TEXT GND_M6i_BY_TEXT GND_M5i_BY_TEXT GND_M4i_BY_TEXT GND_M3i_BY_TEXT GND_M2i_BY_TEXT GND_M1i_BY_TEXT GND_APi_BY_TEXT > 0 
PORES_US_T_VDD_VSS_PAD_TEXT = NET AREA RATIO PORES_US_Ts OVER PWR_M9i_BY_TEXT PWR_M8i_BY_TEXT PWR_M7i_BY_TEXT PWR_M6i_BY_TEXT PWR_M5i_BY_TEXT PWR_M4i_BY_TEXT PWR_M3i_BY_TEXT PWR_M2i_BY_TEXT PWR_M1i_BY_TEXT PWR_APi_BY_TEXT GND_M9i_BY_TEXT GND_M8i_BY_TEXT GND_M7i_BY_TEXT GND_M6i_BY_TEXT GND_M5i_BY_TEXT GND_M4i_BY_TEXT GND_M3i_BY_TEXT GND_M2i_BY_TEXT GND_M1i_BY_TEXT GND_APi_BY_TEXT > 0 
ODRES_US_T_IO_PAD = ODRES_US_T_IO_PAD_pre NOT ODRES_US_T_VDD_VSS_PAD_TEXT
PORES_US_T_IO_PAD = PORES_US_T_IO_PAD_pre NOT PORES_US_T_VDD_VSS_PAD_TEXT
#ELSE
ODRES_US_T_IO_PAD = NET AREA RATIO ODRES_US_Ts OVER IO_PADi > 0
PORES_US_T_IO_PAD = NET AREA RATIO PORES_US_Ts OVER IO_PADi > 0
#ENDIF


#IFDEF FULL_CHIP

ESD.WARN.1 { @ SDI (122;0) needs to be found in each of power, ground, or IOPAD pad of CB, CBD, CB2_WB, CB2_FC and PM2 . Exception: SEALRING_ALL When turn on option "DEFINE_PAD_BY_TEXT", only check connectivity of CB, CBD, CB2_WB, CB2_FC and PM2 with text. When turn off option "DEFINE_PAD_BY_TEXT", only check connectivity of CB, CBD, CB2_WB, CB2_FC and PM2 to STRAP/VDDDMY/VSSDMY Connection is broken by PO/OD/NW resistor   
   ESD_NSDc = NSDc AND SDI
   ESD_PSDc = PSDc AND SDI
   ESD_PSTPi = PSTPi AND SDI
   ESD_NSTPi = NSTPi AND SDI

   //VDD_ODc = ODc AND SDI

   VDD_NSDc = NSDc AND SDI
   VDD_PSDc = PSDc AND SDI
   VDD_PSTPi = PSTPi AND SDI
   VDD_NSTPi = NSTPi AND SDI
   PAD_NOT_DUMMY = PADi AND (NET AREA RATIO PADi OVER VIA1ii > 0)
 

#IFDEF DEFINE_PAD_BY_TEXT
   PAD_VDD_PAD = NET AREA RATIO PAD_NOT_DUMMY OVER PWR_M9i_BY_TEXT PWR_M8i_BY_TEXT PWR_M7i_BY_TEXT PWR_M6i_BY_TEXT PWR_M5i_BY_TEXT PWR_M4i_BY_TEXT PWR_M3i_BY_TEXT PWR_M2i_BY_TEXT PWR_M1i_BY_TEXT PWR_APi_BY_TEXT > 0 
   PAD_IOVSS_PAD = NET AREA RATIO PAD_NOT_DUMMY OVER PWR_M9i_BY_TEXT PWR_M8i_BY_TEXT PWR_M7i_BY_TEXT PWR_M6i_BY_TEXT PWR_M5i_BY_TEXT PWR_M4i_BY_TEXT PWR_M3i_BY_TEXT PWR_M2i_BY_TEXT PWR_M1i_BY_TEXT PWR_APi_BY_TEXT == 0 
#ELSE
   PAD_VDD_PAD = NET AREA RATIO PAD_NOT_DUMMY OVER VDD_PAD VDD_PAD_BY_DUMMY > 0 
   PAD_IOVSS_PAD = NET AREA RATIO PAD_NOT_DUMMY OVER VDD_PAD VDD_PAD_BY_DUMMY == 0 
#ENDIF // DEFINE_PAD_BY_TEXT
 //MERGE ((NET AREA RATIO PAD_VDD_PAD VDD_ODc == 0) NOT SEALRING_ALL)

   MERGE ((NET AREA RATIO PAD_VDD_PAD OVER VDD_NSDc VDD_PSDc VDD_PSTPi VDD_NSTPi== 0) NOT SEALRING_ALL)
   MERGE ((NET AREA RATIO PAD_IOVSS_PAD OVER ESD_NSDc ESD_PSDc ESD_PSTPi ESD_NSTPi== 0) NOT SEALRING_ALL)


}
#ENDIF

ESD.WARN.2 { @ SDI encloure of ACTIVE >= 0
  (DACT INTERACT SDI) NOT SDI
}


ESD.1g { @ Use thin oxide transistor for thin oxide power clamp and thin oxide I/O buffers; use thick oxide transistor for the thick oxide Power Clamp and thick oxide I/O buffers (Figure XXX). DRC will flag the following condition: ((MOS INTERACT OD2) INTERACT SDI) connected to (MOS NOT INTERACT OD2) When turn off option "DEFINE_PAD_BY_TEXT", DRC will exclude Drain/Source/Gate connected to {{PW NOT RW} STRAP}. When turn on option "DEFINE_PAD_BY_TEXT", DRC will exclude Drain/Source/Gate connected to VSS net   
#IFDEF DEFINE_PAD_BY_TEXT
  NSDc_HVMOS_SDI_pre = NET AREA RATIO NSDc_HVMOS_SDI OVER GND_M9i_BY_TEXT GND_M8i_BY_TEXT GND_M7i_BY_TEXT GND_M6i_BY_TEXT GND_M5i_BY_TEXT GND_M4i_BY_TEXT GND_M3i_BY_TEXT GND_M2i_BY_TEXT GND_M1i_BY_TEXT GND_APi_BY_TEXT == 0
  NET AREA RATIO NSDc_HVMOS_SDI_pre OVER NSDc_LVMOS PSDc_LVMOS LV_GATEc > 0
    RDB ESD.1g.hv_N.rep NSDc_HVMOS_SDI_pre NSDc_LVMOS PSDc_LVMOS LV_GATEc
  PSDc_HVMOS_SDI_pre = NET AREA RATIO PSDc_HVMOS_SDI OVER GND_M9i_BY_TEXT GND_M8i_BY_TEXT GND_M7i_BY_TEXT GND_M6i_BY_TEXT GND_M5i_BY_TEXT GND_M4i_BY_TEXT GND_M3i_BY_TEXT GND_M2i_BY_TEXT GND_M1i_BY_TEXT GND_APi_BY_TEXT == 0
  NET AREA RATIO PSDc_HVMOS_SDI_pre OVER NSDc_LVMOS PSDc_LVMOS LV_GATEc > 0
    RDB ESD.1g.hv_P.rep PSDc_HVMOS_SDI_pre NSDc_LVMOS PSDc_LVMOS LV_GATEc
#ELSE
  NET AREA RATIO NSDc_HVMOS_SDI NSDc_LVMOS PSDc_LVMOS LV_GATEc PSTPix > 0 
    [!!AREA(NSDc_HVMOS_SDI)*!AREA(PSTPix)*(!!AREA(NSDc_LVMOS)+!!AREA(PSDc_LVMOS)+!!AREA(LV_GATEc))] 
    RDB ESD.1g.hv_N.rep NSDc_HVMOS_SDI NSDc_LVMOS PSDc_LVMOS LV_GATEc
  NET AREA RATIO PSDc_HVMOS_SDI NSDc_LVMOS PSDc_LVMOS LV_GATEc PSTPix > 0 
    [!!AREA(PSDc_HVMOS_SDI)*!AREA(PSTPix)*(!!AREA(NSDc_LVMOS)+!!AREA(PSDc_LVMOS)+!!AREA(LV_GATEc))] 
    RDB ESD.1g.hv_P.rep PSDc_HVMOS_SDI NSDc_LVMOS PSDc_LVMOS LV_GATEc
#ENDIF
} 


ESD.3g { @ Unit finger width of NMOS and PMOS for I/O buffer and Power Clamp >= ^ESD_3gA um <= ^ESD_3gB um
  EGTE_W = (EGTE INSIDE EDGE OD) NOT INSIDE EDGE UDM
  PATH LENGTH EGTE_W < ESD_3gA
  PATH LENGTH EGTE_W > ESD_3gB
}
ESD.5g { @ For same type OD of the I/O buffer and Power Clamp should be surrounded by a guard-ring. All other type ODs should be placed outside this guard-ring.
  EPMOS NOT INSIDE NTAP_guard_ring_hole
  ENMOS NOT INSIDE PTAP_guard_ring_hole
}

ESD.6g { @ Butted STRAP and the STRAP which are between two sources of the N/PMOS in the same I/O buffer and Power Clamp are strictly prohibited. 
  A = (EXT ENMOSc < ESD_6g ABUT < 90 OPPOSITE REGION CONNECTED) NOT INTERACT GATE
  A INTERACT PSTPi
  B = (EXT EPMOSc < ESD_6g ABUT < 90 OPPOSITE REGION CONNECTED) NOT INTERACT GATE
  B INTERACT NSTPi
}

NWELc = COPY NWEL
CONNECT NWELc
PWELc = COPY PWEL
CONNECT PWELc

ESD.7g { @ Except the ESD device, 2 separate same ODs connectd to 2 different PADs must follow one of the following: 1. The space of 2 same type ODs in the same well. 2. Two same type ODs should be separated by different types of OD. The same type ODs are N+OD and N+OD in the same PW or P-base substrate, or P+OD and P+OD in the same NW or N-base substrate, which connect to 2 different pads (Please refer to section XXX in detail) >= 1.2 
  PACT_CHECK = (PACT INTERACT PSD_IOPAD) NOT EPMOS 
  PACT_CHECK_CB = STAMP (PACT_CHECK INTERACT PSD_IOPAD == 1 BY NET) BY PSD_IOPAD
  P1 = EXT PACT_CHECK_CB < ESD_7g ABUT < 90 SINGULAR REGION NOT CONNECTED
  PACT_CHECK_NW = STAMP (PACT_CHECK INTERACT P1) BY NWELc
  P2 = EXT PACT_CHECK_NW < ESD_7g ABUT < 90 SINGULAR REGION CONNECTED
  ESD_P3 = P1 AND P2
  (ESD_P3 NOT NSTPi) INTERACT PACT_CHECK_CB > 1 BY NET
  PACT_CHECK INTERACT PSD_IOPAD > 1 BY NET
  
  NACT_CHECK = (NACT INTERACT NSD_IOPAD) NOT ENMOS
  NACT_CHECK_CB = STAMP (NACT_CHECK INTERACT NSD_IOPAD == 1 BY NET) BY NSD_IOPAD
  N1 = EXT NACT_CHECK_CB < ESD_7g ABUT < 90 SINGULAR REGION NOT CONNECTED
  NACT_CHECK_PW = STAMP (NACT_CHECK INTERACT N1) BY PWELc
  N2 = EXT NACT_CHECK_PW < ESD_7g ABUT < 90 SINGULAR REGION CONNECTED
  N3 = N1 AND N2
  (N3 NOT PSTPi) INTERACT NACT_CHECK_CB > 1 BY NET
  NACT_CHECK INTERACT NSD_IOPAD > 1 BY NET
}


// Regular I/O
//============

ESD_PMOS_GATE_W = ESD_GATE_W INSIDE EDGE PP
ESD_NMOS_GATE_W = ESD_GATE_W INSIDE EDGE NP
ESD_PMOS_GATE_W_EXP = ((EXPAND EDGE ESD_PMOS_GATE_W INSIDE BY GRID) NOT INSIDE UDM) INTERACT EPSD_DRAIN
ESD_NMOS_GATE_W_EXP = ((EXPAND EDGE ESD_NMOS_GATE_W INSIDE BY GRID) NOT INSIDE UDM) INTERACT ENSD_DRAIN
ESD_PMOS_GATE_W_EXPc = STAMP ESD_PMOS_GATE_W_EXP BY EPMOSc
ESD_NMOS_GATE_W_EXPc = STAMP ESD_NMOS_GATE_W_EXP BY ENMOSc

ESD.18g { @ Total finger width for NMOS in same connection of drain > ^ESD_18g um [check ESD.27g also]
  NET AREA RATIO ESD_NMOS_GATE_W_EXPc < ESD_18g
    [AREA(ESD_NMOS_GATE_W_EXPc)/GRID]
    RDB ESD.18g.NMOS.rep ESD_NMOS_GATE_W_EXPc
}
ESD.19g { @ Total finger width for PMOS in same connection of drain > ^ESD_19g um [check ESD.28g also]
  NET AREA RATIO ESD_PMOS_GATE_W_EXPc < ESD_19g
    [AREA(ESD_PMOS_GATE_W_EXPc)/GRID]
    RDB ESD.19g.PMOS.rep ESD_PMOS_GATE_W_EXPc
}
ESD.20g { @ Channel length: 3.3V Regular I/O NMOS (in OD25_33) >= ^ESD_20g_33V um
  REG_ENGTE_33V = REG_ENGTE AND OD2533
  INT REG_ENGTE_33V < ESD_20g_33V ABUT < 90 SINGULAR REGION
}
ESD.20.0g { @ Channel length: 3.3V Regular I/O PMOS (in OD25_33) >= ^ESD_20g_P_33V um
  REG_EPGTE_33V = REG_EPGTE AND OD2533
  INT REG_EPGTE_33V < ESD_20g_P_33V ABUT < 90 SINGULAR REGION
}
ESD.20.1g { @ Channel length: 2.5V Regular I/O (in OD25) >= ^ESD_20g_25V um
  REG_EGTE_25V = REG_EGTE AND OD25
  INT REG_EGTE_25V < ESD_20g_25V ABUT < 90 SINGULAR REGION
}
ESD.20.2g { @ Channel length: 1.8V Regular I/O (in OD18) >= ^ESD_20g_18V um
  REG_EGTE_18V = (REG_EGTE AND OD18) NOT INSIDE UDM
  INT REG_EGTE_18V < ESD_20g_18V ABUT < 90 SINGULAR REGION
}
ESD.21g { @ The NMOS and PMOS should have an unsilicided area on the drain side. That is, the RPO mask should block the drain side of the device (except the contact region which should remain silicided). DRC can only flag Gate without RPO on regular I/O ESD N/P MOS and HV tolerant I/O ESD PMOS when it shares OD with other regular I/O ESD N/P MOS and HV tolerant I/O ESD PMOS with RPO   
  REG_EGTE NOT INTERACT RPO
}
ESD.22g { @ Overlap of RPO on the drain side to the poly gate for Regular I/O == ^ESD_22g um [check ESD.50g also]
  REG_EGTE OUTSIDE RPO
  REG_EGTE_W = REG_EGTE INSIDE EDGE OD
  X = REG_EGTE_W INSIDE EDGE RPO
  Y = EXPAND EDGE X INSIDE BY ESD_22g
  REG_EGTE WITH EDGE X > 1
  (REG_EGTE AND RPO) XOR Y
}
ESD.23g { @ Width of the RPO on drain side for NMOS Regular I/O >= ^ESD_23g um [check ESD.51g also]
  REG_ENSD = (ENSD INTERACT REG_EGTE) AND RPO
  INT REG_ENSD < ESD_23g ABUT < 90 SINGULAR REGION
}
ESD.24g { @ Width of the RPO on drain side for PMOS Regular I/O >= ^ESD_24g um
  REG_EPSD = (EPSD INTERACT REG_EGTE) AND RPO
  INT REG_EPSD < ESD_24g ABUT < 90 SINGULAR REGION
}
ESD.25g { @ SR_ESD interact with RPO must inside I/O region (OD_18/OD_25)
  (SRESD INTERACT RPO) NOT INSIDE (OR OD18 OD25)
}

// HV Tolerant I/O
//================

TOL_ENOD = ENSD INTERACT TOL_EGTE
TOL_ENG  = (TOL_ENOD NOT INTERACT ECO) NOT INTERACT PSTP
TOL_ENSD = TOL_ENOD NOT TOL_ENG
TOL_ENS  = TOL_ENSD OUTSIDE RPO
TOL_END  = TOL_ENSD NOT OUTSIDE RPO

// ESD.27g is checked by ESD.18g
// ESD.28g is checked by ESD.19g
ESD.29g { @ Channel length: 5V Tolerant I/O NMOS (in OD25_33) >= ^ESD_29g_5 um
  TOL_ENGTE_5V = TOL_ENGTE AND OD2533
  INT TOL_ENGTE_5V < ESD_29g_5 ABUT < 90 SINGULAR REGION
}
ESD.29.0g { @ Channel length: 5V Tolerant I/O PMOS (in OD25_33) >= ^ESD_29g_P_5 um
  TOL_EPGTE_5V = TOL_EPGTE AND OD2533
  INT TOL_EPGTE_5V < ESD_29g_P_5 ABUT < 90 SINGULAR REGION
}
ESD.29.1g { @ Channel length: 3.3V Tolerant I/O (in OD25) >= ^ESD_29g_33 um
  TOL_EGTE_33V = TOL_EGTE AND OD25
  INT TOL_EGTE_33V < ESD_29g_33 ABUT < 90 SINGULAR REGION
}
ESD.29.2g { @ Channel length: 2.5V Tolerant I/O (in OD18) >= ^ESD_29g_25 um
  TOL_EGTE_25V = (TOL_EGTE AND OD18) NOT INSIDE UDM
  INT TOL_EGTE_25V < ESD_29g_25 ABUT < 90 SINGULAR REGION
}
ESD.30g { @ The NMOS and PMOS should have an unsilicided area on the drain side. That is, the RPO mask should block the drain side of the device (except the contact region which should remain silicided). DRC can only flag Gate without RPO on HV tolerant I/O ESD N/PMOS and regular I/O ESD P MOS when it shares OD with other HV tolerant I/O ESD N/PMOS and regular I/O ESD P MOS with RPO   
  TOL_EGTE NOT INTERACT RPO
}
ESD.31g { @ Overlap of RPO on the drain side to the poly gate for NMOS HV Tolerant I/O == ^ESD_31g um
  TOL_ENGTE1 = TOL_EGTE INTERACT TOL_END
  TOL_ENGTE2 = TOL_EGTE INTERACT TOL_ENS
  TOL_ENGTE1 NOT RPO
  TOL_ENGTE2 OUTSIDE RPO
  TOL_ENG NOT INTERACT TOL_ENGTE2
  TOL_ENGTE2_W = TOL_ENGTE2 INSIDE EDGE OD
  X = TOL_ENGTE2_W INSIDE EDGE RPO
  Y = EXPAND EDGE X INSIDE BY ESD_31g
  (TOL_ENGTE2 AND RPO) XOR Y
}
ESD.32g { @ Overlap of RPO on the drain side to the poly gate for PMOS HV Tolerant I/O == ^ESD_32g um
  TOL_EPGTE = TOL_EGTE INTERACT EPSD
  TOL_EPGTE OUTSIDE RPO
  TOL_EPGTE_W = TOL_EPGTE INSIDE EDGE OD
  X = TOL_EPGTE_W INSIDE EDGE RPO
  Y = EXPAND EDGE X INSIDE BY ESD_32g
  TOL_EPGTE WITH EDGE X > 1
  (TOL_EPGTE AND RPO) XOR Y
}
ESD.33g { @ Width of the RPO on drain side for NMOS HV Tolerant I/O >= ^ESD_33g um
  TOL_ENSD = TOL_END AND RPO
  INT TOL_ENSD < ESD_33g ABUT < 90 SINGULAR REGION
}
ESD.34g { @ Width of the RPO on drain side for PMOS HV Tolerant I/O >= ^ESD_34g um
  TOL_EPSD = (EPSD INTERACT TOL_EGTE) AND RPO
  INT TOL_EPSD < ESD_34g ABUT < 90 SINGULAR REGION
}
ESD.36g { @ Space of 1st poly gate(N2) to 2nd poly gate(N3) for NMOS HV Tolerant I/O == ^ESD_36g um
  INT TOL_ENG < ESD_36g ABUT < 90 SINGULAR REGION
  TOL_ENG WITH WIDTH > ESD_36g
  (TOL_EGTE AND NP) NOT INTERACT TOL_ENG
}
ESD.37g { @ The NMOS HV Tolerant I/O should have ESDIMP
  TOL_ENMOS NOT INTERACT ESDIMP
}


// Power Clamp
//============

PCL_GATE_W = ESD_GATE_W INSIDE EDGE PCL_ENMOS
PCL_HV_GATE_W = PCL_GATE_W INSIDE EDGE OD2
PCL_LV_GATE_W = PCL_GATE_W NOT INSIDE EDGE OD2
PCL_HV_GATE_W_EXP = (EXPAND EDGE PCL_HV_GATE_W INSIDE BY GRID) INTERACT ENSD_DRAIN
PCL_LV_GATE_W_EXP = (EXPAND EDGE PCL_LV_GATE_W INSIDE BY GRID) INTERACT ENSD_DRAIN
PCL_HV_GATE_W_EXPc = STAMP PCL_HV_GATE_W_EXP BY ENMOSc
PCL_LV_GATE_W_EXPc = STAMP PCL_LV_GATE_W_EXP BY ENMOSc

PCL2_ENMOS = REG_ENMOS INTERACT (ENSD_DRAIN_pre NOT ENSD_SOURCE_pre) 
PCL2_EGTE = EGTE AND PCL2_ENMOS
PCL2_GATE_W = ESD_GATE_W INSIDE EDGE PCL2_ENMOS
PCL2_HV_GATE_W = PCL2_GATE_W INSIDE EDGE OD25
PCL2_HV_GATE_W_EXP = ((EXPAND EDGE PCL2_HV_GATE_W INSIDE BY GRID) NOT INSIDE UDM) INTERACT ENSD_DRAIN
PCL2_HV_GATE_W_EXPc = STAMP PCL2_HV_GATE_W_EXP BY ENMOSc


ESD.40g { @ Total finger width for 3.3V/2.5V/1.8V fully silicided type Power Clamp in same connection of drain >= ^ESD_40g_HV um
  NET AREA RATIO PCL_HV_GATE_W_EXPc < ESD_40g_HV
    [AREA(PCL_HV_GATE_W_EXPc)/GRID]
    RDB ESD.40g.rep PCL_HV_GATE_W_EXPc
}
ESD.40.1g { @ Total finger width for core fully silicided type Power Clamp in same connection of drain >= ^ESD_40g_LV um
  NET AREA RATIO PCL_LV_GATE_W_EXPc < ESD_40g_LV
    [AREA(PCL_LV_GATE_W_EXPc)/GRID]
    RDB ESD.40.1g.rep PCL_LV_GATE_W_EXPc
}
ESD.42g { @ Channel length for 3.3V Power Clamp (in OD25_33) >= ^ESD_42g_33V um
  PCL_EGTE_33V = (PCL_EGTE OR PCL2_EGTE) AND OD2533
  INT PCL_EGTE_33V < ESD_42g_33V ABUT < 90 SINGULAR REGION
}
ESD.42.1g { @ Channel length for 2.5V Power Clamp (in OD25) >= ^ESD_42g_25V um
  PCL_EGTE_25V = (PCL_EGTE OR PCL2_EGTE) AND OD25
  INT PCL_EGTE_25V < ESD_42g_25V ABUT < 90 SINGULAR REGION
}
ESD.42.2g { @ Channel length for 1.8V Power Clamp (in OD18) >= ^ESD_42g_18V um
  PCL_EGTE_18V = ((PCL_EGTE OR PCL2_EGTE) AND OD18) NOT INSIDE UDM
  INT PCL_EGTE_18V < ESD_42g_18V ABUT < 90 SINGULAR REGION
}  
ESD.42.3g { @ Channel length for 0.85V/1.05V Power Clamp (not OD2) = ^ESD_42g_LV1 ~ ^ESD_42g_LV2 um
  PCL_EGTE_LV_L  = ((PCL_EGTE OR PCL2_EGTE) NOT OD2) COIN EDGE GATE_L
  LENGTH PCL_EGTE_LV_L < ESD_42g_LV1
  LENGTH PCL_EGTE_LV_L > ESD_42g_LV2
}
ESD.49g { @ Total finger width for 3.3V/2.5V RPO type Power Clamp in same connection of drain >= ^ESD_49g um
  NET AREA RATIO PCL2_HV_GATE_W_EXPc < ESD_49g
    [AREA(PCL2_HV_GATE_W_EXPc)/GRID]
    RDB ESD.49g.rep PCL2_HV_GATE_W_EXPc
}
// ESD.50g is checked by ESD.22g
// ESD.51g is checked by ESD.23g
ESD.52g { @ Big MOS of RPO type Power Clamp is strongly recommended has ESDIMP
   PCL2_ENMOS NOT INTERACT ESDIMP
}




NFD = (((NACT NOT INTERACT POLY) AND SDI) CUT RPO) NOT INTERACT RPDMY 
PFD = (((PACT NOT INTERACT POLY) AND SDI) CUT RPO) NOT INTERACT RPDMY
NFDc = STAMP NFD BY NSDc
PFDc = STAMP PFD BY PSDc
NFD_Emitter = NET AREA RATIO NFDc PSTPi > 0
NFD_Collector = NFDc NOT NFD_Emitter 
PFD_Emitter = NET AREA RATIO PFDc NSTPi > 0
PFD_Collector = PFDc NOT PFD_Emitter



ULP_5V_HVMOS:WARNING { @ 5V HVMOS NEVER general offer for ULP process.
  HVMOS= NFD OR PFD
  COPY HVMOS 
}





#ENDIF


VARIABLE  HIA_1gA  0.31
VARIABLE  HIA_1gB  1.6 
VARIABLE  HIA_2gA  5  
VARIABLE  HIA_2gB  40  
VARIABLE  HIA_3g   300.000
VARIABLE  HIA_4gA  0.15
VARIABLE  HIA_4gB  0.4 
VARIABLE  HIA_5gA  0.3
VARIABLE  HIA_5gB  0.8


#IFDEF GUIDELINE_ESD
// HIA_DIO LAYOUT GUIDELINES
//==========================
HIA_NAnode = PSTP NOT OUTSIDE HIADMY
HIA_PAnode = PACT INSIDE HIADMY
HIA_NCathode = NACT INSIDE HIADMY
HIA_PCathode = NSTP NOT OUTSIDE HIADMY
HIA_Anode = HIA_NAnode OR HIA_PAnode
HIA_Cathode = HIA_NCathode OR HIA_PCathode

HIA.1g { @ Width of N+ Active (N-HIA diode's cathode) and P+ Active (P-HIA diode's anode) inside HIA_DUMMY. (Figure XXX and Figure XXX) = 0.31-1.6 
  HIA_NCathode WITH WIDTH < HIA_1gA
  HIA_NCathode WITH WIDTH > HIA_1gB
  HIA_PAnode WITH WIDTH < HIA_1gA
  HIA_PAnode WITH WIDTH > HIA_1gB
}
HIA.2g { @ Length of N+ Active (N-HIA diode's cathode) and P+ Active (P-HIA diode's anode) inside HIA_DUMMY. (Figure XXX and Figure XXX) = 5-40 
  NOT ENCLOSE RECTANGLE HIA_NCathode 0.1 HIA_2gA ORTHOGONAL ONLY
  ENCLOSE RECTANGLE HIA_NCathode 0.1 HIA_2gB+GRID ORTHOGONAL ONLY
  NOT ENCLOSE RECTANGLE HIA_PAnode 0.1 HIA_2gA ORTHOGONAL ONLY
  ENCLOSE RECTANGLE HIA_PAnode 0.1 HIA_2gB+GRID ORTHOGONAL ONLY
}
NHIA_ESD = STAMP HIA_NCathode BY NSDc  //M0_OD1i 
PHIA_ESD = STAMP HIA_PAnode BY PSDc  //M0_OD1i 
#IFDEF DEFINE_PAD_BY_TEXT
NHIA_ESD_IO_PAD_pre = NET AREA RATIO NHIA_ESD OVER IO_PADi PAD_M9i_BY_TEXT PAD_M8i_BY_TEXT PAD_M7i_BY_TEXT PAD_M6i_BY_TEXT PAD_M5i_BY_TEXT PAD_M4i_BY_TEXT PAD_M3i_BY_TEXT PAD_M2i_BY_TEXT PAD_M1i_BY_TEXT PAD_APi_BY_TEXT > 0
NHIA_ESD_VDD_VSS_PAD_TEXT = NET AREA RATIO NHIA_ESD OVER PWR_M9i_BY_TEXT PWR_M8i_BY_TEXT PWR_M7i_BY_TEXT PWR_M6i_BY_TEXT PWR_M5i_BY_TEXT PWR_M4i_BY_TEXT PWR_M3i_BY_TEXT PWR_M2i_BY_TEXT PWR_M1i_BY_TEXT PWR_APi_BY_TEXT GND_M9i_BY_TEXT GND_M8i_BY_TEXT GND_M7i_BY_TEXT GND_M6i_BY_TEXT GND_M5i_BY_TEXT GND_M4i_BY_TEXT GND_M3i_BY_TEXT GND_M2i_BY_TEXT GND_M1i_BY_TEXT GND_APi_BY_TEXT > 0 
NHIA_ESD_IO_PAD = NHIA_ESD_IO_PAD_pre NOT NHIA_ESD_VDD_VSS_PAD_TEXT
PHIA_ESD_IO_PAD_pre = NET AREA RATIO PHIA_ESD OVER IO_PADi PAD_M9i_BY_TEXT PAD_M8i_BY_TEXT PAD_M7i_BY_TEXT PAD_M6i_BY_TEXT PAD_M5i_BY_TEXT PAD_M4i_BY_TEXT PAD_M3i_BY_TEXT PAD_M2i_BY_TEXT PAD_M1i_BY_TEXT PAD_APi_BY_TEXT > 0
PHIA_ESD_VDD_VSS_PAD_TEXT = NET AREA RATIO PHIA_ESD OVER PWR_M9i_BY_TEXT PWR_M8i_BY_TEXT PWR_M7i_BY_TEXT PWR_M6i_BY_TEXT PWR_M5i_BY_TEXT PWR_M4i_BY_TEXT PWR_M3i_BY_TEXT PWR_M2i_BY_TEXT PWR_M1i_BY_TEXT PWR_APi_BY_TEXT GND_M9i_BY_TEXT GND_M8i_BY_TEXT GND_M7i_BY_TEXT GND_M6i_BY_TEXT GND_M5i_BY_TEXT GND_M4i_BY_TEXT GND_M3i_BY_TEXT GND_M2i_BY_TEXT GND_M1i_BY_TEXT GND_APi_BY_TEXT > 0 
PHIA_ESD_IO_PAD = PHIA_ESD_IO_PAD_pre NOT PHIA_ESD_VDD_VSS_PAD_TEXT
HIA.3g { @ Total perimeter of each N+ or P+ ACTIVE inside HIA_dummy in same connection of I/O PAD. (Figure XXX and Figure XXX). The perimeter counts the drawn anode junction parameter region ex. The drawing OD perimeter dimension of active inside HIA_DUMMY= (A+B)*2*N >= 300 
  NET AREA RATIO NHIA_ESD_IO_PAD < HIA_3g
    [PERIM(NHIA_ESD_IO_PAD)] 
  RDB HIA_3G_N.rep NHIA_ESD_IO_PAD
  NET AREA RATIO PHIA_ESD_IO_PAD < HIA_3g
    [PERIM(PHIA_ESD_IO_PAD)] 
  RDB HIA_3G_P.rep PHIA_ESD_IO_PAD
}
#ENDIF
HIA.4g { @ The OD spacing of longer side of anode (P-diode) between anode and cathode, and vice versa for (N-diode). = 0.15~0.4 
  A = LENGTH HIA_NCathode >= HIA_2gA
  B = LENGTH HIA_PAnode >= HIA_2gA
  EXT [A] HIA_NAnode < HIA_4gA ABUT < 90
  EXT (A) HIA_NAnode <= HIA_4gB OPPOSITE 
  EXT [B] HIA_PCathode < HIA_4gA ABUT < 90 
  EXT (B) HIA_PCathode <= HIA_4gB OPPOSITE
}

HIA.5g { @ The OD spacing of shoter side of anode (P-diode) between anode and cathode, and vice versa for (N-diode). = 0.3~0.8 
  A = LENGTH HIA_NCathode <= HIA_1gB
  B = LENGTH HIA_PAnode <= HIA_1gB
  EXT [A] HIA_NAnode < HIA_5gA  ABUT < 90 
  EXT (A) HIA_NAnode <= HIA_5gB OPPOSITE
  EXT [B] HIA_PCathode < HIA_5gA ABUT < 90 
  EXT (B) HIA_PCathode <= HIA_5gB OPPOSITE

}

#ENDIF // GUIDELINE_ESD


///===========================
// HVN_65 Derive layer define 
//===========================
SRDPO_HVDN = SRDPO INTERACT HVN_65
PO_HVDN   = POLY INTERACT HVN_65
GATE_HVDN = GATE INTERACT HVN_65
GATE_W_HVDN = (PO_HVDN INSIDE EDGE HVN_65) COIN INSIDE EDGE GATE_HVDN
OD_HVDN   = OD INTERACT HVN_65
OD_HVDNP  = OD_HVDN AND NP
HVNMOS_DRAIN = NSDi INTERACT HVN_65
HVNMOS_SOURCE = (NSDi INTERACT OD_HVDN) NOT INTERACT HVN_65

//===========================
// HVP_65 Derive layer define 
//===========================
SRDPO_HVDP = SRDPO INTERACT HVP_65
PO_HVDP   = POLY INTERACT HVP_65
GATE_HVDP = GATE INTERACT HVP_65
GATE_W_HVDP = (PO_HVDP INSIDE EDGE HVP_65) COIN INSIDE EDGE GATE_HVDP
OD_HVDP   = OD INTERACT HVP_65
OD_HVDPP  = OD_HVDP AND PP
HVPMOS_DRAIN = PSDi INTERACT HVP_65
HVPMOS_SOURCE = (PSDi INTERACT OD_HVDP) NOT INTERACT HVP_65

// HVN_65 CHECKS
//=============

HVN_65.L.1 { @ Channel length of {GATE INTERACT HVN_65} (except HVD65_55) = 0.6~1.2 
   (LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDN) < HVN_65_L_1_A) NOT INSIDE EDGE HVD65_55         
   (LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDN) > HVN_65_L_1_B) NOT INSIDE EDGE HVD65_55         
}
HVN_65.W.1 { @ Width >= ^HVN_65_W_1
   INT HVN_65 < HVN_65_W_1 ABUT < 90 SINGULAR REGION
}
HVN_65.W.2 { @ Channel width of {GATE INTERACT HVN_65} = ^HVN_65_W_2_B
   LENGTH (GATE_W TOUCH INSIDE EDGE GATE_HVDN) < HVN_65_W_2_A 
   LENGTH (GATE_W TOUCH INSIDE EDGE GATE_HVDN) > HVN_65_W_2_B 
}
HVN_65.W.3 { @ Width of {SR_DPO INTERACT HVN_65} = ^HVN_65_W_3
   NOT WITH WIDTH SRDPO_HVDN == HVN_65_W_3 
}
HVN_65.S.1 { @ Space >= ^HVN_65_S_1  (except HVD65_55)
   (EXT HVN_65 < HVN_65_S_1 ABUT < 90 SINGULAR REGION) NOT INSIDE HVD65_55
}




HVN_65.S.3 { @ {GATE INTERACT HVN_65} space to {NW OR NT_N} >= ^HVN_65_S_3
   A = NWi OR NTNi
   EXT GATE_HVDN A < HVN_65_S_3 ABUT < 90 SINGULAR REGION
}
HVN_65.S.4 { @ Space to PW STRAP (overlap is not allowed) >= ^HVN_65_S_4
   EXT HVN_65 PSTP < HVN_65_S_4 ABUT < 90 SINGULAR REGION
   HVN_65 AND PSTP    
}
HVN_65.S.5 { @ Space to N+ ACTIVE >= ^HVN_65_S_5
   EXT HVN_65 NACT < HVN_65_S_5 ABUT < 90 SINGULAR REGION
}
HVN_65.S.7 { @ Space to DNW >= ^HVN_65_S_7
   EXT HVN_65 DNW < HVN_65_S_7 ABUT < 90 SINGULAR REGION
}
HVN_65.S.8 { @ {GATE edge INSIDE HVN_65} space to {1st SR_DPO INTERACT HVN_65} in drain direction = 0.16
   EXT [GATE_W_HVDN] SRDPO_HVDN < HVN_65_S_8 ABUT < 90 OPPOSITE
   EXT (GATE_W_HVDN) SRDPO_HVDN == HVN_65_S_8 ABUT < 90 OPPOSITE
}
HVN_65.S.9 { @ {GATE edge INSIDE HVN_65} space to {2nd SR_DPO INTERACT HVN_65} in drain direction = 0.38
   EXT (GATE_W_HVDN) SRDPO_HVDN == HVN_65_S_9 ABUT < 90 OPPOSITE
}
HVN_65.S.10__HVN_65.S.13 { @ {CO INSIDE {OD AND HVN_65}} space to {PO INTERACT HVN_65} = ^HVN_65_S_10
@ Maximum CO space in Drain of HVNMOS Definition of CO in Drain of HVNMOS: {CO INSIDE {OD AND HVN_65}} <= ^HVN_65_S_13
   A = COOD INSIDE HVN_65
   B = EXT GATE_W_HVDN [A] == HVN_65_S_10 ABUT < 90 OPPOSITE
   C = INT B <= CO_W_1 OPPOSITE REGION 
   A XOR C
   D = A NOT COIN INSIDE EDGE B
   E = EXT [D] <= HVN_65_S_13 ABUT < 90 OPPOSITE
   F = ENC [D] OD_HVDN <= HVN_65_S_13 ABUT < 90 OPPOSITE
   (D NOT COIN INSIDE EDGE E) NOT COIN INSIDE EDGE F
}
HVN_65.S.11 { @ {CO INSIDE {PO INTERACT HVN_65}} space to {{OD INTERACT HVN_65} AND NP} >= ^HVN_65_S_11
   A = COPO INSIDE PO_HVDN
   EXT A OD_HVDNP < HVN_65_S_11 ABUT < 90 SINGULAR REGION
}
HVN_65.S.12 { @ {PO OR OD} space to {OD AND HVN_65} in PO end-cap direction >= ^HVN_65_S_12   
   A = OD AND HVN_65
   B = A COIN EDGE OD_HVDN 
   EXT B POLY < HVN_65_S_12 ABUT < 90 REGION
   EXT B OD < HVN_65_S_12 ABUT < 90 REGION
}
HVN_65.S.14 { @ GATE space in drain direction for a multi-finger HVNMOS device. DRC check: {{Space of {GATE INTERACT HVN_65}} INSIDE HVN_65} on one OD = ^HVN_65_S_14
   S2 = HVNMOS_DRAIN INTERACT GATE_HVDN == 2
   S3 = GATE_HVDN COIN OUTSIDE EDGE S2
   EXT (S3) == HVN_65_S_14 ABUT < 90 OPPOSITE 
}
HVN_65.S.15 { @ GATE space in source direction for multi-finger HVNMOS devices on one OD	>= 1.2
   S2 = HVNMOS_SOURCE INTERACT GATE_HVDN == 2
   S3 = GATE_HVDN COIN OUTSIDE EDGE S2
   EXT [S3] < HVN_65_S_15 ABUT < 90 OPPOSITE
}
HVN_65.S.17 { @ Space to  {SR_DOD OR DOD} (overlap is not allowed) >= ^HVN_65_S_17
   A = SRDOD OR DOD 
   EXT HVN_65 A < HVN_65_S_17 ABUT < 90 SINGULAR REGION
   HVN_65 AND A    
}


VARIABLE HVN_65_S_18_90 90 // user value
VARIABLE HVN_65_S_18_0.08 0.08
HVN_65.S.18 { @ Space to RPO (overlap is not allow) >= 0.08 
   EXT HVN_65 RPO < HVN_65_S_18_0.08 ABUT < HVN_65_S_18_90 SINGULAR REGION
   HVN_65 AND RPO 
}




HVN_65.EN.1 { @ {GATE INTERACT HVN_65} enclosure by OD_18 >= ^HVN_65_EN_1
  ENC GATE_HVDN OD18 < HVN_65_EN_1 ABUT < 90 SINGULAR REGION
}
HVN_65.EX.1 { @ Extension on N+ ACTIVE (Drian side must be fully inside HVN_65) = ^HVN_65_EX_1
   ENC NACT HVN_65 < HVN_65_EX_1 ABUT < 90 SINGULAR REGION
   ((HVN_65 INTERACT NACT) NOT NACT) WITH WIDTH > HVN_65_EX_1      
   HVNMOS_DRAIN NOT HVN_65     
}
HVN_65.EX.2 { @ OD extension on {PO INTERACT HVN_65} >= ^HVN_65_EX_2
   ENC PO_HVDN OD_HVDN < HVN_65_EX_2 ABUT < 90 OPPOSITE REGION 
}
HVN_65.O.1 { @ Overlap of {I/O NMOS GATE} = ^HVN_65_O_1
   A = EXPAND EDGE GATE_W_HVDN INSIDE BY HVN_65_O_1
   B = HVN_65 AND GATE_HVDN
   A XOR B
}
HVN_65.A.1 { @ Area >= ^HVN_65_A_1
   AREA HVN_65 < HVN_65_A_1
}
HVN_65.A.2 { @ Enclosed area >= ^HVN_65_A_2
   A = HOLES HVN_65 INNER
   B = A NOT HVN_65
   AREA B < HVN_65_A_2
}
HVN_65.R.1 { @ HVN_65 edge landing on OD without landing on GATE is not allowed
   (HVN_65 INSIDE EDGE OD_HVDN) NOT INSIDE EDGE GATE_HVDN
}
HVN_65.R.2 { @ HVN_65 must be fully inside OD_18
   HVN_65 NOT OD18
}
HVN_65.R.3 { @ HV NMOS with 2 fingers GATE and common HV drain as a unit is must.
   A = ILP1i AND GATE_HVDN
   HVN_65 INTERACT A > 1 BY NET
   HVNMOS_DRAIN INTERACT GATE_HVDN == 1
   C = NSDc INTERACT HVNMOS_SOURCE
   D = GATE_HVDN OR HVNMOS_DRAIN
   D INTERACT C > 1 BY NET
}
HVN_65.R.4 { @ The finger number, Nf, should be even numbers. Nf means the finger number of the GATE on one OD
   DFM PROPERTY OD_HVDN GATE_HVDN OVERLAP MULTI 
   [-= FMOD(COUNT(GATE_HVDN),2)] == 1    
}
HVN_65.R.5 { @ {(HVN_65 INTERACT OD) AND PO} must be a rectangle. A concave {(HVN_65 INTERACT OD) AND PO} is not allowed
   A = (HVN_65 INTERACT OD) AND POLY
   NOT RECTANGLE A ORTHOGONAL ONLY    
}
HVN_65.R.6 { @ {{OD OR PO} INTERACT HVN_65} overlap of NW, DNW, VAR, NT_N, TCDDMY. {OD INTERACT NWDMY}, SRM, ROM, BJTDMY. RH_OD, RH_PO, VTL_N, VTL_P, VTUL_N, VTUL_P, VTH_N, VTH_P, UHVT_N, UHVT_P, EHVT_N, EHVT_P, OD_25, OD25_33, OD25_18, OD18_15, or OD18_12 is not allowed   
   A = OD_HVDN OR PO_HVDN
   A AND NWEL
   A AND DNW
   A AND VAR
   A AND NTN
   A AND TCDDMY
   A AND (OD INTERACT NWDMY)
   A AND SRM
   A AND ROM
   A AND BJTDMY
   A AND RHOD
   A AND RHPO
   A AND VTLN 
   A AND VTLP 
   A AND VTHN 
   A AND VTHP
   A AND VTULN 
   A AND VTULP
   A AND VTUHN 
   A AND VTUHP
   A AND EHVT_N
   A AND EHVT_P
   A AND OD25
   A AND OD2533
   A AND OD2518
   A AND OD1815
   A AND OD1812
}
HVN_65.R.8 { @ {{OD INTERACT {GATE INTERACT HVN_65}} INTERACT {GATE NOT INTERACT HVN_65}} is not allowed	
   (OD INTERACT GATE_HVDN) INTERACT (GATE NOT INTERACT HVN_65) 
}

// HVP_65 CHECKS
//=============
HVP_65.L.1 { @ Channel length of {GATE INTERACT HVP_65} (except HVD65_55) = 0.55~1.2 
   (LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDP) < HVP_65_L_1_A) NOT INSIDE EDGE HVD65_55   
   (LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDP) > HVP_65_L_1_B) NOT INSIDE EDGE HVD65_55   
}
HVP_65.W.1 { @ Width >= ^HVP_65_W_1
   INT HVP_65 < HVP_65_W_1 ABUT < 90 SINGULAR REGION
}
HVP_65.W.2 { @ Channel width of {GATE INTERACT HVP_65} = ^HVP_65_W_2_B
   LENGTH (GATE_W TOUCH INSIDE EDGE GATE_HVDP) < HVP_65_W_2_A 
   LENGTH (GATE_W TOUCH INSIDE EDGE GATE_HVDP) > HVP_65_W_2_B 
}
HVP_65.W.3 { @ Width of {SR_DPO INTERACT HVP_65} = 0.12
   NOT WITH WIDTH SRDPO_HVDP == HVP_65_W_3 
}
HVP_65.S.1 { @ Space >= ^HVP_65_S_1
   (EXT HVP_65 < HVP_65_S_1 ABUT < 90 SINGULAR REGION) NOT INSIDE HVD65_55
}

   
HVP_65.S.4 { @ Space to NW STRAP (overlap is not allowed) >= ^HVP_65_S_4
   EXT HVP_65 NSTP < HVP_65_S_4 ABUT < 90 SINGULAR REGION
   HVP_65 AND NSTP  
}    
HVP_65.S.5 { @ Space to P+ ACTIVE >= ^HVP_65_S_5
   EXT HVP_65 PACT < HVP_65_S_5 ABUT < 90 SINGULAR REGION
}    
HVP_65.S.8 { @ {GATE edge INSIDE HVP_65} space to {1st SR_DPO INTERACT HVP_65} in drain direction = ^HVP_65_S_8
   EXT [GATE_W_HVDP] SRDPO_HVDP < HVP_65_S_8 ABUT < 90 OPPOSITE
   EXT (GATE_W_HVDP) SRDPO_HVDP == HVP_65_S_8 ABUT < 90 OPPOSITE
}
HVP_65.S.9 { @ {GATE edge INSIDE HVP_65} space to {2nd SR_DPO INTERACT HVP_65} in drain direction = ^HVP_65_S_9
   EXT (GATE_W_HVDP) SRDPO_HVDP == HVP_65_S_9 ABUT < 90 OPPOSITE
}
HVP_65.S.10__HVP_65.S.13  { @ {CO INSIDE {OD AND HVP_65}} space to {PO INTERACT HVP_65} = ^HVP_65_S_10
@ Maximum CO space in Drain of HVPMOS Definition of CO in Drain of HVPMOS: {CO INSIDE {OD AND HVP_65}} <= ^HVP_65_S_13
   A = COOD INSIDE HVP_65
   B = EXT GATE_W_HVDP [A] == HVP_65_S_10 ABUT < 90 OPPOSITE
   C = INT B <= CO_W_1 OPPOSITE REGION 
   A XOR C
   D = A NOT COIN INSIDE EDGE B
   E = EXT [D] <= HVP_65_S_13 ABUT < 90 OPPOSITE
   F = ENC [D] OD_HVDP <= HVP_65_S_13 ABUT < 90 OPPOSITE
   (D NOT COIN INSIDE EDGE E) NOT COIN INSIDE EDGE F
}
HVP_65.S.11 { @ {CO INSIDE {PO INTERACT HVP_65}} space to {{OD INTERACT HVP_65} AND PP} >= ^HVP_65_S_11
   A = COPO INSIDE PO_HVDP
   EXT A OD_HVDPP < HVP_65_S_11 ABUT < 90 SINGULAR REGION
}
HVP_65.S.12 { @ {PO OR OD} space to {OD AND HVP_65} in PO end-cap direction >= ^HVP_65_S_12
   A = OD AND HVP_65
   B = A COIN EDGE OD_HVDP
   EXT B POLY < HVP_65_S_12 ABUT < 90 REGION
   EXT B OD < HVP_65_S_12 ABUT < 90 REGION
}    
HVP_65.S.14 { @ GATE space in drain direction for a multi-finger HVPMOS device. DRC check: {{Space of {GATE INTERACT HVP_65}} INSIDE HVP_65} in one OD = ^HVP_65_S_14
   S2 = HVPMOS_DRAIN INTERACT GATE_HVDP == 2
   S3 = GATE_HVDP COIN OUTSIDE EDGE S2
   EXT (S3) == HVP_65_S_14 ABUT < 90 OPPOSITE
}
HVP_65.S.15 { @ GATE space in source direction for multi-finger HVPMOS devices on one OD	>= 1.2
   S2 = HVPMOS_SOURCE INTERACT GATE_HVDP == 2
   S3 = GATE_HVDP COIN OUTSIDE EDGE S2
   EXT [S3] < HVP_65_S_15 ABUT < 90 OPPOSITE
}
HVP_65.S.16 { @ Space to  {SR_DOD OR DOD} (overlap is not allowed) >= ^HVP_65_S_16
   A = SRDOD OR DOD 
   EXT HVP_65 A < HVP_65_S_16 ABUT < 90 SINGULAR REGION
   HVP_65 AND A    
}



VARIABLE HVP_65_S_18_90 90 // user value
VARIABLE HVP_65_S_18_0.08 0.08
HVP_65.S.18 { @ Space to RPO (overlap is not allow) >= 0.08 
EXT HVP_65 RPO < HVP_65_S_18_0.08 ABUT < HVP_65_S_18_90 SINGULAR REGION
HVP_65 AND RPO 
}




HVP_65.EN.1 { @ {GATE INTERACT HVP_65} enclosure by {NW AND OD_18} >= ^HVP_65_EN_1
   A = NWEL AND OD18
   ENC GATE_HVDP A < HVP_65_EN_1 ABUT < 90 SINGULAR REGION
}
HVP_65.EN.2 { @ Enclosure by DNW >= ^HVP_65_EN_2
   ENC HVP_65 DNW < HVP_65_EN_2 ABUT < 90 SINGULAR REGION
}
HVP_65.EX.1 { @ Extension on P+ ACTIVE (Drian side must be fully inside HVP_65) = ^HVP_65_EX_1
   ENC PACT HVP_65 < HVP_65_EX_1 ABUT < 90 SINGULAR REGION
   ((HVP_65 INTERACT PACT) NOT PACT) WITH WIDTH > HVP_65_EX_1      
   HVPMOS_DRAIN NOT HVP_65     
}
HVP_65.EX.2 { @ OD extension on {PO INTERACT HVP_65} >= ^HVP_65_EX_2
   ENC PO_HVDP OD_HVDP < HVP_65_EX_2 ABUT < 90 OPPOSITE REGION 
}
HVP_65.O.1 { @ Overlap of {I/O PMOS GATE} = ^HVP_65_O_1
   A = EXPAND EDGE GATE_W_HVDP INSIDE BY HVP_65_O_1
   B = HVP_65 AND GATE_HVDP
   A XOR B
}
HVP_65.A.1 { @ Area >= ^HVP_65_A_1
   AREA HVP_65 < HVP_65_A_1
}
HVP_65.A.2 { @ Enclosed area >= ^HVP_65_A_2
   A = HOLES HVP_65 INNER
   B = A NOT HVP_65
   AREA B < HVP_65_A_2
}
HVP_65.R.1 { @ HVP_65 edge landing on OD without landing on GATE is not allowed 
   (HVP_65 INSIDE EDGE OD_HVDP) NOT INSIDE EDGE GATE_HVDP
}
HVP_65.R.2 { @ HVP_65 must be fully inside OD_18 
   HVP_65 NOT OD18
}
HVP_65.R.3 { @ HV PMOS with 2 fingers GATE and common HV drain as a unit is limited.
   A = ILP1i AND GATE_HVDP
   HVP_65 INTERACT A > 1 BY NET
   HVPMOS_DRAIN INTERACT GATE_HVDP == 1
   C = PSDc INTERACT HVPMOS_SOURCE
   D = GATE_HVDP OR HVPMOS_DRAIN 
   D INTERACT C > 1 BY NET
}
HVP_65.R.4 { @ The finger number, Nf, should be even numbers. Nf means the finger number of the GATE on one OD 
   DFM PROPERTY OD_HVDP GATE_HVDP OVERLAP MULTI 
   [-= FMOD(COUNT(GATE_HVDP),2)] == 1   
}
HVP_65.R.5 { @ {(HVP_65 INTERACT OD) AND PO} must be a rectangle. A concave {(HVP_65 INTERACT OD) AND PO} is not allowed 
   A = (HVP_65 INTERACT OD) AND POLY
   NOT RECTANGLE A ORTHOGONAL ONLY   
}
HVP_65.R.6 { @ {{OD OR PO} INTERACT HVP_65} overlap of VAR, NT_N, TCDDMY. {OD INTERACT NWDMY}, SRM, ROM, BJTDMY. RH_OD, RH_PO, VTL_N, VTL_P, VTUL_N, VTUL_P, VTH_N, VTH_P, UHVT_N, UHVT_P, EHVT_N, EHVT_P, OD_25, OD25_33, OD25_18, OD18_15, or OD18_12 is not allowed   
   A = OD_HVDP OR PO_HVDP
   A AND VAR
   A AND NTN
   A AND TCDDMY
   A AND (OD INTERACT NWDMY)
   A AND SRM
   A AND ROM
   A AND BJTDMY
   A AND RHOD
   A AND RHPO
	 A AND VTLN 
	 A AND VTLP
	 A AND VTHN 
	 A AND VTHP
	 A AND VTULN 
	 A AND VTULP
	 A AND VTUHN 
	 A AND VTUHP
	 A AND EHVT_N
	 A AND EHVT_P
   A AND OD25
   A AND OD2533
   A AND OD2518
   A AND OD1815
   A AND OD1812
}
HVP_65.R.7 { @ HVP_65 must be inside {NW AND DNW} 
   HVP_65 NOT NWEL
   HVP_65 NOT DNW
}
HVP_65.R.8 { @ {{OD INTERACT {GATE INTERACT HVP_65}} INTERACT {GATE NOT INTERACT HVP_65}} is not allowed	
   (OD INTERACT GATE_HVDP) INTERACT (GATE NOT INTERACT HVP_65) 
}


//============================================
// HVD65_GR CHECKS :HVMOS Guard-Ring Rules
//============================================

//HVD65_GR.R.1 is checked by HVD65_GR.R.2, HVD65_GR.R.3 
HVD65_GR.R.2 { @ Every HV NMOS must be surrounded by the P+ OD guard-ring as PW strap 
   OD_HVDN NOT INSIDE PTAP_guard_ring_hole 
   OD_HVDN25_65 NOT INSIDE PTAP_guard_ring_hole 
}
HVD65_GR.R.3 { @ Every HV PMOS must be surrounded by the N+ OD guard-ring as NW strap 
   OD_HVDP NOT INSIDE NTAP_guard_ring_hole
   OD_HVDP25_65 NOT INSIDE NTAP_guard_ring_hole
}
HVD65_GR.R.6 { @ {{HV N/PMOS OR HVMOS Guard-ring} INTERACT RPO} is not allowed 
   (NSTPi TOUCH (NTAP_guard_ring_hole ENCLOSE OD_HVDP)) INTERACT RPO
   (PSTPi TOUCH (PTAP_guard_ring_hole ENCLOSE OD_HVDN)) INTERACT RPO
   OD_HVDP INTERACT RPO
   OD_HVDN INTERACT RPO
   (NSTPi TOUCH (NTAP_guard_ring_hole ENCLOSE OD_HVDP25_65)) INTERACT RPO
   (PSTPi TOUCH (PTAP_guard_ring_hole ENCLOSE OD_HVDN25_65)) INTERACT RPO
   OD_HVDP25_65 INTERACT RPO
   OD_HVDN25_65 INTERACT RPO
}


// HVN25_65 Derive layer define 
//===========================
SRDPO_HVDN25_65 = SRDPO INTERACT HVN25_65
PO_HVDN25_65   = POLY INTERACT HVN25_65
GATE_HVDN25_65 = GATE INTERACT HVN25_65
GATE_W_HVDN25_65 = (PO_HVDN25_65 INSIDE EDGE HVN25_65) COIN INSIDE EDGE GATE_HVDN25_65
OD_HVDN25_65   = OD INTERACT HVN25_65
OD_HVDNP25_65  = OD_HVDN25_65 AND NP
HVNMOS25_65_DRAIN = NSDi INTERACT HVN25_65
HVNMOS25_65_SOURCE = (NSDi INTERACT OD_HVDN25_65) NOT INTERACT HVN25_65

//===========================
// HVP25_65 Derive layer define 
//===========================
SRDPO_HVDP25_65 = SRDPO INTERACT HVP25_65
PO_HVDP25_65   = POLY INTERACT HVP25_65
GATE_HVDP25_65 = GATE INTERACT HVP25_65
GATE_W_HVDP25_65 = (PO_HVDP25_65 INSIDE EDGE HVP25_65) COIN INSIDE EDGE GATE_HVDP25_65
OD_HVDP25_65   = OD INTERACT HVP25_65
OD_HVDPP25_65 = OD_HVDP25_65 AND PP
HVPMOS25_65_DRAIN = PSDi INTERACT HVP25_65
HVPMOS25_65_SOURCE = (PSDi INTERACT OD_HVDP25_65) NOT INTERACT HVP25_65

//============================================
// HVN25_65 Rules CHECKS 
//============================================
#IFDEF N22_ULL
HVN25_65.L.1 { @ Channel length of {GATE INTERACT HVN25_65} (except HVD65_55) = 0.65 ~ 1.2 
   (LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDN25_65) < HVN25_65_L_1_A) NOT INSIDE EDGE HVD65_55         
   (LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDN25_65) > HVN25_65_L_1_B) NOT INSIDE EDGE HVD65_55         
}
HVN25_65.W.1 { @ Width >= 1.06 
   INT HVN25_65 < HVN25_65_W_1 ABUT < 90 SINGULAR REGION
}
HVN25_65.W.2 { @ Channel width of {GATE INTERACT HVN25_65} = 1 ~ 4 
   LENGTH (GATE_W TOUCH INSIDE EDGE GATE_HVDN25_65) < HVN25_65_W_2_A 
   LENGTH (GATE_W TOUCH INSIDE EDGE GATE_HVDN25_65) > HVN25_65_W_2_B 
}
HVN25_65.W.3 { @ Width of {SR_DPO INTERACT HVN25_65} = 0.12 
   NOT WITH WIDTH SRDPO_HVDN25_65 == HVN25_65_W_3 
}
HVN25_65.S.1 { @ Space (except HVD65_55) >= 1.18 
   (EXT HVN25_65 < HVN25_65_S_1 ABUT < 90 SINGULAR REGION) NOT INSIDE HVD65_55
}


HVN25_65.S.3 { @ {GATE INTERACT HVN25_65} space to {NW OR NT_N} >= ^HVN25_65_S_3
   A = NWi OR NTNi
   EXT GATE_HVDN25_65 A < HVN25_65_S_3 ABUT < 90 SINGULAR REGION
}

HVN25_65.S.4 { @ Space to PW STRAP (overlap is not allowed) >= ^HVN25_65_S_4
   EXT HVN25_65 PSTP < HVN25_65_S_4 ABUT < 90 SINGULAR REGION
   HVN25_65 AND PSTP    
}
HVN25_65.S.5 { @ Space to N+ ACTIVE >= ^HVN25_65_S_5
   EXT HVN25_65 NACT < HVN25_65_S_5 ABUT < 90 SINGULAR REGION
}
HVN25_65.S.7 { @ Space to DNW >= ^HVN25_65_S_7
   EXT HVN25_65 DNW < HVN25_65_S_7 ABUT < 90 SINGULAR REGION
}
HVN25_65.S.8 { @ {GATE edge INSIDE HVN25_65} space to {SR_DPO INTERACT HVN25_65} in drain direction = 0.16
   EXT (GATE_W_HVDN25_65) SRDPO_HVDN25_65 == HVN25_65_S_8 ABUT < 90 OPPOSITE
}
HVN25_65.S.10__HVN25_65.S.13 { @ {CO INSIDE {OD AND HVN25_65}} space to {PO INTERACT HVN25_65} = ^HVN25_65_S_10
                               @ Maximum CO space in Drain of HVNMOS Definition of CO in Drain of HVNMOS: {CO INSIDE {OD AND HVN25_65}} <= ^HVN25_65_S_13
   A = COOD INSIDE HVN25_65
   B = EXT GATE_W_HVDN25_65 [A] == HVN25_65_S_10 ABUT < 90 OPPOSITE
   C = INT B <= CO_W_1 OPPOSITE REGION 
   A XOR C
   D = A NOT COIN INSIDE EDGE B
   E = EXT [D] <= HVN25_65_S_13 ABUT < 90 OPPOSITE
   F = ENC [D] OD_HVDN25_65 <= HVN25_65_S_13 ABUT < 90 OPPOSITE
   (D NOT COIN INSIDE EDGE E) NOT COIN INSIDE EDGE F
}
HVN25_65.S.11 { @ {CO INSIDE {PO INTERACT HVN25_65}} space to {{OD INTERACT HVN25_65} AND NP} >= 0.34 
   A = COPO INSIDE PO_HVDN25_65
   EXT A OD_HVDNP25_65 < HVN25_65_S_11 ABUT < 90 SINGULAR REGION
}
HVN25_65.S.12 { @ {PO OR OD} space to {OD AND HVN25_65} in PO end-cap direction >= ^HVN25_65_S_12   
   A = OD AND HVN25_65
   B = A COIN EDGE OD_HVDN25_65 
   EXT B POLY < HVN25_65_S_12 ABUT < 90 REGION
   EXT B OD < HVN25_65_S_12 ABUT < 90 REGION
}
HVN25_65.S.14 { @ GATE space in drain direction for a multi-finger HVNMOS device. DRC check: {{Space of {GATE INTERACT HVN25_65}} INSIDE HVN25_65} on one OD = ^HVN25_65_S_14
   S2 = HVNMOS25_65_DRAIN INTERACT GATE_HVDN25_65 == 2
   S3 = GATE_HVDN25_65 COIN OUTSIDE EDGE S2
   EXT (S3) == HVN25_65_S_14 ABUT < 90 OPPOSITE 
}
HVN25_65.S.15 { @ GATE space in source direction for multi-finger HVNMOS devices on one OD	>= 0.18
   S2 = HVNMOS25_65_SOURCE INTERACT GATE_HVDN25_65 == 2
   S3 = GATE_HVDN25_65 COIN OUTSIDE EDGE S2
   EXT [S3] < HVN25_65_S_15 ABUT < 90 OPPOSITE
}
HVN25_65.S.17 { @ Space to  {SR_DOD OR DOD} (overlap is not allowed) >= ^HVN25_65_S_17
   A = SRDOD OR DOD 
   EXT HVN25_65 A < HVN25_65_S_17 ABUT < 90 SINGULAR REGION
   HVN25_65 AND A    
}



