//=============
RR:RE:EFP.M4.S.2 { @ Cap recommendation: Recommended the line-end space at Mx [line width (W2) = 0.05 um, length (L3) >= 0.15 um] in a line-end configuration: If both longer edges of Mx line-end have parallel run length [0.005 um ~ 0.115 um (L2)] to Mx [space to Mx line-end 0.05 um (S1), and both Mxs are part of one polygon] >= 0.115 
  M4_NOTCH_LL = (((EXPAND EDGE M4_L_END_edge INSIDE BY TypeLEH_LL-GRID) AND M4i) WITH EDGE M4_L_END_edge) INTERACT M4_jog_CORNER_waive

  M4_NOTCH_pre = EXT M4i < TypeLEH_NOTCH ABUT < 90 NOTCH OPPOSITE REGION
  M4_NOTCH = (ENCLOSE RECTANGLE M4_NOTCH_pre TypeLEH_NOTCH-3*GRID GRID) INTERACT M4i > 1
  M4_NOTCH_candidate1 = ENCLOSE RECTANGLE (M4i INTERACT M4_NOTCH) TypeLEH_LL Mx_W
  M4_NOTCH_candidate2 = EXT M4_NOTCH_candidate1 <= TypeLEH_S2 ABUT < 90 OPPOSITE REGION
  M4_NOTCH_candidate3 = (M4_L_END_edge TOUCH EDGE M4_NOTCH_candidate2) INSIDE EDGE M4_NOTCH
  M4_NOTCH_candidate4 = EXPAND EDGE M4_NOTCH_candidate3 INSIDE BY GRID
  M4_NOTCH_candidate5 = (VERTEX (SIZE M4_NOTCH_candidate4 BY TypeLEH_marker-GRID INSIDE OF M4_NOTCH_candidate1 STEP Mx_S *0.7) == 4) INTERACT M4_NOTCH
  M4_NOTCH_candidate6 = EXT [M4_NOTCH_candidate5] M4i <= Mx_S+GRID ABUT < 90 OPPOSITE
  M4_NOTCH_candidate7 = INT (M4_NOTCH_candidate5 NOT COIN EDGE M4_NOTCH_candidate6) <= Mx_W ABUT < 90 OPPOSITE REGION
  M4_NOTCH_candidate = (M4_NOTCH_candidate5 INTERACT M4_NOTCH_candidate7) NOT INTERACT M4_NOTCH_LL
  M4_NOTCH_candidate INTERACT EFPM4S2_M4i
}
#ENDIF
#ENDIF
// EFP.Mx.S.2.R is checked by RR:RE:EFP.M4.S.2

#IFDEF CHECK_EFPM4S3_
#IFDEF _EFPM4S3_
EFPM4S3_M4iCellIn = INSIDE CELL M4i CellsForRRuleRecommended  
EFPM4S3_M4iCellOut = NOT INSIDE CELL M4i ExclCellsForRRuleRecommended 
EFPM4S3_M4iCell = EFPM4S3_M4iCellIn AND EFPM4S3_M4iCellOut
EFPM4S3_M4iMarker = M4i AND RRuleRecommended
EFPM4S3_M4i = ((EFPM4S3_M4iCell OR EFPM4S3_M4iMarker) NOT Block ) NOT excludeRRuleRecommended

// M4 Type Hook 
//=============
TypeHook_M4_H2		  = CONVEX EDGE EFPM4S3_M4i ANGLE1==270 ANGLE2==270 WITH LENGTH <= TypeH_LB
TypeHook_M4_H2_corner	  = EXT TypeHook_M4_H2 [M4] < TypeH_LB ABUT==90 
TypeHook_M4_H2_W	  = INT EFPM4S3_M4i (EFPM4S3_M4i TOUCH EDGE TypeHook_M4_H2_corner) <= TypeH_W ABUT<90 REGION
TypeHook_M4_H2_W_out	  = TypeHook_M4_H2_W NOT TOUCH EDGE TypeHook_M4_H2_corner
TypeHook_M4_H2_L_chk	  = TypeHook_M4_H2_corner TOUCH EDGE TypeHook_M4_H2_W 
TypeHook_M4_H2_OC_pre1	  = (CONVEX EDGE EFPM4S3_M4i ANGLE1==270 ANGLE2==90 ) TOUCH EDGE TypeHook_M4_H2_L_chk
TypeHook_M4_H2_OC_pre2	  = EXT [TypeHook_M4_H2_OC_pre1] TypeHook_M4_H2 <= TypeH_LB ABUT==90 
TypeHook_M4_H2_OC	  = TypeHook_M4_H2_OC_pre2 NOT COIN EDGE (INT EFPM4S3_M4i TypeHook_M4_H2_OC_pre2 < DB_GRID ABUT ==90 REGION)
TypeHook_M4_H2_OC_chk	  = EXT [TypeHook_M4_H2_L_chk] TypeHook_M4_H2_OC < TypeH_S2 ABUT<90 OPPOSITE
TypeHook_M4_H2_IC_OClng  = TypeHook_M4_H2 NOT TOUCH EDGE (TypeHook_M4_H2 NOT COIN EDGE TypeHook_M4_H2_OC_chk)
TypeHook_M4_H2_corner_L  = EXT TypeHook_M4_H2_L_chk [TypeHook_M4_H2] < DB_GRID ABUT==90
TypeHook_M4_H2_corner_IC = EXT [TypeHook_M4_H2] <DB_GRID ABUT==90 
TypeHook_M4_H2_corner_IC_OClng = EXT [TypeHook_M4_H2] TypeHook_M4_H2_IC_OClng <DB_GRID ABUT==90 
TypeHook_M4_H2_short	  = LENGTH TypeHook_M4_H2 < TypeH_S2
TypeHook_M4_H2_corner_err = DFM PROPERTY TypeHook_M4_H2 TypeHook_M4_H2_corner_L TypeHook_M4_H2_corner_IC TypeHook_M4_H2_corner_IC_OClng TypeHook_M4_H2_short OVERLAP ABUT ALSO MULTI
				    [ -= COUNT(TypeHook_M4_H2_short)] >0
				    [ -= COUNT(TypeHook_M4_H2_corner_IC)] >0
				    [ -= COUNT(TypeHook_M4_H2_corner_IC_OClng)] >0
				    [ -= COUNT(TypeHook_M4_H2_corner_L)] >1
TypeHook_M4_H2_err	  = EXPAND EDGE (TypeHook_M4_H2 TOUCH EDGE TypeHook_M4_H2_corner_err) BY 0.001
TypeHook_M4		  = COPY TypeHook_M4_H2_err
RR:RE:EFP.M4.S.3 { @ Hook recommendation: Recommended space from the edge [length <= 0.065 um (L4) between the edges of line width <= 0.055 um (W3 and W3') and either one of the edges >= 0.15 um (L5)] of Mx pattern [with 3 consecutive 270-270-270 degree inner angles] to opposite edge of the same Mx >= 0.155 
   COPY TypeHook_M4 
}
#ENDIF
#ENDIF
// EFP.Mx.S.3.R is checked by RR:RE:EFP.M4.S.3

#IFDEF CHECK_EFPM4S5_
#IFDEF _EFPM4S5_
EFPM4S5_M4iCellIn = INSIDE CELL M4i CellsForRRuleRecommended  
EFPM4S5_M4iCellOut = NOT INSIDE CELL M4i ExclCellsForRRuleRecommended 
EFPM4S5_M4iCell = EFPM4S5_M4iCellIn AND EFPM4S5_M4iCellOut
EFPM4S5_M4iMarker = M4i AND RRuleRecommended
EFPM4S5_M4i = ((EFPM4S5_M4iCell OR EFPM4S5_M4iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M4.S.5 { @ Metal bridge recommendation type-1: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3] when there is no other Mx cut Region B1/B2 Definitions: 1. Region B3 = 0.25 um * S2, generated from vertex CA/CB. 2. S2 = 2 Mx (polygon3/4) with parallel run length 0 um > S2 >= 0.235 um 3. Region B1/B2 = 0.16 um * 0.23 um, generated from Mx (polygon3/4) metal line-end with vertex CA/CB respectively >= 0.055 
  M4_TypeBRS1_prefilter_1 = EXT [M4i] == TypeBRS1_S2 ABUT < 90 OPPOSITE EXTENDED TypeBRS1_S3+NANO
  M4_TypeBRS1_CORNER_pre_1_1 = M4_CORNER_S1 WITH EDGE M4_TypeBRS1_prefilter_1
  M4_TypeBRS1_CORNER_pre_1_2 = EXT [M4_L_END_edge] M4i < TypeBRS1_S5 OPPOSITE
  M4_TypeBRS1_CORNER_pre_1 = M4_TypeBRS1_CORNER_pre_1_1 NOT WITH EDGE M4_TypeBRS1_CORNER_pre_1_2
  M4_TypeBRS1_CORNER_pre_2 = EXT M4_TypeBRS1_CORNER_pre_1 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION
  M4_TypeBRS1_CORNER_pre_3 = M4_TypeBRS1_CORNER_pre_2 INTERACT (M4_TypeBRS1_CORNER_pre_2 AND M4i) > 1
  M4_TypeBRS1_CORNER_pre_4 = M4_TypeBRS1_CORNER_pre_1 INTERACT M4_TypeBRS1_CORNER_pre_3
  
  M4_TypeBRS1_CACB_S23 = EXT M4_TypeBRS1_CORNER_pre_4 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M4_TypeBRS1_CACB_S23_1_1 = M4_TypeBRS1_CACB_S23 INTERACT M4_CORNER_S1 >= 2
  
  M4_TypeBRS1_CACB_S23_1_2 = INT (M4i AND M4_TypeBRS1_CACB_S23_1_1) == Mx_W OPPOSITE REGION
  M4_TypeBRS1_CACB_S23_1_3 = EXPAND EDGE (M4i COIN INSIDE EDGE M4_TypeBRS1_CACB_S23_1_2) OUTSIDE BY Mx_S
  M4_TypeBRS1_CACB_S23_1_4 = M4_TypeBRS1_CACB_S23_1_2 OR M4_TypeBRS1_CACB_S23_1_3
  M4_TypeBRS1_CACB_S23_1_5 = (EXT (M4_TypeBRS1_CORNER_pre_4 INTERACT M4_TypeBRS1_CACB_S23_1_1) >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION) AND M4_TypeBRS1_CACB_S23_1_4
  M4_TypeBRS1_CACB_S23_1_6 = (M4_TypeBRS1_CORNER_pre_4 INTERACT M4_TypeBRS1_CACB_S23_1_1) INTERACT (SIZE M4_TypeBRS1_CACB_S23_1_5 BY GRID)
  M4_TypeBRS1_CACB_S23_1_7 = EXT M4_TypeBRS1_CACB_S23_1_6 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M4_TypeBRS1_CACB_S23_1 = M4_TypeBRS1_CACB_S23_1_7 INTERACT M4_TypeBRS1_CACB_S23_1_6 >= 2
  
  M4_TypeBRS1_CACB_S23_2 = ((EXPAND EDGE (LENGTH ((SIZE M4_TypeBRS1_CACB_S23_1 BY -NANO) AND M4i) == Mx_W) OUTSIDE BY 2*NANO) OR (M4_TypeBRS1_CACB_S23_1 AND M4i)) AND M4_TypeBRS1_CACB_S23_1
  M4_TypeBRS1_CACB_S23_3 = (M4_TypeBRS1_CACB_S23_2 AND M4_TypeBRS1_CACB_S23_1) COIN EDGE M4_TypeBRS1_CACB_S23_1
  M4_TypeBRS1_CACB_S23_4 = M4_TypeBRS1_CACB_S23_1 INTERACT (M4_TypeBRS1_CACB_S23_1 AND M4i) == 2
  M4_TypeBRS1_CACB_S23_5 = M4_TypeBRS1_CACB_S23_4 WITH EDGE M4_TypeBRS1_CACB_S23_3 == 4
  M4_TypeBRS1_CACB_EDGE1 = M4i TOUCH OUTSIDE EDGE M4_TypeBRS1_CACB_S23_5	//CA and CB EDGE
  M4_TypeBRS1_CACB_EDGE2 = EXPAND EDGE M4_TypeBRS1_CACB_EDGE1 OUTSIDE BY GRID			
  M4_TypeBRS1_CACB_EDGE3_1 = EXT M4_TypeBRS1_CACB_EDGE1 M4i == Mx_S OPPOSITE REGION
  M4_TypeBRS1_CACB_EDGE3_2 = EXT M4_TypeBRS1_CACB_EDGE1 M4_TypeBRS1_CACB_S23_2 == Mx_S OPPOSITE REGION
  M4_TypeBRS1_CACB_EDGE4 = M4_TypeBRS1_CACB_EDGE2 NOT M4_TypeBRS1_CACB_EDGE3_1
  M4_TypeBRS1_CACB_EDGE5 = LENGTH M4_TypeBRS1_CACB_EDGE4 == GRID
  M4_TypeBRS1_CACB_EDGE6 = EXPAND EDGE M4_TypeBRS1_CACB_EDGE5 OUTSIDE BY GRID
  M4_TypeBRS1_CACB_EDGE7 = (M4_TypeBRS1_CACB_EDGE6 TOUCH M4_TypeBRS1_CACB_EDGE3_1) OR (M4_TypeBRS1_CACB_EDGE6 TOUCH M4_TypeBRS1_CACB_EDGE3_2)
  
   
  M4_TypeBRS1_CACB_EDGE8_1 = M4_TypeBRS1_CACB_EDGE7 COIN OUTSIDE EDGE M4_TypeBRS1_CACB_EDGE4
  M4_TypeBRS1_CACB_EDGE8 = M4_TypeBRS1_CACB_EDGE8_1 NOT TOUCH EDGE (EXT [M4_TypeBRS1_CACB_EDGE8_1] M4i < TypeBRS1_S4 OPPOSITE)
  
  M4_TypeBRS1_CACB_EDGE9 = EXPAND EDGE M4_TypeBRS1_CACB_EDGE8 OUTSIDE BY TypeBRS1_S4
  M4_TypeBRS1_CACB_EDGE10 = M4_CORNER TOUCH M4_TypeBRS1_CACB_EDGE4
  
  M4_TypeBRS1_CACB_EDGE11_1 = M4_TypeBRS1_CACB_EDGE9 TOUCH OUTSIDE EDGE M4_TypeBRS1_CACB_EDGE10
  M4_TypeBRS1_CACB_EDGE11 = M4_TypeBRS1_CACB_EDGE11_1 NOT TOUCH EDGE (ENC M4i [M4_TypeBRS1_CACB_EDGE11_1] < TypeBRS1_S5 OPPOSITE)
  
  M4_TypeBRS1_CACB_EDGE12 = ENCLOSE RECTANGLE (EXPAND EDGE M4_TypeBRS1_CACB_EDGE11 INSIDE BY TypeBRS1_S5) TypeBRS1_S4 TypeBRS1_S5
  M4_TypeBRS1_CACB_ERROR1 = M4_TypeBRS1_CACB_EDGE12 AND M4i
  M4_TypeBRS1_CACB_ERROR2 = (ENC M4_TypeBRS1_CACB_ERROR1 [M4_TypeBRS1_CACB_EDGE11] <= TypeBRS1_S5 OPPOSITE) OR EDGE (M4_TypeBRS1_CACB_EDGE11 TOUCH EDGE M4_TypeBRS1_CACB_ERROR1)
  M4_TypeBRS1_CACB_ERROR3 = (M4_TypeBRS1_CACB_EDGE11 NOT TOUCH EDGE M4_TypeBRS1_CACB_ERROR2) TOUCH EDGE M4_TypeBRS1_CACB_EDGE12
  M4_TypeBRS1_CACB_ERROR4 = EXPAND EDGE M4_TypeBRS1_CACB_ERROR3 INSIDE BY TypeBRS1_S5
  M4_TypeBRS1_CACB_ERROR5 = ENCLOSE RECTANGLE (M4_TypeBRS1_CACB_ERROR4 NOT ENCLOSE M4_TypeBRS1_CACB_ERROR1) TypeBRS1_S4 TypeBRS1_S5
  M4_TypeBRS1_MARK1 = EXT M4_TypeBRS1_CACB_ERROR5 > 2*Mx_W+2*Mx_S+4*GRID <= TypeBRS1_S2 OPPOSITE REGION
  M4_TypeBRS1_MARK2 = VERTEX (M4_TypeBRS1_MARK1 AND M4i) != 4
  M4_TypeBRS1_MARK3 = M4_TypeBRS1_MARK1 WITH EDGE (M4_TypeBRS1_MARK1 COIN EDGE (M4_TypeBRS1_MARK1 AND M4i)) == 4
  M4_TypeBRS1_MARK4 = M4_TypeBRS1_MARK3 NOT INTERACT M4_TypeBRS1_MARK2
  M4_TypeBRS1_MARK = (EXT (M4_TypeBRS1_MARK4 AND M4i) <= Mx_S OPPOSITE REGION) INSIDE M4_TypeBRS1_CACB_S23_5
  M4_TypeBRS1_MARK INTERACT EFPM4S5_M4i
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPM4S6_
#IFDEF _EFPM4S6_
EFPM4S6_M4iCellIn = INSIDE CELL M4i CellsForRRuleRecommended  
EFPM4S6_M4iCellOut = NOT INSIDE CELL M4i ExclCellsForRRuleRecommended 
EFPM4S6_M4iCell = EFPM4S6_M4iCellIn AND EFPM4S6_M4iCellOut
EFPM4S6_M4iMarker = M4i AND RRuleRecommended
EFPM4S6_M4i = ((EFPM4S6_M4iCell OR EFPM4S6_M4iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M4.S.6 { @ Metal bridge recommendation type-2: Recommended space of 2 Mx lines (polygon1/2) [polygon2 with width = 0.05 um (W) and length (L3) >= 0.3 um, one side of Region B3 fully abutted polygon1] when there is no Mx cut both Region B2 and Region B4, but has other Mx interact both Region B1 and Region B5 Definitions: 1. Region B1 = 0.05 um * 0.08 um, generated from vertex CA. 2. Region B2 = 0.23 um * 0.075 um, generated from Mx (polygon2) side wall with vertex CA. 3. Region B3 = 0.05 um *(L1+L2). L1 = 0.08 um, L2 = 0.12 um 4. Region B4 = 0.05 um * 0.3 um, generated from Mx (polygon2) line-end. 5. Region B5 = S2*S3, generated from vertex CB. 0 um < S2 (polygon3 vertex CB to polygon1) <= 0.055 um, and -0.1 um <= S3 (parallel run length of polygon2 and polygon1) <= -0.03 um >= 0.055 
  M4_L_END_BRS2_metal_pre = M4i WITH EDGE M4_L_END_edge
  M4_L_END_BRS2_metal_enc = M4_L_END_BRS2_metal_pre AND (EXPAND EDGE M4_L_END_edge INSIDE BY TypeBRS2_LL)
  M4_L_END_BRS2_LL = (((EXPAND EDGE M4_L_END_edge INSIDE BY TypeBRS2_LL-GRID) AND M4i) WITH EDGE M4_L_END_edge) INTERACT M4_jog_CORNER_waive
  M4_L_END_BRS2_metal = (ENCLOSE RECTANGLE M4_L_END_BRS2_metal_enc Mx_W TypeBRS2_LL) NOT INTERACT M4_L_END_BRS2_LL
  M4_L_END_BRS2_L_END_edge = M4_L_END_edge COIN EDGE M4_L_END_BRS2_metal
  
  M4_L_END_BRS2_side_edge_pre = INT [M4i] M4_L_END_BRS2_L_END_edge <= TypeBRS2_S5 ABUT == 90 INTERSECTING ONLY
  M4_L_END_BRS2_dense_side_edge_pre = INT [M4i] M4_L_END_BRS2_L_END_edge <= TypeBRS2_LH ABUT == 90 INTERSECTING ONLY
  M4_L_END_BRS2_iso_side_edge_pre = EXT [M4_L_END_BRS2_side_edge_pre] M4i <= TypeBRS2_S4 ABUT < 90 OPPOSITE
  M4_L_END_BRS2_iso_side_edge_pre1 = LENGTH (M4_L_END_BRS2_side_edge_pre NOT COIN EDGE M4_L_END_BRS2_iso_side_edge_pre) >= TypeBRS2_S5
  M4_L_END_BRS2_iso_side_edge_pre2 = (EXPAND EDGE M4_L_END_BRS2_iso_side_edge_pre1 INSIDE BY GRID) WITH EDGE M4_L_END_BRS2_L_END_edge
  M4_L_END_BRS2_iso_side_edge = LENGTH (M4_L_END_BRS2_iso_side_edge_pre1 COIN EDGE M4_L_END_BRS2_iso_side_edge_pre2) >= TypeBRS2_S5
  M4_L_END_BRS2_L_END_edge_waive = EXT [M4_L_END_BRS2_L_END_edge] M4i < TypeBRS2_S2 ABUT < 90 OPPOSITE
  M4_L_END_REGION_BRS2_dense_edge_pre = EXPAND EDGE M4_L_END_BRS2_L_END_edge INSIDE BY TypeBRS2_LH OUTSIDE BY TypeBRS2_LY
  M4_L_END_REGION_BRS2_dense_edge_pre1 = VERTEX (EXT M4_L_END_REGION_BRS2_dense_edge_pre M4i <= Mx_S ABUT < 90 OPPOSITE REGION) == 4
  M4_L_END_REGION_BRS2_dense_edge = LENGTH (M4_L_END_REGION_BRS2_dense_edge_pre COIN EDGE M4_L_END_REGION_BRS2_dense_edge_pre1) >= TypeBRS2_LH+TypeBRS2_LY
  M4_L_END_REGION_BRS2_dense_iso = INT M4_L_END_BRS2_iso_side_edge M4_L_END_REGION_BRS2_dense_edge <= Mx_W ABUT < 90 OPPOSITE REGION
  M4_L_END_BRS2_iso_dense_side_edge_pre = (M4_L_END_REGION_BRS2_dense_edge_pre TOUCH EDGE M4_L_END_BRS2_iso_side_edge) NOT COIN EDGE M4i
  M4_L_END_BRS2_iso_dense_side_edge_pre1 = EXT [M4_L_END_BRS2_iso_dense_side_edge_pre] M4_CORNER <= Mx_S ABUT < 90 OPPOSITE
  M4_L_END_BRS2_iso_dense_side_edge = EXPAND EDGE (M4_L_END_BRS2_iso_dense_side_edge_pre TOUCH EDGE M4_L_END_BRS2_iso_dense_side_edge_pre1) BY GRID EXTEND BY GRID
  M4_L_END_REGION_BRS2_pre1 = EXPAND EDGE M4_L_END_BRS2_L_END_edge INSIDE BY TypeBRS2_LH-TypeBRS2_LY
  M4_L_END_REGION_BRS2_pre2 = ((M4_L_END_REGION_BRS2_pre1 NOT WITH EDGE M4_L_END_BRS2_L_END_edge_waive) INTERACT M4_L_END_REGION_BRS2_dense_iso) INTERACT M4_L_END_BRS2_iso_dense_side_edge
  M4_L_END_REGION_BRS2_pre3 = M4_L_END_edge COIN EDGE M4_L_END_REGION_BRS2_pre2 
  M4_L_END_REGION_BRS2_pre4 = EXPAND EDGE M4_L_END_REGION_BRS2_pre3 INSIDE BY TypeBRS2_LH-TypeBRS2_LY
  M4_L_END_REGION_BRS2_pre5 = EXPAND EDGE (M4_L_END_REGION_BRS2_pre4 COIN EDGE M4_L_END_REGION_BRS2_dense_edge) OUTSIDE BY Mx_S EXTEND BY TypeBRS2_LY
  M4_L_END_REGION_BRS2_pre6 = M4_L_END_REGION_BRS2_pre5 WITH EDGE (LENGTH (M4_L_END_REGION_BRS2_pre5 COIN EDGE M4i) == TypeBRS2_LH+TypeBRS2_LY)
  
  M4_L_END_REGION_BRS2_pre7 = M4_CORNER INTERACT M4_L_END_REGION_BRS2_pre6 
  M4_L_END_REGION_BRS2_pre8 = M4_L_END_REGION_BRS2_pre7 COIN EDGE M4_L_END_REGION_BRS2_pre6
  M4_L_END_REGION_BRS2_pre9 = (EXPAND EDGE M4_L_END_REGION_BRS2_pre8 INSIDE BY GRID EXTEND BY TypeBRS2_LG_max+GRID) TOUCH EDGE M4_L_END_REGION_BRS2_pre6
  M4_L_END_REGION_BRS2_pre10 = M4i COIN EDGE (EXT [M4_CORNER] M4_L_END_REGION_BRS2_pre9 > Mx_W+Mx_S <= Mx_W+Mx_S+TypeBRS2_S3 ABUT < 90 OPPOSITE MEASURE ALL)
  M4_L_END_REGION_BRS2_pre11 = M4_CORNER WITH EDGE M4_L_END_REGION_BRS2_pre10
  M4_L_END_REGION_BRS2_pre12 = EXT [M4_L_END_REGION_BRS2_pre7] M4_L_END_REGION_BRS2_pre11 > TypeBRS2_LGS_min <= TypeBRS2_LGS_max CORNER TO CORNER 
  M4_L_END_REGION_BRS2_MARK = M4_L_END_REGION_BRS2_pre6 WITH EDGE M4_L_END_REGION_BRS2_pre12
  M4_L_END_REGION_BRS2_MARK INTERACT EFPM4S6_M4i
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPM4S7_
#IFDEF _EFPM4S7_
EFPM4S7_M4iCellIn = INSIDE CELL M4i CellsForRRuleRecommended  
EFPM4S7_M4iCellOut = NOT INSIDE CELL M4i ExclCellsForRRuleRecommended 
EFPM4S7_M4iCell = EFPM4S7_M4iCellIn AND EFPM4S7_M4iCellOut
EFPM4S7_M4iMarker = M4i AND RRuleRecommended
EFPM4S7_M4i = ((EFPM4S7_M4iCell OR EFPM4S7_M4iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M4.S.7 { @ Metal bridge recommendation type-3: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3 and Region B4] when neighboring Mx (polygon3/4) with parallel run length > 0 um and there is no other Mx interact Region B1/B2 Definitions: 1. Region B3/B4 = 0.25 um * 0.09 um (L1), generated from vertex CB and CA respectively. 2. L2 = height difference of vertex CA project to vertex CB <= 0.05 um. 3. Region B1/B2 = 0.16 um * 0.115 um, generated from Mx (polygon3/4) line-end with vertex CA and CB respectively >= 0.055 
  M4_TypeBRS3_prefilter_1 = EXT [M4i] == TypeBRS3_S2 ABUT < 90 OPPOSITE
  M4_TypeBRS3_prefilter_2 = M4i TOUCH EDGE M4_TypeBRS3_prefilter_1
  M4_TypeBRS3_prefilter_3 = (M4_CORNER WITH EDGE M4_TypeBRS3_prefilter_2) COIN EDGE M4i
  
  M4_TypeBRS3_prefilter_4_1 = EXT M4_TypeBRS3_prefilter_3 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
  M4_TypeBRS3_prefilter_4_2 = M4i AND M4_TypeBRS3_prefilter_4_1
  M4_TypeBRS3_prefilter_4_3 = EXT [M4_TypeBRS3_prefilter_3] M4_TypeBRS3_prefilter_4_2 <= Mx_S OPPOSITE EXTENDED TypeBRS3_S6
  M4_TypeBRS3_prefilter_4_4 = M4_TypeBRS3_prefilter_3 TOUCH EDGE M4_TypeBRS3_prefilter_4_3 
  M4_TypeBRS3_prefilter_4_5 = EXT [M4_TypeBRS3_prefilter_3] M4_TypeBRS3_prefilter_4_2 > Mx_S+Mx_W <= 2*Mx_S+Mx_W OPPOSITE EXTENDED TypeBRS3_S6
  M4_TypeBRS3_prefilter_4_6 = M4_TypeBRS3_prefilter_4_4 TOUCH EDGE M4_TypeBRS3_prefilter_4_5
  M4_TypeBRS3_prefilter_4 =  EXT M4_TypeBRS3_prefilter_4_6 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
  M4_TypeBRS3_prefilter_5_1 = EXPAND EDGE (M4_TypeBRS3_prefilter_3 COIN EDGE M4_TypeBRS3_prefilter_4) OUTSIDE BY 2*GRID
  M4_TypeBRS3_prefilter_5_2 = INT [M4_TypeBRS3_prefilter_5_1] == GRID OPPOSITE
  M4_TypeBRS3_prefilter_5_3 = EXPAND EDGE M4_TypeBRS3_prefilter_5_2 OUTSIDE BY GRID EXTEND BY GRID
  M4_TypeBRS3_prefilter_5_4 = M4_TypeBRS3_prefilter_5_2 COIN EDGE (M4_TypeBRS3_prefilter_5_3 NOT TOUCH EDGE M4_TypeBRS3_prefilter_3)
  M4_TypeBRS3_prefilter_5_5 = EXPAND EDGE M4_TypeBRS3_prefilter_5_4 OUTSIDE BY GRID
  M4_TypeBRS3_prefilter_5 = M4_TypeBRS3_prefilter_5_1 OR M4_TypeBRS3_prefilter_5_5
  
  M4_TypeBRS3_prefilter_6 = M4_TypeBRS3_prefilter_4 NOT M4_TypeBRS3_prefilter_5
  M4_TypeBRS3_prefilter_7_1 = M4_TypeBRS3_prefilter_6 INTERACT (M4_TypeBRS3_prefilter_6 AND M4i) > 1
  M4_TypeBRS3_prefilter_7 = (M4_TypeBRS3_prefilter_5_1 INTERACT M4_TypeBRS3_prefilter_7_1) OR M4_TypeBRS3_prefilter_7_1
  M4_TypeBRS3_prefilter_8 = EXTENTS M4_TypeBRS3_prefilter_7
  
  M4_TypeBRS3_prefilter_9 = M4_TypeBRS3_prefilter_3 COIN EDGE (M4_CORNER INTERACT M4_TypeBRS3_prefilter_8)
  M4_TypeBRS3_prefilter_10 = EXT M4_TypeBRS3_prefilter_9 M4_TypeBRS3_prefilter_2 == TypeBRS3_S2 OPPOSITE REGION
  M4_TypeBRS3_prefilter_11 = M4_TypeBRS3_prefilter_10 INTERACT (M4_TypeBRS3_prefilter_10 AND M4i) > 1
  M4_TypeBRS3_prefilter_12 = (EXPAND EDGE M4_TypeBRS3_prefilter_3 OUTSIDE BY GRID) NOT INTERACT M4_TypeBRS3_prefilter_11
  M4_TypeBRS3_prefilter_13 = (EXPAND EDGE (M4_TypeBRS3_prefilter_12 NOT COIN EDGE M4i) OUTSIDE BY GRID) OR M4_TypeBRS3_prefilter_12 
  M4_TypeBRS3_prefilter_14 = M4_TypeBRS3_prefilter_11 TOUCH EDGE M4_TypeBRS3_prefilter_13
  M4_TypeBRS3_prefilter_15 = M4_TypeBRS3_prefilter_11 WITH EDGE M4_TypeBRS3_prefilter_14 == 2
  
  M4_TypeBRS3_prefilter_16 = (M4_TypeBRS3_prefilter_11 WITH EDGE (LENGTH (M4_TypeBRS3_prefilter_8 COIN EDGE M4_TypeBRS3_prefilter_11) == TypeBRS3_S2)) NOT M4i
  
  M4_TypeBRS3_CACB_S6_1 = (M4_TypeBRS3_prefilter_8 INTERACT M4_TypeBRS3_prefilter_16 != 6) NOT ENCLOSE M4_TypeBRS3_prefilter_15
  M4_TypeBRS3_CACB_S6_2 = M4_TypeBRS3_CACB_S6_1 WITH WIDTH <= TypeBRS3_S6+GRID
  M4_TypeBRS3_CACB_S6_3 = M4_TypeBRS3_CACB_S6_2 AND M4i
  M4_TypeBRS3_CACB_S6_4 = M4_TypeBRS3_CACB_S6_2 INTERACT M4_TypeBRS3_CACB_S6_3 == 2
  M4_TypeBRS3_CACB_S6_5 = (EXPAND EDGE ((M4_TypeBRS3_CACB_S6_4 AND M4i) COIN EDGE M4i) OUTSIDE BY Mx_S) OR (M4_TypeBRS3_CACB_S6_4 AND M4i)
  M4_TypeBRS3_CACB_S6_6 = M4_TypeBRS3_CACB_S6_4 AND M4_TypeBRS3_CACB_S6_5
  M4_TypeBRS3_CACB_S6_7 = M4_TypeBRS3_CACB_S6_6 WITH EDGE ((M4_TypeBRS3_CACB_S6_6 AND M4i) COIN EDGE M4_TypeBRS3_CACB_S6_6) == 4
  
  M4_TypeBRS3_CACB_S3_1 = LENGTH M4_TypeBRS3_CACB_S6_7 == TypeBRS3_S2
  M4_TypeBRS3_CACB_S3_2 = M4i COIN EDGE M4_TypeBRS3_CACB_S6_7
  M4_TypeBRS3_CACB_S3_3 = LENGTH M4_TypeBRS3_CACB_S3_2 == GRID
  M4_TypeBRS3_CACB_S3_4 = (((M4_CORNER COIN EDGE M4i) NOT COIN EDGE M4_TypeBRS3_CACB_S3_3) NOT COIN EDGE M4_TypeBRS3_CACB_S3_1 ) TOUCH EDGE M4_TypeBRS3_CACB_S6_7
  M4_TypeBRS3_CACB_S3_5 = EXPAND EDGE M4_TypeBRS3_CACB_S3_3 OUTSIDE BY GRID EXTEND BY GRID
  M4_TypeBRS3_CACB_S3_6 = EXPAND EDGE M4_TypeBRS3_CACB_S3_4 OUTSIDE BY GRID EXTEND BY GRID
  
  M4_TypeBRS3_CACB_S3_7 = (((M4_CORNER INTERACT M4_TypeBRS3_CACB_S6_7) NOT INSIDE M4_TypeBRS3_CACB_S6_7) COIN EDGE M4i) NOT COIN EDGE M4_TypeBRS3_CACB_S6_7
  M4_TypeBRS3_CACB_S3_8 = EXPAND EDGE M4_TypeBRS3_CACB_S3_7 OUTSIDE BY GRID EXTEND BY GRID
  M4_TypeBRS3_CACB_S3_9 = M4_TypeBRS3_CACB_S3_1 TOUCH EDGE M4_TypeBRS3_CACB_S3_8
  M4_TypeBRS3_CACB_S3_10 = M4_TypeBRS3_CACB_S3_1 NOT TOUCH EDGE M4_TypeBRS3_CACB_S3_8
  M4_TypeBRS3_CACB_S3_11_1 = EXPAND EDGE M4_TypeBRS3_CACB_S3_9 OUTSIDE BY TypeBRS3_S3
  M4_TypeBRS3_CACB_S3_12_1 = EXPAND EDGE M4_TypeBRS3_CACB_S3_10 OUTSIDE BY TypeBRS3_S3-GRID
  M4_TypeBRS3_CACB_S3_11 = M4_TypeBRS3_CACB_S3_11_1 WITH EDGE ((M4_TypeBRS3_CACB_S3_11_1 AND M4) COIN EDGE M4_TypeBRS3_CACB_S3_11_1) >= 4
  M4_TypeBRS3_CACB_S3_12  = M4_TypeBRS3_CACB_S3_12_1 WITH EDGE ((M4_TypeBRS3_CACB_S3_12_1 AND M4) COIN EDGE M4_TypeBRS3_CACB_S3_12_1) >= 4
  M4_TypeBRS3_CACB_S3_13 = M4_TypeBRS3_CACB_S6_7 OR (M4_TypeBRS3_CACB_S3_11 OR M4_TypeBRS3_CACB_S3_12)
  M4_TypeBRS3_CACB_S3_14 = (M4_TypeBRS3_CACB_S3_13 AND M4i) COIN EDGE M4_TypeBRS3_CACB_S3_13
  M4_TypeBRS3_CACB_S3_15 = ENCLOSE RECTANGLE (M4_TypeBRS3_CACB_S3_13 WITH EDGE M4_TypeBRS3_CACB_S3_14 >= 4) TypeBRS3_S2 2*TypeBRS3_S3
  
  M4_TypeBRS3_CACB_S45_1 = EXPAND EDGE M4_TypeBRS3_CACB_S3_7 OUTSIDE BY 2*GRID 
  M4_TypeBRS3_CACB_S45_2 = M4_TypeBRS3_CACB_S3_15 COIN EDGE M4_TypeBRS3_CACB_S45_1 
  M4_TypeBRS3_CACB_S45_3 = EXT [M4_TypeBRS3_CACB_S3_7] M4i < TypeBRS3_S5 OPPOSITE EXTENDED GRID
  M4_TypeBRS3_CACB_S45_4 = EXT [M4_TypeBRS3_CACB_S45_2] M4i < TypeBRS3_S4 OPPOSITE
  M4_TypeBRS3_CACB_S45_5 = (EXPAND EDGE (M4_TypeBRS3_CACB_S45_1 COIN EDGE M4_TypeBRS3_CACB_S3_15) INSIDE BY 2*GRID) OR M4_TypeBRS3_CACB_S45_1
  M4_TypeBRS3_CACB_S45_6 = (M4_TypeBRS3_CACB_S45_5 NOT COIN EDGE M4i) NOT COIN EDGE M4_TypeBRS3_CACB_S3_15
  M4_TypeBRS3_CACB_S45_7 = ENC M4i [M4_TypeBRS3_CACB_S45_6] == 2*GRID OPPOSITE
  M4_TypeBRS3_CACB_S45_8 = (EXPAND EDGE M4_TypeBRS3_CACB_S45_7 OUTSIDE BY TypeBRS3_S5-2*GRID) OR M4_TypeBRS3_CACB_S45_5 
  M4_TypeBRS3_CACB_S45_9 = LENGTH M4_TypeBRS3_CACB_S45_8  >= TypeBRS3_S5 <= 2*TypeBRS3_S5
  M4_TypeBRS3_CACB_S45_10_1 = M4_TypeBRS3_CACB_S45_9 TOUCH EDGE M4_TypeBRS3_CACB_S3_15
  M4_TypeBRS3_CACB_S45_10_2 = ENC M4i [M4_TypeBRS3_CACB_S45_10_1] < TypeBRS3_S4 OPPOSITE
  M4_TypeBRS3_CACB_S45_10_3 = M4_TypeBRS3_CACB_S45_10_1 TOUCH EDGE M4_TypeBRS3_CACB_S45_10_2 
  M4_TypeBRS3_CACB_S45_10 = M4_TypeBRS3_CACB_S45_10_1 NOT TOUCH EDGE M4_TypeBRS3_CACB_S45_10_2 
  M4_TypeBRS3_CACB_S45_11 = EXPAND EDGE M4_TypeBRS3_CACB_S45_10 INSIDE BY TypeBRS3_S4
  M4_TypeBRS3_CACB_S45_12 = M4_TypeBRS3_CACB_S45_11 INTERACT (M4_TypeBRS3_CACB_S45_11 AND M4i)
  M4_TypeBRS3_CACB_BOXB_waive = (((M4_TypeBRS3_CACB_S45_5 WITH EDGE M4_TypeBRS3_CACB_S45_3) OR (M4_TypeBRS3_CACB_S45_5 WITH EDGE M4_TypeBRS3_CACB_S45_4)) OR (M4_TypeBRS3_CACB_S45_5 INTERACT M4_TypeBRS3_CACB_S45_12)) OR (M4_TypeBRS3_CACB_S45_5 WITH EDGE M4_TypeBRS3_CACB_S45_10_3)
  
  M4_TypeBRS3_CACB_BOXAC_1 = (EXPAND EDGE (M4i COIN EDGE M4_TypeBRS3_CACB_BOXB_waive) INSIDE BY 2*GRID) OR M4_TypeBRS3_CACB_BOXB_waive
  M4_TypeBRS3_CACB_BOXAC_2 = M4_TypeBRS3_CACB_S6_7 NOT INTERACT M4_TypeBRS3_CACB_BOXAC_1 
  M4_TypeBRS3_CACB_BOXAC_3 = M4_TypeBRS3_CACB_S3_9 COIN EDGE M4_TypeBRS3_CACB_BOXAC_2
  M4_TypeBRS3_CACB_BOXAC_4 = M4_TypeBRS3_CACB_S3_10 COIN EDGE M4_TypeBRS3_CACB_BOXAC_2
  M4_TypeBRS3_CACB_BOXAC_5_1 = EXPAND EDGE M4_TypeBRS3_CACB_BOXAC_3 OUTSIDE BY TypeBRS3_S3
  M4_TypeBRS3_CACB_BOXAC_5 = M4_TypeBRS3_CACB_BOXAC_5_1 WITH EDGE ((M4_TypeBRS3_CACB_BOXAC_5_1 AND M4i) COIN EDGE M4_TypeBRS3_CACB_BOXAC_5_1) == 4
  M4_TypeBRS3_CACB_BOXAC_6_1 = EXPAND EDGE M4_TypeBRS3_CACB_BOXAC_4 OUTSIDE BY TypeBRS3_S3-GRID
  M4_TypeBRS3_CACB_BOXAC_6 = M4_TypeBRS3_CACB_BOXAC_6_1 WITH EDGE ((M4_TypeBRS3_CACB_BOXAC_6_1 AND M4i) COIN EDGE M4_TypeBRS3_CACB_BOXAC_6_1) == 4
  M4_TypeBRS3_CACB_BOXAC_7 = ((M4_TypeBRS3_CACB_BOXAC_2 INTERACT M4_TypeBRS3_CACB_BOXAC_5) INTERACT M4_TypeBRS3_CACB_BOXAC_6) OR (M4_TypeBRS3_CACB_BOXAC_5 OR M4_TypeBRS3_CACB_BOXAC_6)
  M4_TypeBRS3_CACB_BOXAC_8 = (M4_TypeBRS3_CACB_BOXAC_7 AND M4i) COIN EDGE M4_TypeBRS3_CACB_BOXAC_7
  M4_TypeBRS3_CACB_BOXAC_9 = INT [M4_TypeBRS3_CACB_BOXAC_8] <= 4*TypeBRS3_S3+2*TypeBRS3_S6+2*GRID OPPOSITE
  M4_TypeBRS3_CACB_BOXAC_10 = ENCLOSE RECTANGLE (M4_TypeBRS3_CACB_BOXAC_7 WITH EDGE M4_TypeBRS3_CACB_BOXAC_9  == 4) TypeBRS3_S2 2*TypeBRS3_S3
  M4_TypeBRS3_CACB_BOXAC_11 = VERTEX (M4_TypeBRS3_CACB_BOXAC_10 AND M4i) != 4
  M4_TypeBRS3_CACB_BOXAC_12 = M4_TypeBRS3_CACB_BOXAC_10 NOT INTERACT M4_TypeBRS3_CACB_BOXAC_11
  M4_TypeBRS3_CACB_BOXC = M4_TypeBRS3_CACB_BOXAC_2 INSIDE M4_TypeBRS3_CACB_BOXAC_12
  M4_TypeBRS3_CACB_MARK = EXT (M4_TypeBRS3_CACB_BOXC AND M4i) <= Mx_S OPPOSITE REGION
  M4_TypeBRS3_CACB_MARK INTERACT EFPM4S7_M4i
}
#ENDIF
#ENDIF
#IFDEF CHECK_EFPM4EN1_
#IFDEF _EFPM4EN1_
EFPM4EN1_M4iCellIn = INSIDE CELL M4i CellsForRRuleRecommended  
EFPM4EN1_M4iCellOut = NOT INSIDE CELL M4i ExclCellsForRRuleRecommended 
EFPM4EN1_M4iCell = EFPM4EN1_M4iCellIn AND EFPM4EN1_M4iCellOut
EFPM4EN1_M4iMarker = M4i AND RRuleRecommended
EFPM4EN1_M4i = ((EFPM4EN1_M4iCell OR EFPM4EN1_M4iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M4.EN.1 { @ Mx/VIAx-1 recommendation: Recommended Mx_A enclosure VIAx-1 [in {VIAx-1 AND Mx_A} space to Mx (SP3+SE) <= 0.06 um side] Definition of Mx_A: Mx with consecutive edge length (L1) <= 0.12 um, (L2) <= 0.06 um, (L3) >= 0.1 um, L1/L3 edge is between 2 outer vertex. L1/L3 space to adjacent Mx (SP3/SP4) = 0.05 um [parallel run length > 0 from VIAx-1] >= 0.01 
   L1_pre = CONVEX EDGE EFPM4EN1_M4i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L2 LENGTH2>=EFP_Mx_EN_1_L3 WITH LENGTH<=EFP_Mx_EN_1_L1
   L2_pre = CONVEX EDGE EFPM4EN1_M4i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH<=EFP_Mx_EN_1_L2
   L3_pre = CONVEX EDGE EFPM4EN1_M4i ANGLE1==90 ANGLE2>=90 <=270 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH>=EFP_Mx_EN_1_L3
   L1_L2_V = INT L1_pre L2_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1_L3_V = INT L1_pre L3_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1 = (L1_pre TOUCH INSIDE EDGE L1_L2_V) TOUCH INSIDE EDGE L1_L3_V
   L3 = L3_pre TOUCH INSIDE EDGE (L1_L3_V WITH EDGE L1)
   L1_DENSE = EXT [L1] M4 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA3_L1_DENSE = VIA3i TOUCH INSIDE EDGE (ENC [VIA3i] L1_DENSE < EFP_Mx_EN_1_SE ABUT<90 OPPOSITE)
   L3_DENSE = EXT [L3] M4 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA3_L3_DENSE = VIA3i TOUCH INSIDE EDGE (ENC [VIA3i] L3_DENSE <= EFP_Mx_EN_1_L1-VIA3_W_1-VIA3_EN_2 ABUT<90 OPPOSITE)
   X = INT VIA3_L1_DENSE VIA3_L3_DENSE <= GRID ABUT==90 INTERSECTING ONLY REGION
   VIA3i INTERACT X  
}
// EFP.Mx.EN.1.R is checked by RR:RE:EFP.M4.EN.1
#ENDIF
#ENDIF
// EFP.Mx.S.5.R is checked by RR:RE:EFP.M4.S.5
// EFP.Mx.S.6.R is checked by RR:RE:EFP.M4.S.6
// EFP.Mx.S.7.R is checked by RR:RE:EFP.M4.S.7

#IFDEF CHECK_EFPM5S2_
#IFDEF _EFPM5S2_
EFPM5S2_M5iCellIn = INSIDE CELL M5i CellsForRRuleRecommended  
EFPM5S2_M5iCellOut = NOT INSIDE CELL M5i ExclCellsForRRuleRecommended 
EFPM5S2_M5iCell = EFPM5S2_M5iCellIn AND EFPM5S2_M5iCellOut
EFPM5S2_M5iMarker = M5i AND RRuleRecommended
EFPM5S2_M5i = ((EFPM5S2_M5iCell OR EFPM5S2_M5iMarker) NOT Block ) NOT excludeRRuleRecommended

// M5 Type Cap
//=============
RR:RE:EFP.M5.S.2 { @ Cap recommendation: Recommended the line-end space at Mx [line width (W2) = 0.05 um, length (L3) >= 0.15 um] in a line-end configuration: If both longer edges of Mx line-end have parallel run length [0.005 um ~ 0.115 um (L2)] to Mx [space to Mx line-end 0.05 um (S1), and both Mxs are part of one polygon] >= 0.115 
  M5_NOTCH_LL = (((EXPAND EDGE M5_L_END_edge INSIDE BY TypeLEH_LL-GRID) AND M5i) WITH EDGE M5_L_END_edge) INTERACT M5_jog_CORNER_waive

  M5_NOTCH_pre = EXT M5i < TypeLEH_NOTCH ABUT < 90 NOTCH OPPOSITE REGION
  M5_NOTCH = (ENCLOSE RECTANGLE M5_NOTCH_pre TypeLEH_NOTCH-3*GRID GRID) INTERACT M5i > 1
  M5_NOTCH_candidate1 = ENCLOSE RECTANGLE (M5i INTERACT M5_NOTCH) TypeLEH_LL Mx_W
  M5_NOTCH_candidate2 = EXT M5_NOTCH_candidate1 <= TypeLEH_S2 ABUT < 90 OPPOSITE REGION
  M5_NOTCH_candidate3 = (M5_L_END_edge TOUCH EDGE M5_NOTCH_candidate2) INSIDE EDGE M5_NOTCH
  M5_NOTCH_candidate4 = EXPAND EDGE M5_NOTCH_candidate3 INSIDE BY GRID
  M5_NOTCH_candidate5 = (VERTEX (SIZE M5_NOTCH_candidate4 BY TypeLEH_marker-GRID INSIDE OF M5_NOTCH_candidate1 STEP Mx_S *0.7) == 4) INTERACT M5_NOTCH
  M5_NOTCH_candidate6 = EXT [M5_NOTCH_candidate5] M5i <= Mx_S+GRID ABUT < 90 OPPOSITE
  M5_NOTCH_candidate7 = INT (M5_NOTCH_candidate5 NOT COIN EDGE M5_NOTCH_candidate6) <= Mx_W ABUT < 90 OPPOSITE REGION
  M5_NOTCH_candidate = (M5_NOTCH_candidate5 INTERACT M5_NOTCH_candidate7) NOT INTERACT M5_NOTCH_LL
  M5_NOTCH_candidate INTERACT EFPM5S2_M5i
}
#ENDIF
#ENDIF
// EFP.Mx.S.2.R is checked by RR:RE:EFP.M5.S.2

#IFDEF CHECK_EFPM5S3_
#IFDEF _EFPM5S3_
EFPM5S3_M5iCellIn = INSIDE CELL M5i CellsForRRuleRecommended  
EFPM5S3_M5iCellOut = NOT INSIDE CELL M5i ExclCellsForRRuleRecommended 
EFPM5S3_M5iCell = EFPM5S3_M5iCellIn AND EFPM5S3_M5iCellOut
EFPM5S3_M5iMarker = M5i AND RRuleRecommended
EFPM5S3_M5i = ((EFPM5S3_M5iCell OR EFPM5S3_M5iMarker) NOT Block ) NOT excludeRRuleRecommended

// M5 Type Hook 
//=============
TypeHook_M5_H2		  = CONVEX EDGE EFPM5S3_M5i ANGLE1==270 ANGLE2==270 WITH LENGTH <= TypeH_LB
TypeHook_M5_H2_corner	  = EXT TypeHook_M5_H2 [M5] < TypeH_LB ABUT==90 
TypeHook_M5_H2_W	  = INT EFPM5S3_M5i (EFPM5S3_M5i TOUCH EDGE TypeHook_M5_H2_corner) <= TypeH_W ABUT<90 REGION
TypeHook_M5_H2_W_out	  = TypeHook_M5_H2_W NOT TOUCH EDGE TypeHook_M5_H2_corner
TypeHook_M5_H2_L_chk	  = TypeHook_M5_H2_corner TOUCH EDGE TypeHook_M5_H2_W 
TypeHook_M5_H2_OC_pre1	  = (CONVEX EDGE EFPM5S3_M5i ANGLE1==270 ANGLE2==90 ) TOUCH EDGE TypeHook_M5_H2_L_chk
TypeHook_M5_H2_OC_pre2	  = EXT [TypeHook_M5_H2_OC_pre1] TypeHook_M5_H2 <= TypeH_LB ABUT==90 
TypeHook_M5_H2_OC	  = TypeHook_M5_H2_OC_pre2 NOT COIN EDGE (INT EFPM5S3_M5i TypeHook_M5_H2_OC_pre2 < DB_GRID ABUT ==90 REGION)
TypeHook_M5_H2_OC_chk	  = EXT [TypeHook_M5_H2_L_chk] TypeHook_M5_H2_OC < TypeH_S2 ABUT<90 OPPOSITE
TypeHook_M5_H2_IC_OClng  = TypeHook_M5_H2 NOT TOUCH EDGE (TypeHook_M5_H2 NOT COIN EDGE TypeHook_M5_H2_OC_chk)
TypeHook_M5_H2_corner_L  = EXT TypeHook_M5_H2_L_chk [TypeHook_M5_H2] < DB_GRID ABUT==90
TypeHook_M5_H2_corner_IC = EXT [TypeHook_M5_H2] <DB_GRID ABUT==90 
TypeHook_M5_H2_corner_IC_OClng = EXT [TypeHook_M5_H2] TypeHook_M5_H2_IC_OClng <DB_GRID ABUT==90 
TypeHook_M5_H2_short	  = LENGTH TypeHook_M5_H2 < TypeH_S2
TypeHook_M5_H2_corner_err = DFM PROPERTY TypeHook_M5_H2 TypeHook_M5_H2_corner_L TypeHook_M5_H2_corner_IC TypeHook_M5_H2_corner_IC_OClng TypeHook_M5_H2_short OVERLAP ABUT ALSO MULTI
				    [ -= COUNT(TypeHook_M5_H2_short)] >0
				    [ -= COUNT(TypeHook_M5_H2_corner_IC)] >0
				    [ -= COUNT(TypeHook_M5_H2_corner_IC_OClng)] >0
				    [ -= COUNT(TypeHook_M5_H2_corner_L)] >1
TypeHook_M5_H2_err	  = EXPAND EDGE (TypeHook_M5_H2 TOUCH EDGE TypeHook_M5_H2_corner_err) BY 0.001
TypeHook_M5		  = COPY TypeHook_M5_H2_err
RR:RE:EFP.M5.S.3 { @ Hook recommendation: Recommended space from the edge [length <= 0.065 um (L4) between the edges of line width <= 0.055 um (W3 and W3') and either one of the edges >= 0.15 um (L5)] of Mx pattern [with 3 consecutive 270-270-270 degree inner angles] to opposite edge of the same Mx >= 0.155 
   COPY TypeHook_M5 
}
#ENDIF
#ENDIF
// EFP.Mx.S.3.R is checked by RR:RE:EFP.M5.S.3

#IFDEF CHECK_EFPM5S5_
#IFDEF _EFPM5S5_
EFPM5S5_M5iCellIn = INSIDE CELL M5i CellsForRRuleRecommended  
EFPM5S5_M5iCellOut = NOT INSIDE CELL M5i ExclCellsForRRuleRecommended 
EFPM5S5_M5iCell = EFPM5S5_M5iCellIn AND EFPM5S5_M5iCellOut
EFPM5S5_M5iMarker = M5i AND RRuleRecommended
EFPM5S5_M5i = ((EFPM5S5_M5iCell OR EFPM5S5_M5iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M5.S.5 { @ Metal bridge recommendation type-1: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3] when there is no other Mx cut Region B1/B2 Definitions: 1. Region B3 = 0.25 um * S2, generated from vertex CA/CB. 2. S2 = 2 Mx (polygon3/4) with parallel run length 0 um > S2 >= 0.235 um 3. Region B1/B2 = 0.16 um * 0.23 um, generated from Mx (polygon3/4) metal line-end with vertex CA/CB respectively >= 0.055 
  M5_TypeBRS1_prefilter_1 = EXT [M5i] == TypeBRS1_S2 ABUT < 90 OPPOSITE EXTENDED TypeBRS1_S3+NANO
  M5_TypeBRS1_CORNER_pre_1_1 = M5_CORNER_S1 WITH EDGE M5_TypeBRS1_prefilter_1
  M5_TypeBRS1_CORNER_pre_1_2 = EXT [M5_L_END_edge] M5i < TypeBRS1_S5 OPPOSITE
  M5_TypeBRS1_CORNER_pre_1 = M5_TypeBRS1_CORNER_pre_1_1 NOT WITH EDGE M5_TypeBRS1_CORNER_pre_1_2
  M5_TypeBRS1_CORNER_pre_2 = EXT M5_TypeBRS1_CORNER_pre_1 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION
  M5_TypeBRS1_CORNER_pre_3 = M5_TypeBRS1_CORNER_pre_2 INTERACT (M5_TypeBRS1_CORNER_pre_2 AND M5i) > 1
  M5_TypeBRS1_CORNER_pre_4 = M5_TypeBRS1_CORNER_pre_1 INTERACT M5_TypeBRS1_CORNER_pre_3
  
  M5_TypeBRS1_CACB_S23 = EXT M5_TypeBRS1_CORNER_pre_4 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M5_TypeBRS1_CACB_S23_1_1 = M5_TypeBRS1_CACB_S23 INTERACT M5_CORNER_S1 >= 2
  
  M5_TypeBRS1_CACB_S23_1_2 = INT (M5i AND M5_TypeBRS1_CACB_S23_1_1) == Mx_W OPPOSITE REGION
  M5_TypeBRS1_CACB_S23_1_3 = EXPAND EDGE (M5i COIN INSIDE EDGE M5_TypeBRS1_CACB_S23_1_2) OUTSIDE BY Mx_S
  M5_TypeBRS1_CACB_S23_1_4 = M5_TypeBRS1_CACB_S23_1_2 OR M5_TypeBRS1_CACB_S23_1_3
  M5_TypeBRS1_CACB_S23_1_5 = (EXT (M5_TypeBRS1_CORNER_pre_4 INTERACT M5_TypeBRS1_CACB_S23_1_1) >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION) AND M5_TypeBRS1_CACB_S23_1_4
  M5_TypeBRS1_CACB_S23_1_6 = (M5_TypeBRS1_CORNER_pre_4 INTERACT M5_TypeBRS1_CACB_S23_1_1) INTERACT (SIZE M5_TypeBRS1_CACB_S23_1_5 BY GRID)
  M5_TypeBRS1_CACB_S23_1_7 = EXT M5_TypeBRS1_CACB_S23_1_6 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M5_TypeBRS1_CACB_S23_1 = M5_TypeBRS1_CACB_S23_1_7 INTERACT M5_TypeBRS1_CACB_S23_1_6 >= 2
  
  M5_TypeBRS1_CACB_S23_2 = ((EXPAND EDGE (LENGTH ((SIZE M5_TypeBRS1_CACB_S23_1 BY -NANO) AND M5i) == Mx_W) OUTSIDE BY 2*NANO) OR (M5_TypeBRS1_CACB_S23_1 AND M5i)) AND M5_TypeBRS1_CACB_S23_1
  M5_TypeBRS1_CACB_S23_3 = (M5_TypeBRS1_CACB_S23_2 AND M5_TypeBRS1_CACB_S23_1) COIN EDGE M5_TypeBRS1_CACB_S23_1
  M5_TypeBRS1_CACB_S23_4 = M5_TypeBRS1_CACB_S23_1 INTERACT (M5_TypeBRS1_CACB_S23_1 AND M5i) == 2
  M5_TypeBRS1_CACB_S23_5 = M5_TypeBRS1_CACB_S23_4 WITH EDGE M5_TypeBRS1_CACB_S23_3 == 4
  M5_TypeBRS1_CACB_EDGE1 = M5i TOUCH OUTSIDE EDGE M5_TypeBRS1_CACB_S23_5	//CA and CB EDGE
  M5_TypeBRS1_CACB_EDGE2 = EXPAND EDGE M5_TypeBRS1_CACB_EDGE1 OUTSIDE BY GRID			
  M5_TypeBRS1_CACB_EDGE3_1 = EXT M5_TypeBRS1_CACB_EDGE1 M5i == Mx_S OPPOSITE REGION
  M5_TypeBRS1_CACB_EDGE3_2 = EXT M5_TypeBRS1_CACB_EDGE1 M5_TypeBRS1_CACB_S23_2 == Mx_S OPPOSITE REGION
  M5_TypeBRS1_CACB_EDGE4 = M5_TypeBRS1_CACB_EDGE2 NOT M5_TypeBRS1_CACB_EDGE3_1
  M5_TypeBRS1_CACB_EDGE5 = LENGTH M5_TypeBRS1_CACB_EDGE4 == GRID
  M5_TypeBRS1_CACB_EDGE6 = EXPAND EDGE M5_TypeBRS1_CACB_EDGE5 OUTSIDE BY GRID
  M5_TypeBRS1_CACB_EDGE7 = (M5_TypeBRS1_CACB_EDGE6 TOUCH M5_TypeBRS1_CACB_EDGE3_1) OR (M5_TypeBRS1_CACB_EDGE6 TOUCH M5_TypeBRS1_CACB_EDGE3_2)
  
   
  M5_TypeBRS1_CACB_EDGE8_1 = M5_TypeBRS1_CACB_EDGE7 COIN OUTSIDE EDGE M5_TypeBRS1_CACB_EDGE4
  M5_TypeBRS1_CACB_EDGE8 = M5_TypeBRS1_CACB_EDGE8_1 NOT TOUCH EDGE (EXT [M5_TypeBRS1_CACB_EDGE8_1] M5i < TypeBRS1_S4 OPPOSITE)
  
  M5_TypeBRS1_CACB_EDGE9 = EXPAND EDGE M5_TypeBRS1_CACB_EDGE8 OUTSIDE BY TypeBRS1_S4
  M5_TypeBRS1_CACB_EDGE10 = M5_CORNER TOUCH M5_TypeBRS1_CACB_EDGE4
  
  M5_TypeBRS1_CACB_EDGE11_1 = M5_TypeBRS1_CACB_EDGE9 TOUCH OUTSIDE EDGE M5_TypeBRS1_CACB_EDGE10
  M5_TypeBRS1_CACB_EDGE11 = M5_TypeBRS1_CACB_EDGE11_1 NOT TOUCH EDGE (ENC M5i [M5_TypeBRS1_CACB_EDGE11_1] < TypeBRS1_S5 OPPOSITE)
  
  M5_TypeBRS1_CACB_EDGE12 = ENCLOSE RECTANGLE (EXPAND EDGE M5_TypeBRS1_CACB_EDGE11 INSIDE BY TypeBRS1_S5) TypeBRS1_S4 TypeBRS1_S5
  M5_TypeBRS1_CACB_ERROR1 = M5_TypeBRS1_CACB_EDGE12 AND M5i
  M5_TypeBRS1_CACB_ERROR2 = (ENC M5_TypeBRS1_CACB_ERROR1 [M5_TypeBRS1_CACB_EDGE11] <= TypeBRS1_S5 OPPOSITE) OR EDGE (M5_TypeBRS1_CACB_EDGE11 TOUCH EDGE M5_TypeBRS1_CACB_ERROR1)
  M5_TypeBRS1_CACB_ERROR3 = (M5_TypeBRS1_CACB_EDGE11 NOT TOUCH EDGE M5_TypeBRS1_CACB_ERROR2) TOUCH EDGE M5_TypeBRS1_CACB_EDGE12
  M5_TypeBRS1_CACB_ERROR4 = EXPAND EDGE M5_TypeBRS1_CACB_ERROR3 INSIDE BY TypeBRS1_S5
  M5_TypeBRS1_CACB_ERROR5 = ENCLOSE RECTANGLE (M5_TypeBRS1_CACB_ERROR4 NOT ENCLOSE M5_TypeBRS1_CACB_ERROR1) TypeBRS1_S4 TypeBRS1_S5
  M5_TypeBRS1_MARK1 = EXT M5_TypeBRS1_CACB_ERROR5 > 2*Mx_W+2*Mx_S+4*GRID <= TypeBRS1_S2 OPPOSITE REGION
  M5_TypeBRS1_MARK2 = VERTEX (M5_TypeBRS1_MARK1 AND M5i) != 4
  M5_TypeBRS1_MARK3 = M5_TypeBRS1_MARK1 WITH EDGE (M5_TypeBRS1_MARK1 COIN EDGE (M5_TypeBRS1_MARK1 AND M5i)) == 4
  M5_TypeBRS1_MARK4 = M5_TypeBRS1_MARK3 NOT INTERACT M5_TypeBRS1_MARK2
  M5_TypeBRS1_MARK = (EXT (M5_TypeBRS1_MARK4 AND M5i) <= Mx_S OPPOSITE REGION) INSIDE M5_TypeBRS1_CACB_S23_5
  M5_TypeBRS1_MARK INTERACT EFPM5S5_M5i
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPM5S6_
#IFDEF _EFPM5S6_
EFPM5S6_M5iCellIn = INSIDE CELL M5i CellsForRRuleRecommended  
EFPM5S6_M5iCellOut = NOT INSIDE CELL M5i ExclCellsForRRuleRecommended 
EFPM5S6_M5iCell = EFPM5S6_M5iCellIn AND EFPM5S6_M5iCellOut
EFPM5S6_M5iMarker = M5i AND RRuleRecommended
EFPM5S6_M5i = ((EFPM5S6_M5iCell OR EFPM5S6_M5iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M5.S.6 { @ Metal bridge recommendation type-2: Recommended space of 2 Mx lines (polygon1/2) [polygon2 with width = 0.05 um (W) and length (L3) >= 0.3 um, one side of Region B3 fully abutted polygon1] when there is no Mx cut both Region B2 and Region B4, but has other Mx interact both Region B1 and Region B5 Definitions: 1. Region B1 = 0.05 um * 0.08 um, generated from vertex CA. 2. Region B2 = 0.23 um * 0.075 um, generated from Mx (polygon2) side wall with vertex CA. 3. Region B3 = 0.05 um *(L1+L2). L1 = 0.08 um, L2 = 0.12 um 4. Region B4 = 0.05 um * 0.3 um, generated from Mx (polygon2) line-end. 5. Region B5 = S2*S3, generated from vertex CB. 0 um < S2 (polygon3 vertex CB to polygon1) <= 0.055 um, and -0.1 um <= S3 (parallel run length of polygon2 and polygon1) <= -0.03 um >= 0.055 
  M5_L_END_BRS2_metal_pre = M5i WITH EDGE M5_L_END_edge
  M5_L_END_BRS2_metal_enc = M5_L_END_BRS2_metal_pre AND (EXPAND EDGE M5_L_END_edge INSIDE BY TypeBRS2_LL)
  M5_L_END_BRS2_LL = (((EXPAND EDGE M5_L_END_edge INSIDE BY TypeBRS2_LL-GRID) AND M5i) WITH EDGE M5_L_END_edge) INTERACT M5_jog_CORNER_waive
  M5_L_END_BRS2_metal = (ENCLOSE RECTANGLE M5_L_END_BRS2_metal_enc Mx_W TypeBRS2_LL) NOT INTERACT M5_L_END_BRS2_LL
  M5_L_END_BRS2_L_END_edge = M5_L_END_edge COIN EDGE M5_L_END_BRS2_metal
  
  M5_L_END_BRS2_side_edge_pre = INT [M5i] M5_L_END_BRS2_L_END_edge <= TypeBRS2_S5 ABUT == 90 INTERSECTING ONLY
  M5_L_END_BRS2_dense_side_edge_pre = INT [M5i] M5_L_END_BRS2_L_END_edge <= TypeBRS2_LH ABUT == 90 INTERSECTING ONLY
  M5_L_END_BRS2_iso_side_edge_pre = EXT [M5_L_END_BRS2_side_edge_pre] M5i <= TypeBRS2_S4 ABUT < 90 OPPOSITE
  M5_L_END_BRS2_iso_side_edge_pre1 = LENGTH (M5_L_END_BRS2_side_edge_pre NOT COIN EDGE M5_L_END_BRS2_iso_side_edge_pre) >= TypeBRS2_S5
  M5_L_END_BRS2_iso_side_edge_pre2 = (EXPAND EDGE M5_L_END_BRS2_iso_side_edge_pre1 INSIDE BY GRID) WITH EDGE M5_L_END_BRS2_L_END_edge
  M5_L_END_BRS2_iso_side_edge = LENGTH (M5_L_END_BRS2_iso_side_edge_pre1 COIN EDGE M5_L_END_BRS2_iso_side_edge_pre2) >= TypeBRS2_S5
  M5_L_END_BRS2_L_END_edge_waive = EXT [M5_L_END_BRS2_L_END_edge] M5i < TypeBRS2_S2 ABUT < 90 OPPOSITE
  M5_L_END_REGION_BRS2_dense_edge_pre = EXPAND EDGE M5_L_END_BRS2_L_END_edge INSIDE BY TypeBRS2_LH OUTSIDE BY TypeBRS2_LY
  M5_L_END_REGION_BRS2_dense_edge_pre1 = VERTEX (EXT M5_L_END_REGION_BRS2_dense_edge_pre M5i <= Mx_S ABUT < 90 OPPOSITE REGION) == 4
  M5_L_END_REGION_BRS2_dense_edge = LENGTH (M5_L_END_REGION_BRS2_dense_edge_pre COIN EDGE M5_L_END_REGION_BRS2_dense_edge_pre1) >= TypeBRS2_LH+TypeBRS2_LY
  M5_L_END_REGION_BRS2_dense_iso = INT M5_L_END_BRS2_iso_side_edge M5_L_END_REGION_BRS2_dense_edge <= Mx_W ABUT < 90 OPPOSITE REGION
  M5_L_END_BRS2_iso_dense_side_edge_pre = (M5_L_END_REGION_BRS2_dense_edge_pre TOUCH EDGE M5_L_END_BRS2_iso_side_edge) NOT COIN EDGE M5i
  M5_L_END_BRS2_iso_dense_side_edge_pre1 = EXT [M5_L_END_BRS2_iso_dense_side_edge_pre] M5_CORNER <= Mx_S ABUT < 90 OPPOSITE
  M5_L_END_BRS2_iso_dense_side_edge = EXPAND EDGE (M5_L_END_BRS2_iso_dense_side_edge_pre TOUCH EDGE M5_L_END_BRS2_iso_dense_side_edge_pre1) BY GRID EXTEND BY GRID
  M5_L_END_REGION_BRS2_pre1 = EXPAND EDGE M5_L_END_BRS2_L_END_edge INSIDE BY TypeBRS2_LH-TypeBRS2_LY
  M5_L_END_REGION_BRS2_pre2 = ((M5_L_END_REGION_BRS2_pre1 NOT WITH EDGE M5_L_END_BRS2_L_END_edge_waive) INTERACT M5_L_END_REGION_BRS2_dense_iso) INTERACT M5_L_END_BRS2_iso_dense_side_edge
  M5_L_END_REGION_BRS2_pre3 = M5_L_END_edge COIN EDGE M5_L_END_REGION_BRS2_pre2 
  M5_L_END_REGION_BRS2_pre4 = EXPAND EDGE M5_L_END_REGION_BRS2_pre3 INSIDE BY TypeBRS2_LH-TypeBRS2_LY
  M5_L_END_REGION_BRS2_pre5 = EXPAND EDGE (M5_L_END_REGION_BRS2_pre4 COIN EDGE M5_L_END_REGION_BRS2_dense_edge) OUTSIDE BY Mx_S EXTEND BY TypeBRS2_LY
  M5_L_END_REGION_BRS2_pre6 = M5_L_END_REGION_BRS2_pre5 WITH EDGE (LENGTH (M5_L_END_REGION_BRS2_pre5 COIN EDGE M5i) == TypeBRS2_LH+TypeBRS2_LY)
  
  M5_L_END_REGION_BRS2_pre7 = M5_CORNER INTERACT M5_L_END_REGION_BRS2_pre6 
  M5_L_END_REGION_BRS2_pre8 = M5_L_END_REGION_BRS2_pre7 COIN EDGE M5_L_END_REGION_BRS2_pre6
  M5_L_END_REGION_BRS2_pre9 = (EXPAND EDGE M5_L_END_REGION_BRS2_pre8 INSIDE BY GRID EXTEND BY TypeBRS2_LG_max+GRID) TOUCH EDGE M5_L_END_REGION_BRS2_pre6
  M5_L_END_REGION_BRS2_pre10 = M5i COIN EDGE (EXT [M5_CORNER] M5_L_END_REGION_BRS2_pre9 > Mx_W+Mx_S <= Mx_W+Mx_S+TypeBRS2_S3 ABUT < 90 OPPOSITE MEASURE ALL)
  M5_L_END_REGION_BRS2_pre11 = M5_CORNER WITH EDGE M5_L_END_REGION_BRS2_pre10
  M5_L_END_REGION_BRS2_pre12 = EXT [M5_L_END_REGION_BRS2_pre7] M5_L_END_REGION_BRS2_pre11 > TypeBRS2_LGS_min <= TypeBRS2_LGS_max CORNER TO CORNER 
  M5_L_END_REGION_BRS2_MARK = M5_L_END_REGION_BRS2_pre6 WITH EDGE M5_L_END_REGION_BRS2_pre12
  M5_L_END_REGION_BRS2_MARK INTERACT EFPM5S6_M5i
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPM5S7_
#IFDEF _EFPM5S7_
EFPM5S7_M5iCellIn = INSIDE CELL M5i CellsForRRuleRecommended  
EFPM5S7_M5iCellOut = NOT INSIDE CELL M5i ExclCellsForRRuleRecommended 
EFPM5S7_M5iCell = EFPM5S7_M5iCellIn AND EFPM5S7_M5iCellOut
EFPM5S7_M5iMarker = M5i AND RRuleRecommended
EFPM5S7_M5i = ((EFPM5S7_M5iCell OR EFPM5S7_M5iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M5.S.7 { @ Metal bridge recommendation type-3: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3 and Region B4] when neighboring Mx (polygon3/4) with parallel run length > 0 um and there is no other Mx interact Region B1/B2 Definitions: 1. Region B3/B4 = 0.25 um * 0.09 um (L1), generated from vertex CB and CA respectively. 2. L2 = height difference of vertex CA project to vertex CB <= 0.05 um. 3. Region B1/B2 = 0.16 um * 0.115 um, generated from Mx (polygon3/4) line-end with vertex CA and CB respectively >= 0.055 
  M5_TypeBRS3_prefilter_1 = EXT [M5i] == TypeBRS3_S2 ABUT < 90 OPPOSITE
  M5_TypeBRS3_prefilter_2 = M5i TOUCH EDGE M5_TypeBRS3_prefilter_1
  M5_TypeBRS3_prefilter_3 = (M5_CORNER WITH EDGE M5_TypeBRS3_prefilter_2) COIN EDGE M5i
  
  M5_TypeBRS3_prefilter_4_1 = EXT M5_TypeBRS3_prefilter_3 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
  M5_TypeBRS3_prefilter_4_2 = M5i AND M5_TypeBRS3_prefilter_4_1
  M5_TypeBRS3_prefilter_4_3 = EXT [M5_TypeBRS3_prefilter_3] M5_TypeBRS3_prefilter_4_2 <= Mx_S OPPOSITE EXTENDED TypeBRS3_S6
  M5_TypeBRS3_prefilter_4_4 = M5_TypeBRS3_prefilter_3 TOUCH EDGE M5_TypeBRS3_prefilter_4_3 
  M5_TypeBRS3_prefilter_4_5 = EXT [M5_TypeBRS3_prefilter_3] M5_TypeBRS3_prefilter_4_2 > Mx_S+Mx_W <= 2*Mx_S+Mx_W OPPOSITE EXTENDED TypeBRS3_S6
  M5_TypeBRS3_prefilter_4_6 = M5_TypeBRS3_prefilter_4_4 TOUCH EDGE M5_TypeBRS3_prefilter_4_5
  M5_TypeBRS3_prefilter_4 =  EXT M5_TypeBRS3_prefilter_4_6 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
  M5_TypeBRS3_prefilter_5_1 = EXPAND EDGE (M5_TypeBRS3_prefilter_3 COIN EDGE M5_TypeBRS3_prefilter_4) OUTSIDE BY 2*GRID
  M5_TypeBRS3_prefilter_5_2 = INT [M5_TypeBRS3_prefilter_5_1] == GRID OPPOSITE
  M5_TypeBRS3_prefilter_5_3 = EXPAND EDGE M5_TypeBRS3_prefilter_5_2 OUTSIDE BY GRID EXTEND BY GRID
  M5_TypeBRS3_prefilter_5_4 = M5_TypeBRS3_prefilter_5_2 COIN EDGE (M5_TypeBRS3_prefilter_5_3 NOT TOUCH EDGE M5_TypeBRS3_prefilter_3)
  M5_TypeBRS3_prefilter_5_5 = EXPAND EDGE M5_TypeBRS3_prefilter_5_4 OUTSIDE BY GRID
  M5_TypeBRS3_prefilter_5 = M5_TypeBRS3_prefilter_5_1 OR M5_TypeBRS3_prefilter_5_5
  
  M5_TypeBRS3_prefilter_6 = M5_TypeBRS3_prefilter_4 NOT M5_TypeBRS3_prefilter_5
  M5_TypeBRS3_prefilter_7_1 = M5_TypeBRS3_prefilter_6 INTERACT (M5_TypeBRS3_prefilter_6 AND M5i) > 1
  M5_TypeBRS3_prefilter_7 = (M5_TypeBRS3_prefilter_5_1 INTERACT M5_TypeBRS3_prefilter_7_1) OR M5_TypeBRS3_prefilter_7_1
  M5_TypeBRS3_prefilter_8 = EXTENTS M5_TypeBRS3_prefilter_7
  
  M5_TypeBRS3_prefilter_9 = M5_TypeBRS3_prefilter_3 COIN EDGE (M5_CORNER INTERACT M5_TypeBRS3_prefilter_8)
  M5_TypeBRS3_prefilter_10 = EXT M5_TypeBRS3_prefilter_9 M5_TypeBRS3_prefilter_2 == TypeBRS3_S2 OPPOSITE REGION
  M5_TypeBRS3_prefilter_11 = M5_TypeBRS3_prefilter_10 INTERACT (M5_TypeBRS3_prefilter_10 AND M5i) > 1
  M5_TypeBRS3_prefilter_12 = (EXPAND EDGE M5_TypeBRS3_prefilter_3 OUTSIDE BY GRID) NOT INTERACT M5_TypeBRS3_prefilter_11
  M5_TypeBRS3_prefilter_13 = (EXPAND EDGE (M5_TypeBRS3_prefilter_12 NOT COIN EDGE M5i) OUTSIDE BY GRID) OR M5_TypeBRS3_prefilter_12 
  M5_TypeBRS3_prefilter_14 = M5_TypeBRS3_prefilter_11 TOUCH EDGE M5_TypeBRS3_prefilter_13
  M5_TypeBRS3_prefilter_15 = M5_TypeBRS3_prefilter_11 WITH EDGE M5_TypeBRS3_prefilter_14 == 2
  
  M5_TypeBRS3_prefilter_16 = (M5_TypeBRS3_prefilter_11 WITH EDGE (LENGTH (M5_TypeBRS3_prefilter_8 COIN EDGE M5_TypeBRS3_prefilter_11) == TypeBRS3_S2)) NOT M5i
  
  M5_TypeBRS3_CACB_S6_1 = (M5_TypeBRS3_prefilter_8 INTERACT M5_TypeBRS3_prefilter_16 != 6) NOT ENCLOSE M5_TypeBRS3_prefilter_15
  M5_TypeBRS3_CACB_S6_2 = M5_TypeBRS3_CACB_S6_1 WITH WIDTH <= TypeBRS3_S6+GRID
  M5_TypeBRS3_CACB_S6_3 = M5_TypeBRS3_CACB_S6_2 AND M5i
  M5_TypeBRS3_CACB_S6_4 = M5_TypeBRS3_CACB_S6_2 INTERACT M5_TypeBRS3_CACB_S6_3 == 2
  M5_TypeBRS3_CACB_S6_5 = (EXPAND EDGE ((M5_TypeBRS3_CACB_S6_4 AND M5i) COIN EDGE M5i) OUTSIDE BY Mx_S) OR (M5_TypeBRS3_CACB_S6_4 AND M5i)
  M5_TypeBRS3_CACB_S6_6 = M5_TypeBRS3_CACB_S6_4 AND M5_TypeBRS3_CACB_S6_5
  M5_TypeBRS3_CACB_S6_7 = M5_TypeBRS3_CACB_S6_6 WITH EDGE ((M5_TypeBRS3_CACB_S6_6 AND M5i) COIN EDGE M5_TypeBRS3_CACB_S6_6) == 4
  
  M5_TypeBRS3_CACB_S3_1 = LENGTH M5_TypeBRS3_CACB_S6_7 == TypeBRS3_S2
  M5_TypeBRS3_CACB_S3_2 = M5i COIN EDGE M5_TypeBRS3_CACB_S6_7
  M5_TypeBRS3_CACB_S3_3 = LENGTH M5_TypeBRS3_CACB_S3_2 == GRID
  M5_TypeBRS3_CACB_S3_4 = (((M5_CORNER COIN EDGE M5i) NOT COIN EDGE M5_TypeBRS3_CACB_S3_3) NOT COIN EDGE M5_TypeBRS3_CACB_S3_1 ) TOUCH EDGE M5_TypeBRS3_CACB_S6_7
  M5_TypeBRS3_CACB_S3_5 = EXPAND EDGE M5_TypeBRS3_CACB_S3_3 OUTSIDE BY GRID EXTEND BY GRID
  M5_TypeBRS3_CACB_S3_6 = EXPAND EDGE M5_TypeBRS3_CACB_S3_4 OUTSIDE BY GRID EXTEND BY GRID
  
  M5_TypeBRS3_CACB_S3_7 = (((M5_CORNER INTERACT M5_TypeBRS3_CACB_S6_7) NOT INSIDE M5_TypeBRS3_CACB_S6_7) COIN EDGE M5i) NOT COIN EDGE M5_TypeBRS3_CACB_S6_7
  M5_TypeBRS3_CACB_S3_8 = EXPAND EDGE M5_TypeBRS3_CACB_S3_7 OUTSIDE BY GRID EXTEND BY GRID
  M5_TypeBRS3_CACB_S3_9 = M5_TypeBRS3_CACB_S3_1 TOUCH EDGE M5_TypeBRS3_CACB_S3_8
  M5_TypeBRS3_CACB_S3_10 = M5_TypeBRS3_CACB_S3_1 NOT TOUCH EDGE M5_TypeBRS3_CACB_S3_8
  M5_TypeBRS3_CACB_S3_11_1 = EXPAND EDGE M5_TypeBRS3_CACB_S3_9 OUTSIDE BY TypeBRS3_S3
  M5_TypeBRS3_CACB_S3_12_1 = EXPAND EDGE M5_TypeBRS3_CACB_S3_10 OUTSIDE BY TypeBRS3_S3-GRID
  M5_TypeBRS3_CACB_S3_11 = M5_TypeBRS3_CACB_S3_11_1 WITH EDGE ((M5_TypeBRS3_CACB_S3_11_1 AND M5) COIN EDGE M5_TypeBRS3_CACB_S3_11_1) >= 4
  M5_TypeBRS3_CACB_S3_12  = M5_TypeBRS3_CACB_S3_12_1 WITH EDGE ((M5_TypeBRS3_CACB_S3_12_1 AND M5) COIN EDGE M5_TypeBRS3_CACB_S3_12_1) >= 4
  M5_TypeBRS3_CACB_S3_13 = M5_TypeBRS3_CACB_S6_7 OR (M5_TypeBRS3_CACB_S3_11 OR M5_TypeBRS3_CACB_S3_12)
  M5_TypeBRS3_CACB_S3_14 = (M5_TypeBRS3_CACB_S3_13 AND M5i) COIN EDGE M5_TypeBRS3_CACB_S3_13
  M5_TypeBRS3_CACB_S3_15 = ENCLOSE RECTANGLE (M5_TypeBRS3_CACB_S3_13 WITH EDGE M5_TypeBRS3_CACB_S3_14 >= 4) TypeBRS3_S2 2*TypeBRS3_S3
  
  M5_TypeBRS3_CACB_S45_1 = EXPAND EDGE M5_TypeBRS3_CACB_S3_7 OUTSIDE BY 2*GRID 
  M5_TypeBRS3_CACB_S45_2 = M5_TypeBRS3_CACB_S3_15 COIN EDGE M5_TypeBRS3_CACB_S45_1 
  M5_TypeBRS3_CACB_S45_3 = EXT [M5_TypeBRS3_CACB_S3_7] M5i < TypeBRS3_S5 OPPOSITE EXTENDED GRID
  M5_TypeBRS3_CACB_S45_4 = EXT [M5_TypeBRS3_CACB_S45_2] M5i < TypeBRS3_S4 OPPOSITE
  M5_TypeBRS3_CACB_S45_5 = (EXPAND EDGE (M5_TypeBRS3_CACB_S45_1 COIN EDGE M5_TypeBRS3_CACB_S3_15) INSIDE BY 2*GRID) OR M5_TypeBRS3_CACB_S45_1
  M5_TypeBRS3_CACB_S45_6 = (M5_TypeBRS3_CACB_S45_5 NOT COIN EDGE M5i) NOT COIN EDGE M5_TypeBRS3_CACB_S3_15
  M5_TypeBRS3_CACB_S45_7 = ENC M5i [M5_TypeBRS3_CACB_S45_6] == 2*GRID OPPOSITE
  M5_TypeBRS3_CACB_S45_8 = (EXPAND EDGE M5_TypeBRS3_CACB_S45_7 OUTSIDE BY TypeBRS3_S5-2*GRID) OR M5_TypeBRS3_CACB_S45_5 
  M5_TypeBRS3_CACB_S45_9 = LENGTH M5_TypeBRS3_CACB_S45_8  >= TypeBRS3_S5 <= 2*TypeBRS3_S5
  M5_TypeBRS3_CACB_S45_10_1 = M5_TypeBRS3_CACB_S45_9 TOUCH EDGE M5_TypeBRS3_CACB_S3_15
  M5_TypeBRS3_CACB_S45_10_2 = ENC M5i [M5_TypeBRS3_CACB_S45_10_1] < TypeBRS3_S4 OPPOSITE
  M5_TypeBRS3_CACB_S45_10_3 = M5_TypeBRS3_CACB_S45_10_1 TOUCH EDGE M5_TypeBRS3_CACB_S45_10_2 
  M5_TypeBRS3_CACB_S45_10 = M5_TypeBRS3_CACB_S45_10_1 NOT TOUCH EDGE M5_TypeBRS3_CACB_S45_10_2 
  M5_TypeBRS3_CACB_S45_11 = EXPAND EDGE M5_TypeBRS3_CACB_S45_10 INSIDE BY TypeBRS3_S4
  M5_TypeBRS3_CACB_S45_12 = M5_TypeBRS3_CACB_S45_11 INTERACT (M5_TypeBRS3_CACB_S45_11 AND M5i)
  M5_TypeBRS3_CACB_BOXB_waive = (((M5_TypeBRS3_CACB_S45_5 WITH EDGE M5_TypeBRS3_CACB_S45_3) OR (M5_TypeBRS3_CACB_S45_5 WITH EDGE M5_TypeBRS3_CACB_S45_4)) OR (M5_TypeBRS3_CACB_S45_5 INTERACT M5_TypeBRS3_CACB_S45_12)) OR (M5_TypeBRS3_CACB_S45_5 WITH EDGE M5_TypeBRS3_CACB_S45_10_3)
  
  M5_TypeBRS3_CACB_BOXAC_1 = (EXPAND EDGE (M5i COIN EDGE M5_TypeBRS3_CACB_BOXB_waive) INSIDE BY 2*GRID) OR M5_TypeBRS3_CACB_BOXB_waive
  M5_TypeBRS3_CACB_BOXAC_2 = M5_TypeBRS3_CACB_S6_7 NOT INTERACT M5_TypeBRS3_CACB_BOXAC_1 
  M5_TypeBRS3_CACB_BOXAC_3 = M5_TypeBRS3_CACB_S3_9 COIN EDGE M5_TypeBRS3_CACB_BOXAC_2
  M5_TypeBRS3_CACB_BOXAC_4 = M5_TypeBRS3_CACB_S3_10 COIN EDGE M5_TypeBRS3_CACB_BOXAC_2
  M5_TypeBRS3_CACB_BOXAC_5_1 = EXPAND EDGE M5_TypeBRS3_CACB_BOXAC_3 OUTSIDE BY TypeBRS3_S3
  M5_TypeBRS3_CACB_BOXAC_5 = M5_TypeBRS3_CACB_BOXAC_5_1 WITH EDGE ((M5_TypeBRS3_CACB_BOXAC_5_1 AND M5i) COIN EDGE M5_TypeBRS3_CACB_BOXAC_5_1) == 4
  M5_TypeBRS3_CACB_BOXAC_6_1 = EXPAND EDGE M5_TypeBRS3_CACB_BOXAC_4 OUTSIDE BY TypeBRS3_S3-GRID
  M5_TypeBRS3_CACB_BOXAC_6 = M5_TypeBRS3_CACB_BOXAC_6_1 WITH EDGE ((M5_TypeBRS3_CACB_BOXAC_6_1 AND M5i) COIN EDGE M5_TypeBRS3_CACB_BOXAC_6_1) == 4
  M5_TypeBRS3_CACB_BOXAC_7 = ((M5_TypeBRS3_CACB_BOXAC_2 INTERACT M5_TypeBRS3_CACB_BOXAC_5) INTERACT M5_TypeBRS3_CACB_BOXAC_6) OR (M5_TypeBRS3_CACB_BOXAC_5 OR M5_TypeBRS3_CACB_BOXAC_6)
  M5_TypeBRS3_CACB_BOXAC_8 = (M5_TypeBRS3_CACB_BOXAC_7 AND M5i) COIN EDGE M5_TypeBRS3_CACB_BOXAC_7
  M5_TypeBRS3_CACB_BOXAC_9 = INT [M5_TypeBRS3_CACB_BOXAC_8] <= 4*TypeBRS3_S3+2*TypeBRS3_S6+2*GRID OPPOSITE
  M5_TypeBRS3_CACB_BOXAC_10 = ENCLOSE RECTANGLE (M5_TypeBRS3_CACB_BOXAC_7 WITH EDGE M5_TypeBRS3_CACB_BOXAC_9  == 4) TypeBRS3_S2 2*TypeBRS3_S3
  M5_TypeBRS3_CACB_BOXAC_11 = VERTEX (M5_TypeBRS3_CACB_BOXAC_10 AND M5i) != 4
  M5_TypeBRS3_CACB_BOXAC_12 = M5_TypeBRS3_CACB_BOXAC_10 NOT INTERACT M5_TypeBRS3_CACB_BOXAC_11
  M5_TypeBRS3_CACB_BOXC = M5_TypeBRS3_CACB_BOXAC_2 INSIDE M5_TypeBRS3_CACB_BOXAC_12
  M5_TypeBRS3_CACB_MARK = EXT (M5_TypeBRS3_CACB_BOXC AND M5i) <= Mx_S OPPOSITE REGION
  M5_TypeBRS3_CACB_MARK INTERACT EFPM5S7_M5i
}
#ENDIF
#ENDIF
#IFDEF CHECK_EFPM5EN1_
#IFDEF _EFPM5EN1_
EFPM5EN1_M5iCellIn = INSIDE CELL M5i CellsForRRuleRecommended  
EFPM5EN1_M5iCellOut = NOT INSIDE CELL M5i ExclCellsForRRuleRecommended 
EFPM5EN1_M5iCell = EFPM5EN1_M5iCellIn AND EFPM5EN1_M5iCellOut
EFPM5EN1_M5iMarker = M5i AND RRuleRecommended
EFPM5EN1_M5i = ((EFPM5EN1_M5iCell OR EFPM5EN1_M5iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M5.EN.1 { @ Mx/VIAx-1 recommendation: Recommended Mx_A enclosure VIAx-1 [in {VIAx-1 AND Mx_A} space to Mx (SP3+SE) <= 0.06 um side] Definition of Mx_A: Mx with consecutive edge length (L1) <= 0.12 um, (L2) <= 0.06 um, (L3) >= 0.1 um, L1/L3 edge is between 2 outer vertex. L1/L3 space to adjacent Mx (SP3/SP4) = 0.05 um [parallel run length > 0 from VIAx-1] >= 0.01 
   L1_pre = CONVEX EDGE EFPM5EN1_M5i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L2 LENGTH2>=EFP_Mx_EN_1_L3 WITH LENGTH<=EFP_Mx_EN_1_L1
   L2_pre = CONVEX EDGE EFPM5EN1_M5i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH<=EFP_Mx_EN_1_L2
   L3_pre = CONVEX EDGE EFPM5EN1_M5i ANGLE1==90 ANGLE2>=90 <=270 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH>=EFP_Mx_EN_1_L3
   L1_L2_V = INT L1_pre L2_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1_L3_V = INT L1_pre L3_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1 = (L1_pre TOUCH INSIDE EDGE L1_L2_V) TOUCH INSIDE EDGE L1_L3_V
   L3 = L3_pre TOUCH INSIDE EDGE (L1_L3_V WITH EDGE L1)
   L1_DENSE = EXT [L1] M5 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA4_L1_DENSE = VIA4i TOUCH INSIDE EDGE (ENC [VIA4i] L1_DENSE < EFP_Mx_EN_1_SE ABUT<90 OPPOSITE)
   L3_DENSE = EXT [L3] M5 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA4_L3_DENSE = VIA4i TOUCH INSIDE EDGE (ENC [VIA4i] L3_DENSE <= EFP_Mx_EN_1_L1-VIA4_W_1-VIA4_EN_2 ABUT<90 OPPOSITE)
   X = INT VIA4_L1_DENSE VIA4_L3_DENSE <= GRID ABUT==90 INTERSECTING ONLY REGION
   VIA4i INTERACT X  
}
// EFP.Mx.EN.1.R is checked by RR:RE:EFP.M5.EN.1
#ENDIF
#ENDIF
// EFP.Mx.S.5.R is checked by RR:RE:EFP.M5.S.5
