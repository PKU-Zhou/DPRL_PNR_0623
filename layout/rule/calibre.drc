  M1_TypeBRS3_CACB_S45_11 = EXPAND EDGE M1_TypeBRS3_CACB_S45_10 INSIDE BY TypeBRS3_S4
  M1_TypeBRS3_CACB_S45_12 = M1_TypeBRS3_CACB_S45_11 INTERACT (M1_TypeBRS3_CACB_S45_11 AND M1i)
  M1_TypeBRS3_CACB_BOXB_waive = (((M1_TypeBRS3_CACB_S45_5 WITH EDGE M1_TypeBRS3_CACB_S45_3) OR (M1_TypeBRS3_CACB_S45_5 WITH EDGE M1_TypeBRS3_CACB_S45_4)) OR (M1_TypeBRS3_CACB_S45_5 INTERACT M1_TypeBRS3_CACB_S45_12)) OR (M1_TypeBRS3_CACB_S45_5 WITH EDGE M1_TypeBRS3_CACB_S45_10_3)
  
  M1_TypeBRS3_CACB_BOXAC_1 = (EXPAND EDGE (M1i COIN EDGE M1_TypeBRS3_CACB_BOXB_waive) INSIDE BY 2*GRID) OR M1_TypeBRS3_CACB_BOXB_waive
  M1_TypeBRS3_CACB_BOXAC_2 = M1_TypeBRS3_CACB_S6_7 NOT INTERACT M1_TypeBRS3_CACB_BOXAC_1 
  M1_TypeBRS3_CACB_BOXAC_3 = M1_TypeBRS3_CACB_S3_9 COIN EDGE M1_TypeBRS3_CACB_BOXAC_2
  M1_TypeBRS3_CACB_BOXAC_4 = M1_TypeBRS3_CACB_S3_10 COIN EDGE M1_TypeBRS3_CACB_BOXAC_2
  M1_TypeBRS3_CACB_BOXAC_5_1 = EXPAND EDGE M1_TypeBRS3_CACB_BOXAC_3 OUTSIDE BY TypeBRS3_S3
  M1_TypeBRS3_CACB_BOXAC_5 = M1_TypeBRS3_CACB_BOXAC_5_1 WITH EDGE ((M1_TypeBRS3_CACB_BOXAC_5_1 AND M1i) COIN EDGE M1_TypeBRS3_CACB_BOXAC_5_1) == 4
  M1_TypeBRS3_CACB_BOXAC_6_1 = EXPAND EDGE M1_TypeBRS3_CACB_BOXAC_4 OUTSIDE BY TypeBRS3_S3-GRID
  M1_TypeBRS3_CACB_BOXAC_6 = M1_TypeBRS3_CACB_BOXAC_6_1 WITH EDGE ((M1_TypeBRS3_CACB_BOXAC_6_1 AND M1i) COIN EDGE M1_TypeBRS3_CACB_BOXAC_6_1) == 4
  M1_TypeBRS3_CACB_BOXAC_7 = ((M1_TypeBRS3_CACB_BOXAC_2 INTERACT M1_TypeBRS3_CACB_BOXAC_5) INTERACT M1_TypeBRS3_CACB_BOXAC_6) OR (M1_TypeBRS3_CACB_BOXAC_5 OR M1_TypeBRS3_CACB_BOXAC_6)
  M1_TypeBRS3_CACB_BOXAC_8 = (M1_TypeBRS3_CACB_BOXAC_7 AND M1i) COIN EDGE M1_TypeBRS3_CACB_BOXAC_7
  M1_TypeBRS3_CACB_BOXAC_9 = INT [M1_TypeBRS3_CACB_BOXAC_8] <= 4*TypeBRS3_S3+2*TypeBRS3_S6+2*GRID OPPOSITE
  M1_TypeBRS3_CACB_BOXAC_10 = ENCLOSE RECTANGLE (M1_TypeBRS3_CACB_BOXAC_7 WITH EDGE M1_TypeBRS3_CACB_BOXAC_9  == 4) TypeBRS3_S2 2*TypeBRS3_S3
  M1_TypeBRS3_CACB_BOXAC_11 = VERTEX (M1_TypeBRS3_CACB_BOXAC_10 AND M1i) != 4
  M1_TypeBRS3_CACB_BOXAC_12 = M1_TypeBRS3_CACB_BOXAC_10 NOT INTERACT M1_TypeBRS3_CACB_BOXAC_11
  M1_TypeBRS3_CACB_BOXC = M1_TypeBRS3_CACB_BOXAC_2 INSIDE M1_TypeBRS3_CACB_BOXAC_12
  M1_TypeBRS3_CACB_MARK = EXT (M1_TypeBRS3_CACB_BOXC AND M1i) <= Mx_S OPPOSITE REGION
  M1_TypeBRS3_CACB_MARK INTERACT EFPM1S7_M1i
}
#ENDIF
#ENDIF
#IFDEF CHECK_EFPM1S8_
#IFDEF _EFPM1S8_
EFPM1S8_M1CellIn = INSIDE CELL M1i CellsForRRuleRecommended  
EFPM1S8_M1CellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
EFPM1S8_M1Cell = EFPM1S8_M1CellIn AND EFPM1S8_M1CellOut
EFPM1S8_M1Marker = M1i AND RRuleRecommended
EFPM1S8_M1 = ((EFPM1S8_M1Cell OR EFPM1S8_M1Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M1.S.8 { @ CO/M1 recommendation type-4: Recommended the M1 (polygon1) line-end [M1 width (W4) < 0.1 um, enclosure of CO (SE) = 0 um] space to U-shape M1 polygon Definition of of "U-shape M1 polygon": 1. M1 has 2 consecutive 270-270 inner vertexes with M1 width <= 0.06 um (W5) 2. Space to M1 (polygon1) <= 0.06 um (S4) and parallel run length >= 0.1 um (L6) in both 2 opposite sides 3. Any M1 interact with Region B6 (0.06 um*W4 from U-shape M1 edge in M1 (polygon1) line-end direction) >= 0.055 
  LINE_END = CONVEX EDGE M1i ANGLE1==90 ANGLE2==90 WITH LENGTH < EFP_M1_S_8_W4
  U_EDGE   = CONVEX EDGE M1i ANGLE1==270 ANGLE2==270 WITH LENGTH < EFP_M1_S_8_S4*2+EFP_M1_S_8_W4
  LINE_END_CO = LINE_END TOUCH INSIDE EDGE CO
  U_EDGE_a = EXT LINE_END_CO [U_EDGE] < EFP_M1_S_8_SP1 OPPOSITE
  LINE_END_a = EXT [LINE_END_CO] U_EDGE < EFP_M1_S_8_SP1 OPPOSITE
  M1_u = M1i WITH EDGE U_EDGE_a
  M1_e = M1i WITH EDGE LINE_END_a
  M1_s = EXT M1_u M1_e <= EFP_M1_S_8_S4 OPPOSITE REGION
  M1_sa = M1_s NOT WITH EDGE U_EDGE_a
  M1_sb = M1_s WITH EDGE U_EDGE_a
  RUN = ENCLOSE RECTANGLE M1_sa GRID EFP_M1_S_8_L6 ORTHOGONAL ONLY
  M1_SE3 =  M1_sb INTERACT (SIZE RUN BY 0.001) == 2
  U_EDGE_b = U_EDGE TOUCH OUTSIDE EDGE M1_SE3 
  M1_W5 = INT [U_EDGE_b] M1i <= EFP_M1_S_8_W5 OPPOSITE
  U_EDGE_c = (U_EDGE_b TOUCH INSIDE EDGE M1_W5) COIN OUTSIDE EDGE M1_SE3
  U_EDGE_d = (EXPAND EDGE U_EDGE_c INSIDE BY EFP_M1_S_8_W5) AND M1i
  U_EDGE_e = INT U_EDGE_c [U_EDGE_d] <= EFP_M1_S_8_W5 OPPOSITE MEASURE COIN
  U_EDGE_e1 = EXPAND EDGE U_EDGE_e OUTSIDE BY 0.001
  U_EDGE_e2 = EXPAND EDGE U_EDGE_e OUTSIDE BY EFP_M1_S_8_B6
  U_EDGE_f = U_EDGE_e2 INTERACT ((U_EDGE_e2 NOT U_EDGE_e1) INTERACT M1i)
  U_EDGE_g = U_EDGE_d INTERACT U_EDGE_f
  (M1_SE3 INTERACT U_EDGE_g) INTERACT EFPM1S8_M1
}
#ENDIF
#ENDIF
// EFP.Mx.S.5.R is checked by RR:RE:EFP.M1.S.5
// EFP.Mx.S.6.R is checked by RR:RE:EFP.M1.S.6
// EFP.Mx.S.7.R is checked by RR:RE:EFP.M1.S.7

#IFDEF CHECK_EFPM2S2_
#IFDEF _EFPM2S2_
EFPM2S2_M2iCellIn = INSIDE CELL M2i CellsForRRuleRecommended  
EFPM2S2_M2iCellOut = NOT INSIDE CELL M2i ExclCellsForRRuleRecommended 
EFPM2S2_M2iCell = EFPM2S2_M2iCellIn AND EFPM2S2_M2iCellOut
EFPM2S2_M2iMarker = M2i AND RRuleRecommended
EFPM2S2_M2i = ((EFPM2S2_M2iCell OR EFPM2S2_M2iMarker) NOT Block ) NOT excludeRRuleRecommended

// M2 Type Cap
//=============
RR:RE:EFP.M2.S.2 { @ Cap recommendation: Recommended the line-end space at Mx [line width (W2) = 0.05 um, length (L3) >= 0.15 um] in a line-end configuration: If both longer edges of Mx line-end have parallel run length [0.005 um ~ 0.115 um (L2)] to Mx [space to Mx line-end 0.05 um (S1), and both Mxs are part of one polygon] >= 0.115 
  M2_NOTCH_LL = (((EXPAND EDGE M2_L_END_edge INSIDE BY TypeLEH_LL-GRID) AND M2i) WITH EDGE M2_L_END_edge) INTERACT M2_jog_CORNER_waive

  M2_NOTCH_pre = EXT M2i < TypeLEH_NOTCH ABUT < 90 NOTCH OPPOSITE REGION
  M2_NOTCH = (ENCLOSE RECTANGLE M2_NOTCH_pre TypeLEH_NOTCH-3*GRID GRID) INTERACT M2i > 1
  M2_NOTCH_candidate1 = ENCLOSE RECTANGLE (M2i INTERACT M2_NOTCH) TypeLEH_LL Mx_W
  M2_NOTCH_candidate2 = EXT M2_NOTCH_candidate1 <= TypeLEH_S2 ABUT < 90 OPPOSITE REGION
  M2_NOTCH_candidate3 = (M2_L_END_edge TOUCH EDGE M2_NOTCH_candidate2) INSIDE EDGE M2_NOTCH
  M2_NOTCH_candidate4 = EXPAND EDGE M2_NOTCH_candidate3 INSIDE BY GRID
  M2_NOTCH_candidate5 = (VERTEX (SIZE M2_NOTCH_candidate4 BY TypeLEH_marker-GRID INSIDE OF M2_NOTCH_candidate1 STEP Mx_S *0.7) == 4) INTERACT M2_NOTCH
  M2_NOTCH_candidate6 = EXT [M2_NOTCH_candidate5] M2i <= Mx_S+GRID ABUT < 90 OPPOSITE
  M2_NOTCH_candidate7 = INT (M2_NOTCH_candidate5 NOT COIN EDGE M2_NOTCH_candidate6) <= Mx_W ABUT < 90 OPPOSITE REGION
  M2_NOTCH_candidate = (M2_NOTCH_candidate5 INTERACT M2_NOTCH_candidate7) NOT INTERACT M2_NOTCH_LL
  M2_NOTCH_candidate INTERACT EFPM2S2_M2i
}
#ENDIF
#ENDIF
// EFP.Mx.S.2.R is checked by RR:RE:EFP.M2.S.2

#IFDEF CHECK_EFPM2S3_
#IFDEF _EFPM2S3_
EFPM2S3_M2iCellIn = INSIDE CELL M2i CellsForRRuleRecommended  
EFPM2S3_M2iCellOut = NOT INSIDE CELL M2i ExclCellsForRRuleRecommended 
EFPM2S3_M2iCell = EFPM2S3_M2iCellIn AND EFPM2S3_M2iCellOut
EFPM2S3_M2iMarker = M2i AND RRuleRecommended
EFPM2S3_M2i = ((EFPM2S3_M2iCell OR EFPM2S3_M2iMarker) NOT Block ) NOT excludeRRuleRecommended

// M2 Type Hook 
//=============
TypeHook_M2_H2		  = CONVEX EDGE EFPM2S3_M2i ANGLE1==270 ANGLE2==270 WITH LENGTH <= TypeH_LB
TypeHook_M2_H2_corner	  = EXT TypeHook_M2_H2 [M2] < TypeH_LB ABUT==90 
TypeHook_M2_H2_W	  = INT EFPM2S3_M2i (EFPM2S3_M2i TOUCH EDGE TypeHook_M2_H2_corner) <= TypeH_W ABUT<90 REGION
TypeHook_M2_H2_W_out	  = TypeHook_M2_H2_W NOT TOUCH EDGE TypeHook_M2_H2_corner
TypeHook_M2_H2_L_chk	  = TypeHook_M2_H2_corner TOUCH EDGE TypeHook_M2_H2_W 
TypeHook_M2_H2_OC_pre1	  = (CONVEX EDGE EFPM2S3_M2i ANGLE1==270 ANGLE2==90 ) TOUCH EDGE TypeHook_M2_H2_L_chk
TypeHook_M2_H2_OC_pre2	  = EXT [TypeHook_M2_H2_OC_pre1] TypeHook_M2_H2 <= TypeH_LB ABUT==90 
TypeHook_M2_H2_OC	  = TypeHook_M2_H2_OC_pre2 NOT COIN EDGE (INT EFPM2S3_M2i TypeHook_M2_H2_OC_pre2 < DB_GRID ABUT ==90 REGION)
TypeHook_M2_H2_OC_chk	  = EXT [TypeHook_M2_H2_L_chk] TypeHook_M2_H2_OC < TypeH_S2 ABUT<90 OPPOSITE
TypeHook_M2_H2_IC_OClng  = TypeHook_M2_H2 NOT TOUCH EDGE (TypeHook_M2_H2 NOT COIN EDGE TypeHook_M2_H2_OC_chk)
TypeHook_M2_H2_corner_L  = EXT TypeHook_M2_H2_L_chk [TypeHook_M2_H2] < DB_GRID ABUT==90
TypeHook_M2_H2_corner_IC = EXT [TypeHook_M2_H2] <DB_GRID ABUT==90 
TypeHook_M2_H2_corner_IC_OClng = EXT [TypeHook_M2_H2] TypeHook_M2_H2_IC_OClng <DB_GRID ABUT==90 
TypeHook_M2_H2_short	  = LENGTH TypeHook_M2_H2 < TypeH_S2
TypeHook_M2_H2_corner_err = DFM PROPERTY TypeHook_M2_H2 TypeHook_M2_H2_corner_L TypeHook_M2_H2_corner_IC TypeHook_M2_H2_corner_IC_OClng TypeHook_M2_H2_short OVERLAP ABUT ALSO MULTI
				    [ -= COUNT(TypeHook_M2_H2_short)] >0
				    [ -= COUNT(TypeHook_M2_H2_corner_IC)] >0
				    [ -= COUNT(TypeHook_M2_H2_corner_IC_OClng)] >0
				    [ -= COUNT(TypeHook_M2_H2_corner_L)] >1
TypeHook_M2_H2_err	  = (EXPAND EDGE (TypeHook_M2_H2 TOUCH EDGE TypeHook_M2_H2_corner_err) BY 0.001) NOT INSIDE SRAMDMY
TypeHook_M2		  = TypeHook_M2_H2_err NOT INSIDE SRAMDMY
RR:RE:EFP.M2.S.3 { @ Hook recommendation: Recommended space from the edge [length <= 0.065 um (L4) between the edges of line width <= 0.055 um (W3 and W3') and either one of the edges >= 0.15 um (L5)] of Mx pattern [with 3 consecutive 270-270-270 degree inner angles] to opposite edge of the same Mx >= 0.155 
   COPY TypeHook_M2 
}
#ENDIF
#ENDIF
// EFP.Mx.S.3.R is checked by RR:RE:EFP.M2.S.3

#IFDEF CHECK_EFPM2S5_
#IFDEF _EFPM2S5_
EFPM2S5_M2iCellIn = INSIDE CELL M2i CellsForRRuleRecommended  
EFPM2S5_M2iCellOut = NOT INSIDE CELL M2i ExclCellsForRRuleRecommended 
EFPM2S5_M2iCell = EFPM2S5_M2iCellIn AND EFPM2S5_M2iCellOut
EFPM2S5_M2iMarker = M2i AND RRuleRecommended
EFPM2S5_M2i = ((EFPM2S5_M2iCell OR EFPM2S5_M2iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M2.S.5 { @ Metal bridge recommendation type-1: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3] when there is no other Mx cut Region B1/B2 Definitions: 1. Region B3 = 0.25 um * S2, generated from vertex CA/CB. 2. S2 = 2 Mx (polygon3/4) with parallel run length 0 um > S2 >= 0.235 um 3. Region B1/B2 = 0.16 um * 0.23 um, generated from Mx (polygon3/4) metal line-end with vertex CA/CB respectively >= 0.055 
  M2_TypeBRS1_prefilter_1 = EXT [M2i] == TypeBRS1_S2 ABUT < 90 OPPOSITE EXTENDED TypeBRS1_S3+NANO
  M2_TypeBRS1_CORNER_pre_1_1 = M2_CORNER_S1 WITH EDGE M2_TypeBRS1_prefilter_1
  M2_TypeBRS1_CORNER_pre_1_2 = EXT [M2_L_END_edge] M2i < TypeBRS1_S5 OPPOSITE
  M2_TypeBRS1_CORNER_pre_1 = M2_TypeBRS1_CORNER_pre_1_1 NOT WITH EDGE M2_TypeBRS1_CORNER_pre_1_2
  M2_TypeBRS1_CORNER_pre_2 = EXT M2_TypeBRS1_CORNER_pre_1 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION
  M2_TypeBRS1_CORNER_pre_3 = M2_TypeBRS1_CORNER_pre_2 INTERACT (M2_TypeBRS1_CORNER_pre_2 AND M2i) > 1
  M2_TypeBRS1_CORNER_pre_4 = M2_TypeBRS1_CORNER_pre_1 INTERACT M2_TypeBRS1_CORNER_pre_3
  
  M2_TypeBRS1_CACB_S23 = EXT M2_TypeBRS1_CORNER_pre_4 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M2_TypeBRS1_CACB_S23_1_1 = M2_TypeBRS1_CACB_S23 INTERACT M2_CORNER_S1 >= 2
  
  M2_TypeBRS1_CACB_S23_1_2 = INT (M2i AND M2_TypeBRS1_CACB_S23_1_1) == Mx_W OPPOSITE REGION
  M2_TypeBRS1_CACB_S23_1_3 = EXPAND EDGE (M2i COIN INSIDE EDGE M2_TypeBRS1_CACB_S23_1_2) OUTSIDE BY Mx_S
  M2_TypeBRS1_CACB_S23_1_4 = M2_TypeBRS1_CACB_S23_1_2 OR M2_TypeBRS1_CACB_S23_1_3
  M2_TypeBRS1_CACB_S23_1_5 = (EXT (M2_TypeBRS1_CORNER_pre_4 INTERACT M2_TypeBRS1_CACB_S23_1_1) >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION) AND M2_TypeBRS1_CACB_S23_1_4
  M2_TypeBRS1_CACB_S23_1_6 = (M2_TypeBRS1_CORNER_pre_4 INTERACT M2_TypeBRS1_CACB_S23_1_1) INTERACT (SIZE M2_TypeBRS1_CACB_S23_1_5 BY GRID)
  M2_TypeBRS1_CACB_S23_1_7 = EXT M2_TypeBRS1_CACB_S23_1_6 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M2_TypeBRS1_CACB_S23_1 = M2_TypeBRS1_CACB_S23_1_7 INTERACT M2_TypeBRS1_CACB_S23_1_6 >= 2
  
  M2_TypeBRS1_CACB_S23_2 = ((EXPAND EDGE (LENGTH ((SIZE M2_TypeBRS1_CACB_S23_1 BY -NANO) AND M2i) == Mx_W) OUTSIDE BY 2*NANO) OR (M2_TypeBRS1_CACB_S23_1 AND M2i)) AND M2_TypeBRS1_CACB_S23_1
  M2_TypeBRS1_CACB_S23_3 = (M2_TypeBRS1_CACB_S23_2 AND M2_TypeBRS1_CACB_S23_1) COIN EDGE M2_TypeBRS1_CACB_S23_1
  M2_TypeBRS1_CACB_S23_4 = M2_TypeBRS1_CACB_S23_1 INTERACT (M2_TypeBRS1_CACB_S23_1 AND M2i) == 2
  M2_TypeBRS1_CACB_S23_5 = M2_TypeBRS1_CACB_S23_4 WITH EDGE M2_TypeBRS1_CACB_S23_3 == 4
  M2_TypeBRS1_CACB_EDGE1 = M2i TOUCH OUTSIDE EDGE M2_TypeBRS1_CACB_S23_5	//CA and CB EDGE
  M2_TypeBRS1_CACB_EDGE2 = EXPAND EDGE M2_TypeBRS1_CACB_EDGE1 OUTSIDE BY GRID			
  M2_TypeBRS1_CACB_EDGE3_1 = EXT M2_TypeBRS1_CACB_EDGE1 M2i == Mx_S OPPOSITE REGION
  M2_TypeBRS1_CACB_EDGE3_2 = EXT M2_TypeBRS1_CACB_EDGE1 M2_TypeBRS1_CACB_S23_2 == Mx_S OPPOSITE REGION
  M2_TypeBRS1_CACB_EDGE4 = M2_TypeBRS1_CACB_EDGE2 NOT M2_TypeBRS1_CACB_EDGE3_1
  M2_TypeBRS1_CACB_EDGE5 = LENGTH M2_TypeBRS1_CACB_EDGE4 == GRID
  M2_TypeBRS1_CACB_EDGE6 = EXPAND EDGE M2_TypeBRS1_CACB_EDGE5 OUTSIDE BY GRID
  M2_TypeBRS1_CACB_EDGE7 = (M2_TypeBRS1_CACB_EDGE6 TOUCH M2_TypeBRS1_CACB_EDGE3_1) OR (M2_TypeBRS1_CACB_EDGE6 TOUCH M2_TypeBRS1_CACB_EDGE3_2)
  
   
  M2_TypeBRS1_CACB_EDGE8_1 = M2_TypeBRS1_CACB_EDGE7 COIN OUTSIDE EDGE M2_TypeBRS1_CACB_EDGE4
  M2_TypeBRS1_CACB_EDGE8 = M2_TypeBRS1_CACB_EDGE8_1 NOT TOUCH EDGE (EXT [M2_TypeBRS1_CACB_EDGE8_1] M2i < TypeBRS1_S4 OPPOSITE)
  
  M2_TypeBRS1_CACB_EDGE9 = EXPAND EDGE M2_TypeBRS1_CACB_EDGE8 OUTSIDE BY TypeBRS1_S4
  M2_TypeBRS1_CACB_EDGE10 = M2_CORNER TOUCH M2_TypeBRS1_CACB_EDGE4
  
  M2_TypeBRS1_CACB_EDGE11_1 = M2_TypeBRS1_CACB_EDGE9 TOUCH OUTSIDE EDGE M2_TypeBRS1_CACB_EDGE10
  M2_TypeBRS1_CACB_EDGE11 = M2_TypeBRS1_CACB_EDGE11_1 NOT TOUCH EDGE (ENC M2i [M2_TypeBRS1_CACB_EDGE11_1] < TypeBRS1_S5 OPPOSITE)
  
  M2_TypeBRS1_CACB_EDGE12 = ENCLOSE RECTANGLE (EXPAND EDGE M2_TypeBRS1_CACB_EDGE11 INSIDE BY TypeBRS1_S5) TypeBRS1_S4 TypeBRS1_S5
  M2_TypeBRS1_CACB_ERROR1 = M2_TypeBRS1_CACB_EDGE12 AND M2i
  M2_TypeBRS1_CACB_ERROR2 = (ENC M2_TypeBRS1_CACB_ERROR1 [M2_TypeBRS1_CACB_EDGE11] <= TypeBRS1_S5 OPPOSITE) OR EDGE (M2_TypeBRS1_CACB_EDGE11 TOUCH EDGE M2_TypeBRS1_CACB_ERROR1)
  M2_TypeBRS1_CACB_ERROR3 = (M2_TypeBRS1_CACB_EDGE11 NOT TOUCH EDGE M2_TypeBRS1_CACB_ERROR2) TOUCH EDGE M2_TypeBRS1_CACB_EDGE12
  M2_TypeBRS1_CACB_ERROR4 = EXPAND EDGE M2_TypeBRS1_CACB_ERROR3 INSIDE BY TypeBRS1_S5
  M2_TypeBRS1_CACB_ERROR5 = ENCLOSE RECTANGLE (M2_TypeBRS1_CACB_ERROR4 NOT ENCLOSE M2_TypeBRS1_CACB_ERROR1) TypeBRS1_S4 TypeBRS1_S5
  M2_TypeBRS1_MARK1 = EXT M2_TypeBRS1_CACB_ERROR5 > 2*Mx_W+2*Mx_S+4*GRID <= TypeBRS1_S2 OPPOSITE REGION
  M2_TypeBRS1_MARK2 = VERTEX (M2_TypeBRS1_MARK1 AND M2i) != 4
  M2_TypeBRS1_MARK3 = M2_TypeBRS1_MARK1 WITH EDGE (M2_TypeBRS1_MARK1 COIN EDGE (M2_TypeBRS1_MARK1 AND M2i)) == 4
  M2_TypeBRS1_MARK4 = M2_TypeBRS1_MARK3 NOT INTERACT M2_TypeBRS1_MARK2
  M2_TypeBRS1_MARK = (EXT (M2_TypeBRS1_MARK4 AND M2i) <= Mx_S OPPOSITE REGION) INSIDE M2_TypeBRS1_CACB_S23_5
  M2_TypeBRS1_MARK INTERACT EFPM2S5_M2i
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPM2S6_
#IFDEF _EFPM2S6_
EFPM2S6_M2iCellIn = INSIDE CELL M2i CellsForRRuleRecommended  
EFPM2S6_M2iCellOut = NOT INSIDE CELL M2i ExclCellsForRRuleRecommended 
EFPM2S6_M2iCell = EFPM2S6_M2iCellIn AND EFPM2S6_M2iCellOut
EFPM2S6_M2iMarker = M2i AND RRuleRecommended
EFPM2S6_M2i = ((EFPM2S6_M2iCell OR EFPM2S6_M2iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M2.S.6 { @ Metal bridge recommendation type-2: Recommended space of 2 Mx lines (polygon1/2) [polygon2 with width = 0.05 um (W) and length (L3) >= 0.3 um, one side of Region B3 fully abutted polygon1] when there is no Mx cut both Region B2 and Region B4, but has other Mx interact both Region B1 and Region B5 Definitions: 1. Region B1 = 0.05 um * 0.08 um, generated from vertex CA. 2. Region B2 = 0.23 um * 0.075 um, generated from Mx (polygon2) side wall with vertex CA. 3. Region B3 = 0.05 um *(L1+L2). L1 = 0.08 um, L2 = 0.12 um 4. Region B4 = 0.05 um * 0.3 um, generated from Mx (polygon2) line-end. 5. Region B5 = S2*S3, generated from vertex CB. 0 um < S2 (polygon3 vertex CB to polygon1) <= 0.055 um, and -0.1 um <= S3 (parallel run length of polygon2 and polygon1) <= -0.03 um >= 0.055 
  M2_L_END_BRS2_metal_pre = M2i WITH EDGE M2_L_END_edge
  M2_L_END_BRS2_metal_enc = M2_L_END_BRS2_metal_pre AND (EXPAND EDGE M2_L_END_edge INSIDE BY TypeBRS2_LL)
  M2_L_END_BRS2_LL = (((EXPAND EDGE M2_L_END_edge INSIDE BY TypeBRS2_LL-GRID) AND M2i) WITH EDGE M2_L_END_edge) INTERACT M2_jog_CORNER_waive
  M2_L_END_BRS2_metal = (ENCLOSE RECTANGLE M2_L_END_BRS2_metal_enc Mx_W TypeBRS2_LL) NOT INTERACT M2_L_END_BRS2_LL
  M2_L_END_BRS2_L_END_edge = M2_L_END_edge COIN EDGE M2_L_END_BRS2_metal
  
  M2_L_END_BRS2_side_edge_pre = INT [M2i] M2_L_END_BRS2_L_END_edge <= TypeBRS2_S5 ABUT == 90 INTERSECTING ONLY
  M2_L_END_BRS2_dense_side_edge_pre = INT [M2i] M2_L_END_BRS2_L_END_edge <= TypeBRS2_LH ABUT == 90 INTERSECTING ONLY
  M2_L_END_BRS2_iso_side_edge_pre = EXT [M2_L_END_BRS2_side_edge_pre] M2i <= TypeBRS2_S4 ABUT < 90 OPPOSITE
  M2_L_END_BRS2_iso_side_edge_pre1 = LENGTH (M2_L_END_BRS2_side_edge_pre NOT COIN EDGE M2_L_END_BRS2_iso_side_edge_pre) >= TypeBRS2_S5
  M2_L_END_BRS2_iso_side_edge_pre2 = (EXPAND EDGE M2_L_END_BRS2_iso_side_edge_pre1 INSIDE BY GRID) WITH EDGE M2_L_END_BRS2_L_END_edge
  M2_L_END_BRS2_iso_side_edge = LENGTH (M2_L_END_BRS2_iso_side_edge_pre1 COIN EDGE M2_L_END_BRS2_iso_side_edge_pre2) >= TypeBRS2_S5
  M2_L_END_BRS2_L_END_edge_waive = EXT [M2_L_END_BRS2_L_END_edge] M2i < TypeBRS2_S2 ABUT < 90 OPPOSITE
  M2_L_END_REGION_BRS2_dense_edge_pre = EXPAND EDGE M2_L_END_BRS2_L_END_edge INSIDE BY TypeBRS2_LH OUTSIDE BY TypeBRS2_LY
  M2_L_END_REGION_BRS2_dense_edge_pre1 = VERTEX (EXT M2_L_END_REGION_BRS2_dense_edge_pre M2i <= Mx_S ABUT < 90 OPPOSITE REGION) == 4
  M2_L_END_REGION_BRS2_dense_edge = LENGTH (M2_L_END_REGION_BRS2_dense_edge_pre COIN EDGE M2_L_END_REGION_BRS2_dense_edge_pre1) >= TypeBRS2_LH+TypeBRS2_LY
  M2_L_END_REGION_BRS2_dense_iso = INT M2_L_END_BRS2_iso_side_edge M2_L_END_REGION_BRS2_dense_edge <= Mx_W ABUT < 90 OPPOSITE REGION
  M2_L_END_BRS2_iso_dense_side_edge_pre = (M2_L_END_REGION_BRS2_dense_edge_pre TOUCH EDGE M2_L_END_BRS2_iso_side_edge) NOT COIN EDGE M2i
  M2_L_END_BRS2_iso_dense_side_edge_pre1 = EXT [M2_L_END_BRS2_iso_dense_side_edge_pre] M2_CORNER <= Mx_S ABUT < 90 OPPOSITE
  M2_L_END_BRS2_iso_dense_side_edge = EXPAND EDGE (M2_L_END_BRS2_iso_dense_side_edge_pre TOUCH EDGE M2_L_END_BRS2_iso_dense_side_edge_pre1) BY GRID EXTEND BY GRID
  M2_L_END_REGION_BRS2_pre1 = EXPAND EDGE M2_L_END_BRS2_L_END_edge INSIDE BY TypeBRS2_LH-TypeBRS2_LY
  M2_L_END_REGION_BRS2_pre2 = ((M2_L_END_REGION_BRS2_pre1 NOT WITH EDGE M2_L_END_BRS2_L_END_edge_waive) INTERACT M2_L_END_REGION_BRS2_dense_iso) INTERACT M2_L_END_BRS2_iso_dense_side_edge
  M2_L_END_REGION_BRS2_pre3 = M2_L_END_edge COIN EDGE M2_L_END_REGION_BRS2_pre2 
  M2_L_END_REGION_BRS2_pre4 = EXPAND EDGE M2_L_END_REGION_BRS2_pre3 INSIDE BY TypeBRS2_LH-TypeBRS2_LY
  M2_L_END_REGION_BRS2_pre5 = EXPAND EDGE (M2_L_END_REGION_BRS2_pre4 COIN EDGE M2_L_END_REGION_BRS2_dense_edge) OUTSIDE BY Mx_S EXTEND BY TypeBRS2_LY
  M2_L_END_REGION_BRS2_pre6 = M2_L_END_REGION_BRS2_pre5 WITH EDGE (LENGTH (M2_L_END_REGION_BRS2_pre5 COIN EDGE M2i) == TypeBRS2_LH+TypeBRS2_LY)
  
  M2_L_END_REGION_BRS2_pre7 = M2_CORNER INTERACT M2_L_END_REGION_BRS2_pre6 
  M2_L_END_REGION_BRS2_pre8 = M2_L_END_REGION_BRS2_pre7 COIN EDGE M2_L_END_REGION_BRS2_pre6
  M2_L_END_REGION_BRS2_pre9 = (EXPAND EDGE M2_L_END_REGION_BRS2_pre8 INSIDE BY GRID EXTEND BY TypeBRS2_LG_max+GRID) TOUCH EDGE M2_L_END_REGION_BRS2_pre6
  M2_L_END_REGION_BRS2_pre10 = M2i COIN EDGE (EXT [M2_CORNER] M2_L_END_REGION_BRS2_pre9 > Mx_W+Mx_S <= Mx_W+Mx_S+TypeBRS2_S3 ABUT < 90 OPPOSITE MEASURE ALL)
  M2_L_END_REGION_BRS2_pre11 = M2_CORNER WITH EDGE M2_L_END_REGION_BRS2_pre10
  M2_L_END_REGION_BRS2_pre12 = EXT [M2_L_END_REGION_BRS2_pre7] M2_L_END_REGION_BRS2_pre11 > TypeBRS2_LGS_min <= TypeBRS2_LGS_max CORNER TO CORNER 
  M2_L_END_REGION_BRS2_MARK = M2_L_END_REGION_BRS2_pre6 WITH EDGE M2_L_END_REGION_BRS2_pre12
  M2_L_END_REGION_BRS2_MARK INTERACT EFPM2S6_M2i
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPM2S7_
#IFDEF _EFPM2S7_
EFPM2S7_M2iCellIn = INSIDE CELL M2i CellsForRRuleRecommended  
EFPM2S7_M2iCellOut = NOT INSIDE CELL M2i ExclCellsForRRuleRecommended 
