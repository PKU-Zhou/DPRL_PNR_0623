#ENDIF // EFP_ONLY

#IFDEF EFP

EFPM1EN_COCellIn = INSIDE CELL COii CellsForRRuleRecommended  
EFPM1EN_COCellOut = NOT INSIDE CELL COii ExclCellsForRRuleRecommended 
EFPM1EN_COCellIn2 = INSIDE CELL CO_VIRT CellsForRRuleRecommended  
EFPM1EN_COCellOut2 = NOT INSIDE CELL CO_VIRT ExclCellsForRRuleRecommended 
EFPM1EN_COCell = (EFPM1EN_COCellIn AND EFPM1EN_COCellOut) OR (EFPM1EN_COCellIn2 AND EFPM1EN_COCellOut2)
EFPM1EN_COMarker1 = COii AND RRuleRecommended
EFPM1EN_COMarker2 = CO_VIRT AND RRuleRecommended
EFPM1EN_COMarker = OR  EFPM1EN_COMarker1 EFPM1EN_COMarker2
EFPM1EN_CO = ((EFPM1EN_COCell OR EFPM1EN_COMarker) NOT Block ) NOT excludeRRuleRecommended


MOSOD                    = OD NOT ((((((BJTDMY OR RHOD) OR RHPO) OR RHDMY1) OR NWDMY) OR INDDMY) OR VAR)
COM1_CO                  = EFPM1EN_CO NOT SEALRING_ALL 

COM1_M1OD                = ((MOSOD NOT POu) AND M1) INTERACT COM1_CO >=2
COM1_M1PO                = (POu AND M1) INTERACT COM1_CO >=2
COM1_SCO                 = (COM1_CO NOT INSIDE SRAMDMY) NOT INTERACT (COM1_M1OD OR COM1_M1PO)

#IFDEF CHECK_EFPM1EN1_
#IFDEF _EFPM1EN1_
COM1_1_M1outexp          = EXPAND EDGE (CONVEX EDGE M1 ANGLE1 ==90 ANGLE2 ==90 WITH LENGTH <= COM1_1_W0) OUTSIDE BY DB_GRID
COM1_1_COen              = EXT [COM1_1_M1outexp] COM1_SCO <= COM1_1_SE ABUT<90 OPPOSITE PARALLEL ONLY
COM1_1_M1W0              = LENGTH (M1 TOUCH EDGE COM1_1_COen) <= COM1_1_W0
COM1_1_M1W0inexp         = EXPAND EDGE COM1_1_M1W0 INSIDE BY DB_GRID
COM1_1_M1L               = LENGTH ((M1 TOUCH EDGE COM1_1_M1W0inexp) NOT TOUCH EDGE COM1_1_M1W0) >= COM1_1_L1 <= COM1_1_L2
COM1_1_M1W0_wL           = COM1_1_M1W0 TOUCH EDGE (COM1_1_M1W0inexp WITH EDGE COM1_1_M1L)
COM1_1_M1W0_S            = EXT [COM1_1_M1W0_wL] M1 <= COM1_1_CMy ABUT<=90 OPPOSITE EXTENDED COM1_1_CMx+DB_GRID
COM1_1_M1W0_Sinexp       = EXPAND EDGE ((COM1_1_M1W0_wL TOUCH EDGE COM1_1_M1W0_S) COIN EDGE COM1_1_COen) INSIDE BY COM1_1_SE+DB_GRID
COM1_1_CO                = (COM1_SCO INTERACT COM1_1_M1W0_Sinexp) NOT INSIDE SRAMDMY
COM1_1_CO_SE_opp         = INT [COM1_1_CO] COM1_1_M1W0_wL <= COM1_1_SE+COM1_1_CO_W OPPOSITE MEASURE ALL
COM1_1_CO_SE             = INT [COM1_1_CO] COM1_1_CO_SE_opp  <= COM1_1_CO_W OPPOSITE 
COM1_1_CO_side           = COM1_1_CO NOT TOUCH EDGE (COM1_1_CO_SE OR EDGE COM1_1_CO_SE_opp)
COM1_1_CO_SB             = EXT [COM1_1_CO_side] M1 <= COM1_1_SB ABUT<90 OPPOSITE EXTENDED COM1_1_SBSC+DB_GRID MEASURE ALL
COM1_1_CO_SC_pre         = COM1_1_CO_side NOT TOUCH EDGE COM1_1_CO_SB
COM1_1_CO_SC_pre2        = EXT [COM1_1_CO_SC_pre] M1 < COM1_1_SC ABUT<90 OPPOSITE EXTENDED COM1_1_SBSC+DB_GRID MEASURE ALL
COM1_1_CO_SC             = COM1_1_CO_SC_pre NOT TOUCH EDGE COM1_1_CO_SC_pre2
COM1_1_CO_COM1_1_1       = (COM1_1_CO WITH EDGE COM1_1_CO_SC) WITH EDGE COM1_1_CO_SB

RR:RE:EFP.M1.EN.1 { @ CO/M1 recommendation type-1: Recommended M1 (MA) enclosure (SE) of CO_A, if either of MA's L1/L2 = 0.02 um ~ 0.08 um Definition of CO_A: Single CO inside M1 (MA) with width (W0) <= 0.1 um. Neighboring M1 (either one M1 polygon or multiple M1 polygons) INTERACT both Region A and B, but NOT INTERACT Region C. Region A: (CMx + W0 + CMx) x CMy Region B: SB x (0.01 um + CO width + 0.01 um) Region C: SC x (0.01 um + CO width + 0.01 um) CMx = 0.06 um, W0 <= 0.1 um, CMy = 0.05 um, SB = 0.07 um, SC = 0.2 um >= 0.005 
  COPY COM1_1_CO_COM1_1_1 
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPM1EN2_
#IFDEF _EFPM1EN2_
COM1_2_M1outexp          = EXPAND EDGE (CONVEX EDGE M1 ANGLE1 ==90 ANGLE2 ==90 WITH LENGTH <= COM1_2_W0) OUTSIDE BY DB_GRID
COM1_2_COen              = EXT [COM1_2_M1outexp] COM1_SCO <= COM1_2_SE ABUT<90 OPPOSITE PARALLEL ONLY
COM1_2_M1W0              = LENGTH (M1 TOUCH EDGE COM1_2_COen) <= COM1_2_W0
COM1_2_M1W0inexp         = EXPAND EDGE COM1_2_M1W0 INSIDE BY DB_GRID
COM1_2_M1L               = LENGTH ((M1 TOUCH EDGE COM1_2_M1W0inexp) NOT TOUCH EDGE COM1_2_M1W0) >= COM1_2_L1 <= COM1_2_L2
COM1_2_M1W0_wL           = COM1_2_M1W0 TOUCH EDGE (COM1_2_M1W0inexp WITH EDGE COM1_2_M1L)
COM1_2_M1W0_S            = EXT [COM1_2_M1W0_wL] M1 <= COM1_2_CMy ABUT<=90 OPPOSITE EXTENDED COM1_2_CMx+DB_GRID
COM1_2_M1W0_Sinexp       = EXPAND EDGE ((COM1_2_M1W0_wL TOUCH EDGE COM1_2_M1W0_S) COIN EDGE COM1_2_COen) INSIDE BY COM1_2_SE+DB_GRID
COM1_2_CO                = (COM1_SCO INTERACT COM1_2_M1W0_Sinexp) NOT INSIDE SRAMDMY
COM1_2_CO_SE_opp         = INT [COM1_2_CO] COM1_2_M1W0_wL <= COM1_2_SE+COM1_2_CO_W OPPOSITE MEASURE ALL
COM1_2_CO_SE             = INT [COM1_2_CO] COM1_2_CO_SE_opp  <= COM1_2_CO_W OPPOSITE 
COM1_2_CO_side           = COM1_2_CO NOT TOUCH EDGE (COM1_2_CO_SE OR EDGE COM1_2_CO_SE_opp)
COM1_2_CO_SB             = EXT [COM1_2_CO_side] M1 <= COM1_2_SB ABUT<90 OPPOSITE EXTENDED COM1_2_SBSC+DB_GRID MEASURE ALL
COM1_2_CO_SC_pre         = COM1_2_CO_side NOT TOUCH EDGE COM1_2_CO_SB
COM1_2_CO_SC_pre2        = EXT [COM1_2_CO_SC_pre] M1 < COM1_2_SC ABUT<90 OPPOSITE EXTENDED COM1_2_SBSC+DB_GRID MEASURE ALL
COM1_2_CO_SC             = COM1_2_CO_SC_pre NOT TOUCH EDGE COM1_2_CO_SC_pre2
COM1_2_CO_COM1_2_1       = (COM1_2_CO WITH EDGE COM1_2_CO_SC) WITH EDGE COM1_2_CO_SB
COM1_2_CO_COM1_2_3       = COM1_2_CO_COM1_2_1 INTERACT (AREA M1 <= COM1_2_AREA)

RR:RE:EFP.M1.EN.2 { @ CO/M1 recommendation type-2: Recommeded M1 (MA) enclosure (SE) of CO_B, if either of MA's L1/L2 = 0.02 um ~ 0.19 um Definition of CO_B: Single CO inside M1 (MA) with width (W0) <= 0.12 um and M1 (MA) area < 0.0147 um2. Neighboring M1 (either one M1 polygon or multiple M1 polygons) INTERACT both Region A and B, but NOT INTERACT Region C. Rregion A: (CMx + W0 + CMx) x CMy Region B: SB x (0.01 um + CO width + 0.01 um) Region C: SC x (0.01 um + CO width + 0.01 um) CMx = 0.06 um, W0 <= 0.12 um, CMy = 0.05 um, SB = 0.085 um, SC = 0.07 um >= 0.005 
  COPY COM1_2_CO_COM1_2_3 
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPM1EN3_
#IFDEF _EFPM1EN3_
COM1_3_CMs_cand1         = LENGTH ( M1 TOUCH EDGE COM1_SCO ) >= COM1_3_L2
COM1_3_CMs_cand2         = EXT [COM1_3_CMs_cand1] M1 <= COM1_3_SB ABUT<90 OPPOSITE
COM1_3_CMs_cand3         = COM1_3_CMs_cand1 TOUCH EDGE COM1_3_CMs_cand2
COM1_3_CO_cand1          = COM1_SCO WITH EDGE COM1_3_CMs_cand3 == 1
COM1_3_M1outexp          = EXPAND EDGE (CONVEX EDGE M1 ANGLE1 ==90 ANGLE2 ==90 WITH LENGTH <= COM1_3_W) OUTSIDE BY DB_GRID
COM1_3_W0_cand1          = EXT COM1_3_CO_cand1 COM1_3_M1outexp >0 <= COM1_3_EN1 OPPOSITE PARALLEL ONLY REGION
COM1_3_W0_cand2          = (M1 TOUCH EDGE COM1_3_W0_cand1) NOT TOUCH EDGE COM1_3_CMs_cand3
COM1_3_CMs_cand4         = INT COM1_3_W0_cand2 [COM1_3_CMs_cand3] <= COM1_3_CMs ABUT==90
COM1_3_CMs_SB            = LENGTH COM1_3_CMs_cand4 >= COM1_3_L2
COM1_3_W0_cand3          = INT COM1_3_CMs_SB [COM1_3_W0_cand2] <= DB_GRID ABUT==90
COM1_3_W0_cand4          = COM1_3_W0_cand2 TOUCH EDGE COM1_3_W0_cand3 
COM1_3_W0_cand5          = EXT [COM1_3_W0_cand4] M1 <= COM1_3_CMy ABUT<=90 OPPOSITE EXTENDED COM1_3_CMx+DB_GRID
COM1_3_W0                = COM1_3_W0_cand4 TOUCH EDGE COM1_3_W0_cand5
COM1_3_L_cand1           = ((CONVEX EDGE M1 ANGLE1 ==90 ANGLE2==90 WITH LENGTH >= COM1_3_Lmin <= COM1_3_Lmax) NOT TOUCH EDGE COM1_3_CMs_SB) NOT TOUCH EDGE COM1_3_W0
COM1_3_L_cand2           = INT COM1_3_W0 [COM1_3_L_cand1] <= DB_GRID ABUT==90
COM1_3_L                 = COM1_3_L_cand1 TOUCH EDGE COM1_3_L_cand2
COM1_3_CMs_SC_cand1      = EXPAND EDGE COM1_3_CMs_SB INSIDE BY COM1_3_CO_W
COM1_3_CMs_SC_cand2      = INT COM1_3_CMs_SB [COM1_3_CMs_SC_cand1] <= COM1_3_CO_W OPPOSITE MEASURE ALL
COM1_3_CMs_SC_cand3      = EXT [COM1_3_CMs_SC_cand2] M1 < COM1_3_SC ABUT<90 OPPOSITE MEASURE ALL
COM1_3_CMs_SC            = COM1_3_CMs_SC_cand2 NOT TOUCH EDGE COM1_3_CMs_SC_cand3
COM1_3_CMs_SC_chk        = COM1_3_CMs_SC_cand1 WITH EDGE COM1_3_CMs_SC
COM1_3_L_chk             = EXPAND EDGE COM1_3_L INSIDE BY COM1_3_W
COM1_3_CO                = (COM1_3_CO_cand1 INTERACT COM1_3_L_chk) INTERACT COM1_3_CMs_SC_chk 

RR:RE:EFP.M1.EN.3 { @ CO/M1 recommendation type-3: Recommeded either M1 (MA in LB edge) enclosure (SE) of CO_C/ M1 (MA in W0 edge) enclosure (EN1), if both of MA's LB >= 0.1 um and MA' LC <= 0.07 um Definition of CO_C: Single CO inside M1 (MA) with width (W0) <= 0.07 um. Neighboring M1 (either one M1 polygon or multiple M1 polygons) INTERACT both Region A and B, but NOT INTERACT Region C. Region A: (CMx + W0 + CMx) x CMy Region B: CMs x SB and will INTERACT LB Region C: CMs x SC and will INTERACT LC CMx = 0.06 um, W0 <= 0.07 um, CMy = 0.05 um, CMs = 0.135 um, SB = 0.05 um, SC = 0.1 um >=/ > 0.005/ 0.02 
  COPY COM1_3_CO
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPVIA1EN1_
#IFDEF _EFPVIA1EN1_
EFPVIA1EN1_VIA1iCellIn1 = INSIDE CELL VIA1ii CellsForRRuleRecommended  
EFPVIA1EN1_VIA1iCellOut1 = NOT INSIDE CELL VIA1ii ExclCellsForRRuleRecommended 
EFPVIA1EN1_VIA1iCellIn2 = INSIDE CELL VIA1_VIRT CellsForRRuleRecommended  
EFPVIA1EN1_VIA1iCellOut2 = NOT INSIDE CELL VIA1_VIRT ExclCellsForRRuleRecommended 
EFPVIA1EN1_VIA1iCell = (EFPVIA1EN1_VIA1iCellIn1 AND EFPVIA1EN1_VIA1iCellOut1) OR (EFPVIA1EN1_VIA1iCellIn2 AND EFPVIA1EN1_VIA1iCellOut2)
EFPVIA1EN1_VIA1iMarker = (VIA1ii OR VIA1_VIRT) AND RRuleRecommended
EFPVIA1EN1_VIA1i = ((EFPVIA1EN1_VIA1iCell OR EFPVIA1EN1_VIA1iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.VIA1.EN.1 { @ M1/VIA1 recommendation type-1: Recommended VIA1_A enclosure by M1_MA. [in M1_MA enclosure of CO (C_SE1) <= 0.01 um side] 1. Definition of M1_MA: M1 area <= 0.01495 um2, enclosure of CO (C_SE1) <= 0.01 um and space to M1 (SP1/ SP2) = 0.05 um [parallel run length > 0 um from VIA1_A] [either one of M1 space to {CO AND M1_MA} <= 0.06 um]. 2. Definition of VIA1_A: V1 stack CO with overlapped area >= 0.0012 um2, enclosure by M1_MA (EN1) <= 0.04 um [adjacent enclosure CO <= 0.01 um side and space to M1 (EN1+SP2) <= 0.09 um] >= 0.01 
   VIA1A = AREA (EFPVIA1EN1_VIA1i AND CO) >= EFP_VIA1_EN_1_VCA
   M1A  = AREA M1 <= EFP_VIA1_EN_1_MA    
   CHECK_VIA1 = (EFPVIA1EN1_VIA1i INTERACT VIA1A) INTERACT M1A
   CHECK_CO = (CO INTERACT VIA1A) INTERACT M1A
   DENSE_M1_EDGE = EXT [M1A] M1 == EFP_VIA1_EN_1_SP ABUT<90 OPPOSITE
   DENSE_M1_EDGE_CO = ENC CHECK_CO [DENSE_M1_EDGE] <=  EFP_VIA1_EN_1_CSE ABUT<90 OPPOSITE
   VIA1_SIDE_EDGE = CHECK_VIA1 TOUCH INSIDE EDGE (ENC [CHECK_VIA1] DENSE_M1_EDGE_CO < EFP_VIA1_EN_1_VSE ABUT<90 OPPOSITE)
   VIA1_END_EDGE = CHECK_VIA1 TOUCH INSIDE EDGE (INT VIA1_SIDE_EDGE [CHECK_VIA1] <= GRID ABUT==90 INTERSECTING ONLY)    
   CHECK_VIA1 WITH EDGE (ENC [VIA1_END_EDGE] DENSE_M1_EDGE <= EFP_VIA1_EN_1_EN1 ABUT<90 OPPOSITE)   
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPVIA1EN2_
#IFDEF _EFPVIA1EN2_
EFPVIA1EN2_VIA1iCellIn1 = INSIDE CELL VIA1ii CellsForRRuleRecommended  
EFPVIA1EN2_VIA1iCellOut1 = NOT INSIDE CELL VIA1ii ExclCellsForRRuleRecommended 
EFPVIA1EN2_VIA1iCellIn2 = INSIDE CELL VIA1_VIRT CellsForRRuleRecommended  
EFPVIA1EN2_VIA1iCellOut2 = NOT INSIDE CELL VIA1_VIRT ExclCellsForRRuleRecommended 
EFPVIA1EN2_VIA1iCell = (EFPVIA1EN2_VIA1iCellIn1 AND EFPVIA1EN2_VIA1iCellOut1) OR (EFPVIA1EN2_VIA1iCellIn2 AND EFPVIA1EN2_VIA1iCellOut2)
EFPVIA1EN2_VIA1iMarker = (VIA1ii OR VIA1_VIRT) AND RRuleRecommended
EFPVIA1EN2_VIA1i = ((EFPVIA1EN2_VIA1iCell OR EFPVIA1EN2_VIA1iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.VIA1.EN.2 { @ M1/VIA1 recommendation type-2: Recommended VIA1_B enclosure by M1_B in side-wall direction. 1. Definition of M1_B: M1 width (W1) <= 0.055 um, length (L1) >= 0.1 um and one side enclosure of CO (C_SE2) = 0 um in sidewall direction. 2. Definition of VIA1_B: VIA1 stack CO with overlapped area >= 0.0016 um2, and M1_B space to M1 (D1) = 0.05 um and space to the other side M1 (D1') >= 0.07 um. [parallel run length > -0.075 um from VIA1_B] >= 0.005 
   VIA1A = AREA (EFPVIA1EN2_VIA1i AND CO) >= EFP_VIA1_EN_2_VCA
   M1A  = ENCLOSE RECTANGLE (INT M1 <= EFP_VIA1_EN_2_W1 OPPOSITE REGION) GRID EFP_VIA1_EN_2_L1 ORTHOGONAL ONLY
   CHECK_VIA1 = (EFPVIA1EN2_VIA1i INTERACT VIA1A) INSIDE M1A
   CHECK_CO = (CO INTERACT VIA1A) INTERACT M1A
   DENSE_VIA1_EDGE = (CHECK_VIA1 TOUCH INSIDE EDGE M1A) TOUCH INSIDE EDGE CO
   DENSE_VIA1_EDGE_M1 = DENSE_VIA1_EDGE TOUCH INSIDE EDGE (EXT [DENSE_VIA1_EDGE] M1 == EFP_VIA1_EN_2_D1 OPPOSITE EXTENDED EFP_VIA1_EN_2_PL)
   ISO_VIA1_EDGE = INT [M1A] DENSE_VIA1_EDGE_M1 <= EFP_VIA1_EN_2_W1 OPPOSITE MEASURE ALL
   ISO_VIA1_EDGEx = (EXPAND EDGE ISO_VIA1_EDGE INSIDE BY GRID EXTEND BY EFP_VIA1_EN_2_PL) TOUCH INSIDE EDGE ISO_VIA1_EDGE 
   ISO_VIA1_EDGE_M1 = EXPAND EDGE (ISO_VIA1_EDGEx TOUCH INSIDE EDGE (EXT (ISO_VIA1_EDGEx) M1 < EFP_VIA1_EN_2_D2 ABUT<90 OPPOSITE MEASURE ALL)) INSIDE BY EFP_VIA1_EN_2_W1-VIA1_W_1
   CHECK_VIA1 INTERACT ISO_VIA1_EDGE_M1
}
#ENDIF
#ENDIF

#IFDEF CHECK_EFPM1S2_
#IFDEF _EFPM1S2_
EFPM1S2_M1iCellIn = INSIDE CELL M1i CellsForRRuleRecommended  
EFPM1S2_M1iCellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
EFPM1S2_M1iCell = EFPM1S2_M1iCellIn AND EFPM1S2_M1iCellOut
EFPM1S2_M1iMarker = M1i AND RRuleRecommended
EFPM1S2_M1i = ((EFPM1S2_M1iCell OR EFPM1S2_M1iMarker) NOT Block ) NOT excludeRRuleRecommended

// M1 Type Cap
//=============
RR:RE:EFP.M1.S.2 { @ Cap recommendation: Recommended the line-end space at Mx [line width (W2) = 0.05 um, length (L3) >= 0.15 um] in a line-end configuration: If both longer edges of Mx line-end have parallel run length [0.005 um ~ 0.115 um (L2)] to Mx [space to Mx line-end 0.05 um (S1), and both Mxs are part of one polygon] >= 0.115 
  M1_NOTCH_LL = (((EXPAND EDGE M1_L_END_edge INSIDE BY TypeLEH_LL-GRID) AND M1i) WITH EDGE M1_L_END_edge) INTERACT M1_jog_CORNER_waive

  M1_NOTCH_pre = EXT M1i < TypeLEH_NOTCH ABUT < 90 NOTCH OPPOSITE REGION
  M1_NOTCH = (ENCLOSE RECTANGLE M1_NOTCH_pre TypeLEH_NOTCH-3*GRID GRID) INTERACT M1i > 1
  M1_NOTCH_candidate1 = ENCLOSE RECTANGLE (M1i INTERACT M1_NOTCH) TypeLEH_LL Mx_W
  M1_NOTCH_candidate2 = EXT M1_NOTCH_candidate1 <= TypeLEH_S2 ABUT < 90 OPPOSITE REGION
  M1_NOTCH_candidate3 = (M1_L_END_edge TOUCH EDGE M1_NOTCH_candidate2) INSIDE EDGE M1_NOTCH
  M1_NOTCH_candidate4 = EXPAND EDGE M1_NOTCH_candidate3 INSIDE BY GRID
  M1_NOTCH_candidate5 = (VERTEX (SIZE M1_NOTCH_candidate4 BY TypeLEH_marker-GRID INSIDE OF M1_NOTCH_candidate1 STEP Mx_S *0.7) == 4) INTERACT M1_NOTCH
  M1_NOTCH_candidate6 = EXT [M1_NOTCH_candidate5] M1i <= Mx_S+GRID ABUT < 90 OPPOSITE
  M1_NOTCH_candidate7 = INT (M1_NOTCH_candidate5 NOT COIN EDGE M1_NOTCH_candidate6) <= Mx_W ABUT < 90 OPPOSITE REGION
  M1_NOTCH_candidate = (M1_NOTCH_candidate5 INTERACT M1_NOTCH_candidate7) NOT INTERACT M1_NOTCH_LL
  M1_NOTCH_candidate INTERACT EFPM1S2_M1i
}
#ENDIF
#ENDIF
// EFP.Mx.S.2.R is checked by RR:RE:EFP.M1.S.2

#IFDEF CHECK_EFPM1S3_
#IFDEF _EFPM1S3_
EFPM1S3_M1iCellIn = INSIDE CELL M1i CellsForRRuleRecommended  
EFPM1S3_M1iCellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
EFPM1S3_M1iCell = EFPM1S3_M1iCellIn AND EFPM1S3_M1iCellOut
EFPM1S3_M1iMarker = M1i AND RRuleRecommended
EFPM1S3_M1i = ((EFPM1S3_M1iCell OR EFPM1S3_M1iMarker) NOT Block ) NOT excludeRRuleRecommended

// M1 Type Hook 
//=============
TypeHook_M1_H2		  = CONVEX EDGE EFPM1S3_M1i ANGLE1==270 ANGLE2==270 WITH LENGTH <= TypeH_LB
TypeHook_M1_H2_corner	  = EXT TypeHook_M1_H2 [M1] < TypeH_LB ABUT==90 
TypeHook_M1_H2_W	  = INT EFPM1S3_M1i (EFPM1S3_M1i TOUCH EDGE TypeHook_M1_H2_corner) <= TypeH_W ABUT<90 REGION
TypeHook_M1_H2_W_out	  = TypeHook_M1_H2_W NOT TOUCH EDGE TypeHook_M1_H2_corner
TypeHook_M1_H2_L_chk	  = TypeHook_M1_H2_corner TOUCH EDGE TypeHook_M1_H2_W 
TypeHook_M1_H2_OC_pre1	  = (CONVEX EDGE EFPM1S3_M1i ANGLE1==270 ANGLE2==90 ) TOUCH EDGE TypeHook_M1_H2_L_chk
TypeHook_M1_H2_OC_pre2	  = EXT [TypeHook_M1_H2_OC_pre1] TypeHook_M1_H2 <= TypeH_LB ABUT==90 
TypeHook_M1_H2_OC	  = TypeHook_M1_H2_OC_pre2 NOT COIN EDGE (INT EFPM1S3_M1i TypeHook_M1_H2_OC_pre2 < DB_GRID ABUT ==90 REGION)
TypeHook_M1_H2_OC_chk	  = EXT [TypeHook_M1_H2_L_chk] TypeHook_M1_H2_OC < TypeH_S2 ABUT<90 OPPOSITE
TypeHook_M1_H2_IC_OClng  = TypeHook_M1_H2 NOT TOUCH EDGE (TypeHook_M1_H2 NOT COIN EDGE TypeHook_M1_H2_OC_chk)
TypeHook_M1_H2_corner_L  = EXT TypeHook_M1_H2_L_chk [TypeHook_M1_H2] < DB_GRID ABUT==90
TypeHook_M1_H2_corner_IC = EXT [TypeHook_M1_H2] <DB_GRID ABUT==90 
TypeHook_M1_H2_corner_IC_OClng = EXT [TypeHook_M1_H2] TypeHook_M1_H2_IC_OClng <DB_GRID ABUT==90 
TypeHook_M1_H2_short	  = LENGTH TypeHook_M1_H2 < TypeH_S2
TypeHook_M1_H2_corner_err = DFM PROPERTY TypeHook_M1_H2 TypeHook_M1_H2_corner_L TypeHook_M1_H2_corner_IC TypeHook_M1_H2_corner_IC_OClng TypeHook_M1_H2_short OVERLAP ABUT ALSO MULTI
				    [ -= COUNT(TypeHook_M1_H2_short)] >0
				    [ -= COUNT(TypeHook_M1_H2_corner_IC)] >0
				    [ -= COUNT(TypeHook_M1_H2_corner_IC_OClng)] >0
				    [ -= COUNT(TypeHook_M1_H2_corner_L)] >1
TypeHook_M1_H2_err	  = (EXPAND EDGE (TypeHook_M1_H2 TOUCH EDGE TypeHook_M1_H2_corner_err) BY 0.001) NOT INSIDE SRAMDMY
TypeHook_M1		  = TypeHook_M1_H2_err NOT INSIDE SRAMDMY
RR:RE:EFP.M1.S.3 { @ Hook recommendation: Recommended space from the edge [length <= 0.065 um (L4) between the edges of line width <= 0.055 um (W3 and W3') and either one of the edges >= 0.15 um (L5)] of Mx pattern [with 3 consecutive 270-270-270 degree inner angles] to opposite edge of the same Mx >= 0.155 
   COPY TypeHook_M1 
}
#ENDIF
#ENDIF
// EFP.Mx.S.3.R is checked by RR:RE:EFP.M1.S.3

#IFDEF CHECK_EFPM1S5_
#IFDEF _EFPM1S5_
EFPM1S5_M1iCellIn = INSIDE CELL M1i CellsForRRuleRecommended  
EFPM1S5_M1iCellOut = NOT INSIDE CELL M1i ExclCellsForRRuleRecommended 
EFPM1S5_M1iCell = EFPM1S5_M1iCellIn AND EFPM1S5_M1iCellOut
EFPM1S5_M1iMarker = M1i AND RRuleRecommended
EFPM1S5_M1i = ((EFPM1S5_M1iCell OR EFPM1S5_M1iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M1.S.5 { @ Metal bridge recommendation type-1: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3] when there is no other Mx cut Region B1/B2 Definitions: 1. Region B3 = 0.25 um * S2, generated from vertex CA/CB. 2. S2 = 2 Mx (polygon3/4) with parallel run length 0 um > S2 >= 0.235 um 3. Region B1/B2 = 0.16 um * 0.23 um, generated from Mx (polygon3/4) metal line-end with vertex CA/CB respectively >= 0.055 
  M1_TypeBRS1_prefilter_1 = EXT [M1i] == TypeBRS1_S2 ABUT < 90 OPPOSITE EXTENDED TypeBRS1_S3+NANO
  M1_TypeBRS1_CORNER_pre_1_1 = M1_CORNER_S1 WITH EDGE M1_TypeBRS1_prefilter_1
  M1_TypeBRS1_CORNER_pre_1_2 = EXT [M1_L_END_edge] M1i < TypeBRS1_S5 OPPOSITE
  M1_TypeBRS1_CORNER_pre_1 = M1_TypeBRS1_CORNER_pre_1_1 NOT WITH EDGE M1_TypeBRS1_CORNER_pre_1_2
  M1_TypeBRS1_CORNER_pre_2 = EXT M1_TypeBRS1_CORNER_pre_1 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION
  M1_TypeBRS1_CORNER_pre_3 = M1_TypeBRS1_CORNER_pre_2 INTERACT (M1_TypeBRS1_CORNER_pre_2 AND M1i) > 1
  M1_TypeBRS1_CORNER_pre_4 = M1_TypeBRS1_CORNER_pre_1 INTERACT M1_TypeBRS1_CORNER_pre_3
  
  M1_TypeBRS1_CACB_S23 = EXT M1_TypeBRS1_CORNER_pre_4 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M1_TypeBRS1_CACB_S23_1_1 = M1_TypeBRS1_CACB_S23 INTERACT M1_CORNER_S1 >= 2
  
  M1_TypeBRS1_CACB_S23_1_2 = INT (M1i AND M1_TypeBRS1_CACB_S23_1_1) == Mx_W OPPOSITE REGION
  M1_TypeBRS1_CACB_S23_1_3 = EXPAND EDGE (M1i COIN INSIDE EDGE M1_TypeBRS1_CACB_S23_1_2) OUTSIDE BY Mx_S
  M1_TypeBRS1_CACB_S23_1_4 = M1_TypeBRS1_CACB_S23_1_2 OR M1_TypeBRS1_CACB_S23_1_3
  M1_TypeBRS1_CACB_S23_1_5 = (EXT (M1_TypeBRS1_CORNER_pre_4 INTERACT M1_TypeBRS1_CACB_S23_1_1) >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION) AND M1_TypeBRS1_CACB_S23_1_4
  M1_TypeBRS1_CACB_S23_1_6 = (M1_TypeBRS1_CORNER_pre_4 INTERACT M1_TypeBRS1_CACB_S23_1_1) INTERACT (SIZE M1_TypeBRS1_CACB_S23_1_5 BY GRID)
  M1_TypeBRS1_CACB_S23_1_7 = EXT M1_TypeBRS1_CACB_S23_1_6 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M1_TypeBRS1_CACB_S23_1 = M1_TypeBRS1_CACB_S23_1_7 INTERACT M1_TypeBRS1_CACB_S23_1_6 >= 2
  
  M1_TypeBRS1_CACB_S23_2 = ((EXPAND EDGE (LENGTH ((SIZE M1_TypeBRS1_CACB_S23_1 BY -NANO) AND M1i) == Mx_W) OUTSIDE BY 2*NANO) OR (M1_TypeBRS1_CACB_S23_1 AND M1i)) AND M1_TypeBRS1_CACB_S23_1
  M1_TypeBRS1_CACB_S23_3 = (M1_TypeBRS1_CACB_S23_2 AND M1_TypeBRS1_CACB_S23_1) COIN EDGE M1_TypeBRS1_CACB_S23_1
  M1_TypeBRS1_CACB_S23_4 = M1_TypeBRS1_CACB_S23_1 INTERACT (M1_TypeBRS1_CACB_S23_1 AND M1i) == 2
  M1_TypeBRS1_CACB_S23_5 = M1_TypeBRS1_CACB_S23_4 WITH EDGE M1_TypeBRS1_CACB_S23_3 == 4
  M1_TypeBRS1_CACB_EDGE1 = M1i TOUCH OUTSIDE EDGE M1_TypeBRS1_CACB_S23_5	//CA and CB EDGE
  M1_TypeBRS1_CACB_EDGE2 = EXPAND EDGE M1_TypeBRS1_CACB_EDGE1 OUTSIDE BY GRID			
  M1_TypeBRS1_CACB_EDGE3_1 = EXT M1_TypeBRS1_CACB_EDGE1 M1i == Mx_S OPPOSITE REGION
  M1_TypeBRS1_CACB_EDGE3_2 = EXT M1_TypeBRS1_CACB_EDGE1 M1_TypeBRS1_CACB_S23_2 == Mx_S OPPOSITE REGION
  M1_TypeBRS1_CACB_EDGE4 = M1_TypeBRS1_CACB_EDGE2 NOT M1_TypeBRS1_CACB_EDGE3_1
  M1_TypeBRS1_CACB_EDGE5 = LENGTH M1_TypeBRS1_CACB_EDGE4 == GRID
  M1_TypeBRS1_CACB_EDGE6 = EXPAND EDGE M1_TypeBRS1_CACB_EDGE5 OUTSIDE BY GRID
  M1_TypeBRS1_CACB_EDGE7 = (M1_TypeBRS1_CACB_EDGE6 TOUCH M1_TypeBRS1_CACB_EDGE3_1) OR (M1_TypeBRS1_CACB_EDGE6 TOUCH M1_TypeBRS1_CACB_EDGE3_2)
  
   
  M1_TypeBRS1_CACB_EDGE8_1 = M1_TypeBRS1_CACB_EDGE7 COIN OUTSIDE EDGE M1_TypeBRS1_CACB_EDGE4
  M1_TypeBRS1_CACB_EDGE8 = M1_TypeBRS1_CACB_EDGE8_1 NOT TOUCH EDGE (EXT [M1_TypeBRS1_CACB_EDGE8_1] M1i < TypeBRS1_S4 OPPOSITE)
  
  M1_TypeBRS1_CACB_EDGE9 = EXPAND EDGE M1_TypeBRS1_CACB_EDGE8 OUTSIDE BY TypeBRS1_S4
  M1_TypeBRS1_CACB_EDGE10 = M1_CORNER TOUCH M1_TypeBRS1_CACB_EDGE4
  
  M1_TypeBRS1_CACB_EDGE11_1 = M1_TypeBRS1_CACB_EDGE9 TOUCH OUTSIDE EDGE M1_TypeBRS1_CACB_EDGE10
  M1_TypeBRS1_CACB_EDGE11 = M1_TypeBRS1_CACB_EDGE11_1 NOT TOUCH EDGE (ENC M1i [M1_TypeBRS1_CACB_EDGE11_1] < TypeBRS1_S5 OPPOSITE)
  
  M1_TypeBRS1_CACB_EDGE12 = ENCLOSE RECTANGLE (EXPAND EDGE M1_TypeBRS1_CACB_EDGE11 INSIDE BY TypeBRS1_S5) TypeBRS1_S4 TypeBRS1_S5
  M1_TypeBRS1_CACB_ERROR1 = M1_TypeBRS1_CACB_EDGE12 AND M1i
  M1_TypeBRS1_CACB_ERROR2 = (ENC M1_TypeBRS1_CACB_ERROR1 [M1_TypeBRS1_CACB_EDGE11] <= TypeBRS1_S5 OPPOSITE) OR EDGE (M1_TypeBRS1_CACB_EDGE11 TOUCH EDGE M1_TypeBRS1_CACB_ERROR1)
  M1_TypeBRS1_CACB_ERROR3 = (M1_TypeBRS1_CACB_EDGE11 NOT TOUCH EDGE M1_TypeBRS1_CACB_ERROR2) TOUCH EDGE M1_TypeBRS1_CACB_EDGE12
  M1_TypeBRS1_CACB_ERROR4 = EXPAND EDGE M1_TypeBRS1_CACB_ERROR3 INSIDE BY TypeBRS1_S5
  M1_TypeBRS1_CACB_ERROR5 = ENCLOSE RECTANGLE (M1_TypeBRS1_CACB_ERROR4 NOT ENCLOSE M1_TypeBRS1_CACB_ERROR1) TypeBRS1_S4 TypeBRS1_S5
  M1_TypeBRS1_MARK1 = EXT M1_TypeBRS1_CACB_ERROR5 > 2*Mx_W+2*Mx_S+4*GRID <= TypeBRS1_S2 OPPOSITE REGION
