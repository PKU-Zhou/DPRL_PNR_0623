}

// EHVT_P.R.2 and EHVT_P.R.3 are checked by EHVT_P.W.1 and EHVT_P.S.1

EHVT_P.R.1 { @ Overlap of N+ ACTIVE, VAR, EHVT_N, UHVT_N, UHVT_P, VTH_N, VTH_P, VTL_N, VTL_P, VTUL_N, VTUL_P, NT_N, or OD2 is not allowed   
  EHVT_P AND VAR
  EHVT_P AND OD2
  EHVT_P AND NTN
  EHVT_P AND NACT
  EHVT_P AND EHVT_N
  EHVT_P AND VTHN
  EHVT_P AND VTHP
  EHVT_P AND VTLN
  EHVT_P AND VTLP
  EHVT_P AND VTUHN
  EHVT_P AND VTUHP
  EHVT_P AND VTULN
  EHVT_P AND VTULP
}
// EHVT_P.R.2 and EHVT_P.R.3 are checked by EHVT_P.W.1 and EHVT_P.S.1

EHVT_N.R.4 { @ For 22ULL process: At CHIP level, only 4 or fewer of the following 8 device types are allowed. LOGIC (5 VT types): (1) ultra low Vt = {VTUL_N OR VTUL_P} (2) low Vt = {VTL_N OR VTL_P} (3) high Vt = {VTH_N OR VTH_P} (4) ultra high Vt = {UHVT_N OR UHVT_P} (5) extreme high Vt = {EHVT_N OR EHVT_P} SRAM (3 cell implant types): (6) standard = {SRM NOT SRM_ULL} (7) ultra low leakage = {SRM_ULL NOT TGO_EHVT} (8) extreme low leakage = {SRM_ULL AND TGO_EHVT}   
  VTUL_NP = VTULN OR VTULP 
  VTL_NP  = VTLN OR VTLP
  VTH_NP  = VTHN OR VTHP
  UHVT_NP = VTUHN OR VTUHP
  EHVT_NP = EHVT_N OR EHVT_P
  STD     = SRM NOT SRM_ULL
  SRM_ULL_NOTTGO = SRM_ULL NOT TGO_EHVT
  SRM_ULL_TGO = SRM_ULL AND TGO_EHVT



  CHIP_DV = DFM PROPERTY CHIP VTUL_NP VTL_NP VTH_NP UHVT_NP EHVT_NP STD SRM_ULL_NOTTGO SRM_ULL_TGO OVERLAP ABUT ALSO MULTI
   [ DV1 = (AREA(VTUL_NP)>0) ? 1 : 0 ]
   [ DV2 = (AREA(VTL_NP)>0) ? 1 : 0 ]
   [ DV3 = (AREA(VTH_NP)>0) ? 1 : 0 ]
   [ DV4 = (AREA(UHVT_NP)>0) ? 1 : 0 ]
   [ DV5 = (AREA(EHVT_NP)>0) ? 1 : 0 ]
   [ DV6 = (AREA(STD)>0) ? 1 : 0 ]
   [ DV7 = (AREA(SRM_ULL_NOTTGO)>0) ? 1 : 0 ]
   [ DV8 = (AREA(SRM_ULL_TGO)>0) ? 1 : 0 ]

  DFM PROPERTY CHIP_DV 
  [-= PROPERTY(CHIP_DV,DV1)+PROPERTY(CHIP_DV,DV2)+PROPERTY(CHIP_DV,DV3)+PROPERTY(CHIP_DV,DV4)+PROPERTY(CHIP_DV,DV5)+PROPERTY(CHIP_DV,DV6)+PROPERTY(CHIP_DV,DV7)+PROPERTY(CHIP_DV,DV8)] >4
}




// TGO_EHVT CHECKS
//==============
TGO_EHVT.W.1 { @ Width >= ^TGO_EHVT_W_1  
  A = INT TGO_EHVT < TGO_EHVT_W_1 ABUT < 90 REGION PROJ==0
  B = EXT [TGO_EHVT] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = INT B >= TGO_EHVT_R_3_A < TGO_EHVT_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = INT B >= TGO_EHVT_R_3_B < TGO_EHVT_R_3_C+0.001 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = INT TGO_EHVT < TGO_EHVT_W_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
TGO_EHVT.W.2 { @ Channel length of {GATE INSIDE TGO_EHVT} (Except SRAMDMY;0) = 0.04/0.05/0.06/0.08/0.09~1 
  (LENGTH (GATE_L INSIDE EDGE TGO_EHVT) < TGO_EHVT_W_2_A) NOT INSIDE EDGE SRAMDMY
  (LENGTH (GATE_L INSIDE EDGE TGO_EHVT) > TGO_EHVT_W_2_A < TGO_EHVT_W_2_B) NOT INSIDE EDGE SRAMDMY
  (LENGTH (GATE_L INSIDE EDGE TGO_EHVT) > TGO_EHVT_W_2_B < TGO_EHVT_W_2_C) NOT INSIDE EDGE SRAMDMY
  (LENGTH (GATE_L INSIDE EDGE TGO_EHVT) > TGO_EHVT_W_2_C < TGO_EHVT_W_2_D) NOT INSIDE EDGE SRAMDMY
  (LENGTH (GATE_L INSIDE EDGE TGO_EHVT) > TGO_EHVT_W_2_D < TGO_EHVT_W_2_E) NOT INSIDE EDGE SRAMDMY
  (LENGTH (GATE_L INSIDE EDGE TGO_EHVT) > TGO_EHVT_W_2_F) NOT INSIDE EDGE SRAMDMY

}
TGO_EHVT.S.1 { @ Space >= ^TGO_EHVT_S_1 
  A = EXT TGO_EHVT < TGO_EHVT_S_1 ABUT < 90 REGION PROJ==0
  B = INT [TGO_EHVT] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = EXT B >= TGO_EHVT_R_3_A < TGO_EHVT_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = EXT B >= TGO_EHVT_R_3_B < TGO_EHVT_R_3_C+0.001 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = EXT TGO_EHVT < TGO_EHVT_S_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
TGO_EHVT.S.2__TGO_EHVT.S.3 { @ Space to gate in PO endcap direction >= ^TGO_EHVT_S_2 & in S/D direction >= ^TGO_EHVT_S_3, {ACTIVE OR GATE} cut TGO_EHVT is not allowed.
  A = GATE NOT INTERACT TGO_EHVT
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (TGO_EHVT_S_3 - TGO_EHVT_S_2)) OR A
  C = SIZE B BY TGO_EHVT_S_2
  TGO_EHVT AND C
  DACT CUT TGO_EHVT
  GATE CUT TGO_EHVT
}
TGO_EHVT.S.4 { @ Space to unsilicided OD or high R resistor >= ^TGO_EHVT_S_4
  EXT TGO_EHVT AYRE < TGO_EHVT_S_4 ABUT < 90 SINGULAR REGION
  AND TGO_EHVT AYRE    
}  
TGO_EHVT.S.5 { @ Space [parallel run length > 0.33 um, TGO_EHVT space without INTERACT {{OD OR SR_DOD} OR DOD}] >= ^TGO_EHVT_S_5
  X = EXT TGO_EHVT < TGO_EHVT_S_5 OPPOSITE REGION
  Y = X NOT INTERACT ALL_OD
  ENCLOSE RECTANGLE Y GRID TGO_EHVT_S_5_L+GRID ORTHOGONAL ONLY
}
TGO_EHVT.EN.1__TGO_EHVT.EN.2 { @ Enclosure of gate in S/D direction >= ^TGO_EHVT_EN_1 & in PO endcap direction >= ^TGO_EHVT_EN_2 
  A = GATE INTERACT TGO_EHVT
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (TGO_EHVT_EN_1 - TGO_EHVT_EN_2)) OR A
  C = SIZE B BY TGO_EHVT_EN_2
  C NOT TGO_EHVT
}
TGO_EHVT.L.1 { @ 45-degree edge length >= ^TGO_EHVT_L_1 
  TGO_EHVT_EDGE_45 = TGO_EHVT ANGLE == 45
  LENGTH TGO_EHVT_EDGE_45 < TGO_EHVT_L_1  
}
TGO_EHVT.A.1 { @ Area >= ^TGO_EHVT_A_1, except DMY_SCH.
  AREA (TGO_EHVT NOT INSIDE DMY_SCH) < TGO_EHVT_A_1
}
TGO_EHVT.A.2 { @ Enclosed area >= ^TGO_EHVT_A_2, except DMY_SCH.
  A = HOLES TGO_EHVT INNER
  B = A NOT TGO_EHVT
  AREA (B NOT INSIDE DMY_SCH) < TGO_EHVT_A_2
}
// TGO_EHVT.R.2 and TGO_EHVT.R.3 are checked by TGO_EHVT.W.1 and TGO_EHVT.S.1


TGO_EHVT.R.1 { @ Overlap of VTH_N, VTH_P, VTL_N, VTL_P, VTUL_N, VTUL_P, UHVT_N, UHVT_P, NT_N or OD2 is not allowed   
  TGO_EHVT AND VTHN
  TGO_EHVT AND VTHP
  TGO_EHVT AND VTLN
  TGO_EHVT AND VTLP
  TGO_EHVT AND VTULN
  TGO_EHVT AND VTULP
  TGO_EHVT AND VTUHN
  TGO_EHVT AND VTUHP
  TGO_EHVT AND NTN
  TGO_EHVT AND OD2
}

TGO_EHVT.R.4 { @ TGO_EHVT and {EHVT_N OR EHVT_P} must be identically. (Except SRAMDMY;0)   
  EHVT = OR EHVT_N EHVT_P
    (TGO_EHVT XOR EHVT) NOT INSIDE SRAMDMY
}

#ENDIF




VTLN_N25_OD      = VTLN_N25 AND OD
VTLN_N25_PO      = VTLN_N25 AND POLY
VTLN_N25_GATE_W  = GATE_W INSIDE EDGE VTLN_N25
VTLN_N25_GATE_L  = GATE_L INSIDE EDGE VTLN_N25
VTLNN25W45       = NWEL OR (NTN OR VTLN_N25)
VTLNN25S8        = OD2 NOT VTLNN25W45
VTLNN25W5        = OD2 OR VTLNN25W45
VTLNN25A3        = (OD2 NOT OUTSIDE VTLN_N25) NOT VTLNN25W45
VTLNN25A5        = (OD2 INTERACT VTLN_N25) OR VTLNN25W45
VTLNN25OR        = (OD2 INTERACT VTLN_N25) OR VTLNN25W45
VTLNN25NOT       = (OD2 INTERACT VTLN_N25) NOT VTLNN25W45

VTLN_P25_OD      = VTLN_P25 AND OD
VTLN_P25_PO      = VTLN_P25 AND POLY
VTLN_P25_GATE_W  = GATE_W INSIDE EDGE VTLN_P25
VTLN_P25_GATE_L  = GATE_L INSIDE EDGE VTLN_P25
VTLNP25S1        = VTLN_P25 OR NWEL 
VTLNP25S2        = VTLN_P25 OR ( NW1V OR NW2V )
VTLNP25W4        = NWEL NOT VTLN_P25
VTLNP25A3_1      = NTN OR VTLN_P25
VTLNP25A3        = (NWEL NOT OUTSIDE VTLN_P25) NOT VTLNP25A3_1






VTLN_N25.W.1 { @ Width >= 0.24 
  (INT VTLN_N25 < VTLN_N25_W_1 ABUT < 90 SINGULAR REGION ) NOT INSIDE SRAM_WAIVE_N28
}
VARIABLE VTLN_N25_W_2_1.2 1.2
VARIABLE VTLN_N25_W_2_0.4 0.4
VTLN_N25.W.2 { @ Channel length in VTLN_N25 = 0.4~1.2 
LENGTH VTLN_N25_GATE_L < VTLN_N25_W_2_0.4 
LENGTH VTLN_N25_GATE_L > VTLN_N25_W_2_1.2
}

VTLN_N25.W.3 { @ Channel width in VTLN_N25 >= 0.27 
  LENGTH VTLN_N25_GATE_W < VTLN_N25_W_3
}
VTLN_N25.W.4 { @ Width of {OD2 NOT {NW OR {NT_N OR VTLN_N25}}}. DRC only check OD2 which interact with VTLN_N25 >= 0.24 
  INT VTLNN25NOT < VTLN_N25_W_4 ABUT < 90 SINGULAR REGION 
}
VTLN_N25.W.5 { @ Width of {OD2 OR {NW OR {NT_N OR VTLN_N25}}}(for NW, please refer to NW.W.1) >= 0.24 
  (INT VTLNN25W5 < VTLN_N25_W_5 ABUT < 90 OPPOSITE SYMMETRIC REGION) NOT INSIDE SRAM_WAIVE_N28
  (INT VTLNN25W5 < VTLN_N25_W_5 ABUT < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (INT VTLNN25W5< VTLN_N25_W_5 ABUT < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28
}
VTLN_N25.S.1  { @ Space >= 0.24 
  EXT VTLN_N25 < VTLN_N25_S_1 ABUT < 90 SINGULAR REGION
}
VTLN_N25.S.2 { @ Space to (VTLN_N25 OR {RW OR PW}) with different potential >= 1 
  VTLN_N25c = PWELi AND VTLN_N25
  EXT VTLN_N25c < VTLN_N25_S_2 ABUT < 90 NOT CONNECTED SINGULAR REGION
  EXT VTLN_N25c PWELi < VTLN_N25_S_2 ABUT < 90 NOT CONNECTED SINGULAR REGION
}
VTLN_N25.S.3  { @ Space to PW STRAP >= 0.065 
  (EXT VTLN_N25 PSTP < VTLN_N25_S_3 ABUT < 90 SINGULAR REGION) NOT INSIDE (OR SRAM_WAIVE_N28 LDMOS)
}
VTLN_N25.S.4 { @ Space to N+ ACTIVE >= 0.065 
  (EXT VTLN_N25 NPOD < VTLN_N25_S_4 ABUT < 90 SINGULAR REGION) NOT INSIDE (OR SRAM_WAIVE_N28 LDMOS)
  (NPOD CUT VTLN_N25) NOT INSIDE (OR SRAM_WAIVE_N28 LDMOS)
}
VTLN_N25.S.4.1 { @ At least one edge of VTLN_N25 inner vertex space to N+ ACTIVE >= 0.105 
  NACTx = (NPOD NOT INTERACT RNWEL) NOT VTLN_N25 
  OD_CONVEX_CORNER = INT [NACTx] < GRID ABUT == 90 INTERSECTING ONLY 
  VTLN_N25_CONCAVE_CORNER = EXT [VTLN_N25] < (VTLN_N25_S_4_1-VTLN_N25_S_4+GRID) ABUT == 90 INTERSECTING ONLY 
  X1 = ANGLE  OD_CONVEX_CORNER == 0
  X2 = ANGLE  VTLN_N25_CONCAVE_CORNER == 0
  A = EXT [X1] X2 < VTLN_N25_S_4_1 OPPOSITE EXTENDED VTLN_N25_S_4      
  X3 = ANGLE  OD_CONVEX_CORNER == 90
  X4 = ANGLE  VTLN_N25_CONCAVE_CORNER == 90
  B = EXT [X3] X4 < VTLN_N25_S_4_1 OPPOSITE EXTENDED VTLN_N25_S_4  
  INT A B < GRID ABUT == 90 INTERSECTING ONLY REGION
    OD_CONCAVE_CORNER = EXT [NACTx] <  (VTLN_N25_S_4_1-VTLN_N25_S_4+GRID) ABUT == 90 INTERSECTING ONLY 
  VTLN_N25_CONVEX_CORNER = INT [VTLN_N25] <  GRID ABUT == 90 INTERSECTING ONLY 
  Y1 = ANGLE  OD_CONCAVE_CORNER == 0
  Y2 = ANGLE  VTLN_N25_CONVEX_CORNER == 0
  C = EXT Y1 [Y2] < VTLN_N25_S_4_1 OPPOSITE EXTENDED VTLN_N25_S_4  
  Y3 = ANGLE  OD_CONCAVE_CORNER == 90
  Y4 = ANGLE  VTLN_N25_CONVEX_CORNER == 90
  D = EXT Y3 [Y4] < VTLN_N25_S_4_1 OPPOSITE EXTENDED VTLN_N25_S_4 
  INT C D < GRID ABUT == 90 INTERSECTING ONLY REGION
}
VTLN_N25.S.5 { @ Space to {N+ ACTIVE INTERACT OD2} >= 0.18 
  (EXT VTLN_N25 NACT2 < VTLN_N25_S_5 ABUT < 90 SINGULAR REGION) NOT INSIDE  LDMOS
}
VTLN_N25.S.6 { @ Space to NW. Space = 0 is allowed >= 0.24 
  EXT VTLN_N25 NWEL < VTLN_N25_S_6 ABUT < 90 > 0 SINGULAR REGION
}
VTLN_N25.S.7 { @ Space to NT_N >= 0.24 
  EXT VTLN_N25 NTNi < VTLN_N25_S_7 ABUT < 90 SINGULAR REGION
}
VTLN_N25.S.8 { @ Space of {OD2 NOT {NW OR {NT_N OR VTLN_N25}}} >= 0.24 
  EXT VTLNN25S8 < VTLN_N25_S_8 ABUT < 90 SINGULAR REGION
}
VTLN_N25.S.9 { @ Space of {OD2 OR {NW OR {NT_N OR VTLN_N25}}} , DRC only check OD2 which interact with VTLN_N25 >= 0.24 
  EXT VTLNN25OR < VTLN_N25_S_9 ABUT < 90 SINGULAR REGION
}
VTLN_N25.S.10 { @ Space [parallel run length > 0.5 um, VTLN_N25 space without INTERACT {{OD OR SR_DOD} OR DOD}] >= 0.3 
  X = EXT VTLN_N25 < VTLN_N25_S_10 OPPOSITE REGION
    Y = X NOT INTERACT ((OD OR DOD) OR SRDOD)
  ENCLOSE RECTANGLE Y GRID VTLN_N25_S_10_L+GRID ORTHOGONAL ONLY
}
VTLN_N25.EN.1 { @ Enclosure of N+ ACTIVE >= 0.18 
  (ENC NACT VTLN_N25 < VTLN_N25_EN_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  NACT CUT VTLN_N25
}
VTLN_N25.EN.2 { @ Enclosure of PW STRAP >= 0.065 
  (ENC PSTP VTLN_N25 < VTLN_N25_EN_2 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
VTLN_N25.EN.3 { @ {DNW INTERACT VTLN_N25} enclosure by NW >= 1 
  (ENC (DNWi INTERACT VTLN_N25) NWEL < VTLN_N25_EN_3 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
VTLN_N25.A.1 { @ Area >= 0.4 
  AREA VTLN_N25 < VTLN_N25_A_1
}
VTLN_N25.A.2 { @ Enclosure area >= 0.4 
  A = HOLES VTLN_N25 INNER
  B = A NOT VTLN_N25
  AREA B < VTLN_N25_A_2
}
VTLN_N25.A.3 { @ Area of {OD2 AND VTLN_N25} >= 0.4 
  AREA (OD2 AND VTLN_N25) < VTLN_N25_A_3
}
VTLN_N25.A.4 { @ Enclosure area of {OD2 NOT {OD2 AND VTLN_N25}} >= 0.4 
  VTLNN25CHK = OD2 NOT (OD2 AND VTLN_N25)
  A = HOLES VTLNN25CHK INNER
  B = A NOT VTLNN25CHK
  AREA B < VTLN_N25_A_4
}






VTLN_N25.R.1 { @ {N+ ACTIVE INTERACT VTLN_N25} must be inside OD_25   
  (NACT INTERACT VTLN_N25)  NOT OD25
}
VTLN_N25.R.2 { @ VTLN_N25 must INSIDE OD_25   
    VTLN_N25 NOT INSIDE OD25 
}
VTLN_N25.R.3 { @ Overlap of NW, NWDMY, NT_N, BJTDMY, VAR, VTL_N, VTL_P, VTLN_P25, ROM, POFUSE, or SRM is not allowed   
  VTLN_N25 AND NWEL
  VTLN_N25 AND NWDMY
  VTLN_N25 AND NTN
  VTLN_N25 AND BJTDMY
  VTLN_N25 AND VAR
  VTLN_N25 AND VTLN
  VTLN_N25 AND VTLP
  VTLN_N25 AND VTLN_P25
  VTLN_N25 AND ROM
  VTLN_N25 AND POFUSE
  VTLN_N25 AND SRM
}  









VTLN_P25.W.1 { @ Width >= 0.24 
  (INT VTLN_P25 < VTLN_P25_W_1 ABUT < 90 SINGULAR REGION ) NOT INSIDE SRAM_WAIVE_N28
}
VARIABLE VTLN_P25_W_2_1.2 1.2
VARIABLE VTLN_P25_W_2_0.4 0.4
VTLN_P25.W.2 { @ Channel length in VTLN_P25 = 0.4~1.2 
LENGTH VTLN_P25_GATE_L < VTLN_P25_W_2_0.4 
LENGTH VTLN_P25_GATE_L > VTLN_P25_W_2_1.2
}

VTLN_P25.W.3 { @ Channel width in VTLN_P25 >= 0.27 
  LENGTH VTLN_P25_GATE_W < VTLN_P25_W_3
}
VTLN_P25.W.4 { @ Width of {NW NOT VTLN_P25}(for NW, please refer to NW.W.1) >= 0.24 
  (INT VTLNP25W4 < VTLN_P25_W_4 ABUT < 90 OPPOSITE SYMMETRIC REGION) NOT INSIDE SRAM_WAIVE_N28
  (INT VTLNP25W4 < VTLN_P25_W_4 ABUT < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (INT VTLNP25W4 < VTLN_P25_W_4 ABUT < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28
}
VTLN_P25.S.1  { @ Space to {VTLN_P25 OR NW} >= 0.24 
  EXT VTLN_P25 VTLNP25S1 < VTLN_P25_S_1 ABUT < 90 SINGULAR REGION
}
VTLN_P25.S.2 { @ Space to {VTLN_P25 OR {NW1V OR NW2V}} with different potential >= 1 
  A = VTLN_P25 OR ( NW1V OR NW2V )
  Ac = STAMP A BY NWi
  VTLN_P25c = STAMP VTLN_P25 BY NWi
  EXT VTLN_P25c Ac < VTLN_P25_S_2 ABUT < 90 > 0 SINGULAR REGION NOT CONNECTED
}
VTLN_P25.S.3  { @ Space to NW STRAP >= 0.065 
  (EXT VTLN_P25 NSTP < VTLN_P25_S_3 ABUT < 90 SINGULAR REGION) NOT INSIDE (OR SRAM_WAIVE_N28 LDMOS)
}
VTLN_P25.S.4 { @ Space to P+ ACTIVE >= 0.065 
  (EXT VTLN_P25 PACT < VTLN_P25_S_4 ABUT < 90 SINGULAR REGION) NOT INSIDE (OR SRAM_WAIVE_N28 LDMOS)
  (PACT CUT VTLN_P25) NOT INSIDE (OR SRAM_WAIVE_N28 LDMOS)
}
VTLN_P25.S.5 { @ At least one edge of VTLN_P25 inner vertex space to P+ ACTIVE >= 0.105 
  PACTx = PACT NOT VTLN_P25 
  OD_CONVEX_CORNER = INT [PACTx] < GRID ABUT == 90 INTERSECTING ONLY 
  VTLN_P25_CONCAVE_CORNER = EXT [VTLN_P25] < (VTLN_P25_S_5-VTLN_P25_S_4+GRID) ABUT == 90 INTERSECTING ONLY 
  X1 = ANGLE  OD_CONVEX_CORNER == 0
  X2 = ANGLE  VTLN_P25_CONCAVE_CORNER == 0
  A = EXT [X1] X2 < VTLN_P25_S_5 OPPOSITE EXTENDED VTLN_P25_S_4      
  X3 = ANGLE  OD_CONVEX_CORNER == 90
  X4 = ANGLE  VTLN_P25_CONCAVE_CORNER == 90
  B = EXT [X3] X4 < VTLN_P25_S_5 OPPOSITE EXTENDED VTLN_P25_S_4  
  INT A B < GRID ABUT == 90 INTERSECTING ONLY REGION
    OD_CONCAVE_CORNER = EXT [PACTx] <  (VTLN_P25_S_5-VTLN_P25_S_4+GRID) ABUT == 90 INTERSECTING ONLY 
  VTLN_P25_CONVEX_CORNER = INT [VTLN_P25] <  GRID ABUT == 90 INTERSECTING ONLY 
  Y1 = ANGLE  OD_CONCAVE_CORNER == 0
  Y2 = ANGLE  VTLN_P25_CONVEX_CORNER == 0
  C = EXT Y1 [Y2] < VTLN_P25_S_5 OPPOSITE EXTENDED VTLN_P25_S_4  
  Y3 = ANGLE  OD_CONCAVE_CORNER == 90
  Y4 = ANGLE  VTLN_P25_CONVEX_CORNER == 90
  D = EXT Y3 [Y4] < VTLN_P25_S_5 OPPOSITE EXTENDED VTLN_P25_S_4 
  INT C D < GRID ABUT == 90 INTERSECTING ONLY REGION
}
VTLN_P25.S.6 { @ Space to {P+ ACTIVE INTERACT OD2} >= 0.18 
  (EXT VTLN_P25 PACT2 < VTLN_P25_S_6 ABUT < 90 SINGULAR REGION) NOT INSIDE LDMOS
}
VTLN_P25.S.7 { @ Space of {NW NOT VTLN_P25} >= 0.24 
  EXT VTLNP25W4 < VTLN_P25_S_7 ABUT < 90 SINGULAR REGION
}
VTLN_P25.S.10 { @ Space [parallel run length > 0.5 um, VTLN_P25 space without INTERACT {{OD OR SR_DOD} OR DOD}] >= 0.3 
  X = EXT VTLN_P25 < VTLN_P25_S_10 OPPOSITE REGION
    Y = X NOT INTERACT ((OD OR DOD) OR SRDOD)
  ENCLOSE RECTANGLE Y GRID VTLN_P25_S_10_L+GRID ORTHOGONAL ONLY
}
VTLN_P25.EN.1 { @ Enclosure of P+ ACTIVE >= 0.18 
  (ENC PACT VTLN_P25 < VTLN_P25_EN_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  PACT CUT VTLN_P25
}
VTLN_P25.EN.2 { @ Enclosure of NW STRAP >= 0.065 
  (ENC NSTP VTLN_P25 < VTLN_P25_EN_2 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
VTLN_P25.EN.3 { @ {DNW INTERACT VTLN_P25} enclosure by NW >= 1 
  (ENC (DNWi INTERACT VTLN_P25) NWEL < VTLN_P25_EN_3 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
VTLN_P25.EN.4 { @ Enclosure by NW. Enclosure = 0 is allowed >= 0.24 
  ENC VTLN_P25 NWEL < VTLN_P25_EN_4 ABUT < 90 > 0 SINGULAR REGION
}
VTLN_P25.A.1 { @ Area >= 0.4 
  AREA VTLN_P25 < VTLN_P25_A_1
}
VTLN_P25.A.2 { @ Enclosure area >= 0.4 
  A = HOLES VTLN_P25 INNER
  B = A NOT VTLN_P25
  AREA B < VTLN_P25_A_2
}
VTLN_P25.A.3 { @ Area of {{NW NOT OUTSIDE VTLN_P25} NOT {NT_N OR VTLN_P25}} >= 0.4 
  AREA VTLNP25A3 < VTLN_P25_A_3
}
VTLN_P25.A.4 { @ Enclosure area of {{NW NOT OUTSIDE VTLN_P25} NOT {NT_N OR VTLN_P25}} >= 0.4 
  A = HOLES VTLNP25A3 INNER
  B = A NOT VTLNP25A3
  AREA B < VTLN_P25_A_4
}
VTLN_P25.A.5 { @ Area of {OD2 AND VTLN_P25} >= 0.4 
  AREA (OD2 AND VTLN_P25) < VTLN_P25_A_5
}
VTLN_P25.A.6 { @ Enclosure area of {OD2 NOT {OD2 AND VTLN_P25}} >= 0.4 
  VTLNP25CHK = OD2 NOT (OD2 AND VTLN_P25)
  A = HOLES VTLNP25CHK INNER
  B = A NOT VTLNP25CHK
  AREA B < VTLN_P25_A_6
}








VTLN_P25.R.1 { @ {P+ ACTIVE INTERACT VTLN_P25} must be inside OD_25   
  (PACT INTERACT VTLN_P25) NOT OD25
}
VTLN_P25.R.2 { @ VTLN_P25 must INSIDE OD_25   
  VTLN_P25 NOT INSIDE OD25
}
VTLN_P25.R.3 { @ Overlap of {NW INTERACT NWDMY}, NT_N, BJTDMY, VAR, VTL_N, VTL_P, VTLN_N25, ROM, POFUSE, or SRM is not allowed   
  VTLN_P25 AND (NWEL INTERACT NWDMY)
  VTLN_P25 AND NTN 
  VTLN_P25 AND BJTDMY
  VTLN_P25 AND VAR
  VTLN_P25 AND VTLN
  VTLN_P25 AND VTLP
  VTLN_P25 AND VTLN_N25
  VTLN_P25 AND ROM
  VTLN_P25 AND POFUSE
  VTLN_P25 AND SRM
} 
VTLN_P25.R.6 { @ VTLN_P25 must be inside NW   
  VTLN_P25 NOT NWEL
}




//PMET CHECKS
//===========

REAL_POLY = ((POLY OR SRDPO) OR DPO) NOT CPO
REAL_POLY_P = REAL_POLY AND PP  

PMET.W.1 { @ Width >= 0.16 
  INT PMET < PMET_W_1 ABUT < 90 SINGULAR REGION
}

PMET.S.1 { @ Space >= 0.16 
  EXT PMET < PMET_S_1 ABUT < 90 SINGULAR REGION
}

PMET.S.2 { @ Space if at least one PMET width < 0.22 um >= 0.22 
  Thin_PMET = PMET WITH WIDTH < PMET_S_2_W
  EXT Thin_PMET PMET < PMET_S_2 ABUT < 90 SINGULAR REGION
}

PMET.S.3 { @ Space to {{{PO OR SR_DPO} OR DPO} NOT CPO} >= 0.04 
  EXT PMET REAL_POLY < PMET_S_3 ABUT < 90 SINGULAR REGION
}

PMET.S.9 { @ Space to NMOS GATE >= 0.065 
  GATE_N = GATE AND NP   
  EXT PMET GATE_N < PMET_S_9 ABUT < 90 SINGULAR REGION
}

PMET.EX.1 { @ {{{PO OR SR_DPO} OR DPO} NOT CPO} extension on PMET >= 0.1 
  ENC PMET ALL_POLY < PMET_EX_1 ABUT < 90 OPPOSITE REGION
}

PMET.EX.6 { @ Extension on {{{PO OR SR_DPO} OR DPO} NOT CPO} >= 0.04 
  ENC REAL_POLY PMET < PMET_EX_6 ABUT < 90 REGION
}
PMET.EX.7 { @ Extension on {{{PO OR SR_DPO} OR DPO} NOT CPO} [edge length >= 0.17 um (R4)] (This check doesn't include LOGO, SRAMDMY;0 (186;0) and OD2) >= 0.05 
  WAIVE_REGION = SRAMDMY OR (LOGO OR CPO)
  REAL_CORE_POLY_EDGE = LENGTH ((REAL_POLY NOT OD2) INSIDE EDGE PMET) >= PMET_EX_7_L
  (ENC REAL_CORE_POLY_EDGE PMET < PMET_EX_7 ABUT < 90 OPPOSITE REGION) NOT INSIDE WAIVE_REGION 
}
PMET.EX.8 { @ Extension on {{{PO OR SR_DPO} OR DPO} NOT CPO}. [INSIDE OD2] >= 0.09 
  (ENC (REAL_POLY INSIDE OD2) PMET < PMET_EX_8 ABUT < 90 REGION) NOT OUTSIDE OD2
}
PMET.O.1 { @ Overlap of {{{PO OR SR_DPO} OR DPO} NOT CPO} >= 0.1 
  A = PMET INSIDE EDGE REAL_POLY
  INT A REAL_POLY < PMET_O_1 ABUT < 90 OPPOSITE REGION
}
PMET.EN.1 { @ Enclosure of P+ metal gate and high R resistors >= 0.19 
  ENC RES_METAL_GATE_P PMET < PMET_EN_1 ABUT < 90 SINGULAR REGION
  ENC RES_High_R PMET < PMET_EN_1 ABUT < 90 SINGULAR REGION
}

PMET.L.1 { @ 45-degree edge length >= 0.5 
  PMET_EDGE_45 = PMET ANGLE == 45
  LENGTH PMET_EDGE_45 < PMET_L_1
}

PMET.A.1 { @ Area >= 0.108 
  AREA PMET < PMET_A_1
}

PMET.A.3 { @ Enclosed area >= 0.108 
  A = HOLES PMET INNER
  B = A NOT PMET
  AREA B < PMET_A_3
}  

PMET.R.1 {@ PMET must fully cover {Core PMOS GATE SIZING 0.04 um} >= 0.04 
  GATE_CORE_P = (((GATE NOT OD2) AND PP) NOT INSIDE TCDDMY) NOT INSIDE (SRAM_WAIVE_N28 OR ICOVL)
  (SIZE GATE_CORE_P BY PMET_R_1) NOT PMET
}


PMET.R.2 { @ PMET must fully cover {I/O PMOS GATE SIZING 0.09 um} >= 0.09 
  GATE_IO_P = ((GATE AND OD2) AND PP) NOT INSIDE (TCDDMY OR GATED)
  (SIZE GATE_IO_P BY PMET_R_2) NOT PMET
}

PMET.R.3 { @ Overlap of NMOS GATE is not allowed   
  GATE_N = GATE AND NP 
  (GATE_N AND PMET) NOT INSIDE GATED
}

PMET.R.4 { @ Overlap with SRM, NT_N, RH_OD, DIODMY, BJTDMY, and NWDMY is not allowed   
  PMET AND SRM
  PMET AND NTN
  PMET AND RHOD
  PMET AND DIODMY
  PMET AND BJTDMY
  PMET AND NWDMY
}

PMET.R.5 { @ PMET must fully cover all PMOS GATE and P+ metal gate and high R resistors. (This check doesn't include the region covered by SRM, NT_N, RH_OD, DIODMY, BJTDMY, NWDMY, and TCDDMY)   
  EXCLUDE_REGION = (((((((SRM OR SRAM_WAIVE_N28) OR NTN) OR RHOD) OR DIODMY) OR BJTDMY) OR NWDMY) OR TCDDMY) OR GATED
  ((GATE_PP NOT PMET) NOT EXCLUDE_REGION) NOT INSIDE ICOVL
  ((RES_Metal_GATE_P NOT PMET) NOT EXCLUDE_REGION) NOT INSIDE ICOVL
  ((RES_HIGH_R NOT PMET) NOT EXCLUDE_REGION) NOT INSIDE ICOVL
}





//PP CHECKS
//=========
PP_CORE  = ((PP NOT CSRDMY) NOT SR_EDGE_P4) NOT INSIDE SRCSR_P4
IMP1     = NP OR PP_CORE
ODIMP1   = OD COINCIDENT INSIDE EDGE IMP1 
PP_BEDGE = PP INSIDE EDGE OD   

PP.W.1 { @ Width >= 0.16 
  INT PP < PP_W_1 ABUT < 90 SINGULAR REGION
}
PP.S.1 { @ Space >= 0.16 
  (EXT PP < PP_S_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}

PP.S.2 { @ Space if at least one PP width < 0.22 um. DRC can flag opposite side only >= 0.22 
  A = INT [PP] < PP_S_2_W OPPOSITE ABUT < 90 SINGULAR   
  EXT A PP < PP_S_2 ABUT < 90 OPPOSITE REGION
}
PP.S.3 { @ Space to N+ ACTIVE (non-butted) >= 0.065 
  (EXT PP NACT < PP_S_3 ABUT < 90 > 0 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  X = EXT PP [NACT] < 0.001 ABUT == 0
  Y = EXPAND EDGE X OUTSIDE BY 0.001
  (Y NOT INTERACT PPOD) NOT INSIDE SRAM_WAIVE_N28
}

// PP.S.4 is checked by PP.S.3 and PP.R.3

PP.S.5 { @ Space to NW STRAP (non-butted) >= 0.02 
  (EXT PP NSTP < PP_S_5 ABUT < 90 > 0 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  X = EXT PP [NSTP] < 0.001 ABUT == 0
  Y = EXPAND EDGE X OUTSIDE BY 0.001
  (Y NOT INTERACT PPOD) NOT INSIDE SRAM_WAIVE_N28
}
PP.S.6 { @ {PP edge on OD} space to NMOS GATE >= 0.16 
  (EXT GATEN_W PP_BEDGE < PP_S_6 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28
}

EX_GATEN = EXPAND EDGE GATEN_W OUTSIDE BY PP_S_7 EXTEND BY PP_S_7_J

PP.S.7 { @ Butted PW STRAP space to PO in the same OD [the butted N+ ACTIVE extending 0 < J1 < 0.08 um] >= 0.16 
  A = EX_GATEN AND BUTT_PSTP
  B = EX_GATEN AND NACT
  C = A INTERACT B
  D = SD INTERACT C
  E = GATEN_W COIN OUTSIDE EDGE D
  F = EXPAND EDGE E OUTSIDE BY PP_S_7 EXTEND BY PP_S_7_J
  (C AND F) NOT INSIDE SRAM_WAIVE_N28
}
PP.S.8 { @ Space to N-type unsilicided OD resistor >= 0.1 
  EXT PP (NP AND ODRES_US) < PP_S_8 ABUT < 90 SINGULAR REGION
}
PP.S.9 { @ Space [parallel run length > 0.33 um, PP space NOT INTERACT {{OD OR SR_DOD} OR DOD}] >= 0.25 
  X = EXT PP < PP_S_9 OPPOSITE REGION
  Y = X NOT INTERACT ALL_OD
  ENCLOSE RECTANGLE Y GRID PP_S_9_L+GRID ORTHOGONAL ONLY
}

PP.EN.1 { @ {NP OR PP} enclosure of {PO NOT CPO} >= 0.065 
  (ENC (POLY NOT CPO) IMP < PP_EN_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (((POLY NOT CPO) NOT LOGO) NOT IMP) NOT INSIDE SRAM_WAIVE_N28
}
PP.EX.1 { @ Extension on P+ ACTIVE >= 0.065 
  (ENC PACT PP_CORE < PP_EX_1 ABUT < 90 > 0 SINGULAR REGION) NOT INSIDE (SRAM_WAIVE_N28 OR P1VNIX)
  X = ENC [PACT] PP_CORE < 0.001 ABUT == 0
  Y = EXPAND EDGE X OUTSIDE BY 0.001
  (Y NOT INTERACT NPOD) NOT INSIDE SRAM_WAIVE_N28
  ((EXPAND EDGE ODIMP1 INSIDE BY 0.001) AND PACT) NOT INSIDE (SRAM_WAIVE_N28 OR P1VNIX)
}
PP.EX.2 { @ Extension on PW STRAP >= 0.02 
  (ENC PSTP PP_CORE < PP_EX_2 ABUT < 90 > 0 SINGULAR REGION) NOT INSIDE (SRAM_WAIVE_N28 OR P1VNIX)
  X = ENC [PSTP] PP_CORE < 0.001 ABUT == 0
  Y = EXPAND EDGE X OUTSIDE BY 0.001
  (Y NOT INTERACT NPOD) NOT INSIDE SRAM_WAIVE_N28
  ((EXPAND EDGE ODIMP1 INSIDE BY 0.001) AND PSTP) NOT INSIDE (SRAM_WAIVE_N28 OR P1VNIX)
}
PP.EX.3 { @ Extension on P-type unsilicided OD resistor >= 0.1 
  ENC ODRES_US PP < PP_EX_3 ABUT < 90 SINGULAR REGION
}
PP.EX.4 { @ {PP edge on OD} extension on PMOS GATE >= 0.16 
  (ENC GATEP_W PP_BEDGE < PP_EX_4 ABUT < 90 OPPOSITE REGION) NOT INSIDE (SRAM_WAIVE_N28 OR GATED)
}
PP.O.1 { @ Overlap of OD >= 0.08 
  (INT OD PP < PP_O_1 ABUT < 90 > 0 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
PP.L.1 { @ 45-degree edge length >= 0.5 
  PP_EDGE_45 = PP ANGLE == 45 
  LENGTH PP_EDGE_45 < PP_L_1    
}

PP_CHK1 = SIZE (SIZE (SIZE ((PP NOT OD2) AND NWEL) BY 0.07) BY -0.14) BY 0.07
PP_CHK2 = SIZE (SIZE (SIZE ((PP AND OD2) AND NWEL) BY 0.07) BY -0.14) BY 0.07

PP.A.1 { @ Area of PP, {{{{{PP NOT OD2} AND NW} SIZING 0.07 um} SIZING -0.14 um} SIZING 0.07 um}, {{{{{PP AND OD2} AND NW} SIZING 0.07 um} SIZING -0.14 um} SIZING 0.07 um}, except the rectangle pattern [with one of edge length = 0.33, any 2 outer vertexes space = 0.16 um, area (O1) >= 0.07] >= 0.108 
  A = AREA PP < PP_A_1
  B = AREA (RECTANGLE A) >= PP_A_2
  C = B WITH EDGE (LENGTH A == PP_A_2_L)
  D = INT C < GRID ABUT == 90 INTERSECTING ONLY REGION
  E = EXT [C] PP == PP_A_2_S OPPOSITE EXTENDED GRID
  F = D WITH EDGE E
  G = C INTERACT F >= 2
  (A NOT G) NOT INSIDE SRAM_WAIVE_N28

  A_CHK1 = AREA PP_CHK1 < PP_A_1
  B_CHK1 = AREA (RECTANGLE A_CHK1) >= PP_A_2
  C_CHK1 = B_CHK1 WITH EDGE (LENGTH A_CHK1 == PP_A_2_L)
  D_CHK1 = INT C_CHK1 < GRID ABUT == 90 INTERSECTING ONLY REGION
  E_CHK1 = EXT [C_CHK1] PP_CHK1 == PP_A_2_S OPPOSITE EXTENDED GRID
  F_CHK1 = D_CHK1 WITH EDGE E_CHK1
  G_CHK1 = C_CHK1 INTERACT F_CHK1 >= 2
  (A_CHK1 NOT G_CHK1) NOT INSIDE SRAM_WAIVE_N28

  A_CHK2 = AREA PP_CHK2 < PP_A_1
  B_CHK2 = AREA (RECTANGLE A_CHK2) >= PP_A_2
  C_CHK2 = B_CHK2 WITH EDGE (LENGTH A_CHK2 == PP_A_2_L)
  D_CHK2 = INT C_CHK2 < GRID ABUT == 90 INTERSECTING ONLY REGION
  E_CHK2 = EXT [C_CHK2] PP_CHK2 == PP_A_2_S OPPOSITE EXTENDED GRID
  F_CHK2 = D_CHK2 WITH EDGE E_CHK2
  G_CHK2 = C_CHK2 INTERACT F_CHK2 >= 2
  (A_CHK2 NOT G_CHK2) NOT INSIDE SRAM_WAIVE_N28
}
PP.A.3 { @ Enclosed area of PP, {{{{{PP NOT OD2} AND NW} SIZING 0.07 um} SIZING -0.14 um} SIZING 0.07 um}, {{{{{PP AND OD2} AND NW} SIZING 0.07 um} SIZING -0.14 um} SIZING 0.07 um}, except the rectangle pattern [with one of edge length = 0.33, any 2 inner vertexes space = 0.16 um, area (P1) >= 0.07] >= 0.108 
  A = AREA (HOLES PP INNER EMPTY) < PP_A_3
  B = AREA (RECTANGLE A) >= PP_A_4
  C = B WITH EDGE (LENGTH A == PP_A_4_L)
  D = INT C < GRID ABUT == 90 INTERSECTING ONLY REGION
  E = ENC [C] PP == PP_A_4_W OPPOSITE EXTENDED GRID MEASURE ALL
  F = D WITH EDGE E
  G = C INTERACT F >= 2
  A NOT G

  A_CHK1 = AREA (HOLES PP_CHK1 INNER EMPTY) < PP_A_3
  B_CHK1 = AREA (RECTANGLE A_CHK1) >= PP_A_4
  C_CHK1 = B_CHK1 WITH EDGE (LENGTH A_CHK1 == PP_A_4_L)
  D_CHK1 = INT C_CHK1 < GRID ABUT == 90 INTERSECTING ONLY REGION
  E_CHK1 = ENC [C_CHK1] PP_CHK1 == PP_A_4_W OPPOSITE EXTENDED GRID MEASURE ALL
  F_CHK1 = D_CHK1 WITH EDGE E_CHK1
  G_CHK1 = C_CHK1 INTERACT F_CHK1 >= 2
  A_CHK1 NOT G_CHK1

  A_CHK2 = AREA (HOLES PP_CHK2 INNER EMPTY) < PP_A_3
  B_CHK2 = AREA (RECTANGLE A_CHK2) >= PP_A_4
  C_CHK2 = B_CHK2 WITH EDGE (LENGTH A_CHK2 == PP_A_4_L)
  D_CHK2 = INT C_CHK2 < GRID ABUT == 90 INTERSECTING ONLY REGION
  E_CHK2 = ENC [C_CHK2] PP_CHK2 == PP_A_4_W OPPOSITE EXTENDED GRID MEASURE ALL
  F_CHK2 = D_CHK2 WITH EDGE E_CHK2
  G_CHK2 = C_CHK2 INTERACT F_CHK2 >= 2
  A_CHK2 NOT G_CHK2
}

PP.A.5 { @ Area of butted PW STRAP >= 0.021 
  (AREA BUTT_PSTP < PP_A_5) NOT INSIDE SRAM_WAIVE_N28
}  

EXGATE_PP_CORE = SIZE (GATE_PP NOT OD2) BY PP_R_1
PP.R.1 { @ PP must fully cover {Core PMOS GATE SIZING 0.065 um}   
  (EXGATE_PP_CORE NOT PP) NOT INSIDE SRAM_WAIVE_N28
}

EXGATE_PP_IO = SIZE (GATE_PP AND OD2) BY PP_R_2
PP.R.2 { @ PP must fully cover {I/O PMOS GATE SIZING 0.13 um}   
  EXGATE_PP_IO NOT PP
}

PP.R.3 { @ Overlap of NP is not allowed   
  PP AND NP
}


// PP.R.4 is checked by OD.R.1

// PP.R.5 is checked by PP.EN.1



//NP CHECKS
//=========

NP_BEDGE = NP INSIDE EDGE OD   

NP.W.1 { @ Width >= 0.16 
  (INT NP < NP_W_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
NP.S.1 { @ Space >= 0.16 
  EXT NP < NP_S_1 ABUT < 90 SINGULAR REGION
}

NP.S.2 { @ Space if at least one NP width < 0.22 um. DRC can flag opposite side only >= 0.22 
  A = INT [NP] < NP_S_2_W OPPOSITE ABUT < 90 SINGULAR   
  (EXT A NP < NP_S_2 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28
}
NP.S.3 { @ Space to P+ ACTIVE (non-butted) >= 0.065 
  (EXT NP PACT < NP_S_3 ABUT < 90 > 0 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  X = EXT NP [PACT] < 0.001 ABUT == 0
  Y = EXPAND EDGE X OUTSIDE BY 0.001
  (Y NOT INTERACT NPOD) NOT INSIDE SRAM_WAIVE_N28
}

// NP.S.4 is checked by NP.S.3 and PP.R.3

NP.S.5 { @ Space to PW STRAP (non-butted) >= 0.02 
  (EXT NP PSTP < NP_S_5 ABUT < 90 > 0 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  X = EXT NP [PSTP] < 0.001 ABUT == 0
  Y = EXPAND EDGE X OUTSIDE BY 0.001
  (Y NOT INTERACT NPOD) NOT INSIDE SRAM_WAIVE_N28
}
NP.S.6 { @ {NP edge on OD} space to PMOS GATE >= 0.16 
  (EXT GATEP_W NP_BEDGE < NP_S_6 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28
}

EX_GATEP = EXPAND EDGE GATEP_W OUTSIDE BY NP_S_7 EXTEND BY NP_S_7_J

NP.S.7 { @ Butted NW STRAP space to PO in the same OD [the butted P+ ACTIVE extending 0 < J1 < 0.08 um] >= 0.16 
  A = EX_GATEP AND BUTT_NSTP
  B = EX_GATEP AND PACT
  C = A INTERACT B
  D = SD INTERACT C
  E = GATEP_W COIN OUTSIDE EDGE D
  F = EXPAND EDGE E OUTSIDE BY NP_S_7 EXTEND BY NP_S_7_J
  (C AND F) NOT INSIDE SRAM_WAIVE_N28
}
NP.S.8 { @ Space to P-type unsilicided OD resistor or high R resistor >= 0.1 
  EXT NP (PP AND ODRES_US) < NP_S_8 ABUT < 90 SINGULAR REGION
  EXT NP RES_High_R < NP_S_8 ABUT < 90 SINGULAR REGION MEASURE ALL
}


NP.S.9 { @ Space [parallel run length > 0.33 um, NP space NOT INTERACT {{OD OR SR_DOD} OR DOD}] >= 0.25 
  X = EXT NP < NP_S_9 OPPOSITE REGION
  Y = X NOT INTERACT ALL_OD
  ENCLOSE RECTANGLE Y GRID NP_S_9_L+GRID ORTHOGONAL ONLY
}



// NP.EN.1 is checked by PP.EN.1

NP.EX.1 { @ Extension on N+ ACTIVE >= 0.065 
  A = NACT NOT ODWR
  (ENC A NP < NP_EX_1 ABUT < 90 > 0 SINGULAR REGION) NOT INSIDE (SRAM_WAIVE_N28 OR N1VNIX)
  X = ENC [A] NP < 0.001 ABUT == 0
  Y = EXPAND EDGE X OUTSIDE BY 0.001
  (Y NOT INTERACT PPOD) NOT INSIDE SRAM_WAIVE_N28
  ((EXPAND EDGE ODIMP1 INSIDE BY 0.001) AND NACT) NOT INSIDE (SRAM_WAIVE_N28 OR N1VNIX)
}
NP.EX.2 { @ Extension on NW STRAP >= 0.02 
  (ENC NSTP NP < NP_EX_2 ABUT < 90 > 0 SINGULAR REGION) NOT INSIDE (SRAM_WAIVE_N28 OR N1VNIX)
  X = ENC [NSTP] NP < 0.001 ABUT == 0
  Y = EXPAND EDGE X OUTSIDE BY 0.001
  (Y NOT INTERACT PPOD) NOT INSIDE SRAM_WAIVE_N28
  ((EXPAND EDGE ODIMP1 INSIDE BY 0.001) AND NSTP) NOT INSIDE (SRAM_WAIVE_N28 OR N1VNIX)
}
NP.EX.3 { @ Extension on N-type unsilicided OD resistor >= 0.1 
  ENC ODRES_US NP < NP_EX_3 ABUT < 90 SINGULAR REGION
}
NP.EX.4 { @ {NP edge on OD} extension on NMOS GATE >= 0.16 
  (ENC GATEN_W NP_BEDGE < NP_EX_4 ABUT < 90 OPPOSITE REGION) NOT INSIDE (SRAM_WAIVE_N28 OR GATED)
}
NP.O.1 { @ Overlap of OD >= 0.08 
  (INT OD NP < NP_O_1  ABUT < 90 > 0 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
NP.L.1 { @ 45-degree edge length >= 0.5 
  NP_EDGE_45 = NP ANGLE == 45 
  LENGTH NP_EDGE_45 < NP_L_1    
}

NP_CHK1 = SIZE (SIZE (SIZE (((NP NOT OD2) NOT NWEL) OR NTN) BY 0.07) BY -0.14) BY 0.07
NP_CHK2 = SIZE (SIZE (SIZE (((NP AND OD2) NOT NWEL) NOT NTN) BY 0.07) BY -0.14) BY 0.07

NP.A.1 { @ Area of NP, {{{{{{NP NOT OD2} NOT NW} OR NT_N} SIZING 0.07} SIZING -0.14} SIZING 0.07}, {{{{{{NP AND OD2} NOT NW} NOT NT_N} SIZING 0.07} SIZING -0.14} SIZING 0.07} >= 0.108. Rectangular area of NP, {{{{{{NP NOT OD2} NOT NW} OR NT_N} SIZING 0.07} SIZING -0.14} SIZING 0.07}, {{{{{{NP AND OD2} NOT NW} NOT NT_N} SIZING 0.07} SIZING -0.14} SIZING 0.07} [with one of edge length = 0.33 um, any two edge corners space = 0.16 um] >= 0.07
  A = AREA NP < NP_A_1
  B = AREA (RECTANGLE A) >= NP_A_2
  C = B WITH EDGE (LENGTH A == NP_A_2_L)
  D = INT C < GRID ABUT == 90 INTERSECTING ONLY REGION
  E = EXT [C] NP == NP_A_2_S OPPOSITE EXTENDED GRID
  F = D WITH EDGE E
  G = C INTERACT F >= 2
  A NOT G
  
  A_CHK1 = AREA NP_CHK1 < NP_A_1
  B_CHK1 = AREA (RECTANGLE A_CHK1) >= NP_A_2
  C_CHK1 = B_CHK1 WITH EDGE (LENGTH A_CHK1 == NP_A_2_L)
  D_CHK1 = INT C_CHK1 < GRID ABUT == 90 INTERSECTING ONLY REGION
  E_CHK1 = EXT [C_CHK1] NP_CHK1 == NP_A_2_S OPPOSITE EXTENDED GRID
  F_CHK1 = D_CHK1 WITH EDGE E_CHK1
  G_CHK1 = C_CHK1 INTERACT F_CHK1 >= 2
  A_CHK1 NOT G_CHK1

  A_CHK2 = AREA NP_CHK2 < NP_A_1
  B_CHK2 = AREA (RECTANGLE A_CHK2) >= NP_A_2
  C_CHK2 = B_CHK2 WITH EDGE (LENGTH A_CHK2 == NP_A_2_L)
  D_CHK2 = INT C_CHK2 < GRID ABUT == 90 INTERSECTING ONLY REGION
  E_CHK2 = EXT [C_CHK2] NP_CHK2 == NP_A_2_S OPPOSITE EXTENDED GRID
  F_CHK2 = D_CHK2 WITH EDGE E_CHK2
  G_CHK2 = C_CHK2 INTERACT F_CHK2 >= 2
  A_CHK2 NOT G_CHK2
}
NP.A.3 { @ Enclosed area of NP, {{{{{{NP NOT OD2} NOT NW} OR NT_N} SIZING 0.07} SIZING -0.14} SIZING 0.07}, {{{{{{NP AND OD2} NOT NW} NOT NT_N} SIZING 0.07} SIZING -0.14} SIZING 0.07} >= 0.108. Enclosed rectangular area of NP, {{{{{{NP NOT OD2} NOT NW} OR NT_N} SIZING 0.07} SIZING -0.14} SIZING 0.07}, {{{{{{NP AND OD2} NOT NW} NOT NT_N} SIZING 0.07} SIZING -0.14} SIZING 0.07} [with one of edge length = 0.33 um, any two edge corners width = 0.16 um] >= 0.07
  A = AREA (HOLES NP INNER EMPTY) < NP_A_3
  B = AREA (RECTANGLE A) >= NP_A_4
  C = B WITH EDGE (LENGTH A == NP_A_4_L)
  D = INT C < GRID ABUT == 90 INTERSECTING ONLY REGION
  E = ENC [C] NP == NP_A_4_W OPPOSITE EXTENDED GRID MEASURE ALL
  F = D WITH EDGE E
  G = C INTERACT F >= 2
  (A NOT G) NOT INSIDE SRAM_WAIVE_N28

  A_CHK1 = AREA (HOLES NP_CHK1 INNER EMPTY) < NP_A_3
  B_CHK1 = AREA (RECTANGLE A_CHK1) >= NP_A_4
  C_CHK1 = B_CHK1 WITH EDGE (LENGTH A_CHK1 == NP_A_4_L)
  D_CHK1 = INT C_CHK1 < GRID ABUT == 90 INTERSECTING ONLY REGION
  E_CHK1 = ENC [C_CHK1] NP_CHK1 == NP_A_4_W OPPOSITE EXTENDED GRID MEASURE ALL
  F_CHK1 = D_CHK1 WITH EDGE E_CHK1
  G_CHK1 = C_CHK1 INTERACT F_CHK1 >= 2
  (A_CHK1 NOT G_CHK1) NOT INSIDE SRAM_WAIVE_N28

  A_CHK2 = AREA (HOLES NP_CHK2 INNER EMPTY) < NP_A_3
  B_CHK2 = AREA (RECTANGLE A_CHK2) >= NP_A_4
  C_CHK2 = B_CHK2 WITH EDGE (LENGTH A_CHK2 == NP_A_4_L)
  D_CHK2 = INT C_CHK2 < GRID ABUT == 90 INTERSECTING ONLY REGION
  E_CHK2 = ENC [C_CHK2] NP_CHK2 == NP_A_4_W OPPOSITE EXTENDED GRID MEASURE ALL
  F_CHK2 = D_CHK2 WITH EDGE E_CHK2
  G_CHK2 = C_CHK2 INTERACT F_CHK2 >= 2
  (A_CHK2 NOT G_CHK2) NOT INSIDE SRAM_WAIVE_N28
}

NP.A.5 { @ Area of butted NW STRAP >= 0.021 
  (AREA BUTT_NSTP < NP_A_5) NOT INSIDE SRAM_WAIVE_N28
}  

EXGATE_NP_CORE = SIZE (GATE_NP NOT OD2) BY NP_R_1
NP.R.1 { @ NP must fully cover {Core NMOS GATE SIZING 0.065 um}   
  (EXGATE_NP_CORE NOT NP) NOT INSIDE SRAM_WAIVE_N28
}

EXGATE_NP_IO = SIZE (GATE_NP AND OD2) BY NP_R_2
NP.R.2 { @ NP must fully cover {I/O NMOS GATE SIZING 0.13 um}   
  EXGATE_NP_IO NOT NP
}

// NP.R.3 is checked by PP.R.3



// NP.R.4 is checked by OD.R.1

// NP.R.5 is checked by PP.EN.1



// SSD CHECKS
//============

#IFDEF FULL_CHIP
SSD.DN.1 {@ Strained S/D (mask ID: 123) open ratio should be >= 6% and be as uniform as possible over the chip DRC methodology: Minimum {{{{{PP AND NW} NOT {{{{{{{{RH_OD OR RH_PO} OR VAR} OR SR_ESD} OR OD2} OR BJTDMY} OR DIODMY} OR {{NP AND NW} NOT SRM}} OR {AVTP OR AVTP2}}} OR {DOD AND PP}} AND {{OD OR DOD} OR SR_DOD}} NOT {{PO OR DPO} OR SR_DPO}} density across full chip >= 6% >= 6% 
  SSD = ((((PPi AND NWi) NOT ((((((((RHOD OR RHPO) OR VARi) OR SRESD) OR OD2i) OR BJTDMY) OR DIODMY) OR ((NPi AND NWi) NOT SRM)) OR (AVTP OR AVTP2))) OR (DOD AND PPi)) AND ((OD OR DOD) OR SRDOD)) NOT ((POi OR DPO) OR SRDPO)
  DENSITY SSD < SSD_DN_1 INSIDE OF LAYER CHIPx PRINT SSD.DN.1.density RDB SSD.DN.1.RDB.density
}

#ENDIF




//DIODMY CHECKS
//=========

DIODMY_PACT = DIODMY INTERACT PACT

DIODMY.W.1 { @ Width of DIODMY [INTERACT P+ ACTIVE] >= 0.16 
  INT DIODMY_PACT < DIODMY_W_1 ABUT < 90 SINGULAR REGION
}

DIODMY.S.1 { @ Space of DIODMY [INTERACT P+ ACTIVE] >= 0.16 
  EXT DIODMY_PACT < DIODMY_S_1 ABUT < 90 SINGULAR REGION
}

DIODMY.S.2 { @ DIODMY [INTERACT P+ ACTIVE] space to P+ ACTIVE ({P+ ACTIVE CUT DIODMY} is not allowed) >= 0.065 
  EXT DIODMY_PACT PACT < DIODMY_S_2 ABUT < 90 SINGULAR REGION
  PACT CUT DIODMY
}

DIODMY.EN.1 { @ Enclosure of P+ ACTIVE [NOT INTERACT {{PO OR SR_DPO} OR RH_OD} but INTERACT CO] >= 0.065 
  PACT_CHK = (PACT NOT INTERACT (SR_POLY OR RHOD)) INTERACT CO  
  ENC PACT_CHK DIODMY < DIODMY_EN_1 ABUT < 90 SINGULAR REGION
}

DIODMY.A.1 { @ Area of DIODMY [INTERACT P+ ACTIVE] >= 0.108 
  AREA DIODMY_PACT < DIODMY_A_1
}

DIODMY.A.2 { @ Enclosed area of DIODMY [INTERACT P+ ACTIVE] >= 0.108 
  A = (HOLES DIODMY_PACT INNER) NOT DIODMY_PACT
  AREA A < DIODMY_A_2
}
DIODMY.R.1 { @ Core P+ ACTIVE [NOT INTERACT {{PO OR SR_DPO} OR RH_OD} but INTERACT CO] must be covered by DIODMY (This check doesn't include the regions covered by BJTDMY and HIA_DUMMY)   
  ((((PACT NOT OD2) NOT INTERACT ((POLY OR SRDPO) OR RHOD)) INTERACT CO) NOT DIODMY) NOT INSIDE (BJTDMY OR HIADMY)      
}
DIODMY.R.2 { @ Overlap of DOD, and {OD INTERACT {PO OR SR_DPO}} is not allowed   
  DIODMY AND DOD      
  DIODMY AND (OD INTERACT SR_POLY)
}

DIODMY_L.R.2 { @ DIODMY_L must be drawn identically to DIODMY. (DIODMY_L can't be stand-alone without DIODMY)   
  A = DIODMY INTERACT DIODMY_L
  DIODMY_L XOR A
}



//LOGICAL OPERATION RULE
//======================

LDN.EX.1 { @ NP extension on NW >= 0.16 

  A = ENC NWEL NP < LDN_EX_1 ABUT > 0 < 90 OPPOSITE REGION
  B = ENC NWEL [NP] < LDN_EX_1 ABUT == 0 OPPOSITE 
  (NOT ENCLOSE RECTANGLE A GRID LDN_EX_1 ORTHOGONAL ONLY) NOT INSIDE SRAM_WAIVE_N28
  (LENGTH B < LDN_EX_1) NOT INSIDE EDGE SRAM_WAIVE_N28
  (ENC NWEL NP < LDN_EX_1 ABUT > 0 < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (ENC NWEL NP < LDN_EX_1 ABUT > 0 < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28
  (EXT (NP NOT NWEL) < LDN_EX_1 ABUT > 0 < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (EXT (NP NOT NWEL) < LDN_EX_1 ABUT > 0 < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28
	
}
LDN.EX.2 { @ NP extension on OD2 >= 0.16 

  A = ENC OD2 NP < LDN_EX_2 ABUT > 0 < 90 OPPOSITE REGION
  B = ENC OD2 [NP] < LDN_EX_2 ABUT == 0 OPPOSITE 
  NOT ENCLOSE RECTANGLE A GRID LDN_EX_2 ORTHOGONAL ONLY
  LENGTH B < LDN_EX_2
  ENC OD2 NP < LDN_EX_2 ABUT > 0 < 90 CORNER SINGULAR REGION  
  ENC OD2 NP < LDN_EX_2 ABUT > 0 < 90 PROJ == 0 REGION 
  EXT (NP NOT OD2) < LDN_EX_2 ABUT > 0 < 90 CORNER SINGULAR REGION  
  EXT (NP NOT OD2) < LDN_EX_2 ABUT > 0 < 90 PROJ == 0 REGION
	
}
LDN.EX.3 { @ NP extension on {{RH_OD OR RH_PO} OR BJTDMY} >= 0.16 
CHECK_LAYER = (RHOD OR RHPO) OR BJTDMY
  A = ENC CHECK_LAYER NP < LDN_EX_3 ABUT > 0 < 90 OPPOSITE REGION
  B = ENC CHECK_LAYER [NP] < LDN_EX_3 ABUT == 0 OPPOSITE 
  NOT ENCLOSE RECTANGLE A GRID LDN_EX_3 ORTHOGONAL ONLY
  LENGTH B < LDN_EX_3
  ENC CHECK_LAYER NP < LDN_EX_3 ABUT > 0 < 90 CORNER SINGULAR REGION  
  ENC CHECK_LAYER NP < LDN_EX_3 ABUT > 0 < 90 PROJ == 0 REGION 
  EXT (NP NOT CHECK_LAYER) < LDN_EX_3 ABUT > 0 < 90 CORNER SINGULAR REGION  
  EXT (NP NOT CHECK_LAYER) < LDN_EX_3 ABUT > 0 < 90 PROJ == 0 REGION
}
LDN.EX.4 { @ NP extension on VAR >= 0.16 
  A = ENC VAR NP < LDN_EX_4 ABUT > 0 < 90 OPPOSITE REGION
  B = ENC VAR [NP] < LDN_EX_4 ABUT == 0 OPPOSITE 
  NOT ENCLOSE RECTANGLE A GRID LDN_EX_4 ORTHOGONAL ONLY
  LENGTH B < LDN_EX_4
  ENC VAR NP < LDN_EX_4 ABUT > 0 < 90 CORNER SINGULAR REGION  
  ENC VAR NP < LDN_EX_4 ABUT > 0 < 90 PROJ == 0 REGION 
  EXT (NP NOT VAR) < LDN_EX_4 ABUT > 0 < 90 CORNER SINGULAR REGION  
  EXT (NP NOT VAR) < LDN_EX_4 ABUT > 0 < 90 PROJ == 0 REGION
}
LDN.O.1 { @ NP overlap of OD2 >= 0.16 
  A = INT OD2 NP < LDN_O_1 ABUT >0 < 90 OPPOSITE REGION
  B = INT OD2 [NP] < LDN_O_1 ABUT == 0 OPPOSITE 
  NOT ENCLOSE RECTANGLE A GRID LDN_O_1 ORTHOGONAL ONLY
  LENGTH B < LDN_O_1
  INT OD2 NP < LDN_O_1 ABUT > 0 < 90 CORNER SINGULAR REGION  
  INT OD2 NP < LDN_O_1 ABUT > 0 < 90 PROJ == 0 REGION 
  EXT (OD2 AND NP) < LDN_O_1 ABUT > 0 < 90 CORNER SINGULAR REGION  
  EXT (OD2 AND NP) < LDN_O_1 ABUT > 0 < 90 PROJ == 0 REGION 
}
LDP.EX.1 { @ PP extension on OD2 >= 0.16 
  A = ENC OD2 PP < LDP_EX_1 ABUT > 0 < 90 OPPOSITE REGION
  B = ENC OD2 [PP] < LDP_EX_1 ABUT == 0 OPPOSITE 
  (NOT ENCLOSE RECTANGLE A GRID LDP_EX_1 ORTHOGONAL ONLY) NOT INSIDE SRAM_WAIVE_N28
  (LENGTH B < LDP_EX_1) NOT INSIDE EDGE SRAM_WAIVE_N28
  (ENC OD2 PP < LDP_EX_1 ABUT > 0 < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (ENC OD2 PP < LDP_EX_1 ABUT > 0 < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28
  (EXT (PP NOT OD2) < LDP_EX_1 ABUT > 0 < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (EXT (PP NOT OD2) < LDP_EX_1 ABUT > 0 < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28
}
LDP.EX.2 { @ PP extension on {{RH_OD OR RH_PO} OR BJTDMY} >= 0.16 
  CHECK_LAYER = (RHOD OR RHPO) OR BJTDMY
  A = ENC CHECK_LAYER PP < LDP_EX_2 ABUT > 0 < 90 OPPOSITE REGION
  B = ENC CHECK_LAYER [PP] < LDP_EX_2 ABUT == 0 OPPOSITE 
  (NOT ENCLOSE RECTANGLE A GRID LDP_EX_2 ORTHOGONAL ONLY) NOT INSIDE SRAM_WAIVE_N28
  (LENGTH B < LDP_EX_2) NOT INSIDE EDGE SRAM_WAIVE_N28
  (ENC CHECK_LAYER PP < LDP_EX_2 ABUT > 0 < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (ENC CHECK_LAYER PP < LDP_EX_2 ABUT > 0 < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28
  (EXT (PP NOT CHECK_LAYER) < LDP_EX_2 ABUT > 0 < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (EXT (PP NOT CHECK_LAYER) < LDP_EX_2 ABUT > 0 < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28
}

LDP.EX.3 { @ PP extension on VAR >= 0.16 
  A = ENC VAR PP < LDP_EX_3 ABUT > 0 < 90 OPPOSITE REGION
  B = ENC VAR [PP] < LDP_EX_3 ABUT == 0 OPPOSITE 
  (NOT ENCLOSE RECTANGLE A GRID LDP_EX_3 ORTHOGONAL ONLY) NOT INSIDE SRAM_WAIVE_N28
  (LENGTH B < LDP_EX_3) NOT INSIDE EDGE SRAM_WAIVE_N28
  (ENC VAR PP < LDP_EX_3 ABUT > 0 < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (ENC VAR PP < LDP_EX_3 ABUT > 0 < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28
  (EXT (PP NOT VAR) < LDP_EX_3 ABUT > 0 < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (EXT (PP NOT VAR) < LDP_EX_3 ABUT > 0 < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28

}
LDP.O.1 { @ PP overlap of NW >= 0.16 
  A = INT NWEL PP < LDP_O_1 ABUT >0 < 90 OPPOSITE REGION
  B = INT NWEL [PP] < LDP_O_1 ABUT == 0 OPPOSITE 
  NOT ENCLOSE RECTANGLE A GRID LDP_O_1 ORTHOGONAL ONLY
  LENGTH B < LDP_O_1
  INT NWEL PP < LDP_O_1 ABUT > 0 < 90 CORNER SINGULAR REGION  
  INT NWEL PP < LDP_O_1 ABUT > 0 < 90 PROJ == 0 REGION 
  EXT (NWEL AND PP) < LDP_O_1 ABUT > 0 < 90 CORNER SINGULAR REGION  
  EXT (NWEL AND PP) < LDP_O_1 ABUT > 0 < 90 PROJ == 0 REGION 
}
LDP.O.2 { @ PP overlap of OD2 >= 0.16 
  A = INT OD2 PP < LDP_O_2 ABUT >0 < 90 OPPOSITE REGION
  B = INT OD2 [PP] < LDP_O_2 ABUT == 0 OPPOSITE 
  NOT ENCLOSE RECTANGLE A GRID LDP_O_2 ORTHOGONAL ONLY
  LENGTH B < LDP_O_2
  INT OD2 PP < LDP_O_2 ABUT > 0 < 90 CORNER SINGULAR REGION  
  INT OD2 PP < LDP_O_2 ABUT > 0 < 90 PROJ == 0 REGION 
  EXT (OD2 AND PP) < LDP_O_2 ABUT > 0 < 90 CORNER SINGULAR REGION  
  EXT (OD2 AND PP) < LDP_O_2 ABUT > 0 < 90 PROJ == 0 REGION 
}


// ESDIMP CHECKS
//==============

ESDIMP.W.1 { @ Width >= 0.5 
  INT ESDIMP < ESDIMP_W_1 ABUT < 90 SINGULAR REGION
}
ESDIMP.S.1 { @ Space >= 0.5 
  EXT ESDIMP < ESDIMP_S_1 ABUT < 90 SINGULAR REGION
}
ESDIMP.EN.1 { @ {OD NOT PO} enclosure of ESDIMP. ESDIMP must be fully inside {OD NOT PO} >= 0.4 
  OD_NPO = OD NOT POLY
  ENC ESDIMP OD_NPO < ESDIMP_EN_1 ABUT < 90 SINGULAR REGION
  ESDIMP NOT OD_NPO
}
ESDIMP.A.1 { @ Area >= 1 
  AREA ESDIMP < ESDIMP_A_1
}
ESDIMP.A.2 { @ Enclosed area >= 1 
  A = HOLES ESDIMP INNER
  B = A NOT ESDIMP
  AREA B < ESDIMP_A_2
}
ESDIMP.R.1 { @ ESDIMP must be fully inside N+ ACTIVE   
  ESDIMP NOT NACT
}



//RPO CHECKS
//==========
Wide_RPO   = RPO INTERACT (WITH WIDTH RPO > RPO_EX_2_W)
Small_RPO  = RPO INTERACT (WITH WIDTH RPO <= RPO_EX_3_W)

RPO.W.1 { @ Width >= 0.32 
  INT RPO < RPO_W_1 ABUT < 90 SINGULAR REGION
}
RPO.S.1 { @ Space >= 0.32 
  EXT RPO < RPO_S_1 ABUT < 90 SINGULAR REGION
}
RPO.S.2 { @ Space to OD >= 0.22 
  EXT RPO OD < RPO_S_2 ABUT < 90 SINGULAR REGION
}




RPO.S.3 { @ Space to CO (overlap of CO is not allowed.) >= 0.12 
  (EXT RPO CO < RPO_S_3 ABUT < 90 SINGULAR REGION) NOT INSIDE (SEALRING_ALL OR ICOVL)
  (RPO AND CO) NOT INSIDE (SEALRING_ALL OR ICOVL)
}


RPO.S.4 { @ Space to GATE (overlap of GATE is not allowed except ESD circuit.) >= 0.38 
  NOGT = GATE NOT (SDI OR (RPO_DEVICE OR (ANALOG_DEVICE INTERACT RPO))) 
  (EXT RPO NOGT < RPO_S_4 ABUT < 90 SINGULAR REGION) NOT INSIDE ICOVL
  (RPO AND NOGT) NOT INSIDE ICOVL
}
RPO.S.5 { @ Space to PO >= 0.3 
  EXT RPO FPO1 < RPO_S_5 ABUT < 90 SINGULAR REGION
}
RPO.EX.1 { @ Extension on unsilicided OD resistor or high R resistor >= 0.22 
  ENC (OD AND RHOD) RPO < RPO_EX_1 ABUT < 90 SINGULAR REGION
  ENC (POLY AND RHPO) RPO < RPO_EX_1 ABUT < 90 SINGULAR REGION
  RPO INSIDE (OD AND RHOD)
  RPO INSIDE (POLY AND RHPO)
}
RPO.EX.2 { @ Extension on unsilicided OD resistor or high R resistor [RPO width and length > 10 um] >= 0.3 
  ENC (OD AND RHOD) Wide_RPO < RPO_EX_2 ABUT < 90 SINGULAR REGION
  ENC (POLY AND RHPO) Wide_RPO < RPO_EX_2 ABUT < 90 SINGULAR REGION
}
RPO.EX.3 { @ Extension on unsilicided OD resistor or high R resistor [RPO width <= 0.43 um] >= 0.3 
  ENC (OD AND RHOD) Small_RPO < RPO_EX_3 ABUT < 90 SINGULAR REGION
  ENC (POLY AND RHPO) Small_RPO < RPO_EX_3 ABUT < 90 SINGULAR REGION
}

RPO.EX.4 { @ OD extension on RPO >= 0.22 
  ENC RPO OD < RPO_EX_4 ABUT < 90 SINGULAR REGION
}
RPO.EX.5 { @ {SR_DOD OR DOD} extension on RPO >= 0.12 
  ENC RPO SRDOD < RPO_EX_5 ABUT < 90 SINGULAR REGION
  ENC RPO DOD < RPO_EX_5 ABUT < 90 SINGULAR REGION      
}
RPO.A.1 { @ Area of RPO [NOT INSIDE RH_PO] >= 0.9 
  AREA (RPO NOT INSIDE RHPO) < RPO_A_1 
}

RPO.A.3 { @ Area of RPO [INSIDE RH_PO] >= 0.26 
  AREA (RPO INSIDE RHPO) < RPO_A_3 
}

RPO.A.2 { @ Enclosed area >= 0.9 
  A = HOLES RPO INNER
  B = A NOT RPO
  (AREA B < RPO_A_2) NOT INSIDE SEALRING_ALL
}
RPO.R.1 { @ Butted NP/PP on unsilicided OD resistor or high R resistor is not allowed   
  X = ((RPO AND POLY) AND RHPO) OR ((RPO AND OD) AND RHOD)
  NX = X AND NP
  PX = X AND PP    
  Y  = NX INTERACT PX
  X INTERACT Y
}

//RH_OD CHECKS
//=================

ODRES_SILICIDE = COPY ODRES_SI
ODRES_UNSILICIDE = COPY ODRES_US
SRDPO_RHOD = SRDPO AND RHOD
OD_RHOD    = OD AND RHOD
ODRES_L = ODRES NOT INSIDE EDGE OD  

RH_OD.W.1 { @ Width of unsilicided OD resistor >= 0.4 
  INT ODRES_UNSILICIDE < RH_OD_W_1 ABUT < 90 SINGULAR REGION
}

RH_OD.W.2 { @ Maximum width of OD resistor <= 5 
  A = ODRES_UNSILICIDE TOUCH INSIDE EDGE RPO  
  PATH LENGTH A > RH_OD_W_2 
  ODRES_SILICIDE WITH WIDTH > RH_OD_W_2
}

SRDPO_ODRES = (SRDPO AND RPO) AND RHOD

RH_OD.W.3 { @ Width of {SR_DPO AND RH_OD} in width direction = 0.15~1 
  SRDPO_L = EXT ODRES_L [SRDPO_RHOD] >= RH_OD_S_5A <=RH_OD_S_5B OPPOSITE EXCLUDE SHIELDED 4
  INT SRDPO_L SRDPO_RHOD < RH_OD_W_3 ABUT<90 OPPOSITE REGION
  INT (SRDPO_L) SRDPO_RHOD <= RH_OD_W_3_A ABUT<90 OPPOSITE
}
RH_OD.S.4 { @ RH_OD space to OD (OD CUT RH_OD is not allowed) >= 0.16 
  EXT RHOD OD < RH_OD_S_4 ABUT < 90 SINGULAR REGION 
  OD CUT RHOD
}
RH_OD.S.5 { @ OD resistor space to {SR_DPO AND RH_OD} in width direction >= 0.04 <=0.4
  EXT [ODRES_L] SRDPO_RHOD < RH_OD_S_5A OPPOSITE
  EXT (ODRES_L) SRDPO_RHOD <= RH_OD_S_5B OPPOSITE
}
RH_OD.EN.2 { @ RH_OD enclosure of {RH_OD AND OD} >= 0.19 
  ENC (RHOD AND OD) RHOD < RH_OD_EN_2 ABUT < 90 SINGULAR REGION 
}
//RH_OD.EN.3 is checked by RH_OD.R.6
RH_OD.L.1 { @ Length of unsilicided OD resistor >= 0.4 
  RES_L = ODRES_UNSILICIDE INSIDE EDGE RPO
  X = PATH LENGTH RES_L < RH_OD_L_1
  CHECK_RES = ODRES_UNSILICIDE WITH EDGE X
  RES_E = CHECK_RES COIN INSIDE EDGE RPO
  A = EXPAND EDGE RES_E INSIDE BY GRID
  B = SIZE A BY (RH_OD_L_1/2 - GRID*2) INSIDE OF ODRES_UNSILICIDE STEP PO_S_3*0.7  
  C = CHECK_RES NOT B 
  CHECK_RES NOT INTERACT C
  D = INT C < GRID*2 ABUT < 90 REGION
  CHECK_RES INTERACT D
}
RH_OD.L.2 { @ Maximum length of {OD AND RH_OD} of unsilicided OD resistor <= 100 
  A = (OD AND RHOD) TOUCH EDGE ((OD AND RHOD) INSIDE EDGE RPO)
  PATH LENGTH A > RH_OD_L_2      
}

OD_RES_RPO_L = EXPAND EDGE (ODRES_US NOT INSIDE EDGE OD) BY GRID
OD_RES_RPO_W = EXPAND EDGE (ODRES_US INSIDE EDGE OD) BY GRID
CONNECT OD_RES_RPO_L OD_RES_RPO_W

RH_OD.R.1 { @ Square number (length/width) of unsilicided OD resistor must be >= 1 (This check doesn't include the region covered by RHDMY1 (117;4) for non-precision usage)   
  (NET AREA RATIO OD_RES_RPO_L OD_RES_RPO_W < RH_OD_R_1) NOT INSIDE RHDMY1
}

RH_OD.R.2 { @ RPO intersecting {RH_OD AND OD} must form 2 or more ODs for unsilicided OD resistor   
  OD_END = (OD INTERACT ODRES_UNSILICIDE) NOT ODRES_UNSILICIDE     
  ODRES_UNSILICIDE NOT INTERACT OD_END >= 2
}

RH_OD.R.5 { @ For OD resistor must be fully covered by RH_OD DRC can flag: {{OD AND RPDMY} NOT RH_OD}   
  (OD AND RPDMY) NOT RHOD
}

RH_OD.R.6 { @ {SR_DPO INTERACT RH_OD} must be fully covered by RH_OD. And the number of SR_DPO [INTERACT RH_OD] must be >= 2   
  (SRDPO INTERACT RHOD) NOT RHOD
  RHOD NOT INTERACT SRDPO >= 2
}
RH_OD.R.7 { @ In same RPO, either the length of {{OD OR SR_DPO} AND RH_OD} or the length of {{{OD OR SR_DPO} AND RH_OD} AND {RPO SIZING 0.16 um}} in length direction of unsilicided OD resistor must be the same  
  X = SRDPO_RHOD OR OD_RHOD
  INSIDE_E1 = EXPAND EDGE (X INSIDE EDGE RPO) INSIDE BY 0.001 EXTEND BY RH_OD_R_7   
  CHECK_EDGEA = X COIN INSIDE EDGE INSIDE_E1 
  CHECK_EDGEB = X TOUCH INSIDE EDGE INSIDE_E1 
  A = DFM PROPERTY RPO CHECK_EDGEA OVERLAP ABUT ALSO MULTI
  [-= MAX(LENGTH(CHECK_EDGEA)) - MIN(LENGTH(CHECK_EDGEA)) ] != 0
  DFM PROPERTY A CHECK_EDGEB OVERLAP ABUT ALSO MULTI
  [-= MAX(LENGTH(CHECK_EDGEB)) - MIN(LENGTH(CHECK_EDGEB)) ] != 0
}
RH_OD.R.10 { @ RPDMY intersecting {OD AND RH_OD} must form 2 or more ODs for silicided OD resistor   
  OD_END = (OD INTERACT ODRES_SI) NOT ODRES_SI     
  ODRES_SI NOT INTERACT OD_END >= 2
}
RH_OD.R.11 { @ OD resistor must be ACTIVE   
  ODRES NOT DACT 
}


//RH_PO CHECKS
//=============

PORES_SILICIDE = COPY RES_Metal_GATE
PORES_UNSILICIDE = COPY RES_High_R

RH_PO.W.1 { @  Width of high R resistor = ^RH_PO_W_1A ~ ^RH_PO_W_1B
  INT PORES_UNSILICIDE < RH_PO_W_1A ABUT < 90 SINGULAR REGION
  LENGTH (RPO COIN EDGE PORES_UNSILICIDE) > RH_PO_W_1B
}


RH_PO.W.5 { @ Width of SR_DPO of {RH_PO INTERACT RPO} region >= 0.06 
  SR_DPO_CHK = SRDPO AND (RHPO INTERACT RPO)
  INT SR_DPO_CHK < RH_PO_W_5 ABUT < 90 SINGULAR REGION
}



RH_PO.W.6 { @ Width of horizontal {PO OR SR_DPO} of {RH_PO INTERACT RPO} >= 0.1 
  (INT SR_POLY SR_POLY_HORIZONTAL < RH_PO_W_6 ABUT < 90 OPPOSITE REGION) INSIDE (RHPO INTERACT RPO) 
}

RH_PO.S.3 { @ RH_PO space to OD (overlap is not allowed) >= 0.16 
  (EXT RHPO OD < RH_PO_S_3 ABUT < 90 SINGULAR REGION INSIDE ALSO) NOT INSIDE ICOVL
}
RH_PO.S.4 { @ RH_PO space to SR_DOD (SR_DOD cut RH_PO is not allowed) >= 0.065 
  EXT RHPO SRDOD < RH_PO_S_4 ABUT < 90 SINGULAR REGION
  SRDOD CUT RHPO
}
RH_PO.S.6 { @ Space of {PO OR SR_DPO} of {RH_PO INTERACT RPO} region >= 0.16 
  SR_POLY_CHK = SR_POLY AND (RHPO INTERACT RPO)
  EXT SR_POLY_CHK < RH_PO_S_6 ABUT < 90 SINGULAR REGION
}




RH_PO.EN.2 { @ RH_PO enclosure of {RH_PO AND {PO OR SR_DPO}} >= 0.19 
  ENC (RHPO AND SR_POLY) RHPO < RH_PO_EN_2 ABUT < 90 SINGULAR REGION
}

PORES_SRDPO_EDGE_RPO = ((RPO NOT PORES_UNSILICIDE) NOT SRDPO) INTERACT (PORES_UNSILICIDE OR SRDPO) == 1
PORES_EDGE_RPO = (RPO NOT PORES_UNSILICIDE) INTERACT PORES_UNSILICIDE == 1

RH_PO.EN.3 { @ RH_PO enclosure of SR_DPO in width direction >= 0.22 
  PORES_EDGE_RPOx = PORES_EDGE_RPO NOT INTERACT PORES_SRDPO_EDGE_RPO  
  SRDPO_CHK1 = SRDPO TOUCH EDGE PORES_SRDPO_EDGE_RPO 
  SRDPO_CHK2a = SRDPO TOUCH EDGE ((SRDPO TOUCH OUTSIDE EDGE PORES_EDGE_RPOx) OR EDGE (SRDPO TOUCH INSIDE EDGE (SRDPO INSIDE EDGE PORES_EDGE_RPOx)))
  SRDPO_CHK2b = SRDPO TOUCH INSIDE EDGE (INT SRDPO_CHK2a [SRDPO] < GRID ABUT==90 INTERSECTING ONLY)
  SRDPO_CHK2 = ((SRDPO WITH EDGE SRDPO_CHK2a) NOT TOUCH INSIDE EDGE SRDPO_CHK2a) NOT TOUCH INSIDE EDGE SRDPO_CHK2b
  SRDPO_CHK = SRDPO_CHK1 OR EDGE SRDPO_CHK2
  ENC SRDPO_CHK RHPO < RH_PO_EN_3A ABUT < 90 REGION
  
  PORES_SILICIDE_L = PORES_SILICIDE NOT INSIDE EDGE POLY
  X2 = (EXT PORES_SILICIDE_L SRDPO <= 1 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE RHPO
  X3 = SRDPO INTERACT X2 == 1
  X3 NOT RHPO
  X4 = X3 TOUCH OUTSIDE EDGE X2
  X5 = X3 TOUCH INSIDE EDGE (INT X4 [X3] < GRID ABUT==90 INTERSECTING ONLY)
  X6 = (X3 NOT TOUCH INSIDE EDGE X4) NOT TOUCH INSIDE EDGE X5
  ENC X6 RHPO < RH_PO_EN_3A ABUT < 90 REGION
}  
RH_PO.EN.4 { @ RH_PO enclosure of {RH_PO AND SR_DOD} >= 0.065 
  ENC (SRDOD AND RHPO) RHPO < RH_PO_EN_4 ABUT < 90 SINGULAR REGION
}
RH_PO.L.1 { @ Length of high R resistor >= 0.4 
  RES_L = PORES_UNSILICIDE INSIDE EDGE RPO
  LENGTH RES_L < RH_PO_L_1 
}
RH_PO.L.2 { @ Maximum Length of {PO AND RH_PO} of high R resistor <= 25 
  A = (POLY AND RHPO) TOUCH EDGE (PORES_UNSILICIDE INSIDE EDGE RPO)
  LENGTH A > RH_PO_L_2   
}
RH_PO.A.1 { @ Area of {{PO AND RH_PO} NOT INTERACT RPO} >= 0.1 
  AREA ((POLY AND RHPO) NOT INTERACT RPO) < RH_PO_A_1
}
RH_PO.A.2 { @ Area of {{PO AND RH_PO} INTERACT RPO} >= 0.045 
  AREA ((POLY AND RHPO) INTERACT RPO) < RH_PO_A_2
}

PO_RES_RPO_L = EXPAND EDGE (PORES_US NOT INSIDE EDGE POLY) BY GRID
PO_RES_RPO_W = EXPAND EDGE (PORES_US INSIDE EDGE POLY) BY GRID
CONNECT PO_RES_RPO_L PO_RES_RPO_W

RH_PO.R.1 { @ Square number (length/width) of high R resistor must be >= 1 (This check doesn't include the region covered by RHDMY1 (117;4) for non-precision usage)   
  (NET AREA RATIO PO_RES_RPO_L PO_RES_RPO_W < RH_PO_R_1) NOT INSIDE RHDMY1
}





RH_PO.R.2 { @ RPO intersecting {PO AND RH_PO} must form 2 or more POs for high R resistor   
  PO_END = (POLY INTERACT PORES_UNSILICIDE) NOT PORES_UNSILICIDE     
  (PORES_UNSILICIDE NOT INTERACT PO_END >= 2) NOT INSIDE (SEALRING_ALL OR ICOVL)
}
RH_PO.R.5 { @ Metal gate and high R resistor must be fully covered by RH_PO DRC can flag: {{PO AND RPDMY} NOT RH_PO}   
   (POLY AND RPDMY) NOT RHPO
}
RH_PO.R.6 { @ {SR_DPO INTERACT RH_PO} must be fully covered by RH_PO. (SR_DPO must be placed 2-side beside metal gate and high R resistor array edge. This check doesn't include single high R resistor inside RFDMY or FCDMY) For each metal gate resistor, DRC flag no SR_DPO or other metal gate resistor within 1 um in width direction   
  RFC_DMY = RFDMY OR FCDMY
  WAIVE = (PORES_UNSILICIDE INSIDE RFC_DMY) INTERACT (RPO INTERACT PORES_UNSILICIDE == 1)   
  ((SRDPO INTERACT RHPO) NOT RHPO) NOT INSIDE (SEALRING_ALL OR ICOVL)
  ((RHPO NOT INTERACT SRDPO >= 2) NOT INSIDE (SEALRING_ALL OR ICOVL)) NOT INTERACT WAIVE
  ((PORES_EDGE_RPO NOT INTERACT SRDPO >= 1) NOT INSIDE (SEALRING_ALL OR ICOVL)) NOT INTERACT WAIVE
   PORES_SILICIDE_L = PORES_SILICIDE NOT INSIDE EDGE POLY
   X1 = (EXT PORES_SILICIDE_L <= 1 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE RHPO
   X2 = (EXT PORES_SILICIDE_L SRDPO <= 1 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE RHPO
   (PORES_SILICIDE_L NOT COIN OUTSIDE EDGE X1) NOT COIN OUTSIDE EDGE X2
}
RH_PO.R.7 { @ In same RPO, either the length of {{PO OR SR_DPO} AND RH_PO} or the length of {{{PO OR SR_DPO} AND RH_PO} AND {RPO SIZING 0.16 um}} in length direction of high R resistor must be the same
  INSIDE_E1 = EXPAND EDGE ((SR_POLY AND RHPO) INSIDE EDGE RPO) INSIDE BY 0.001 EXTEND BY RH_PO_R_7   
  CHECK_EDGEA = (SR_POLY COIN INSIDE EDGE INSIDE_E1) NOT INSIDE EDGE (SEALRING_ALL OR ICOVL)
  CHECK_EDGEB = (SR_POLY TOUCH INSIDE EDGE INSIDE_E1) NOT INSIDE EDGE (SEALRING_ALL OR ICOVL)
  A = DFM PROPERTY RPO CHECK_EDGEA OVERLAP ABUT ALSO MULTI
  [-= MAX(LENGTH(CHECK_EDGEA)) - MIN(LENGTH(CHECK_EDGEA)) ] != 0
  DFM PROPERTY A CHECK_EDGEB OVERLAP ABUT ALSO MULTI
  [-= MAX(LENGTH(CHECK_EDGEB)) - MIN(LENGTH(CHECK_EDGEB)) ] != 0
}

RH_PO.R.10 { @ {{PO OR SR_DPO} INSIDE RH_PO} must be a rectangle   
  (NOT RECTANGLE (SR_POLY INSIDE RHPO)) NOT INSIDE (SEALRING_ALL OR ICOVL)
}
RH_PO.R.11 { @ {{{PO OR SR_DPO} INTERACT RPO} AND RH_PO} must be fully inside {PP AND PMET}   
  (((SR_POLY INTERACT RPO) AND RHPO) NOT (PP AND PMET)) NOT INSIDE (SEALRING_ALL OR ICOVL)
}
RH_PO.R.12 { @ RPO cut RH_PO is not allowed   
  RPO CUT RHPO
}
RH_PO.R.14 { @ In same RPDMY, either the length of {{PO OR SR_DPO} AND RH_PO} or the length of {{{PO OR SR_DPO} AND RH_PO} AND {RPDMY SIZING 0.16 um}} in length direction of metal gate resistor must be the same
  RPDMY_CHECK = RPDMY INTERACT PORES_SILICIDE
  INSIDE_E1 = EXPAND EDGE ((SR_POLY AND RHPO) INSIDE EDGE RPDMY_CHECK) INSIDE BY 0.001 EXTEND BY RH_PO_R_14 
  CHECK_EDGEA = SR_POLY COIN INSIDE EDGE INSIDE_E1
  CHECK_EDGEB = SR_POLY TOUCH INSIDE EDGE INSIDE_E1
  A = DFM PROPERTY RPDMY_CHECK CHECK_EDGEA OVERLAP ABUT ALSO MULTI
  [-= MAX(LENGTH(CHECK_EDGEA)) - MIN(LENGTH(CHECK_EDGEA)) ] != 0
  DFM PROPERTY A CHECK_EDGEB OVERLAP ABUT ALSO MULTI
  [-= MAX(LENGTH(CHECK_EDGEB)) - MIN(LENGTH(CHECK_EDGEB)) ] != 0
}
RH_PO.R.13 { @ RPDMY intersecting {PO AND RH_PO} must form 2 or more POs for metal gate resistor   
  PO_END = (POLY INTERACT PORES_SILICIDE) NOT PORES_SILICIDE     
  PORES_SILICIDE NOT INTERACT PO_END >= 2
}

RH_PO.R.18 { @ {PO INTERACT {PO55 OR PO65}} must be inside {RH_PO INTERACT RPO}   
 RH_PO_R_18_CHECK = POLY INTERACT (PO55 OR PO65) 
 RH_PO_R_18_CHECK NOT INSIDE (RHPO INTERACT RPOi)
}

RH_PO.R.19 { @ {{DPO OR SR_DPO} INTERACT {PO55 OR PO65}} is not allowed   
  (DPO OR SRDPO) INTERACT (PO55 OR PO65)
}
RH_PO.R.20 { @ {PO INTERACT {PO55 OR PO65}} must be inside OD2   
  RH_PO_R_20_CHECK = POLY INTERACT (PO55 OR PO65)
  RH_PO_R_20_CHECK NOT INSIDE OD2
}

RH_PO.R.21 { @ {PO55 OR PO65} must be inside {PO NOT RPO}   
  (PO55 OR PO65) NOT INSIDE (POLY NOT RPOi)
}


RH_PO.R.22 { @ PO65V can't interact with PO55V   
  PO65V INTERACT PO55V
}

RH_PO.R.23 { @ {{{{RH_PO AND PO} NOT INTERACT RPO} AND RPDMY} AND NP} overlap with PMET is not allowed   
    RH_PO_R_23_CHECK = (((RHPO AND POLY) NOT INTERACT RPOi) AND RPDMY) AND NP
    RH_PO_R_23_CHECK AND PMET
}





// AVT CHECKS
//==============

AVT.W.1 { @ Width >= ^AVT_W_1   
  A = INT AVT < AVT_W_1 ABUT < 90 REGION PROJ==0
  B = EXT [AVT] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = INT B >= AVT_R_3_A < AVT_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = INT B >= AVT_R_3_B < AVT_W_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = INT AVT < AVT_W_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
AVT.S.1 { @ Space >= ^AVT_S_1 
  A = EXT AVT < AVT_S_1 ABUT < 90 REGION PROJ==0
  B = INT [AVT] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = EXT B >= AVT_R_3_A < AVT_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = EXT B >= AVT_R_3_B < AVT_S_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = EXT AVT < AVT_S_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
AVT.S.2__AVT.S.3 { @ Space to gate in PO endcap direction >= ^AVT_S_2 & in S/D direction >= ^AVT_S_3, AVT cut {ACTIVE OR GATE} is not allowed.
  A = GATE NOT INTERACT AVT
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (AVT_S_3 - AVT_S_2)) OR A
  C = SIZE B BY AVT_S_2
  AVT AND C
  DACT CUT AVT
  GATE CUT AVT
}
AVT.S.4 { @ Space to unsilicided OD or high R resistor >= ^AVT_S_4
  EXT AVT AYRE < AVT_S_4 ABUT < 90 SINGULAR REGION
  AND AVT AYRE    
}  
AVT.S.5 { @ Space [parallel run length > 0.33 um, AVT space without INTERACT {{OD OR SR_DOD} OR DOD}] >= ^AVT_S_5
  X = EXT AVT < AVT_S_5 OPPOSITE REGION
  Y = X NOT INTERACT ALL_OD
  ENCLOSE RECTANGLE Y GRID AVT_S_5_L+GRID ORTHOGONAL ONLY
}


VARIABLE AVT_S_6_0.24 0.24
AVT.S.6 { @ Space to NW. Space = 0 um is allowed >= 0.24 
     EXT AVT NWi < AVT_S_6_0.24 ABUT > 0 < 90 SINGULAR REGION
}

VARIABLE AVT_S_7_0.24 0.24
AVT.S.7 { @ Space to OD2 or NT_N. Space = 0 um is allowed >= 0.24 

    EXT AVT OD2 < AVT_S_7_0.24 ABUT > 0 < 90 SINGULAR REGION
    EXT AVT NTN < AVT_S_7_0.24 ABUT > 0 < 90 SINGULAR REGION
}




VARIABLE  AVT_S_8_0.065     0.065
AVT.S.8 { @ Space to ACTIVE ({ACTIVE OR GATE} cut AVT is not allowed) >= 0.065 
    EXT AVT DACT < AVT_S_8_0.065 ABUT <90 SINGULAR REGION
    (DACT OR GATE) CUT AVT
}








AVT.EN.1__AVT.EN.2 { @ Enclosure of gate in S/D direction >= ^AVT_EN_1 & in PO endcap direction >= ^AVT_EN_2 
  A = GATE INTERACT AVT
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (AVT_EN_1 - AVT_EN_2)) OR A
  C = SIZE B BY AVT_EN_2
  C NOT AVT
}




VARIABLE  AVT_EN_3_0.065     0.065
AVT.EN.3 { @ Enclosure of ACTIVE >= 0.065 

    ENC DACT AVT < AVT_EN_3_0.065 ABUT <90 SINGULAR REGION
}


AVT.L.1 { @ 45-degree edge length >= ^AVT_L_1 
  AVT_EDGE_45 = AVT ANGLE == 45
  LENGTH AVT_EDGE_45 < AVT_L_1  
}
AVT.A.1 { @ Area >= ^AVT_A_1
  AREA AVT < AVT_A_1
}
AVT.A.2 { @ Enclosed area >= ^AVT_A_2
  A = HOLES AVT INNER
  B = A NOT AVT
  AREA B < AVT_A_2
}
// AVT.R.2 and AVT.R.3 are checked by AVT.W.1 and AVT.S.1



AVT.R.1 { @ Overlap of RH_OD, RH_PO, VAR, BJTDMY, LOGO, TCDDMY, NWDMY, SR_ESD, SDI, GB_ALL, VTH_N, VTH_P, VTL_N, VTL_P, VTUL_N, VTUL_P, UHVT_N, UHVT_P, NT_N, OD2, NW or P+ACTIVE is not allowed   
  AVT AND PACT
  AVT AND NWi
  AVT AND OD2
  AVT AND NTN
  AVT AND VTHN
  AVT AND VTHP
  AVT AND VTLN
  AVT AND VTLP
  AVT AND VTUHN  //UHVT_N
  AVT AND VTUHP  //UHVT_P
  AVT AND VTULN
  AVT AND VTULP
  AVT AND RHOD
  AVT AND RHPO
  AVT AND BJTDMY
  AVT AND VAR
  AVT AND LOGO
  AVT AND NWDMY
  AVT AND TCDDMY
  AVT AND SRESD
  AVT AND SDI
  AVT AND GB_ALL
}





AVT.W.3 { @ Channel length of {(GATE AND NP) AND AVT} >= ^AVT_W_3
  NAVT_GATE_L = GATE_L INSIDE EDGE (NP AND AVT)
  LENGTH NAVT_GATE_L < AVT_W_3
}
AVT.WARN.1 { @ LAST GATE [in AVT, connects to CO] space to the 2nd {PO OR SR_DPO} [INSIDE AVT, in S/D and outside OD direction] from LAST GATE <= 0.8 
  GATE_CHK = ((POLY INTERACT CO) AND OD) INSIDE AVT
  SDx = (OD INTERACT GATE_CHK) NOT GATE_CHK
  MUST_LAST_GATE_CHK = SDx INTERACT GATE_CHK == 1
  GATE_EGDE_CHK = (POLY INTERACT CO) COIN INSIDE EDGE GATE_CHK
  LAST_GATE_EDGE = GATE_EGDE_CHK COIN OUTSIDE EDGE MUST_LAST_GATE_CHK 
  SR_POLY_CHK = SR_POLY INSIDE AVT
  GOOD_EDGE = DFM SPACE [LAST_GATE_EDGE] SR_POLY_CHK <= AVT_WARN_1 BY EXT HORIZONTAL COUNT == AVT_WARN_1_C BY LAYER SR_POLY_CHK
  LAST_GATE_EDGE NOT COIN EDGE GOOD_EDGE
}

#IFDEF N22_ULL

AVT2.R.1 { @ AVT2 must be drawn identically to AVT (only allowed AVT2 in ULL process)   
  CHK = AVT INTERACT AVT2
  AVT2 XOR CHK
}

AVT2.R.2 { @ Stand-alone AVT and AVT2 can't coexist in the same chip (only allowed AVT2 in ULL process) DRC flag: (AVT2 XOR AVT) INTERACT (CHIP INTERACT AVT2)   
  CHK1 = AVT2 XOR AVT
  CHK2 = CHIP INTERACT AVT2
  CHK1 INTERACT CHK2
}
AVT2.R.3 { @ Stand-alone AVTP can't coexist with AVT2 in the same chip (only allowed AVT2 in ULL process) DRC flag: (AVTP XOR AVTP2) INTERACT (CHIP INTERACT AVT2)   
  (AVTP XOR AVTP2) INTERACT (CHIP INTERACT AVT2)
}





AVTP.W.1 { @ Width >= 0.16 
  A = INT AVTP < AVTP_W_1 ABUT < 90 REGION PROJ==0
  B = EXT [AVTP] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = INT B >= AVTP_R_3_A < AVTP_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = INT B >= AVTP_R_3_B < AVTP_W_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = INT AVTP < AVTP_W_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
AVTP.W.3 { @ Channel length of {{GATE AND PP} AND AVT_P} >= 0.24 
  PAVT_GATE_L = GATE_L INSIDE EDGE (PP AND AVTP)
  LENGTH PAVT_GATE_L < AVTP_W_3
}
AVTP.S.1 { @ Space >= 0.16 
  A = EXT AVTP < AVTP_S_1 ABUT < 90 REGION PROJ==0
  B = INT [AVTP] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = EXT B >= AVTP_R_3_A < AVTP_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = EXT B >= AVTP_R_3_B < AVTP_S_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = EXT AVTP < AVTP_S_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
AVTP.S.2__AVTP.S.3 { @ Space to gate in PO endcap direction >= ^AVTP_S_2 & in S/D direction >= ^AVTP_S_3, AVTP cut {ACTIVE OR GATE} is not allowed.
  A = GATE NOT INTERACT AVTP
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (AVTP_S_3 - AVTP_S_2)) OR A
  C = SIZE B BY AVTP_S_2
  AVTP AND C
  DACT CUT AVTP
  GATE CUT AVTP
}
AVTP.S.4 { @ Space to unsilicided OD or high R resistor >= 0.15 
  EXT AVTP AYRE < AVTP_S_4 ABUT < 90 SINGULAR REGION
  AND AVTP AYRE    
}  
AVTP.S.5 { @ Space [parallel run length > 0.33 um, AVT_P space without INTERACT {{OD OR SR_DOD} OR DOD}] >= 0.25 
  X = EXT AVTP < AVTP_S_5 OPPOSITE REGION
  Y = X NOT INTERACT ALL_OD
  ENCLOSE RECTANGLE Y GRID AVTP_S_5_L+GRID ORTHOGONAL ONLY
}


VARIABLE AVTP_S_6_0.24 0.24
AVTP.S.6 { @ Space to OD2 or NT_N. Space = 0 um is allowed >= 0.24 
    EXT AVTP OD2 < AVTP_S_6_0.24 ABUT > 0 < 90 SINGULAR REGION
    EXT AVTP NTN < AVTP_S_6_0.24 ABUT > 0 < 90 SINGULAR REGION
}






VARIABLE  AVTP_S_8_0.065     0.065
AVTP.S.8 { @ Space to ACTIVE ({ACTIVE OR GATE} cut AVTP is not allowed) >= 0.065 
    EXT AVTP DACT < AVTP_S_8_0.065 ABUT <90 SINGULAR REGION
    (DACT OR GATE) CUT AVTP
}


AVTP.EN.1__AVTP.EN.2 { @ Enclosure of gate in S/D direction >= ^AVTP_EN_1 & in PO endcap direction >= ^AVTP_EN_2 
  A = GATE INTERACT AVTP
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (AVTP_EN_1 - AVTP_EN_2)) OR A
  C = SIZE B BY AVTP_EN_2
  C NOT AVTP
}



VARIABLE  AVTP_EN_3_0.065     0.065
AVTP.EN.3 { @ Enclosure of ACTIVE >= 0.065 
    ENC DACT AVTP < AVTP_EN_3_0.065 ABUT <90 SINGULAR REGION
}


AVTP.L.1 { @ 45-degree edge length >= 0.5 
  AVTP_EDGE_45 = AVTP ANGLE == 45
  LENGTH AVTP_EDGE_45 < AVTP_L_1  
}
AVTP.A.1 { @ Area >= 0.108 
  AREA AVTP < AVTP_A_1
}
AVTP.A.2 { @ Enclosed area >= 0.108 
  A = HOLES AVTP INNER
  B = A NOT AVTP
  AREA B < AVTP_A_2
}
AVTP.R.1 { @ Overlap of RH_OD, RH_PO, VAR, BJTDMY, LOGO, TCDDMY, NWDMY, SR_ESD, SDI, GB_ALL, VTH_N, VTH_P, VTL_N, VTL_P, VTUL_N, VTUL_P, UHVT_N, UHVT_P, NT_N, OD2 or N+ACTIVE is not allowed   
  AVTP AND NACT
  AVTP AND OD2
  AVTP AND NTN
  AVTP AND VTHN
  AVTP AND VTHP
  AVTP AND VTLN
  AVTP AND VTLP
  AVTP AND VTUHN  //UHVT_N
  AVTP AND VTUHP	 //UHVT_P
  AVTP AND VTULN
  AVTP AND VTULP
  AVTP AND RHOD
  AVTP AND RHPO
  AVTP AND BJTDMY
  AVTP AND VAR
  AVTP AND LOGO
  AVTP AND NWDMY
  AVTP AND TCDDMY
  AVTP AND SRESD
  AVTP AND SDI
  AVTP AND GB_ALL
}
// AVTP.R.2 and AVTP.R.3 are checked by AVTP.W.1 and AVTP.S.1

AVTP.R.5 { @ AVTP must be fully inside NW   
    AVTP NOT INSIDE NWi
}







AVTP.WARN.1 { @ LAST GATE [in AVT_P, connects to CO] space to the 2nd {PO OR SR_DPO} [INSIDE AVT_P, in S/D and outside OD direction] from LAST GATE <= 0.8 
  GATE_CHK = ((POLY INTERACT CO) AND OD) INSIDE AVTP
  SDx = (OD INTERACT GATE_CHK) NOT GATE_CHK
  MUST_LAST_GATE_CHK = SDx INTERACT GATE_CHK == 1
  GATE_EGDE_CHK = (POLY INTERACT CO) COIN INSIDE EDGE GATE_CHK
  LAST_GATE_EDGE = GATE_EGDE_CHK COIN OUTSIDE EDGE MUST_LAST_GATE_CHK 
  SR_POLY_CHK = SR_POLY INSIDE AVTP
  GOOD_EDGE = DFM SPACE [LAST_GATE_EDGE] SR_POLY_CHK <= AVTP_WARN_1 BY EXT HORIZONTAL COUNT == AVTP_WARN_1_C BY LAYER SR_POLY_CHK
  LAST_GATE_EDGE NOT COIN EDGE GOOD_EDGE
}

AVTP2.R.1 { @ AVTP2 must be drawn identically to AVTP (only allowed AVTP2 in ULL process)   
  CHK = AVTP INTERACT AVTP2
  AVTP2 XOR CHK
}

AVTP2.R.2 { @ Stand-alone AVTP and AVTP2 can't coexist in the same chip (only allowed AVTP2 in ULL process) DRC flag: (AVTP2 XOR AVTP) INTERACT (CHIP INTERACT AVTP2)   
  CHK1 = AVTP2 XOR AVTP
  CHK2 = CHIP INTERACT AVTP2
  CHK1 INTERACT CHK2
}

AVTP2.R.3 { @ Stand-alone AVT can't coexist with AVTP2 in the same chip (only allowed AVTP2 in ULL process) DRC flag: (AVT XOR AVT2) INTERACT (CHIP INTERACT AVTP2)   
  (AVT XOR AVT2) INTERACT (CHIP INTERACT AVTP2)
}





#ENDIF


//RFMOS CHECKS
//==========

RF.W.1 { @ Width of {PO OR SR_DPO} [INSIDE RF_PP] = 0.03 
  SR_POLY_CHECK = (OR POLY SRDPO) INSIDE RF_PP 
  SR_POLY_CHECK NOT WITH WIDTH == RF_W_1
}
RF.W.2 { @ Width of {PO NOT INTERACT OD2} [INSIDE RFDMY] (This check doesn't include the regions covered by NT_N, VAR, and RH_PO) = 0.03/0.035/0.04/0.045/0.05/0.06/0.08/0.09~1 
  POLY_CHECK = ((((((POLY NOT INTERACT OD2) INSIDE RFDMY) NOT INSIDE NTNi) NOT INSIDE VAR) NOT INSIDE RHPO) NOT INSIDE LOGO) NOT INSIDE SRAM_WAIVE_N28
  POLY_CHECK WITH WIDTH < RF_W_2A
  POLY_CHECK WITH WIDTH > RF_W_2A < RF_W_2B
  POLY_CHECK WITH WIDTH > RF_W_2B < RF_W_2C
  POLY_CHECK WITH WIDTH > RF_W_2C < RF_W_2D
  POLY_CHECK WITH WIDTH > RF_W_2D < RF_W_2E
  POLY_CHECK WITH WIDTH > RF_W_2E < RF_W_2F
  POLY_CHECK WITH WIDTH > RF_W_2F < RF_W_2G
  POLY_CHECK WITH WIDTH > RF_W_2G < RF_W_2H
  POLY_CHECK WITH WIDTH > RF_W_2I
}
RF.W.3 { @ Channel length of core device [INSIDE RFDMY] (This check doesn't include the regions covered by OD2, NT_N, and VAR) = 0.03/0.035/0.04/0.045/0.05/0.06/0.08/0.09~1 
  GATE_L_CHECK = (GATE_L INSIDE EDGE RFDMY) OUTSIDE EDGE ((((OD2 OR NTNi) OR VAR) OR LOGO) OR SRAM_WAIVE_N28)
  GATE_L_CHECK LENGTH < RF_W_2A
  GATE_L_CHECK LENGTH > RF_W_2A < RF_W_2B
  GATE_L_CHECK LENGTH > RF_W_2B < RF_W_2C
  GATE_L_CHECK LENGTH > RF_W_2C < RF_W_2D
  GATE_L_CHECK LENGTH > RF_W_2D < RF_W_2E
  GATE_L_CHECK LENGTH > RF_W_2E < RF_W_2F
  GATE_L_CHECK LENGTH > RF_W_2F < RF_W_2G
  GATE_L_CHECK LENGTH > RF_W_2G < RF_W_2H
  GATE_L_CHECK LENGTH > RF_W_2I
}

RF.S.1 { @ The {{GATE SIZING 0.06 um} AND PO} space to neighboring poly {PO OR SR_DPO} = 0.18 
  GATE_CHECK = GATE INSIDE RFPP_EXC
  PO_CHECK = (SIZE GATE_CHECK BY RF_S_1_S) AND POLY
  GOOD_EDGE = EXT [PO_CHECK] SR_POLY == RF_S_1 EXCLUDE SHIELDED 4 OPPOSITE
  (PO_CHECK TOUCH EDGE GATE_W) NOT COIN INSIDE EDGE GOOD_EDGE
}

RF.S.2 { @ OD space to SR_DPO in horizontal direction = 0.025 
  OD_CHECK = GROW (OD INSIDE RFPP_EXC) RIGHT BY RF_S_2 LEFT BY RF_S_2
  OD_CHECK_E = ANGLE OD_CHECK == 90
  BAD_EDGE = OD_CHECK_E NOT COIN OUTSIDE EDGE SRDPO
  (OD_CHECK WITH EDGE BAD_EDGE) NOT (OD INSIDE RFPP_EXC)
}

RF.EX.1 { @ OD extension on {PO OR SR_DPO} of core device >= 0.075 
  GATE_CHECK = LV_GATE INSIDE RFPP_EXC
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE GATE_W
  ENC GATE_W_CHECK OD < RF_EX_1 ABUT < 90 REGION

  SR_GATE_CHECK = LV_SR_GATE INSIDE RFPP_EXC
  SR_GATE_W_CHECK = SR_GATE_CHECK TOUCH EDGE SR_GATE_W
  ENC SR_GATE_W_CHECK OD < RF_EX_1 ABUT < 90 REGION
}

RF.R.1 { @ RF_PP layer must be fully covered by RFDMY {161;0}   
  RF_PP NOT RFDMY
}


RF.R.4 { @ RF_PP must be inside core region   
  RF_PP AND OD2
}



//VAR CHECKS
//==========

VAR_GATE = GATE NOT OUTSIDE VAR
VAR_GATE_W = VAR_GATE TOUCH EDGE GATE_W
VAR_GATE_L = VAR_GATE NOT TOUCH EDGE GATE_W


VAR.W.2 { @ Channel length of {{{GATE NOT OD2} AND VAR} NOT RFDMY} = 0.06~1 
  LV_VAR_GATE_L = (VAR_GATE_L NOT INSIDE EDGE OD2) OUTSIDE EDGE RFDMY
  LENGTH LV_VAR_GATE_L < VAR_W_2A
  LENGTH LV_VAR_GATE_L > VAR_W_2B
}


VAR.W.2.1 { @ Channel length of {{{GATE NOT OD2} AND VAR} AND RFDMY} = 0.06~1 
  LV_VAR_GATE_L = ((VAR_GATE_L NOT INSIDE EDGE OD2) NOT OUTSIDE EDGE RFDMY) OUTSIDE EDGE DVAR_F
  LENGTH LV_VAR_GATE_L < VAR_W_2_1A
  LENGTH LV_VAR_GATE_L > VAR_W_2_1B
}
VAR.W.3 { @ Channel length of {{{GATE AND OD2} AND VAR} NOT RFDMY} = 0.2~2 
  HV_VAR_GATE_L = (VAR_GATE_L INSIDE EDGE OD2) OUTSIDE EDGE RFDMY
  LENGTH HV_VAR_GATE_L < VAR_W_3A
  LENGTH HV_VAR_GATE_L > VAR_W_3B
}
VAR.W.3.1 { @ Channel length of {{{GATE AND OD2} AND VAR} AND RFDMY} = 0.2~2 
  HV_VAR_GATE_L = (VAR_GATE_L INSIDE EDGE OD2) NOT OUTSIDE EDGE RFDMY
  LENGTH HV_VAR_GATE_L < VAR_W_3_1A
  LENGTH HV_VAR_GATE_L > VAR_W_3_1B
}
VAR.W.4 { @ Channel width of {GATE AND VAR} >= 0.4 
  LENGTH (VAR_GATE_W OUTSIDE EDGE DVAR_F) < VAR_W_4 
}

VAR.S.1 { @ Space to ACTIVE >= 0.13 
  EXT VAR DACT < VAR_S_1 ABUT < 90 SINGULAR REGION
}
VAR.EN.1 { @ Enclosure of OD >= 0.16 
  ENC OD VAR < VAR_EN_1 ABUT < 90 SINGULAR REGION
  OD CUT VAR
}
VAR.R.1 { @ VAR layer must be drawn to fully cover the varactor devices   
  VAR_GATE NOT VAR
}

VAR.R.4 { @ Overlap of {{PO AND ACTIVE} SIZING 0.16 um} is not allowed   
  VAR_E = SIZE VAR BY VAR_R_4*2
  VAR_EXG = (GATE INTERACT VAR_E) OUTSIDE VAR
  VAR_EXGS = SIZE VAR_EXG BY VAR_R_4
  VAR AND VAR_EXGS
}

VAR.R.2 { @ Overlap of VTL_N, VTL_P, VTH_N, VTH_P, VTUL_N, VTUL_P, UHVT_N, UHVT_P, EHVT_N, EHVT_P, NT_N, or RPO is not allowed   
  VAR AND VTLN
  VAR AND VTLP
  VAR AND VTULN
  VAR AND VTULP 
  VAR AND VTHN
  VAR AND VTHP
  VAR AND VTUHN
  VAR AND VTUHP
  VAR AND VTLNIO
  VAR AND NTN
  VAR AND RPO
  VAR AND EHVT_N
  VAR AND EHVT_P
}

VAR.R.3 { @ PP overlap of {{GATE AND NW} AND VAR} is not allowed   
  (VAR_GATE AND NWEL) AND PP
}
VAR.R.5 { @ NP must fully cover {{{{{VAR AND GATE} AND NW} SIZING 0.19 um} AND OD} SIZING 0.13 um}   
  A = SIZE (VAR AND (GATE AND NWEL)) BY VAR_R_5_1
  B = SIZE (A AND OD) BY VAR_R_5_2
  B NOT NP
}


VAR.R.6 { @ NP overlap of {{GATE NOT NW} AND VAR} is not allowed   
  (VAR_GATE NOT NWEL) AND NP
}
VAR.R.7 { @ PP must fully cover {{{{{VAR AND GATE} NOT NW} SIZING 0.19 um} AND OD} SIZING 0.13 um}   
  A = SIZE (VAR AND (GATE NOT NWEL)) BY VAR_R_7_1
  B = SIZE (A AND OD) BY VAR_R_7_2
  B NOT PP
}




#ENDIF // FRONT_END


//CO CHECKS
//=========



CO.W.1 { @ Width (maximum = minimum) = 0.04 
  A = NOT RECTANGLE CO == CO_W_1 BY == CO_W_1 ORTHOGONAL ONLY
  (A NOT VIA_EXD) NOT INSIDE (SRAM_WAIVE_N28 OR ICOVL)
}

CO_NODAL = STAMP CO BY COii

CO.S.1 { @ Space >= 0.07 
  (EXT CO < CO_S_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
CO.S.2 { @ Space to 3-neighboring CO (distance < 0.09 um) >= 0.085 
  COx = RECTANGLE CO == CO_W_1 BY == CO_W_1 ORTHOGONAL ONLY
  X = WITH NEIGHBOR COx > 2 SPACE < CO_S_2_D
  (EXT X COx < CO_S_2 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
CO.S.3 { @ Space to neighboring CO [different net] >= 0.08 
  (EXT CO_NODAL < CO_S_3 ABUT < 90 NOT CONNECTED REGION) NOT INSIDE SRAM_WAIVE_N28
}


CO.S.4 { @ {CO INSIDE OD} space to GATE (overlap is not allowed) >= 0.03 
	(EXT COOD GATE < CO_S_4 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (CO AND GATE) NOT INSIDE SRAM_WAIVE_N28
}
CO.S.5 { @ {CO INSIDE OD} space to GATE of core device [channel length > 0.09 um] (overlap is not allowed) >= 0.04 
  X = LV_GATE WITH EDGE (LENGTH LV_GATE_L > CO_S_5_L)
  (EXT COOD X < CO_S_5 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
// Overlap not allow was checked by CO.S.4


CO.S.6 { @ {CO INSIDE PO} space to OD >= 0.035 
  (EXT COPO OD < CO_S_6 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}


CO.S.7 { @ {CO INSIDE OD} space to 1.8V/2.5V GATE (overlap is not allowed) >= 0.07 
  EXT COOD HV_GATE < CO_S_7 ABUT < 90 SINGULAR REGION
// Overlap not allow was checked by CO.S.4
}
CO.S.8 { @ Space to butted PP/NP edge on OD (overlap of NP/PP boundary on OD is not allowed.) >= 0.035 
  (EXT NP_PP_BTE COOD < CO_S_8 ABUT < 90 REGION) NOT INSIDE (SRAM_WAIVE_N28 OR SEALRING_ALL)
  (ENC COOD NP_PP_BTE < CO_S_8 ABUT < 90 REGION) NOT INSIDE (SRAM_WAIVE_N28 OR SEALRING_ALL)
  (((COOD NOT CSRDMY) NOT SEALRING_ALL) CUT PP) NOT INSIDE (SRAM_WAIVE_N28 OR SEALRING_ALL)       // exclude sealring region
  (ENC COOD PP < 0.001 ABUT < 90 SINGULAR REGION) NOT INSIDE (SRAM_WAIVE_N28 OR SEALRING_ALL)
  (ENC COOD NP < 0.001 ABUT < 90 SINGULAR REGION) NOT INSIDE (SRAM_WAIVE_N28 OR SEALRING_ALL)
}
CO.S.9 { @ {CO AND SRAMDMY;0 (186;0)} space to {CO NOT SRAMDMY;0 (186;0)} >= 0.2 
   (EXT (CO AND SRAMDMY) (CO NOT SRAMDMY) < CO_S_9 ABUT < 90 SINGULAR REGION) NOT INSIDE SRM_3
}
CO.S.12 { @ {CO INSIDE OD} space to {PO OR SR_DPO} in vertical direction >= 0.04 
  SR_POLY_H = ANGLE SR_POLY == 0
  (EXT COOD SR_POLY_H < CO_S_12 ABUT < 90 REGION) NOT INSIDE SRAM_WAIVE_N28
}
CO.S.13 { @ Maximum effective CO space in Source/Drain of device [channel width > 0.6 um] (This check doesn't include the regions covered by VAR, SR_ESD, SDI and DECAPDMY (129;0)) Definition of effective CO: CO projection space to GATE <= 0.11 um (D2) Definition of maximum effective CO space (B3): Channel width - effective CO projection lengths (D3) to GATE. Besides, if there is no CO in Source/Drain or no CO connected to Source/Drain by OD, it is allowed. CO projection space to PO (without CO shielding) > 0.11 um will be flagged on gate. <= ^CO_S_13
  GATE_W_COS13   = LENGTH GATE_W > CO_S_13_W
  GATE_CHK      = (GATE WITH EDGE GATE_W_COS13) NOT INSIDE EDGE ((((VAR OR SRESD) OR SDI) OR (OR DECAPDMY HVD HVD_65)) OR (RPO_DEVICE OR (ANALOG_DEVICE INTERACT RPO))) 
  SD_CHK        = SD INTERACT (CO OR DSTP)
  GATE_W_CHK    = (GATE_W_COS13 COIN INSIDE EDGE GATE_CHK) COIN OUTSIDE EDGE SD_CHK
  CO_IN_GATE_W  = EXT CO [GATE_W_CHK] <= CO_S_13_S OPPOSITE
  A = GATE_W_CHK NOT COIN EDGE CO_IN_GATE_W
  LENGTH A > CO_S_13
}
 


// CO.EN.0 is checked by either {CO.EN.3/CO.EN.7} or {CO.EN.6/CO.EN.4} or {CO.EN.6/CO.EN.7} or CO.EN.5
// CO.EN.0.1 is checked by either {CO.EN.6.1/CO.EN.7} or {CO.EN.3.2/CO.EN.7} or {CO.EN.4} or {CO.EN.6.2/CO.EN.7} or CO.EN.5

CO.EN.1 { @ Enclosure by OD >= 0.005 
  (ENC COOD OD < CO_EN_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}

CO.EN.1.1 { @ Enclosure by OD [width = 0.07 um ~ 0.09 um, space 0.07 um to {OD OR SR_DOD} with 0.05 um width] (Width is measured in parallel to space direction) >= 0.01 
  Wide_OD1 = INT [OD] >= CO_EN_1_1_W1 <= CO_EN_1_1_W2 OPPOSITE
  Wide_OD2 = INT [OD_SRDOD] == CO_EN_1_1_W3 OPPOSITE
  X = EXT [Wide_OD1] Wide_OD2 == CO_EN_1_1_S OPPOSITE
  ENC COOD X < CO_EN_1_1 ABUT < 90 OPPOSITE REGION
}
CO.EN.2 { @ Enclosure by OD [at least 2 opposite sides] >= 0.03 
  X = RECTANGLE ENCLOSURE COOD OD ABUT < 90 SINGULAR GOOD CO_EN_1 CO_EN_2 OPPOSITE CO_EN_1 CO_EN_2 OPPOSITE
  Y = ENC [X] OD < CO_EN_2 ABUT < 90 OPPOSITE
  Z = X TOUCH EDGE Y
  (INT Z < CO_W_1 ABUT == 90 INTERSECTING ONLY REGION) NOT INSIDE SRAM_WAIVE_N28   // adjacent narrow sides
}

POLY_W35 = POLY WITH WIDTH < CO_EN_3_W
POLY_W4 = POLY WITH WIDTH >= CO_EN_3_W <= CO_EN_4_W
POLY_W9 = POLY WITH WIDTH > CO_EN_4_W
POLY_W3_B = POLY WITH WIDTH == CO_EN_13_W_A   //0.03
POLY_W35_B = POLY WITH WIDTH == CO_EN_13_W_B  //0.035
POLY_W4_B = POLY WITH WIDTH == CO_EN_3_W //0.04
POLY_WL4_B = POLY WITH WIDTH > CO_EN_3_W //0.04~

COPO_W35 = COPO NOT OUTSIDE POLY_W35
COPO_W4 = (COPO OUTSIDE POLY_W35) NOT OUTSIDE POLY_W4 
COPO_W9 = (COPO OUTSIDE POLY_W35) OUTSIDE POLY_W4
COPO_W3_B  = COPO NOT OUTSIDE POLY_W3_B 
COPO_W35_B = (COPO OUTSIDE POLY_W3_B) NOT OUTSIDE POLY_W35_B  
COPO_W4_B = ((COPO OUTSIDE POLY_W3_B) OUTSIDE POLY_W35_B) NOT OUTSIDE POLY_W4_B
COPO_WL4_B = (((COPO OUTSIDE POLY_W3_B) OUTSIDE POLY_W35_B) OUTSIDE POLY_W4_B) NOT OUTSIDE POLY_WL4_B


CO.EN.3 { @ Enclosure by PO [PO width < 0.04 um], except DMY_SCH >= -0.005 
  (((SIZE COPO_W35 BY CO_EN_3) NOT POLY) NOT INSIDE SRAM_WAIVE_N28) NOT INSIDE DMY_SCH
}


CO.EN.4__CO.EN.5 { @ Enclosure by PO [at least two opposite sides] >= ^CO_EN_4 ,or [all sides] >= ^CO_EN_5
  A = RECTANGLE ENCLOSURE COPO_W9 POLY ABUT < 90 SINGULAR GOOD CO_EN_6 CO_EN_4 OPPOSITE CO_EN_6 CO_EN_4 OPPOSITE   
  ENC A POLY < CO_EN_5 ABUT < 90 SINGULAR REGION    
}
// CO.EN.4 and CO.EN.5 are checked by CO.EN.4__CO.EN.5

CO.EN.6 { @ Enclosure by PO [PO width >= 0.04 um], except DMY_SCH >= 0 
  ((COPO_W4 NOT POLY) NOT INSIDE (SRAM_WAIVE_N28 OR SEALRING_ALL)) NOT INSIDE DMY_SCH
  ((COPO_W9 NOT POLY) NOT INSIDE (SRAM_WAIVE_N28 OR SEALRING_ALL)) NOT INSIDE DMY_SCH
}


CO.EN.6.1 { @ Enclosure by PO [PO width = 0.04 um] >= -0.005 inside DMY_SCH
  (((SIZE COPO_W4_B BY CO_EN_3_B) NOT POLY) NOT INSIDE SRAM_WAIVE_N28) INSIDE DMY_SCH
}
CO.EN.6.2 { @ Enclosure by PO [PO width > 0.04 um] >= 0 inside	DMY_SCH
  ((COPO_WL4_B NOT POLY) NOT INSIDE SRAM_WAIVE_N28) INSIDE DMY_SCH
}

CO.EN.3.2 { @ Enclosure by PO [PO width == 0.03, 0.035 um] >= -0.01 inside	DMY_SCH 
  (((SIZE COPO_W3_B BY CO_EN_13) NOT POLY) NOT INSIDE SRAM_WAIVE_N28) INSIDE DMY_SCH
  (((SIZE COPO_W35_B BY CO_EN_13) NOT POLY) NOT INSIDE SRAM_WAIVE_N28) INSIDE DMY_SCH
}

CO.EN.7 { @ Enclosure by PO [PO width <= 0.09 um, at least 2 opposite sides] to avoid high Rc >= 0.05 
  B = RECTANGLE ENCLOSURE (SIZE COPO_W35 BY CO_EN_3) POLY ABUT < 90 SINGULAR GOOD 0 CO_EN_7-CO_EN_3 OPPOSITE 0 CO_EN_7-CO_EN_3 OPPOSITE
  (COPO_W35 INTERACT B) NOT INSIDE SRAM_WAIVE_N28     
  C = RECTANGLE ENCLOSURE COPO_W4 POLY ABUT < 90 SINGULAR GOOD CO_EN_6 CO_EN_7 OPPOSITE CO_EN_6 CO_EN_7 OPPOSITE
  (ENC C POLY < CO_EN_7 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28
}



CO.EN.14 {@ CO [INSIDE OD2] enclosure by OD [space to PO < 0.05 um] >= 0.015 
  CO_OD2 = CO INSIDE OD2
  A = ENC CO_OD2 [OD] < CO_EN_14 ABUT<90 OPPOSITE
  EXT [A] POLY < CO_EN_14_S OPPOSITE 
}
CO.EN.15 {@ CO [INSIDE OD2] enclosure by PO [space to OD < 0.05 um] >= 0.015 
  CO_OD2 = CO INSIDE OD2
  A = ENC CO_OD2 [POLY] < CO_EN_15 ABUT<90 OPPOSITE
  EXT [A] OD < CO_EN_15_S OPPOSITE 
}

// CO.R.1 is checked by RPO.S.3
// CO.R.2 is checked by CO.W.1

CO.R.3 { @ CO must be fully covered by M1 and {OD OR {{PO SIZING 0.005 um} NOT CPO}}, except DMY_SCH   
  (((COPO NOT ((SIZE POLY BY 0.005) NOT CPO)) NOT INSIDE SRAM_WAIVE_N28) NOT INSIDE SEALRING_ALL )NOT INSIDE DMY_SCH
}
CO.R.3.2 { @ Square CO must be fully covered by M1 and {OD OR {{PO SIZING 0.01 um} NOT CPO}} inside DMY_SCH.   
  (((COPO NOT ((SIZE POLY BY 0.01) NOT CPO)) NOT INSIDE SRAM_WAIVE_N28) NOT INSIDE SEALRING_ALL) INSIDE DMY_SCH
}
// Fully covered by M1 checked by rule M1.EN.1

CO.R.4 { @ Overlap of SR_DPO is not allowed   
  CO AND SRDPO
}



CO.R.16 { @ CO overlap silicided OD resistor body or overlap metal gate resistor body is not allowed DRC flags: {CO AND {{{{OD AND RHOD} OR {PO AND RHPO}} AND RPDMY} NOT INTERACT RPO}}   
  CO AND ODRES_SI
  CO AND PORES_SI
}

#IFDEF CHECK_VIRTUAL_CO
//CO_VIRT.R.1 is checked by related rules (CO rules)
CO_VIRT.R.2 {@ CO_VIRT (30;30) must be 0.04 um x 0.04 um
   NOT RECTANGLE CO_VIRT == CO_W_1 BY == CO_W_1 ORTHOGONAL ONLY
}
CO_VIRT.R.3 {@ CO_VIRT (30;30) interact CO (30;0) is not allowed   
   CO_VIRT INTERACT COii
}
CO_VIRT.R.4 {@ CO_VIRT (30;30) must be fully covered by ROM (50;6)   
   CO_VIRT NOT ROM
}
#ENDIF




#IFDEF M1_V1_M2_CHECKS


//M1 CHECKS
//=========
M1_EDGE_45 = M1 ANGLE == 45

M1.W.1 { @ Width >= 0.05 
  INT M1 < M1_W_1 ABUT < 90 SINGULAR REGION    
}
M1.W.2 { @ Width of 45-degree bent M1. (Please make sure the vertex of 45-degree pattern is on 0.005 um grid (refer to the guideline, G.6gU, in section XXX)) >= 0.17 
  INT M1_EDGE_45 < M1_W_2 ABUT < 90 REGION
}

M1.W.3 { @ Maximum width <= 4.5 
  (M1_MAX_WIDTH WITH WIDTH > M1_W_3) NOT INSIDE IND_REGION
}
M1.W.4 { @ Length of the edge with adjacent edge < 0.05 um [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex-270 degree inner vertex; DRC doesn't flag if there is M1 within the area formed by 0.16 um extension from these 2 edges and the 90 degree outer vertex.] >= 0.065 
  E1 = CONVEX EDGE M1 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH < M1_W_4_L1
  E2 = CONVEX EDGE M1 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH >= M1_W_4_L1 < M1_W_4_L2
  A = INT [E1]    < M1_W_4_L2 ABUT == 90 INTERSECTING ONLY
  B = INT [E2] E1 < M1_W_4_L2 ABUT == 90 INTERSECTING ONLY
  C = INT [E1] E2 < M1_W_4_L2 ABUT == 90 INTERSECTING ONLY
  D = OR EDGE  B (OR EDGE A C)
  CORNER_BAD_pre = EXPAND EDGE D INSIDE BY 0.001
  W = EXT [D] M1 < 0.16
  CORNER_BAD_pre NOT WITH EDGE W
}


M1.S.1 { @ Space >= 0.05 
  (EXT M1 < M1_S_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
M1.S.2 { @ Space [at least one metal line width > 0.1 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.06 
  X = EXT M1_20 M1 < M1_S_2 OPPOSITE REGION MEASURE ALL
  Y = X NOT M1
  ENCLOSE RECTANGLE Y GRID M1_S_2_L+GRID
}
M1.S.3 { @ Space [at least one metal line width > 0.18 um (W2) and the parallel run length > 0.22 um (L2)] >= 0.1 
  X = EXT M1_21 M1 < M1_S_3 OPPOSITE REGION MEASURE ALL
  Y = X NOT M1
  ENCLOSE RECTANGLE Y GRID M1_S_3_L+GRID
}
M1.S.4 { @ Space [at least one metal line width > 0.47 um (W3) and the parallel run length > 0.47 um (L3)] >= 0.13 
  X = EXT M1_22 M1 < M1_S_4 OPPOSITE REGION MEASURE ALL
  Y = X NOT M1
  ENCLOSE RECTANGLE Y GRID M1_S_4_L+GRID
}
M1.S.5 { @ Space [at least one metal line width > 0.63 um (W4) and the parallel run length > 0.63 um (L4)] >= 0.15 
  X = EXT M1_23 M1 < M1_S_5 OPPOSITE REGION MEASURE ALL
  Y = X NOT M1
  ENCLOSE RECTANGLE Y GRID M1_S_5_L+GRID
}
M1.S.6 { @ Space [at least one metal line width > 1.5 um (W5) and the parallel run length > 1.5 um (L5)] >= 0.5 
  X = EXT M1_30 M1 < M1_S_6 OPPOSITE REGION MEASURE ALL
  Y = X NOT M1
  ENCLOSE RECTANGLE Y 0.001 M1_S_6_L+0.001
}
M1.S.7 { @ Space to M1 line-end [parallel run length > -0.025 um (T)] . Definition of "M1 line-end": M1 edge with length < 0.07 um (W) between 2 outer vertex >= 0.06 
  A = CONVEX EDGE M1 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M1_S_7_W
  (EXT A M1 < M1_S_7 ABUT < 90 OPPOSITE EXTENDED M1_S_7_T REGION) NOT INSIDE SRAM_WAIVE_N28
}
M1.S.8 { @ Space (S1) to dense M1 line-end [parallel run length > -0.025 um (T)], Definition of dense M1 line-end: 1. M1 line-end: M1 edge with length < 0.07 um (W) between 2 outer vertex. 2. Other metal INTERACT Region 1. Region 1 = (T+Q) x S2. (W+S2) < 0.12 um. This check doesn't include small jog with edge length < 0.05 um (R) >= 0.07 
  A = CONVEX EDGE M1 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M1_S_8_W
  B = EXT [A] M1 < M1_S_8 ABUT < 90 OPPOSITE EXTENDED M1_S_8_T
  C = A TOUCH INSIDE EDGE B
  D = INT C [M1] < M1_S_8_Q ABUT == 90 INTERSECTING ONLY
  I = LENGTH D >= M1_W_1
  J = EXPAND EDGE I INSIDE BY GRID 
  K = LENGTH J == GRID
  L = K NOT TOUCH EDGE C
  M = EXPAND EDGE L INSIDE BY M1_S_8_T
  N = J NOT M
  O = I COIN INSIDE EDGE N
  PW = INT O M1 < (M1_S_8_P - M1_S_1) ABUT < 90 OPPOSITE EXTENDED M1_S_8_T
  PS = EXT O M1 < (M1_S_8_P - M1_W_1) ABUT < 90 OPPOSITE EXTENDED M1_S_8_T
  Q = DFM PROPERTY O PS PW OVERLAP ABUT ALSO MULTI
  [-= MIN(EW(PW)) + MIN(EW(PS))] < M1_S_8_P
  R = C TOUCH EDGE (J WITH EDGE Q)
  (EXT R M1 < M1_S_8 ABUT < 90 OPPOSITE EXTENDED M1_S_8_T REGION) NOT INSIDE SRAM_WAIVE_N28
}
M1.S.9 { @ Space to 45-degree bent M1 >= 0.17 
  X = EXPAND EDGE M1_EDGE_45 OUTSIDE BY M1_S_9
  X AND M1
}














M1.S.35 { @ Space (DRC only flag: M1 space error region INTERACT {SRAMDMY NOT {SRAMDMY SIZING -0.5 um}}) >= 0.05 
  FLAG_REGION = SRAMDMY NOT (SIZE SRAMDMY BY -M1_S_35_S)
  (EXT M1 < M1_S_35 ABUT < 90 SINGULAR REGION) INTERACT FLAG_REGION
}
// M1.EN.0 is checked by M1.EN.1 and M1.EN.2__M1.EN.6






M1.EN.1 { @ Enclosure of CO >= 0 
  ((CO NOT M1) NOT INSIDE SRAM_WAIVE_N28) NOT INSIDE SEALRING_ALL
}
M1.EN.2__M1.EN.6 { @ Enclosure of CO [at least two opposite sides] >= ^M1_EN_2 OR Enclosure of CO [all sides] >= ^M1_EN_6
  X = RECTANGLE ENCLOSURE CO M1 ABUT < 90 SINGULAR GOOD 0 M1_EN_2 OPPOSITE 0 M1_EN_2 OPPOSITE
  ((ENC X M1 < M1_EN_6 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28) NOT INSIDE SEALRING_ALL
}
// M1.EN.2 and M1.EN.6 are checked by M1.EN.2__M1.EN.6

M1Wide_0.7 = M1Wide_2_0 WITH WIDTH > M1_EN_3_W
M1.EN.3 { @ Enclosure of CO [M1 width > 0.7 um] >= 0.03 
   A = CO INSIDE M1Wide_0.7
   (ENC A M1 < M1_EN_3 ABUT < 90 SINGULAR REGION) NOT INSIDE SEALRING_ALL
}

M1.EN.4 { @ Enclosure of CO [M1 width >= 0.08 um, M1 space < 0.06 um and parallel run length > 0.18 um] (This check doesn't include 2 COs with space < 0.08 um) >= 0.015 
  W1 = M1i WITH WIDTH >= M1_EN_4_W
  W =  EXT W1 [M1] < M1_EN_4_S1 ABUT < 90 OPPOSITE MEASURE ALL
  S =  EXT W [M1i] < M1_EN_4_S1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S5_H = EXPAND EDGE S1_H BY 0.005
  S5_V = EXPAND EDGE S1_V BY 0.005
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M1_EN_4_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M1_EN_4_L
  S7 = (S1_H INSIDE EDGE S6_H) OR EDGE (S1_V INSIDE EDGE S6_V)
  EN = ENC CO S7 < M1_EN_4 ABUT < 90 OPPOSITE REGION
  err_co = CO INTERACT EN 
  effRegion = (M1i AND (ODi XOR POi)) INTERACT err_co
  check_co = CO INTERACT effRegion
  COMerged = SIZE check_co BY M1_EN_4_S2/2-0.001 INSIDE OF effRegion STEP M1_S_1*0.7
  COMerged_good = COMerged INTERACT check_co >= 2 // good co area II
  err_co_f = err_co NOT INTERACT COMerged_good
  EN INTERACT err_co_f
}

M1.EN.5 { @ Enclosure of CO [at least 2 opposite sides, M1 area < 0.014 um2] >= 0.03 
  sM1s = AREA M1 < M1_EN_5_A
  A = RECTANGLE ENCLOSURE CO sM1s ABUT >0 < 90 GOOD 0 M1_EN_5 OPPOSITE 0 M1_EN_5 OPPOSITE
 (ENC A sM1s < M1_EN_5 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}


M1.L.1 { @ Length of 45-degree bent M1 (minimum edge length) >= 0.5 
  (LENGTH M1_EDGE_45 < M1_L_1) NOT INSIDE EDGE SEALRING_ALL
}

M1.A.1 { @ Area >= 0.0115 
  (AREA M1 < M1_A_1) NOT INSIDE SRAM_WAIVE_N28
}
M1.A.2 { @ Area [with all of edge lengths < 0.2 um, any edge length >= 0.13 um] (This check doesn't include the patterns filling 0.05 um x 0.2 um rectangular tile) >= 0.014 
  A = LENGTH M1 >= M1_A_2_L1 
  B = M1 NOT WITH EDGE A  
  C = LENGTH B >= M1_A_2_L2 
  D = M1 WITH EDGE C  
  E = AREA D < M1_A_2
  (NOT ENCLOSE RECTANGLE E M1_A_2_W M1_A_2_L1 ORTHOGONAL ONLY) NOT INSIDE SRAM_WAIVE_N28
}
M1.A.3 { @ Area [with all of edge lengths < 0.13 um] (This check doesn't include the patterns filling 0.05 um x 0.13 um rectangular tile) >= 0.038 
  A = AREA M1 < M1_A_3
  B = LENGTH A >= M1_A_3_L1
  C = A NOT WITH EDGE B
  (NOT ENCLOSE RECTANGLE C M1_A_3_W M1_A_3_L2 ORTHOGONAL ONLY) NOT INSIDE SRAM_WAIVE_N28
}

VARIABLE M1_A_4pre ((M1_A_4 + (M1_S_1 * M1_S_1 * 3.142))/(2 * M1_S_1))*((M1_A_4 + (M1_S_1 * M1_S_1 * 3.142))/(2 * M1_S_1))/3.141 // user value

M1.A.4 { @ Enclosed area >= 0.2 
  X = HOLES M1 INNER < M1_A_4pre
  AREA ( X NOT M1 ) < M1_A_4
}






// 'M1.DN.0' is checked by related rules




//'My.DN.0' is not necessary to check
//'My.DN.1' is not necessary to check
//'My.DN.2' is not necessary to check
//'My.DN.3' is not necessary to check

//'Mr.DN.0' is not necessary to check
//'Mr.DN.1' is not necessary to check
//'Mr.DN.2' is not necessary to check
//'Mr.DN.3' is not necessary to check



//'M1.DN.1' is checked by M1.DN.1
#IFDEF CHECK_LOW_DENSITY
M1.DN.1 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum metal density in window 125 um x 125 um, stepping 62.5*20% um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10%+3% 
#ELSE
@ Minimum metal density in window 125 um x 125 um, stepping 62.5 um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10% 
#ENDIF
  EXC_LOW = M1_EXC_LOW OR ICOVL
  N = M1x NOT EXC_LOW
  D = CHIP NOT EXC_LOW 
  A = CHIP_M1 NOT EXC_LOW
  X = DENSITY A M1x CHIP N D < M1_DN_1 WINDOW M1_DN_1_W STEP M1_DN_1_S BACKUP INSIDE OF LAYER CHIP_M1 PRINT M1.DN.1.density RDB M1.DN.1.RDB.density
          [~(AREA(A)-M1_DN_1_E)*!!(AREA(A)-M1_DN_1_E)+AREA(N)/AREA(D)+!~(AREA(M1x)/AREA(CHIP)-M1_DN_1)+!(AREA(M1x)/AREA(CHIP)-M1_DN_1)]


  COPY X    
}
#ENDIF



//'M1.DN.2' is checked by M1.DN.2
M1.DN.2 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum metal density in window 125 um x 125 um, stepping 62.5*20% um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 85%-3% 
#ELSE
@ Maximum metal density in window 125 um x 125 um, stepping 62.5 um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 85% 
#ENDIF
  EXC_HIGH = M1_EXC_HIGH OR ICOVL
  N = M1x NOT EXC_HIGH
  D = CHIP NOT EXC_HIGH 
  A = CHIPx NOT EXC_HIGH
  X = DENSITY A M1x CHIP N D > M1_DN_2 WINDOW M1_DN_2_W STEP M1_DN_2_S BACKUP INSIDE OF LAYER CHIPx PRINT M1.DN.2.density RDB M1.DN.2.RDB.density
          [~(M1_DN_2_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M1x)/AREA(CHIP)-M1_DN_2)]


  COPY X    
}

//'M1.DN.3' is checked by M1.DN.3
M1.DN.3 { @ The metal density difference between any 2 neighboring checking windows including DMxEXCL [window 200 um x 200 um, stepping 200 um] Anticipate metal density gradient from layout of small cell by targeting density ~50% (this way, it will limit the risk of low density and of high gradient) (Except ICOVL) <= 50% 
   EXCEPT =  COPY ICOVL
   M1x_Chk = M1x NOT EXCEPT
   DENSITY M1x_Chk EXCEPT CHIP <=1 WINDOW M1_DN_3_W BACKUP GRADIENT > M1_DN_3 ABSOLUTE CORNER INSIDE OF LAYER CHIPx PRINT M1.DN.3.density RDB M1.DN.3.RDB.density
    [ (AREA(M1x_Chk)+AREA(EXCEPT)*M1_DN_3_V)/AREA(CHIP) ] 
}

M1_CORE = M1x NOT SRCSR_P4


#IFDEF CHECK_LOW_DENSITY
M1.DN.6 { @ Metal Density >= ^M1_DN_6 must be followed for item(A) to (C)
@ (A) Metal density [checking window ^M1_DN_6_W_A um x ^M1_DN_6_W_A um, stepping ^M1_DN_6_S_A um] >= ^M1_DN_6
@ (B) Maximum area of merged low density windows [checking window ^M1_DN_6_W_BC um x ^M1_DN_6_W_BC um, stepping ^M1_DN_6_S_BC um, density < ^M1_DN_6] <= ^M1_DN_6_A_B um2. Merged low density windows width <= ^M1_DN_6_U um is except.
@ (C) Maximum area of merged low density windows [checking window ^M1_DN_6_W_BC um x ^M1_DN_6_W_BC um, stepping ^M1_DN_6_S_BC um, density < ^M1_DN_6] <= ^M1_DN_6_A_C um2
@ 1. The following special regions are excluded
@    Chip corner triangle empty areas if sealring is added by tsmc. 
@    LOWMEDN
@ 2. This rule is applied while the width of (checking window NOT above excluding region) >= ^M1_DN_6_E_A um for (A) and >= ^M1_DN_6_E_BC um for both (B)/(C) 
  M1_CHECK = M1x NOT (NEW_DEN_EXC OR ICOVL)
  CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
  // Condition-A
  ERR_WIN_A = DENSITY M1_CHECK CHIP_CHECK < M1_DN_6 WINDOW M1_DN_6_W_A STEP M1_DN_6_S_A INSIDE OF LAYER CHIP_M1 BACKUP 
	[ AREA(M1_CHECK)/AREA(CHIP_CHECK) ]
  F_A = WITH WIDTH (ERR_WIN_A NOT (NEW_DEN_EXC OR ICOVL)) >= M1_DN_6_E_A
  DENSITY F_A M1_CHECK CHIP_CHECK < M1_DN_6 WINDOW M1_DN_6_W_A STEP M1_DN_6_S_A INSIDE OF LAYER CHIP_M1 BACKUP PRINT M1.DN.6_A.density
         [ !AREA(F_A)+AREA(M1_CHECK)/AREA(CHIP_CHECK) ]
  // Condition-B 
  ERR_WIN_B = DENSITY M1_CHECK CHIP_CHECK < M1_DN_6 WINDOW M1_DN_6_W_BC STEP M1_DN_6_S_BC INSIDE OF LAYER CHIP_M1 BACKUP 
	[ AREA(M1_CHECK)/AREA(CHIP_CHECK) ]
  F_B = WITH WIDTH (ERR_WIN_B NOT (NEW_DEN_EXC OR ICOVL)) >= M1_DN_6_E_BC
  A = DENSITY F_B M1_CHECK CHIP_CHECK < M1_DN_6 WINDOW M1_DN_6_W_BC STEP M1_DN_6_S_BC INSIDE OF LAYER CHIP_M1 BACKUP PRINT M1.DN.6_BC.density
         [ !AREA(F_B)+AREA(M1_CHECK)/AREA(CHIP_CHECK) ]
  B = AREA A > M1_DN_6_A_B
  C = SIZE B BY M1_DN_6_U/2 UNDEROVER
  B INTERACT C
  // Condition-C
  AREA B > M1_DN_6_A_C
}
#ENDIF






//'DMx_O.R.1' is checked by DM1_O.R.1
DM1_O.R.1 { @ DMx_O INTERACT Mx is not allowed. [Mx, and My only]   
  DM1_O INTERACT M1i
}

