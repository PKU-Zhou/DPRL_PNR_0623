  M7_TypeBRS3_CACB_BOXAC_6 = M7_TypeBRS3_CACB_BOXAC_6_1 WITH EDGE ((M7_TypeBRS3_CACB_BOXAC_6_1 AND M7i) COIN EDGE M7_TypeBRS3_CACB_BOXAC_6_1) == 4
  M7_TypeBRS3_CACB_BOXAC_7 = ((M7_TypeBRS3_CACB_BOXAC_2 INTERACT M7_TypeBRS3_CACB_BOXAC_5) INTERACT M7_TypeBRS3_CACB_BOXAC_6) OR (M7_TypeBRS3_CACB_BOXAC_5 OR M7_TypeBRS3_CACB_BOXAC_6)
  M7_TypeBRS3_CACB_BOXAC_8 = (M7_TypeBRS3_CACB_BOXAC_7 AND M7i) COIN EDGE M7_TypeBRS3_CACB_BOXAC_7
  M7_TypeBRS3_CACB_BOXAC_9 = INT [M7_TypeBRS3_CACB_BOXAC_8] <= 4*TypeBRS3_S3+2*TypeBRS3_S6+2*GRID OPPOSITE
  M7_TypeBRS3_CACB_BOXAC_10 = ENCLOSE RECTANGLE (M7_TypeBRS3_CACB_BOXAC_7 WITH EDGE M7_TypeBRS3_CACB_BOXAC_9  == 4) TypeBRS3_S2 2*TypeBRS3_S3
  M7_TypeBRS3_CACB_BOXAC_11 = VERTEX (M7_TypeBRS3_CACB_BOXAC_10 AND M7i) != 4
  M7_TypeBRS3_CACB_BOXAC_12 = M7_TypeBRS3_CACB_BOXAC_10 NOT INTERACT M7_TypeBRS3_CACB_BOXAC_11
  M7_TypeBRS3_CACB_BOXC = M7_TypeBRS3_CACB_BOXAC_2 INSIDE M7_TypeBRS3_CACB_BOXAC_12
  M7_TypeBRS3_CACB_MARK = EXT (M7_TypeBRS3_CACB_BOXC AND M7i) <= Mx_S OPPOSITE REGION
  M7_TypeBRS3_CACB_MARK INTERACT EFPM7S7_M7i
}
#ENDIF
#ENDIF
#IFDEF CHECK_EFPM7EN1_
#IFDEF _EFPM7EN1_
EFPM7EN1_M7iCellIn = INSIDE CELL M7i CellsForRRuleRecommended  
EFPM7EN1_M7iCellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
EFPM7EN1_M7iCell = EFPM7EN1_M7iCellIn AND EFPM7EN1_M7iCellOut
EFPM7EN1_M7iMarker = M7i AND RRuleRecommended
EFPM7EN1_M7i = ((EFPM7EN1_M7iCell OR EFPM7EN1_M7iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M7.EN.1 { @ Mx/VIAx-1 recommendation: Recommended Mx_A enclosure VIAx-1 [in {VIAx-1 AND Mx_A} space to Mx (SP3+SE) <= 0.06 um side] Definition of Mx_A: Mx with consecutive edge length (L1) <= 0.12 um, (L2) <= 0.06 um, (L3) >= 0.1 um, L1/L3 edge is between 2 outer vertex. L1/L3 space to adjacent Mx (SP3/SP4) = 0.05 um [parallel run length > 0 from VIAx-1] >= 0.01 
   L1_pre = CONVEX EDGE EFPM7EN1_M7i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L2 LENGTH2>=EFP_Mx_EN_1_L3 WITH LENGTH<=EFP_Mx_EN_1_L1
   L2_pre = CONVEX EDGE EFPM7EN1_M7i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH<=EFP_Mx_EN_1_L2
   L3_pre = CONVEX EDGE EFPM7EN1_M7i ANGLE1==90 ANGLE2>=90 <=270 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH>=EFP_Mx_EN_1_L3
   L1_L2_V = INT L1_pre L2_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1_L3_V = INT L1_pre L3_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1 = (L1_pre TOUCH INSIDE EDGE L1_L2_V) TOUCH INSIDE EDGE L1_L3_V
   L3 = L3_pre TOUCH INSIDE EDGE (L1_L3_V WITH EDGE L1)
   L1_DENSE = EXT [L1] M7 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA6_L1_DENSE = VIA6i TOUCH INSIDE EDGE (ENC [VIA6i] L1_DENSE < EFP_Mx_EN_1_SE ABUT<90 OPPOSITE)
   L3_DENSE = EXT [L3] M7 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA6_L3_DENSE = VIA6i TOUCH INSIDE EDGE (ENC [VIA6i] L3_DENSE <= EFP_Mx_EN_1_L1-VIA6_W_1-VIA6_EN_2 ABUT<90 OPPOSITE)
   X = INT VIA6_L1_DENSE VIA6_L3_DENSE <= GRID ABUT==90 INTERSECTING ONLY REGION
   VIA6i INTERACT X  
}
// EFP.Mx.EN.1.R is checked by RR:RE:EFP.M7.EN.1
#ENDIF
#ENDIF
// EFP.Mx.S.5.R is checked by RR:RE:EFP.M7.S.5
// EFP.Mx.S.6.R is checked by RR:RE:EFP.M7.S.6
// EFP.Mx.S.7.R is checked by RR:RE:EFP.M7.S.7


#ENDIF // EFP

