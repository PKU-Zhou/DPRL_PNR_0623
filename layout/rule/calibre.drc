SR.R.9:AP {@ Width of seal-ring enhanced zone (SREZ)= 6 um (layout forbidden area.) Only M1~AP and DMV pattern are allowed in seal-ring enhanced zone region (DMV pattern: metal/via dummy pattern, DOD, & DPO) Each M1~AP patterns in seal-ring enhanced zone region must follow the following conditions: 1. Each M1~Mtop must be connected to seal-ring wall 2. Each AP can only connect to the inner seal-ring wall 3. Each M1~AP overlap SLDB is not allowed   
   ((APi NOT INTERACT SEALRING_ORI) CUT ISOR_P4) AND ISOR_P4
   (APi AND SEALRING_ALL) AND (CB2Fi OR CB2Wi)
   (APi INTERACT ISOR_P4) AND SEALRING_DB
}
// SR.R.9 is checked by SR.R.9:AP

SR.UBM:WARNING1 { @ Do not draw UBM on Chip corner stress relief pattern/Seal ring/seal-ring enhanced zone  
  SRCSR_P4 AND UBMi
}

CB.W.3 { @ Width of CB/CBD/RV line opening in inner seal-ring = 2 
  X1 = ANGLE SR_CB1_BAR_INNER != 45
  X2 = ANGLE SR_CB1_BAR_INNER == 45
  INT X1 > CB_W_3 < CB_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > CB_W_3+0.01 < CB_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < CB_W_3 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < CB_W_3-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}

#IFDEF DBOC
CB.W.4 { @ Width of CB/CBD line opening in SLDB. == 0
  SEALRING_DB AND CB1i
}
#ELSE
CB.W.4 { @ Width of CB/CBD/RV line opening in SLDB = 2 
  X1 = ANGLE SR_CB1_BAR_SLDB != 45
  X2 = ANGLE SR_CB1_BAR_SLDB == 45
  INT X1 > CB_W_4 < CB_W_4*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > CB_W_4+0.01 < CB_W_4*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < CB_W_4 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < CB_W_4-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
CB.EN.2 { @ Enclosure of CB/CBD/RV by AP in inner seal-ring >= 1 
  X1 = ANGLE SR_CB1_BAR_INNER != 45
  X2 = ANGLE SR_CB1_BAR_INNER == 45
  ENC X1 SR_AP_BAR_INNER < CB_EN_2 ABUT < 90 OPPOSITE REGION
  ENC X2 SR_AP_BAR_INNER < CB_EN_2-GRID ABUT < 90 OPPOSITE REGION
  (SR_CB1_BAR_INNER AND CHIP_AP) NOT SR_AP_BAR_INNER
}
CB.EN.3 { @ Enclosure of CB/CBD/RV by AP in SLDB >= 1 
  X1 = ANGLE SR_CB1_BAR_SLDB != 45
  X2 = ANGLE SR_CB1_BAR_SLDB == 45
  ENC X1 SR_AP_BAR_SLDB < CB_EN_3 ABUT < 90 OPPOSITE REGION
  ENC X2 SR_AP_BAR_SLDB < CB_EN_3-GRID ABUT < 90 OPPOSITE REGION
  (SR_CB1_BAR_SLDB AND CHIP_AP) NOT SR_AP_BAR_SLDB     
}
//Define for AP.W.3 & AP.EN.2 Enhaance
SR_INNER_D2 = DONUT SEALRING_ORI > 1
AP_AND_SR = SR_INNER_D2 AND AP
AP_INT_SR = APi INTERACT SR_INNER_D2

AP.W.3{ @ Width of AP bar bar overlaps with inner seal-ring and SREZ (Except AP connect to inner seal-ring from Prime Chip) (DRC tolerance at 45-degree turning: +-0.020 um) = 8 
 AP_INT_CHIP = AP AND (SIZE (HOLES SEALRING_ALL) BY 0.005 )  
 X = (AP INTERACT SR_INNER_D2) AND SEALRING_ALL
 X1 = ANGLE X != 45
 X2 = ANGLE X == 45
 (INT X1 < AP_W_3 ABUT < 90 OPPOSITE PARALLEL ONLY REGION) NOT INTERACT AP_INT_CHIP
 (INT X1 > AP_W_3 < AP_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION) NOT INTERACT AP_INT_CHIP
 (INT X2 < AP_W_3-GRID*4 ABUT < 90 OPPOSITE PARALLEL ONLY REGION) NOT INTERACT AP_INT_CHIP
 (INT X2 > AP_W_3+GRID*4 < AP_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION) NOT INTERACT AP_INT_CHIP
 MAY_NG_AP = AP AND (EXPAND EDGE SEALRING_ALL INSIDE BY 3 CORNER FILL)
 MAY_NG_AP NOT TOUCH (AP AND (HOLES SEALRING_ALL))
 NOT DONUT AP_AND_SR 
 AP COIN EDGE SEALRING_ORI
 (AP NOT INTERACT (SEALRING_DB OR SEALRING_ORI)) AND SEALRING_ALL
 }

AP.EN.2 { @ Enclosure of AP bar overlaps with inner seal-ring and SREZ by inner seal-ring (DRC tolerance at 45-degree turning: +-0.02 um) = 1 
 AP_INT_SR_CHK =  AP_INT_SR NOT COIN EDGE (HOLES AP_INT_SR)
 ANGLE (ENC (AP_INT_SR_CHK) SEALRING_INNER == AP_EN_2 ) != 45
 ENC [AP_INT_SR_CHK] SEALRING_INNER < AP_EN_2-0.02 ABUT < 90 OPPOSITE PARALLEL
 ENC [AP_INT_SR_CHK] SEALRING_INNER > AP_EN_2+0.02 < 2 ABUT < 90 OPPOSITE PARALLEL
}


AP.W.4 { @ Width of AP bar in SLDB. == ^AP_W_4
  X1 = ANGLE SR_AP_BAR_SLDB != 45
  X2 = ANGLE SR_AP_BAR_SLDB == 45
  INT X1 > AP_W_4 < AP_W_4*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > AP_W_4+GRID < AP_W_4*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  WITH WIDTH SR_AP_BAR_SLDB >= AP_W_4*2
  INT X1 < AP_W_4 ABUT < 90 REGION
  INT X2 < AP_W_4-GRID ABUT < 90 REGION
}
CB2.W.5 { @ Width of CB2_WB/CB2_FC line opening in outer seal ring. == ^CB2_W_5
  X1 = ANGLE SR_CB2_BAR_OUTER != 45
  X2 = ANGLE SR_CB2_BAR_OUTER == 45
  INT X1 > CB2_W_5 < CB2_W_5*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > CB2_W_5+0.005 < CB2_W_5*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < CB2_W_5 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < CB2_W_5-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}

CB2.W.6 { @ Width of CB2_WB/CB2_FC line opening in SLDB. == ^CB2_W_6
  X1 = ANGLE SR_CB2_BAR_SLDB != 45
  X2 = ANGLE SR_CB2_BAR_SLDB == 45
  INT X1 > CB2_W_6 < CB2_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > CB2_W_6+0.005 < CB2_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < CB2_W_6 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < CB2_W_6-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
#ENDIF

#IFDEF WITH_POLYIMIDE 
PM.R.3 { @ Polyimide is prohibited over outer seal-ring and SLDB regions. It only covers seal-ring enhanced zone/ inner seal-ring area 6 um / 6 um (On-layout dimension). Please see Figure Cross-sectional view of seal-ring wall. (PM drawn pattern must cover outer seal-ring and SLDB regions.)   
  (SEALRING_ORI_OUTER OR SEALRING_DB) NOT PMi
  SEALRING_ORI_INNER AND PMi
}
#ENDIF


// Seal-Ring Wall Layout Rule Check
//=====================
CO.W.2__CO.W.3 { @ Width of CO bar in seal ring and SLDB. == ^CO_W_2/^CO_W_3  
  INT SR_CO_P4 < CO_W_2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  A = SR_CO_P4 WITH WIDTH > CO_W_2
  B = ANGLE SR_CO_P4 == 45
  C = INT B < CO_W_2 + 0.005 REGION
  D = A NOT C
  ENCLOSE RECTANGLE D 1 0.005
}
// CO.W.2 and CO.W.3 are checked by CO.W.2__CO.W.3

#IFDEF M1_V1_M2_CHECKS

M1.W.7 { @ Width of M1 metal line in outer seal-ring. (DRC tolerance at 45-degree turning: +-0.02 um) = 2 Width of M1 metal line in outer seal ring == ^M1_W_7
  X1 = ANGLE SR_M1_OUTER != 45
  X2 = ANGLE SR_M1_OUTER == 45
  WITH WIDTH SR_M1_OUTER >= M1_W_7*2
  INT X1 > M1_W_7 < M1_W_7*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M1_W_7+4*GRID < M1_W_7*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M1_W_7 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M1_W_7-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
M1.W.8 { @ Width of M1 metal line in inner seal-ring. (DRC tolerance at 45-degree turning: +-0.02 um) = 6 Width of M1 metal line in inner seal ring == ^M1_W_8
  X1 = ANGLE SR_M1_INNER != 45
  X2 = ANGLE SR_M1_INNER == 45
  WITH WIDTH SR_M1_INNER >= M1_W_8*2
  INT X1 > M1_W_8 < M1_W_8*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M1_W_8+4*GRID < M1_W_8*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M1_W_8 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M1_W_8-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
M1.W.6 { @ Width of M1 metal line in SLDB = 0.5 Width of M1 metal line in SLDB == ^M1_W_6
  X1 = ANGLE SLDB_M1_LINE != 45
  X2 = ANGLE SLDB_M1_LINE == 45
  WITH WIDTH SLDB_M1_LINE >= M1_W_6*2
  INT X1 > M1_W_6 < M1_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M1_W_6+4*GRID < M1_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M1_W_6 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M1_W_6-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}


SR_VIA1_BAR_SLDB = SR_VIA1_BAR AND SEALRING_DB	
SR_VIA1_BAR_SR = SR_VIA1_BAR NOT SEALRING_DB	
SR_VIA1_HOLE_SLDB = SR_VIA1_HOLE AND SEALRING_DB
SR_VIA1_HOLE_SR = SR_VIA1_HOLE NOT SEALRING_DB

VIA1.W.2__VIA1.W.4 { @ Width of VIA1(VIAx) bar of sealring/SLDB = ^VIA1_W_2/^VIA1_W_4
  X1 = ANGLE SR_VIA1_BAR != 45
  X2 = ANGLE SR_VIA1_BAR == 45
  INT X1 > VIA1_W_2 < VIA1_W_2*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > VIA1_W_2+GRID < VIA1_W_2*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  (WITH WIDTH SR_VIA1_BAR >= VIA1_W_2*2) ENCLOSE RECTANGLE 2 GRID
  INT X1 < VIA1_W_2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < VIA1_W_2-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'VIAx.W.2' is checked by VIA1.W.2__VIA1.W.4
//'VIAx.W.4' is checked by VIA1.W.2__VIA1.W.4
// VIA1.W.2 and VIA1.W.4 are checked by VIA1.W.2__VIA1.W.4
VIA1.W.3__VIA1.W.5 { @ Width of VIA1(VIAx) hole of sealring/SLDB = ^VIA1_W_3/^VIA1_W_5
  X1 = ANGLE SR_VIA1_HOLE != 45
  X2 = ANGLE SR_VIA1_HOLE == 45
  INT X1 > VIA1_W_3 < VIA1_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > VIA1_W_3+GRID < VIA1_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  WITH WIDTH SR_VIA1_HOLE >= VIA1_W_3*2
  INT X1 < VIA1_W_3 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < VIA1_W_3-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'VIAx.W.3' is checked by VIA1.W.3__VIA1.W.5
//'VIAx.W.5' is checked by VIA1.W.3__VIA1.W.5
// VIA1.W.3 and VIA1.W.5 are checked by VIA1.W.3__VIA1.W.5

VIA1.EN.25 { @ Enclosure of VIAx bar by Mx in seal-ring >= 0.21 
  ENC SR_VIA1_BAR_SR M1 < VIA1_EN_25 ABUT < 90 SINGULAR REGION
}
VIA1.EN.26 { @ Enclosure of VIAx hole by Mx in seal-ring >= 0.23 
  ENC SR_VIA1_HOLE_SR M1 < VIA1_EN_26 ABUT < 90 SINGULAR REGION
}
VIA1.EN.27 { @ Enclosure of VIAx hole by Mx in SLDB >= 0.03 
  ENC SR_VIA1_HOLE_SLDB M1 < VIA1_EN_27 ABUT < 90 SINGULAR REGION
}


VIA1.S.24 { @ Space of VIAx hole in seal-ring >= 0.375 
  EXT SR_VIA1_HOLE_SR < VIA1_S_24 ABUT < 90 SINGULAR REGION
}

VIA1.S.25 { @ Space of VIAx hole to VIAx bar in seal-ring >= 0.35 
  EXT SR_VIA1_HOLE_SR SR_VIA1_BAR_SR < VIA1_S_25 ABUT < 90 SINGULAR REGION
}

VIA1.S.26 { @ Opposite space of VIAx hole in SLDB >= 0.2 
  EXT SR_VIA1_HOLE_SLDB < VIA1_S_26 ABUT < 90 OPPOSITE REGION
}

VIA1.S.27 { @ Space of VIAx hole in SLDB >= 0.1 
  EXT SR_VIA1_HOLE_SLDB < VIA1_S_27 ABUT < 90 SINGULAR REGION
}

M2.W.7 { @ Width of Mx metal line in outer seal-ring. (DRC tolerance at 45-degree turning: +-0.02 um) = 2 
  X1 = ANGLE SR_M2_OUTER != 45
  X2 = ANGLE SR_M2_OUTER == 45
  WITH WIDTH SR_M2_OUTER >= M2_W_7*2
  INT X1 > M2_W_7 < M2_W_7*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M2_W_7+4*GRID < M2_W_7*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M2_W_7 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M2_W_7-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
M2.W.8 { @ Width of Mx metal line in inner seal-ring. (DRC tolerance at 45-degree turning: +-0.02 um) = 6 
  X1 = ANGLE SR_M2_INNER != 45
  X2 = ANGLE SR_M2_INNER == 45
  WITH WIDTH SR_M2_INNER >= M2_W_8*2
  INT X1 > M2_W_8 < M2_W_8*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M2_W_8+4*GRID < M2_W_8*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M2_W_8 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M2_W_8-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
M2.W.6 { @ Width of Mx metal line in SLDB. (DRC tolerance at 45-degree turning: +-0.02 um) = 0.5 
  X1 = ANGLE SLDB_M2_LINE != 45
  X2 = ANGLE SLDB_M2_LINE == 45
  WITH WIDTH SLDB_M2_LINE >= M2_W_6*2
  INT X1 > M2_W_6 < M2_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M2_W_6+4*GRID < M2_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M2_W_6 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M2_W_6-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}

M2.S.35 { @ Minimum space of Mx between Mx metal bars in the direction parallel/ vertical to prime chip edge >= 0.5 
  EXT SLDB_M2_LINE < M2_S_35 ABUT < 90 OPPOSITE REGION
}

M2.S.36 { @ Space of Mx between Mx metal bars in the direction parallel to prime chip edge between the same metal bars >= 2.5 
  INT SLDB_M2_DOT_EDGE < M2_S_36 ABUT < 90 OPPOSITE REGION
}
#ENDIF //M1_V1_M2_CHECKS

#IFDEF BACK_END
SR_VIA2_BAR_SLDB = SR_VIA2_BAR AND SEALRING_DB	
SR_VIA2_BAR_SR = SR_VIA2_BAR NOT SEALRING_DB	
SR_VIA2_HOLE_SLDB = SR_VIA2_HOLE AND SEALRING_DB
SR_VIA2_HOLE_SR = SR_VIA2_HOLE NOT SEALRING_DB

VIA2.W.2__VIA2.W.4 { @ Width of VIA2(VIAx) bar of sealring/SLDB = ^VIA2_W_2/^VIA2_W_4
  X1 = ANGLE SR_VIA2_BAR != 45
  X2 = ANGLE SR_VIA2_BAR == 45
  INT X1 > VIA2_W_2 < VIA2_W_2*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > VIA2_W_2+GRID < VIA2_W_2*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  (WITH WIDTH SR_VIA2_BAR >= VIA2_W_2*2) ENCLOSE RECTANGLE 2 GRID
  INT X1 < VIA2_W_2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < VIA2_W_2-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'VIAx.W.2' is checked by VIA2.W.2__VIA2.W.4
//'VIAx.W.4' is checked by VIA2.W.2__VIA2.W.4
// VIA2.W.2 and VIA2.W.4 are checked by VIA2.W.2__VIA2.W.4
VIA2.W.3__VIA2.W.5 { @ Width of VIA2(VIAx) hole of sealring/SLDB = ^VIA2_W_3/^VIA2_W_5
  X1 = ANGLE SR_VIA2_HOLE != 45
  X2 = ANGLE SR_VIA2_HOLE == 45
  INT X1 > VIA2_W_3 < VIA2_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
