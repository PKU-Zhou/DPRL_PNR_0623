#IFDEF M1_V1_M2_CHECKS
// M1 WMJ JOG Rules
//=============================
// Wide M1s14 space error in OPC region checking
//====================================================

Wide_M1s14 = ENCLOSE RECTANGLE (SIZE M1 BY M1_S_14_W1B/2 UNDEROVER) M1_S_14_W1B+GRID M1_S_14_L1B+GRID ORTHOGONAL ONLY
M1s14_CHECK_REGION = M1 AND (SIZE Wide_M1s14 BY M1_S_14_S1B + GRID)
M1s14_OPC_REGION_pre1 = EXT [Wide_M1s14] M1s14_CHECK_REGION < M1_S_14_S1B OPPOSITE MEASURE ALL
M1s14_OPC_REGION_pre1_H = ANGLE M1s14_OPC_REGION_pre1 == 0
M1s14_OPC_REGION_pre1_V = ANGLE M1s14_OPC_REGION_pre1 == 90
M1s14_OPC_REGION_pre0_V = INT M1s14_OPC_REGION_pre1_H [Wide_M1s14] < GRID ABUT == 90 INTERSECTING ONLY 
M1s14_OPC_REGION_pre3_V = EXT M1s14_OPC_REGION_pre1_H [Wide_M1s14] < GRID ABUT == 90 INTERSECTING ONLY 
M1s14_OPC_REGION_pre4_V = (M1s14_CHECK_REGION TOUCH INSIDE EDGE M1s14_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M1s14_OPC_REGION_pre3_V
M1s14_OPC_REGION_pre0_H = INT M1s14_OPC_REGION_pre1_V [Wide_M1s14] < GRID ABUT == 90 INTERSECTING ONLY 
M1s14_OPC_REGION_pre3_H = EXT M1s14_OPC_REGION_pre1_V [Wide_M1s14] < GRID ABUT == 90 INTERSECTING ONLY 
M1s14_OPC_REGION_pre4_H = (M1s14_CHECK_REGION TOUCH INSIDE EDGE M1s14_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M1s14_OPC_REGION_pre3_H
M1s14_OPC_REGION_pre5_H = (EXPAND EDGE M1s14_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M1s14_OPC_REGION_pre4_V BY GRID)
M1s14_OPC_REGION_pre5_V = (EXPAND EDGE M1s14_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M1s14_OPC_REGION_pre4_H BY GRID)
M1s14_OPC_REGION_pre6_H = DFM PROPERTY M1s14_OPC_REGION_pre5_H M1s14_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M1s14_OPC_REGION_pre1_H)] > M1_S_14_L1B
M1s14_OPC_REGION_pre6_V = DFM PROPERTY M1s14_OPC_REGION_pre5_V M1s14_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M1s14_OPC_REGION_pre1_V)] > M1_S_14_L1B
M1s14_OPC_REGION_pre7_H = M1s14_OPC_REGION_pre1_H INSIDE EDGE M1s14_OPC_REGION_pre6_H
M1s14_OPC_REGION_pre7_V = M1s14_OPC_REGION_pre1_V INSIDE EDGE M1s14_OPC_REGION_pre6_V
M1s14_OPC_REGION_pre2_H = EXT M1s14_OPC_REGION_pre7_H M1s14_CHECK_REGION < M1_S_14_S1B OPPOSITE REGION MEASURE ALL
M1s14_OPC_REGION_pre2_V = EXT M1s14_OPC_REGION_pre7_V M1s14_CHECK_REGION < M1_S_14_S1B OPPOSITE REGION MEASURE ALL

M1s14_M1_H = M1 INTERACT M1s14_OPC_REGION_pre2_H
M1s14_M1_V = M1 INTERACT M1s14_OPC_REGION_pre2_V
M1s14_M1_ALL = M1s14_M1_H OR M1s14_M1_V
M1s14_OPC_EDGE_H = ANGLE (M1s14_M1_H NOT OUTSIDE EDGE M1s14_OPC_REGION_pre2_H) == 0
M1s14_OPC_EDGE_V = ANGLE (M1s14_M1_V NOT OUTSIDE EDGE M1s14_OPC_REGION_pre2_V) == 90

Wide_M1s14_H = Wide_M1s14 INTERACT M1s14_OPC_REGION_pre2_H
Wide_M1s14_V = Wide_M1s14 INTERACT M1s14_OPC_REGION_pre2_V
Wide_M1s14_WI_JOG_H = (M1 AND (Wide_M1s14_H OR M1s14_OPC_REGION_pre2_H)) INTERACT Wide_M1s14_H
Wide_M1s14_WI_JOG_V = (M1 AND (Wide_M1s14_V OR M1s14_OPC_REGION_pre2_V)) INTERACT Wide_M1s14_V

Wide_M1s14_WI_EXT_EDGE_H = M1s14_OPC_EDGE_H NOT COIN EDGE (INT [M1s14_OPC_EDGE_H] M1s14_M1_H <= M1_S_14_W1B OPPOSITE)
Wide_M1s14_WI_EXT_EDGE_V = M1s14_OPC_EDGE_V NOT COIN EDGE (INT [M1s14_OPC_EDGE_V] M1s14_M1_V <= M1_S_14_W1B OPPOSITE)

M1s14_OPC_REGION_H = (EXT Wide_M1s14_WI_JOG_H M1s14_OPC_EDGE_H < M1_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s14_OPC_REGION_pre2_H
M1s14_OPC_REGION_V = (EXT Wide_M1s14_WI_JOG_V M1s14_OPC_EDGE_V < M1_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s14_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M1s14_SP_err1_REG_H = (EXT Wide_M1s14_WI_EXT_EDGE_H M1s14_M1_H < M1_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s14_OPC_REGION_H
M1s14_SP_err1_REG_V = (EXT Wide_M1s14_WI_EXT_EDGE_V M1s14_M1_V < M1_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s14_OPC_REGION_V
M1s14_EDGE_H_err3 = ANGLE M1s14_SP_err1_REG_H == 0
M1s14_EDGE_V_err3 = ANGLE M1s14_SP_err1_REG_V == 90
M1s14_SP_err1_REG_H_eff = DFM PROPERTY M1s14_SP_err1_REG_H M1s14_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M1s14_EDGE_H_err3)] <= 2*M1_S_14_L2A
M1s14_SP_err1_REG_V_eff = DFM PROPERTY M1s14_SP_err1_REG_V M1s14_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M1s14_EDGE_V_err3)] <= 2*M1_S_14_L2A

  M1s14_R1_CHK = EXT Wide_M1s14 M1s14_M1_ALL < M1_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M1s14_NOTCH_EDGE_H = ANGLE (EXT [Wide_M1s14_WI_JOG_H] < M1_S_14_S1B OPPOSITE NOTCH) == 0
  M1s14_NOTCH_EDGE_V = ANGLE (EXT [Wide_M1s14_WI_JOG_V] < M1_S_14_S1B OPPOSITE NOTCH) == 90
  M1s14_NOTCH_REGION_H = (EXT M1s14_NOTCH_EDGE_H < M1_S_14_S1B OPPOSITE REGION) AND M1s14_OPC_REGION_H
  M1s14_NOTCH_REGION_V = (EXT M1s14_NOTCH_EDGE_V < M1_S_14_S1B OPPOSITE REGION) AND M1s14_OPC_REGION_V
  
// Check NON-Notch region
  M1s14_SP_err1_REG_H_eff5 = M1s14_SP_err1_REG_H_eff NOT M1s14_NOTCH_REGION_H
  M1s14_SP_err1_REG_V_eff5 = M1s14_SP_err1_REG_V_eff NOT M1s14_NOTCH_REGION_V
  CONNECT M1s14_SP_err1_REG_H_eff5 (M1s14_OPC_REGION_H NOT M1s14_NOTCH_REGION_H)
  CONNECT M1s14_SP_err1_REG_V_eff5 (M1s14_OPC_REGION_V NOT M1s14_NOTCH_REGION_V)
  M1s14_SP_err1_REG_H_eff5a = M1s14_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M1s14_CHECK_REGION
  M1s14_SP_err1_REG_V_eff5a = M1s14_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M1s14_CHECK_REGION
  M1s14_S3C_NNH_H = (EXT M1s14_SP_err1_REG_H_eff5a < M1_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M1
  M1s14_S3C_NNH_V = (EXT M1s14_SP_err1_REG_V_eff5a < M1_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M1
  
// Check Notch H region
  M1s14_SP_err1_REG_H_eff6 = M1s14_SP_err1_REG_H_eff INSIDE M1s14_NOTCH_REGION_H
  M1s14_SP_err1_REG_V_eff6 = M1s14_SP_err1_REG_V_eff INSIDE M1s14_NOTCH_REGION_V
  CONNECT M1s14_SP_err1_REG_H_eff6 M1s14_NOTCH_REGION_H
  CONNECT M1s14_SP_err1_REG_V_eff6 M1s14_NOTCH_REGION_V  
  M1s14_SP_err1_REG_H_eff6a = M1s14_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M1s14_CHECK_REGION
  M1s14_SP_err1_REG_V_eff6a = M1s14_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M1s14_CHECK_REGION
  M1s14_S3C_NH_H = (EXT M1s14_SP_err1_REG_H_eff6a < M1_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M1
  M1s14_S3C_NH_V = (EXT M1s14_SP_err1_REG_V_eff6a < M1_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M1

// Find Space error region(large space S2A2) //
M1s14_SP_err2_REG_H = (EXT Wide_M1s14_WI_EXT_EDGE_H M1s14_OPC_EDGE_H < M1_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s14_OPC_REGION_H
M1s14_SP_err2_REG_V = (EXT Wide_M1s14_WI_EXT_EDGE_V M1s14_OPC_EDGE_V < M1_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s14_OPC_REGION_V
M1s14_EDGE_H_err2 = M1s14_SP_err2_REG_H COIN EDGE M1s14_OPC_EDGE_H
M1s14_EDGE_V_err2 = M1s14_SP_err2_REG_V COIN EDGE M1s14_OPC_EDGE_V

M1s14_SP_err2_REG_H_eff1 = DFM PROPERTY M1s14_SP_err2_REG_H M1s14_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M1s14_EDGE_H_err2)] > 2*M1_S_14_L2A
M1s14_SP_err2_REG_V_eff1 = DFM PROPERTY M1s14_SP_err2_REG_V M1s14_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M1s14_EDGE_V_err2)] > 2*M1_S_14_L2A

// Find Space error region(small space S2A3) //
M1s14_SP_err3_REG_H = (EXT Wide_M1s14_WI_EXT_EDGE_H M1s14_OPC_EDGE_H < M1_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s14_OPC_REGION_H
M1s14_SP_err3_REG_V = (EXT Wide_M1s14_WI_EXT_EDGE_V M1s14_OPC_EDGE_V < M1_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s14_OPC_REGION_V


M1.S.14 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.08 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.29 um (S1B) region >= 0.3 
  ((M1s14_SP_err1_REG_H_eff INTERACT M1s14_S3C_NNH_H) OR M1s14_S3C_NNH_H) INTERACT M1s14_R1_CHK
  ((M1s14_SP_err1_REG_H_eff INTERACT M1s14_S3C_NH_H) OR M1s14_S3C_NH_H) INTERACT M1s14_R1_CHK
  ((M1s14_SP_err1_REG_V_eff INTERACT M1s14_S3C_NNH_V) OR M1s14_S3C_NNH_V) INTERACT M1s14_R1_CHK
  ((M1s14_SP_err1_REG_V_eff INTERACT M1s14_S3C_NH_V) OR M1s14_S3C_NH_V) INTERACT M1s14_R1_CHK
}
M1.S.15 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.1 
  (M1s14_SP_err2_REG_H_eff1 AND M1s14_OPC_REGION_H) INTERACT Wide_M1s14_WI_JOG_H
  (M1s14_SP_err2_REG_V_eff1 AND M1s14_OPC_REGION_V) INTERACT Wide_M1s14_WI_JOG_V
}
M1.S.16 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M1s14_SP_err3_REG_H AND M1s14_OPC_REGION_H) INTERACT Wide_M1s14_WI_JOG_H
  (M1s14_SP_err3_REG_V AND M1s14_OPC_REGION_V) INTERACT Wide_M1s14_WI_JOG_V
}

// Wide M1s17 space error in OPC region checking
//====================================================

Wide_M1s17 = ENCLOSE RECTANGLE (SIZE M1 BY M1_S_17_W1B/2 UNDEROVER) M1_S_17_W1B+GRID M1_S_17_L1B+GRID ORTHOGONAL ONLY
M1s17_CHECK_REGION = M1 AND (SIZE Wide_M1s17 BY M1_S_17_S1B + GRID)
M1s17_OPC_REGION_pre1 = EXT [Wide_M1s17] M1s17_CHECK_REGION < M1_S_17_S1B OPPOSITE MEASURE ALL
M1s17_OPC_REGION_pre1_H = ANGLE M1s17_OPC_REGION_pre1 == 0
M1s17_OPC_REGION_pre1_V = ANGLE M1s17_OPC_REGION_pre1 == 90
M1s17_OPC_REGION_pre0_V = INT M1s17_OPC_REGION_pre1_H [Wide_M1s17] < GRID ABUT == 90 INTERSECTING ONLY 
M1s17_OPC_REGION_pre3_V = EXT M1s17_OPC_REGION_pre1_H [Wide_M1s17] < GRID ABUT == 90 INTERSECTING ONLY 
M1s17_OPC_REGION_pre4_V = (M1s17_CHECK_REGION TOUCH INSIDE EDGE M1s17_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M1s17_OPC_REGION_pre3_V
M1s17_OPC_REGION_pre0_H = INT M1s17_OPC_REGION_pre1_V [Wide_M1s17] < GRID ABUT == 90 INTERSECTING ONLY 
M1s17_OPC_REGION_pre3_H = EXT M1s17_OPC_REGION_pre1_V [Wide_M1s17] < GRID ABUT == 90 INTERSECTING ONLY 
M1s17_OPC_REGION_pre4_H = (M1s17_CHECK_REGION TOUCH INSIDE EDGE M1s17_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M1s17_OPC_REGION_pre3_H
M1s17_OPC_REGION_pre5_H = (EXPAND EDGE M1s17_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M1s17_OPC_REGION_pre4_V BY GRID)
M1s17_OPC_REGION_pre5_V = (EXPAND EDGE M1s17_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M1s17_OPC_REGION_pre4_H BY GRID)
M1s17_OPC_REGION_pre6_H = DFM PROPERTY M1s17_OPC_REGION_pre5_H M1s17_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M1s17_OPC_REGION_pre1_H)] > M1_S_17_L1B
M1s17_OPC_REGION_pre6_V = DFM PROPERTY M1s17_OPC_REGION_pre5_V M1s17_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M1s17_OPC_REGION_pre1_V)] > M1_S_17_L1B
M1s17_OPC_REGION_pre7_H = M1s17_OPC_REGION_pre1_H INSIDE EDGE M1s17_OPC_REGION_pre6_H
M1s17_OPC_REGION_pre7_V = M1s17_OPC_REGION_pre1_V INSIDE EDGE M1s17_OPC_REGION_pre6_V
M1s17_OPC_REGION_pre2_H = EXT M1s17_OPC_REGION_pre7_H M1s17_CHECK_REGION < M1_S_17_S1B OPPOSITE REGION MEASURE ALL
M1s17_OPC_REGION_pre2_V = EXT M1s17_OPC_REGION_pre7_V M1s17_CHECK_REGION < M1_S_17_S1B OPPOSITE REGION MEASURE ALL

M1s17_M1_H = M1 INTERACT M1s17_OPC_REGION_pre2_H
M1s17_M1_V = M1 INTERACT M1s17_OPC_REGION_pre2_V
M1s17_M1_ALL = M1s17_M1_H OR M1s17_M1_V
M1s17_OPC_EDGE_H = ANGLE (M1s17_M1_H NOT OUTSIDE EDGE M1s17_OPC_REGION_pre2_H) == 0
M1s17_OPC_EDGE_V = ANGLE (M1s17_M1_V NOT OUTSIDE EDGE M1s17_OPC_REGION_pre2_V) == 90

Wide_M1s17_H = Wide_M1s17 INTERACT M1s17_OPC_REGION_pre2_H
Wide_M1s17_V = Wide_M1s17 INTERACT M1s17_OPC_REGION_pre2_V
Wide_M1s17_WI_JOG_H = (M1 AND (Wide_M1s17_H OR M1s17_OPC_REGION_pre2_H)) INTERACT Wide_M1s17_H
Wide_M1s17_WI_JOG_V = (M1 AND (Wide_M1s17_V OR M1s17_OPC_REGION_pre2_V)) INTERACT Wide_M1s17_V

Wide_M1s17_WI_EXT_EDGE_H = M1s17_OPC_EDGE_H NOT COIN EDGE (INT [M1s17_OPC_EDGE_H] M1s17_M1_H <= M1_S_17_W1B OPPOSITE)
Wide_M1s17_WI_EXT_EDGE_V = M1s17_OPC_EDGE_V NOT COIN EDGE (INT [M1s17_OPC_EDGE_V] M1s17_M1_V <= M1_S_17_W1B OPPOSITE)

M1s17_OPC_REGION_H = (EXT Wide_M1s17_WI_JOG_H M1s17_OPC_EDGE_H < M1_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s17_OPC_REGION_pre2_H
M1s17_OPC_REGION_V = (EXT Wide_M1s17_WI_JOG_V M1s17_OPC_EDGE_V < M1_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s17_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M1s17_SP_err1_REG_H = (EXT Wide_M1s17_WI_EXT_EDGE_H M1s17_M1_H < M1_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s17_OPC_REGION_H
M1s17_SP_err1_REG_V = (EXT Wide_M1s17_WI_EXT_EDGE_V M1s17_M1_V < M1_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s17_OPC_REGION_V
M1s17_EDGE_H_err3 = ANGLE M1s17_SP_err1_REG_H == 0
M1s17_EDGE_V_err3 = ANGLE M1s17_SP_err1_REG_V == 90
M1s17_SP_err1_REG_H_eff = DFM PROPERTY M1s17_SP_err1_REG_H M1s17_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M1s17_EDGE_H_err3)] <= 2*M1_S_17_L2A
M1s17_SP_err1_REG_V_eff = DFM PROPERTY M1s17_SP_err1_REG_V M1s17_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M1s17_EDGE_V_err3)] <= 2*M1_S_17_L2A

  M1s17_R1_CHK = EXT Wide_M1s17 M1s17_M1_ALL < M1_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M1s17_NOTCH_EDGE_H = ANGLE (EXT [Wide_M1s17_WI_JOG_H] < M1_S_17_S1B OPPOSITE NOTCH) == 0
  M1s17_NOTCH_EDGE_V = ANGLE (EXT [Wide_M1s17_WI_JOG_V] < M1_S_17_S1B OPPOSITE NOTCH) == 90
  M1s17_NOTCH_REGION_H = (EXT M1s17_NOTCH_EDGE_H < M1_S_17_S1B OPPOSITE REGION) AND M1s17_OPC_REGION_H
  M1s17_NOTCH_REGION_V = (EXT M1s17_NOTCH_EDGE_V < M1_S_17_S1B OPPOSITE REGION) AND M1s17_OPC_REGION_V
  
// Check NON-Notch region
  M1s17_SP_err1_REG_H_eff5 = M1s17_SP_err1_REG_H_eff NOT M1s17_NOTCH_REGION_H
  M1s17_SP_err1_REG_V_eff5 = M1s17_SP_err1_REG_V_eff NOT M1s17_NOTCH_REGION_V
  CONNECT M1s17_SP_err1_REG_H_eff5 (M1s17_OPC_REGION_H NOT M1s17_NOTCH_REGION_H)
  CONNECT M1s17_SP_err1_REG_V_eff5 (M1s17_OPC_REGION_V NOT M1s17_NOTCH_REGION_V)
  M1s17_SP_err1_REG_H_eff5a = M1s17_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M1s17_CHECK_REGION
  M1s17_SP_err1_REG_V_eff5a = M1s17_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M1s17_CHECK_REGION
  M1s17_S3C_NNH_H = (EXT M1s17_SP_err1_REG_H_eff5a < M1_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M1
  M1s17_S3C_NNH_V = (EXT M1s17_SP_err1_REG_V_eff5a < M1_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M1
  
// Check Notch H region
  M1s17_SP_err1_REG_H_eff6 = M1s17_SP_err1_REG_H_eff INSIDE M1s17_NOTCH_REGION_H
  M1s17_SP_err1_REG_V_eff6 = M1s17_SP_err1_REG_V_eff INSIDE M1s17_NOTCH_REGION_V
  CONNECT M1s17_SP_err1_REG_H_eff6 M1s17_NOTCH_REGION_H
  CONNECT M1s17_SP_err1_REG_V_eff6 M1s17_NOTCH_REGION_V  
  M1s17_SP_err1_REG_H_eff6a = M1s17_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M1s17_CHECK_REGION
  M1s17_SP_err1_REG_V_eff6a = M1s17_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M1s17_CHECK_REGION
  M1s17_S3C_NH_H = (EXT M1s17_SP_err1_REG_H_eff6a < M1_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M1
  M1s17_S3C_NH_V = (EXT M1s17_SP_err1_REG_V_eff6a < M1_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M1

// Find Space error region(large space S2A2) //
M1s17_SP_err2_REG_H = (EXT Wide_M1s17_WI_EXT_EDGE_H M1s17_OPC_EDGE_H < M1_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s17_OPC_REGION_H
M1s17_SP_err2_REG_V = (EXT Wide_M1s17_WI_EXT_EDGE_V M1s17_OPC_EDGE_V < M1_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s17_OPC_REGION_V
M1s17_EDGE_H_err2 = M1s17_SP_err2_REG_H COIN EDGE M1s17_OPC_EDGE_H
M1s17_EDGE_V_err2 = M1s17_SP_err2_REG_V COIN EDGE M1s17_OPC_EDGE_V

M1s17_SP_err2_REG_H_eff1 = DFM PROPERTY M1s17_SP_err2_REG_H M1s17_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M1s17_EDGE_H_err2)] > 2*M1_S_17_L2A
M1s17_SP_err2_REG_V_eff1 = DFM PROPERTY M1s17_SP_err2_REG_V M1s17_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M1s17_EDGE_V_err2)] > 2*M1_S_17_L2A

// Find Space error region(small space S2A3) //
M1s17_SP_err3_REG_H = (EXT Wide_M1s17_WI_EXT_EDGE_H M1s17_OPC_EDGE_H < M1_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s17_OPC_REGION_H
M1s17_SP_err3_REG_V = (EXT Wide_M1s17_WI_EXT_EDGE_V M1s17_OPC_EDGE_V < M1_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s17_OPC_REGION_V


M1.S.17 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.47 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.13 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.47 um (W1B) and the parallel run length > 0.5 um (L1B) in metal space < 0.32 um (S1B) region >= 0.3 
  ((M1s17_SP_err1_REG_H_eff INTERACT M1s17_S3C_NNH_H) OR M1s17_S3C_NNH_H) INTERACT M1s17_R1_CHK
  ((M1s17_SP_err1_REG_H_eff INTERACT M1s17_S3C_NH_H) OR M1s17_S3C_NH_H) INTERACT M1s17_R1_CHK
  ((M1s17_SP_err1_REG_V_eff INTERACT M1s17_S3C_NNH_V) OR M1s17_S3C_NNH_V) INTERACT M1s17_R1_CHK
  ((M1s17_SP_err1_REG_V_eff INTERACT M1s17_S3C_NH_V) OR M1s17_S3C_NH_V) INTERACT M1s17_R1_CHK
}
M1.S.18 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.13 
  (M1s17_SP_err2_REG_H_eff1 AND M1s17_OPC_REGION_H) INTERACT Wide_M1s17_WI_JOG_H
  (M1s17_SP_err2_REG_V_eff1 AND M1s17_OPC_REGION_V) INTERACT Wide_M1s17_WI_JOG_V
}
M1.S.19 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M1s17_SP_err3_REG_H AND M1s17_OPC_REGION_H) INTERACT Wide_M1s17_WI_JOG_H
  (M1s17_SP_err3_REG_V AND M1s17_OPC_REGION_V) INTERACT Wide_M1s17_WI_JOG_V
}

// Wide M1s20 space error in OPC region checking
//====================================================

Wide_M1s20 = ENCLOSE RECTANGLE (SIZE M1 BY M1_S_20_W1B/2 UNDEROVER) M1_S_20_W1B+GRID M1_S_20_L1B+GRID ORTHOGONAL ONLY
M1s20_CHECK_REGION = M1 AND (SIZE Wide_M1s20 BY M1_S_20_S1B + GRID)
M1s20_OPC_REGION_pre1 = EXT [Wide_M1s20] M1s20_CHECK_REGION < M1_S_20_S1B OPPOSITE MEASURE ALL
M1s20_OPC_REGION_pre1_H = ANGLE M1s20_OPC_REGION_pre1 == 0
M1s20_OPC_REGION_pre1_V = ANGLE M1s20_OPC_REGION_pre1 == 90
M1s20_OPC_REGION_pre0_V = INT M1s20_OPC_REGION_pre1_H [Wide_M1s20] < GRID ABUT == 90 INTERSECTING ONLY 
M1s20_OPC_REGION_pre3_V = EXT M1s20_OPC_REGION_pre1_H [Wide_M1s20] < GRID ABUT == 90 INTERSECTING ONLY 
M1s20_OPC_REGION_pre4_V = (M1s20_CHECK_REGION TOUCH INSIDE EDGE M1s20_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M1s20_OPC_REGION_pre3_V
M1s20_OPC_REGION_pre0_H = INT M1s20_OPC_REGION_pre1_V [Wide_M1s20] < GRID ABUT == 90 INTERSECTING ONLY 
M1s20_OPC_REGION_pre3_H = EXT M1s20_OPC_REGION_pre1_V [Wide_M1s20] < GRID ABUT == 90 INTERSECTING ONLY 
M1s20_OPC_REGION_pre4_H = (M1s20_CHECK_REGION TOUCH INSIDE EDGE M1s20_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M1s20_OPC_REGION_pre3_H
M1s20_OPC_REGION_pre5_H = (EXPAND EDGE M1s20_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M1s20_OPC_REGION_pre4_V BY GRID)
M1s20_OPC_REGION_pre5_V = (EXPAND EDGE M1s20_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M1s20_OPC_REGION_pre4_H BY GRID)
M1s20_OPC_REGION_pre6_H = DFM PROPERTY M1s20_OPC_REGION_pre5_H M1s20_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M1s20_OPC_REGION_pre1_H)] > M1_S_20_L1B
M1s20_OPC_REGION_pre6_V = DFM PROPERTY M1s20_OPC_REGION_pre5_V M1s20_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M1s20_OPC_REGION_pre1_V)] > M1_S_20_L1B
M1s20_OPC_REGION_pre7_H = M1s20_OPC_REGION_pre1_H INSIDE EDGE M1s20_OPC_REGION_pre6_H
M1s20_OPC_REGION_pre7_V = M1s20_OPC_REGION_pre1_V INSIDE EDGE M1s20_OPC_REGION_pre6_V
M1s20_OPC_REGION_pre2_H = EXT M1s20_OPC_REGION_pre7_H M1s20_CHECK_REGION < M1_S_20_S1B OPPOSITE REGION MEASURE ALL
M1s20_OPC_REGION_pre2_V = EXT M1s20_OPC_REGION_pre7_V M1s20_CHECK_REGION < M1_S_20_S1B OPPOSITE REGION MEASURE ALL

M1s20_M1_H = M1 INTERACT M1s20_OPC_REGION_pre2_H
M1s20_M1_V = M1 INTERACT M1s20_OPC_REGION_pre2_V
M1s20_M1_ALL = M1s20_M1_H OR M1s20_M1_V
M1s20_OPC_EDGE_H = ANGLE (M1s20_M1_H NOT OUTSIDE EDGE M1s20_OPC_REGION_pre2_H) == 0
M1s20_OPC_EDGE_V = ANGLE (M1s20_M1_V NOT OUTSIDE EDGE M1s20_OPC_REGION_pre2_V) == 90

Wide_M1s20_H = Wide_M1s20 INTERACT M1s20_OPC_REGION_pre2_H
Wide_M1s20_V = Wide_M1s20 INTERACT M1s20_OPC_REGION_pre2_V
Wide_M1s20_WI_JOG_H = (M1 AND (Wide_M1s20_H OR M1s20_OPC_REGION_pre2_H)) INTERACT Wide_M1s20_H
Wide_M1s20_WI_JOG_V = (M1 AND (Wide_M1s20_V OR M1s20_OPC_REGION_pre2_V)) INTERACT Wide_M1s20_V

Wide_M1s20_WI_EXT_EDGE_H = M1s20_OPC_EDGE_H NOT COIN EDGE (INT [M1s20_OPC_EDGE_H] M1s20_M1_H <= M1_S_20_W1B OPPOSITE)
Wide_M1s20_WI_EXT_EDGE_V = M1s20_OPC_EDGE_V NOT COIN EDGE (INT [M1s20_OPC_EDGE_V] M1s20_M1_V <= M1_S_20_W1B OPPOSITE)

M1s20_OPC_REGION_H = (EXT Wide_M1s20_WI_JOG_H M1s20_OPC_EDGE_H < M1_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s20_OPC_REGION_pre2_H
M1s20_OPC_REGION_V = (EXT Wide_M1s20_WI_JOG_V M1s20_OPC_EDGE_V < M1_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s20_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M1s20_SP_err1_REG_H = (EXT Wide_M1s20_WI_EXT_EDGE_H M1s20_M1_H < M1_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s20_OPC_REGION_H
M1s20_SP_err1_REG_V = (EXT Wide_M1s20_WI_EXT_EDGE_V M1s20_M1_V < M1_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s20_OPC_REGION_V
M1s20_EDGE_H_err3 = ANGLE M1s20_SP_err1_REG_H == 0
M1s20_EDGE_V_err3 = ANGLE M1s20_SP_err1_REG_V == 90
M1s20_SP_err1_REG_H_eff = DFM PROPERTY M1s20_SP_err1_REG_H M1s20_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M1s20_EDGE_H_err3)] <= 2*M1_S_20_L2A
M1s20_SP_err1_REG_V_eff = DFM PROPERTY M1s20_SP_err1_REG_V M1s20_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M1s20_EDGE_V_err3)] <= 2*M1_S_20_L2A

  M1s20_R1_CHK = EXT Wide_M1s20 M1s20_M1_ALL < M1_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M1s20_NOTCH_EDGE_H = ANGLE (EXT [Wide_M1s20_WI_JOG_H] < M1_S_20_S1B OPPOSITE NOTCH) == 0
  M1s20_NOTCH_EDGE_V = ANGLE (EXT [Wide_M1s20_WI_JOG_V] < M1_S_20_S1B OPPOSITE NOTCH) == 90
  M1s20_NOTCH_REGION_H = (EXT M1s20_NOTCH_EDGE_H < M1_S_20_S1B OPPOSITE REGION) AND M1s20_OPC_REGION_H
  M1s20_NOTCH_REGION_V = (EXT M1s20_NOTCH_EDGE_V < M1_S_20_S1B OPPOSITE REGION) AND M1s20_OPC_REGION_V
  
// Check NON-Notch region
  M1s20_SP_err1_REG_H_eff5 = M1s20_SP_err1_REG_H_eff NOT M1s20_NOTCH_REGION_H
  M1s20_SP_err1_REG_V_eff5 = M1s20_SP_err1_REG_V_eff NOT M1s20_NOTCH_REGION_V
  CONNECT M1s20_SP_err1_REG_H_eff5 (M1s20_OPC_REGION_H NOT M1s20_NOTCH_REGION_H)
  CONNECT M1s20_SP_err1_REG_V_eff5 (M1s20_OPC_REGION_V NOT M1s20_NOTCH_REGION_V)
  M1s20_SP_err1_REG_H_eff5a = M1s20_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M1s20_CHECK_REGION
  M1s20_SP_err1_REG_V_eff5a = M1s20_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M1s20_CHECK_REGION
  M1s20_S3C_NNH_H = (EXT M1s20_SP_err1_REG_H_eff5a < M1_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M1
  M1s20_S3C_NNH_V = (EXT M1s20_SP_err1_REG_V_eff5a < M1_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M1
  
// Check Notch H region
  M1s20_SP_err1_REG_H_eff6 = M1s20_SP_err1_REG_H_eff INSIDE M1s20_NOTCH_REGION_H
  M1s20_SP_err1_REG_V_eff6 = M1s20_SP_err1_REG_V_eff INSIDE M1s20_NOTCH_REGION_V
  CONNECT M1s20_SP_err1_REG_H_eff6 M1s20_NOTCH_REGION_H
  CONNECT M1s20_SP_err1_REG_V_eff6 M1s20_NOTCH_REGION_V  
  M1s20_SP_err1_REG_H_eff6a = M1s20_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M1s20_CHECK_REGION
  M1s20_SP_err1_REG_V_eff6a = M1s20_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M1s20_CHECK_REGION
  M1s20_S3C_NH_H = (EXT M1s20_SP_err1_REG_H_eff6a < M1_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M1
  M1s20_S3C_NH_V = (EXT M1s20_SP_err1_REG_V_eff6a < M1_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M1

// Find Space error region(large space S2A2) //
M1s20_SP_err2_REG_H = (EXT Wide_M1s20_WI_EXT_EDGE_H M1s20_OPC_EDGE_H < M1_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s20_OPC_REGION_H
M1s20_SP_err2_REG_V = (EXT Wide_M1s20_WI_EXT_EDGE_V M1s20_OPC_EDGE_V < M1_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s20_OPC_REGION_V
M1s20_EDGE_H_err2 = M1s20_SP_err2_REG_H COIN EDGE M1s20_OPC_EDGE_H
M1s20_EDGE_V_err2 = M1s20_SP_err2_REG_V COIN EDGE M1s20_OPC_EDGE_V

M1s20_SP_err2_REG_H_eff1 = DFM PROPERTY M1s20_SP_err2_REG_H M1s20_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M1s20_EDGE_H_err2)] > 2*M1_S_20_L2A
M1s20_SP_err2_REG_V_eff1 = DFM PROPERTY M1s20_SP_err2_REG_V M1s20_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M1s20_EDGE_V_err2)] > 2*M1_S_20_L2A

// Find Space error region(small space S2A3) //
M1s20_SP_err3_REG_H = (EXT Wide_M1s20_WI_EXT_EDGE_H M1s20_OPC_EDGE_H < M1_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s20_OPC_REGION_H
M1s20_SP_err3_REG_V = (EXT Wide_M1s20_WI_EXT_EDGE_V M1s20_OPC_EDGE_V < M1_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s20_OPC_REGION_V


M1.S.20 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.63 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.15 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.63 um (W1B) and the parallel run length > 0.7 um (L1B) in metal space < 0.34 um (S1B) region >= 0.3 
  ((M1s20_SP_err1_REG_H_eff INTERACT M1s20_S3C_NNH_H) OR M1s20_S3C_NNH_H) INTERACT M1s20_R1_CHK
  ((M1s20_SP_err1_REG_H_eff INTERACT M1s20_S3C_NH_H) OR M1s20_S3C_NH_H) INTERACT M1s20_R1_CHK
  ((M1s20_SP_err1_REG_V_eff INTERACT M1s20_S3C_NNH_V) OR M1s20_S3C_NNH_V) INTERACT M1s20_R1_CHK
  ((M1s20_SP_err1_REG_V_eff INTERACT M1s20_S3C_NH_V) OR M1s20_S3C_NH_V) INTERACT M1s20_R1_CHK
}
M1.S.21 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.15 
  (M1s20_SP_err2_REG_H_eff1 AND M1s20_OPC_REGION_H) INTERACT Wide_M1s20_WI_JOG_H
  (M1s20_SP_err2_REG_V_eff1 AND M1s20_OPC_REGION_V) INTERACT Wide_M1s20_WI_JOG_V
}
M1.S.22 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M1s20_SP_err3_REG_H AND M1s20_OPC_REGION_H) INTERACT Wide_M1s20_WI_JOG_H
  (M1s20_SP_err3_REG_V AND M1s20_OPC_REGION_V) INTERACT Wide_M1s20_WI_JOG_V
}

// Wide M1s23 space error in OPC region checking
//====================================================

Wide_M1s23 = ENCLOSE RECTANGLE (SIZE M1 BY M1_S_23_W1B/2 UNDEROVER) M1_S_23_W1B+GRID M1_S_23_L1B+GRID ORTHOGONAL ONLY
M1s23_CHECK_REGION = M1 AND (SIZE Wide_M1s23 BY M1_S_23_S1B + GRID)
M1s23_OPC_REGION_pre1 = EXT [Wide_M1s23] M1s23_CHECK_REGION < M1_S_23_S1B OPPOSITE MEASURE ALL
M1s23_OPC_REGION_pre1_H = ANGLE M1s23_OPC_REGION_pre1 == 0
M1s23_OPC_REGION_pre1_V = ANGLE M1s23_OPC_REGION_pre1 == 90
M1s23_OPC_REGION_pre0_V = INT M1s23_OPC_REGION_pre1_H [Wide_M1s23] < GRID ABUT == 90 INTERSECTING ONLY 
M1s23_OPC_REGION_pre3_V = EXT M1s23_OPC_REGION_pre1_H [Wide_M1s23] < GRID ABUT == 90 INTERSECTING ONLY 
M1s23_OPC_REGION_pre4_V = (M1s23_CHECK_REGION TOUCH INSIDE EDGE M1s23_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M1s23_OPC_REGION_pre3_V
M1s23_OPC_REGION_pre0_H = INT M1s23_OPC_REGION_pre1_V [Wide_M1s23] < GRID ABUT == 90 INTERSECTING ONLY 
M1s23_OPC_REGION_pre3_H = EXT M1s23_OPC_REGION_pre1_V [Wide_M1s23] < GRID ABUT == 90 INTERSECTING ONLY 
M1s23_OPC_REGION_pre4_H = (M1s23_CHECK_REGION TOUCH INSIDE EDGE M1s23_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M1s23_OPC_REGION_pre3_H
M1s23_OPC_REGION_pre5_H = (EXPAND EDGE M1s23_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M1s23_OPC_REGION_pre4_V BY GRID)
M1s23_OPC_REGION_pre5_V = (EXPAND EDGE M1s23_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M1s23_OPC_REGION_pre4_H BY GRID)
M1s23_OPC_REGION_pre6_H = DFM PROPERTY M1s23_OPC_REGION_pre5_H M1s23_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M1s23_OPC_REGION_pre1_H)] > M1_S_23_L1B
M1s23_OPC_REGION_pre6_V = DFM PROPERTY M1s23_OPC_REGION_pre5_V M1s23_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M1s23_OPC_REGION_pre1_V)] > M1_S_23_L1B
M1s23_OPC_REGION_pre7_H = M1s23_OPC_REGION_pre1_H INSIDE EDGE M1s23_OPC_REGION_pre6_H
M1s23_OPC_REGION_pre7_V = M1s23_OPC_REGION_pre1_V INSIDE EDGE M1s23_OPC_REGION_pre6_V
M1s23_OPC_REGION_pre2_H = EXT M1s23_OPC_REGION_pre7_H M1s23_CHECK_REGION < M1_S_23_S1B OPPOSITE REGION MEASURE ALL
M1s23_OPC_REGION_pre2_V = EXT M1s23_OPC_REGION_pre7_V M1s23_CHECK_REGION < M1_S_23_S1B OPPOSITE REGION MEASURE ALL

M1s23_M1_H = M1 INTERACT M1s23_OPC_REGION_pre2_H
M1s23_M1_V = M1 INTERACT M1s23_OPC_REGION_pre2_V
M1s23_M1_ALL = M1s23_M1_H OR M1s23_M1_V
M1s23_OPC_EDGE_H = ANGLE (M1s23_M1_H NOT OUTSIDE EDGE M1s23_OPC_REGION_pre2_H) == 0
M1s23_OPC_EDGE_V = ANGLE (M1s23_M1_V NOT OUTSIDE EDGE M1s23_OPC_REGION_pre2_V) == 90

Wide_M1s23_H = Wide_M1s23 INTERACT M1s23_OPC_REGION_pre2_H
Wide_M1s23_V = Wide_M1s23 INTERACT M1s23_OPC_REGION_pre2_V
Wide_M1s23_WI_JOG_H = (M1 AND (Wide_M1s23_H OR M1s23_OPC_REGION_pre2_H)) INTERACT Wide_M1s23_H
Wide_M1s23_WI_JOG_V = (M1 AND (Wide_M1s23_V OR M1s23_OPC_REGION_pre2_V)) INTERACT Wide_M1s23_V

Wide_M1s23_WI_EXT_EDGE_H = M1s23_OPC_EDGE_H NOT COIN EDGE (INT [M1s23_OPC_EDGE_H] M1s23_M1_H <= M1_S_23_W1B OPPOSITE)
Wide_M1s23_WI_EXT_EDGE_V = M1s23_OPC_EDGE_V NOT COIN EDGE (INT [M1s23_OPC_EDGE_V] M1s23_M1_V <= M1_S_23_W1B OPPOSITE)

M1s23_OPC_REGION_H = (EXT Wide_M1s23_WI_JOG_H M1s23_OPC_EDGE_H < M1_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s23_OPC_REGION_pre2_H
M1s23_OPC_REGION_V = (EXT Wide_M1s23_WI_JOG_V M1s23_OPC_EDGE_V < M1_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s23_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M1s23_SP_err1_REG_H = (EXT Wide_M1s23_WI_EXT_EDGE_H M1s23_M1_H < M1_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s23_OPC_REGION_H
M1s23_SP_err1_REG_V = (EXT Wide_M1s23_WI_EXT_EDGE_V M1s23_M1_V < M1_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s23_OPC_REGION_V
M1s23_EDGE_H_err3 = ANGLE M1s23_SP_err1_REG_H == 0
M1s23_EDGE_V_err3 = ANGLE M1s23_SP_err1_REG_V == 90
M1s23_SP_err1_REG_H_eff = DFM PROPERTY M1s23_SP_err1_REG_H M1s23_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M1s23_EDGE_H_err3)] <= 2*M1_S_23_L2A
M1s23_SP_err1_REG_V_eff = DFM PROPERTY M1s23_SP_err1_REG_V M1s23_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M1s23_EDGE_V_err3)] <= 2*M1_S_23_L2A

  M1s23_R1_CHK = EXT Wide_M1s23 M1s23_M1_ALL < M1_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M1s23_NOTCH_EDGE_H = ANGLE (EXT [Wide_M1s23_WI_JOG_H] < M1_S_23_S1B OPPOSITE NOTCH) == 0
  M1s23_NOTCH_EDGE_V = ANGLE (EXT [Wide_M1s23_WI_JOG_V] < M1_S_23_S1B OPPOSITE NOTCH) == 90
  M1s23_NOTCH_REGION_H = (EXT M1s23_NOTCH_EDGE_H < M1_S_23_S1B OPPOSITE REGION) AND M1s23_OPC_REGION_H
  M1s23_NOTCH_REGION_V = (EXT M1s23_NOTCH_EDGE_V < M1_S_23_S1B OPPOSITE REGION) AND M1s23_OPC_REGION_V
  
// Check NON-Notch region
  M1s23_SP_err1_REG_H_eff5 = M1s23_SP_err1_REG_H_eff NOT M1s23_NOTCH_REGION_H
  M1s23_SP_err1_REG_V_eff5 = M1s23_SP_err1_REG_V_eff NOT M1s23_NOTCH_REGION_V
  CONNECT M1s23_SP_err1_REG_H_eff5 (M1s23_OPC_REGION_H NOT M1s23_NOTCH_REGION_H)
  CONNECT M1s23_SP_err1_REG_V_eff5 (M1s23_OPC_REGION_V NOT M1s23_NOTCH_REGION_V)
  M1s23_SP_err1_REG_H_eff5a = M1s23_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M1s23_CHECK_REGION
  M1s23_SP_err1_REG_V_eff5a = M1s23_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M1s23_CHECK_REGION
  M1s23_S3C_NNH_H = (EXT M1s23_SP_err1_REG_H_eff5a < M1_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M1
  M1s23_S3C_NNH_V = (EXT M1s23_SP_err1_REG_V_eff5a < M1_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M1
  
// Check Notch H region
  M1s23_SP_err1_REG_H_eff6 = M1s23_SP_err1_REG_H_eff INSIDE M1s23_NOTCH_REGION_H
  M1s23_SP_err1_REG_V_eff6 = M1s23_SP_err1_REG_V_eff INSIDE M1s23_NOTCH_REGION_V
  CONNECT M1s23_SP_err1_REG_H_eff6 M1s23_NOTCH_REGION_H
  CONNECT M1s23_SP_err1_REG_V_eff6 M1s23_NOTCH_REGION_V  
  M1s23_SP_err1_REG_H_eff6a = M1s23_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M1s23_CHECK_REGION
  M1s23_SP_err1_REG_V_eff6a = M1s23_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M1s23_CHECK_REGION
  M1s23_S3C_NH_H = (EXT M1s23_SP_err1_REG_H_eff6a < M1_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M1
  M1s23_S3C_NH_V = (EXT M1s23_SP_err1_REG_V_eff6a < M1_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M1

// Find Space error region(large space S2A2) //
M1s23_SP_err2_REG_H = (EXT Wide_M1s23_WI_EXT_EDGE_H M1s23_OPC_EDGE_H < M1_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s23_OPC_REGION_H
M1s23_SP_err2_REG_V = (EXT Wide_M1s23_WI_EXT_EDGE_V M1s23_OPC_EDGE_V < M1_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s23_OPC_REGION_V
M1s23_EDGE_H_err2 = M1s23_SP_err2_REG_H COIN EDGE M1s23_OPC_EDGE_H
M1s23_EDGE_V_err2 = M1s23_SP_err2_REG_V COIN EDGE M1s23_OPC_EDGE_V

M1s23_SP_err2_REG_H_eff1 = DFM PROPERTY M1s23_SP_err2_REG_H M1s23_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M1s23_EDGE_H_err2)] > 2*M1_S_23_L2A
M1s23_SP_err2_REG_V_eff1 = DFM PROPERTY M1s23_SP_err2_REG_V M1s23_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M1s23_EDGE_V_err2)] > 2*M1_S_23_L2A

// Find Space error region(small space S2A3) //
M1s23_SP_err3_REG_H = (EXT Wide_M1s23_WI_EXT_EDGE_H M1s23_OPC_EDGE_H < M1_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s23_OPC_REGION_H
M1s23_SP_err3_REG_V = (EXT Wide_M1s23_WI_EXT_EDGE_V M1s23_OPC_EDGE_V < M1_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s23_OPC_REGION_V


M1.S.23 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 1.5 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.3 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 1.5 um (W1B) and the parallel run length > 1.5 um (L1B) in metal space < 0.5 um (S1B) region >= 0.3 
  ((M1s23_SP_err1_REG_H_eff INTERACT M1s23_S3C_NNH_H) OR M1s23_S3C_NNH_H) INTERACT M1s23_R1_CHK
  ((M1s23_SP_err1_REG_H_eff INTERACT M1s23_S3C_NH_H) OR M1s23_S3C_NH_H) INTERACT M1s23_R1_CHK
  ((M1s23_SP_err1_REG_V_eff INTERACT M1s23_S3C_NNH_V) OR M1s23_S3C_NNH_V) INTERACT M1s23_R1_CHK
  ((M1s23_SP_err1_REG_V_eff INTERACT M1s23_S3C_NH_V) OR M1s23_S3C_NH_V) INTERACT M1s23_R1_CHK
}
M1.S.24 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.3 
  (M1s23_SP_err2_REG_H_eff1 AND M1s23_OPC_REGION_H) INTERACT Wide_M1s23_WI_JOG_H
  (M1s23_SP_err2_REG_V_eff1 AND M1s23_OPC_REGION_V) INTERACT Wide_M1s23_WI_JOG_V
}
M1.S.25 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M1s23_SP_err3_REG_H AND M1s23_OPC_REGION_H) INTERACT Wide_M1s23_WI_JOG_H
  (M1s23_SP_err3_REG_V AND M1s23_OPC_REGION_V) INTERACT Wide_M1s23_WI_JOG_V
}


// M2 WMJ JOG Rules
//=============================
// Wide M2s14 space error in OPC region checking
//====================================================

Wide_M2s14 = ENCLOSE RECTANGLE (SIZE M2 BY M2_S_14_W1B/2 UNDEROVER) M2_S_14_W1B+GRID M2_S_14_L1B+GRID ORTHOGONAL ONLY
M2s14_CHECK_REGION = M2 AND (SIZE Wide_M2s14 BY M2_S_14_S1B + GRID)
M2s14_OPC_REGION_pre1 = EXT [Wide_M2s14] M2s14_CHECK_REGION < M2_S_14_S1B OPPOSITE MEASURE ALL
M2s14_OPC_REGION_pre1_H = ANGLE M2s14_OPC_REGION_pre1 == 0
M2s14_OPC_REGION_pre1_V = ANGLE M2s14_OPC_REGION_pre1 == 90
M2s14_OPC_REGION_pre0_V = INT M2s14_OPC_REGION_pre1_H [Wide_M2s14] < GRID ABUT == 90 INTERSECTING ONLY 
M2s14_OPC_REGION_pre3_V = EXT M2s14_OPC_REGION_pre1_H [Wide_M2s14] < GRID ABUT == 90 INTERSECTING ONLY 
M2s14_OPC_REGION_pre4_V = (M2s14_CHECK_REGION TOUCH INSIDE EDGE M2s14_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M2s14_OPC_REGION_pre3_V
M2s14_OPC_REGION_pre0_H = INT M2s14_OPC_REGION_pre1_V [Wide_M2s14] < GRID ABUT == 90 INTERSECTING ONLY 
M2s14_OPC_REGION_pre3_H = EXT M2s14_OPC_REGION_pre1_V [Wide_M2s14] < GRID ABUT == 90 INTERSECTING ONLY 
M2s14_OPC_REGION_pre4_H = (M2s14_CHECK_REGION TOUCH INSIDE EDGE M2s14_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M2s14_OPC_REGION_pre3_H
M2s14_OPC_REGION_pre5_H = (EXPAND EDGE M2s14_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M2s14_OPC_REGION_pre4_V BY GRID)
M2s14_OPC_REGION_pre5_V = (EXPAND EDGE M2s14_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M2s14_OPC_REGION_pre4_H BY GRID)
M2s14_OPC_REGION_pre6_H = DFM PROPERTY M2s14_OPC_REGION_pre5_H M2s14_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M2s14_OPC_REGION_pre1_H)] > M2_S_14_L1B
M2s14_OPC_REGION_pre6_V = DFM PROPERTY M2s14_OPC_REGION_pre5_V M2s14_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M2s14_OPC_REGION_pre1_V)] > M2_S_14_L1B
M2s14_OPC_REGION_pre7_H = M2s14_OPC_REGION_pre1_H INSIDE EDGE M2s14_OPC_REGION_pre6_H
M2s14_OPC_REGION_pre7_V = M2s14_OPC_REGION_pre1_V INSIDE EDGE M2s14_OPC_REGION_pre6_V
M2s14_OPC_REGION_pre2_H = EXT M2s14_OPC_REGION_pre7_H M2s14_CHECK_REGION < M2_S_14_S1B OPPOSITE REGION MEASURE ALL
M2s14_OPC_REGION_pre2_V = EXT M2s14_OPC_REGION_pre7_V M2s14_CHECK_REGION < M2_S_14_S1B OPPOSITE REGION MEASURE ALL

M2s14_M2_H = M2 INTERACT M2s14_OPC_REGION_pre2_H
M2s14_M2_V = M2 INTERACT M2s14_OPC_REGION_pre2_V
M2s14_M2_ALL = M2s14_M2_H OR M2s14_M2_V
M2s14_OPC_EDGE_H = ANGLE (M2s14_M2_H NOT OUTSIDE EDGE M2s14_OPC_REGION_pre2_H) == 0
M2s14_OPC_EDGE_V = ANGLE (M2s14_M2_V NOT OUTSIDE EDGE M2s14_OPC_REGION_pre2_V) == 90

Wide_M2s14_H = Wide_M2s14 INTERACT M2s14_OPC_REGION_pre2_H
Wide_M2s14_V = Wide_M2s14 INTERACT M2s14_OPC_REGION_pre2_V
Wide_M2s14_WI_JOG_H = (M2 AND (Wide_M2s14_H OR M2s14_OPC_REGION_pre2_H)) INTERACT Wide_M2s14_H
Wide_M2s14_WI_JOG_V = (M2 AND (Wide_M2s14_V OR M2s14_OPC_REGION_pre2_V)) INTERACT Wide_M2s14_V

Wide_M2s14_WI_EXT_EDGE_H = M2s14_OPC_EDGE_H NOT COIN EDGE (INT [M2s14_OPC_EDGE_H] M2s14_M2_H <= M2_S_14_W1B OPPOSITE)
Wide_M2s14_WI_EXT_EDGE_V = M2s14_OPC_EDGE_V NOT COIN EDGE (INT [M2s14_OPC_EDGE_V] M2s14_M2_V <= M2_S_14_W1B OPPOSITE)

M2s14_OPC_REGION_H = (EXT Wide_M2s14_WI_JOG_H M2s14_OPC_EDGE_H < M2_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s14_OPC_REGION_pre2_H
M2s14_OPC_REGION_V = (EXT Wide_M2s14_WI_JOG_V M2s14_OPC_EDGE_V < M2_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s14_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M2s14_SP_err1_REG_H = (EXT Wide_M2s14_WI_EXT_EDGE_H M2s14_M2_H < M2_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s14_OPC_REGION_H
M2s14_SP_err1_REG_V = (EXT Wide_M2s14_WI_EXT_EDGE_V M2s14_M2_V < M2_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s14_OPC_REGION_V
M2s14_EDGE_H_err3 = ANGLE M2s14_SP_err1_REG_H == 0
M2s14_EDGE_V_err3 = ANGLE M2s14_SP_err1_REG_V == 90
M2s14_SP_err1_REG_H_eff = DFM PROPERTY M2s14_SP_err1_REG_H M2s14_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M2s14_EDGE_H_err3)] <= 2*M2_S_14_L2A
M2s14_SP_err1_REG_V_eff = DFM PROPERTY M2s14_SP_err1_REG_V M2s14_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M2s14_EDGE_V_err3)] <= 2*M2_S_14_L2A

  M2s14_R1_CHK = EXT Wide_M2s14 M2s14_M2_ALL < M2_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M2s14_NOTCH_EDGE_H = ANGLE (EXT [Wide_M2s14_WI_JOG_H] < M2_S_14_S1B OPPOSITE NOTCH) == 0
  M2s14_NOTCH_EDGE_V = ANGLE (EXT [Wide_M2s14_WI_JOG_V] < M2_S_14_S1B OPPOSITE NOTCH) == 90
  M2s14_NOTCH_REGION_H = (EXT M2s14_NOTCH_EDGE_H < M2_S_14_S1B OPPOSITE REGION) AND M2s14_OPC_REGION_H
  M2s14_NOTCH_REGION_V = (EXT M2s14_NOTCH_EDGE_V < M2_S_14_S1B OPPOSITE REGION) AND M2s14_OPC_REGION_V
  
// Check NON-Notch region
  M2s14_SP_err1_REG_H_eff5 = M2s14_SP_err1_REG_H_eff NOT M2s14_NOTCH_REGION_H
  M2s14_SP_err1_REG_V_eff5 = M2s14_SP_err1_REG_V_eff NOT M2s14_NOTCH_REGION_V
  CONNECT M2s14_SP_err1_REG_H_eff5 (M2s14_OPC_REGION_H NOT M2s14_NOTCH_REGION_H)
  CONNECT M2s14_SP_err1_REG_V_eff5 (M2s14_OPC_REGION_V NOT M2s14_NOTCH_REGION_V)
  M2s14_SP_err1_REG_H_eff5a = M2s14_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M2s14_CHECK_REGION
  M2s14_SP_err1_REG_V_eff5a = M2s14_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M2s14_CHECK_REGION
  M2s14_S3C_NNH_H = (EXT M2s14_SP_err1_REG_H_eff5a < M2_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M2
  M2s14_S3C_NNH_V = (EXT M2s14_SP_err1_REG_V_eff5a < M2_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M2
  
// Check Notch H region
  M2s14_SP_err1_REG_H_eff6 = M2s14_SP_err1_REG_H_eff INSIDE M2s14_NOTCH_REGION_H
  M2s14_SP_err1_REG_V_eff6 = M2s14_SP_err1_REG_V_eff INSIDE M2s14_NOTCH_REGION_V
  CONNECT M2s14_SP_err1_REG_H_eff6 M2s14_NOTCH_REGION_H
  CONNECT M2s14_SP_err1_REG_V_eff6 M2s14_NOTCH_REGION_V  
  M2s14_SP_err1_REG_H_eff6a = M2s14_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M2s14_CHECK_REGION
  M2s14_SP_err1_REG_V_eff6a = M2s14_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M2s14_CHECK_REGION
  M2s14_S3C_NH_H = (EXT M2s14_SP_err1_REG_H_eff6a < M2_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M2
  M2s14_S3C_NH_V = (EXT M2s14_SP_err1_REG_V_eff6a < M2_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M2

// Find Space error region(large space S2A2) //
M2s14_SP_err2_REG_H = (EXT Wide_M2s14_WI_EXT_EDGE_H M2s14_OPC_EDGE_H < M2_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s14_OPC_REGION_H
M2s14_SP_err2_REG_V = (EXT Wide_M2s14_WI_EXT_EDGE_V M2s14_OPC_EDGE_V < M2_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s14_OPC_REGION_V
M2s14_EDGE_H_err2 = M2s14_SP_err2_REG_H COIN EDGE M2s14_OPC_EDGE_H
M2s14_EDGE_V_err2 = M2s14_SP_err2_REG_V COIN EDGE M2s14_OPC_EDGE_V

M2s14_SP_err2_REG_H_eff1 = DFM PROPERTY M2s14_SP_err2_REG_H M2s14_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M2s14_EDGE_H_err2)] > 2*M2_S_14_L2A
M2s14_SP_err2_REG_V_eff1 = DFM PROPERTY M2s14_SP_err2_REG_V M2s14_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M2s14_EDGE_V_err2)] > 2*M2_S_14_L2A

// Find Space error region(small space S2A3) //
M2s14_SP_err3_REG_H = (EXT Wide_M2s14_WI_EXT_EDGE_H M2s14_OPC_EDGE_H < M2_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s14_OPC_REGION_H
M2s14_SP_err3_REG_V = (EXT Wide_M2s14_WI_EXT_EDGE_V M2s14_OPC_EDGE_V < M2_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s14_OPC_REGION_V


M2.S.14 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.08 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.29 um (S1B) region >= 0.3 
  ((M2s14_SP_err1_REG_H_eff INTERACT M2s14_S3C_NNH_H) OR M2s14_S3C_NNH_H) INTERACT M2s14_R1_CHK
  ((M2s14_SP_err1_REG_H_eff INTERACT M2s14_S3C_NH_H) OR M2s14_S3C_NH_H) INTERACT M2s14_R1_CHK
  ((M2s14_SP_err1_REG_V_eff INTERACT M2s14_S3C_NNH_V) OR M2s14_S3C_NNH_V) INTERACT M2s14_R1_CHK
  ((M2s14_SP_err1_REG_V_eff INTERACT M2s14_S3C_NH_V) OR M2s14_S3C_NH_V) INTERACT M2s14_R1_CHK
}
M2.S.15 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.1 
  (M2s14_SP_err2_REG_H_eff1 AND M2s14_OPC_REGION_H) INTERACT Wide_M2s14_WI_JOG_H
  (M2s14_SP_err2_REG_V_eff1 AND M2s14_OPC_REGION_V) INTERACT Wide_M2s14_WI_JOG_V
}
M2.S.16 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M2s14_SP_err3_REG_H AND M2s14_OPC_REGION_H) INTERACT Wide_M2s14_WI_JOG_H
  (M2s14_SP_err3_REG_V AND M2s14_OPC_REGION_V) INTERACT Wide_M2s14_WI_JOG_V
}

// Wide M2s17 space error in OPC region checking
//====================================================

Wide_M2s17 = ENCLOSE RECTANGLE (SIZE M2 BY M2_S_17_W1B/2 UNDEROVER) M2_S_17_W1B+GRID M2_S_17_L1B+GRID ORTHOGONAL ONLY
M2s17_CHECK_REGION = M2 AND (SIZE Wide_M2s17 BY M2_S_17_S1B + GRID)
M2s17_OPC_REGION_pre1 = EXT [Wide_M2s17] M2s17_CHECK_REGION < M2_S_17_S1B OPPOSITE MEASURE ALL
M2s17_OPC_REGION_pre1_H = ANGLE M2s17_OPC_REGION_pre1 == 0
M2s17_OPC_REGION_pre1_V = ANGLE M2s17_OPC_REGION_pre1 == 90
M2s17_OPC_REGION_pre0_V = INT M2s17_OPC_REGION_pre1_H [Wide_M2s17] < GRID ABUT == 90 INTERSECTING ONLY 
M2s17_OPC_REGION_pre3_V = EXT M2s17_OPC_REGION_pre1_H [Wide_M2s17] < GRID ABUT == 90 INTERSECTING ONLY 
M2s17_OPC_REGION_pre4_V = (M2s17_CHECK_REGION TOUCH INSIDE EDGE M2s17_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M2s17_OPC_REGION_pre3_V
M2s17_OPC_REGION_pre0_H = INT M2s17_OPC_REGION_pre1_V [Wide_M2s17] < GRID ABUT == 90 INTERSECTING ONLY 
M2s17_OPC_REGION_pre3_H = EXT M2s17_OPC_REGION_pre1_V [Wide_M2s17] < GRID ABUT == 90 INTERSECTING ONLY 
M2s17_OPC_REGION_pre4_H = (M2s17_CHECK_REGION TOUCH INSIDE EDGE M2s17_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M2s17_OPC_REGION_pre3_H
M2s17_OPC_REGION_pre5_H = (EXPAND EDGE M2s17_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M2s17_OPC_REGION_pre4_V BY GRID)
M2s17_OPC_REGION_pre5_V = (EXPAND EDGE M2s17_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M2s17_OPC_REGION_pre4_H BY GRID)
M2s17_OPC_REGION_pre6_H = DFM PROPERTY M2s17_OPC_REGION_pre5_H M2s17_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M2s17_OPC_REGION_pre1_H)] > M2_S_17_L1B
M2s17_OPC_REGION_pre6_V = DFM PROPERTY M2s17_OPC_REGION_pre5_V M2s17_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M2s17_OPC_REGION_pre1_V)] > M2_S_17_L1B
M2s17_OPC_REGION_pre7_H = M2s17_OPC_REGION_pre1_H INSIDE EDGE M2s17_OPC_REGION_pre6_H
M2s17_OPC_REGION_pre7_V = M2s17_OPC_REGION_pre1_V INSIDE EDGE M2s17_OPC_REGION_pre6_V
M2s17_OPC_REGION_pre2_H = EXT M2s17_OPC_REGION_pre7_H M2s17_CHECK_REGION < M2_S_17_S1B OPPOSITE REGION MEASURE ALL
M2s17_OPC_REGION_pre2_V = EXT M2s17_OPC_REGION_pre7_V M2s17_CHECK_REGION < M2_S_17_S1B OPPOSITE REGION MEASURE ALL

M2s17_M2_H = M2 INTERACT M2s17_OPC_REGION_pre2_H
M2s17_M2_V = M2 INTERACT M2s17_OPC_REGION_pre2_V
M2s17_M2_ALL = M2s17_M2_H OR M2s17_M2_V
M2s17_OPC_EDGE_H = ANGLE (M2s17_M2_H NOT OUTSIDE EDGE M2s17_OPC_REGION_pre2_H) == 0
M2s17_OPC_EDGE_V = ANGLE (M2s17_M2_V NOT OUTSIDE EDGE M2s17_OPC_REGION_pre2_V) == 90

Wide_M2s17_H = Wide_M2s17 INTERACT M2s17_OPC_REGION_pre2_H
Wide_M2s17_V = Wide_M2s17 INTERACT M2s17_OPC_REGION_pre2_V
Wide_M2s17_WI_JOG_H = (M2 AND (Wide_M2s17_H OR M2s17_OPC_REGION_pre2_H)) INTERACT Wide_M2s17_H
Wide_M2s17_WI_JOG_V = (M2 AND (Wide_M2s17_V OR M2s17_OPC_REGION_pre2_V)) INTERACT Wide_M2s17_V

Wide_M2s17_WI_EXT_EDGE_H = M2s17_OPC_EDGE_H NOT COIN EDGE (INT [M2s17_OPC_EDGE_H] M2s17_M2_H <= M2_S_17_W1B OPPOSITE)
Wide_M2s17_WI_EXT_EDGE_V = M2s17_OPC_EDGE_V NOT COIN EDGE (INT [M2s17_OPC_EDGE_V] M2s17_M2_V <= M2_S_17_W1B OPPOSITE)

M2s17_OPC_REGION_H = (EXT Wide_M2s17_WI_JOG_H M2s17_OPC_EDGE_H < M2_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s17_OPC_REGION_pre2_H
M2s17_OPC_REGION_V = (EXT Wide_M2s17_WI_JOG_V M2s17_OPC_EDGE_V < M2_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s17_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M2s17_SP_err1_REG_H = (EXT Wide_M2s17_WI_EXT_EDGE_H M2s17_M2_H < M2_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s17_OPC_REGION_H
M2s17_SP_err1_REG_V = (EXT Wide_M2s17_WI_EXT_EDGE_V M2s17_M2_V < M2_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s17_OPC_REGION_V
M2s17_EDGE_H_err3 = ANGLE M2s17_SP_err1_REG_H == 0
M2s17_EDGE_V_err3 = ANGLE M2s17_SP_err1_REG_V == 90
M2s17_SP_err1_REG_H_eff = DFM PROPERTY M2s17_SP_err1_REG_H M2s17_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M2s17_EDGE_H_err3)] <= 2*M2_S_17_L2A
M2s17_SP_err1_REG_V_eff = DFM PROPERTY M2s17_SP_err1_REG_V M2s17_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M2s17_EDGE_V_err3)] <= 2*M2_S_17_L2A

  M2s17_R1_CHK = EXT Wide_M2s17 M2s17_M2_ALL < M2_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M2s17_NOTCH_EDGE_H = ANGLE (EXT [Wide_M2s17_WI_JOG_H] < M2_S_17_S1B OPPOSITE NOTCH) == 0
  M2s17_NOTCH_EDGE_V = ANGLE (EXT [Wide_M2s17_WI_JOG_V] < M2_S_17_S1B OPPOSITE NOTCH) == 90
  M2s17_NOTCH_REGION_H = (EXT M2s17_NOTCH_EDGE_H < M2_S_17_S1B OPPOSITE REGION) AND M2s17_OPC_REGION_H
  M2s17_NOTCH_REGION_V = (EXT M2s17_NOTCH_EDGE_V < M2_S_17_S1B OPPOSITE REGION) AND M2s17_OPC_REGION_V
  
// Check NON-Notch region
  M2s17_SP_err1_REG_H_eff5 = M2s17_SP_err1_REG_H_eff NOT M2s17_NOTCH_REGION_H
  M2s17_SP_err1_REG_V_eff5 = M2s17_SP_err1_REG_V_eff NOT M2s17_NOTCH_REGION_V
  CONNECT M2s17_SP_err1_REG_H_eff5 (M2s17_OPC_REGION_H NOT M2s17_NOTCH_REGION_H)
  CONNECT M2s17_SP_err1_REG_V_eff5 (M2s17_OPC_REGION_V NOT M2s17_NOTCH_REGION_V)
  M2s17_SP_err1_REG_H_eff5a = M2s17_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M2s17_CHECK_REGION
  M2s17_SP_err1_REG_V_eff5a = M2s17_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M2s17_CHECK_REGION
  M2s17_S3C_NNH_H = (EXT M2s17_SP_err1_REG_H_eff5a < M2_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M2
  M2s17_S3C_NNH_V = (EXT M2s17_SP_err1_REG_V_eff5a < M2_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M2
  
// Check Notch H region
  M2s17_SP_err1_REG_H_eff6 = M2s17_SP_err1_REG_H_eff INSIDE M2s17_NOTCH_REGION_H
  M2s17_SP_err1_REG_V_eff6 = M2s17_SP_err1_REG_V_eff INSIDE M2s17_NOTCH_REGION_V
  CONNECT M2s17_SP_err1_REG_H_eff6 M2s17_NOTCH_REGION_H
  CONNECT M2s17_SP_err1_REG_V_eff6 M2s17_NOTCH_REGION_V  
  M2s17_SP_err1_REG_H_eff6a = M2s17_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M2s17_CHECK_REGION
  M2s17_SP_err1_REG_V_eff6a = M2s17_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M2s17_CHECK_REGION
  M2s17_S3C_NH_H = (EXT M2s17_SP_err1_REG_H_eff6a < M2_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M2
  M2s17_S3C_NH_V = (EXT M2s17_SP_err1_REG_V_eff6a < M2_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M2

// Find Space error region(large space S2A2) //
M2s17_SP_err2_REG_H = (EXT Wide_M2s17_WI_EXT_EDGE_H M2s17_OPC_EDGE_H < M2_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s17_OPC_REGION_H
M2s17_SP_err2_REG_V = (EXT Wide_M2s17_WI_EXT_EDGE_V M2s17_OPC_EDGE_V < M2_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s17_OPC_REGION_V
M2s17_EDGE_H_err2 = M2s17_SP_err2_REG_H COIN EDGE M2s17_OPC_EDGE_H
M2s17_EDGE_V_err2 = M2s17_SP_err2_REG_V COIN EDGE M2s17_OPC_EDGE_V

M2s17_SP_err2_REG_H_eff1 = DFM PROPERTY M2s17_SP_err2_REG_H M2s17_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M2s17_EDGE_H_err2)] > 2*M2_S_17_L2A
M2s17_SP_err2_REG_V_eff1 = DFM PROPERTY M2s17_SP_err2_REG_V M2s17_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M2s17_EDGE_V_err2)] > 2*M2_S_17_L2A

// Find Space error region(small space S2A3) //
M2s17_SP_err3_REG_H = (EXT Wide_M2s17_WI_EXT_EDGE_H M2s17_OPC_EDGE_H < M2_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s17_OPC_REGION_H
M2s17_SP_err3_REG_V = (EXT Wide_M2s17_WI_EXT_EDGE_V M2s17_OPC_EDGE_V < M2_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s17_OPC_REGION_V


M2.S.17 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.47 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.13 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.47 um (W1B) and the parallel run length > 0.5 um (L1B) in metal space < 0.32 um (S1B) region >= 0.3 
  ((M2s17_SP_err1_REG_H_eff INTERACT M2s17_S3C_NNH_H) OR M2s17_S3C_NNH_H) INTERACT M2s17_R1_CHK
  ((M2s17_SP_err1_REG_H_eff INTERACT M2s17_S3C_NH_H) OR M2s17_S3C_NH_H) INTERACT M2s17_R1_CHK
  ((M2s17_SP_err1_REG_V_eff INTERACT M2s17_S3C_NNH_V) OR M2s17_S3C_NNH_V) INTERACT M2s17_R1_CHK
  ((M2s17_SP_err1_REG_V_eff INTERACT M2s17_S3C_NH_V) OR M2s17_S3C_NH_V) INTERACT M2s17_R1_CHK
}
M2.S.18 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.13 
  (M2s17_SP_err2_REG_H_eff1 AND M2s17_OPC_REGION_H) INTERACT Wide_M2s17_WI_JOG_H
  (M2s17_SP_err2_REG_V_eff1 AND M2s17_OPC_REGION_V) INTERACT Wide_M2s17_WI_JOG_V
}
M2.S.19 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M2s17_SP_err3_REG_H AND M2s17_OPC_REGION_H) INTERACT Wide_M2s17_WI_JOG_H
  (M2s17_SP_err3_REG_V AND M2s17_OPC_REGION_V) INTERACT Wide_M2s17_WI_JOG_V
}

// Wide M2s20 space error in OPC region checking
//====================================================

Wide_M2s20 = ENCLOSE RECTANGLE (SIZE M2 BY M2_S_20_W1B/2 UNDEROVER) M2_S_20_W1B+GRID M2_S_20_L1B+GRID ORTHOGONAL ONLY
M2s20_CHECK_REGION = M2 AND (SIZE Wide_M2s20 BY M2_S_20_S1B + GRID)
M2s20_OPC_REGION_pre1 = EXT [Wide_M2s20] M2s20_CHECK_REGION < M2_S_20_S1B OPPOSITE MEASURE ALL
M2s20_OPC_REGION_pre1_H = ANGLE M2s20_OPC_REGION_pre1 == 0
M2s20_OPC_REGION_pre1_V = ANGLE M2s20_OPC_REGION_pre1 == 90
M2s20_OPC_REGION_pre0_V = INT M2s20_OPC_REGION_pre1_H [Wide_M2s20] < GRID ABUT == 90 INTERSECTING ONLY 
M2s20_OPC_REGION_pre3_V = EXT M2s20_OPC_REGION_pre1_H [Wide_M2s20] < GRID ABUT == 90 INTERSECTING ONLY 
M2s20_OPC_REGION_pre4_V = (M2s20_CHECK_REGION TOUCH INSIDE EDGE M2s20_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M2s20_OPC_REGION_pre3_V
M2s20_OPC_REGION_pre0_H = INT M2s20_OPC_REGION_pre1_V [Wide_M2s20] < GRID ABUT == 90 INTERSECTING ONLY 
M2s20_OPC_REGION_pre3_H = EXT M2s20_OPC_REGION_pre1_V [Wide_M2s20] < GRID ABUT == 90 INTERSECTING ONLY 
M2s20_OPC_REGION_pre4_H = (M2s20_CHECK_REGION TOUCH INSIDE EDGE M2s20_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M2s20_OPC_REGION_pre3_H
M2s20_OPC_REGION_pre5_H = (EXPAND EDGE M2s20_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M2s20_OPC_REGION_pre4_V BY GRID)
M2s20_OPC_REGION_pre5_V = (EXPAND EDGE M2s20_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M2s20_OPC_REGION_pre4_H BY GRID)
M2s20_OPC_REGION_pre6_H = DFM PROPERTY M2s20_OPC_REGION_pre5_H M2s20_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M2s20_OPC_REGION_pre1_H)] > M2_S_20_L1B
M2s20_OPC_REGION_pre6_V = DFM PROPERTY M2s20_OPC_REGION_pre5_V M2s20_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M2s20_OPC_REGION_pre1_V)] > M2_S_20_L1B
M2s20_OPC_REGION_pre7_H = M2s20_OPC_REGION_pre1_H INSIDE EDGE M2s20_OPC_REGION_pre6_H
M2s20_OPC_REGION_pre7_V = M2s20_OPC_REGION_pre1_V INSIDE EDGE M2s20_OPC_REGION_pre6_V
M2s20_OPC_REGION_pre2_H = EXT M2s20_OPC_REGION_pre7_H M2s20_CHECK_REGION < M2_S_20_S1B OPPOSITE REGION MEASURE ALL
M2s20_OPC_REGION_pre2_V = EXT M2s20_OPC_REGION_pre7_V M2s20_CHECK_REGION < M2_S_20_S1B OPPOSITE REGION MEASURE ALL

M2s20_M2_H = M2 INTERACT M2s20_OPC_REGION_pre2_H
M2s20_M2_V = M2 INTERACT M2s20_OPC_REGION_pre2_V
M2s20_M2_ALL = M2s20_M2_H OR M2s20_M2_V
M2s20_OPC_EDGE_H = ANGLE (M2s20_M2_H NOT OUTSIDE EDGE M2s20_OPC_REGION_pre2_H) == 0
M2s20_OPC_EDGE_V = ANGLE (M2s20_M2_V NOT OUTSIDE EDGE M2s20_OPC_REGION_pre2_V) == 90

Wide_M2s20_H = Wide_M2s20 INTERACT M2s20_OPC_REGION_pre2_H
Wide_M2s20_V = Wide_M2s20 INTERACT M2s20_OPC_REGION_pre2_V
Wide_M2s20_WI_JOG_H = (M2 AND (Wide_M2s20_H OR M2s20_OPC_REGION_pre2_H)) INTERACT Wide_M2s20_H
Wide_M2s20_WI_JOG_V = (M2 AND (Wide_M2s20_V OR M2s20_OPC_REGION_pre2_V)) INTERACT Wide_M2s20_V

Wide_M2s20_WI_EXT_EDGE_H = M2s20_OPC_EDGE_H NOT COIN EDGE (INT [M2s20_OPC_EDGE_H] M2s20_M2_H <= M2_S_20_W1B OPPOSITE)
Wide_M2s20_WI_EXT_EDGE_V = M2s20_OPC_EDGE_V NOT COIN EDGE (INT [M2s20_OPC_EDGE_V] M2s20_M2_V <= M2_S_20_W1B OPPOSITE)

M2s20_OPC_REGION_H = (EXT Wide_M2s20_WI_JOG_H M2s20_OPC_EDGE_H < M2_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s20_OPC_REGION_pre2_H
M2s20_OPC_REGION_V = (EXT Wide_M2s20_WI_JOG_V M2s20_OPC_EDGE_V < M2_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s20_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M2s20_SP_err1_REG_H = (EXT Wide_M2s20_WI_EXT_EDGE_H M2s20_M2_H < M2_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s20_OPC_REGION_H
M2s20_SP_err1_REG_V = (EXT Wide_M2s20_WI_EXT_EDGE_V M2s20_M2_V < M2_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s20_OPC_REGION_V
M2s20_EDGE_H_err3 = ANGLE M2s20_SP_err1_REG_H == 0
M2s20_EDGE_V_err3 = ANGLE M2s20_SP_err1_REG_V == 90
M2s20_SP_err1_REG_H_eff = DFM PROPERTY M2s20_SP_err1_REG_H M2s20_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M2s20_EDGE_H_err3)] <= 2*M2_S_20_L2A
M2s20_SP_err1_REG_V_eff = DFM PROPERTY M2s20_SP_err1_REG_V M2s20_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M2s20_EDGE_V_err3)] <= 2*M2_S_20_L2A

  M2s20_R1_CHK = EXT Wide_M2s20 M2s20_M2_ALL < M2_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M2s20_NOTCH_EDGE_H = ANGLE (EXT [Wide_M2s20_WI_JOG_H] < M2_S_20_S1B OPPOSITE NOTCH) == 0
  M2s20_NOTCH_EDGE_V = ANGLE (EXT [Wide_M2s20_WI_JOG_V] < M2_S_20_S1B OPPOSITE NOTCH) == 90
  M2s20_NOTCH_REGION_H = (EXT M2s20_NOTCH_EDGE_H < M2_S_20_S1B OPPOSITE REGION) AND M2s20_OPC_REGION_H
  M2s20_NOTCH_REGION_V = (EXT M2s20_NOTCH_EDGE_V < M2_S_20_S1B OPPOSITE REGION) AND M2s20_OPC_REGION_V
  
// Check NON-Notch region
  M2s20_SP_err1_REG_H_eff5 = M2s20_SP_err1_REG_H_eff NOT M2s20_NOTCH_REGION_H
  M2s20_SP_err1_REG_V_eff5 = M2s20_SP_err1_REG_V_eff NOT M2s20_NOTCH_REGION_V
  CONNECT M2s20_SP_err1_REG_H_eff5 (M2s20_OPC_REGION_H NOT M2s20_NOTCH_REGION_H)
  CONNECT M2s20_SP_err1_REG_V_eff5 (M2s20_OPC_REGION_V NOT M2s20_NOTCH_REGION_V)
  M2s20_SP_err1_REG_H_eff5a = M2s20_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M2s20_CHECK_REGION
  M2s20_SP_err1_REG_V_eff5a = M2s20_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M2s20_CHECK_REGION
  M2s20_S3C_NNH_H = (EXT M2s20_SP_err1_REG_H_eff5a < M2_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M2
  M2s20_S3C_NNH_V = (EXT M2s20_SP_err1_REG_V_eff5a < M2_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M2
  
// Check Notch H region
  M2s20_SP_err1_REG_H_eff6 = M2s20_SP_err1_REG_H_eff INSIDE M2s20_NOTCH_REGION_H
  M2s20_SP_err1_REG_V_eff6 = M2s20_SP_err1_REG_V_eff INSIDE M2s20_NOTCH_REGION_V
  CONNECT M2s20_SP_err1_REG_H_eff6 M2s20_NOTCH_REGION_H
  CONNECT M2s20_SP_err1_REG_V_eff6 M2s20_NOTCH_REGION_V  
  M2s20_SP_err1_REG_H_eff6a = M2s20_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M2s20_CHECK_REGION
  M2s20_SP_err1_REG_V_eff6a = M2s20_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M2s20_CHECK_REGION
  M2s20_S3C_NH_H = (EXT M2s20_SP_err1_REG_H_eff6a < M2_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M2
  M2s20_S3C_NH_V = (EXT M2s20_SP_err1_REG_V_eff6a < M2_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M2

// Find Space error region(large space S2A2) //
M2s20_SP_err2_REG_H = (EXT Wide_M2s20_WI_EXT_EDGE_H M2s20_OPC_EDGE_H < M2_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s20_OPC_REGION_H
M2s20_SP_err2_REG_V = (EXT Wide_M2s20_WI_EXT_EDGE_V M2s20_OPC_EDGE_V < M2_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s20_OPC_REGION_V
M2s20_EDGE_H_err2 = M2s20_SP_err2_REG_H COIN EDGE M2s20_OPC_EDGE_H
M2s20_EDGE_V_err2 = M2s20_SP_err2_REG_V COIN EDGE M2s20_OPC_EDGE_V

M2s20_SP_err2_REG_H_eff1 = DFM PROPERTY M2s20_SP_err2_REG_H M2s20_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M2s20_EDGE_H_err2)] > 2*M2_S_20_L2A
M2s20_SP_err2_REG_V_eff1 = DFM PROPERTY M2s20_SP_err2_REG_V M2s20_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M2s20_EDGE_V_err2)] > 2*M2_S_20_L2A

// Find Space error region(small space S2A3) //
M2s20_SP_err3_REG_H = (EXT Wide_M2s20_WI_EXT_EDGE_H M2s20_OPC_EDGE_H < M2_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s20_OPC_REGION_H
M2s20_SP_err3_REG_V = (EXT Wide_M2s20_WI_EXT_EDGE_V M2s20_OPC_EDGE_V < M2_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s20_OPC_REGION_V


M2.S.20 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.63 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.15 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.63 um (W1B) and the parallel run length > 0.7 um (L1B) in metal space < 0.34 um (S1B) region >= 0.3 
  ((M2s20_SP_err1_REG_H_eff INTERACT M2s20_S3C_NNH_H) OR M2s20_S3C_NNH_H) INTERACT M2s20_R1_CHK
  ((M2s20_SP_err1_REG_H_eff INTERACT M2s20_S3C_NH_H) OR M2s20_S3C_NH_H) INTERACT M2s20_R1_CHK
  ((M2s20_SP_err1_REG_V_eff INTERACT M2s20_S3C_NNH_V) OR M2s20_S3C_NNH_V) INTERACT M2s20_R1_CHK
  ((M2s20_SP_err1_REG_V_eff INTERACT M2s20_S3C_NH_V) OR M2s20_S3C_NH_V) INTERACT M2s20_R1_CHK
}
M2.S.21 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.15 
  (M2s20_SP_err2_REG_H_eff1 AND M2s20_OPC_REGION_H) INTERACT Wide_M2s20_WI_JOG_H
  (M2s20_SP_err2_REG_V_eff1 AND M2s20_OPC_REGION_V) INTERACT Wide_M2s20_WI_JOG_V
}
M2.S.22 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M2s20_SP_err3_REG_H AND M2s20_OPC_REGION_H) INTERACT Wide_M2s20_WI_JOG_H
  (M2s20_SP_err3_REG_V AND M2s20_OPC_REGION_V) INTERACT Wide_M2s20_WI_JOG_V
}

// Wide M2s23 space error in OPC region checking
//====================================================

Wide_M2s23 = ENCLOSE RECTANGLE (SIZE M2 BY M2_S_23_W1B/2 UNDEROVER) M2_S_23_W1B+GRID M2_S_23_L1B+GRID ORTHOGONAL ONLY
M2s23_CHECK_REGION = M2 AND (SIZE Wide_M2s23 BY M2_S_23_S1B + GRID)
M2s23_OPC_REGION_pre1 = EXT [Wide_M2s23] M2s23_CHECK_REGION < M2_S_23_S1B OPPOSITE MEASURE ALL
M2s23_OPC_REGION_pre1_H = ANGLE M2s23_OPC_REGION_pre1 == 0
M2s23_OPC_REGION_pre1_V = ANGLE M2s23_OPC_REGION_pre1 == 90
M2s23_OPC_REGION_pre0_V = INT M2s23_OPC_REGION_pre1_H [Wide_M2s23] < GRID ABUT == 90 INTERSECTING ONLY 
M2s23_OPC_REGION_pre3_V = EXT M2s23_OPC_REGION_pre1_H [Wide_M2s23] < GRID ABUT == 90 INTERSECTING ONLY 
M2s23_OPC_REGION_pre4_V = (M2s23_CHECK_REGION TOUCH INSIDE EDGE M2s23_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M2s23_OPC_REGION_pre3_V
M2s23_OPC_REGION_pre0_H = INT M2s23_OPC_REGION_pre1_V [Wide_M2s23] < GRID ABUT == 90 INTERSECTING ONLY 
M2s23_OPC_REGION_pre3_H = EXT M2s23_OPC_REGION_pre1_V [Wide_M2s23] < GRID ABUT == 90 INTERSECTING ONLY 
M2s23_OPC_REGION_pre4_H = (M2s23_CHECK_REGION TOUCH INSIDE EDGE M2s23_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M2s23_OPC_REGION_pre3_H
M2s23_OPC_REGION_pre5_H = (EXPAND EDGE M2s23_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M2s23_OPC_REGION_pre4_V BY GRID)
M2s23_OPC_REGION_pre5_V = (EXPAND EDGE M2s23_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M2s23_OPC_REGION_pre4_H BY GRID)
M2s23_OPC_REGION_pre6_H = DFM PROPERTY M2s23_OPC_REGION_pre5_H M2s23_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M2s23_OPC_REGION_pre1_H)] > M2_S_23_L1B
M2s23_OPC_REGION_pre6_V = DFM PROPERTY M2s23_OPC_REGION_pre5_V M2s23_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M2s23_OPC_REGION_pre1_V)] > M2_S_23_L1B
M2s23_OPC_REGION_pre7_H = M2s23_OPC_REGION_pre1_H INSIDE EDGE M2s23_OPC_REGION_pre6_H
M2s23_OPC_REGION_pre7_V = M2s23_OPC_REGION_pre1_V INSIDE EDGE M2s23_OPC_REGION_pre6_V
M2s23_OPC_REGION_pre2_H = EXT M2s23_OPC_REGION_pre7_H M2s23_CHECK_REGION < M2_S_23_S1B OPPOSITE REGION MEASURE ALL
M2s23_OPC_REGION_pre2_V = EXT M2s23_OPC_REGION_pre7_V M2s23_CHECK_REGION < M2_S_23_S1B OPPOSITE REGION MEASURE ALL

M2s23_M2_H = M2 INTERACT M2s23_OPC_REGION_pre2_H
M2s23_M2_V = M2 INTERACT M2s23_OPC_REGION_pre2_V
M2s23_M2_ALL = M2s23_M2_H OR M2s23_M2_V
M2s23_OPC_EDGE_H = ANGLE (M2s23_M2_H NOT OUTSIDE EDGE M2s23_OPC_REGION_pre2_H) == 0
M2s23_OPC_EDGE_V = ANGLE (M2s23_M2_V NOT OUTSIDE EDGE M2s23_OPC_REGION_pre2_V) == 90

Wide_M2s23_H = Wide_M2s23 INTERACT M2s23_OPC_REGION_pre2_H
Wide_M2s23_V = Wide_M2s23 INTERACT M2s23_OPC_REGION_pre2_V
Wide_M2s23_WI_JOG_H = (M2 AND (Wide_M2s23_H OR M2s23_OPC_REGION_pre2_H)) INTERACT Wide_M2s23_H
Wide_M2s23_WI_JOG_V = (M2 AND (Wide_M2s23_V OR M2s23_OPC_REGION_pre2_V)) INTERACT Wide_M2s23_V

Wide_M2s23_WI_EXT_EDGE_H = M2s23_OPC_EDGE_H NOT COIN EDGE (INT [M2s23_OPC_EDGE_H] M2s23_M2_H <= M2_S_23_W1B OPPOSITE)
Wide_M2s23_WI_EXT_EDGE_V = M2s23_OPC_EDGE_V NOT COIN EDGE (INT [M2s23_OPC_EDGE_V] M2s23_M2_V <= M2_S_23_W1B OPPOSITE)

M2s23_OPC_REGION_H = (EXT Wide_M2s23_WI_JOG_H M2s23_OPC_EDGE_H < M2_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s23_OPC_REGION_pre2_H
M2s23_OPC_REGION_V = (EXT Wide_M2s23_WI_JOG_V M2s23_OPC_EDGE_V < M2_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s23_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M2s23_SP_err1_REG_H = (EXT Wide_M2s23_WI_EXT_EDGE_H M2s23_M2_H < M2_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s23_OPC_REGION_H
M2s23_SP_err1_REG_V = (EXT Wide_M2s23_WI_EXT_EDGE_V M2s23_M2_V < M2_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s23_OPC_REGION_V
M2s23_EDGE_H_err3 = ANGLE M2s23_SP_err1_REG_H == 0
M2s23_EDGE_V_err3 = ANGLE M2s23_SP_err1_REG_V == 90
M2s23_SP_err1_REG_H_eff = DFM PROPERTY M2s23_SP_err1_REG_H M2s23_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M2s23_EDGE_H_err3)] <= 2*M2_S_23_L2A
M2s23_SP_err1_REG_V_eff = DFM PROPERTY M2s23_SP_err1_REG_V M2s23_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M2s23_EDGE_V_err3)] <= 2*M2_S_23_L2A

  M2s23_R1_CHK = EXT Wide_M2s23 M2s23_M2_ALL < M2_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M2s23_NOTCH_EDGE_H = ANGLE (EXT [Wide_M2s23_WI_JOG_H] < M2_S_23_S1B OPPOSITE NOTCH) == 0
  M2s23_NOTCH_EDGE_V = ANGLE (EXT [Wide_M2s23_WI_JOG_V] < M2_S_23_S1B OPPOSITE NOTCH) == 90
  M2s23_NOTCH_REGION_H = (EXT M2s23_NOTCH_EDGE_H < M2_S_23_S1B OPPOSITE REGION) AND M2s23_OPC_REGION_H
  M2s23_NOTCH_REGION_V = (EXT M2s23_NOTCH_EDGE_V < M2_S_23_S1B OPPOSITE REGION) AND M2s23_OPC_REGION_V
  
// Check NON-Notch region
  M2s23_SP_err1_REG_H_eff5 = M2s23_SP_err1_REG_H_eff NOT M2s23_NOTCH_REGION_H
  M2s23_SP_err1_REG_V_eff5 = M2s23_SP_err1_REG_V_eff NOT M2s23_NOTCH_REGION_V
  CONNECT M2s23_SP_err1_REG_H_eff5 (M2s23_OPC_REGION_H NOT M2s23_NOTCH_REGION_H)
  CONNECT M2s23_SP_err1_REG_V_eff5 (M2s23_OPC_REGION_V NOT M2s23_NOTCH_REGION_V)
  M2s23_SP_err1_REG_H_eff5a = M2s23_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M2s23_CHECK_REGION
  M2s23_SP_err1_REG_V_eff5a = M2s23_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M2s23_CHECK_REGION
  M2s23_S3C_NNH_H = (EXT M2s23_SP_err1_REG_H_eff5a < M2_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M2
  M2s23_S3C_NNH_V = (EXT M2s23_SP_err1_REG_V_eff5a < M2_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M2
  
// Check Notch H region
  M2s23_SP_err1_REG_H_eff6 = M2s23_SP_err1_REG_H_eff INSIDE M2s23_NOTCH_REGION_H
  M2s23_SP_err1_REG_V_eff6 = M2s23_SP_err1_REG_V_eff INSIDE M2s23_NOTCH_REGION_V
  CONNECT M2s23_SP_err1_REG_H_eff6 M2s23_NOTCH_REGION_H
  CONNECT M2s23_SP_err1_REG_V_eff6 M2s23_NOTCH_REGION_V  
  M2s23_SP_err1_REG_H_eff6a = M2s23_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M2s23_CHECK_REGION
  M2s23_SP_err1_REG_V_eff6a = M2s23_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M2s23_CHECK_REGION
  M2s23_S3C_NH_H = (EXT M2s23_SP_err1_REG_H_eff6a < M2_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M2
  M2s23_S3C_NH_V = (EXT M2s23_SP_err1_REG_V_eff6a < M2_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M2

// Find Space error region(large space S2A2) //
M2s23_SP_err2_REG_H = (EXT Wide_M2s23_WI_EXT_EDGE_H M2s23_OPC_EDGE_H < M2_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s23_OPC_REGION_H
M2s23_SP_err2_REG_V = (EXT Wide_M2s23_WI_EXT_EDGE_V M2s23_OPC_EDGE_V < M2_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s23_OPC_REGION_V
M2s23_EDGE_H_err2 = M2s23_SP_err2_REG_H COIN EDGE M2s23_OPC_EDGE_H
M2s23_EDGE_V_err2 = M2s23_SP_err2_REG_V COIN EDGE M2s23_OPC_EDGE_V

M2s23_SP_err2_REG_H_eff1 = DFM PROPERTY M2s23_SP_err2_REG_H M2s23_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M2s23_EDGE_H_err2)] > 2*M2_S_23_L2A
M2s23_SP_err2_REG_V_eff1 = DFM PROPERTY M2s23_SP_err2_REG_V M2s23_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M2s23_EDGE_V_err2)] > 2*M2_S_23_L2A

// Find Space error region(small space S2A3) //
M2s23_SP_err3_REG_H = (EXT Wide_M2s23_WI_EXT_EDGE_H M2s23_OPC_EDGE_H < M2_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s23_OPC_REGION_H
M2s23_SP_err3_REG_V = (EXT Wide_M2s23_WI_EXT_EDGE_V M2s23_OPC_EDGE_V < M2_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s23_OPC_REGION_V


M2.S.23 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 1.5 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.3 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 1.5 um (W1B) and the parallel run length > 1.5 um (L1B) in metal space < 0.5 um (S1B) region >= 0.3 
  ((M2s23_SP_err1_REG_H_eff INTERACT M2s23_S3C_NNH_H) OR M2s23_S3C_NNH_H) INTERACT M2s23_R1_CHK
  ((M2s23_SP_err1_REG_H_eff INTERACT M2s23_S3C_NH_H) OR M2s23_S3C_NH_H) INTERACT M2s23_R1_CHK
  ((M2s23_SP_err1_REG_V_eff INTERACT M2s23_S3C_NNH_V) OR M2s23_S3C_NNH_V) INTERACT M2s23_R1_CHK
  ((M2s23_SP_err1_REG_V_eff INTERACT M2s23_S3C_NH_V) OR M2s23_S3C_NH_V) INTERACT M2s23_R1_CHK
}
M2.S.24 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.3 
  (M2s23_SP_err2_REG_H_eff1 AND M2s23_OPC_REGION_H) INTERACT Wide_M2s23_WI_JOG_H
  (M2s23_SP_err2_REG_V_eff1 AND M2s23_OPC_REGION_V) INTERACT Wide_M2s23_WI_JOG_V
}
M2.S.25 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M2s23_SP_err3_REG_H AND M2s23_OPC_REGION_H) INTERACT Wide_M2s23_WI_JOG_H
  (M2s23_SP_err3_REG_V AND M2s23_OPC_REGION_V) INTERACT Wide_M2s23_WI_JOG_V
}

#ENDIF //M1_V1_M2_CHECKS

#IFDEF BACK_END
// M3 WMJ JOG Rules
//=============================
// Wide M3s14 space error in OPC region checking
//====================================================

Wide_M3s14 = ENCLOSE RECTANGLE (SIZE M3 BY M3_S_14_W1B/2 UNDEROVER) M3_S_14_W1B+GRID M3_S_14_L1B+GRID ORTHOGONAL ONLY
M3s14_CHECK_REGION = M3 AND (SIZE Wide_M3s14 BY M3_S_14_S1B + GRID)
M3s14_OPC_REGION_pre1 = EXT [Wide_M3s14] M3s14_CHECK_REGION < M3_S_14_S1B OPPOSITE MEASURE ALL
M3s14_OPC_REGION_pre1_H = ANGLE M3s14_OPC_REGION_pre1 == 0
M3s14_OPC_REGION_pre1_V = ANGLE M3s14_OPC_REGION_pre1 == 90
M3s14_OPC_REGION_pre0_V = INT M3s14_OPC_REGION_pre1_H [Wide_M3s14] < GRID ABUT == 90 INTERSECTING ONLY 
M3s14_OPC_REGION_pre3_V = EXT M3s14_OPC_REGION_pre1_H [Wide_M3s14] < GRID ABUT == 90 INTERSECTING ONLY 
M3s14_OPC_REGION_pre4_V = (M3s14_CHECK_REGION TOUCH INSIDE EDGE M3s14_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M3s14_OPC_REGION_pre3_V
M3s14_OPC_REGION_pre0_H = INT M3s14_OPC_REGION_pre1_V [Wide_M3s14] < GRID ABUT == 90 INTERSECTING ONLY 
M3s14_OPC_REGION_pre3_H = EXT M3s14_OPC_REGION_pre1_V [Wide_M3s14] < GRID ABUT == 90 INTERSECTING ONLY 
M3s14_OPC_REGION_pre4_H = (M3s14_CHECK_REGION TOUCH INSIDE EDGE M3s14_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M3s14_OPC_REGION_pre3_H
M3s14_OPC_REGION_pre5_H = (EXPAND EDGE M3s14_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M3s14_OPC_REGION_pre4_V BY GRID)
M3s14_OPC_REGION_pre5_V = (EXPAND EDGE M3s14_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M3s14_OPC_REGION_pre4_H BY GRID)
M3s14_OPC_REGION_pre6_H = DFM PROPERTY M3s14_OPC_REGION_pre5_H M3s14_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M3s14_OPC_REGION_pre1_H)] > M3_S_14_L1B
M3s14_OPC_REGION_pre6_V = DFM PROPERTY M3s14_OPC_REGION_pre5_V M3s14_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M3s14_OPC_REGION_pre1_V)] > M3_S_14_L1B
M3s14_OPC_REGION_pre7_H = M3s14_OPC_REGION_pre1_H INSIDE EDGE M3s14_OPC_REGION_pre6_H
M3s14_OPC_REGION_pre7_V = M3s14_OPC_REGION_pre1_V INSIDE EDGE M3s14_OPC_REGION_pre6_V
M3s14_OPC_REGION_pre2_H = EXT M3s14_OPC_REGION_pre7_H M3s14_CHECK_REGION < M3_S_14_S1B OPPOSITE REGION MEASURE ALL
M3s14_OPC_REGION_pre2_V = EXT M3s14_OPC_REGION_pre7_V M3s14_CHECK_REGION < M3_S_14_S1B OPPOSITE REGION MEASURE ALL

M3s14_M3_H = M3 INTERACT M3s14_OPC_REGION_pre2_H
M3s14_M3_V = M3 INTERACT M3s14_OPC_REGION_pre2_V
M3s14_M3_ALL = M3s14_M3_H OR M3s14_M3_V
M3s14_OPC_EDGE_H = ANGLE (M3s14_M3_H NOT OUTSIDE EDGE M3s14_OPC_REGION_pre2_H) == 0
M3s14_OPC_EDGE_V = ANGLE (M3s14_M3_V NOT OUTSIDE EDGE M3s14_OPC_REGION_pre2_V) == 90

Wide_M3s14_H = Wide_M3s14 INTERACT M3s14_OPC_REGION_pre2_H
Wide_M3s14_V = Wide_M3s14 INTERACT M3s14_OPC_REGION_pre2_V
Wide_M3s14_WI_JOG_H = (M3 AND (Wide_M3s14_H OR M3s14_OPC_REGION_pre2_H)) INTERACT Wide_M3s14_H
Wide_M3s14_WI_JOG_V = (M3 AND (Wide_M3s14_V OR M3s14_OPC_REGION_pre2_V)) INTERACT Wide_M3s14_V

Wide_M3s14_WI_EXT_EDGE_H = M3s14_OPC_EDGE_H NOT COIN EDGE (INT [M3s14_OPC_EDGE_H] M3s14_M3_H <= M3_S_14_W1B OPPOSITE)
Wide_M3s14_WI_EXT_EDGE_V = M3s14_OPC_EDGE_V NOT COIN EDGE (INT [M3s14_OPC_EDGE_V] M3s14_M3_V <= M3_S_14_W1B OPPOSITE)

M3s14_OPC_REGION_H = (EXT Wide_M3s14_WI_JOG_H M3s14_OPC_EDGE_H < M3_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s14_OPC_REGION_pre2_H
M3s14_OPC_REGION_V = (EXT Wide_M3s14_WI_JOG_V M3s14_OPC_EDGE_V < M3_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s14_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M3s14_SP_err1_REG_H = (EXT Wide_M3s14_WI_EXT_EDGE_H M3s14_M3_H < M3_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s14_OPC_REGION_H
M3s14_SP_err1_REG_V = (EXT Wide_M3s14_WI_EXT_EDGE_V M3s14_M3_V < M3_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s14_OPC_REGION_V
M3s14_EDGE_H_err3 = ANGLE M3s14_SP_err1_REG_H == 0
M3s14_EDGE_V_err3 = ANGLE M3s14_SP_err1_REG_V == 90
M3s14_SP_err1_REG_H_eff = DFM PROPERTY M3s14_SP_err1_REG_H M3s14_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M3s14_EDGE_H_err3)] <= 2*M3_S_14_L2A
M3s14_SP_err1_REG_V_eff = DFM PROPERTY M3s14_SP_err1_REG_V M3s14_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M3s14_EDGE_V_err3)] <= 2*M3_S_14_L2A

  M3s14_R1_CHK = EXT Wide_M3s14 M3s14_M3_ALL < M3_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M3s14_NOTCH_EDGE_H = ANGLE (EXT [Wide_M3s14_WI_JOG_H] < M3_S_14_S1B OPPOSITE NOTCH) == 0
  M3s14_NOTCH_EDGE_V = ANGLE (EXT [Wide_M3s14_WI_JOG_V] < M3_S_14_S1B OPPOSITE NOTCH) == 90
  M3s14_NOTCH_REGION_H = (EXT M3s14_NOTCH_EDGE_H < M3_S_14_S1B OPPOSITE REGION) AND M3s14_OPC_REGION_H
  M3s14_NOTCH_REGION_V = (EXT M3s14_NOTCH_EDGE_V < M3_S_14_S1B OPPOSITE REGION) AND M3s14_OPC_REGION_V
  
// Check NON-Notch region
  M3s14_SP_err1_REG_H_eff5 = M3s14_SP_err1_REG_H_eff NOT M3s14_NOTCH_REGION_H
  M3s14_SP_err1_REG_V_eff5 = M3s14_SP_err1_REG_V_eff NOT M3s14_NOTCH_REGION_V
  CONNECT M3s14_SP_err1_REG_H_eff5 (M3s14_OPC_REGION_H NOT M3s14_NOTCH_REGION_H)
  CONNECT M3s14_SP_err1_REG_V_eff5 (M3s14_OPC_REGION_V NOT M3s14_NOTCH_REGION_V)
  M3s14_SP_err1_REG_H_eff5a = M3s14_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M3s14_CHECK_REGION
  M3s14_SP_err1_REG_V_eff5a = M3s14_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M3s14_CHECK_REGION
  M3s14_S3C_NNH_H = (EXT M3s14_SP_err1_REG_H_eff5a < M3_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M3
  M3s14_S3C_NNH_V = (EXT M3s14_SP_err1_REG_V_eff5a < M3_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M3
  
// Check Notch H region
  M3s14_SP_err1_REG_H_eff6 = M3s14_SP_err1_REG_H_eff INSIDE M3s14_NOTCH_REGION_H
  M3s14_SP_err1_REG_V_eff6 = M3s14_SP_err1_REG_V_eff INSIDE M3s14_NOTCH_REGION_V
  CONNECT M3s14_SP_err1_REG_H_eff6 M3s14_NOTCH_REGION_H
  CONNECT M3s14_SP_err1_REG_V_eff6 M3s14_NOTCH_REGION_V  
  M3s14_SP_err1_REG_H_eff6a = M3s14_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M3s14_CHECK_REGION
  M3s14_SP_err1_REG_V_eff6a = M3s14_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M3s14_CHECK_REGION
  M3s14_S3C_NH_H = (EXT M3s14_SP_err1_REG_H_eff6a < M3_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M3
  M3s14_S3C_NH_V = (EXT M3s14_SP_err1_REG_V_eff6a < M3_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M3

// Find Space error region(large space S2A2) //
M3s14_SP_err2_REG_H = (EXT Wide_M3s14_WI_EXT_EDGE_H M3s14_OPC_EDGE_H < M3_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s14_OPC_REGION_H
M3s14_SP_err2_REG_V = (EXT Wide_M3s14_WI_EXT_EDGE_V M3s14_OPC_EDGE_V < M3_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s14_OPC_REGION_V
M3s14_EDGE_H_err2 = M3s14_SP_err2_REG_H COIN EDGE M3s14_OPC_EDGE_H
M3s14_EDGE_V_err2 = M3s14_SP_err2_REG_V COIN EDGE M3s14_OPC_EDGE_V

M3s14_SP_err2_REG_H_eff1 = DFM PROPERTY M3s14_SP_err2_REG_H M3s14_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M3s14_EDGE_H_err2)] > 2*M3_S_14_L2A
M3s14_SP_err2_REG_V_eff1 = DFM PROPERTY M3s14_SP_err2_REG_V M3s14_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M3s14_EDGE_V_err2)] > 2*M3_S_14_L2A

// Find Space error region(small space S2A3) //
M3s14_SP_err3_REG_H = (EXT Wide_M3s14_WI_EXT_EDGE_H M3s14_OPC_EDGE_H < M3_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s14_OPC_REGION_H
M3s14_SP_err3_REG_V = (EXT Wide_M3s14_WI_EXT_EDGE_V M3s14_OPC_EDGE_V < M3_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s14_OPC_REGION_V


M3.S.14 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.08 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.29 um (S1B) region >= 0.3 
  ((M3s14_SP_err1_REG_H_eff INTERACT M3s14_S3C_NNH_H) OR M3s14_S3C_NNH_H) INTERACT M3s14_R1_CHK
  ((M3s14_SP_err1_REG_H_eff INTERACT M3s14_S3C_NH_H) OR M3s14_S3C_NH_H) INTERACT M3s14_R1_CHK
  ((M3s14_SP_err1_REG_V_eff INTERACT M3s14_S3C_NNH_V) OR M3s14_S3C_NNH_V) INTERACT M3s14_R1_CHK
  ((M3s14_SP_err1_REG_V_eff INTERACT M3s14_S3C_NH_V) OR M3s14_S3C_NH_V) INTERACT M3s14_R1_CHK
}
M3.S.15 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.1 
  (M3s14_SP_err2_REG_H_eff1 AND M3s14_OPC_REGION_H) INTERACT Wide_M3s14_WI_JOG_H
  (M3s14_SP_err2_REG_V_eff1 AND M3s14_OPC_REGION_V) INTERACT Wide_M3s14_WI_JOG_V
}
M3.S.16 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M3s14_SP_err3_REG_H AND M3s14_OPC_REGION_H) INTERACT Wide_M3s14_WI_JOG_H
  (M3s14_SP_err3_REG_V AND M3s14_OPC_REGION_V) INTERACT Wide_M3s14_WI_JOG_V
}

// Wide M3s17 space error in OPC region checking
//====================================================

Wide_M3s17 = ENCLOSE RECTANGLE (SIZE M3 BY M3_S_17_W1B/2 UNDEROVER) M3_S_17_W1B+GRID M3_S_17_L1B+GRID ORTHOGONAL ONLY
M3s17_CHECK_REGION = M3 AND (SIZE Wide_M3s17 BY M3_S_17_S1B + GRID)
M3s17_OPC_REGION_pre1 = EXT [Wide_M3s17] M3s17_CHECK_REGION < M3_S_17_S1B OPPOSITE MEASURE ALL
M3s17_OPC_REGION_pre1_H = ANGLE M3s17_OPC_REGION_pre1 == 0
M3s17_OPC_REGION_pre1_V = ANGLE M3s17_OPC_REGION_pre1 == 90
M3s17_OPC_REGION_pre0_V = INT M3s17_OPC_REGION_pre1_H [Wide_M3s17] < GRID ABUT == 90 INTERSECTING ONLY 
M3s17_OPC_REGION_pre3_V = EXT M3s17_OPC_REGION_pre1_H [Wide_M3s17] < GRID ABUT == 90 INTERSECTING ONLY 
M3s17_OPC_REGION_pre4_V = (M3s17_CHECK_REGION TOUCH INSIDE EDGE M3s17_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M3s17_OPC_REGION_pre3_V
M3s17_OPC_REGION_pre0_H = INT M3s17_OPC_REGION_pre1_V [Wide_M3s17] < GRID ABUT == 90 INTERSECTING ONLY 
M3s17_OPC_REGION_pre3_H = EXT M3s17_OPC_REGION_pre1_V [Wide_M3s17] < GRID ABUT == 90 INTERSECTING ONLY 
M3s17_OPC_REGION_pre4_H = (M3s17_CHECK_REGION TOUCH INSIDE EDGE M3s17_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M3s17_OPC_REGION_pre3_H
M3s17_OPC_REGION_pre5_H = (EXPAND EDGE M3s17_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M3s17_OPC_REGION_pre4_V BY GRID)
M3s17_OPC_REGION_pre5_V = (EXPAND EDGE M3s17_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M3s17_OPC_REGION_pre4_H BY GRID)
M3s17_OPC_REGION_pre6_H = DFM PROPERTY M3s17_OPC_REGION_pre5_H M3s17_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M3s17_OPC_REGION_pre1_H)] > M3_S_17_L1B
M3s17_OPC_REGION_pre6_V = DFM PROPERTY M3s17_OPC_REGION_pre5_V M3s17_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M3s17_OPC_REGION_pre1_V)] > M3_S_17_L1B
M3s17_OPC_REGION_pre7_H = M3s17_OPC_REGION_pre1_H INSIDE EDGE M3s17_OPC_REGION_pre6_H
M3s17_OPC_REGION_pre7_V = M3s17_OPC_REGION_pre1_V INSIDE EDGE M3s17_OPC_REGION_pre6_V
M3s17_OPC_REGION_pre2_H = EXT M3s17_OPC_REGION_pre7_H M3s17_CHECK_REGION < M3_S_17_S1B OPPOSITE REGION MEASURE ALL
M3s17_OPC_REGION_pre2_V = EXT M3s17_OPC_REGION_pre7_V M3s17_CHECK_REGION < M3_S_17_S1B OPPOSITE REGION MEASURE ALL

M3s17_M3_H = M3 INTERACT M3s17_OPC_REGION_pre2_H
M3s17_M3_V = M3 INTERACT M3s17_OPC_REGION_pre2_V
M3s17_M3_ALL = M3s17_M3_H OR M3s17_M3_V
M3s17_OPC_EDGE_H = ANGLE (M3s17_M3_H NOT OUTSIDE EDGE M3s17_OPC_REGION_pre2_H) == 0
M3s17_OPC_EDGE_V = ANGLE (M3s17_M3_V NOT OUTSIDE EDGE M3s17_OPC_REGION_pre2_V) == 90

Wide_M3s17_H = Wide_M3s17 INTERACT M3s17_OPC_REGION_pre2_H
Wide_M3s17_V = Wide_M3s17 INTERACT M3s17_OPC_REGION_pre2_V
Wide_M3s17_WI_JOG_H = (M3 AND (Wide_M3s17_H OR M3s17_OPC_REGION_pre2_H)) INTERACT Wide_M3s17_H
Wide_M3s17_WI_JOG_V = (M3 AND (Wide_M3s17_V OR M3s17_OPC_REGION_pre2_V)) INTERACT Wide_M3s17_V

Wide_M3s17_WI_EXT_EDGE_H = M3s17_OPC_EDGE_H NOT COIN EDGE (INT [M3s17_OPC_EDGE_H] M3s17_M3_H <= M3_S_17_W1B OPPOSITE)
Wide_M3s17_WI_EXT_EDGE_V = M3s17_OPC_EDGE_V NOT COIN EDGE (INT [M3s17_OPC_EDGE_V] M3s17_M3_V <= M3_S_17_W1B OPPOSITE)

M3s17_OPC_REGION_H = (EXT Wide_M3s17_WI_JOG_H M3s17_OPC_EDGE_H < M3_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s17_OPC_REGION_pre2_H
M3s17_OPC_REGION_V = (EXT Wide_M3s17_WI_JOG_V M3s17_OPC_EDGE_V < M3_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s17_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M3s17_SP_err1_REG_H = (EXT Wide_M3s17_WI_EXT_EDGE_H M3s17_M3_H < M3_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s17_OPC_REGION_H
M3s17_SP_err1_REG_V = (EXT Wide_M3s17_WI_EXT_EDGE_V M3s17_M3_V < M3_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s17_OPC_REGION_V
M3s17_EDGE_H_err3 = ANGLE M3s17_SP_err1_REG_H == 0
M3s17_EDGE_V_err3 = ANGLE M3s17_SP_err1_REG_V == 90
M3s17_SP_err1_REG_H_eff = DFM PROPERTY M3s17_SP_err1_REG_H M3s17_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M3s17_EDGE_H_err3)] <= 2*M3_S_17_L2A
M3s17_SP_err1_REG_V_eff = DFM PROPERTY M3s17_SP_err1_REG_V M3s17_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M3s17_EDGE_V_err3)] <= 2*M3_S_17_L2A

  M3s17_R1_CHK = EXT Wide_M3s17 M3s17_M3_ALL < M3_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M3s17_NOTCH_EDGE_H = ANGLE (EXT [Wide_M3s17_WI_JOG_H] < M3_S_17_S1B OPPOSITE NOTCH) == 0
  M3s17_NOTCH_EDGE_V = ANGLE (EXT [Wide_M3s17_WI_JOG_V] < M3_S_17_S1B OPPOSITE NOTCH) == 90
  M3s17_NOTCH_REGION_H = (EXT M3s17_NOTCH_EDGE_H < M3_S_17_S1B OPPOSITE REGION) AND M3s17_OPC_REGION_H
  M3s17_NOTCH_REGION_V = (EXT M3s17_NOTCH_EDGE_V < M3_S_17_S1B OPPOSITE REGION) AND M3s17_OPC_REGION_V
  
// Check NON-Notch region
  M3s17_SP_err1_REG_H_eff5 = M3s17_SP_err1_REG_H_eff NOT M3s17_NOTCH_REGION_H
  M3s17_SP_err1_REG_V_eff5 = M3s17_SP_err1_REG_V_eff NOT M3s17_NOTCH_REGION_V
  CONNECT M3s17_SP_err1_REG_H_eff5 (M3s17_OPC_REGION_H NOT M3s17_NOTCH_REGION_H)
  CONNECT M3s17_SP_err1_REG_V_eff5 (M3s17_OPC_REGION_V NOT M3s17_NOTCH_REGION_V)
  M3s17_SP_err1_REG_H_eff5a = M3s17_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M3s17_CHECK_REGION
  M3s17_SP_err1_REG_V_eff5a = M3s17_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M3s17_CHECK_REGION
  M3s17_S3C_NNH_H = (EXT M3s17_SP_err1_REG_H_eff5a < M3_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M3
  M3s17_S3C_NNH_V = (EXT M3s17_SP_err1_REG_V_eff5a < M3_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M3
  
// Check Notch H region
  M3s17_SP_err1_REG_H_eff6 = M3s17_SP_err1_REG_H_eff INSIDE M3s17_NOTCH_REGION_H
  M3s17_SP_err1_REG_V_eff6 = M3s17_SP_err1_REG_V_eff INSIDE M3s17_NOTCH_REGION_V
  CONNECT M3s17_SP_err1_REG_H_eff6 M3s17_NOTCH_REGION_H
  CONNECT M3s17_SP_err1_REG_V_eff6 M3s17_NOTCH_REGION_V  
  M3s17_SP_err1_REG_H_eff6a = M3s17_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M3s17_CHECK_REGION
  M3s17_SP_err1_REG_V_eff6a = M3s17_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M3s17_CHECK_REGION
  M3s17_S3C_NH_H = (EXT M3s17_SP_err1_REG_H_eff6a < M3_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M3
  M3s17_S3C_NH_V = (EXT M3s17_SP_err1_REG_V_eff6a < M3_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M3

// Find Space error region(large space S2A2) //
M3s17_SP_err2_REG_H = (EXT Wide_M3s17_WI_EXT_EDGE_H M3s17_OPC_EDGE_H < M3_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s17_OPC_REGION_H
M3s17_SP_err2_REG_V = (EXT Wide_M3s17_WI_EXT_EDGE_V M3s17_OPC_EDGE_V < M3_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s17_OPC_REGION_V
M3s17_EDGE_H_err2 = M3s17_SP_err2_REG_H COIN EDGE M3s17_OPC_EDGE_H
M3s17_EDGE_V_err2 = M3s17_SP_err2_REG_V COIN EDGE M3s17_OPC_EDGE_V

M3s17_SP_err2_REG_H_eff1 = DFM PROPERTY M3s17_SP_err2_REG_H M3s17_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M3s17_EDGE_H_err2)] > 2*M3_S_17_L2A
M3s17_SP_err2_REG_V_eff1 = DFM PROPERTY M3s17_SP_err2_REG_V M3s17_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M3s17_EDGE_V_err2)] > 2*M3_S_17_L2A

// Find Space error region(small space S2A3) //
M3s17_SP_err3_REG_H = (EXT Wide_M3s17_WI_EXT_EDGE_H M3s17_OPC_EDGE_H < M3_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s17_OPC_REGION_H
M3s17_SP_err3_REG_V = (EXT Wide_M3s17_WI_EXT_EDGE_V M3s17_OPC_EDGE_V < M3_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s17_OPC_REGION_V


M3.S.17 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.47 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.13 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.47 um (W1B) and the parallel run length > 0.5 um (L1B) in metal space < 0.32 um (S1B) region >= 0.3 
  ((M3s17_SP_err1_REG_H_eff INTERACT M3s17_S3C_NNH_H) OR M3s17_S3C_NNH_H) INTERACT M3s17_R1_CHK
  ((M3s17_SP_err1_REG_H_eff INTERACT M3s17_S3C_NH_H) OR M3s17_S3C_NH_H) INTERACT M3s17_R1_CHK
  ((M3s17_SP_err1_REG_V_eff INTERACT M3s17_S3C_NNH_V) OR M3s17_S3C_NNH_V) INTERACT M3s17_R1_CHK
  ((M3s17_SP_err1_REG_V_eff INTERACT M3s17_S3C_NH_V) OR M3s17_S3C_NH_V) INTERACT M3s17_R1_CHK
}
M3.S.18 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.13 
  (M3s17_SP_err2_REG_H_eff1 AND M3s17_OPC_REGION_H) INTERACT Wide_M3s17_WI_JOG_H
  (M3s17_SP_err2_REG_V_eff1 AND M3s17_OPC_REGION_V) INTERACT Wide_M3s17_WI_JOG_V
}
M3.S.19 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M3s17_SP_err3_REG_H AND M3s17_OPC_REGION_H) INTERACT Wide_M3s17_WI_JOG_H
  (M3s17_SP_err3_REG_V AND M3s17_OPC_REGION_V) INTERACT Wide_M3s17_WI_JOG_V
}

// Wide M3s20 space error in OPC region checking
//====================================================

Wide_M3s20 = ENCLOSE RECTANGLE (SIZE M3 BY M3_S_20_W1B/2 UNDEROVER) M3_S_20_W1B+GRID M3_S_20_L1B+GRID ORTHOGONAL ONLY
M3s20_CHECK_REGION = M3 AND (SIZE Wide_M3s20 BY M3_S_20_S1B + GRID)
M3s20_OPC_REGION_pre1 = EXT [Wide_M3s20] M3s20_CHECK_REGION < M3_S_20_S1B OPPOSITE MEASURE ALL
M3s20_OPC_REGION_pre1_H = ANGLE M3s20_OPC_REGION_pre1 == 0
M3s20_OPC_REGION_pre1_V = ANGLE M3s20_OPC_REGION_pre1 == 90
M3s20_OPC_REGION_pre0_V = INT M3s20_OPC_REGION_pre1_H [Wide_M3s20] < GRID ABUT == 90 INTERSECTING ONLY 
M3s20_OPC_REGION_pre3_V = EXT M3s20_OPC_REGION_pre1_H [Wide_M3s20] < GRID ABUT == 90 INTERSECTING ONLY 
M3s20_OPC_REGION_pre4_V = (M3s20_CHECK_REGION TOUCH INSIDE EDGE M3s20_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M3s20_OPC_REGION_pre3_V
M3s20_OPC_REGION_pre0_H = INT M3s20_OPC_REGION_pre1_V [Wide_M3s20] < GRID ABUT == 90 INTERSECTING ONLY 
M3s20_OPC_REGION_pre3_H = EXT M3s20_OPC_REGION_pre1_V [Wide_M3s20] < GRID ABUT == 90 INTERSECTING ONLY 
M3s20_OPC_REGION_pre4_H = (M3s20_CHECK_REGION TOUCH INSIDE EDGE M3s20_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M3s20_OPC_REGION_pre3_H
M3s20_OPC_REGION_pre5_H = (EXPAND EDGE M3s20_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M3s20_OPC_REGION_pre4_V BY GRID)
M3s20_OPC_REGION_pre5_V = (EXPAND EDGE M3s20_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M3s20_OPC_REGION_pre4_H BY GRID)
M3s20_OPC_REGION_pre6_H = DFM PROPERTY M3s20_OPC_REGION_pre5_H M3s20_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M3s20_OPC_REGION_pre1_H)] > M3_S_20_L1B
M3s20_OPC_REGION_pre6_V = DFM PROPERTY M3s20_OPC_REGION_pre5_V M3s20_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M3s20_OPC_REGION_pre1_V)] > M3_S_20_L1B
M3s20_OPC_REGION_pre7_H = M3s20_OPC_REGION_pre1_H INSIDE EDGE M3s20_OPC_REGION_pre6_H
M3s20_OPC_REGION_pre7_V = M3s20_OPC_REGION_pre1_V INSIDE EDGE M3s20_OPC_REGION_pre6_V
M3s20_OPC_REGION_pre2_H = EXT M3s20_OPC_REGION_pre7_H M3s20_CHECK_REGION < M3_S_20_S1B OPPOSITE REGION MEASURE ALL
M3s20_OPC_REGION_pre2_V = EXT M3s20_OPC_REGION_pre7_V M3s20_CHECK_REGION < M3_S_20_S1B OPPOSITE REGION MEASURE ALL

M3s20_M3_H = M3 INTERACT M3s20_OPC_REGION_pre2_H
M3s20_M3_V = M3 INTERACT M3s20_OPC_REGION_pre2_V
M3s20_M3_ALL = M3s20_M3_H OR M3s20_M3_V
M3s20_OPC_EDGE_H = ANGLE (M3s20_M3_H NOT OUTSIDE EDGE M3s20_OPC_REGION_pre2_H) == 0
M3s20_OPC_EDGE_V = ANGLE (M3s20_M3_V NOT OUTSIDE EDGE M3s20_OPC_REGION_pre2_V) == 90

Wide_M3s20_H = Wide_M3s20 INTERACT M3s20_OPC_REGION_pre2_H
Wide_M3s20_V = Wide_M3s20 INTERACT M3s20_OPC_REGION_pre2_V
Wide_M3s20_WI_JOG_H = (M3 AND (Wide_M3s20_H OR M3s20_OPC_REGION_pre2_H)) INTERACT Wide_M3s20_H
Wide_M3s20_WI_JOG_V = (M3 AND (Wide_M3s20_V OR M3s20_OPC_REGION_pre2_V)) INTERACT Wide_M3s20_V

Wide_M3s20_WI_EXT_EDGE_H = M3s20_OPC_EDGE_H NOT COIN EDGE (INT [M3s20_OPC_EDGE_H] M3s20_M3_H <= M3_S_20_W1B OPPOSITE)
Wide_M3s20_WI_EXT_EDGE_V = M3s20_OPC_EDGE_V NOT COIN EDGE (INT [M3s20_OPC_EDGE_V] M3s20_M3_V <= M3_S_20_W1B OPPOSITE)

M3s20_OPC_REGION_H = (EXT Wide_M3s20_WI_JOG_H M3s20_OPC_EDGE_H < M3_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s20_OPC_REGION_pre2_H
M3s20_OPC_REGION_V = (EXT Wide_M3s20_WI_JOG_V M3s20_OPC_EDGE_V < M3_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s20_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M3s20_SP_err1_REG_H = (EXT Wide_M3s20_WI_EXT_EDGE_H M3s20_M3_H < M3_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s20_OPC_REGION_H
M3s20_SP_err1_REG_V = (EXT Wide_M3s20_WI_EXT_EDGE_V M3s20_M3_V < M3_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s20_OPC_REGION_V
M3s20_EDGE_H_err3 = ANGLE M3s20_SP_err1_REG_H == 0
M3s20_EDGE_V_err3 = ANGLE M3s20_SP_err1_REG_V == 90
M3s20_SP_err1_REG_H_eff = DFM PROPERTY M3s20_SP_err1_REG_H M3s20_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M3s20_EDGE_H_err3)] <= 2*M3_S_20_L2A
M3s20_SP_err1_REG_V_eff = DFM PROPERTY M3s20_SP_err1_REG_V M3s20_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M3s20_EDGE_V_err3)] <= 2*M3_S_20_L2A

  M3s20_R1_CHK = EXT Wide_M3s20 M3s20_M3_ALL < M3_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M3s20_NOTCH_EDGE_H = ANGLE (EXT [Wide_M3s20_WI_JOG_H] < M3_S_20_S1B OPPOSITE NOTCH) == 0
  M3s20_NOTCH_EDGE_V = ANGLE (EXT [Wide_M3s20_WI_JOG_V] < M3_S_20_S1B OPPOSITE NOTCH) == 90
  M3s20_NOTCH_REGION_H = (EXT M3s20_NOTCH_EDGE_H < M3_S_20_S1B OPPOSITE REGION) AND M3s20_OPC_REGION_H
  M3s20_NOTCH_REGION_V = (EXT M3s20_NOTCH_EDGE_V < M3_S_20_S1B OPPOSITE REGION) AND M3s20_OPC_REGION_V
  
// Check NON-Notch region
  M3s20_SP_err1_REG_H_eff5 = M3s20_SP_err1_REG_H_eff NOT M3s20_NOTCH_REGION_H
  M3s20_SP_err1_REG_V_eff5 = M3s20_SP_err1_REG_V_eff NOT M3s20_NOTCH_REGION_V
  CONNECT M3s20_SP_err1_REG_H_eff5 (M3s20_OPC_REGION_H NOT M3s20_NOTCH_REGION_H)
  CONNECT M3s20_SP_err1_REG_V_eff5 (M3s20_OPC_REGION_V NOT M3s20_NOTCH_REGION_V)
  M3s20_SP_err1_REG_H_eff5a = M3s20_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M3s20_CHECK_REGION
  M3s20_SP_err1_REG_V_eff5a = M3s20_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M3s20_CHECK_REGION
  M3s20_S3C_NNH_H = (EXT M3s20_SP_err1_REG_H_eff5a < M3_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M3
  M3s20_S3C_NNH_V = (EXT M3s20_SP_err1_REG_V_eff5a < M3_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M3
  
// Check Notch H region
  M3s20_SP_err1_REG_H_eff6 = M3s20_SP_err1_REG_H_eff INSIDE M3s20_NOTCH_REGION_H
  M3s20_SP_err1_REG_V_eff6 = M3s20_SP_err1_REG_V_eff INSIDE M3s20_NOTCH_REGION_V
  CONNECT M3s20_SP_err1_REG_H_eff6 M3s20_NOTCH_REGION_H
  CONNECT M3s20_SP_err1_REG_V_eff6 M3s20_NOTCH_REGION_V  
  M3s20_SP_err1_REG_H_eff6a = M3s20_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M3s20_CHECK_REGION
  M3s20_SP_err1_REG_V_eff6a = M3s20_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M3s20_CHECK_REGION
  M3s20_S3C_NH_H = (EXT M3s20_SP_err1_REG_H_eff6a < M3_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M3
  M3s20_S3C_NH_V = (EXT M3s20_SP_err1_REG_V_eff6a < M3_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M3

// Find Space error region(large space S2A2) //
M3s20_SP_err2_REG_H = (EXT Wide_M3s20_WI_EXT_EDGE_H M3s20_OPC_EDGE_H < M3_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s20_OPC_REGION_H
M3s20_SP_err2_REG_V = (EXT Wide_M3s20_WI_EXT_EDGE_V M3s20_OPC_EDGE_V < M3_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s20_OPC_REGION_V
M3s20_EDGE_H_err2 = M3s20_SP_err2_REG_H COIN EDGE M3s20_OPC_EDGE_H
M3s20_EDGE_V_err2 = M3s20_SP_err2_REG_V COIN EDGE M3s20_OPC_EDGE_V

M3s20_SP_err2_REG_H_eff1 = DFM PROPERTY M3s20_SP_err2_REG_H M3s20_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M3s20_EDGE_H_err2)] > 2*M3_S_20_L2A
M3s20_SP_err2_REG_V_eff1 = DFM PROPERTY M3s20_SP_err2_REG_V M3s20_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M3s20_EDGE_V_err2)] > 2*M3_S_20_L2A

// Find Space error region(small space S2A3) //
M3s20_SP_err3_REG_H = (EXT Wide_M3s20_WI_EXT_EDGE_H M3s20_OPC_EDGE_H < M3_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s20_OPC_REGION_H
M3s20_SP_err3_REG_V = (EXT Wide_M3s20_WI_EXT_EDGE_V M3s20_OPC_EDGE_V < M3_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s20_OPC_REGION_V


M3.S.20 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.63 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.15 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.63 um (W1B) and the parallel run length > 0.7 um (L1B) in metal space < 0.34 um (S1B) region >= 0.3 
  ((M3s20_SP_err1_REG_H_eff INTERACT M3s20_S3C_NNH_H) OR M3s20_S3C_NNH_H) INTERACT M3s20_R1_CHK
  ((M3s20_SP_err1_REG_H_eff INTERACT M3s20_S3C_NH_H) OR M3s20_S3C_NH_H) INTERACT M3s20_R1_CHK
  ((M3s20_SP_err1_REG_V_eff INTERACT M3s20_S3C_NNH_V) OR M3s20_S3C_NNH_V) INTERACT M3s20_R1_CHK
  ((M3s20_SP_err1_REG_V_eff INTERACT M3s20_S3C_NH_V) OR M3s20_S3C_NH_V) INTERACT M3s20_R1_CHK
}
M3.S.21 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.15 
  (M3s20_SP_err2_REG_H_eff1 AND M3s20_OPC_REGION_H) INTERACT Wide_M3s20_WI_JOG_H
  (M3s20_SP_err2_REG_V_eff1 AND M3s20_OPC_REGION_V) INTERACT Wide_M3s20_WI_JOG_V
}
M3.S.22 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M3s20_SP_err3_REG_H AND M3s20_OPC_REGION_H) INTERACT Wide_M3s20_WI_JOG_H
  (M3s20_SP_err3_REG_V AND M3s20_OPC_REGION_V) INTERACT Wide_M3s20_WI_JOG_V
}

// Wide M3s23 space error in OPC region checking
//====================================================

Wide_M3s23 = ENCLOSE RECTANGLE (SIZE M3 BY M3_S_23_W1B/2 UNDEROVER) M3_S_23_W1B+GRID M3_S_23_L1B+GRID ORTHOGONAL ONLY
M3s23_CHECK_REGION = M3 AND (SIZE Wide_M3s23 BY M3_S_23_S1B + GRID)
M3s23_OPC_REGION_pre1 = EXT [Wide_M3s23] M3s23_CHECK_REGION < M3_S_23_S1B OPPOSITE MEASURE ALL
M3s23_OPC_REGION_pre1_H = ANGLE M3s23_OPC_REGION_pre1 == 0
M3s23_OPC_REGION_pre1_V = ANGLE M3s23_OPC_REGION_pre1 == 90
M3s23_OPC_REGION_pre0_V = INT M3s23_OPC_REGION_pre1_H [Wide_M3s23] < GRID ABUT == 90 INTERSECTING ONLY 
M3s23_OPC_REGION_pre3_V = EXT M3s23_OPC_REGION_pre1_H [Wide_M3s23] < GRID ABUT == 90 INTERSECTING ONLY 
M3s23_OPC_REGION_pre4_V = (M3s23_CHECK_REGION TOUCH INSIDE EDGE M3s23_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M3s23_OPC_REGION_pre3_V
M3s23_OPC_REGION_pre0_H = INT M3s23_OPC_REGION_pre1_V [Wide_M3s23] < GRID ABUT == 90 INTERSECTING ONLY 
M3s23_OPC_REGION_pre3_H = EXT M3s23_OPC_REGION_pre1_V [Wide_M3s23] < GRID ABUT == 90 INTERSECTING ONLY 
M3s23_OPC_REGION_pre4_H = (M3s23_CHECK_REGION TOUCH INSIDE EDGE M3s23_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M3s23_OPC_REGION_pre3_H
M3s23_OPC_REGION_pre5_H = (EXPAND EDGE M3s23_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M3s23_OPC_REGION_pre4_V BY GRID)
M3s23_OPC_REGION_pre5_V = (EXPAND EDGE M3s23_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M3s23_OPC_REGION_pre4_H BY GRID)
M3s23_OPC_REGION_pre6_H = DFM PROPERTY M3s23_OPC_REGION_pre5_H M3s23_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M3s23_OPC_REGION_pre1_H)] > M3_S_23_L1B
M3s23_OPC_REGION_pre6_V = DFM PROPERTY M3s23_OPC_REGION_pre5_V M3s23_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M3s23_OPC_REGION_pre1_V)] > M3_S_23_L1B
M3s23_OPC_REGION_pre7_H = M3s23_OPC_REGION_pre1_H INSIDE EDGE M3s23_OPC_REGION_pre6_H
M3s23_OPC_REGION_pre7_V = M3s23_OPC_REGION_pre1_V INSIDE EDGE M3s23_OPC_REGION_pre6_V
M3s23_OPC_REGION_pre2_H = EXT M3s23_OPC_REGION_pre7_H M3s23_CHECK_REGION < M3_S_23_S1B OPPOSITE REGION MEASURE ALL
M3s23_OPC_REGION_pre2_V = EXT M3s23_OPC_REGION_pre7_V M3s23_CHECK_REGION < M3_S_23_S1B OPPOSITE REGION MEASURE ALL

M3s23_M3_H = M3 INTERACT M3s23_OPC_REGION_pre2_H
M3s23_M3_V = M3 INTERACT M3s23_OPC_REGION_pre2_V
M3s23_M3_ALL = M3s23_M3_H OR M3s23_M3_V
M3s23_OPC_EDGE_H = ANGLE (M3s23_M3_H NOT OUTSIDE EDGE M3s23_OPC_REGION_pre2_H) == 0
M3s23_OPC_EDGE_V = ANGLE (M3s23_M3_V NOT OUTSIDE EDGE M3s23_OPC_REGION_pre2_V) == 90

Wide_M3s23_H = Wide_M3s23 INTERACT M3s23_OPC_REGION_pre2_H
Wide_M3s23_V = Wide_M3s23 INTERACT M3s23_OPC_REGION_pre2_V
Wide_M3s23_WI_JOG_H = (M3 AND (Wide_M3s23_H OR M3s23_OPC_REGION_pre2_H)) INTERACT Wide_M3s23_H
Wide_M3s23_WI_JOG_V = (M3 AND (Wide_M3s23_V OR M3s23_OPC_REGION_pre2_V)) INTERACT Wide_M3s23_V

Wide_M3s23_WI_EXT_EDGE_H = M3s23_OPC_EDGE_H NOT COIN EDGE (INT [M3s23_OPC_EDGE_H] M3s23_M3_H <= M3_S_23_W1B OPPOSITE)
Wide_M3s23_WI_EXT_EDGE_V = M3s23_OPC_EDGE_V NOT COIN EDGE (INT [M3s23_OPC_EDGE_V] M3s23_M3_V <= M3_S_23_W1B OPPOSITE)

M3s23_OPC_REGION_H = (EXT Wide_M3s23_WI_JOG_H M3s23_OPC_EDGE_H < M3_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s23_OPC_REGION_pre2_H
M3s23_OPC_REGION_V = (EXT Wide_M3s23_WI_JOG_V M3s23_OPC_EDGE_V < M3_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s23_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M3s23_SP_err1_REG_H = (EXT Wide_M3s23_WI_EXT_EDGE_H M3s23_M3_H < M3_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s23_OPC_REGION_H
M3s23_SP_err1_REG_V = (EXT Wide_M3s23_WI_EXT_EDGE_V M3s23_M3_V < M3_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s23_OPC_REGION_V
M3s23_EDGE_H_err3 = ANGLE M3s23_SP_err1_REG_H == 0
M3s23_EDGE_V_err3 = ANGLE M3s23_SP_err1_REG_V == 90
M3s23_SP_err1_REG_H_eff = DFM PROPERTY M3s23_SP_err1_REG_H M3s23_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M3s23_EDGE_H_err3)] <= 2*M3_S_23_L2A
M3s23_SP_err1_REG_V_eff = DFM PROPERTY M3s23_SP_err1_REG_V M3s23_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M3s23_EDGE_V_err3)] <= 2*M3_S_23_L2A

  M3s23_R1_CHK = EXT Wide_M3s23 M3s23_M3_ALL < M3_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M3s23_NOTCH_EDGE_H = ANGLE (EXT [Wide_M3s23_WI_JOG_H] < M3_S_23_S1B OPPOSITE NOTCH) == 0
  M3s23_NOTCH_EDGE_V = ANGLE (EXT [Wide_M3s23_WI_JOG_V] < M3_S_23_S1B OPPOSITE NOTCH) == 90
  M3s23_NOTCH_REGION_H = (EXT M3s23_NOTCH_EDGE_H < M3_S_23_S1B OPPOSITE REGION) AND M3s23_OPC_REGION_H
  M3s23_NOTCH_REGION_V = (EXT M3s23_NOTCH_EDGE_V < M3_S_23_S1B OPPOSITE REGION) AND M3s23_OPC_REGION_V
  
// Check NON-Notch region
  M3s23_SP_err1_REG_H_eff5 = M3s23_SP_err1_REG_H_eff NOT M3s23_NOTCH_REGION_H
  M3s23_SP_err1_REG_V_eff5 = M3s23_SP_err1_REG_V_eff NOT M3s23_NOTCH_REGION_V
  CONNECT M3s23_SP_err1_REG_H_eff5 (M3s23_OPC_REGION_H NOT M3s23_NOTCH_REGION_H)
  CONNECT M3s23_SP_err1_REG_V_eff5 (M3s23_OPC_REGION_V NOT M3s23_NOTCH_REGION_V)
  M3s23_SP_err1_REG_H_eff5a = M3s23_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M3s23_CHECK_REGION
  M3s23_SP_err1_REG_V_eff5a = M3s23_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M3s23_CHECK_REGION
  M3s23_S3C_NNH_H = (EXT M3s23_SP_err1_REG_H_eff5a < M3_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M3
  M3s23_S3C_NNH_V = (EXT M3s23_SP_err1_REG_V_eff5a < M3_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M3
  
// Check Notch H region
  M3s23_SP_err1_REG_H_eff6 = M3s23_SP_err1_REG_H_eff INSIDE M3s23_NOTCH_REGION_H
  M3s23_SP_err1_REG_V_eff6 = M3s23_SP_err1_REG_V_eff INSIDE M3s23_NOTCH_REGION_V
  CONNECT M3s23_SP_err1_REG_H_eff6 M3s23_NOTCH_REGION_H
  CONNECT M3s23_SP_err1_REG_V_eff6 M3s23_NOTCH_REGION_V  
  M3s23_SP_err1_REG_H_eff6a = M3s23_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M3s23_CHECK_REGION
  M3s23_SP_err1_REG_V_eff6a = M3s23_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M3s23_CHECK_REGION
  M3s23_S3C_NH_H = (EXT M3s23_SP_err1_REG_H_eff6a < M3_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M3
  M3s23_S3C_NH_V = (EXT M3s23_SP_err1_REG_V_eff6a < M3_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M3

// Find Space error region(large space S2A2) //
M3s23_SP_err2_REG_H = (EXT Wide_M3s23_WI_EXT_EDGE_H M3s23_OPC_EDGE_H < M3_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s23_OPC_REGION_H
M3s23_SP_err2_REG_V = (EXT Wide_M3s23_WI_EXT_EDGE_V M3s23_OPC_EDGE_V < M3_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s23_OPC_REGION_V
M3s23_EDGE_H_err2 = M3s23_SP_err2_REG_H COIN EDGE M3s23_OPC_EDGE_H
M3s23_EDGE_V_err2 = M3s23_SP_err2_REG_V COIN EDGE M3s23_OPC_EDGE_V

M3s23_SP_err2_REG_H_eff1 = DFM PROPERTY M3s23_SP_err2_REG_H M3s23_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M3s23_EDGE_H_err2)] > 2*M3_S_23_L2A
M3s23_SP_err2_REG_V_eff1 = DFM PROPERTY M3s23_SP_err2_REG_V M3s23_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M3s23_EDGE_V_err2)] > 2*M3_S_23_L2A

// Find Space error region(small space S2A3) //
M3s23_SP_err3_REG_H = (EXT Wide_M3s23_WI_EXT_EDGE_H M3s23_OPC_EDGE_H < M3_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s23_OPC_REGION_H
M3s23_SP_err3_REG_V = (EXT Wide_M3s23_WI_EXT_EDGE_V M3s23_OPC_EDGE_V < M3_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s23_OPC_REGION_V


M3.S.23 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 1.5 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.3 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 1.5 um (W1B) and the parallel run length > 1.5 um (L1B) in metal space < 0.5 um (S1B) region >= 0.3 
  ((M3s23_SP_err1_REG_H_eff INTERACT M3s23_S3C_NNH_H) OR M3s23_S3C_NNH_H) INTERACT M3s23_R1_CHK
  ((M3s23_SP_err1_REG_H_eff INTERACT M3s23_S3C_NH_H) OR M3s23_S3C_NH_H) INTERACT M3s23_R1_CHK
  ((M3s23_SP_err1_REG_V_eff INTERACT M3s23_S3C_NNH_V) OR M3s23_S3C_NNH_V) INTERACT M3s23_R1_CHK
  ((M3s23_SP_err1_REG_V_eff INTERACT M3s23_S3C_NH_V) OR M3s23_S3C_NH_V) INTERACT M3s23_R1_CHK
}
M3.S.24 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.3 
  (M3s23_SP_err2_REG_H_eff1 AND M3s23_OPC_REGION_H) INTERACT Wide_M3s23_WI_JOG_H
  (M3s23_SP_err2_REG_V_eff1 AND M3s23_OPC_REGION_V) INTERACT Wide_M3s23_WI_JOG_V
}
M3.S.25 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M3s23_SP_err3_REG_H AND M3s23_OPC_REGION_H) INTERACT Wide_M3s23_WI_JOG_H
  (M3s23_SP_err3_REG_V AND M3s23_OPC_REGION_V) INTERACT Wide_M3s23_WI_JOG_V
}


// M4 WMJ JOG Rules
//=============================
// Wide M4s14 space error in OPC region checking
//====================================================

Wide_M4s14 = ENCLOSE RECTANGLE (SIZE M4 BY M4_S_14_W1B/2 UNDEROVER) M4_S_14_W1B+GRID M4_S_14_L1B+GRID ORTHOGONAL ONLY
M4s14_CHECK_REGION = M4 AND (SIZE Wide_M4s14 BY M4_S_14_S1B + GRID)
M4s14_OPC_REGION_pre1 = EXT [Wide_M4s14] M4s14_CHECK_REGION < M4_S_14_S1B OPPOSITE MEASURE ALL
M4s14_OPC_REGION_pre1_H = ANGLE M4s14_OPC_REGION_pre1 == 0
M4s14_OPC_REGION_pre1_V = ANGLE M4s14_OPC_REGION_pre1 == 90
M4s14_OPC_REGION_pre0_V = INT M4s14_OPC_REGION_pre1_H [Wide_M4s14] < GRID ABUT == 90 INTERSECTING ONLY 
M4s14_OPC_REGION_pre3_V = EXT M4s14_OPC_REGION_pre1_H [Wide_M4s14] < GRID ABUT == 90 INTERSECTING ONLY 
M4s14_OPC_REGION_pre4_V = (M4s14_CHECK_REGION TOUCH INSIDE EDGE M4s14_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M4s14_OPC_REGION_pre3_V
M4s14_OPC_REGION_pre0_H = INT M4s14_OPC_REGION_pre1_V [Wide_M4s14] < GRID ABUT == 90 INTERSECTING ONLY 
M4s14_OPC_REGION_pre3_H = EXT M4s14_OPC_REGION_pre1_V [Wide_M4s14] < GRID ABUT == 90 INTERSECTING ONLY 
M4s14_OPC_REGION_pre4_H = (M4s14_CHECK_REGION TOUCH INSIDE EDGE M4s14_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M4s14_OPC_REGION_pre3_H
M4s14_OPC_REGION_pre5_H = (EXPAND EDGE M4s14_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M4s14_OPC_REGION_pre4_V BY GRID)
M4s14_OPC_REGION_pre5_V = (EXPAND EDGE M4s14_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M4s14_OPC_REGION_pre4_H BY GRID)
M4s14_OPC_REGION_pre6_H = DFM PROPERTY M4s14_OPC_REGION_pre5_H M4s14_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M4s14_OPC_REGION_pre1_H)] > M4_S_14_L1B
M4s14_OPC_REGION_pre6_V = DFM PROPERTY M4s14_OPC_REGION_pre5_V M4s14_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M4s14_OPC_REGION_pre1_V)] > M4_S_14_L1B
M4s14_OPC_REGION_pre7_H = M4s14_OPC_REGION_pre1_H INSIDE EDGE M4s14_OPC_REGION_pre6_H
M4s14_OPC_REGION_pre7_V = M4s14_OPC_REGION_pre1_V INSIDE EDGE M4s14_OPC_REGION_pre6_V
M4s14_OPC_REGION_pre2_H = EXT M4s14_OPC_REGION_pre7_H M4s14_CHECK_REGION < M4_S_14_S1B OPPOSITE REGION MEASURE ALL
M4s14_OPC_REGION_pre2_V = EXT M4s14_OPC_REGION_pre7_V M4s14_CHECK_REGION < M4_S_14_S1B OPPOSITE REGION MEASURE ALL

M4s14_M4_H = M4 INTERACT M4s14_OPC_REGION_pre2_H
M4s14_M4_V = M4 INTERACT M4s14_OPC_REGION_pre2_V
M4s14_M4_ALL = M4s14_M4_H OR M4s14_M4_V
M4s14_OPC_EDGE_H = ANGLE (M4s14_M4_H NOT OUTSIDE EDGE M4s14_OPC_REGION_pre2_H) == 0
M4s14_OPC_EDGE_V = ANGLE (M4s14_M4_V NOT OUTSIDE EDGE M4s14_OPC_REGION_pre2_V) == 90

Wide_M4s14_H = Wide_M4s14 INTERACT M4s14_OPC_REGION_pre2_H
Wide_M4s14_V = Wide_M4s14 INTERACT M4s14_OPC_REGION_pre2_V
Wide_M4s14_WI_JOG_H = (M4 AND (Wide_M4s14_H OR M4s14_OPC_REGION_pre2_H)) INTERACT Wide_M4s14_H
Wide_M4s14_WI_JOG_V = (M4 AND (Wide_M4s14_V OR M4s14_OPC_REGION_pre2_V)) INTERACT Wide_M4s14_V

Wide_M4s14_WI_EXT_EDGE_H = M4s14_OPC_EDGE_H NOT COIN EDGE (INT [M4s14_OPC_EDGE_H] M4s14_M4_H <= M4_S_14_W1B OPPOSITE)
Wide_M4s14_WI_EXT_EDGE_V = M4s14_OPC_EDGE_V NOT COIN EDGE (INT [M4s14_OPC_EDGE_V] M4s14_M4_V <= M4_S_14_W1B OPPOSITE)

M4s14_OPC_REGION_H = (EXT Wide_M4s14_WI_JOG_H M4s14_OPC_EDGE_H < M4_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s14_OPC_REGION_pre2_H
M4s14_OPC_REGION_V = (EXT Wide_M4s14_WI_JOG_V M4s14_OPC_EDGE_V < M4_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s14_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M4s14_SP_err1_REG_H = (EXT Wide_M4s14_WI_EXT_EDGE_H M4s14_M4_H < M4_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s14_OPC_REGION_H
M4s14_SP_err1_REG_V = (EXT Wide_M4s14_WI_EXT_EDGE_V M4s14_M4_V < M4_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s14_OPC_REGION_V
M4s14_EDGE_H_err3 = ANGLE M4s14_SP_err1_REG_H == 0
M4s14_EDGE_V_err3 = ANGLE M4s14_SP_err1_REG_V == 90
M4s14_SP_err1_REG_H_eff = DFM PROPERTY M4s14_SP_err1_REG_H M4s14_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M4s14_EDGE_H_err3)] <= 2*M4_S_14_L2A
M4s14_SP_err1_REG_V_eff = DFM PROPERTY M4s14_SP_err1_REG_V M4s14_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M4s14_EDGE_V_err3)] <= 2*M4_S_14_L2A

  M4s14_R1_CHK = EXT Wide_M4s14 M4s14_M4_ALL < M4_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M4s14_NOTCH_EDGE_H = ANGLE (EXT [Wide_M4s14_WI_JOG_H] < M4_S_14_S1B OPPOSITE NOTCH) == 0
  M4s14_NOTCH_EDGE_V = ANGLE (EXT [Wide_M4s14_WI_JOG_V] < M4_S_14_S1B OPPOSITE NOTCH) == 90
  M4s14_NOTCH_REGION_H = (EXT M4s14_NOTCH_EDGE_H < M4_S_14_S1B OPPOSITE REGION) AND M4s14_OPC_REGION_H
  M4s14_NOTCH_REGION_V = (EXT M4s14_NOTCH_EDGE_V < M4_S_14_S1B OPPOSITE REGION) AND M4s14_OPC_REGION_V
  
// Check NON-Notch region
  M4s14_SP_err1_REG_H_eff5 = M4s14_SP_err1_REG_H_eff NOT M4s14_NOTCH_REGION_H
  M4s14_SP_err1_REG_V_eff5 = M4s14_SP_err1_REG_V_eff NOT M4s14_NOTCH_REGION_V
  CONNECT M4s14_SP_err1_REG_H_eff5 (M4s14_OPC_REGION_H NOT M4s14_NOTCH_REGION_H)
  CONNECT M4s14_SP_err1_REG_V_eff5 (M4s14_OPC_REGION_V NOT M4s14_NOTCH_REGION_V)
  M4s14_SP_err1_REG_H_eff5a = M4s14_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M4s14_CHECK_REGION
  M4s14_SP_err1_REG_V_eff5a = M4s14_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M4s14_CHECK_REGION
  M4s14_S3C_NNH_H = (EXT M4s14_SP_err1_REG_H_eff5a < M4_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M4
  M4s14_S3C_NNH_V = (EXT M4s14_SP_err1_REG_V_eff5a < M4_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M4
  
// Check Notch H region
  M4s14_SP_err1_REG_H_eff6 = M4s14_SP_err1_REG_H_eff INSIDE M4s14_NOTCH_REGION_H
  M4s14_SP_err1_REG_V_eff6 = M4s14_SP_err1_REG_V_eff INSIDE M4s14_NOTCH_REGION_V
  CONNECT M4s14_SP_err1_REG_H_eff6 M4s14_NOTCH_REGION_H
  CONNECT M4s14_SP_err1_REG_V_eff6 M4s14_NOTCH_REGION_V  
  M4s14_SP_err1_REG_H_eff6a = M4s14_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M4s14_CHECK_REGION
  M4s14_SP_err1_REG_V_eff6a = M4s14_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M4s14_CHECK_REGION
  M4s14_S3C_NH_H = (EXT M4s14_SP_err1_REG_H_eff6a < M4_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M4
  M4s14_S3C_NH_V = (EXT M4s14_SP_err1_REG_V_eff6a < M4_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M4

// Find Space error region(large space S2A2) //
M4s14_SP_err2_REG_H = (EXT Wide_M4s14_WI_EXT_EDGE_H M4s14_OPC_EDGE_H < M4_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s14_OPC_REGION_H
M4s14_SP_err2_REG_V = (EXT Wide_M4s14_WI_EXT_EDGE_V M4s14_OPC_EDGE_V < M4_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s14_OPC_REGION_V
M4s14_EDGE_H_err2 = M4s14_SP_err2_REG_H COIN EDGE M4s14_OPC_EDGE_H
M4s14_EDGE_V_err2 = M4s14_SP_err2_REG_V COIN EDGE M4s14_OPC_EDGE_V

M4s14_SP_err2_REG_H_eff1 = DFM PROPERTY M4s14_SP_err2_REG_H M4s14_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M4s14_EDGE_H_err2)] > 2*M4_S_14_L2A
M4s14_SP_err2_REG_V_eff1 = DFM PROPERTY M4s14_SP_err2_REG_V M4s14_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M4s14_EDGE_V_err2)] > 2*M4_S_14_L2A

// Find Space error region(small space S2A3) //
M4s14_SP_err3_REG_H = (EXT Wide_M4s14_WI_EXT_EDGE_H M4s14_OPC_EDGE_H < M4_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s14_OPC_REGION_H
M4s14_SP_err3_REG_V = (EXT Wide_M4s14_WI_EXT_EDGE_V M4s14_OPC_EDGE_V < M4_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s14_OPC_REGION_V


M4.S.14 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.08 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.29 um (S1B) region >= 0.3 
  ((M4s14_SP_err1_REG_H_eff INTERACT M4s14_S3C_NNH_H) OR M4s14_S3C_NNH_H) INTERACT M4s14_R1_CHK
  ((M4s14_SP_err1_REG_H_eff INTERACT M4s14_S3C_NH_H) OR M4s14_S3C_NH_H) INTERACT M4s14_R1_CHK
  ((M4s14_SP_err1_REG_V_eff INTERACT M4s14_S3C_NNH_V) OR M4s14_S3C_NNH_V) INTERACT M4s14_R1_CHK
  ((M4s14_SP_err1_REG_V_eff INTERACT M4s14_S3C_NH_V) OR M4s14_S3C_NH_V) INTERACT M4s14_R1_CHK
}
M4.S.15 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.1 
  (M4s14_SP_err2_REG_H_eff1 AND M4s14_OPC_REGION_H) INTERACT Wide_M4s14_WI_JOG_H
  (M4s14_SP_err2_REG_V_eff1 AND M4s14_OPC_REGION_V) INTERACT Wide_M4s14_WI_JOG_V
}
M4.S.16 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M4s14_SP_err3_REG_H AND M4s14_OPC_REGION_H) INTERACT Wide_M4s14_WI_JOG_H
  (M4s14_SP_err3_REG_V AND M4s14_OPC_REGION_V) INTERACT Wide_M4s14_WI_JOG_V
}

// Wide M4s17 space error in OPC region checking
//====================================================

Wide_M4s17 = ENCLOSE RECTANGLE (SIZE M4 BY M4_S_17_W1B/2 UNDEROVER) M4_S_17_W1B+GRID M4_S_17_L1B+GRID ORTHOGONAL ONLY
M4s17_CHECK_REGION = M4 AND (SIZE Wide_M4s17 BY M4_S_17_S1B + GRID)
M4s17_OPC_REGION_pre1 = EXT [Wide_M4s17] M4s17_CHECK_REGION < M4_S_17_S1B OPPOSITE MEASURE ALL
M4s17_OPC_REGION_pre1_H = ANGLE M4s17_OPC_REGION_pre1 == 0
M4s17_OPC_REGION_pre1_V = ANGLE M4s17_OPC_REGION_pre1 == 90
M4s17_OPC_REGION_pre0_V = INT M4s17_OPC_REGION_pre1_H [Wide_M4s17] < GRID ABUT == 90 INTERSECTING ONLY 
M4s17_OPC_REGION_pre3_V = EXT M4s17_OPC_REGION_pre1_H [Wide_M4s17] < GRID ABUT == 90 INTERSECTING ONLY 
M4s17_OPC_REGION_pre4_V = (M4s17_CHECK_REGION TOUCH INSIDE EDGE M4s17_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M4s17_OPC_REGION_pre3_V
M4s17_OPC_REGION_pre0_H = INT M4s17_OPC_REGION_pre1_V [Wide_M4s17] < GRID ABUT == 90 INTERSECTING ONLY 
M4s17_OPC_REGION_pre3_H = EXT M4s17_OPC_REGION_pre1_V [Wide_M4s17] < GRID ABUT == 90 INTERSECTING ONLY 
M4s17_OPC_REGION_pre4_H = (M4s17_CHECK_REGION TOUCH INSIDE EDGE M4s17_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M4s17_OPC_REGION_pre3_H
M4s17_OPC_REGION_pre5_H = (EXPAND EDGE M4s17_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M4s17_OPC_REGION_pre4_V BY GRID)
M4s17_OPC_REGION_pre5_V = (EXPAND EDGE M4s17_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M4s17_OPC_REGION_pre4_H BY GRID)
M4s17_OPC_REGION_pre6_H = DFM PROPERTY M4s17_OPC_REGION_pre5_H M4s17_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M4s17_OPC_REGION_pre1_H)] > M4_S_17_L1B
M4s17_OPC_REGION_pre6_V = DFM PROPERTY M4s17_OPC_REGION_pre5_V M4s17_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M4s17_OPC_REGION_pre1_V)] > M4_S_17_L1B
M4s17_OPC_REGION_pre7_H = M4s17_OPC_REGION_pre1_H INSIDE EDGE M4s17_OPC_REGION_pre6_H
M4s17_OPC_REGION_pre7_V = M4s17_OPC_REGION_pre1_V INSIDE EDGE M4s17_OPC_REGION_pre6_V
M4s17_OPC_REGION_pre2_H = EXT M4s17_OPC_REGION_pre7_H M4s17_CHECK_REGION < M4_S_17_S1B OPPOSITE REGION MEASURE ALL
M4s17_OPC_REGION_pre2_V = EXT M4s17_OPC_REGION_pre7_V M4s17_CHECK_REGION < M4_S_17_S1B OPPOSITE REGION MEASURE ALL

M4s17_M4_H = M4 INTERACT M4s17_OPC_REGION_pre2_H
M4s17_M4_V = M4 INTERACT M4s17_OPC_REGION_pre2_V
M4s17_M4_ALL = M4s17_M4_H OR M4s17_M4_V
M4s17_OPC_EDGE_H = ANGLE (M4s17_M4_H NOT OUTSIDE EDGE M4s17_OPC_REGION_pre2_H) == 0
M4s17_OPC_EDGE_V = ANGLE (M4s17_M4_V NOT OUTSIDE EDGE M4s17_OPC_REGION_pre2_V) == 90

Wide_M4s17_H = Wide_M4s17 INTERACT M4s17_OPC_REGION_pre2_H
Wide_M4s17_V = Wide_M4s17 INTERACT M4s17_OPC_REGION_pre2_V
Wide_M4s17_WI_JOG_H = (M4 AND (Wide_M4s17_H OR M4s17_OPC_REGION_pre2_H)) INTERACT Wide_M4s17_H
Wide_M4s17_WI_JOG_V = (M4 AND (Wide_M4s17_V OR M4s17_OPC_REGION_pre2_V)) INTERACT Wide_M4s17_V

Wide_M4s17_WI_EXT_EDGE_H = M4s17_OPC_EDGE_H NOT COIN EDGE (INT [M4s17_OPC_EDGE_H] M4s17_M4_H <= M4_S_17_W1B OPPOSITE)
Wide_M4s17_WI_EXT_EDGE_V = M4s17_OPC_EDGE_V NOT COIN EDGE (INT [M4s17_OPC_EDGE_V] M4s17_M4_V <= M4_S_17_W1B OPPOSITE)

M4s17_OPC_REGION_H = (EXT Wide_M4s17_WI_JOG_H M4s17_OPC_EDGE_H < M4_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s17_OPC_REGION_pre2_H
M4s17_OPC_REGION_V = (EXT Wide_M4s17_WI_JOG_V M4s17_OPC_EDGE_V < M4_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s17_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M4s17_SP_err1_REG_H = (EXT Wide_M4s17_WI_EXT_EDGE_H M4s17_M4_H < M4_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s17_OPC_REGION_H
M4s17_SP_err1_REG_V = (EXT Wide_M4s17_WI_EXT_EDGE_V M4s17_M4_V < M4_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s17_OPC_REGION_V
M4s17_EDGE_H_err3 = ANGLE M4s17_SP_err1_REG_H == 0
M4s17_EDGE_V_err3 = ANGLE M4s17_SP_err1_REG_V == 90
M4s17_SP_err1_REG_H_eff = DFM PROPERTY M4s17_SP_err1_REG_H M4s17_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M4s17_EDGE_H_err3)] <= 2*M4_S_17_L2A
M4s17_SP_err1_REG_V_eff = DFM PROPERTY M4s17_SP_err1_REG_V M4s17_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M4s17_EDGE_V_err3)] <= 2*M4_S_17_L2A

  M4s17_R1_CHK = EXT Wide_M4s17 M4s17_M4_ALL < M4_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M4s17_NOTCH_EDGE_H = ANGLE (EXT [Wide_M4s17_WI_JOG_H] < M4_S_17_S1B OPPOSITE NOTCH) == 0
  M4s17_NOTCH_EDGE_V = ANGLE (EXT [Wide_M4s17_WI_JOG_V] < M4_S_17_S1B OPPOSITE NOTCH) == 90
  M4s17_NOTCH_REGION_H = (EXT M4s17_NOTCH_EDGE_H < M4_S_17_S1B OPPOSITE REGION) AND M4s17_OPC_REGION_H
  M4s17_NOTCH_REGION_V = (EXT M4s17_NOTCH_EDGE_V < M4_S_17_S1B OPPOSITE REGION) AND M4s17_OPC_REGION_V
  
// Check NON-Notch region
  M4s17_SP_err1_REG_H_eff5 = M4s17_SP_err1_REG_H_eff NOT M4s17_NOTCH_REGION_H
  M4s17_SP_err1_REG_V_eff5 = M4s17_SP_err1_REG_V_eff NOT M4s17_NOTCH_REGION_V
  CONNECT M4s17_SP_err1_REG_H_eff5 (M4s17_OPC_REGION_H NOT M4s17_NOTCH_REGION_H)
  CONNECT M4s17_SP_err1_REG_V_eff5 (M4s17_OPC_REGION_V NOT M4s17_NOTCH_REGION_V)
  M4s17_SP_err1_REG_H_eff5a = M4s17_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M4s17_CHECK_REGION
  M4s17_SP_err1_REG_V_eff5a = M4s17_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M4s17_CHECK_REGION
  M4s17_S3C_NNH_H = (EXT M4s17_SP_err1_REG_H_eff5a < M4_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M4
  M4s17_S3C_NNH_V = (EXT M4s17_SP_err1_REG_V_eff5a < M4_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M4
  
// Check Notch H region
  M4s17_SP_err1_REG_H_eff6 = M4s17_SP_err1_REG_H_eff INSIDE M4s17_NOTCH_REGION_H
  M4s17_SP_err1_REG_V_eff6 = M4s17_SP_err1_REG_V_eff INSIDE M4s17_NOTCH_REGION_V
  CONNECT M4s17_SP_err1_REG_H_eff6 M4s17_NOTCH_REGION_H
  CONNECT M4s17_SP_err1_REG_V_eff6 M4s17_NOTCH_REGION_V  
  M4s17_SP_err1_REG_H_eff6a = M4s17_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M4s17_CHECK_REGION
  M4s17_SP_err1_REG_V_eff6a = M4s17_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M4s17_CHECK_REGION
  M4s17_S3C_NH_H = (EXT M4s17_SP_err1_REG_H_eff6a < M4_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M4
  M4s17_S3C_NH_V = (EXT M4s17_SP_err1_REG_V_eff6a < M4_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M4

// Find Space error region(large space S2A2) //
M4s17_SP_err2_REG_H = (EXT Wide_M4s17_WI_EXT_EDGE_H M4s17_OPC_EDGE_H < M4_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s17_OPC_REGION_H
M4s17_SP_err2_REG_V = (EXT Wide_M4s17_WI_EXT_EDGE_V M4s17_OPC_EDGE_V < M4_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s17_OPC_REGION_V
M4s17_EDGE_H_err2 = M4s17_SP_err2_REG_H COIN EDGE M4s17_OPC_EDGE_H
M4s17_EDGE_V_err2 = M4s17_SP_err2_REG_V COIN EDGE M4s17_OPC_EDGE_V

M4s17_SP_err2_REG_H_eff1 = DFM PROPERTY M4s17_SP_err2_REG_H M4s17_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M4s17_EDGE_H_err2)] > 2*M4_S_17_L2A
M4s17_SP_err2_REG_V_eff1 = DFM PROPERTY M4s17_SP_err2_REG_V M4s17_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M4s17_EDGE_V_err2)] > 2*M4_S_17_L2A

// Find Space error region(small space S2A3) //
M4s17_SP_err3_REG_H = (EXT Wide_M4s17_WI_EXT_EDGE_H M4s17_OPC_EDGE_H < M4_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s17_OPC_REGION_H
M4s17_SP_err3_REG_V = (EXT Wide_M4s17_WI_EXT_EDGE_V M4s17_OPC_EDGE_V < M4_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s17_OPC_REGION_V


M4.S.17 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.47 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.13 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.47 um (W1B) and the parallel run length > 0.5 um (L1B) in metal space < 0.32 um (S1B) region >= 0.3 
  ((M4s17_SP_err1_REG_H_eff INTERACT M4s17_S3C_NNH_H) OR M4s17_S3C_NNH_H) INTERACT M4s17_R1_CHK
  ((M4s17_SP_err1_REG_H_eff INTERACT M4s17_S3C_NH_H) OR M4s17_S3C_NH_H) INTERACT M4s17_R1_CHK
  ((M4s17_SP_err1_REG_V_eff INTERACT M4s17_S3C_NNH_V) OR M4s17_S3C_NNH_V) INTERACT M4s17_R1_CHK
  ((M4s17_SP_err1_REG_V_eff INTERACT M4s17_S3C_NH_V) OR M4s17_S3C_NH_V) INTERACT M4s17_R1_CHK
}
M4.S.18 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.13 
  (M4s17_SP_err2_REG_H_eff1 AND M4s17_OPC_REGION_H) INTERACT Wide_M4s17_WI_JOG_H
  (M4s17_SP_err2_REG_V_eff1 AND M4s17_OPC_REGION_V) INTERACT Wide_M4s17_WI_JOG_V
}
M4.S.19 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M4s17_SP_err3_REG_H AND M4s17_OPC_REGION_H) INTERACT Wide_M4s17_WI_JOG_H
  (M4s17_SP_err3_REG_V AND M4s17_OPC_REGION_V) INTERACT Wide_M4s17_WI_JOG_V
}

// Wide M4s20 space error in OPC region checking
//====================================================

Wide_M4s20 = ENCLOSE RECTANGLE (SIZE M4 BY M4_S_20_W1B/2 UNDEROVER) M4_S_20_W1B+GRID M4_S_20_L1B+GRID ORTHOGONAL ONLY
M4s20_CHECK_REGION = M4 AND (SIZE Wide_M4s20 BY M4_S_20_S1B + GRID)
M4s20_OPC_REGION_pre1 = EXT [Wide_M4s20] M4s20_CHECK_REGION < M4_S_20_S1B OPPOSITE MEASURE ALL
M4s20_OPC_REGION_pre1_H = ANGLE M4s20_OPC_REGION_pre1 == 0
M4s20_OPC_REGION_pre1_V = ANGLE M4s20_OPC_REGION_pre1 == 90
M4s20_OPC_REGION_pre0_V = INT M4s20_OPC_REGION_pre1_H [Wide_M4s20] < GRID ABUT == 90 INTERSECTING ONLY 
M4s20_OPC_REGION_pre3_V = EXT M4s20_OPC_REGION_pre1_H [Wide_M4s20] < GRID ABUT == 90 INTERSECTING ONLY 
M4s20_OPC_REGION_pre4_V = (M4s20_CHECK_REGION TOUCH INSIDE EDGE M4s20_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M4s20_OPC_REGION_pre3_V
M4s20_OPC_REGION_pre0_H = INT M4s20_OPC_REGION_pre1_V [Wide_M4s20] < GRID ABUT == 90 INTERSECTING ONLY 
M4s20_OPC_REGION_pre3_H = EXT M4s20_OPC_REGION_pre1_V [Wide_M4s20] < GRID ABUT == 90 INTERSECTING ONLY 
M4s20_OPC_REGION_pre4_H = (M4s20_CHECK_REGION TOUCH INSIDE EDGE M4s20_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M4s20_OPC_REGION_pre3_H
M4s20_OPC_REGION_pre5_H = (EXPAND EDGE M4s20_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M4s20_OPC_REGION_pre4_V BY GRID)
M4s20_OPC_REGION_pre5_V = (EXPAND EDGE M4s20_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M4s20_OPC_REGION_pre4_H BY GRID)
M4s20_OPC_REGION_pre6_H = DFM PROPERTY M4s20_OPC_REGION_pre5_H M4s20_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M4s20_OPC_REGION_pre1_H)] > M4_S_20_L1B
M4s20_OPC_REGION_pre6_V = DFM PROPERTY M4s20_OPC_REGION_pre5_V M4s20_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M4s20_OPC_REGION_pre1_V)] > M4_S_20_L1B
M4s20_OPC_REGION_pre7_H = M4s20_OPC_REGION_pre1_H INSIDE EDGE M4s20_OPC_REGION_pre6_H
M4s20_OPC_REGION_pre7_V = M4s20_OPC_REGION_pre1_V INSIDE EDGE M4s20_OPC_REGION_pre6_V
M4s20_OPC_REGION_pre2_H = EXT M4s20_OPC_REGION_pre7_H M4s20_CHECK_REGION < M4_S_20_S1B OPPOSITE REGION MEASURE ALL
M4s20_OPC_REGION_pre2_V = EXT M4s20_OPC_REGION_pre7_V M4s20_CHECK_REGION < M4_S_20_S1B OPPOSITE REGION MEASURE ALL

M4s20_M4_H = M4 INTERACT M4s20_OPC_REGION_pre2_H
M4s20_M4_V = M4 INTERACT M4s20_OPC_REGION_pre2_V
M4s20_M4_ALL = M4s20_M4_H OR M4s20_M4_V
M4s20_OPC_EDGE_H = ANGLE (M4s20_M4_H NOT OUTSIDE EDGE M4s20_OPC_REGION_pre2_H) == 0
M4s20_OPC_EDGE_V = ANGLE (M4s20_M4_V NOT OUTSIDE EDGE M4s20_OPC_REGION_pre2_V) == 90

Wide_M4s20_H = Wide_M4s20 INTERACT M4s20_OPC_REGION_pre2_H
Wide_M4s20_V = Wide_M4s20 INTERACT M4s20_OPC_REGION_pre2_V
Wide_M4s20_WI_JOG_H = (M4 AND (Wide_M4s20_H OR M4s20_OPC_REGION_pre2_H)) INTERACT Wide_M4s20_H
Wide_M4s20_WI_JOG_V = (M4 AND (Wide_M4s20_V OR M4s20_OPC_REGION_pre2_V)) INTERACT Wide_M4s20_V

Wide_M4s20_WI_EXT_EDGE_H = M4s20_OPC_EDGE_H NOT COIN EDGE (INT [M4s20_OPC_EDGE_H] M4s20_M4_H <= M4_S_20_W1B OPPOSITE)
Wide_M4s20_WI_EXT_EDGE_V = M4s20_OPC_EDGE_V NOT COIN EDGE (INT [M4s20_OPC_EDGE_V] M4s20_M4_V <= M4_S_20_W1B OPPOSITE)

M4s20_OPC_REGION_H = (EXT Wide_M4s20_WI_JOG_H M4s20_OPC_EDGE_H < M4_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s20_OPC_REGION_pre2_H
M4s20_OPC_REGION_V = (EXT Wide_M4s20_WI_JOG_V M4s20_OPC_EDGE_V < M4_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s20_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M4s20_SP_err1_REG_H = (EXT Wide_M4s20_WI_EXT_EDGE_H M4s20_M4_H < M4_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s20_OPC_REGION_H
M4s20_SP_err1_REG_V = (EXT Wide_M4s20_WI_EXT_EDGE_V M4s20_M4_V < M4_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s20_OPC_REGION_V
M4s20_EDGE_H_err3 = ANGLE M4s20_SP_err1_REG_H == 0
M4s20_EDGE_V_err3 = ANGLE M4s20_SP_err1_REG_V == 90
M4s20_SP_err1_REG_H_eff = DFM PROPERTY M4s20_SP_err1_REG_H M4s20_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M4s20_EDGE_H_err3)] <= 2*M4_S_20_L2A
M4s20_SP_err1_REG_V_eff = DFM PROPERTY M4s20_SP_err1_REG_V M4s20_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M4s20_EDGE_V_err3)] <= 2*M4_S_20_L2A

  M4s20_R1_CHK = EXT Wide_M4s20 M4s20_M4_ALL < M4_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M4s20_NOTCH_EDGE_H = ANGLE (EXT [Wide_M4s20_WI_JOG_H] < M4_S_20_S1B OPPOSITE NOTCH) == 0
  M4s20_NOTCH_EDGE_V = ANGLE (EXT [Wide_M4s20_WI_JOG_V] < M4_S_20_S1B OPPOSITE NOTCH) == 90
  M4s20_NOTCH_REGION_H = (EXT M4s20_NOTCH_EDGE_H < M4_S_20_S1B OPPOSITE REGION) AND M4s20_OPC_REGION_H
  M4s20_NOTCH_REGION_V = (EXT M4s20_NOTCH_EDGE_V < M4_S_20_S1B OPPOSITE REGION) AND M4s20_OPC_REGION_V
  
// Check NON-Notch region
  M4s20_SP_err1_REG_H_eff5 = M4s20_SP_err1_REG_H_eff NOT M4s20_NOTCH_REGION_H
  M4s20_SP_err1_REG_V_eff5 = M4s20_SP_err1_REG_V_eff NOT M4s20_NOTCH_REGION_V
  CONNECT M4s20_SP_err1_REG_H_eff5 (M4s20_OPC_REGION_H NOT M4s20_NOTCH_REGION_H)
  CONNECT M4s20_SP_err1_REG_V_eff5 (M4s20_OPC_REGION_V NOT M4s20_NOTCH_REGION_V)
  M4s20_SP_err1_REG_H_eff5a = M4s20_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M4s20_CHECK_REGION
  M4s20_SP_err1_REG_V_eff5a = M4s20_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M4s20_CHECK_REGION
  M4s20_S3C_NNH_H = (EXT M4s20_SP_err1_REG_H_eff5a < M4_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M4
  M4s20_S3C_NNH_V = (EXT M4s20_SP_err1_REG_V_eff5a < M4_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M4
  
// Check Notch H region
  M4s20_SP_err1_REG_H_eff6 = M4s20_SP_err1_REG_H_eff INSIDE M4s20_NOTCH_REGION_H
  M4s20_SP_err1_REG_V_eff6 = M4s20_SP_err1_REG_V_eff INSIDE M4s20_NOTCH_REGION_V
  CONNECT M4s20_SP_err1_REG_H_eff6 M4s20_NOTCH_REGION_H
  CONNECT M4s20_SP_err1_REG_V_eff6 M4s20_NOTCH_REGION_V  
  M4s20_SP_err1_REG_H_eff6a = M4s20_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M4s20_CHECK_REGION
  M4s20_SP_err1_REG_V_eff6a = M4s20_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M4s20_CHECK_REGION
  M4s20_S3C_NH_H = (EXT M4s20_SP_err1_REG_H_eff6a < M4_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M4
  M4s20_S3C_NH_V = (EXT M4s20_SP_err1_REG_V_eff6a < M4_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M4

// Find Space error region(large space S2A2) //
M4s20_SP_err2_REG_H = (EXT Wide_M4s20_WI_EXT_EDGE_H M4s20_OPC_EDGE_H < M4_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s20_OPC_REGION_H
M4s20_SP_err2_REG_V = (EXT Wide_M4s20_WI_EXT_EDGE_V M4s20_OPC_EDGE_V < M4_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s20_OPC_REGION_V
M4s20_EDGE_H_err2 = M4s20_SP_err2_REG_H COIN EDGE M4s20_OPC_EDGE_H
M4s20_EDGE_V_err2 = M4s20_SP_err2_REG_V COIN EDGE M4s20_OPC_EDGE_V

M4s20_SP_err2_REG_H_eff1 = DFM PROPERTY M4s20_SP_err2_REG_H M4s20_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M4s20_EDGE_H_err2)] > 2*M4_S_20_L2A
M4s20_SP_err2_REG_V_eff1 = DFM PROPERTY M4s20_SP_err2_REG_V M4s20_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M4s20_EDGE_V_err2)] > 2*M4_S_20_L2A

// Find Space error region(small space S2A3) //
M4s20_SP_err3_REG_H = (EXT Wide_M4s20_WI_EXT_EDGE_H M4s20_OPC_EDGE_H < M4_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s20_OPC_REGION_H
M4s20_SP_err3_REG_V = (EXT Wide_M4s20_WI_EXT_EDGE_V M4s20_OPC_EDGE_V < M4_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s20_OPC_REGION_V


M4.S.20 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.63 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.15 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.63 um (W1B) and the parallel run length > 0.7 um (L1B) in metal space < 0.34 um (S1B) region >= 0.3 
  ((M4s20_SP_err1_REG_H_eff INTERACT M4s20_S3C_NNH_H) OR M4s20_S3C_NNH_H) INTERACT M4s20_R1_CHK
  ((M4s20_SP_err1_REG_H_eff INTERACT M4s20_S3C_NH_H) OR M4s20_S3C_NH_H) INTERACT M4s20_R1_CHK
  ((M4s20_SP_err1_REG_V_eff INTERACT M4s20_S3C_NNH_V) OR M4s20_S3C_NNH_V) INTERACT M4s20_R1_CHK
  ((M4s20_SP_err1_REG_V_eff INTERACT M4s20_S3C_NH_V) OR M4s20_S3C_NH_V) INTERACT M4s20_R1_CHK
}
M4.S.21 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.15 
  (M4s20_SP_err2_REG_H_eff1 AND M4s20_OPC_REGION_H) INTERACT Wide_M4s20_WI_JOG_H
  (M4s20_SP_err2_REG_V_eff1 AND M4s20_OPC_REGION_V) INTERACT Wide_M4s20_WI_JOG_V
}
M4.S.22 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M4s20_SP_err3_REG_H AND M4s20_OPC_REGION_H) INTERACT Wide_M4s20_WI_JOG_H
  (M4s20_SP_err3_REG_V AND M4s20_OPC_REGION_V) INTERACT Wide_M4s20_WI_JOG_V
}

// Wide M4s23 space error in OPC region checking
//====================================================

Wide_M4s23 = ENCLOSE RECTANGLE (SIZE M4 BY M4_S_23_W1B/2 UNDEROVER) M4_S_23_W1B+GRID M4_S_23_L1B+GRID ORTHOGONAL ONLY
M4s23_CHECK_REGION = M4 AND (SIZE Wide_M4s23 BY M4_S_23_S1B + GRID)
M4s23_OPC_REGION_pre1 = EXT [Wide_M4s23] M4s23_CHECK_REGION < M4_S_23_S1B OPPOSITE MEASURE ALL
M4s23_OPC_REGION_pre1_H = ANGLE M4s23_OPC_REGION_pre1 == 0
M4s23_OPC_REGION_pre1_V = ANGLE M4s23_OPC_REGION_pre1 == 90
M4s23_OPC_REGION_pre0_V = INT M4s23_OPC_REGION_pre1_H [Wide_M4s23] < GRID ABUT == 90 INTERSECTING ONLY 
M4s23_OPC_REGION_pre3_V = EXT M4s23_OPC_REGION_pre1_H [Wide_M4s23] < GRID ABUT == 90 INTERSECTING ONLY 
M4s23_OPC_REGION_pre4_V = (M4s23_CHECK_REGION TOUCH INSIDE EDGE M4s23_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M4s23_OPC_REGION_pre3_V
M4s23_OPC_REGION_pre0_H = INT M4s23_OPC_REGION_pre1_V [Wide_M4s23] < GRID ABUT == 90 INTERSECTING ONLY 
M4s23_OPC_REGION_pre3_H = EXT M4s23_OPC_REGION_pre1_V [Wide_M4s23] < GRID ABUT == 90 INTERSECTING ONLY 
M4s23_OPC_REGION_pre4_H = (M4s23_CHECK_REGION TOUCH INSIDE EDGE M4s23_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M4s23_OPC_REGION_pre3_H
M4s23_OPC_REGION_pre5_H = (EXPAND EDGE M4s23_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M4s23_OPC_REGION_pre4_V BY GRID)
M4s23_OPC_REGION_pre5_V = (EXPAND EDGE M4s23_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M4s23_OPC_REGION_pre4_H BY GRID)
M4s23_OPC_REGION_pre6_H = DFM PROPERTY M4s23_OPC_REGION_pre5_H M4s23_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M4s23_OPC_REGION_pre1_H)] > M4_S_23_L1B
M4s23_OPC_REGION_pre6_V = DFM PROPERTY M4s23_OPC_REGION_pre5_V M4s23_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M4s23_OPC_REGION_pre1_V)] > M4_S_23_L1B
M4s23_OPC_REGION_pre7_H = M4s23_OPC_REGION_pre1_H INSIDE EDGE M4s23_OPC_REGION_pre6_H
M4s23_OPC_REGION_pre7_V = M4s23_OPC_REGION_pre1_V INSIDE EDGE M4s23_OPC_REGION_pre6_V
M4s23_OPC_REGION_pre2_H = EXT M4s23_OPC_REGION_pre7_H M4s23_CHECK_REGION < M4_S_23_S1B OPPOSITE REGION MEASURE ALL
M4s23_OPC_REGION_pre2_V = EXT M4s23_OPC_REGION_pre7_V M4s23_CHECK_REGION < M4_S_23_S1B OPPOSITE REGION MEASURE ALL

M4s23_M4_H = M4 INTERACT M4s23_OPC_REGION_pre2_H
M4s23_M4_V = M4 INTERACT M4s23_OPC_REGION_pre2_V
M4s23_M4_ALL = M4s23_M4_H OR M4s23_M4_V
M4s23_OPC_EDGE_H = ANGLE (M4s23_M4_H NOT OUTSIDE EDGE M4s23_OPC_REGION_pre2_H) == 0
M4s23_OPC_EDGE_V = ANGLE (M4s23_M4_V NOT OUTSIDE EDGE M4s23_OPC_REGION_pre2_V) == 90

Wide_M4s23_H = Wide_M4s23 INTERACT M4s23_OPC_REGION_pre2_H
Wide_M4s23_V = Wide_M4s23 INTERACT M4s23_OPC_REGION_pre2_V
Wide_M4s23_WI_JOG_H = (M4 AND (Wide_M4s23_H OR M4s23_OPC_REGION_pre2_H)) INTERACT Wide_M4s23_H
Wide_M4s23_WI_JOG_V = (M4 AND (Wide_M4s23_V OR M4s23_OPC_REGION_pre2_V)) INTERACT Wide_M4s23_V

Wide_M4s23_WI_EXT_EDGE_H = M4s23_OPC_EDGE_H NOT COIN EDGE (INT [M4s23_OPC_EDGE_H] M4s23_M4_H <= M4_S_23_W1B OPPOSITE)
Wide_M4s23_WI_EXT_EDGE_V = M4s23_OPC_EDGE_V NOT COIN EDGE (INT [M4s23_OPC_EDGE_V] M4s23_M4_V <= M4_S_23_W1B OPPOSITE)

M4s23_OPC_REGION_H = (EXT Wide_M4s23_WI_JOG_H M4s23_OPC_EDGE_H < M4_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s23_OPC_REGION_pre2_H
M4s23_OPC_REGION_V = (EXT Wide_M4s23_WI_JOG_V M4s23_OPC_EDGE_V < M4_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s23_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M4s23_SP_err1_REG_H = (EXT Wide_M4s23_WI_EXT_EDGE_H M4s23_M4_H < M4_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s23_OPC_REGION_H
M4s23_SP_err1_REG_V = (EXT Wide_M4s23_WI_EXT_EDGE_V M4s23_M4_V < M4_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s23_OPC_REGION_V
M4s23_EDGE_H_err3 = ANGLE M4s23_SP_err1_REG_H == 0
M4s23_EDGE_V_err3 = ANGLE M4s23_SP_err1_REG_V == 90
M4s23_SP_err1_REG_H_eff = DFM PROPERTY M4s23_SP_err1_REG_H M4s23_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M4s23_EDGE_H_err3)] <= 2*M4_S_23_L2A
M4s23_SP_err1_REG_V_eff = DFM PROPERTY M4s23_SP_err1_REG_V M4s23_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M4s23_EDGE_V_err3)] <= 2*M4_S_23_L2A

  M4s23_R1_CHK = EXT Wide_M4s23 M4s23_M4_ALL < M4_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M4s23_NOTCH_EDGE_H = ANGLE (EXT [Wide_M4s23_WI_JOG_H] < M4_S_23_S1B OPPOSITE NOTCH) == 0
  M4s23_NOTCH_EDGE_V = ANGLE (EXT [Wide_M4s23_WI_JOG_V] < M4_S_23_S1B OPPOSITE NOTCH) == 90
  M4s23_NOTCH_REGION_H = (EXT M4s23_NOTCH_EDGE_H < M4_S_23_S1B OPPOSITE REGION) AND M4s23_OPC_REGION_H
  M4s23_NOTCH_REGION_V = (EXT M4s23_NOTCH_EDGE_V < M4_S_23_S1B OPPOSITE REGION) AND M4s23_OPC_REGION_V
  
// Check NON-Notch region
  M4s23_SP_err1_REG_H_eff5 = M4s23_SP_err1_REG_H_eff NOT M4s23_NOTCH_REGION_H
  M4s23_SP_err1_REG_V_eff5 = M4s23_SP_err1_REG_V_eff NOT M4s23_NOTCH_REGION_V
  CONNECT M4s23_SP_err1_REG_H_eff5 (M4s23_OPC_REGION_H NOT M4s23_NOTCH_REGION_H)
  CONNECT M4s23_SP_err1_REG_V_eff5 (M4s23_OPC_REGION_V NOT M4s23_NOTCH_REGION_V)
  M4s23_SP_err1_REG_H_eff5a = M4s23_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M4s23_CHECK_REGION
  M4s23_SP_err1_REG_V_eff5a = M4s23_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M4s23_CHECK_REGION
  M4s23_S3C_NNH_H = (EXT M4s23_SP_err1_REG_H_eff5a < M4_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M4
  M4s23_S3C_NNH_V = (EXT M4s23_SP_err1_REG_V_eff5a < M4_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M4
  
// Check Notch H region
  M4s23_SP_err1_REG_H_eff6 = M4s23_SP_err1_REG_H_eff INSIDE M4s23_NOTCH_REGION_H
  M4s23_SP_err1_REG_V_eff6 = M4s23_SP_err1_REG_V_eff INSIDE M4s23_NOTCH_REGION_V
  CONNECT M4s23_SP_err1_REG_H_eff6 M4s23_NOTCH_REGION_H
  CONNECT M4s23_SP_err1_REG_V_eff6 M4s23_NOTCH_REGION_V  
  M4s23_SP_err1_REG_H_eff6a = M4s23_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M4s23_CHECK_REGION
  M4s23_SP_err1_REG_V_eff6a = M4s23_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M4s23_CHECK_REGION
  M4s23_S3C_NH_H = (EXT M4s23_SP_err1_REG_H_eff6a < M4_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M4
  M4s23_S3C_NH_V = (EXT M4s23_SP_err1_REG_V_eff6a < M4_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M4

// Find Space error region(large space S2A2) //
M4s23_SP_err2_REG_H = (EXT Wide_M4s23_WI_EXT_EDGE_H M4s23_OPC_EDGE_H < M4_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s23_OPC_REGION_H
M4s23_SP_err2_REG_V = (EXT Wide_M4s23_WI_EXT_EDGE_V M4s23_OPC_EDGE_V < M4_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s23_OPC_REGION_V
M4s23_EDGE_H_err2 = M4s23_SP_err2_REG_H COIN EDGE M4s23_OPC_EDGE_H
M4s23_EDGE_V_err2 = M4s23_SP_err2_REG_V COIN EDGE M4s23_OPC_EDGE_V

M4s23_SP_err2_REG_H_eff1 = DFM PROPERTY M4s23_SP_err2_REG_H M4s23_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M4s23_EDGE_H_err2)] > 2*M4_S_23_L2A
M4s23_SP_err2_REG_V_eff1 = DFM PROPERTY M4s23_SP_err2_REG_V M4s23_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M4s23_EDGE_V_err2)] > 2*M4_S_23_L2A

// Find Space error region(small space S2A3) //
M4s23_SP_err3_REG_H = (EXT Wide_M4s23_WI_EXT_EDGE_H M4s23_OPC_EDGE_H < M4_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s23_OPC_REGION_H
M4s23_SP_err3_REG_V = (EXT Wide_M4s23_WI_EXT_EDGE_V M4s23_OPC_EDGE_V < M4_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s23_OPC_REGION_V


M4.S.23 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 1.5 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.3 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 1.5 um (W1B) and the parallel run length > 1.5 um (L1B) in metal space < 0.5 um (S1B) region >= 0.3 
  ((M4s23_SP_err1_REG_H_eff INTERACT M4s23_S3C_NNH_H) OR M4s23_S3C_NNH_H) INTERACT M4s23_R1_CHK
  ((M4s23_SP_err1_REG_H_eff INTERACT M4s23_S3C_NH_H) OR M4s23_S3C_NH_H) INTERACT M4s23_R1_CHK
  ((M4s23_SP_err1_REG_V_eff INTERACT M4s23_S3C_NNH_V) OR M4s23_S3C_NNH_V) INTERACT M4s23_R1_CHK
  ((M4s23_SP_err1_REG_V_eff INTERACT M4s23_S3C_NH_V) OR M4s23_S3C_NH_V) INTERACT M4s23_R1_CHK
}
M4.S.24 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.3 
  (M4s23_SP_err2_REG_H_eff1 AND M4s23_OPC_REGION_H) INTERACT Wide_M4s23_WI_JOG_H
  (M4s23_SP_err2_REG_V_eff1 AND M4s23_OPC_REGION_V) INTERACT Wide_M4s23_WI_JOG_V
}
M4.S.25 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M4s23_SP_err3_REG_H AND M4s23_OPC_REGION_H) INTERACT Wide_M4s23_WI_JOG_H
  (M4s23_SP_err3_REG_V AND M4s23_OPC_REGION_V) INTERACT Wide_M4s23_WI_JOG_V
}


// M5 WMJ JOG Rules
//=============================
// Wide M5s14 space error in OPC region checking
//====================================================

Wide_M5s14 = ENCLOSE RECTANGLE (SIZE M5 BY M5_S_14_W1B/2 UNDEROVER) M5_S_14_W1B+GRID M5_S_14_L1B+GRID ORTHOGONAL ONLY
M5s14_CHECK_REGION = M5 AND (SIZE Wide_M5s14 BY M5_S_14_S1B + GRID)
M5s14_OPC_REGION_pre1 = EXT [Wide_M5s14] M5s14_CHECK_REGION < M5_S_14_S1B OPPOSITE MEASURE ALL
M5s14_OPC_REGION_pre1_H = ANGLE M5s14_OPC_REGION_pre1 == 0
M5s14_OPC_REGION_pre1_V = ANGLE M5s14_OPC_REGION_pre1 == 90
M5s14_OPC_REGION_pre0_V = INT M5s14_OPC_REGION_pre1_H [Wide_M5s14] < GRID ABUT == 90 INTERSECTING ONLY 
M5s14_OPC_REGION_pre3_V = EXT M5s14_OPC_REGION_pre1_H [Wide_M5s14] < GRID ABUT == 90 INTERSECTING ONLY 
M5s14_OPC_REGION_pre4_V = (M5s14_CHECK_REGION TOUCH INSIDE EDGE M5s14_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M5s14_OPC_REGION_pre3_V
M5s14_OPC_REGION_pre0_H = INT M5s14_OPC_REGION_pre1_V [Wide_M5s14] < GRID ABUT == 90 INTERSECTING ONLY 
M5s14_OPC_REGION_pre3_H = EXT M5s14_OPC_REGION_pre1_V [Wide_M5s14] < GRID ABUT == 90 INTERSECTING ONLY 
M5s14_OPC_REGION_pre4_H = (M5s14_CHECK_REGION TOUCH INSIDE EDGE M5s14_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M5s14_OPC_REGION_pre3_H
M5s14_OPC_REGION_pre5_H = (EXPAND EDGE M5s14_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M5s14_OPC_REGION_pre4_V BY GRID)
M5s14_OPC_REGION_pre5_V = (EXPAND EDGE M5s14_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M5s14_OPC_REGION_pre4_H BY GRID)
M5s14_OPC_REGION_pre6_H = DFM PROPERTY M5s14_OPC_REGION_pre5_H M5s14_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M5s14_OPC_REGION_pre1_H)] > M5_S_14_L1B
M5s14_OPC_REGION_pre6_V = DFM PROPERTY M5s14_OPC_REGION_pre5_V M5s14_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M5s14_OPC_REGION_pre1_V)] > M5_S_14_L1B
M5s14_OPC_REGION_pre7_H = M5s14_OPC_REGION_pre1_H INSIDE EDGE M5s14_OPC_REGION_pre6_H
M5s14_OPC_REGION_pre7_V = M5s14_OPC_REGION_pre1_V INSIDE EDGE M5s14_OPC_REGION_pre6_V
M5s14_OPC_REGION_pre2_H = EXT M5s14_OPC_REGION_pre7_H M5s14_CHECK_REGION < M5_S_14_S1B OPPOSITE REGION MEASURE ALL
M5s14_OPC_REGION_pre2_V = EXT M5s14_OPC_REGION_pre7_V M5s14_CHECK_REGION < M5_S_14_S1B OPPOSITE REGION MEASURE ALL

M5s14_M5_H = M5 INTERACT M5s14_OPC_REGION_pre2_H
M5s14_M5_V = M5 INTERACT M5s14_OPC_REGION_pre2_V
M5s14_M5_ALL = M5s14_M5_H OR M5s14_M5_V
M5s14_OPC_EDGE_H = ANGLE (M5s14_M5_H NOT OUTSIDE EDGE M5s14_OPC_REGION_pre2_H) == 0
M5s14_OPC_EDGE_V = ANGLE (M5s14_M5_V NOT OUTSIDE EDGE M5s14_OPC_REGION_pre2_V) == 90

Wide_M5s14_H = Wide_M5s14 INTERACT M5s14_OPC_REGION_pre2_H
Wide_M5s14_V = Wide_M5s14 INTERACT M5s14_OPC_REGION_pre2_V
Wide_M5s14_WI_JOG_H = (M5 AND (Wide_M5s14_H OR M5s14_OPC_REGION_pre2_H)) INTERACT Wide_M5s14_H
Wide_M5s14_WI_JOG_V = (M5 AND (Wide_M5s14_V OR M5s14_OPC_REGION_pre2_V)) INTERACT Wide_M5s14_V

Wide_M5s14_WI_EXT_EDGE_H = M5s14_OPC_EDGE_H NOT COIN EDGE (INT [M5s14_OPC_EDGE_H] M5s14_M5_H <= M5_S_14_W1B OPPOSITE)
Wide_M5s14_WI_EXT_EDGE_V = M5s14_OPC_EDGE_V NOT COIN EDGE (INT [M5s14_OPC_EDGE_V] M5s14_M5_V <= M5_S_14_W1B OPPOSITE)

M5s14_OPC_REGION_H = (EXT Wide_M5s14_WI_JOG_H M5s14_OPC_EDGE_H < M5_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s14_OPC_REGION_pre2_H
M5s14_OPC_REGION_V = (EXT Wide_M5s14_WI_JOG_V M5s14_OPC_EDGE_V < M5_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s14_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M5s14_SP_err1_REG_H = (EXT Wide_M5s14_WI_EXT_EDGE_H M5s14_M5_H < M5_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s14_OPC_REGION_H
M5s14_SP_err1_REG_V = (EXT Wide_M5s14_WI_EXT_EDGE_V M5s14_M5_V < M5_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s14_OPC_REGION_V
M5s14_EDGE_H_err3 = ANGLE M5s14_SP_err1_REG_H == 0
M5s14_EDGE_V_err3 = ANGLE M5s14_SP_err1_REG_V == 90
M5s14_SP_err1_REG_H_eff = DFM PROPERTY M5s14_SP_err1_REG_H M5s14_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M5s14_EDGE_H_err3)] <= 2*M5_S_14_L2A
M5s14_SP_err1_REG_V_eff = DFM PROPERTY M5s14_SP_err1_REG_V M5s14_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M5s14_EDGE_V_err3)] <= 2*M5_S_14_L2A

  M5s14_R1_CHK = EXT Wide_M5s14 M5s14_M5_ALL < M5_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M5s14_NOTCH_EDGE_H = ANGLE (EXT [Wide_M5s14_WI_JOG_H] < M5_S_14_S1B OPPOSITE NOTCH) == 0
  M5s14_NOTCH_EDGE_V = ANGLE (EXT [Wide_M5s14_WI_JOG_V] < M5_S_14_S1B OPPOSITE NOTCH) == 90
  M5s14_NOTCH_REGION_H = (EXT M5s14_NOTCH_EDGE_H < M5_S_14_S1B OPPOSITE REGION) AND M5s14_OPC_REGION_H
  M5s14_NOTCH_REGION_V = (EXT M5s14_NOTCH_EDGE_V < M5_S_14_S1B OPPOSITE REGION) AND M5s14_OPC_REGION_V
  
// Check NON-Notch region
  M5s14_SP_err1_REG_H_eff5 = M5s14_SP_err1_REG_H_eff NOT M5s14_NOTCH_REGION_H
  M5s14_SP_err1_REG_V_eff5 = M5s14_SP_err1_REG_V_eff NOT M5s14_NOTCH_REGION_V
  CONNECT M5s14_SP_err1_REG_H_eff5 (M5s14_OPC_REGION_H NOT M5s14_NOTCH_REGION_H)
  CONNECT M5s14_SP_err1_REG_V_eff5 (M5s14_OPC_REGION_V NOT M5s14_NOTCH_REGION_V)
  M5s14_SP_err1_REG_H_eff5a = M5s14_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M5s14_CHECK_REGION
  M5s14_SP_err1_REG_V_eff5a = M5s14_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M5s14_CHECK_REGION
  M5s14_S3C_NNH_H = (EXT M5s14_SP_err1_REG_H_eff5a < M5_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M5
  M5s14_S3C_NNH_V = (EXT M5s14_SP_err1_REG_V_eff5a < M5_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M5
  
// Check Notch H region
  M5s14_SP_err1_REG_H_eff6 = M5s14_SP_err1_REG_H_eff INSIDE M5s14_NOTCH_REGION_H
  M5s14_SP_err1_REG_V_eff6 = M5s14_SP_err1_REG_V_eff INSIDE M5s14_NOTCH_REGION_V
  CONNECT M5s14_SP_err1_REG_H_eff6 M5s14_NOTCH_REGION_H
  CONNECT M5s14_SP_err1_REG_V_eff6 M5s14_NOTCH_REGION_V  
  M5s14_SP_err1_REG_H_eff6a = M5s14_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M5s14_CHECK_REGION
  M5s14_SP_err1_REG_V_eff6a = M5s14_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M5s14_CHECK_REGION
  M5s14_S3C_NH_H = (EXT M5s14_SP_err1_REG_H_eff6a < M5_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M5
  M5s14_S3C_NH_V = (EXT M5s14_SP_err1_REG_V_eff6a < M5_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M5

// Find Space error region(large space S2A2) //
M5s14_SP_err2_REG_H = (EXT Wide_M5s14_WI_EXT_EDGE_H M5s14_OPC_EDGE_H < M5_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s14_OPC_REGION_H
M5s14_SP_err2_REG_V = (EXT Wide_M5s14_WI_EXT_EDGE_V M5s14_OPC_EDGE_V < M5_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s14_OPC_REGION_V
M5s14_EDGE_H_err2 = M5s14_SP_err2_REG_H COIN EDGE M5s14_OPC_EDGE_H
M5s14_EDGE_V_err2 = M5s14_SP_err2_REG_V COIN EDGE M5s14_OPC_EDGE_V

M5s14_SP_err2_REG_H_eff1 = DFM PROPERTY M5s14_SP_err2_REG_H M5s14_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M5s14_EDGE_H_err2)] > 2*M5_S_14_L2A
M5s14_SP_err2_REG_V_eff1 = DFM PROPERTY M5s14_SP_err2_REG_V M5s14_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M5s14_EDGE_V_err2)] > 2*M5_S_14_L2A

// Find Space error region(small space S2A3) //
M5s14_SP_err3_REG_H = (EXT Wide_M5s14_WI_EXT_EDGE_H M5s14_OPC_EDGE_H < M5_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s14_OPC_REGION_H
M5s14_SP_err3_REG_V = (EXT Wide_M5s14_WI_EXT_EDGE_V M5s14_OPC_EDGE_V < M5_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s14_OPC_REGION_V


M5.S.14 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.08 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.29 um (S1B) region >= 0.3 
  ((M5s14_SP_err1_REG_H_eff INTERACT M5s14_S3C_NNH_H) OR M5s14_S3C_NNH_H) INTERACT M5s14_R1_CHK
  ((M5s14_SP_err1_REG_H_eff INTERACT M5s14_S3C_NH_H) OR M5s14_S3C_NH_H) INTERACT M5s14_R1_CHK
  ((M5s14_SP_err1_REG_V_eff INTERACT M5s14_S3C_NNH_V) OR M5s14_S3C_NNH_V) INTERACT M5s14_R1_CHK
  ((M5s14_SP_err1_REG_V_eff INTERACT M5s14_S3C_NH_V) OR M5s14_S3C_NH_V) INTERACT M5s14_R1_CHK
}
M5.S.15 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.1 
  (M5s14_SP_err2_REG_H_eff1 AND M5s14_OPC_REGION_H) INTERACT Wide_M5s14_WI_JOG_H
  (M5s14_SP_err2_REG_V_eff1 AND M5s14_OPC_REGION_V) INTERACT Wide_M5s14_WI_JOG_V
}
M5.S.16 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M5s14_SP_err3_REG_H AND M5s14_OPC_REGION_H) INTERACT Wide_M5s14_WI_JOG_H
  (M5s14_SP_err3_REG_V AND M5s14_OPC_REGION_V) INTERACT Wide_M5s14_WI_JOG_V
}

// Wide M5s17 space error in OPC region checking
//====================================================

Wide_M5s17 = ENCLOSE RECTANGLE (SIZE M5 BY M5_S_17_W1B/2 UNDEROVER) M5_S_17_W1B+GRID M5_S_17_L1B+GRID ORTHOGONAL ONLY
M5s17_CHECK_REGION = M5 AND (SIZE Wide_M5s17 BY M5_S_17_S1B + GRID)
M5s17_OPC_REGION_pre1 = EXT [Wide_M5s17] M5s17_CHECK_REGION < M5_S_17_S1B OPPOSITE MEASURE ALL
M5s17_OPC_REGION_pre1_H = ANGLE M5s17_OPC_REGION_pre1 == 0
M5s17_OPC_REGION_pre1_V = ANGLE M5s17_OPC_REGION_pre1 == 90
M5s17_OPC_REGION_pre0_V = INT M5s17_OPC_REGION_pre1_H [Wide_M5s17] < GRID ABUT == 90 INTERSECTING ONLY 
M5s17_OPC_REGION_pre3_V = EXT M5s17_OPC_REGION_pre1_H [Wide_M5s17] < GRID ABUT == 90 INTERSECTING ONLY 
M5s17_OPC_REGION_pre4_V = (M5s17_CHECK_REGION TOUCH INSIDE EDGE M5s17_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M5s17_OPC_REGION_pre3_V
M5s17_OPC_REGION_pre0_H = INT M5s17_OPC_REGION_pre1_V [Wide_M5s17] < GRID ABUT == 90 INTERSECTING ONLY 
M5s17_OPC_REGION_pre3_H = EXT M5s17_OPC_REGION_pre1_V [Wide_M5s17] < GRID ABUT == 90 INTERSECTING ONLY 
M5s17_OPC_REGION_pre4_H = (M5s17_CHECK_REGION TOUCH INSIDE EDGE M5s17_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M5s17_OPC_REGION_pre3_H
M5s17_OPC_REGION_pre5_H = (EXPAND EDGE M5s17_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M5s17_OPC_REGION_pre4_V BY GRID)
M5s17_OPC_REGION_pre5_V = (EXPAND EDGE M5s17_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M5s17_OPC_REGION_pre4_H BY GRID)
M5s17_OPC_REGION_pre6_H = DFM PROPERTY M5s17_OPC_REGION_pre5_H M5s17_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M5s17_OPC_REGION_pre1_H)] > M5_S_17_L1B
M5s17_OPC_REGION_pre6_V = DFM PROPERTY M5s17_OPC_REGION_pre5_V M5s17_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M5s17_OPC_REGION_pre1_V)] > M5_S_17_L1B
M5s17_OPC_REGION_pre7_H = M5s17_OPC_REGION_pre1_H INSIDE EDGE M5s17_OPC_REGION_pre6_H
M5s17_OPC_REGION_pre7_V = M5s17_OPC_REGION_pre1_V INSIDE EDGE M5s17_OPC_REGION_pre6_V
M5s17_OPC_REGION_pre2_H = EXT M5s17_OPC_REGION_pre7_H M5s17_CHECK_REGION < M5_S_17_S1B OPPOSITE REGION MEASURE ALL
M5s17_OPC_REGION_pre2_V = EXT M5s17_OPC_REGION_pre7_V M5s17_CHECK_REGION < M5_S_17_S1B OPPOSITE REGION MEASURE ALL

M5s17_M5_H = M5 INTERACT M5s17_OPC_REGION_pre2_H
M5s17_M5_V = M5 INTERACT M5s17_OPC_REGION_pre2_V
M5s17_M5_ALL = M5s17_M5_H OR M5s17_M5_V
M5s17_OPC_EDGE_H = ANGLE (M5s17_M5_H NOT OUTSIDE EDGE M5s17_OPC_REGION_pre2_H) == 0
M5s17_OPC_EDGE_V = ANGLE (M5s17_M5_V NOT OUTSIDE EDGE M5s17_OPC_REGION_pre2_V) == 90

Wide_M5s17_H = Wide_M5s17 INTERACT M5s17_OPC_REGION_pre2_H
Wide_M5s17_V = Wide_M5s17 INTERACT M5s17_OPC_REGION_pre2_V
Wide_M5s17_WI_JOG_H = (M5 AND (Wide_M5s17_H OR M5s17_OPC_REGION_pre2_H)) INTERACT Wide_M5s17_H
Wide_M5s17_WI_JOG_V = (M5 AND (Wide_M5s17_V OR M5s17_OPC_REGION_pre2_V)) INTERACT Wide_M5s17_V

Wide_M5s17_WI_EXT_EDGE_H = M5s17_OPC_EDGE_H NOT COIN EDGE (INT [M5s17_OPC_EDGE_H] M5s17_M5_H <= M5_S_17_W1B OPPOSITE)
Wide_M5s17_WI_EXT_EDGE_V = M5s17_OPC_EDGE_V NOT COIN EDGE (INT [M5s17_OPC_EDGE_V] M5s17_M5_V <= M5_S_17_W1B OPPOSITE)

M5s17_OPC_REGION_H = (EXT Wide_M5s17_WI_JOG_H M5s17_OPC_EDGE_H < M5_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s17_OPC_REGION_pre2_H
M5s17_OPC_REGION_V = (EXT Wide_M5s17_WI_JOG_V M5s17_OPC_EDGE_V < M5_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s17_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M5s17_SP_err1_REG_H = (EXT Wide_M5s17_WI_EXT_EDGE_H M5s17_M5_H < M5_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s17_OPC_REGION_H
M5s17_SP_err1_REG_V = (EXT Wide_M5s17_WI_EXT_EDGE_V M5s17_M5_V < M5_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s17_OPC_REGION_V
M5s17_EDGE_H_err3 = ANGLE M5s17_SP_err1_REG_H == 0
M5s17_EDGE_V_err3 = ANGLE M5s17_SP_err1_REG_V == 90
M5s17_SP_err1_REG_H_eff = DFM PROPERTY M5s17_SP_err1_REG_H M5s17_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M5s17_EDGE_H_err3)] <= 2*M5_S_17_L2A
M5s17_SP_err1_REG_V_eff = DFM PROPERTY M5s17_SP_err1_REG_V M5s17_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M5s17_EDGE_V_err3)] <= 2*M5_S_17_L2A

  M5s17_R1_CHK = EXT Wide_M5s17 M5s17_M5_ALL < M5_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M5s17_NOTCH_EDGE_H = ANGLE (EXT [Wide_M5s17_WI_JOG_H] < M5_S_17_S1B OPPOSITE NOTCH) == 0
  M5s17_NOTCH_EDGE_V = ANGLE (EXT [Wide_M5s17_WI_JOG_V] < M5_S_17_S1B OPPOSITE NOTCH) == 90
  M5s17_NOTCH_REGION_H = (EXT M5s17_NOTCH_EDGE_H < M5_S_17_S1B OPPOSITE REGION) AND M5s17_OPC_REGION_H
  M5s17_NOTCH_REGION_V = (EXT M5s17_NOTCH_EDGE_V < M5_S_17_S1B OPPOSITE REGION) AND M5s17_OPC_REGION_V
  
// Check NON-Notch region
  M5s17_SP_err1_REG_H_eff5 = M5s17_SP_err1_REG_H_eff NOT M5s17_NOTCH_REGION_H
  M5s17_SP_err1_REG_V_eff5 = M5s17_SP_err1_REG_V_eff NOT M5s17_NOTCH_REGION_V
  CONNECT M5s17_SP_err1_REG_H_eff5 (M5s17_OPC_REGION_H NOT M5s17_NOTCH_REGION_H)
  CONNECT M5s17_SP_err1_REG_V_eff5 (M5s17_OPC_REGION_V NOT M5s17_NOTCH_REGION_V)
  M5s17_SP_err1_REG_H_eff5a = M5s17_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M5s17_CHECK_REGION
  M5s17_SP_err1_REG_V_eff5a = M5s17_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M5s17_CHECK_REGION
  M5s17_S3C_NNH_H = (EXT M5s17_SP_err1_REG_H_eff5a < M5_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M5
  M5s17_S3C_NNH_V = (EXT M5s17_SP_err1_REG_V_eff5a < M5_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M5
  
// Check Notch H region
  M5s17_SP_err1_REG_H_eff6 = M5s17_SP_err1_REG_H_eff INSIDE M5s17_NOTCH_REGION_H
  M5s17_SP_err1_REG_V_eff6 = M5s17_SP_err1_REG_V_eff INSIDE M5s17_NOTCH_REGION_V
  CONNECT M5s17_SP_err1_REG_H_eff6 M5s17_NOTCH_REGION_H
  CONNECT M5s17_SP_err1_REG_V_eff6 M5s17_NOTCH_REGION_V  
  M5s17_SP_err1_REG_H_eff6a = M5s17_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M5s17_CHECK_REGION
  M5s17_SP_err1_REG_V_eff6a = M5s17_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M5s17_CHECK_REGION
  M5s17_S3C_NH_H = (EXT M5s17_SP_err1_REG_H_eff6a < M5_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M5
  M5s17_S3C_NH_V = (EXT M5s17_SP_err1_REG_V_eff6a < M5_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M5

// Find Space error region(large space S2A2) //
M5s17_SP_err2_REG_H = (EXT Wide_M5s17_WI_EXT_EDGE_H M5s17_OPC_EDGE_H < M5_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s17_OPC_REGION_H
M5s17_SP_err2_REG_V = (EXT Wide_M5s17_WI_EXT_EDGE_V M5s17_OPC_EDGE_V < M5_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s17_OPC_REGION_V
M5s17_EDGE_H_err2 = M5s17_SP_err2_REG_H COIN EDGE M5s17_OPC_EDGE_H
M5s17_EDGE_V_err2 = M5s17_SP_err2_REG_V COIN EDGE M5s17_OPC_EDGE_V

M5s17_SP_err2_REG_H_eff1 = DFM PROPERTY M5s17_SP_err2_REG_H M5s17_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M5s17_EDGE_H_err2)] > 2*M5_S_17_L2A
M5s17_SP_err2_REG_V_eff1 = DFM PROPERTY M5s17_SP_err2_REG_V M5s17_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M5s17_EDGE_V_err2)] > 2*M5_S_17_L2A

// Find Space error region(small space S2A3) //
M5s17_SP_err3_REG_H = (EXT Wide_M5s17_WI_EXT_EDGE_H M5s17_OPC_EDGE_H < M5_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s17_OPC_REGION_H
M5s17_SP_err3_REG_V = (EXT Wide_M5s17_WI_EXT_EDGE_V M5s17_OPC_EDGE_V < M5_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s17_OPC_REGION_V


M5.S.17 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.47 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.13 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.47 um (W1B) and the parallel run length > 0.5 um (L1B) in metal space < 0.32 um (S1B) region >= 0.3 
  ((M5s17_SP_err1_REG_H_eff INTERACT M5s17_S3C_NNH_H) OR M5s17_S3C_NNH_H) INTERACT M5s17_R1_CHK
  ((M5s17_SP_err1_REG_H_eff INTERACT M5s17_S3C_NH_H) OR M5s17_S3C_NH_H) INTERACT M5s17_R1_CHK
  ((M5s17_SP_err1_REG_V_eff INTERACT M5s17_S3C_NNH_V) OR M5s17_S3C_NNH_V) INTERACT M5s17_R1_CHK
  ((M5s17_SP_err1_REG_V_eff INTERACT M5s17_S3C_NH_V) OR M5s17_S3C_NH_V) INTERACT M5s17_R1_CHK
}
M5.S.18 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.13 
  (M5s17_SP_err2_REG_H_eff1 AND M5s17_OPC_REGION_H) INTERACT Wide_M5s17_WI_JOG_H
  (M5s17_SP_err2_REG_V_eff1 AND M5s17_OPC_REGION_V) INTERACT Wide_M5s17_WI_JOG_V
}
M5.S.19 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M5s17_SP_err3_REG_H AND M5s17_OPC_REGION_H) INTERACT Wide_M5s17_WI_JOG_H
  (M5s17_SP_err3_REG_V AND M5s17_OPC_REGION_V) INTERACT Wide_M5s17_WI_JOG_V
}

// Wide M5s20 space error in OPC region checking
//====================================================

Wide_M5s20 = ENCLOSE RECTANGLE (SIZE M5 BY M5_S_20_W1B/2 UNDEROVER) M5_S_20_W1B+GRID M5_S_20_L1B+GRID ORTHOGONAL ONLY
M5s20_CHECK_REGION = M5 AND (SIZE Wide_M5s20 BY M5_S_20_S1B + GRID)
M5s20_OPC_REGION_pre1 = EXT [Wide_M5s20] M5s20_CHECK_REGION < M5_S_20_S1B OPPOSITE MEASURE ALL
M5s20_OPC_REGION_pre1_H = ANGLE M5s20_OPC_REGION_pre1 == 0
M5s20_OPC_REGION_pre1_V = ANGLE M5s20_OPC_REGION_pre1 == 90
M5s20_OPC_REGION_pre0_V = INT M5s20_OPC_REGION_pre1_H [Wide_M5s20] < GRID ABUT == 90 INTERSECTING ONLY 
M5s20_OPC_REGION_pre3_V = EXT M5s20_OPC_REGION_pre1_H [Wide_M5s20] < GRID ABUT == 90 INTERSECTING ONLY 
M5s20_OPC_REGION_pre4_V = (M5s20_CHECK_REGION TOUCH INSIDE EDGE M5s20_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M5s20_OPC_REGION_pre3_V
M5s20_OPC_REGION_pre0_H = INT M5s20_OPC_REGION_pre1_V [Wide_M5s20] < GRID ABUT == 90 INTERSECTING ONLY 
M5s20_OPC_REGION_pre3_H = EXT M5s20_OPC_REGION_pre1_V [Wide_M5s20] < GRID ABUT == 90 INTERSECTING ONLY 
M5s20_OPC_REGION_pre4_H = (M5s20_CHECK_REGION TOUCH INSIDE EDGE M5s20_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M5s20_OPC_REGION_pre3_H
M5s20_OPC_REGION_pre5_H = (EXPAND EDGE M5s20_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M5s20_OPC_REGION_pre4_V BY GRID)
M5s20_OPC_REGION_pre5_V = (EXPAND EDGE M5s20_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M5s20_OPC_REGION_pre4_H BY GRID)
M5s20_OPC_REGION_pre6_H = DFM PROPERTY M5s20_OPC_REGION_pre5_H M5s20_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M5s20_OPC_REGION_pre1_H)] > M5_S_20_L1B
M5s20_OPC_REGION_pre6_V = DFM PROPERTY M5s20_OPC_REGION_pre5_V M5s20_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M5s20_OPC_REGION_pre1_V)] > M5_S_20_L1B
M5s20_OPC_REGION_pre7_H = M5s20_OPC_REGION_pre1_H INSIDE EDGE M5s20_OPC_REGION_pre6_H
M5s20_OPC_REGION_pre7_V = M5s20_OPC_REGION_pre1_V INSIDE EDGE M5s20_OPC_REGION_pre6_V
M5s20_OPC_REGION_pre2_H = EXT M5s20_OPC_REGION_pre7_H M5s20_CHECK_REGION < M5_S_20_S1B OPPOSITE REGION MEASURE ALL
M5s20_OPC_REGION_pre2_V = EXT M5s20_OPC_REGION_pre7_V M5s20_CHECK_REGION < M5_S_20_S1B OPPOSITE REGION MEASURE ALL

M5s20_M5_H = M5 INTERACT M5s20_OPC_REGION_pre2_H
M5s20_M5_V = M5 INTERACT M5s20_OPC_REGION_pre2_V
M5s20_M5_ALL = M5s20_M5_H OR M5s20_M5_V
M5s20_OPC_EDGE_H = ANGLE (M5s20_M5_H NOT OUTSIDE EDGE M5s20_OPC_REGION_pre2_H) == 0
M5s20_OPC_EDGE_V = ANGLE (M5s20_M5_V NOT OUTSIDE EDGE M5s20_OPC_REGION_pre2_V) == 90

Wide_M5s20_H = Wide_M5s20 INTERACT M5s20_OPC_REGION_pre2_H
Wide_M5s20_V = Wide_M5s20 INTERACT M5s20_OPC_REGION_pre2_V
Wide_M5s20_WI_JOG_H = (M5 AND (Wide_M5s20_H OR M5s20_OPC_REGION_pre2_H)) INTERACT Wide_M5s20_H
Wide_M5s20_WI_JOG_V = (M5 AND (Wide_M5s20_V OR M5s20_OPC_REGION_pre2_V)) INTERACT Wide_M5s20_V

Wide_M5s20_WI_EXT_EDGE_H = M5s20_OPC_EDGE_H NOT COIN EDGE (INT [M5s20_OPC_EDGE_H] M5s20_M5_H <= M5_S_20_W1B OPPOSITE)
Wide_M5s20_WI_EXT_EDGE_V = M5s20_OPC_EDGE_V NOT COIN EDGE (INT [M5s20_OPC_EDGE_V] M5s20_M5_V <= M5_S_20_W1B OPPOSITE)

M5s20_OPC_REGION_H = (EXT Wide_M5s20_WI_JOG_H M5s20_OPC_EDGE_H < M5_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s20_OPC_REGION_pre2_H
M5s20_OPC_REGION_V = (EXT Wide_M5s20_WI_JOG_V M5s20_OPC_EDGE_V < M5_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s20_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M5s20_SP_err1_REG_H = (EXT Wide_M5s20_WI_EXT_EDGE_H M5s20_M5_H < M5_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s20_OPC_REGION_H
M5s20_SP_err1_REG_V = (EXT Wide_M5s20_WI_EXT_EDGE_V M5s20_M5_V < M5_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s20_OPC_REGION_V
M5s20_EDGE_H_err3 = ANGLE M5s20_SP_err1_REG_H == 0
M5s20_EDGE_V_err3 = ANGLE M5s20_SP_err1_REG_V == 90
M5s20_SP_err1_REG_H_eff = DFM PROPERTY M5s20_SP_err1_REG_H M5s20_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M5s20_EDGE_H_err3)] <= 2*M5_S_20_L2A
M5s20_SP_err1_REG_V_eff = DFM PROPERTY M5s20_SP_err1_REG_V M5s20_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M5s20_EDGE_V_err3)] <= 2*M5_S_20_L2A

  M5s20_R1_CHK = EXT Wide_M5s20 M5s20_M5_ALL < M5_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M5s20_NOTCH_EDGE_H = ANGLE (EXT [Wide_M5s20_WI_JOG_H] < M5_S_20_S1B OPPOSITE NOTCH) == 0
  M5s20_NOTCH_EDGE_V = ANGLE (EXT [Wide_M5s20_WI_JOG_V] < M5_S_20_S1B OPPOSITE NOTCH) == 90
  M5s20_NOTCH_REGION_H = (EXT M5s20_NOTCH_EDGE_H < M5_S_20_S1B OPPOSITE REGION) AND M5s20_OPC_REGION_H
  M5s20_NOTCH_REGION_V = (EXT M5s20_NOTCH_EDGE_V < M5_S_20_S1B OPPOSITE REGION) AND M5s20_OPC_REGION_V
  
// Check NON-Notch region
  M5s20_SP_err1_REG_H_eff5 = M5s20_SP_err1_REG_H_eff NOT M5s20_NOTCH_REGION_H
  M5s20_SP_err1_REG_V_eff5 = M5s20_SP_err1_REG_V_eff NOT M5s20_NOTCH_REGION_V
  CONNECT M5s20_SP_err1_REG_H_eff5 (M5s20_OPC_REGION_H NOT M5s20_NOTCH_REGION_H)
  CONNECT M5s20_SP_err1_REG_V_eff5 (M5s20_OPC_REGION_V NOT M5s20_NOTCH_REGION_V)
  M5s20_SP_err1_REG_H_eff5a = M5s20_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M5s20_CHECK_REGION
  M5s20_SP_err1_REG_V_eff5a = M5s20_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M5s20_CHECK_REGION
  M5s20_S3C_NNH_H = (EXT M5s20_SP_err1_REG_H_eff5a < M5_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M5
  M5s20_S3C_NNH_V = (EXT M5s20_SP_err1_REG_V_eff5a < M5_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M5
  
// Check Notch H region
  M5s20_SP_err1_REG_H_eff6 = M5s20_SP_err1_REG_H_eff INSIDE M5s20_NOTCH_REGION_H
  M5s20_SP_err1_REG_V_eff6 = M5s20_SP_err1_REG_V_eff INSIDE M5s20_NOTCH_REGION_V
  CONNECT M5s20_SP_err1_REG_H_eff6 M5s20_NOTCH_REGION_H
  CONNECT M5s20_SP_err1_REG_V_eff6 M5s20_NOTCH_REGION_V  
  M5s20_SP_err1_REG_H_eff6a = M5s20_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M5s20_CHECK_REGION
  M5s20_SP_err1_REG_V_eff6a = M5s20_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M5s20_CHECK_REGION
  M5s20_S3C_NH_H = (EXT M5s20_SP_err1_REG_H_eff6a < M5_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M5
  M5s20_S3C_NH_V = (EXT M5s20_SP_err1_REG_V_eff6a < M5_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M5

// Find Space error region(large space S2A2) //
M5s20_SP_err2_REG_H = (EXT Wide_M5s20_WI_EXT_EDGE_H M5s20_OPC_EDGE_H < M5_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s20_OPC_REGION_H
M5s20_SP_err2_REG_V = (EXT Wide_M5s20_WI_EXT_EDGE_V M5s20_OPC_EDGE_V < M5_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s20_OPC_REGION_V
M5s20_EDGE_H_err2 = M5s20_SP_err2_REG_H COIN EDGE M5s20_OPC_EDGE_H
M5s20_EDGE_V_err2 = M5s20_SP_err2_REG_V COIN EDGE M5s20_OPC_EDGE_V

M5s20_SP_err2_REG_H_eff1 = DFM PROPERTY M5s20_SP_err2_REG_H M5s20_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M5s20_EDGE_H_err2)] > 2*M5_S_20_L2A
M5s20_SP_err2_REG_V_eff1 = DFM PROPERTY M5s20_SP_err2_REG_V M5s20_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M5s20_EDGE_V_err2)] > 2*M5_S_20_L2A

// Find Space error region(small space S2A3) //
M5s20_SP_err3_REG_H = (EXT Wide_M5s20_WI_EXT_EDGE_H M5s20_OPC_EDGE_H < M5_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s20_OPC_REGION_H
M5s20_SP_err3_REG_V = (EXT Wide_M5s20_WI_EXT_EDGE_V M5s20_OPC_EDGE_V < M5_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s20_OPC_REGION_V


M5.S.20 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.63 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.15 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.63 um (W1B) and the parallel run length > 0.7 um (L1B) in metal space < 0.34 um (S1B) region >= 0.3 
  ((M5s20_SP_err1_REG_H_eff INTERACT M5s20_S3C_NNH_H) OR M5s20_S3C_NNH_H) INTERACT M5s20_R1_CHK
  ((M5s20_SP_err1_REG_H_eff INTERACT M5s20_S3C_NH_H) OR M5s20_S3C_NH_H) INTERACT M5s20_R1_CHK
  ((M5s20_SP_err1_REG_V_eff INTERACT M5s20_S3C_NNH_V) OR M5s20_S3C_NNH_V) INTERACT M5s20_R1_CHK
  ((M5s20_SP_err1_REG_V_eff INTERACT M5s20_S3C_NH_V) OR M5s20_S3C_NH_V) INTERACT M5s20_R1_CHK
}
M5.S.21 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.15 
  (M5s20_SP_err2_REG_H_eff1 AND M5s20_OPC_REGION_H) INTERACT Wide_M5s20_WI_JOG_H
  (M5s20_SP_err2_REG_V_eff1 AND M5s20_OPC_REGION_V) INTERACT Wide_M5s20_WI_JOG_V
}
M5.S.22 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M5s20_SP_err3_REG_H AND M5s20_OPC_REGION_H) INTERACT Wide_M5s20_WI_JOG_H
  (M5s20_SP_err3_REG_V AND M5s20_OPC_REGION_V) INTERACT Wide_M5s20_WI_JOG_V
}

// Wide M5s23 space error in OPC region checking
//====================================================

Wide_M5s23 = ENCLOSE RECTANGLE (SIZE M5 BY M5_S_23_W1B/2 UNDEROVER) M5_S_23_W1B+GRID M5_S_23_L1B+GRID ORTHOGONAL ONLY
M5s23_CHECK_REGION = M5 AND (SIZE Wide_M5s23 BY M5_S_23_S1B + GRID)
M5s23_OPC_REGION_pre1 = EXT [Wide_M5s23] M5s23_CHECK_REGION < M5_S_23_S1B OPPOSITE MEASURE ALL
M5s23_OPC_REGION_pre1_H = ANGLE M5s23_OPC_REGION_pre1 == 0
M5s23_OPC_REGION_pre1_V = ANGLE M5s23_OPC_REGION_pre1 == 90
M5s23_OPC_REGION_pre0_V = INT M5s23_OPC_REGION_pre1_H [Wide_M5s23] < GRID ABUT == 90 INTERSECTING ONLY 
M5s23_OPC_REGION_pre3_V = EXT M5s23_OPC_REGION_pre1_H [Wide_M5s23] < GRID ABUT == 90 INTERSECTING ONLY 
M5s23_OPC_REGION_pre4_V = (M5s23_CHECK_REGION TOUCH INSIDE EDGE M5s23_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M5s23_OPC_REGION_pre3_V
M5s23_OPC_REGION_pre0_H = INT M5s23_OPC_REGION_pre1_V [Wide_M5s23] < GRID ABUT == 90 INTERSECTING ONLY 
M5s23_OPC_REGION_pre3_H = EXT M5s23_OPC_REGION_pre1_V [Wide_M5s23] < GRID ABUT == 90 INTERSECTING ONLY 
M5s23_OPC_REGION_pre4_H = (M5s23_CHECK_REGION TOUCH INSIDE EDGE M5s23_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M5s23_OPC_REGION_pre3_H
M5s23_OPC_REGION_pre5_H = (EXPAND EDGE M5s23_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M5s23_OPC_REGION_pre4_V BY GRID)
M5s23_OPC_REGION_pre5_V = (EXPAND EDGE M5s23_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M5s23_OPC_REGION_pre4_H BY GRID)
M5s23_OPC_REGION_pre6_H = DFM PROPERTY M5s23_OPC_REGION_pre5_H M5s23_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M5s23_OPC_REGION_pre1_H)] > M5_S_23_L1B
M5s23_OPC_REGION_pre6_V = DFM PROPERTY M5s23_OPC_REGION_pre5_V M5s23_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M5s23_OPC_REGION_pre1_V)] > M5_S_23_L1B
M5s23_OPC_REGION_pre7_H = M5s23_OPC_REGION_pre1_H INSIDE EDGE M5s23_OPC_REGION_pre6_H
M5s23_OPC_REGION_pre7_V = M5s23_OPC_REGION_pre1_V INSIDE EDGE M5s23_OPC_REGION_pre6_V
M5s23_OPC_REGION_pre2_H = EXT M5s23_OPC_REGION_pre7_H M5s23_CHECK_REGION < M5_S_23_S1B OPPOSITE REGION MEASURE ALL
M5s23_OPC_REGION_pre2_V = EXT M5s23_OPC_REGION_pre7_V M5s23_CHECK_REGION < M5_S_23_S1B OPPOSITE REGION MEASURE ALL

M5s23_M5_H = M5 INTERACT M5s23_OPC_REGION_pre2_H
M5s23_M5_V = M5 INTERACT M5s23_OPC_REGION_pre2_V
M5s23_M5_ALL = M5s23_M5_H OR M5s23_M5_V
M5s23_OPC_EDGE_H = ANGLE (M5s23_M5_H NOT OUTSIDE EDGE M5s23_OPC_REGION_pre2_H) == 0
M5s23_OPC_EDGE_V = ANGLE (M5s23_M5_V NOT OUTSIDE EDGE M5s23_OPC_REGION_pre2_V) == 90

Wide_M5s23_H = Wide_M5s23 INTERACT M5s23_OPC_REGION_pre2_H
Wide_M5s23_V = Wide_M5s23 INTERACT M5s23_OPC_REGION_pre2_V
Wide_M5s23_WI_JOG_H = (M5 AND (Wide_M5s23_H OR M5s23_OPC_REGION_pre2_H)) INTERACT Wide_M5s23_H
Wide_M5s23_WI_JOG_V = (M5 AND (Wide_M5s23_V OR M5s23_OPC_REGION_pre2_V)) INTERACT Wide_M5s23_V

Wide_M5s23_WI_EXT_EDGE_H = M5s23_OPC_EDGE_H NOT COIN EDGE (INT [M5s23_OPC_EDGE_H] M5s23_M5_H <= M5_S_23_W1B OPPOSITE)
Wide_M5s23_WI_EXT_EDGE_V = M5s23_OPC_EDGE_V NOT COIN EDGE (INT [M5s23_OPC_EDGE_V] M5s23_M5_V <= M5_S_23_W1B OPPOSITE)

M5s23_OPC_REGION_H = (EXT Wide_M5s23_WI_JOG_H M5s23_OPC_EDGE_H < M5_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s23_OPC_REGION_pre2_H
M5s23_OPC_REGION_V = (EXT Wide_M5s23_WI_JOG_V M5s23_OPC_EDGE_V < M5_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s23_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M5s23_SP_err1_REG_H = (EXT Wide_M5s23_WI_EXT_EDGE_H M5s23_M5_H < M5_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s23_OPC_REGION_H
M5s23_SP_err1_REG_V = (EXT Wide_M5s23_WI_EXT_EDGE_V M5s23_M5_V < M5_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s23_OPC_REGION_V
M5s23_EDGE_H_err3 = ANGLE M5s23_SP_err1_REG_H == 0
M5s23_EDGE_V_err3 = ANGLE M5s23_SP_err1_REG_V == 90
M5s23_SP_err1_REG_H_eff = DFM PROPERTY M5s23_SP_err1_REG_H M5s23_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M5s23_EDGE_H_err3)] <= 2*M5_S_23_L2A
M5s23_SP_err1_REG_V_eff = DFM PROPERTY M5s23_SP_err1_REG_V M5s23_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M5s23_EDGE_V_err3)] <= 2*M5_S_23_L2A

  M5s23_R1_CHK = EXT Wide_M5s23 M5s23_M5_ALL < M5_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M5s23_NOTCH_EDGE_H = ANGLE (EXT [Wide_M5s23_WI_JOG_H] < M5_S_23_S1B OPPOSITE NOTCH) == 0
  M5s23_NOTCH_EDGE_V = ANGLE (EXT [Wide_M5s23_WI_JOG_V] < M5_S_23_S1B OPPOSITE NOTCH) == 90
  M5s23_NOTCH_REGION_H = (EXT M5s23_NOTCH_EDGE_H < M5_S_23_S1B OPPOSITE REGION) AND M5s23_OPC_REGION_H
  M5s23_NOTCH_REGION_V = (EXT M5s23_NOTCH_EDGE_V < M5_S_23_S1B OPPOSITE REGION) AND M5s23_OPC_REGION_V
  
// Check NON-Notch region
  M5s23_SP_err1_REG_H_eff5 = M5s23_SP_err1_REG_H_eff NOT M5s23_NOTCH_REGION_H
  M5s23_SP_err1_REG_V_eff5 = M5s23_SP_err1_REG_V_eff NOT M5s23_NOTCH_REGION_V
  CONNECT M5s23_SP_err1_REG_H_eff5 (M5s23_OPC_REGION_H NOT M5s23_NOTCH_REGION_H)
  CONNECT M5s23_SP_err1_REG_V_eff5 (M5s23_OPC_REGION_V NOT M5s23_NOTCH_REGION_V)
  M5s23_SP_err1_REG_H_eff5a = M5s23_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M5s23_CHECK_REGION
  M5s23_SP_err1_REG_V_eff5a = M5s23_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M5s23_CHECK_REGION
  M5s23_S3C_NNH_H = (EXT M5s23_SP_err1_REG_H_eff5a < M5_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M5
  M5s23_S3C_NNH_V = (EXT M5s23_SP_err1_REG_V_eff5a < M5_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M5
  
// Check Notch H region
  M5s23_SP_err1_REG_H_eff6 = M5s23_SP_err1_REG_H_eff INSIDE M5s23_NOTCH_REGION_H
  M5s23_SP_err1_REG_V_eff6 = M5s23_SP_err1_REG_V_eff INSIDE M5s23_NOTCH_REGION_V
  CONNECT M5s23_SP_err1_REG_H_eff6 M5s23_NOTCH_REGION_H
  CONNECT M5s23_SP_err1_REG_V_eff6 M5s23_NOTCH_REGION_V  
  M5s23_SP_err1_REG_H_eff6a = M5s23_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M5s23_CHECK_REGION
  M5s23_SP_err1_REG_V_eff6a = M5s23_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M5s23_CHECK_REGION
  M5s23_S3C_NH_H = (EXT M5s23_SP_err1_REG_H_eff6a < M5_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M5
  M5s23_S3C_NH_V = (EXT M5s23_SP_err1_REG_V_eff6a < M5_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M5

// Find Space error region(large space S2A2) //
M5s23_SP_err2_REG_H = (EXT Wide_M5s23_WI_EXT_EDGE_H M5s23_OPC_EDGE_H < M5_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s23_OPC_REGION_H
M5s23_SP_err2_REG_V = (EXT Wide_M5s23_WI_EXT_EDGE_V M5s23_OPC_EDGE_V < M5_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s23_OPC_REGION_V
M5s23_EDGE_H_err2 = M5s23_SP_err2_REG_H COIN EDGE M5s23_OPC_EDGE_H
M5s23_EDGE_V_err2 = M5s23_SP_err2_REG_V COIN EDGE M5s23_OPC_EDGE_V

M5s23_SP_err2_REG_H_eff1 = DFM PROPERTY M5s23_SP_err2_REG_H M5s23_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M5s23_EDGE_H_err2)] > 2*M5_S_23_L2A
M5s23_SP_err2_REG_V_eff1 = DFM PROPERTY M5s23_SP_err2_REG_V M5s23_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M5s23_EDGE_V_err2)] > 2*M5_S_23_L2A

// Find Space error region(small space S2A3) //
M5s23_SP_err3_REG_H = (EXT Wide_M5s23_WI_EXT_EDGE_H M5s23_OPC_EDGE_H < M5_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s23_OPC_REGION_H
M5s23_SP_err3_REG_V = (EXT Wide_M5s23_WI_EXT_EDGE_V M5s23_OPC_EDGE_V < M5_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s23_OPC_REGION_V


M5.S.23 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 1.5 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.3 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 1.5 um (W1B) and the parallel run length > 1.5 um (L1B) in metal space < 0.5 um (S1B) region >= 0.3 
  ((M5s23_SP_err1_REG_H_eff INTERACT M5s23_S3C_NNH_H) OR M5s23_S3C_NNH_H) INTERACT M5s23_R1_CHK
  ((M5s23_SP_err1_REG_H_eff INTERACT M5s23_S3C_NH_H) OR M5s23_S3C_NH_H) INTERACT M5s23_R1_CHK
  ((M5s23_SP_err1_REG_V_eff INTERACT M5s23_S3C_NNH_V) OR M5s23_S3C_NNH_V) INTERACT M5s23_R1_CHK
  ((M5s23_SP_err1_REG_V_eff INTERACT M5s23_S3C_NH_V) OR M5s23_S3C_NH_V) INTERACT M5s23_R1_CHK
}
M5.S.24 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.3 
  (M5s23_SP_err2_REG_H_eff1 AND M5s23_OPC_REGION_H) INTERACT Wide_M5s23_WI_JOG_H
  (M5s23_SP_err2_REG_V_eff1 AND M5s23_OPC_REGION_V) INTERACT Wide_M5s23_WI_JOG_V
}
M5.S.25 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M5s23_SP_err3_REG_H AND M5s23_OPC_REGION_H) INTERACT Wide_M5s23_WI_JOG_H
  (M5s23_SP_err3_REG_V AND M5s23_OPC_REGION_V) INTERACT Wide_M5s23_WI_JOG_V
}


// M6 WMJ JOG Rules
//=============================
// Wide M6s14 space error in OPC region checking
//====================================================

Wide_M6s14 = ENCLOSE RECTANGLE (SIZE M6 BY M6_S_14_W1B/2 UNDEROVER) M6_S_14_W1B+GRID M6_S_14_L1B+GRID ORTHOGONAL ONLY
M6s14_CHECK_REGION = M6 AND (SIZE Wide_M6s14 BY M6_S_14_S1B + GRID)
M6s14_OPC_REGION_pre1 = EXT [Wide_M6s14] M6s14_CHECK_REGION < M6_S_14_S1B OPPOSITE MEASURE ALL
M6s14_OPC_REGION_pre1_H = ANGLE M6s14_OPC_REGION_pre1 == 0
M6s14_OPC_REGION_pre1_V = ANGLE M6s14_OPC_REGION_pre1 == 90
M6s14_OPC_REGION_pre0_V = INT M6s14_OPC_REGION_pre1_H [Wide_M6s14] < GRID ABUT == 90 INTERSECTING ONLY 
M6s14_OPC_REGION_pre3_V = EXT M6s14_OPC_REGION_pre1_H [Wide_M6s14] < GRID ABUT == 90 INTERSECTING ONLY 
M6s14_OPC_REGION_pre4_V = (M6s14_CHECK_REGION TOUCH INSIDE EDGE M6s14_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M6s14_OPC_REGION_pre3_V
M6s14_OPC_REGION_pre0_H = INT M6s14_OPC_REGION_pre1_V [Wide_M6s14] < GRID ABUT == 90 INTERSECTING ONLY 
M6s14_OPC_REGION_pre3_H = EXT M6s14_OPC_REGION_pre1_V [Wide_M6s14] < GRID ABUT == 90 INTERSECTING ONLY 
M6s14_OPC_REGION_pre4_H = (M6s14_CHECK_REGION TOUCH INSIDE EDGE M6s14_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M6s14_OPC_REGION_pre3_H
M6s14_OPC_REGION_pre5_H = (EXPAND EDGE M6s14_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M6s14_OPC_REGION_pre4_V BY GRID)
M6s14_OPC_REGION_pre5_V = (EXPAND EDGE M6s14_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M6s14_OPC_REGION_pre4_H BY GRID)
M6s14_OPC_REGION_pre6_H = DFM PROPERTY M6s14_OPC_REGION_pre5_H M6s14_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M6s14_OPC_REGION_pre1_H)] > M6_S_14_L1B
M6s14_OPC_REGION_pre6_V = DFM PROPERTY M6s14_OPC_REGION_pre5_V M6s14_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M6s14_OPC_REGION_pre1_V)] > M6_S_14_L1B
M6s14_OPC_REGION_pre7_H = M6s14_OPC_REGION_pre1_H INSIDE EDGE M6s14_OPC_REGION_pre6_H
M6s14_OPC_REGION_pre7_V = M6s14_OPC_REGION_pre1_V INSIDE EDGE M6s14_OPC_REGION_pre6_V
M6s14_OPC_REGION_pre2_H = EXT M6s14_OPC_REGION_pre7_H M6s14_CHECK_REGION < M6_S_14_S1B OPPOSITE REGION MEASURE ALL
M6s14_OPC_REGION_pre2_V = EXT M6s14_OPC_REGION_pre7_V M6s14_CHECK_REGION < M6_S_14_S1B OPPOSITE REGION MEASURE ALL

M6s14_M6_H = M6 INTERACT M6s14_OPC_REGION_pre2_H
M6s14_M6_V = M6 INTERACT M6s14_OPC_REGION_pre2_V
M6s14_M6_ALL = M6s14_M6_H OR M6s14_M6_V
M6s14_OPC_EDGE_H = ANGLE (M6s14_M6_H NOT OUTSIDE EDGE M6s14_OPC_REGION_pre2_H) == 0
M6s14_OPC_EDGE_V = ANGLE (M6s14_M6_V NOT OUTSIDE EDGE M6s14_OPC_REGION_pre2_V) == 90

Wide_M6s14_H = Wide_M6s14 INTERACT M6s14_OPC_REGION_pre2_H
Wide_M6s14_V = Wide_M6s14 INTERACT M6s14_OPC_REGION_pre2_V
Wide_M6s14_WI_JOG_H = (M6 AND (Wide_M6s14_H OR M6s14_OPC_REGION_pre2_H)) INTERACT Wide_M6s14_H
Wide_M6s14_WI_JOG_V = (M6 AND (Wide_M6s14_V OR M6s14_OPC_REGION_pre2_V)) INTERACT Wide_M6s14_V

Wide_M6s14_WI_EXT_EDGE_H = M6s14_OPC_EDGE_H NOT COIN EDGE (INT [M6s14_OPC_EDGE_H] M6s14_M6_H <= M6_S_14_W1B OPPOSITE)
Wide_M6s14_WI_EXT_EDGE_V = M6s14_OPC_EDGE_V NOT COIN EDGE (INT [M6s14_OPC_EDGE_V] M6s14_M6_V <= M6_S_14_W1B OPPOSITE)

M6s14_OPC_REGION_H = (EXT Wide_M6s14_WI_JOG_H M6s14_OPC_EDGE_H < M6_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s14_OPC_REGION_pre2_H
M6s14_OPC_REGION_V = (EXT Wide_M6s14_WI_JOG_V M6s14_OPC_EDGE_V < M6_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s14_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M6s14_SP_err1_REG_H = (EXT Wide_M6s14_WI_EXT_EDGE_H M6s14_M6_H < M6_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s14_OPC_REGION_H
M6s14_SP_err1_REG_V = (EXT Wide_M6s14_WI_EXT_EDGE_V M6s14_M6_V < M6_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s14_OPC_REGION_V
M6s14_EDGE_H_err3 = ANGLE M6s14_SP_err1_REG_H == 0
M6s14_EDGE_V_err3 = ANGLE M6s14_SP_err1_REG_V == 90
M6s14_SP_err1_REG_H_eff = DFM PROPERTY M6s14_SP_err1_REG_H M6s14_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M6s14_EDGE_H_err3)] <= 2*M6_S_14_L2A
M6s14_SP_err1_REG_V_eff = DFM PROPERTY M6s14_SP_err1_REG_V M6s14_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M6s14_EDGE_V_err3)] <= 2*M6_S_14_L2A

  M6s14_R1_CHK = EXT Wide_M6s14 M6s14_M6_ALL < M6_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M6s14_NOTCH_EDGE_H = ANGLE (EXT [Wide_M6s14_WI_JOG_H] < M6_S_14_S1B OPPOSITE NOTCH) == 0
  M6s14_NOTCH_EDGE_V = ANGLE (EXT [Wide_M6s14_WI_JOG_V] < M6_S_14_S1B OPPOSITE NOTCH) == 90
  M6s14_NOTCH_REGION_H = (EXT M6s14_NOTCH_EDGE_H < M6_S_14_S1B OPPOSITE REGION) AND M6s14_OPC_REGION_H
  M6s14_NOTCH_REGION_V = (EXT M6s14_NOTCH_EDGE_V < M6_S_14_S1B OPPOSITE REGION) AND M6s14_OPC_REGION_V
  
// Check NON-Notch region
  M6s14_SP_err1_REG_H_eff5 = M6s14_SP_err1_REG_H_eff NOT M6s14_NOTCH_REGION_H
  M6s14_SP_err1_REG_V_eff5 = M6s14_SP_err1_REG_V_eff NOT M6s14_NOTCH_REGION_V
  CONNECT M6s14_SP_err1_REG_H_eff5 (M6s14_OPC_REGION_H NOT M6s14_NOTCH_REGION_H)
  CONNECT M6s14_SP_err1_REG_V_eff5 (M6s14_OPC_REGION_V NOT M6s14_NOTCH_REGION_V)
  M6s14_SP_err1_REG_H_eff5a = M6s14_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M6s14_CHECK_REGION
  M6s14_SP_err1_REG_V_eff5a = M6s14_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M6s14_CHECK_REGION
  M6s14_S3C_NNH_H = (EXT M6s14_SP_err1_REG_H_eff5a < M6_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M6
  M6s14_S3C_NNH_V = (EXT M6s14_SP_err1_REG_V_eff5a < M6_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M6
  
// Check Notch H region
  M6s14_SP_err1_REG_H_eff6 = M6s14_SP_err1_REG_H_eff INSIDE M6s14_NOTCH_REGION_H
  M6s14_SP_err1_REG_V_eff6 = M6s14_SP_err1_REG_V_eff INSIDE M6s14_NOTCH_REGION_V
  CONNECT M6s14_SP_err1_REG_H_eff6 M6s14_NOTCH_REGION_H
  CONNECT M6s14_SP_err1_REG_V_eff6 M6s14_NOTCH_REGION_V  
  M6s14_SP_err1_REG_H_eff6a = M6s14_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M6s14_CHECK_REGION
  M6s14_SP_err1_REG_V_eff6a = M6s14_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M6s14_CHECK_REGION
  M6s14_S3C_NH_H = (EXT M6s14_SP_err1_REG_H_eff6a < M6_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M6
  M6s14_S3C_NH_V = (EXT M6s14_SP_err1_REG_V_eff6a < M6_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M6

// Find Space error region(large space S2A2) //
M6s14_SP_err2_REG_H = (EXT Wide_M6s14_WI_EXT_EDGE_H M6s14_OPC_EDGE_H < M6_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s14_OPC_REGION_H
M6s14_SP_err2_REG_V = (EXT Wide_M6s14_WI_EXT_EDGE_V M6s14_OPC_EDGE_V < M6_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s14_OPC_REGION_V
M6s14_EDGE_H_err2 = M6s14_SP_err2_REG_H COIN EDGE M6s14_OPC_EDGE_H
M6s14_EDGE_V_err2 = M6s14_SP_err2_REG_V COIN EDGE M6s14_OPC_EDGE_V

M6s14_SP_err2_REG_H_eff1 = DFM PROPERTY M6s14_SP_err2_REG_H M6s14_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M6s14_EDGE_H_err2)] > 2*M6_S_14_L2A
M6s14_SP_err2_REG_V_eff1 = DFM PROPERTY M6s14_SP_err2_REG_V M6s14_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M6s14_EDGE_V_err2)] > 2*M6_S_14_L2A

// Find Space error region(small space S2A3) //
M6s14_SP_err3_REG_H = (EXT Wide_M6s14_WI_EXT_EDGE_H M6s14_OPC_EDGE_H < M6_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s14_OPC_REGION_H
M6s14_SP_err3_REG_V = (EXT Wide_M6s14_WI_EXT_EDGE_V M6s14_OPC_EDGE_V < M6_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s14_OPC_REGION_V


M6.S.14 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.08 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.29 um (S1B) region >= 0.3 
  ((M6s14_SP_err1_REG_H_eff INTERACT M6s14_S3C_NNH_H) OR M6s14_S3C_NNH_H) INTERACT M6s14_R1_CHK
  ((M6s14_SP_err1_REG_H_eff INTERACT M6s14_S3C_NH_H) OR M6s14_S3C_NH_H) INTERACT M6s14_R1_CHK
  ((M6s14_SP_err1_REG_V_eff INTERACT M6s14_S3C_NNH_V) OR M6s14_S3C_NNH_V) INTERACT M6s14_R1_CHK
  ((M6s14_SP_err1_REG_V_eff INTERACT M6s14_S3C_NH_V) OR M6s14_S3C_NH_V) INTERACT M6s14_R1_CHK
}
M6.S.15 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.1 
  (M6s14_SP_err2_REG_H_eff1 AND M6s14_OPC_REGION_H) INTERACT Wide_M6s14_WI_JOG_H
  (M6s14_SP_err2_REG_V_eff1 AND M6s14_OPC_REGION_V) INTERACT Wide_M6s14_WI_JOG_V
}
M6.S.16 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M6s14_SP_err3_REG_H AND M6s14_OPC_REGION_H) INTERACT Wide_M6s14_WI_JOG_H
  (M6s14_SP_err3_REG_V AND M6s14_OPC_REGION_V) INTERACT Wide_M6s14_WI_JOG_V
}

// Wide M6s17 space error in OPC region checking
//====================================================

Wide_M6s17 = ENCLOSE RECTANGLE (SIZE M6 BY M6_S_17_W1B/2 UNDEROVER) M6_S_17_W1B+GRID M6_S_17_L1B+GRID ORTHOGONAL ONLY
M6s17_CHECK_REGION = M6 AND (SIZE Wide_M6s17 BY M6_S_17_S1B + GRID)
M6s17_OPC_REGION_pre1 = EXT [Wide_M6s17] M6s17_CHECK_REGION < M6_S_17_S1B OPPOSITE MEASURE ALL
M6s17_OPC_REGION_pre1_H = ANGLE M6s17_OPC_REGION_pre1 == 0
M6s17_OPC_REGION_pre1_V = ANGLE M6s17_OPC_REGION_pre1 == 90
M6s17_OPC_REGION_pre0_V = INT M6s17_OPC_REGION_pre1_H [Wide_M6s17] < GRID ABUT == 90 INTERSECTING ONLY 
M6s17_OPC_REGION_pre3_V = EXT M6s17_OPC_REGION_pre1_H [Wide_M6s17] < GRID ABUT == 90 INTERSECTING ONLY 
M6s17_OPC_REGION_pre4_V = (M6s17_CHECK_REGION TOUCH INSIDE EDGE M6s17_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M6s17_OPC_REGION_pre3_V
M6s17_OPC_REGION_pre0_H = INT M6s17_OPC_REGION_pre1_V [Wide_M6s17] < GRID ABUT == 90 INTERSECTING ONLY 
M6s17_OPC_REGION_pre3_H = EXT M6s17_OPC_REGION_pre1_V [Wide_M6s17] < GRID ABUT == 90 INTERSECTING ONLY 
M6s17_OPC_REGION_pre4_H = (M6s17_CHECK_REGION TOUCH INSIDE EDGE M6s17_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M6s17_OPC_REGION_pre3_H
M6s17_OPC_REGION_pre5_H = (EXPAND EDGE M6s17_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M6s17_OPC_REGION_pre4_V BY GRID)
M6s17_OPC_REGION_pre5_V = (EXPAND EDGE M6s17_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M6s17_OPC_REGION_pre4_H BY GRID)
M6s17_OPC_REGION_pre6_H = DFM PROPERTY M6s17_OPC_REGION_pre5_H M6s17_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M6s17_OPC_REGION_pre1_H)] > M6_S_17_L1B
M6s17_OPC_REGION_pre6_V = DFM PROPERTY M6s17_OPC_REGION_pre5_V M6s17_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M6s17_OPC_REGION_pre1_V)] > M6_S_17_L1B
M6s17_OPC_REGION_pre7_H = M6s17_OPC_REGION_pre1_H INSIDE EDGE M6s17_OPC_REGION_pre6_H
M6s17_OPC_REGION_pre7_V = M6s17_OPC_REGION_pre1_V INSIDE EDGE M6s17_OPC_REGION_pre6_V
M6s17_OPC_REGION_pre2_H = EXT M6s17_OPC_REGION_pre7_H M6s17_CHECK_REGION < M6_S_17_S1B OPPOSITE REGION MEASURE ALL
M6s17_OPC_REGION_pre2_V = EXT M6s17_OPC_REGION_pre7_V M6s17_CHECK_REGION < M6_S_17_S1B OPPOSITE REGION MEASURE ALL

M6s17_M6_H = M6 INTERACT M6s17_OPC_REGION_pre2_H
M6s17_M6_V = M6 INTERACT M6s17_OPC_REGION_pre2_V
M6s17_M6_ALL = M6s17_M6_H OR M6s17_M6_V
M6s17_OPC_EDGE_H = ANGLE (M6s17_M6_H NOT OUTSIDE EDGE M6s17_OPC_REGION_pre2_H) == 0
M6s17_OPC_EDGE_V = ANGLE (M6s17_M6_V NOT OUTSIDE EDGE M6s17_OPC_REGION_pre2_V) == 90

Wide_M6s17_H = Wide_M6s17 INTERACT M6s17_OPC_REGION_pre2_H
Wide_M6s17_V = Wide_M6s17 INTERACT M6s17_OPC_REGION_pre2_V
Wide_M6s17_WI_JOG_H = (M6 AND (Wide_M6s17_H OR M6s17_OPC_REGION_pre2_H)) INTERACT Wide_M6s17_H
Wide_M6s17_WI_JOG_V = (M6 AND (Wide_M6s17_V OR M6s17_OPC_REGION_pre2_V)) INTERACT Wide_M6s17_V

Wide_M6s17_WI_EXT_EDGE_H = M6s17_OPC_EDGE_H NOT COIN EDGE (INT [M6s17_OPC_EDGE_H] M6s17_M6_H <= M6_S_17_W1B OPPOSITE)
Wide_M6s17_WI_EXT_EDGE_V = M6s17_OPC_EDGE_V NOT COIN EDGE (INT [M6s17_OPC_EDGE_V] M6s17_M6_V <= M6_S_17_W1B OPPOSITE)

M6s17_OPC_REGION_H = (EXT Wide_M6s17_WI_JOG_H M6s17_OPC_EDGE_H < M6_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s17_OPC_REGION_pre2_H
M6s17_OPC_REGION_V = (EXT Wide_M6s17_WI_JOG_V M6s17_OPC_EDGE_V < M6_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s17_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M6s17_SP_err1_REG_H = (EXT Wide_M6s17_WI_EXT_EDGE_H M6s17_M6_H < M6_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s17_OPC_REGION_H
M6s17_SP_err1_REG_V = (EXT Wide_M6s17_WI_EXT_EDGE_V M6s17_M6_V < M6_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s17_OPC_REGION_V
M6s17_EDGE_H_err3 = ANGLE M6s17_SP_err1_REG_H == 0
M6s17_EDGE_V_err3 = ANGLE M6s17_SP_err1_REG_V == 90
M6s17_SP_err1_REG_H_eff = DFM PROPERTY M6s17_SP_err1_REG_H M6s17_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M6s17_EDGE_H_err3)] <= 2*M6_S_17_L2A
M6s17_SP_err1_REG_V_eff = DFM PROPERTY M6s17_SP_err1_REG_V M6s17_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M6s17_EDGE_V_err3)] <= 2*M6_S_17_L2A

  M6s17_R1_CHK = EXT Wide_M6s17 M6s17_M6_ALL < M6_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M6s17_NOTCH_EDGE_H = ANGLE (EXT [Wide_M6s17_WI_JOG_H] < M6_S_17_S1B OPPOSITE NOTCH) == 0
  M6s17_NOTCH_EDGE_V = ANGLE (EXT [Wide_M6s17_WI_JOG_V] < M6_S_17_S1B OPPOSITE NOTCH) == 90
  M6s17_NOTCH_REGION_H = (EXT M6s17_NOTCH_EDGE_H < M6_S_17_S1B OPPOSITE REGION) AND M6s17_OPC_REGION_H
  M6s17_NOTCH_REGION_V = (EXT M6s17_NOTCH_EDGE_V < M6_S_17_S1B OPPOSITE REGION) AND M6s17_OPC_REGION_V
  
// Check NON-Notch region
  M6s17_SP_err1_REG_H_eff5 = M6s17_SP_err1_REG_H_eff NOT M6s17_NOTCH_REGION_H
  M6s17_SP_err1_REG_V_eff5 = M6s17_SP_err1_REG_V_eff NOT M6s17_NOTCH_REGION_V
  CONNECT M6s17_SP_err1_REG_H_eff5 (M6s17_OPC_REGION_H NOT M6s17_NOTCH_REGION_H)
  CONNECT M6s17_SP_err1_REG_V_eff5 (M6s17_OPC_REGION_V NOT M6s17_NOTCH_REGION_V)
  M6s17_SP_err1_REG_H_eff5a = M6s17_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M6s17_CHECK_REGION
  M6s17_SP_err1_REG_V_eff5a = M6s17_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M6s17_CHECK_REGION
  M6s17_S3C_NNH_H = (EXT M6s17_SP_err1_REG_H_eff5a < M6_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M6
  M6s17_S3C_NNH_V = (EXT M6s17_SP_err1_REG_V_eff5a < M6_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M6
  
// Check Notch H region
  M6s17_SP_err1_REG_H_eff6 = M6s17_SP_err1_REG_H_eff INSIDE M6s17_NOTCH_REGION_H
  M6s17_SP_err1_REG_V_eff6 = M6s17_SP_err1_REG_V_eff INSIDE M6s17_NOTCH_REGION_V
  CONNECT M6s17_SP_err1_REG_H_eff6 M6s17_NOTCH_REGION_H
  CONNECT M6s17_SP_err1_REG_V_eff6 M6s17_NOTCH_REGION_V  
  M6s17_SP_err1_REG_H_eff6a = M6s17_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M6s17_CHECK_REGION
  M6s17_SP_err1_REG_V_eff6a = M6s17_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M6s17_CHECK_REGION
  M6s17_S3C_NH_H = (EXT M6s17_SP_err1_REG_H_eff6a < M6_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M6
  M6s17_S3C_NH_V = (EXT M6s17_SP_err1_REG_V_eff6a < M6_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M6

// Find Space error region(large space S2A2) //
M6s17_SP_err2_REG_H = (EXT Wide_M6s17_WI_EXT_EDGE_H M6s17_OPC_EDGE_H < M6_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s17_OPC_REGION_H
M6s17_SP_err2_REG_V = (EXT Wide_M6s17_WI_EXT_EDGE_V M6s17_OPC_EDGE_V < M6_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s17_OPC_REGION_V
M6s17_EDGE_H_err2 = M6s17_SP_err2_REG_H COIN EDGE M6s17_OPC_EDGE_H
M6s17_EDGE_V_err2 = M6s17_SP_err2_REG_V COIN EDGE M6s17_OPC_EDGE_V

M6s17_SP_err2_REG_H_eff1 = DFM PROPERTY M6s17_SP_err2_REG_H M6s17_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M6s17_EDGE_H_err2)] > 2*M6_S_17_L2A
M6s17_SP_err2_REG_V_eff1 = DFM PROPERTY M6s17_SP_err2_REG_V M6s17_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M6s17_EDGE_V_err2)] > 2*M6_S_17_L2A

// Find Space error region(small space S2A3) //
M6s17_SP_err3_REG_H = (EXT Wide_M6s17_WI_EXT_EDGE_H M6s17_OPC_EDGE_H < M6_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s17_OPC_REGION_H
M6s17_SP_err3_REG_V = (EXT Wide_M6s17_WI_EXT_EDGE_V M6s17_OPC_EDGE_V < M6_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s17_OPC_REGION_V


M6.S.17 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.47 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.13 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.47 um (W1B) and the parallel run length > 0.5 um (L1B) in metal space < 0.32 um (S1B) region >= 0.3 
  ((M6s17_SP_err1_REG_H_eff INTERACT M6s17_S3C_NNH_H) OR M6s17_S3C_NNH_H) INTERACT M6s17_R1_CHK
  ((M6s17_SP_err1_REG_H_eff INTERACT M6s17_S3C_NH_H) OR M6s17_S3C_NH_H) INTERACT M6s17_R1_CHK
  ((M6s17_SP_err1_REG_V_eff INTERACT M6s17_S3C_NNH_V) OR M6s17_S3C_NNH_V) INTERACT M6s17_R1_CHK
  ((M6s17_SP_err1_REG_V_eff INTERACT M6s17_S3C_NH_V) OR M6s17_S3C_NH_V) INTERACT M6s17_R1_CHK
}
M6.S.18 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.13 
  (M6s17_SP_err2_REG_H_eff1 AND M6s17_OPC_REGION_H) INTERACT Wide_M6s17_WI_JOG_H
  (M6s17_SP_err2_REG_V_eff1 AND M6s17_OPC_REGION_V) INTERACT Wide_M6s17_WI_JOG_V
}
M6.S.19 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M6s17_SP_err3_REG_H AND M6s17_OPC_REGION_H) INTERACT Wide_M6s17_WI_JOG_H
  (M6s17_SP_err3_REG_V AND M6s17_OPC_REGION_V) INTERACT Wide_M6s17_WI_JOG_V
}

// Wide M6s20 space error in OPC region checking
//====================================================

Wide_M6s20 = ENCLOSE RECTANGLE (SIZE M6 BY M6_S_20_W1B/2 UNDEROVER) M6_S_20_W1B+GRID M6_S_20_L1B+GRID ORTHOGONAL ONLY
M6s20_CHECK_REGION = M6 AND (SIZE Wide_M6s20 BY M6_S_20_S1B + GRID)
M6s20_OPC_REGION_pre1 = EXT [Wide_M6s20] M6s20_CHECK_REGION < M6_S_20_S1B OPPOSITE MEASURE ALL
M6s20_OPC_REGION_pre1_H = ANGLE M6s20_OPC_REGION_pre1 == 0
M6s20_OPC_REGION_pre1_V = ANGLE M6s20_OPC_REGION_pre1 == 90
M6s20_OPC_REGION_pre0_V = INT M6s20_OPC_REGION_pre1_H [Wide_M6s20] < GRID ABUT == 90 INTERSECTING ONLY 
M6s20_OPC_REGION_pre3_V = EXT M6s20_OPC_REGION_pre1_H [Wide_M6s20] < GRID ABUT == 90 INTERSECTING ONLY 
M6s20_OPC_REGION_pre4_V = (M6s20_CHECK_REGION TOUCH INSIDE EDGE M6s20_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M6s20_OPC_REGION_pre3_V
M6s20_OPC_REGION_pre0_H = INT M6s20_OPC_REGION_pre1_V [Wide_M6s20] < GRID ABUT == 90 INTERSECTING ONLY 
M6s20_OPC_REGION_pre3_H = EXT M6s20_OPC_REGION_pre1_V [Wide_M6s20] < GRID ABUT == 90 INTERSECTING ONLY 
M6s20_OPC_REGION_pre4_H = (M6s20_CHECK_REGION TOUCH INSIDE EDGE M6s20_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M6s20_OPC_REGION_pre3_H
M6s20_OPC_REGION_pre5_H = (EXPAND EDGE M6s20_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M6s20_OPC_REGION_pre4_V BY GRID)
M6s20_OPC_REGION_pre5_V = (EXPAND EDGE M6s20_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M6s20_OPC_REGION_pre4_H BY GRID)
M6s20_OPC_REGION_pre6_H = DFM PROPERTY M6s20_OPC_REGION_pre5_H M6s20_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M6s20_OPC_REGION_pre1_H)] > M6_S_20_L1B
M6s20_OPC_REGION_pre6_V = DFM PROPERTY M6s20_OPC_REGION_pre5_V M6s20_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M6s20_OPC_REGION_pre1_V)] > M6_S_20_L1B
M6s20_OPC_REGION_pre7_H = M6s20_OPC_REGION_pre1_H INSIDE EDGE M6s20_OPC_REGION_pre6_H
M6s20_OPC_REGION_pre7_V = M6s20_OPC_REGION_pre1_V INSIDE EDGE M6s20_OPC_REGION_pre6_V
M6s20_OPC_REGION_pre2_H = EXT M6s20_OPC_REGION_pre7_H M6s20_CHECK_REGION < M6_S_20_S1B OPPOSITE REGION MEASURE ALL
M6s20_OPC_REGION_pre2_V = EXT M6s20_OPC_REGION_pre7_V M6s20_CHECK_REGION < M6_S_20_S1B OPPOSITE REGION MEASURE ALL

M6s20_M6_H = M6 INTERACT M6s20_OPC_REGION_pre2_H
M6s20_M6_V = M6 INTERACT M6s20_OPC_REGION_pre2_V
M6s20_M6_ALL = M6s20_M6_H OR M6s20_M6_V
M6s20_OPC_EDGE_H = ANGLE (M6s20_M6_H NOT OUTSIDE EDGE M6s20_OPC_REGION_pre2_H) == 0
M6s20_OPC_EDGE_V = ANGLE (M6s20_M6_V NOT OUTSIDE EDGE M6s20_OPC_REGION_pre2_V) == 90

Wide_M6s20_H = Wide_M6s20 INTERACT M6s20_OPC_REGION_pre2_H
Wide_M6s20_V = Wide_M6s20 INTERACT M6s20_OPC_REGION_pre2_V
Wide_M6s20_WI_JOG_H = (M6 AND (Wide_M6s20_H OR M6s20_OPC_REGION_pre2_H)) INTERACT Wide_M6s20_H
Wide_M6s20_WI_JOG_V = (M6 AND (Wide_M6s20_V OR M6s20_OPC_REGION_pre2_V)) INTERACT Wide_M6s20_V

Wide_M6s20_WI_EXT_EDGE_H = M6s20_OPC_EDGE_H NOT COIN EDGE (INT [M6s20_OPC_EDGE_H] M6s20_M6_H <= M6_S_20_W1B OPPOSITE)
Wide_M6s20_WI_EXT_EDGE_V = M6s20_OPC_EDGE_V NOT COIN EDGE (INT [M6s20_OPC_EDGE_V] M6s20_M6_V <= M6_S_20_W1B OPPOSITE)

M6s20_OPC_REGION_H = (EXT Wide_M6s20_WI_JOG_H M6s20_OPC_EDGE_H < M6_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s20_OPC_REGION_pre2_H
M6s20_OPC_REGION_V = (EXT Wide_M6s20_WI_JOG_V M6s20_OPC_EDGE_V < M6_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s20_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M6s20_SP_err1_REG_H = (EXT Wide_M6s20_WI_EXT_EDGE_H M6s20_M6_H < M6_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s20_OPC_REGION_H
M6s20_SP_err1_REG_V = (EXT Wide_M6s20_WI_EXT_EDGE_V M6s20_M6_V < M6_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s20_OPC_REGION_V
M6s20_EDGE_H_err3 = ANGLE M6s20_SP_err1_REG_H == 0
M6s20_EDGE_V_err3 = ANGLE M6s20_SP_err1_REG_V == 90
M6s20_SP_err1_REG_H_eff = DFM PROPERTY M6s20_SP_err1_REG_H M6s20_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M6s20_EDGE_H_err3)] <= 2*M6_S_20_L2A
M6s20_SP_err1_REG_V_eff = DFM PROPERTY M6s20_SP_err1_REG_V M6s20_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M6s20_EDGE_V_err3)] <= 2*M6_S_20_L2A

  M6s20_R1_CHK = EXT Wide_M6s20 M6s20_M6_ALL < M6_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M6s20_NOTCH_EDGE_H = ANGLE (EXT [Wide_M6s20_WI_JOG_H] < M6_S_20_S1B OPPOSITE NOTCH) == 0
  M6s20_NOTCH_EDGE_V = ANGLE (EXT [Wide_M6s20_WI_JOG_V] < M6_S_20_S1B OPPOSITE NOTCH) == 90
  M6s20_NOTCH_REGION_H = (EXT M6s20_NOTCH_EDGE_H < M6_S_20_S1B OPPOSITE REGION) AND M6s20_OPC_REGION_H
  M6s20_NOTCH_REGION_V = (EXT M6s20_NOTCH_EDGE_V < M6_S_20_S1B OPPOSITE REGION) AND M6s20_OPC_REGION_V
  
// Check NON-Notch region
  M6s20_SP_err1_REG_H_eff5 = M6s20_SP_err1_REG_H_eff NOT M6s20_NOTCH_REGION_H
  M6s20_SP_err1_REG_V_eff5 = M6s20_SP_err1_REG_V_eff NOT M6s20_NOTCH_REGION_V
  CONNECT M6s20_SP_err1_REG_H_eff5 (M6s20_OPC_REGION_H NOT M6s20_NOTCH_REGION_H)
  CONNECT M6s20_SP_err1_REG_V_eff5 (M6s20_OPC_REGION_V NOT M6s20_NOTCH_REGION_V)
  M6s20_SP_err1_REG_H_eff5a = M6s20_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M6s20_CHECK_REGION
  M6s20_SP_err1_REG_V_eff5a = M6s20_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M6s20_CHECK_REGION
  M6s20_S3C_NNH_H = (EXT M6s20_SP_err1_REG_H_eff5a < M6_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M6
  M6s20_S3C_NNH_V = (EXT M6s20_SP_err1_REG_V_eff5a < M6_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M6
  
// Check Notch H region
  M6s20_SP_err1_REG_H_eff6 = M6s20_SP_err1_REG_H_eff INSIDE M6s20_NOTCH_REGION_H
  M6s20_SP_err1_REG_V_eff6 = M6s20_SP_err1_REG_V_eff INSIDE M6s20_NOTCH_REGION_V
  CONNECT M6s20_SP_err1_REG_H_eff6 M6s20_NOTCH_REGION_H
  CONNECT M6s20_SP_err1_REG_V_eff6 M6s20_NOTCH_REGION_V  
  M6s20_SP_err1_REG_H_eff6a = M6s20_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M6s20_CHECK_REGION
  M6s20_SP_err1_REG_V_eff6a = M6s20_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M6s20_CHECK_REGION
  M6s20_S3C_NH_H = (EXT M6s20_SP_err1_REG_H_eff6a < M6_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M6
  M6s20_S3C_NH_V = (EXT M6s20_SP_err1_REG_V_eff6a < M6_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M6

// Find Space error region(large space S2A2) //
M6s20_SP_err2_REG_H = (EXT Wide_M6s20_WI_EXT_EDGE_H M6s20_OPC_EDGE_H < M6_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s20_OPC_REGION_H
M6s20_SP_err2_REG_V = (EXT Wide_M6s20_WI_EXT_EDGE_V M6s20_OPC_EDGE_V < M6_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s20_OPC_REGION_V
M6s20_EDGE_H_err2 = M6s20_SP_err2_REG_H COIN EDGE M6s20_OPC_EDGE_H
M6s20_EDGE_V_err2 = M6s20_SP_err2_REG_V COIN EDGE M6s20_OPC_EDGE_V

M6s20_SP_err2_REG_H_eff1 = DFM PROPERTY M6s20_SP_err2_REG_H M6s20_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M6s20_EDGE_H_err2)] > 2*M6_S_20_L2A
M6s20_SP_err2_REG_V_eff1 = DFM PROPERTY M6s20_SP_err2_REG_V M6s20_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M6s20_EDGE_V_err2)] > 2*M6_S_20_L2A

// Find Space error region(small space S2A3) //
M6s20_SP_err3_REG_H = (EXT Wide_M6s20_WI_EXT_EDGE_H M6s20_OPC_EDGE_H < M6_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s20_OPC_REGION_H
M6s20_SP_err3_REG_V = (EXT Wide_M6s20_WI_EXT_EDGE_V M6s20_OPC_EDGE_V < M6_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s20_OPC_REGION_V


M6.S.20 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.63 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.15 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.63 um (W1B) and the parallel run length > 0.7 um (L1B) in metal space < 0.34 um (S1B) region >= 0.3 
  ((M6s20_SP_err1_REG_H_eff INTERACT M6s20_S3C_NNH_H) OR M6s20_S3C_NNH_H) INTERACT M6s20_R1_CHK
  ((M6s20_SP_err1_REG_H_eff INTERACT M6s20_S3C_NH_H) OR M6s20_S3C_NH_H) INTERACT M6s20_R1_CHK
  ((M6s20_SP_err1_REG_V_eff INTERACT M6s20_S3C_NNH_V) OR M6s20_S3C_NNH_V) INTERACT M6s20_R1_CHK
  ((M6s20_SP_err1_REG_V_eff INTERACT M6s20_S3C_NH_V) OR M6s20_S3C_NH_V) INTERACT M6s20_R1_CHK
}
M6.S.21 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.15 
  (M6s20_SP_err2_REG_H_eff1 AND M6s20_OPC_REGION_H) INTERACT Wide_M6s20_WI_JOG_H
  (M6s20_SP_err2_REG_V_eff1 AND M6s20_OPC_REGION_V) INTERACT Wide_M6s20_WI_JOG_V
}
M6.S.22 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M6s20_SP_err3_REG_H AND M6s20_OPC_REGION_H) INTERACT Wide_M6s20_WI_JOG_H
  (M6s20_SP_err3_REG_V AND M6s20_OPC_REGION_V) INTERACT Wide_M6s20_WI_JOG_V
}

// Wide M6s23 space error in OPC region checking
//====================================================

Wide_M6s23 = ENCLOSE RECTANGLE (SIZE M6 BY M6_S_23_W1B/2 UNDEROVER) M6_S_23_W1B+GRID M6_S_23_L1B+GRID ORTHOGONAL ONLY
M6s23_CHECK_REGION = M6 AND (SIZE Wide_M6s23 BY M6_S_23_S1B + GRID)
M6s23_OPC_REGION_pre1 = EXT [Wide_M6s23] M6s23_CHECK_REGION < M6_S_23_S1B OPPOSITE MEASURE ALL
M6s23_OPC_REGION_pre1_H = ANGLE M6s23_OPC_REGION_pre1 == 0
M6s23_OPC_REGION_pre1_V = ANGLE M6s23_OPC_REGION_pre1 == 90
M6s23_OPC_REGION_pre0_V = INT M6s23_OPC_REGION_pre1_H [Wide_M6s23] < GRID ABUT == 90 INTERSECTING ONLY 
M6s23_OPC_REGION_pre3_V = EXT M6s23_OPC_REGION_pre1_H [Wide_M6s23] < GRID ABUT == 90 INTERSECTING ONLY 
M6s23_OPC_REGION_pre4_V = (M6s23_CHECK_REGION TOUCH INSIDE EDGE M6s23_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M6s23_OPC_REGION_pre3_V
M6s23_OPC_REGION_pre0_H = INT M6s23_OPC_REGION_pre1_V [Wide_M6s23] < GRID ABUT == 90 INTERSECTING ONLY 
M6s23_OPC_REGION_pre3_H = EXT M6s23_OPC_REGION_pre1_V [Wide_M6s23] < GRID ABUT == 90 INTERSECTING ONLY 
M6s23_OPC_REGION_pre4_H = (M6s23_CHECK_REGION TOUCH INSIDE EDGE M6s23_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M6s23_OPC_REGION_pre3_H
M6s23_OPC_REGION_pre5_H = (EXPAND EDGE M6s23_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M6s23_OPC_REGION_pre4_V BY GRID)
M6s23_OPC_REGION_pre5_V = (EXPAND EDGE M6s23_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M6s23_OPC_REGION_pre4_H BY GRID)
M6s23_OPC_REGION_pre6_H = DFM PROPERTY M6s23_OPC_REGION_pre5_H M6s23_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M6s23_OPC_REGION_pre1_H)] > M6_S_23_L1B
M6s23_OPC_REGION_pre6_V = DFM PROPERTY M6s23_OPC_REGION_pre5_V M6s23_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M6s23_OPC_REGION_pre1_V)] > M6_S_23_L1B
M6s23_OPC_REGION_pre7_H = M6s23_OPC_REGION_pre1_H INSIDE EDGE M6s23_OPC_REGION_pre6_H
M6s23_OPC_REGION_pre7_V = M6s23_OPC_REGION_pre1_V INSIDE EDGE M6s23_OPC_REGION_pre6_V
M6s23_OPC_REGION_pre2_H = EXT M6s23_OPC_REGION_pre7_H M6s23_CHECK_REGION < M6_S_23_S1B OPPOSITE REGION MEASURE ALL
M6s23_OPC_REGION_pre2_V = EXT M6s23_OPC_REGION_pre7_V M6s23_CHECK_REGION < M6_S_23_S1B OPPOSITE REGION MEASURE ALL

M6s23_M6_H = M6 INTERACT M6s23_OPC_REGION_pre2_H
M6s23_M6_V = M6 INTERACT M6s23_OPC_REGION_pre2_V
M6s23_M6_ALL = M6s23_M6_H OR M6s23_M6_V
M6s23_OPC_EDGE_H = ANGLE (M6s23_M6_H NOT OUTSIDE EDGE M6s23_OPC_REGION_pre2_H) == 0
M6s23_OPC_EDGE_V = ANGLE (M6s23_M6_V NOT OUTSIDE EDGE M6s23_OPC_REGION_pre2_V) == 90

Wide_M6s23_H = Wide_M6s23 INTERACT M6s23_OPC_REGION_pre2_H
Wide_M6s23_V = Wide_M6s23 INTERACT M6s23_OPC_REGION_pre2_V
Wide_M6s23_WI_JOG_H = (M6 AND (Wide_M6s23_H OR M6s23_OPC_REGION_pre2_H)) INTERACT Wide_M6s23_H
Wide_M6s23_WI_JOG_V = (M6 AND (Wide_M6s23_V OR M6s23_OPC_REGION_pre2_V)) INTERACT Wide_M6s23_V

Wide_M6s23_WI_EXT_EDGE_H = M6s23_OPC_EDGE_H NOT COIN EDGE (INT [M6s23_OPC_EDGE_H] M6s23_M6_H <= M6_S_23_W1B OPPOSITE)
Wide_M6s23_WI_EXT_EDGE_V = M6s23_OPC_EDGE_V NOT COIN EDGE (INT [M6s23_OPC_EDGE_V] M6s23_M6_V <= M6_S_23_W1B OPPOSITE)

M6s23_OPC_REGION_H = (EXT Wide_M6s23_WI_JOG_H M6s23_OPC_EDGE_H < M6_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s23_OPC_REGION_pre2_H
M6s23_OPC_REGION_V = (EXT Wide_M6s23_WI_JOG_V M6s23_OPC_EDGE_V < M6_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s23_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M6s23_SP_err1_REG_H = (EXT Wide_M6s23_WI_EXT_EDGE_H M6s23_M6_H < M6_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s23_OPC_REGION_H
M6s23_SP_err1_REG_V = (EXT Wide_M6s23_WI_EXT_EDGE_V M6s23_M6_V < M6_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s23_OPC_REGION_V
M6s23_EDGE_H_err3 = ANGLE M6s23_SP_err1_REG_H == 0
M6s23_EDGE_V_err3 = ANGLE M6s23_SP_err1_REG_V == 90
M6s23_SP_err1_REG_H_eff = DFM PROPERTY M6s23_SP_err1_REG_H M6s23_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M6s23_EDGE_H_err3)] <= 2*M6_S_23_L2A
M6s23_SP_err1_REG_V_eff = DFM PROPERTY M6s23_SP_err1_REG_V M6s23_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M6s23_EDGE_V_err3)] <= 2*M6_S_23_L2A

  M6s23_R1_CHK = EXT Wide_M6s23 M6s23_M6_ALL < M6_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M6s23_NOTCH_EDGE_H = ANGLE (EXT [Wide_M6s23_WI_JOG_H] < M6_S_23_S1B OPPOSITE NOTCH) == 0
  M6s23_NOTCH_EDGE_V = ANGLE (EXT [Wide_M6s23_WI_JOG_V] < M6_S_23_S1B OPPOSITE NOTCH) == 90
  M6s23_NOTCH_REGION_H = (EXT M6s23_NOTCH_EDGE_H < M6_S_23_S1B OPPOSITE REGION) AND M6s23_OPC_REGION_H
  M6s23_NOTCH_REGION_V = (EXT M6s23_NOTCH_EDGE_V < M6_S_23_S1B OPPOSITE REGION) AND M6s23_OPC_REGION_V
  
// Check NON-Notch region
  M6s23_SP_err1_REG_H_eff5 = M6s23_SP_err1_REG_H_eff NOT M6s23_NOTCH_REGION_H
  M6s23_SP_err1_REG_V_eff5 = M6s23_SP_err1_REG_V_eff NOT M6s23_NOTCH_REGION_V
  CONNECT M6s23_SP_err1_REG_H_eff5 (M6s23_OPC_REGION_H NOT M6s23_NOTCH_REGION_H)
  CONNECT M6s23_SP_err1_REG_V_eff5 (M6s23_OPC_REGION_V NOT M6s23_NOTCH_REGION_V)
  M6s23_SP_err1_REG_H_eff5a = M6s23_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M6s23_CHECK_REGION
  M6s23_SP_err1_REG_V_eff5a = M6s23_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M6s23_CHECK_REGION
  M6s23_S3C_NNH_H = (EXT M6s23_SP_err1_REG_H_eff5a < M6_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M6
  M6s23_S3C_NNH_V = (EXT M6s23_SP_err1_REG_V_eff5a < M6_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M6
  
// Check Notch H region
  M6s23_SP_err1_REG_H_eff6 = M6s23_SP_err1_REG_H_eff INSIDE M6s23_NOTCH_REGION_H
  M6s23_SP_err1_REG_V_eff6 = M6s23_SP_err1_REG_V_eff INSIDE M6s23_NOTCH_REGION_V
  CONNECT M6s23_SP_err1_REG_H_eff6 M6s23_NOTCH_REGION_H
  CONNECT M6s23_SP_err1_REG_V_eff6 M6s23_NOTCH_REGION_V  
  M6s23_SP_err1_REG_H_eff6a = M6s23_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M6s23_CHECK_REGION
  M6s23_SP_err1_REG_V_eff6a = M6s23_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M6s23_CHECK_REGION
  M6s23_S3C_NH_H = (EXT M6s23_SP_err1_REG_H_eff6a < M6_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M6
  M6s23_S3C_NH_V = (EXT M6s23_SP_err1_REG_V_eff6a < M6_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M6

// Find Space error region(large space S2A2) //
M6s23_SP_err2_REG_H = (EXT Wide_M6s23_WI_EXT_EDGE_H M6s23_OPC_EDGE_H < M6_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s23_OPC_REGION_H
M6s23_SP_err2_REG_V = (EXT Wide_M6s23_WI_EXT_EDGE_V M6s23_OPC_EDGE_V < M6_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s23_OPC_REGION_V
M6s23_EDGE_H_err2 = M6s23_SP_err2_REG_H COIN EDGE M6s23_OPC_EDGE_H
M6s23_EDGE_V_err2 = M6s23_SP_err2_REG_V COIN EDGE M6s23_OPC_EDGE_V

M6s23_SP_err2_REG_H_eff1 = DFM PROPERTY M6s23_SP_err2_REG_H M6s23_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M6s23_EDGE_H_err2)] > 2*M6_S_23_L2A
M6s23_SP_err2_REG_V_eff1 = DFM PROPERTY M6s23_SP_err2_REG_V M6s23_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M6s23_EDGE_V_err2)] > 2*M6_S_23_L2A

// Find Space error region(small space S2A3) //
M6s23_SP_err3_REG_H = (EXT Wide_M6s23_WI_EXT_EDGE_H M6s23_OPC_EDGE_H < M6_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s23_OPC_REGION_H
M6s23_SP_err3_REG_V = (EXT Wide_M6s23_WI_EXT_EDGE_V M6s23_OPC_EDGE_V < M6_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s23_OPC_REGION_V


M6.S.23 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 1.5 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.3 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 1.5 um (W1B) and the parallel run length > 1.5 um (L1B) in metal space < 0.5 um (S1B) region >= 0.3 
  ((M6s23_SP_err1_REG_H_eff INTERACT M6s23_S3C_NNH_H) OR M6s23_S3C_NNH_H) INTERACT M6s23_R1_CHK
  ((M6s23_SP_err1_REG_H_eff INTERACT M6s23_S3C_NH_H) OR M6s23_S3C_NH_H) INTERACT M6s23_R1_CHK
  ((M6s23_SP_err1_REG_V_eff INTERACT M6s23_S3C_NNH_V) OR M6s23_S3C_NNH_V) INTERACT M6s23_R1_CHK
  ((M6s23_SP_err1_REG_V_eff INTERACT M6s23_S3C_NH_V) OR M6s23_S3C_NH_V) INTERACT M6s23_R1_CHK
}
M6.S.24 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.3 
  (M6s23_SP_err2_REG_H_eff1 AND M6s23_OPC_REGION_H) INTERACT Wide_M6s23_WI_JOG_H
  (M6s23_SP_err2_REG_V_eff1 AND M6s23_OPC_REGION_V) INTERACT Wide_M6s23_WI_JOG_V
}
M6.S.25 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M6s23_SP_err3_REG_H AND M6s23_OPC_REGION_H) INTERACT Wide_M6s23_WI_JOG_H
  (M6s23_SP_err3_REG_V AND M6s23_OPC_REGION_V) INTERACT Wide_M6s23_WI_JOG_V
}


// M7 WMJ JOG Rules
//=============================
// Wide M7s14 space error in OPC region checking
//====================================================

Wide_M7s14 = ENCLOSE RECTANGLE (SIZE M7 BY M7_S_14_W1B/2 UNDEROVER) M7_S_14_W1B+GRID M7_S_14_L1B+GRID ORTHOGONAL ONLY
M7s14_CHECK_REGION = M7 AND (SIZE Wide_M7s14 BY M7_S_14_S1B + GRID)
M7s14_OPC_REGION_pre1 = EXT [Wide_M7s14] M7s14_CHECK_REGION < M7_S_14_S1B OPPOSITE MEASURE ALL
M7s14_OPC_REGION_pre1_H = ANGLE M7s14_OPC_REGION_pre1 == 0
M7s14_OPC_REGION_pre1_V = ANGLE M7s14_OPC_REGION_pre1 == 90
M7s14_OPC_REGION_pre0_V = INT M7s14_OPC_REGION_pre1_H [Wide_M7s14] < GRID ABUT == 90 INTERSECTING ONLY 
M7s14_OPC_REGION_pre3_V = EXT M7s14_OPC_REGION_pre1_H [Wide_M7s14] < GRID ABUT == 90 INTERSECTING ONLY 
M7s14_OPC_REGION_pre4_V = (M7s14_CHECK_REGION TOUCH INSIDE EDGE M7s14_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M7s14_OPC_REGION_pre3_V
M7s14_OPC_REGION_pre0_H = INT M7s14_OPC_REGION_pre1_V [Wide_M7s14] < GRID ABUT == 90 INTERSECTING ONLY 
M7s14_OPC_REGION_pre3_H = EXT M7s14_OPC_REGION_pre1_V [Wide_M7s14] < GRID ABUT == 90 INTERSECTING ONLY 
M7s14_OPC_REGION_pre4_H = (M7s14_CHECK_REGION TOUCH INSIDE EDGE M7s14_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M7s14_OPC_REGION_pre3_H
M7s14_OPC_REGION_pre5_H = (EXPAND EDGE M7s14_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M7s14_OPC_REGION_pre4_V BY GRID)
M7s14_OPC_REGION_pre5_V = (EXPAND EDGE M7s14_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M7s14_OPC_REGION_pre4_H BY GRID)
M7s14_OPC_REGION_pre6_H = DFM PROPERTY M7s14_OPC_REGION_pre5_H M7s14_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M7s14_OPC_REGION_pre1_H)] > M7_S_14_L1B
M7s14_OPC_REGION_pre6_V = DFM PROPERTY M7s14_OPC_REGION_pre5_V M7s14_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M7s14_OPC_REGION_pre1_V)] > M7_S_14_L1B
M7s14_OPC_REGION_pre7_H = M7s14_OPC_REGION_pre1_H INSIDE EDGE M7s14_OPC_REGION_pre6_H
M7s14_OPC_REGION_pre7_V = M7s14_OPC_REGION_pre1_V INSIDE EDGE M7s14_OPC_REGION_pre6_V
M7s14_OPC_REGION_pre2_H = EXT M7s14_OPC_REGION_pre7_H M7s14_CHECK_REGION < M7_S_14_S1B OPPOSITE REGION MEASURE ALL
M7s14_OPC_REGION_pre2_V = EXT M7s14_OPC_REGION_pre7_V M7s14_CHECK_REGION < M7_S_14_S1B OPPOSITE REGION MEASURE ALL

M7s14_M7_H = M7 INTERACT M7s14_OPC_REGION_pre2_H
M7s14_M7_V = M7 INTERACT M7s14_OPC_REGION_pre2_V
M7s14_M7_ALL = M7s14_M7_H OR M7s14_M7_V
M7s14_OPC_EDGE_H = ANGLE (M7s14_M7_H NOT OUTSIDE EDGE M7s14_OPC_REGION_pre2_H) == 0
M7s14_OPC_EDGE_V = ANGLE (M7s14_M7_V NOT OUTSIDE EDGE M7s14_OPC_REGION_pre2_V) == 90

Wide_M7s14_H = Wide_M7s14 INTERACT M7s14_OPC_REGION_pre2_H
Wide_M7s14_V = Wide_M7s14 INTERACT M7s14_OPC_REGION_pre2_V
Wide_M7s14_WI_JOG_H = (M7 AND (Wide_M7s14_H OR M7s14_OPC_REGION_pre2_H)) INTERACT Wide_M7s14_H
Wide_M7s14_WI_JOG_V = (M7 AND (Wide_M7s14_V OR M7s14_OPC_REGION_pre2_V)) INTERACT Wide_M7s14_V

Wide_M7s14_WI_EXT_EDGE_H = M7s14_OPC_EDGE_H NOT COIN EDGE (INT [M7s14_OPC_EDGE_H] M7s14_M7_H <= M7_S_14_W1B OPPOSITE)
Wide_M7s14_WI_EXT_EDGE_V = M7s14_OPC_EDGE_V NOT COIN EDGE (INT [M7s14_OPC_EDGE_V] M7s14_M7_V <= M7_S_14_W1B OPPOSITE)

M7s14_OPC_REGION_H = (EXT Wide_M7s14_WI_JOG_H M7s14_OPC_EDGE_H < M7_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s14_OPC_REGION_pre2_H
M7s14_OPC_REGION_V = (EXT Wide_M7s14_WI_JOG_V M7s14_OPC_EDGE_V < M7_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s14_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M7s14_SP_err1_REG_H = (EXT Wide_M7s14_WI_EXT_EDGE_H M7s14_M7_H < M7_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s14_OPC_REGION_H
M7s14_SP_err1_REG_V = (EXT Wide_M7s14_WI_EXT_EDGE_V M7s14_M7_V < M7_S_14_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s14_OPC_REGION_V
M7s14_EDGE_H_err3 = ANGLE M7s14_SP_err1_REG_H == 0
M7s14_EDGE_V_err3 = ANGLE M7s14_SP_err1_REG_V == 90
M7s14_SP_err1_REG_H_eff = DFM PROPERTY M7s14_SP_err1_REG_H M7s14_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M7s14_EDGE_H_err3)] <= 2*M7_S_14_L2A
M7s14_SP_err1_REG_V_eff = DFM PROPERTY M7s14_SP_err1_REG_V M7s14_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M7s14_EDGE_V_err3)] <= 2*M7_S_14_L2A

  M7s14_R1_CHK = EXT Wide_M7s14 M7s14_M7_ALL < M7_S_14_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M7s14_NOTCH_EDGE_H = ANGLE (EXT [Wide_M7s14_WI_JOG_H] < M7_S_14_S1B OPPOSITE NOTCH) == 0
  M7s14_NOTCH_EDGE_V = ANGLE (EXT [Wide_M7s14_WI_JOG_V] < M7_S_14_S1B OPPOSITE NOTCH) == 90
  M7s14_NOTCH_REGION_H = (EXT M7s14_NOTCH_EDGE_H < M7_S_14_S1B OPPOSITE REGION) AND M7s14_OPC_REGION_H
  M7s14_NOTCH_REGION_V = (EXT M7s14_NOTCH_EDGE_V < M7_S_14_S1B OPPOSITE REGION) AND M7s14_OPC_REGION_V
  
// Check NON-Notch region
  M7s14_SP_err1_REG_H_eff5 = M7s14_SP_err1_REG_H_eff NOT M7s14_NOTCH_REGION_H
  M7s14_SP_err1_REG_V_eff5 = M7s14_SP_err1_REG_V_eff NOT M7s14_NOTCH_REGION_V
  CONNECT M7s14_SP_err1_REG_H_eff5 (M7s14_OPC_REGION_H NOT M7s14_NOTCH_REGION_H)
  CONNECT M7s14_SP_err1_REG_V_eff5 (M7s14_OPC_REGION_V NOT M7s14_NOTCH_REGION_V)
  M7s14_SP_err1_REG_H_eff5a = M7s14_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M7s14_CHECK_REGION
  M7s14_SP_err1_REG_V_eff5a = M7s14_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M7s14_CHECK_REGION
  M7s14_S3C_NNH_H = (EXT M7s14_SP_err1_REG_H_eff5a < M7_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M7
  M7s14_S3C_NNH_V = (EXT M7s14_SP_err1_REG_V_eff5a < M7_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M7
  
// Check Notch H region
  M7s14_SP_err1_REG_H_eff6 = M7s14_SP_err1_REG_H_eff INSIDE M7s14_NOTCH_REGION_H
  M7s14_SP_err1_REG_V_eff6 = M7s14_SP_err1_REG_V_eff INSIDE M7s14_NOTCH_REGION_V
  CONNECT M7s14_SP_err1_REG_H_eff6 M7s14_NOTCH_REGION_H
  CONNECT M7s14_SP_err1_REG_V_eff6 M7s14_NOTCH_REGION_V  
  M7s14_SP_err1_REG_H_eff6a = M7s14_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M7s14_CHECK_REGION
  M7s14_SP_err1_REG_V_eff6a = M7s14_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M7s14_CHECK_REGION
  M7s14_S3C_NH_H = (EXT M7s14_SP_err1_REG_H_eff6a < M7_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M7
  M7s14_S3C_NH_V = (EXT M7s14_SP_err1_REG_V_eff6a < M7_S_14_S3C ABUT < 90 REGION CONNECTED) NOT M7

// Find Space error region(large space S2A2) //
M7s14_SP_err2_REG_H = (EXT Wide_M7s14_WI_EXT_EDGE_H M7s14_OPC_EDGE_H < M7_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s14_OPC_REGION_H
M7s14_SP_err2_REG_V = (EXT Wide_M7s14_WI_EXT_EDGE_V M7s14_OPC_EDGE_V < M7_S_14_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s14_OPC_REGION_V
M7s14_EDGE_H_err2 = M7s14_SP_err2_REG_H COIN EDGE M7s14_OPC_EDGE_H
M7s14_EDGE_V_err2 = M7s14_SP_err2_REG_V COIN EDGE M7s14_OPC_EDGE_V

M7s14_SP_err2_REG_H_eff1 = DFM PROPERTY M7s14_SP_err2_REG_H M7s14_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M7s14_EDGE_H_err2)] > 2*M7_S_14_L2A
M7s14_SP_err2_REG_V_eff1 = DFM PROPERTY M7s14_SP_err2_REG_V M7s14_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M7s14_EDGE_V_err2)] > 2*M7_S_14_L2A

// Find Space error region(small space S2A3) //
M7s14_SP_err3_REG_H = (EXT Wide_M7s14_WI_EXT_EDGE_H M7s14_OPC_EDGE_H < M7_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s14_OPC_REGION_H
M7s14_SP_err3_REG_V = (EXT Wide_M7s14_WI_EXT_EDGE_V M7s14_OPC_EDGE_V < M7_S_14_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s14_OPC_REGION_V


M7.S.14 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.08 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.29 um (S1B) region >= 0.3 
  ((M7s14_SP_err1_REG_H_eff INTERACT M7s14_S3C_NNH_H) OR M7s14_S3C_NNH_H) INTERACT M7s14_R1_CHK
  ((M7s14_SP_err1_REG_H_eff INTERACT M7s14_S3C_NH_H) OR M7s14_S3C_NH_H) INTERACT M7s14_R1_CHK
  ((M7s14_SP_err1_REG_V_eff INTERACT M7s14_S3C_NNH_V) OR M7s14_S3C_NNH_V) INTERACT M7s14_R1_CHK
  ((M7s14_SP_err1_REG_V_eff INTERACT M7s14_S3C_NH_V) OR M7s14_S3C_NH_V) INTERACT M7s14_R1_CHK
}
M7.S.15 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.1 
  (M7s14_SP_err2_REG_H_eff1 AND M7s14_OPC_REGION_H) INTERACT Wide_M7s14_WI_JOG_H
  (M7s14_SP_err2_REG_V_eff1 AND M7s14_OPC_REGION_V) INTERACT Wide_M7s14_WI_JOG_V
}
M7.S.16 { @ Wide metal [width > 0.25 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M7s14_SP_err3_REG_H AND M7s14_OPC_REGION_H) INTERACT Wide_M7s14_WI_JOG_H
  (M7s14_SP_err3_REG_V AND M7s14_OPC_REGION_V) INTERACT Wide_M7s14_WI_JOG_V
}

// Wide M7s17 space error in OPC region checking
//====================================================

Wide_M7s17 = ENCLOSE RECTANGLE (SIZE M7 BY M7_S_17_W1B/2 UNDEROVER) M7_S_17_W1B+GRID M7_S_17_L1B+GRID ORTHOGONAL ONLY
M7s17_CHECK_REGION = M7 AND (SIZE Wide_M7s17 BY M7_S_17_S1B + GRID)
M7s17_OPC_REGION_pre1 = EXT [Wide_M7s17] M7s17_CHECK_REGION < M7_S_17_S1B OPPOSITE MEASURE ALL
M7s17_OPC_REGION_pre1_H = ANGLE M7s17_OPC_REGION_pre1 == 0
M7s17_OPC_REGION_pre1_V = ANGLE M7s17_OPC_REGION_pre1 == 90
M7s17_OPC_REGION_pre0_V = INT M7s17_OPC_REGION_pre1_H [Wide_M7s17] < GRID ABUT == 90 INTERSECTING ONLY 
M7s17_OPC_REGION_pre3_V = EXT M7s17_OPC_REGION_pre1_H [Wide_M7s17] < GRID ABUT == 90 INTERSECTING ONLY 
M7s17_OPC_REGION_pre4_V = (M7s17_CHECK_REGION TOUCH INSIDE EDGE M7s17_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M7s17_OPC_REGION_pre3_V
M7s17_OPC_REGION_pre0_H = INT M7s17_OPC_REGION_pre1_V [Wide_M7s17] < GRID ABUT == 90 INTERSECTING ONLY 
M7s17_OPC_REGION_pre3_H = EXT M7s17_OPC_REGION_pre1_V [Wide_M7s17] < GRID ABUT == 90 INTERSECTING ONLY 
M7s17_OPC_REGION_pre4_H = (M7s17_CHECK_REGION TOUCH INSIDE EDGE M7s17_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M7s17_OPC_REGION_pre3_H
M7s17_OPC_REGION_pre5_H = (EXPAND EDGE M7s17_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M7s17_OPC_REGION_pre4_V BY GRID)
M7s17_OPC_REGION_pre5_V = (EXPAND EDGE M7s17_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M7s17_OPC_REGION_pre4_H BY GRID)
M7s17_OPC_REGION_pre6_H = DFM PROPERTY M7s17_OPC_REGION_pre5_H M7s17_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M7s17_OPC_REGION_pre1_H)] > M7_S_17_L1B
M7s17_OPC_REGION_pre6_V = DFM PROPERTY M7s17_OPC_REGION_pre5_V M7s17_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M7s17_OPC_REGION_pre1_V)] > M7_S_17_L1B
M7s17_OPC_REGION_pre7_H = M7s17_OPC_REGION_pre1_H INSIDE EDGE M7s17_OPC_REGION_pre6_H
M7s17_OPC_REGION_pre7_V = M7s17_OPC_REGION_pre1_V INSIDE EDGE M7s17_OPC_REGION_pre6_V
M7s17_OPC_REGION_pre2_H = EXT M7s17_OPC_REGION_pre7_H M7s17_CHECK_REGION < M7_S_17_S1B OPPOSITE REGION MEASURE ALL
M7s17_OPC_REGION_pre2_V = EXT M7s17_OPC_REGION_pre7_V M7s17_CHECK_REGION < M7_S_17_S1B OPPOSITE REGION MEASURE ALL

M7s17_M7_H = M7 INTERACT M7s17_OPC_REGION_pre2_H
M7s17_M7_V = M7 INTERACT M7s17_OPC_REGION_pre2_V
M7s17_M7_ALL = M7s17_M7_H OR M7s17_M7_V
M7s17_OPC_EDGE_H = ANGLE (M7s17_M7_H NOT OUTSIDE EDGE M7s17_OPC_REGION_pre2_H) == 0
M7s17_OPC_EDGE_V = ANGLE (M7s17_M7_V NOT OUTSIDE EDGE M7s17_OPC_REGION_pre2_V) == 90

Wide_M7s17_H = Wide_M7s17 INTERACT M7s17_OPC_REGION_pre2_H
Wide_M7s17_V = Wide_M7s17 INTERACT M7s17_OPC_REGION_pre2_V
Wide_M7s17_WI_JOG_H = (M7 AND (Wide_M7s17_H OR M7s17_OPC_REGION_pre2_H)) INTERACT Wide_M7s17_H
Wide_M7s17_WI_JOG_V = (M7 AND (Wide_M7s17_V OR M7s17_OPC_REGION_pre2_V)) INTERACT Wide_M7s17_V

Wide_M7s17_WI_EXT_EDGE_H = M7s17_OPC_EDGE_H NOT COIN EDGE (INT [M7s17_OPC_EDGE_H] M7s17_M7_H <= M7_S_17_W1B OPPOSITE)
Wide_M7s17_WI_EXT_EDGE_V = M7s17_OPC_EDGE_V NOT COIN EDGE (INT [M7s17_OPC_EDGE_V] M7s17_M7_V <= M7_S_17_W1B OPPOSITE)

M7s17_OPC_REGION_H = (EXT Wide_M7s17_WI_JOG_H M7s17_OPC_EDGE_H < M7_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s17_OPC_REGION_pre2_H
M7s17_OPC_REGION_V = (EXT Wide_M7s17_WI_JOG_V M7s17_OPC_EDGE_V < M7_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s17_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M7s17_SP_err1_REG_H = (EXT Wide_M7s17_WI_EXT_EDGE_H M7s17_M7_H < M7_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s17_OPC_REGION_H
M7s17_SP_err1_REG_V = (EXT Wide_M7s17_WI_EXT_EDGE_V M7s17_M7_V < M7_S_17_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s17_OPC_REGION_V
M7s17_EDGE_H_err3 = ANGLE M7s17_SP_err1_REG_H == 0
M7s17_EDGE_V_err3 = ANGLE M7s17_SP_err1_REG_V == 90
M7s17_SP_err1_REG_H_eff = DFM PROPERTY M7s17_SP_err1_REG_H M7s17_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M7s17_EDGE_H_err3)] <= 2*M7_S_17_L2A
M7s17_SP_err1_REG_V_eff = DFM PROPERTY M7s17_SP_err1_REG_V M7s17_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M7s17_EDGE_V_err3)] <= 2*M7_S_17_L2A

  M7s17_R1_CHK = EXT Wide_M7s17 M7s17_M7_ALL < M7_S_17_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M7s17_NOTCH_EDGE_H = ANGLE (EXT [Wide_M7s17_WI_JOG_H] < M7_S_17_S1B OPPOSITE NOTCH) == 0
  M7s17_NOTCH_EDGE_V = ANGLE (EXT [Wide_M7s17_WI_JOG_V] < M7_S_17_S1B OPPOSITE NOTCH) == 90
  M7s17_NOTCH_REGION_H = (EXT M7s17_NOTCH_EDGE_H < M7_S_17_S1B OPPOSITE REGION) AND M7s17_OPC_REGION_H
  M7s17_NOTCH_REGION_V = (EXT M7s17_NOTCH_EDGE_V < M7_S_17_S1B OPPOSITE REGION) AND M7s17_OPC_REGION_V
  
// Check NON-Notch region
  M7s17_SP_err1_REG_H_eff5 = M7s17_SP_err1_REG_H_eff NOT M7s17_NOTCH_REGION_H
  M7s17_SP_err1_REG_V_eff5 = M7s17_SP_err1_REG_V_eff NOT M7s17_NOTCH_REGION_V
  CONNECT M7s17_SP_err1_REG_H_eff5 (M7s17_OPC_REGION_H NOT M7s17_NOTCH_REGION_H)
  CONNECT M7s17_SP_err1_REG_V_eff5 (M7s17_OPC_REGION_V NOT M7s17_NOTCH_REGION_V)
  M7s17_SP_err1_REG_H_eff5a = M7s17_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M7s17_CHECK_REGION
  M7s17_SP_err1_REG_V_eff5a = M7s17_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M7s17_CHECK_REGION
  M7s17_S3C_NNH_H = (EXT M7s17_SP_err1_REG_H_eff5a < M7_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M7
  M7s17_S3C_NNH_V = (EXT M7s17_SP_err1_REG_V_eff5a < M7_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M7
  
// Check Notch H region
  M7s17_SP_err1_REG_H_eff6 = M7s17_SP_err1_REG_H_eff INSIDE M7s17_NOTCH_REGION_H
  M7s17_SP_err1_REG_V_eff6 = M7s17_SP_err1_REG_V_eff INSIDE M7s17_NOTCH_REGION_V
  CONNECT M7s17_SP_err1_REG_H_eff6 M7s17_NOTCH_REGION_H
  CONNECT M7s17_SP_err1_REG_V_eff6 M7s17_NOTCH_REGION_V  
  M7s17_SP_err1_REG_H_eff6a = M7s17_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M7s17_CHECK_REGION
  M7s17_SP_err1_REG_V_eff6a = M7s17_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M7s17_CHECK_REGION
  M7s17_S3C_NH_H = (EXT M7s17_SP_err1_REG_H_eff6a < M7_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M7
  M7s17_S3C_NH_V = (EXT M7s17_SP_err1_REG_V_eff6a < M7_S_17_S3C ABUT < 90 REGION CONNECTED) NOT M7

// Find Space error region(large space S2A2) //
M7s17_SP_err2_REG_H = (EXT Wide_M7s17_WI_EXT_EDGE_H M7s17_OPC_EDGE_H < M7_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s17_OPC_REGION_H
M7s17_SP_err2_REG_V = (EXT Wide_M7s17_WI_EXT_EDGE_V M7s17_OPC_EDGE_V < M7_S_17_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s17_OPC_REGION_V
M7s17_EDGE_H_err2 = M7s17_SP_err2_REG_H COIN EDGE M7s17_OPC_EDGE_H
M7s17_EDGE_V_err2 = M7s17_SP_err2_REG_V COIN EDGE M7s17_OPC_EDGE_V

M7s17_SP_err2_REG_H_eff1 = DFM PROPERTY M7s17_SP_err2_REG_H M7s17_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M7s17_EDGE_H_err2)] > 2*M7_S_17_L2A
M7s17_SP_err2_REG_V_eff1 = DFM PROPERTY M7s17_SP_err2_REG_V M7s17_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M7s17_EDGE_V_err2)] > 2*M7_S_17_L2A

// Find Space error region(small space S2A3) //
M7s17_SP_err3_REG_H = (EXT Wide_M7s17_WI_EXT_EDGE_H M7s17_OPC_EDGE_H < M7_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s17_OPC_REGION_H
M7s17_SP_err3_REG_V = (EXT Wide_M7s17_WI_EXT_EDGE_V M7s17_OPC_EDGE_V < M7_S_17_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s17_OPC_REGION_V


M7.S.17 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.47 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.13 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.47 um (W1B) and the parallel run length > 0.5 um (L1B) in metal space < 0.32 um (S1B) region >= 0.3 
  ((M7s17_SP_err1_REG_H_eff INTERACT M7s17_S3C_NNH_H) OR M7s17_S3C_NNH_H) INTERACT M7s17_R1_CHK
  ((M7s17_SP_err1_REG_H_eff INTERACT M7s17_S3C_NH_H) OR M7s17_S3C_NH_H) INTERACT M7s17_R1_CHK
  ((M7s17_SP_err1_REG_V_eff INTERACT M7s17_S3C_NNH_V) OR M7s17_S3C_NNH_V) INTERACT M7s17_R1_CHK
  ((M7s17_SP_err1_REG_V_eff INTERACT M7s17_S3C_NH_V) OR M7s17_S3C_NH_V) INTERACT M7s17_R1_CHK
}
M7.S.18 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.13 
  (M7s17_SP_err2_REG_H_eff1 AND M7s17_OPC_REGION_H) INTERACT Wide_M7s17_WI_JOG_H
  (M7s17_SP_err2_REG_V_eff1 AND M7s17_OPC_REGION_V) INTERACT Wide_M7s17_WI_JOG_V
}
M7.S.19 { @ Wide metal [width > 0.47 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M7s17_SP_err3_REG_H AND M7s17_OPC_REGION_H) INTERACT Wide_M7s17_WI_JOG_H
  (M7s17_SP_err3_REG_V AND M7s17_OPC_REGION_V) INTERACT Wide_M7s17_WI_JOG_V
}

// Wide M7s20 space error in OPC region checking
//====================================================

Wide_M7s20 = ENCLOSE RECTANGLE (SIZE M7 BY M7_S_20_W1B/2 UNDEROVER) M7_S_20_W1B+GRID M7_S_20_L1B+GRID ORTHOGONAL ONLY
M7s20_CHECK_REGION = M7 AND (SIZE Wide_M7s20 BY M7_S_20_S1B + GRID)
M7s20_OPC_REGION_pre1 = EXT [Wide_M7s20] M7s20_CHECK_REGION < M7_S_20_S1B OPPOSITE MEASURE ALL
M7s20_OPC_REGION_pre1_H = ANGLE M7s20_OPC_REGION_pre1 == 0
M7s20_OPC_REGION_pre1_V = ANGLE M7s20_OPC_REGION_pre1 == 90
M7s20_OPC_REGION_pre0_V = INT M7s20_OPC_REGION_pre1_H [Wide_M7s20] < GRID ABUT == 90 INTERSECTING ONLY 
M7s20_OPC_REGION_pre3_V = EXT M7s20_OPC_REGION_pre1_H [Wide_M7s20] < GRID ABUT == 90 INTERSECTING ONLY 
M7s20_OPC_REGION_pre4_V = (M7s20_CHECK_REGION TOUCH INSIDE EDGE M7s20_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M7s20_OPC_REGION_pre3_V
M7s20_OPC_REGION_pre0_H = INT M7s20_OPC_REGION_pre1_V [Wide_M7s20] < GRID ABUT == 90 INTERSECTING ONLY 
M7s20_OPC_REGION_pre3_H = EXT M7s20_OPC_REGION_pre1_V [Wide_M7s20] < GRID ABUT == 90 INTERSECTING ONLY 
M7s20_OPC_REGION_pre4_H = (M7s20_CHECK_REGION TOUCH INSIDE EDGE M7s20_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M7s20_OPC_REGION_pre3_H
M7s20_OPC_REGION_pre5_H = (EXPAND EDGE M7s20_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M7s20_OPC_REGION_pre4_V BY GRID)
M7s20_OPC_REGION_pre5_V = (EXPAND EDGE M7s20_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M7s20_OPC_REGION_pre4_H BY GRID)
M7s20_OPC_REGION_pre6_H = DFM PROPERTY M7s20_OPC_REGION_pre5_H M7s20_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M7s20_OPC_REGION_pre1_H)] > M7_S_20_L1B
M7s20_OPC_REGION_pre6_V = DFM PROPERTY M7s20_OPC_REGION_pre5_V M7s20_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M7s20_OPC_REGION_pre1_V)] > M7_S_20_L1B
M7s20_OPC_REGION_pre7_H = M7s20_OPC_REGION_pre1_H INSIDE EDGE M7s20_OPC_REGION_pre6_H
M7s20_OPC_REGION_pre7_V = M7s20_OPC_REGION_pre1_V INSIDE EDGE M7s20_OPC_REGION_pre6_V
M7s20_OPC_REGION_pre2_H = EXT M7s20_OPC_REGION_pre7_H M7s20_CHECK_REGION < M7_S_20_S1B OPPOSITE REGION MEASURE ALL
M7s20_OPC_REGION_pre2_V = EXT M7s20_OPC_REGION_pre7_V M7s20_CHECK_REGION < M7_S_20_S1B OPPOSITE REGION MEASURE ALL

M7s20_M7_H = M7 INTERACT M7s20_OPC_REGION_pre2_H
M7s20_M7_V = M7 INTERACT M7s20_OPC_REGION_pre2_V
M7s20_M7_ALL = M7s20_M7_H OR M7s20_M7_V
M7s20_OPC_EDGE_H = ANGLE (M7s20_M7_H NOT OUTSIDE EDGE M7s20_OPC_REGION_pre2_H) == 0
M7s20_OPC_EDGE_V = ANGLE (M7s20_M7_V NOT OUTSIDE EDGE M7s20_OPC_REGION_pre2_V) == 90

Wide_M7s20_H = Wide_M7s20 INTERACT M7s20_OPC_REGION_pre2_H
Wide_M7s20_V = Wide_M7s20 INTERACT M7s20_OPC_REGION_pre2_V
Wide_M7s20_WI_JOG_H = (M7 AND (Wide_M7s20_H OR M7s20_OPC_REGION_pre2_H)) INTERACT Wide_M7s20_H
Wide_M7s20_WI_JOG_V = (M7 AND (Wide_M7s20_V OR M7s20_OPC_REGION_pre2_V)) INTERACT Wide_M7s20_V

Wide_M7s20_WI_EXT_EDGE_H = M7s20_OPC_EDGE_H NOT COIN EDGE (INT [M7s20_OPC_EDGE_H] M7s20_M7_H <= M7_S_20_W1B OPPOSITE)
Wide_M7s20_WI_EXT_EDGE_V = M7s20_OPC_EDGE_V NOT COIN EDGE (INT [M7s20_OPC_EDGE_V] M7s20_M7_V <= M7_S_20_W1B OPPOSITE)

M7s20_OPC_REGION_H = (EXT Wide_M7s20_WI_JOG_H M7s20_OPC_EDGE_H < M7_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s20_OPC_REGION_pre2_H
M7s20_OPC_REGION_V = (EXT Wide_M7s20_WI_JOG_V M7s20_OPC_EDGE_V < M7_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s20_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M7s20_SP_err1_REG_H = (EXT Wide_M7s20_WI_EXT_EDGE_H M7s20_M7_H < M7_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s20_OPC_REGION_H
M7s20_SP_err1_REG_V = (EXT Wide_M7s20_WI_EXT_EDGE_V M7s20_M7_V < M7_S_20_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s20_OPC_REGION_V
M7s20_EDGE_H_err3 = ANGLE M7s20_SP_err1_REG_H == 0
M7s20_EDGE_V_err3 = ANGLE M7s20_SP_err1_REG_V == 90
M7s20_SP_err1_REG_H_eff = DFM PROPERTY M7s20_SP_err1_REG_H M7s20_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M7s20_EDGE_H_err3)] <= 2*M7_S_20_L2A
M7s20_SP_err1_REG_V_eff = DFM PROPERTY M7s20_SP_err1_REG_V M7s20_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M7s20_EDGE_V_err3)] <= 2*M7_S_20_L2A

  M7s20_R1_CHK = EXT Wide_M7s20 M7s20_M7_ALL < M7_S_20_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M7s20_NOTCH_EDGE_H = ANGLE (EXT [Wide_M7s20_WI_JOG_H] < M7_S_20_S1B OPPOSITE NOTCH) == 0
  M7s20_NOTCH_EDGE_V = ANGLE (EXT [Wide_M7s20_WI_JOG_V] < M7_S_20_S1B OPPOSITE NOTCH) == 90
  M7s20_NOTCH_REGION_H = (EXT M7s20_NOTCH_EDGE_H < M7_S_20_S1B OPPOSITE REGION) AND M7s20_OPC_REGION_H
  M7s20_NOTCH_REGION_V = (EXT M7s20_NOTCH_EDGE_V < M7_S_20_S1B OPPOSITE REGION) AND M7s20_OPC_REGION_V
  
// Check NON-Notch region
  M7s20_SP_err1_REG_H_eff5 = M7s20_SP_err1_REG_H_eff NOT M7s20_NOTCH_REGION_H
  M7s20_SP_err1_REG_V_eff5 = M7s20_SP_err1_REG_V_eff NOT M7s20_NOTCH_REGION_V
  CONNECT M7s20_SP_err1_REG_H_eff5 (M7s20_OPC_REGION_H NOT M7s20_NOTCH_REGION_H)
  CONNECT M7s20_SP_err1_REG_V_eff5 (M7s20_OPC_REGION_V NOT M7s20_NOTCH_REGION_V)
  M7s20_SP_err1_REG_H_eff5a = M7s20_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M7s20_CHECK_REGION
  M7s20_SP_err1_REG_V_eff5a = M7s20_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M7s20_CHECK_REGION
  M7s20_S3C_NNH_H = (EXT M7s20_SP_err1_REG_H_eff5a < M7_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M7
  M7s20_S3C_NNH_V = (EXT M7s20_SP_err1_REG_V_eff5a < M7_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M7
  
// Check Notch H region
  M7s20_SP_err1_REG_H_eff6 = M7s20_SP_err1_REG_H_eff INSIDE M7s20_NOTCH_REGION_H
  M7s20_SP_err1_REG_V_eff6 = M7s20_SP_err1_REG_V_eff INSIDE M7s20_NOTCH_REGION_V
  CONNECT M7s20_SP_err1_REG_H_eff6 M7s20_NOTCH_REGION_H
  CONNECT M7s20_SP_err1_REG_V_eff6 M7s20_NOTCH_REGION_V  
  M7s20_SP_err1_REG_H_eff6a = M7s20_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M7s20_CHECK_REGION
  M7s20_SP_err1_REG_V_eff6a = M7s20_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M7s20_CHECK_REGION
  M7s20_S3C_NH_H = (EXT M7s20_SP_err1_REG_H_eff6a < M7_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M7
  M7s20_S3C_NH_V = (EXT M7s20_SP_err1_REG_V_eff6a < M7_S_20_S3C ABUT < 90 REGION CONNECTED) NOT M7

// Find Space error region(large space S2A2) //
M7s20_SP_err2_REG_H = (EXT Wide_M7s20_WI_EXT_EDGE_H M7s20_OPC_EDGE_H < M7_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s20_OPC_REGION_H
M7s20_SP_err2_REG_V = (EXT Wide_M7s20_WI_EXT_EDGE_V M7s20_OPC_EDGE_V < M7_S_20_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s20_OPC_REGION_V
M7s20_EDGE_H_err2 = M7s20_SP_err2_REG_H COIN EDGE M7s20_OPC_EDGE_H
M7s20_EDGE_V_err2 = M7s20_SP_err2_REG_V COIN EDGE M7s20_OPC_EDGE_V

M7s20_SP_err2_REG_H_eff1 = DFM PROPERTY M7s20_SP_err2_REG_H M7s20_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M7s20_EDGE_H_err2)] > 2*M7_S_20_L2A
M7s20_SP_err2_REG_V_eff1 = DFM PROPERTY M7s20_SP_err2_REG_V M7s20_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M7s20_EDGE_V_err2)] > 2*M7_S_20_L2A

// Find Space error region(small space S2A3) //
M7s20_SP_err3_REG_H = (EXT Wide_M7s20_WI_EXT_EDGE_H M7s20_OPC_EDGE_H < M7_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s20_OPC_REGION_H
M7s20_SP_err3_REG_V = (EXT Wide_M7s20_WI_EXT_EDGE_V M7s20_OPC_EDGE_V < M7_S_20_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s20_OPC_REGION_V


M7.S.20 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.63 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.15 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.63 um (W1B) and the parallel run length > 0.7 um (L1B) in metal space < 0.34 um (S1B) region >= 0.3 
  ((M7s20_SP_err1_REG_H_eff INTERACT M7s20_S3C_NNH_H) OR M7s20_S3C_NNH_H) INTERACT M7s20_R1_CHK
  ((M7s20_SP_err1_REG_H_eff INTERACT M7s20_S3C_NH_H) OR M7s20_S3C_NH_H) INTERACT M7s20_R1_CHK
  ((M7s20_SP_err1_REG_V_eff INTERACT M7s20_S3C_NNH_V) OR M7s20_S3C_NNH_V) INTERACT M7s20_R1_CHK
  ((M7s20_SP_err1_REG_V_eff INTERACT M7s20_S3C_NH_V) OR M7s20_S3C_NH_V) INTERACT M7s20_R1_CHK
}
M7.S.21 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.15 
  (M7s20_SP_err2_REG_H_eff1 AND M7s20_OPC_REGION_H) INTERACT Wide_M7s20_WI_JOG_H
  (M7s20_SP_err2_REG_V_eff1 AND M7s20_OPC_REGION_V) INTERACT Wide_M7s20_WI_JOG_V
}
M7.S.22 { @ Wide metal [width > 0.63 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M7s20_SP_err3_REG_H AND M7s20_OPC_REGION_H) INTERACT Wide_M7s20_WI_JOG_H
  (M7s20_SP_err3_REG_V AND M7s20_OPC_REGION_V) INTERACT Wide_M7s20_WI_JOG_V
}

// Wide M7s23 space error in OPC region checking
//====================================================

Wide_M7s23 = ENCLOSE RECTANGLE (SIZE M7 BY M7_S_23_W1B/2 UNDEROVER) M7_S_23_W1B+GRID M7_S_23_L1B+GRID ORTHOGONAL ONLY
M7s23_CHECK_REGION = M7 AND (SIZE Wide_M7s23 BY M7_S_23_S1B + GRID)
M7s23_OPC_REGION_pre1 = EXT [Wide_M7s23] M7s23_CHECK_REGION < M7_S_23_S1B OPPOSITE MEASURE ALL
M7s23_OPC_REGION_pre1_H = ANGLE M7s23_OPC_REGION_pre1 == 0
M7s23_OPC_REGION_pre1_V = ANGLE M7s23_OPC_REGION_pre1 == 90
M7s23_OPC_REGION_pre0_V = INT M7s23_OPC_REGION_pre1_H [Wide_M7s23] < GRID ABUT == 90 INTERSECTING ONLY 
M7s23_OPC_REGION_pre3_V = EXT M7s23_OPC_REGION_pre1_H [Wide_M7s23] < GRID ABUT == 90 INTERSECTING ONLY 
M7s23_OPC_REGION_pre4_V = (M7s23_CHECK_REGION TOUCH INSIDE EDGE M7s23_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M7s23_OPC_REGION_pre3_V
M7s23_OPC_REGION_pre0_H = INT M7s23_OPC_REGION_pre1_V [Wide_M7s23] < GRID ABUT == 90 INTERSECTING ONLY 
M7s23_OPC_REGION_pre3_H = EXT M7s23_OPC_REGION_pre1_V [Wide_M7s23] < GRID ABUT == 90 INTERSECTING ONLY 
M7s23_OPC_REGION_pre4_H = (M7s23_CHECK_REGION TOUCH INSIDE EDGE M7s23_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M7s23_OPC_REGION_pre3_H
M7s23_OPC_REGION_pre5_H = (EXPAND EDGE M7s23_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M7s23_OPC_REGION_pre4_V BY GRID)
M7s23_OPC_REGION_pre5_V = (EXPAND EDGE M7s23_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M7s23_OPC_REGION_pre4_H BY GRID)
M7s23_OPC_REGION_pre6_H = DFM PROPERTY M7s23_OPC_REGION_pre5_H M7s23_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M7s23_OPC_REGION_pre1_H)] > M7_S_23_L1B
M7s23_OPC_REGION_pre6_V = DFM PROPERTY M7s23_OPC_REGION_pre5_V M7s23_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M7s23_OPC_REGION_pre1_V)] > M7_S_23_L1B
M7s23_OPC_REGION_pre7_H = M7s23_OPC_REGION_pre1_H INSIDE EDGE M7s23_OPC_REGION_pre6_H
M7s23_OPC_REGION_pre7_V = M7s23_OPC_REGION_pre1_V INSIDE EDGE M7s23_OPC_REGION_pre6_V
M7s23_OPC_REGION_pre2_H = EXT M7s23_OPC_REGION_pre7_H M7s23_CHECK_REGION < M7_S_23_S1B OPPOSITE REGION MEASURE ALL
M7s23_OPC_REGION_pre2_V = EXT M7s23_OPC_REGION_pre7_V M7s23_CHECK_REGION < M7_S_23_S1B OPPOSITE REGION MEASURE ALL

M7s23_M7_H = M7 INTERACT M7s23_OPC_REGION_pre2_H
M7s23_M7_V = M7 INTERACT M7s23_OPC_REGION_pre2_V
M7s23_M7_ALL = M7s23_M7_H OR M7s23_M7_V
M7s23_OPC_EDGE_H = ANGLE (M7s23_M7_H NOT OUTSIDE EDGE M7s23_OPC_REGION_pre2_H) == 0
M7s23_OPC_EDGE_V = ANGLE (M7s23_M7_V NOT OUTSIDE EDGE M7s23_OPC_REGION_pre2_V) == 90

Wide_M7s23_H = Wide_M7s23 INTERACT M7s23_OPC_REGION_pre2_H
Wide_M7s23_V = Wide_M7s23 INTERACT M7s23_OPC_REGION_pre2_V
Wide_M7s23_WI_JOG_H = (M7 AND (Wide_M7s23_H OR M7s23_OPC_REGION_pre2_H)) INTERACT Wide_M7s23_H
Wide_M7s23_WI_JOG_V = (M7 AND (Wide_M7s23_V OR M7s23_OPC_REGION_pre2_V)) INTERACT Wide_M7s23_V

Wide_M7s23_WI_EXT_EDGE_H = M7s23_OPC_EDGE_H NOT COIN EDGE (INT [M7s23_OPC_EDGE_H] M7s23_M7_H <= M7_S_23_W1B OPPOSITE)
Wide_M7s23_WI_EXT_EDGE_V = M7s23_OPC_EDGE_V NOT COIN EDGE (INT [M7s23_OPC_EDGE_V] M7s23_M7_V <= M7_S_23_W1B OPPOSITE)

M7s23_OPC_REGION_H = (EXT Wide_M7s23_WI_JOG_H M7s23_OPC_EDGE_H < M7_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s23_OPC_REGION_pre2_H
M7s23_OPC_REGION_V = (EXT Wide_M7s23_WI_JOG_V M7s23_OPC_EDGE_V < M7_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s23_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M7s23_SP_err1_REG_H = (EXT Wide_M7s23_WI_EXT_EDGE_H M7s23_M7_H < M7_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s23_OPC_REGION_H
M7s23_SP_err1_REG_V = (EXT Wide_M7s23_WI_EXT_EDGE_V M7s23_M7_V < M7_S_23_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s23_OPC_REGION_V
M7s23_EDGE_H_err3 = ANGLE M7s23_SP_err1_REG_H == 0
M7s23_EDGE_V_err3 = ANGLE M7s23_SP_err1_REG_V == 90
M7s23_SP_err1_REG_H_eff = DFM PROPERTY M7s23_SP_err1_REG_H M7s23_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M7s23_EDGE_H_err3)] <= 2*M7_S_23_L2A
M7s23_SP_err1_REG_V_eff = DFM PROPERTY M7s23_SP_err1_REG_V M7s23_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                            [-= LENGTH(M7s23_EDGE_V_err3)] <= 2*M7_S_23_L2A

  M7s23_R1_CHK = EXT Wide_M7s23 M7s23_M7_ALL < M7_S_23_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M7s23_NOTCH_EDGE_H = ANGLE (EXT [Wide_M7s23_WI_JOG_H] < M7_S_23_S1B OPPOSITE NOTCH) == 0
  M7s23_NOTCH_EDGE_V = ANGLE (EXT [Wide_M7s23_WI_JOG_V] < M7_S_23_S1B OPPOSITE NOTCH) == 90
  M7s23_NOTCH_REGION_H = (EXT M7s23_NOTCH_EDGE_H < M7_S_23_S1B OPPOSITE REGION) AND M7s23_OPC_REGION_H
  M7s23_NOTCH_REGION_V = (EXT M7s23_NOTCH_EDGE_V < M7_S_23_S1B OPPOSITE REGION) AND M7s23_OPC_REGION_V
  
// Check NON-Notch region
  M7s23_SP_err1_REG_H_eff5 = M7s23_SP_err1_REG_H_eff NOT M7s23_NOTCH_REGION_H
  M7s23_SP_err1_REG_V_eff5 = M7s23_SP_err1_REG_V_eff NOT M7s23_NOTCH_REGION_V
  CONNECT M7s23_SP_err1_REG_H_eff5 (M7s23_OPC_REGION_H NOT M7s23_NOTCH_REGION_H)
  CONNECT M7s23_SP_err1_REG_V_eff5 (M7s23_OPC_REGION_V NOT M7s23_NOTCH_REGION_V)
  M7s23_SP_err1_REG_H_eff5a = M7s23_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M7s23_CHECK_REGION
  M7s23_SP_err1_REG_V_eff5a = M7s23_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M7s23_CHECK_REGION
  M7s23_S3C_NNH_H = (EXT M7s23_SP_err1_REG_H_eff5a < M7_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M7
  M7s23_S3C_NNH_V = (EXT M7s23_SP_err1_REG_V_eff5a < M7_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M7
  
// Check Notch H region
  M7s23_SP_err1_REG_H_eff6 = M7s23_SP_err1_REG_H_eff INSIDE M7s23_NOTCH_REGION_H
  M7s23_SP_err1_REG_V_eff6 = M7s23_SP_err1_REG_V_eff INSIDE M7s23_NOTCH_REGION_V
  CONNECT M7s23_SP_err1_REG_H_eff6 M7s23_NOTCH_REGION_H
  CONNECT M7s23_SP_err1_REG_V_eff6 M7s23_NOTCH_REGION_V  
  M7s23_SP_err1_REG_H_eff6a = M7s23_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M7s23_CHECK_REGION
  M7s23_SP_err1_REG_V_eff6a = M7s23_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M7s23_CHECK_REGION
  M7s23_S3C_NH_H = (EXT M7s23_SP_err1_REG_H_eff6a < M7_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M7
  M7s23_S3C_NH_V = (EXT M7s23_SP_err1_REG_V_eff6a < M7_S_23_S3C ABUT < 90 REGION CONNECTED) NOT M7

// Find Space error region(large space S2A2) //
M7s23_SP_err2_REG_H = (EXT Wide_M7s23_WI_EXT_EDGE_H M7s23_OPC_EDGE_H < M7_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s23_OPC_REGION_H
M7s23_SP_err2_REG_V = (EXT Wide_M7s23_WI_EXT_EDGE_V M7s23_OPC_EDGE_V < M7_S_23_S2A2 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s23_OPC_REGION_V
M7s23_EDGE_H_err2 = M7s23_SP_err2_REG_H COIN EDGE M7s23_OPC_EDGE_H
M7s23_EDGE_V_err2 = M7s23_SP_err2_REG_V COIN EDGE M7s23_OPC_EDGE_V

M7s23_SP_err2_REG_H_eff1 = DFM PROPERTY M7s23_SP_err2_REG_H M7s23_EDGE_H_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M7s23_EDGE_H_err2)] > 2*M7_S_23_L2A
M7s23_SP_err2_REG_V_eff1 = DFM PROPERTY M7s23_SP_err2_REG_V M7s23_EDGE_V_err2 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M7s23_EDGE_V_err2)] > 2*M7_S_23_L2A

// Find Space error region(small space S2A3) //
M7s23_SP_err3_REG_H = (EXT Wide_M7s23_WI_EXT_EDGE_H M7s23_OPC_EDGE_H < M7_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s23_OPC_REGION_H
M7s23_SP_err3_REG_V = (EXT Wide_M7s23_WI_EXT_EDGE_V M7s23_OPC_EDGE_V < M7_S_23_S2A3 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s23_OPC_REGION_V


M7.S.23 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 1.5 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.3 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 1.5 um (W1B) and the parallel run length > 1.5 um (L1B) in metal space < 0.5 um (S1B) region >= 0.3 
  ((M7s23_SP_err1_REG_H_eff INTERACT M7s23_S3C_NNH_H) OR M7s23_S3C_NNH_H) INTERACT M7s23_R1_CHK
  ((M7s23_SP_err1_REG_H_eff INTERACT M7s23_S3C_NH_H) OR M7s23_S3C_NH_H) INTERACT M7s23_R1_CHK
  ((M7s23_SP_err1_REG_V_eff INTERACT M7s23_S3C_NNH_V) OR M7s23_S3C_NNH_V) INTERACT M7s23_R1_CHK
  ((M7s23_SP_err1_REG_V_eff INTERACT M7s23_S3C_NH_V) OR M7s23_S3C_NH_V) INTERACT M7s23_R1_CHK
}
M7.S.24 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length > 0.22 um (L2A)] in wide metal space regionB >= 0.3 
  (M7s23_SP_err2_REG_H_eff1 AND M7s23_OPC_REGION_H) INTERACT Wide_M7s23_WI_JOG_H
  (M7s23_SP_err2_REG_V_eff1 AND M7s23_OPC_REGION_V) INTERACT Wide_M7s23_WI_JOG_V
}
M7.S.25 { @ Wide metal [width > 1.5 um (W1B)] space to metal [parallel run length <= 0.22 um (L2A)] in wide metal space regionB >= 0.06 
  (M7s23_SP_err3_REG_H AND M7s23_OPC_REGION_H) INTERACT Wide_M7s23_WI_JOG_H
  (M7s23_SP_err3_REG_V AND M7s23_OPC_REGION_V) INTERACT Wide_M7s23_WI_JOG_V
}

#ENDIF //BACK_END


#IFDEF M1_V1_M2_CHECKS
// Wide M1s27 space error in OPC region checking
//====================================================

Wide_M1s27 = ENCLOSE RECTANGLE (SIZE M1 BY M1_S_27_W1B/2 UNDEROVER) M1_S_27_W1B+GRID M1_S_27_L1B+GRID ORTHOGONAL ONLY
M1s27_CHECK_REGION = M1 AND (SIZE Wide_M1s27 BY M1_S_27_S1B + GRID)
M1s27_OPC_REGION_pre1 = EXT [Wide_M1s27] M1s27_CHECK_REGION < M1_S_27_S1B OPPOSITE MEASURE ALL
M1s27_OPC_REGION_pre1_H = ANGLE M1s27_OPC_REGION_pre1 == 0
M1s27_OPC_REGION_pre1_V = ANGLE M1s27_OPC_REGION_pre1 == 90
M1s27_OPC_REGION_pre0_V = INT M1s27_OPC_REGION_pre1_H [Wide_M1s27] < GRID ABUT == 90 INTERSECTING ONLY
M1s27_OPC_REGION_pre3_V = EXT M1s27_OPC_REGION_pre1_H [Wide_M1s27] < GRID ABUT == 90 INTERSECTING ONLY
M1s27_OPC_REGION_pre4_V = (M1s27_CHECK_REGION TOUCH INSIDE EDGE M1s27_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M1s27_OPC_REGION_pre3_V
M1s27_OPC_REGION_pre0_H = INT M1s27_OPC_REGION_pre1_V [Wide_M1s27] < GRID ABUT == 90 INTERSECTING ONLY
M1s27_OPC_REGION_pre3_H = EXT M1s27_OPC_REGION_pre1_V [Wide_M1s27] < GRID ABUT == 90 INTERSECTING ONLY
M1s27_OPC_REGION_pre4_H = (M1s27_CHECK_REGION TOUCH INSIDE EDGE M1s27_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M1s27_OPC_REGION_pre3_H
M1s27_OPC_REGION_pre5_H = (EXPAND EDGE M1s27_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M1s27_OPC_REGION_pre4_V BY GRID)
M1s27_OPC_REGION_pre5_V = (EXPAND EDGE M1s27_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M1s27_OPC_REGION_pre4_H BY GRID)
M1s27_OPC_REGION_pre6_H = DFM PROPERTY M1s27_OPC_REGION_pre5_H M1s27_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M1s27_OPC_REGION_pre1_H)] > M1_S_27_L1B
M1s27_OPC_REGION_pre6_V = DFM PROPERTY M1s27_OPC_REGION_pre5_V M1s27_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M1s27_OPC_REGION_pre1_V)] > M1_S_27_L1B
M1s27_OPC_REGION_pre7_H = M1s27_OPC_REGION_pre1_H INSIDE EDGE M1s27_OPC_REGION_pre6_H
M1s27_OPC_REGION_pre7_V = M1s27_OPC_REGION_pre1_V INSIDE EDGE M1s27_OPC_REGION_pre6_V
M1s27_OPC_REGION_pre2_H = EXT M1s27_OPC_REGION_pre7_H M1s27_CHECK_REGION < M1_S_27_S1B OPPOSITE REGION MEASURE ALL
M1s27_OPC_REGION_pre2_V = EXT M1s27_OPC_REGION_pre7_V M1s27_CHECK_REGION < M1_S_27_S1B OPPOSITE REGION MEASURE ALL

M1s27_M1_H = M1 INTERACT M1s27_OPC_REGION_pre2_H
M1s27_M1_V = M1 INTERACT M1s27_OPC_REGION_pre2_V
M1s27_M1_ALL = M1s27_M1_H OR M1s27_M1_V
M1s27_OPC_EDGE_H = ANGLE (M1s27_M1_H NOT OUTSIDE EDGE M1s27_OPC_REGION_pre2_H) == 0
M1s27_OPC_EDGE_V = ANGLE (M1s27_M1_V NOT OUTSIDE EDGE M1s27_OPC_REGION_pre2_V) == 90

Wide_M1s27_H = Wide_M1s27 INTERACT M1s27_OPC_REGION_pre2_H
Wide_M1s27_V = Wide_M1s27 INTERACT M1s27_OPC_REGION_pre2_V
Wide_M1s27_WI_JOG_H = (M1 AND (Wide_M1s27_H OR M1s27_OPC_REGION_pre2_H)) INTERACT Wide_M1s27_H
Wide_M1s27_WI_JOG_V = (M1 AND (Wide_M1s27_V OR M1s27_OPC_REGION_pre2_V)) INTERACT Wide_M1s27_V

Wide_M1s27_WI_EXT_EDGE_H = M1s27_OPC_EDGE_H NOT COIN EDGE (INT [M1s27_OPC_EDGE_H] M1s27_M1_H <= M1_S_27_W1B OPPOSITE)
Wide_M1s27_WI_EXT_EDGE_V = M1s27_OPC_EDGE_V NOT COIN EDGE (INT [M1s27_OPC_EDGE_V] M1s27_M1_V <= M1_S_27_W1B OPPOSITE)

M1s27_OPC_REGION_H = (EXT Wide_M1s27_WI_JOG_H M1s27_OPC_EDGE_H < M1_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s27_OPC_REGION_pre2_H
M1s27_OPC_REGION_V = (EXT Wide_M1s27_WI_JOG_V M1s27_OPC_EDGE_V < M1_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s27_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M1s27_SP_err1_REG_H = (EXT Wide_M1s27_WI_EXT_EDGE_H M1s27_M1_H < M1_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s27_OPC_REGION_H
M1s27_SP_err1_REG_V = (EXT Wide_M1s27_WI_EXT_EDGE_V M1s27_M1_V < M1_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M1s27_OPC_REGION_V

M1s27_EDGE_H_err3 = ANGLE M1s27_SP_err1_REG_H == 0
M1s27_EDGE_V_err3 = ANGLE M1s27_SP_err1_REG_V == 90
M1s27_SP_err1_REG_H_eff = DFM PROPERTY M1s27_SP_err1_REG_H M1s27_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M1s27_EDGE_H_err3)] <= 2*M1_S_27_L2A
M1s27_SP_err1_REG_V_eff = DFM PROPERTY M1s27_SP_err1_REG_V M1s27_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M1s27_EDGE_V_err3)] <= 2*M1_S_27_L2A
			       
  M1s27_R1_CHK = EXT Wide_M1s27 M1s27_M1_ALL < M1_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M1s27_NOTCH_EDGE_H = ANGLE (EXT [Wide_M1s27_WI_JOG_H] < M1_S_27_S1B OPPOSITE NOTCH) == 0
  M1s27_NOTCH_EDGE_V = ANGLE (EXT [Wide_M1s27_WI_JOG_V] < M1_S_27_S1B OPPOSITE NOTCH) == 90
  M1s27_NOTCH_REGION_H = (EXT M1s27_NOTCH_EDGE_H < M1_S_27_S1B OPPOSITE REGION) AND M1s27_OPC_REGION_H
  M1s27_NOTCH_REGION_V = (EXT M1s27_NOTCH_EDGE_V < M1_S_27_S1B OPPOSITE REGION) AND M1s27_OPC_REGION_V
  
// Check NON-Notch region
  M1s27_SP_err1_REG_H_eff5 = M1s27_SP_err1_REG_H_eff NOT M1s27_NOTCH_REGION_H
  M1s27_SP_err1_REG_V_eff5 = M1s27_SP_err1_REG_V_eff NOT M1s27_NOTCH_REGION_V
  CONNECT M1s27_SP_err1_REG_H_eff5 (M1s27_OPC_REGION_H NOT M1s27_NOTCH_REGION_H)
  CONNECT M1s27_SP_err1_REG_V_eff5 (M1s27_OPC_REGION_V NOT M1s27_NOTCH_REGION_V)
  M1s27_SP_err1_REG_H_eff5a = M1s27_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M1s27_CHECK_REGION
  M1s27_SP_err1_REG_V_eff5a = M1s27_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M1s27_CHECK_REGION
  M1s27_S3C_NNH_H = (EXT M1s27_SP_err1_REG_H_eff5a < M1_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M1
  M1s27_S3C_NNH_V = (EXT M1s27_SP_err1_REG_V_eff5a < M1_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M1

// Check Notch H region
  M1s27_SP_err1_REG_H_eff6 = M1s27_SP_err1_REG_H_eff INSIDE M1s27_NOTCH_REGION_H
  M1s27_SP_err1_REG_V_eff6 = M1s27_SP_err1_REG_V_eff INSIDE M1s27_NOTCH_REGION_V
  CONNECT M1s27_SP_err1_REG_H_eff6 M1s27_NOTCH_REGION_H
  CONNECT M1s27_SP_err1_REG_V_eff6 M1s27_NOTCH_REGION_V  
  M1s27_SP_err1_REG_H_eff6a = M1s27_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M1s27_CHECK_REGION
  M1s27_SP_err1_REG_V_eff6a = M1s27_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M1s27_CHECK_REGION
  M1s27_S3C_NH_H = (EXT M1s27_SP_err1_REG_H_eff6a < M1_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M1
  M1s27_S3C_NH_V = (EXT M1s27_SP_err1_REG_V_eff6a < M1_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M1

M1.S.27 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.1 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.19 um (S1B) region >= 0.3 
  ((M1s27_SP_err1_REG_H_eff INTERACT M1s27_S3C_NNH_H) OR M1s27_S3C_NNH_H) INTERACT M1s27_R1_CHK
  ((M1s27_SP_err1_REG_H_eff INTERACT M1s27_S3C_NH_H) OR M1s27_S3C_NH_H) INTERACT M1s27_R1_CHK
  ((M1s27_SP_err1_REG_V_eff INTERACT M1s27_S3C_NNH_V) OR M1s27_S3C_NNH_V) INTERACT M1s27_R1_CHK
  ((M1s27_SP_err1_REG_V_eff INTERACT M1s27_S3C_NH_V) OR M1s27_S3C_NH_V) INTERACT M1s27_R1_CHK
}


// Wide M2s27 space error in OPC region checking
//====================================================

Wide_M2s27 = ENCLOSE RECTANGLE (SIZE M2 BY M2_S_27_W1B/2 UNDEROVER) M2_S_27_W1B+GRID M2_S_27_L1B+GRID ORTHOGONAL ONLY
M2s27_CHECK_REGION = M2 AND (SIZE Wide_M2s27 BY M2_S_27_S1B + GRID)
M2s27_OPC_REGION_pre1 = EXT [Wide_M2s27] M2s27_CHECK_REGION < M2_S_27_S1B OPPOSITE MEASURE ALL
M2s27_OPC_REGION_pre1_H = ANGLE M2s27_OPC_REGION_pre1 == 0
M2s27_OPC_REGION_pre1_V = ANGLE M2s27_OPC_REGION_pre1 == 90
M2s27_OPC_REGION_pre0_V = INT M2s27_OPC_REGION_pre1_H [Wide_M2s27] < GRID ABUT == 90 INTERSECTING ONLY
M2s27_OPC_REGION_pre3_V = EXT M2s27_OPC_REGION_pre1_H [Wide_M2s27] < GRID ABUT == 90 INTERSECTING ONLY
M2s27_OPC_REGION_pre4_V = (M2s27_CHECK_REGION TOUCH INSIDE EDGE M2s27_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M2s27_OPC_REGION_pre3_V
M2s27_OPC_REGION_pre0_H = INT M2s27_OPC_REGION_pre1_V [Wide_M2s27] < GRID ABUT == 90 INTERSECTING ONLY
M2s27_OPC_REGION_pre3_H = EXT M2s27_OPC_REGION_pre1_V [Wide_M2s27] < GRID ABUT == 90 INTERSECTING ONLY
M2s27_OPC_REGION_pre4_H = (M2s27_CHECK_REGION TOUCH INSIDE EDGE M2s27_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M2s27_OPC_REGION_pre3_H
M2s27_OPC_REGION_pre5_H = (EXPAND EDGE M2s27_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M2s27_OPC_REGION_pre4_V BY GRID)
M2s27_OPC_REGION_pre5_V = (EXPAND EDGE M2s27_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M2s27_OPC_REGION_pre4_H BY GRID)
M2s27_OPC_REGION_pre6_H = DFM PROPERTY M2s27_OPC_REGION_pre5_H M2s27_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M2s27_OPC_REGION_pre1_H)] > M2_S_27_L1B
M2s27_OPC_REGION_pre6_V = DFM PROPERTY M2s27_OPC_REGION_pre5_V M2s27_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M2s27_OPC_REGION_pre1_V)] > M2_S_27_L1B
M2s27_OPC_REGION_pre7_H = M2s27_OPC_REGION_pre1_H INSIDE EDGE M2s27_OPC_REGION_pre6_H
M2s27_OPC_REGION_pre7_V = M2s27_OPC_REGION_pre1_V INSIDE EDGE M2s27_OPC_REGION_pre6_V
M2s27_OPC_REGION_pre2_H = EXT M2s27_OPC_REGION_pre7_H M2s27_CHECK_REGION < M2_S_27_S1B OPPOSITE REGION MEASURE ALL
M2s27_OPC_REGION_pre2_V = EXT M2s27_OPC_REGION_pre7_V M2s27_CHECK_REGION < M2_S_27_S1B OPPOSITE REGION MEASURE ALL

M2s27_M2_H = M2 INTERACT M2s27_OPC_REGION_pre2_H
M2s27_M2_V = M2 INTERACT M2s27_OPC_REGION_pre2_V
M2s27_M2_ALL = M2s27_M2_H OR M2s27_M2_V
M2s27_OPC_EDGE_H = ANGLE (M2s27_M2_H NOT OUTSIDE EDGE M2s27_OPC_REGION_pre2_H) == 0
M2s27_OPC_EDGE_V = ANGLE (M2s27_M2_V NOT OUTSIDE EDGE M2s27_OPC_REGION_pre2_V) == 90

Wide_M2s27_H = Wide_M2s27 INTERACT M2s27_OPC_REGION_pre2_H
Wide_M2s27_V = Wide_M2s27 INTERACT M2s27_OPC_REGION_pre2_V
Wide_M2s27_WI_JOG_H = (M2 AND (Wide_M2s27_H OR M2s27_OPC_REGION_pre2_H)) INTERACT Wide_M2s27_H
Wide_M2s27_WI_JOG_V = (M2 AND (Wide_M2s27_V OR M2s27_OPC_REGION_pre2_V)) INTERACT Wide_M2s27_V

Wide_M2s27_WI_EXT_EDGE_H = M2s27_OPC_EDGE_H NOT COIN EDGE (INT [M2s27_OPC_EDGE_H] M2s27_M2_H <= M2_S_27_W1B OPPOSITE)
Wide_M2s27_WI_EXT_EDGE_V = M2s27_OPC_EDGE_V NOT COIN EDGE (INT [M2s27_OPC_EDGE_V] M2s27_M2_V <= M2_S_27_W1B OPPOSITE)

M2s27_OPC_REGION_H = (EXT Wide_M2s27_WI_JOG_H M2s27_OPC_EDGE_H < M2_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s27_OPC_REGION_pre2_H
M2s27_OPC_REGION_V = (EXT Wide_M2s27_WI_JOG_V M2s27_OPC_EDGE_V < M2_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s27_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M2s27_SP_err1_REG_H = (EXT Wide_M2s27_WI_EXT_EDGE_H M2s27_M2_H < M2_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s27_OPC_REGION_H
M2s27_SP_err1_REG_V = (EXT Wide_M2s27_WI_EXT_EDGE_V M2s27_M2_V < M2_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M2s27_OPC_REGION_V

M2s27_EDGE_H_err3 = ANGLE M2s27_SP_err1_REG_H == 0
M2s27_EDGE_V_err3 = ANGLE M2s27_SP_err1_REG_V == 90
M2s27_SP_err1_REG_H_eff = DFM PROPERTY M2s27_SP_err1_REG_H M2s27_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M2s27_EDGE_H_err3)] <= 2*M2_S_27_L2A
M2s27_SP_err1_REG_V_eff = DFM PROPERTY M2s27_SP_err1_REG_V M2s27_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M2s27_EDGE_V_err3)] <= 2*M2_S_27_L2A
			       
  M2s27_R1_CHK = EXT Wide_M2s27 M2s27_M2_ALL < M2_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M2s27_NOTCH_EDGE_H = ANGLE (EXT [Wide_M2s27_WI_JOG_H] < M2_S_27_S1B OPPOSITE NOTCH) == 0
  M2s27_NOTCH_EDGE_V = ANGLE (EXT [Wide_M2s27_WI_JOG_V] < M2_S_27_S1B OPPOSITE NOTCH) == 90
  M2s27_NOTCH_REGION_H = (EXT M2s27_NOTCH_EDGE_H < M2_S_27_S1B OPPOSITE REGION) AND M2s27_OPC_REGION_H
  M2s27_NOTCH_REGION_V = (EXT M2s27_NOTCH_EDGE_V < M2_S_27_S1B OPPOSITE REGION) AND M2s27_OPC_REGION_V
  
// Check NON-Notch region
  M2s27_SP_err1_REG_H_eff5 = M2s27_SP_err1_REG_H_eff NOT M2s27_NOTCH_REGION_H
  M2s27_SP_err1_REG_V_eff5 = M2s27_SP_err1_REG_V_eff NOT M2s27_NOTCH_REGION_V
  CONNECT M2s27_SP_err1_REG_H_eff5 (M2s27_OPC_REGION_H NOT M2s27_NOTCH_REGION_H)
  CONNECT M2s27_SP_err1_REG_V_eff5 (M2s27_OPC_REGION_V NOT M2s27_NOTCH_REGION_V)
  M2s27_SP_err1_REG_H_eff5a = M2s27_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M2s27_CHECK_REGION
  M2s27_SP_err1_REG_V_eff5a = M2s27_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M2s27_CHECK_REGION
  M2s27_S3C_NNH_H = (EXT M2s27_SP_err1_REG_H_eff5a < M2_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M2
  M2s27_S3C_NNH_V = (EXT M2s27_SP_err1_REG_V_eff5a < M2_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M2

// Check Notch H region
  M2s27_SP_err1_REG_H_eff6 = M2s27_SP_err1_REG_H_eff INSIDE M2s27_NOTCH_REGION_H
  M2s27_SP_err1_REG_V_eff6 = M2s27_SP_err1_REG_V_eff INSIDE M2s27_NOTCH_REGION_V
  CONNECT M2s27_SP_err1_REG_H_eff6 M2s27_NOTCH_REGION_H
  CONNECT M2s27_SP_err1_REG_V_eff6 M2s27_NOTCH_REGION_V  
  M2s27_SP_err1_REG_H_eff6a = M2s27_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M2s27_CHECK_REGION
  M2s27_SP_err1_REG_V_eff6a = M2s27_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M2s27_CHECK_REGION
  M2s27_S3C_NH_H = (EXT M2s27_SP_err1_REG_H_eff6a < M2_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M2
  M2s27_S3C_NH_V = (EXT M2s27_SP_err1_REG_V_eff6a < M2_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M2

M2.S.27 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.1 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.19 um (S1B) region >= 0.3 
  ((M2s27_SP_err1_REG_H_eff INTERACT M2s27_S3C_NNH_H) OR M2s27_S3C_NNH_H) INTERACT M2s27_R1_CHK
  ((M2s27_SP_err1_REG_H_eff INTERACT M2s27_S3C_NH_H) OR M2s27_S3C_NH_H) INTERACT M2s27_R1_CHK
  ((M2s27_SP_err1_REG_V_eff INTERACT M2s27_S3C_NNH_V) OR M2s27_S3C_NNH_V) INTERACT M2s27_R1_CHK
  ((M2s27_SP_err1_REG_V_eff INTERACT M2s27_S3C_NH_V) OR M2s27_S3C_NH_V) INTERACT M2s27_R1_CHK
}

#ENDIF //M1_V1_M2_CHECKS

#IFDEF BACK_END
// Wide M3s27 space error in OPC region checking
//====================================================

Wide_M3s27 = ENCLOSE RECTANGLE (SIZE M3 BY M3_S_27_W1B/2 UNDEROVER) M3_S_27_W1B+GRID M3_S_27_L1B+GRID ORTHOGONAL ONLY
M3s27_CHECK_REGION = M3 AND (SIZE Wide_M3s27 BY M3_S_27_S1B + GRID)
M3s27_OPC_REGION_pre1 = EXT [Wide_M3s27] M3s27_CHECK_REGION < M3_S_27_S1B OPPOSITE MEASURE ALL
M3s27_OPC_REGION_pre1_H = ANGLE M3s27_OPC_REGION_pre1 == 0
M3s27_OPC_REGION_pre1_V = ANGLE M3s27_OPC_REGION_pre1 == 90
M3s27_OPC_REGION_pre0_V = INT M3s27_OPC_REGION_pre1_H [Wide_M3s27] < GRID ABUT == 90 INTERSECTING ONLY
M3s27_OPC_REGION_pre3_V = EXT M3s27_OPC_REGION_pre1_H [Wide_M3s27] < GRID ABUT == 90 INTERSECTING ONLY
M3s27_OPC_REGION_pre4_V = (M3s27_CHECK_REGION TOUCH INSIDE EDGE M3s27_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M3s27_OPC_REGION_pre3_V
M3s27_OPC_REGION_pre0_H = INT M3s27_OPC_REGION_pre1_V [Wide_M3s27] < GRID ABUT == 90 INTERSECTING ONLY
M3s27_OPC_REGION_pre3_H = EXT M3s27_OPC_REGION_pre1_V [Wide_M3s27] < GRID ABUT == 90 INTERSECTING ONLY
M3s27_OPC_REGION_pre4_H = (M3s27_CHECK_REGION TOUCH INSIDE EDGE M3s27_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M3s27_OPC_REGION_pre3_H
M3s27_OPC_REGION_pre5_H = (EXPAND EDGE M3s27_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M3s27_OPC_REGION_pre4_V BY GRID)
M3s27_OPC_REGION_pre5_V = (EXPAND EDGE M3s27_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M3s27_OPC_REGION_pre4_H BY GRID)
M3s27_OPC_REGION_pre6_H = DFM PROPERTY M3s27_OPC_REGION_pre5_H M3s27_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M3s27_OPC_REGION_pre1_H)] > M3_S_27_L1B
M3s27_OPC_REGION_pre6_V = DFM PROPERTY M3s27_OPC_REGION_pre5_V M3s27_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M3s27_OPC_REGION_pre1_V)] > M3_S_27_L1B
M3s27_OPC_REGION_pre7_H = M3s27_OPC_REGION_pre1_H INSIDE EDGE M3s27_OPC_REGION_pre6_H
M3s27_OPC_REGION_pre7_V = M3s27_OPC_REGION_pre1_V INSIDE EDGE M3s27_OPC_REGION_pre6_V
M3s27_OPC_REGION_pre2_H = EXT M3s27_OPC_REGION_pre7_H M3s27_CHECK_REGION < M3_S_27_S1B OPPOSITE REGION MEASURE ALL
M3s27_OPC_REGION_pre2_V = EXT M3s27_OPC_REGION_pre7_V M3s27_CHECK_REGION < M3_S_27_S1B OPPOSITE REGION MEASURE ALL

M3s27_M3_H = M3 INTERACT M3s27_OPC_REGION_pre2_H
M3s27_M3_V = M3 INTERACT M3s27_OPC_REGION_pre2_V
M3s27_M3_ALL = M3s27_M3_H OR M3s27_M3_V
M3s27_OPC_EDGE_H = ANGLE (M3s27_M3_H NOT OUTSIDE EDGE M3s27_OPC_REGION_pre2_H) == 0
M3s27_OPC_EDGE_V = ANGLE (M3s27_M3_V NOT OUTSIDE EDGE M3s27_OPC_REGION_pre2_V) == 90

Wide_M3s27_H = Wide_M3s27 INTERACT M3s27_OPC_REGION_pre2_H
Wide_M3s27_V = Wide_M3s27 INTERACT M3s27_OPC_REGION_pre2_V
Wide_M3s27_WI_JOG_H = (M3 AND (Wide_M3s27_H OR M3s27_OPC_REGION_pre2_H)) INTERACT Wide_M3s27_H
Wide_M3s27_WI_JOG_V = (M3 AND (Wide_M3s27_V OR M3s27_OPC_REGION_pre2_V)) INTERACT Wide_M3s27_V

Wide_M3s27_WI_EXT_EDGE_H = M3s27_OPC_EDGE_H NOT COIN EDGE (INT [M3s27_OPC_EDGE_H] M3s27_M3_H <= M3_S_27_W1B OPPOSITE)
Wide_M3s27_WI_EXT_EDGE_V = M3s27_OPC_EDGE_V NOT COIN EDGE (INT [M3s27_OPC_EDGE_V] M3s27_M3_V <= M3_S_27_W1B OPPOSITE)

M3s27_OPC_REGION_H = (EXT Wide_M3s27_WI_JOG_H M3s27_OPC_EDGE_H < M3_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s27_OPC_REGION_pre2_H
M3s27_OPC_REGION_V = (EXT Wide_M3s27_WI_JOG_V M3s27_OPC_EDGE_V < M3_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s27_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M3s27_SP_err1_REG_H = (EXT Wide_M3s27_WI_EXT_EDGE_H M3s27_M3_H < M3_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s27_OPC_REGION_H
M3s27_SP_err1_REG_V = (EXT Wide_M3s27_WI_EXT_EDGE_V M3s27_M3_V < M3_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M3s27_OPC_REGION_V

M3s27_EDGE_H_err3 = ANGLE M3s27_SP_err1_REG_H == 0
M3s27_EDGE_V_err3 = ANGLE M3s27_SP_err1_REG_V == 90
M3s27_SP_err1_REG_H_eff = DFM PROPERTY M3s27_SP_err1_REG_H M3s27_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M3s27_EDGE_H_err3)] <= 2*M3_S_27_L2A
M3s27_SP_err1_REG_V_eff = DFM PROPERTY M3s27_SP_err1_REG_V M3s27_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M3s27_EDGE_V_err3)] <= 2*M3_S_27_L2A
			       
  M3s27_R1_CHK = EXT Wide_M3s27 M3s27_M3_ALL < M3_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M3s27_NOTCH_EDGE_H = ANGLE (EXT [Wide_M3s27_WI_JOG_H] < M3_S_27_S1B OPPOSITE NOTCH) == 0
  M3s27_NOTCH_EDGE_V = ANGLE (EXT [Wide_M3s27_WI_JOG_V] < M3_S_27_S1B OPPOSITE NOTCH) == 90
  M3s27_NOTCH_REGION_H = (EXT M3s27_NOTCH_EDGE_H < M3_S_27_S1B OPPOSITE REGION) AND M3s27_OPC_REGION_H
  M3s27_NOTCH_REGION_V = (EXT M3s27_NOTCH_EDGE_V < M3_S_27_S1B OPPOSITE REGION) AND M3s27_OPC_REGION_V
  
// Check NON-Notch region
  M3s27_SP_err1_REG_H_eff5 = M3s27_SP_err1_REG_H_eff NOT M3s27_NOTCH_REGION_H
  M3s27_SP_err1_REG_V_eff5 = M3s27_SP_err1_REG_V_eff NOT M3s27_NOTCH_REGION_V
  CONNECT M3s27_SP_err1_REG_H_eff5 (M3s27_OPC_REGION_H NOT M3s27_NOTCH_REGION_H)
  CONNECT M3s27_SP_err1_REG_V_eff5 (M3s27_OPC_REGION_V NOT M3s27_NOTCH_REGION_V)
  M3s27_SP_err1_REG_H_eff5a = M3s27_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M3s27_CHECK_REGION
  M3s27_SP_err1_REG_V_eff5a = M3s27_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M3s27_CHECK_REGION
  M3s27_S3C_NNH_H = (EXT M3s27_SP_err1_REG_H_eff5a < M3_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M3
  M3s27_S3C_NNH_V = (EXT M3s27_SP_err1_REG_V_eff5a < M3_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M3

// Check Notch H region
  M3s27_SP_err1_REG_H_eff6 = M3s27_SP_err1_REG_H_eff INSIDE M3s27_NOTCH_REGION_H
  M3s27_SP_err1_REG_V_eff6 = M3s27_SP_err1_REG_V_eff INSIDE M3s27_NOTCH_REGION_V
  CONNECT M3s27_SP_err1_REG_H_eff6 M3s27_NOTCH_REGION_H
  CONNECT M3s27_SP_err1_REG_V_eff6 M3s27_NOTCH_REGION_V  
  M3s27_SP_err1_REG_H_eff6a = M3s27_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M3s27_CHECK_REGION
  M3s27_SP_err1_REG_V_eff6a = M3s27_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M3s27_CHECK_REGION
  M3s27_S3C_NH_H = (EXT M3s27_SP_err1_REG_H_eff6a < M3_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M3
  M3s27_S3C_NH_V = (EXT M3s27_SP_err1_REG_V_eff6a < M3_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M3

M3.S.27 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.1 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.19 um (S1B) region >= 0.3 
  ((M3s27_SP_err1_REG_H_eff INTERACT M3s27_S3C_NNH_H) OR M3s27_S3C_NNH_H) INTERACT M3s27_R1_CHK
  ((M3s27_SP_err1_REG_H_eff INTERACT M3s27_S3C_NH_H) OR M3s27_S3C_NH_H) INTERACT M3s27_R1_CHK
  ((M3s27_SP_err1_REG_V_eff INTERACT M3s27_S3C_NNH_V) OR M3s27_S3C_NNH_V) INTERACT M3s27_R1_CHK
  ((M3s27_SP_err1_REG_V_eff INTERACT M3s27_S3C_NH_V) OR M3s27_S3C_NH_V) INTERACT M3s27_R1_CHK
}


// Wide M4s27 space error in OPC region checking
//====================================================

Wide_M4s27 = ENCLOSE RECTANGLE (SIZE M4 BY M4_S_27_W1B/2 UNDEROVER) M4_S_27_W1B+GRID M4_S_27_L1B+GRID ORTHOGONAL ONLY
M4s27_CHECK_REGION = M4 AND (SIZE Wide_M4s27 BY M4_S_27_S1B + GRID)
M4s27_OPC_REGION_pre1 = EXT [Wide_M4s27] M4s27_CHECK_REGION < M4_S_27_S1B OPPOSITE MEASURE ALL
M4s27_OPC_REGION_pre1_H = ANGLE M4s27_OPC_REGION_pre1 == 0
M4s27_OPC_REGION_pre1_V = ANGLE M4s27_OPC_REGION_pre1 == 90
M4s27_OPC_REGION_pre0_V = INT M4s27_OPC_REGION_pre1_H [Wide_M4s27] < GRID ABUT == 90 INTERSECTING ONLY
M4s27_OPC_REGION_pre3_V = EXT M4s27_OPC_REGION_pre1_H [Wide_M4s27] < GRID ABUT == 90 INTERSECTING ONLY
M4s27_OPC_REGION_pre4_V = (M4s27_CHECK_REGION TOUCH INSIDE EDGE M4s27_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M4s27_OPC_REGION_pre3_V
M4s27_OPC_REGION_pre0_H = INT M4s27_OPC_REGION_pre1_V [Wide_M4s27] < GRID ABUT == 90 INTERSECTING ONLY
M4s27_OPC_REGION_pre3_H = EXT M4s27_OPC_REGION_pre1_V [Wide_M4s27] < GRID ABUT == 90 INTERSECTING ONLY
M4s27_OPC_REGION_pre4_H = (M4s27_CHECK_REGION TOUCH INSIDE EDGE M4s27_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M4s27_OPC_REGION_pre3_H
M4s27_OPC_REGION_pre5_H = (EXPAND EDGE M4s27_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M4s27_OPC_REGION_pre4_V BY GRID)
M4s27_OPC_REGION_pre5_V = (EXPAND EDGE M4s27_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M4s27_OPC_REGION_pre4_H BY GRID)
M4s27_OPC_REGION_pre6_H = DFM PROPERTY M4s27_OPC_REGION_pre5_H M4s27_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M4s27_OPC_REGION_pre1_H)] > M4_S_27_L1B
M4s27_OPC_REGION_pre6_V = DFM PROPERTY M4s27_OPC_REGION_pre5_V M4s27_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M4s27_OPC_REGION_pre1_V)] > M4_S_27_L1B
M4s27_OPC_REGION_pre7_H = M4s27_OPC_REGION_pre1_H INSIDE EDGE M4s27_OPC_REGION_pre6_H
M4s27_OPC_REGION_pre7_V = M4s27_OPC_REGION_pre1_V INSIDE EDGE M4s27_OPC_REGION_pre6_V
M4s27_OPC_REGION_pre2_H = EXT M4s27_OPC_REGION_pre7_H M4s27_CHECK_REGION < M4_S_27_S1B OPPOSITE REGION MEASURE ALL
M4s27_OPC_REGION_pre2_V = EXT M4s27_OPC_REGION_pre7_V M4s27_CHECK_REGION < M4_S_27_S1B OPPOSITE REGION MEASURE ALL

M4s27_M4_H = M4 INTERACT M4s27_OPC_REGION_pre2_H
M4s27_M4_V = M4 INTERACT M4s27_OPC_REGION_pre2_V
M4s27_M4_ALL = M4s27_M4_H OR M4s27_M4_V
M4s27_OPC_EDGE_H = ANGLE (M4s27_M4_H NOT OUTSIDE EDGE M4s27_OPC_REGION_pre2_H) == 0
M4s27_OPC_EDGE_V = ANGLE (M4s27_M4_V NOT OUTSIDE EDGE M4s27_OPC_REGION_pre2_V) == 90

Wide_M4s27_H = Wide_M4s27 INTERACT M4s27_OPC_REGION_pre2_H
Wide_M4s27_V = Wide_M4s27 INTERACT M4s27_OPC_REGION_pre2_V
Wide_M4s27_WI_JOG_H = (M4 AND (Wide_M4s27_H OR M4s27_OPC_REGION_pre2_H)) INTERACT Wide_M4s27_H
Wide_M4s27_WI_JOG_V = (M4 AND (Wide_M4s27_V OR M4s27_OPC_REGION_pre2_V)) INTERACT Wide_M4s27_V

Wide_M4s27_WI_EXT_EDGE_H = M4s27_OPC_EDGE_H NOT COIN EDGE (INT [M4s27_OPC_EDGE_H] M4s27_M4_H <= M4_S_27_W1B OPPOSITE)
Wide_M4s27_WI_EXT_EDGE_V = M4s27_OPC_EDGE_V NOT COIN EDGE (INT [M4s27_OPC_EDGE_V] M4s27_M4_V <= M4_S_27_W1B OPPOSITE)

M4s27_OPC_REGION_H = (EXT Wide_M4s27_WI_JOG_H M4s27_OPC_EDGE_H < M4_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s27_OPC_REGION_pre2_H
M4s27_OPC_REGION_V = (EXT Wide_M4s27_WI_JOG_V M4s27_OPC_EDGE_V < M4_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s27_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M4s27_SP_err1_REG_H = (EXT Wide_M4s27_WI_EXT_EDGE_H M4s27_M4_H < M4_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s27_OPC_REGION_H
M4s27_SP_err1_REG_V = (EXT Wide_M4s27_WI_EXT_EDGE_V M4s27_M4_V < M4_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M4s27_OPC_REGION_V

M4s27_EDGE_H_err3 = ANGLE M4s27_SP_err1_REG_H == 0
M4s27_EDGE_V_err3 = ANGLE M4s27_SP_err1_REG_V == 90
M4s27_SP_err1_REG_H_eff = DFM PROPERTY M4s27_SP_err1_REG_H M4s27_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M4s27_EDGE_H_err3)] <= 2*M4_S_27_L2A
M4s27_SP_err1_REG_V_eff = DFM PROPERTY M4s27_SP_err1_REG_V M4s27_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M4s27_EDGE_V_err3)] <= 2*M4_S_27_L2A
			       
  M4s27_R1_CHK = EXT Wide_M4s27 M4s27_M4_ALL < M4_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M4s27_NOTCH_EDGE_H = ANGLE (EXT [Wide_M4s27_WI_JOG_H] < M4_S_27_S1B OPPOSITE NOTCH) == 0
  M4s27_NOTCH_EDGE_V = ANGLE (EXT [Wide_M4s27_WI_JOG_V] < M4_S_27_S1B OPPOSITE NOTCH) == 90
  M4s27_NOTCH_REGION_H = (EXT M4s27_NOTCH_EDGE_H < M4_S_27_S1B OPPOSITE REGION) AND M4s27_OPC_REGION_H
  M4s27_NOTCH_REGION_V = (EXT M4s27_NOTCH_EDGE_V < M4_S_27_S1B OPPOSITE REGION) AND M4s27_OPC_REGION_V
  
// Check NON-Notch region
  M4s27_SP_err1_REG_H_eff5 = M4s27_SP_err1_REG_H_eff NOT M4s27_NOTCH_REGION_H
  M4s27_SP_err1_REG_V_eff5 = M4s27_SP_err1_REG_V_eff NOT M4s27_NOTCH_REGION_V
  CONNECT M4s27_SP_err1_REG_H_eff5 (M4s27_OPC_REGION_H NOT M4s27_NOTCH_REGION_H)
  CONNECT M4s27_SP_err1_REG_V_eff5 (M4s27_OPC_REGION_V NOT M4s27_NOTCH_REGION_V)
  M4s27_SP_err1_REG_H_eff5a = M4s27_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M4s27_CHECK_REGION
  M4s27_SP_err1_REG_V_eff5a = M4s27_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M4s27_CHECK_REGION
  M4s27_S3C_NNH_H = (EXT M4s27_SP_err1_REG_H_eff5a < M4_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M4
  M4s27_S3C_NNH_V = (EXT M4s27_SP_err1_REG_V_eff5a < M4_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M4

// Check Notch H region
  M4s27_SP_err1_REG_H_eff6 = M4s27_SP_err1_REG_H_eff INSIDE M4s27_NOTCH_REGION_H
  M4s27_SP_err1_REG_V_eff6 = M4s27_SP_err1_REG_V_eff INSIDE M4s27_NOTCH_REGION_V
  CONNECT M4s27_SP_err1_REG_H_eff6 M4s27_NOTCH_REGION_H
  CONNECT M4s27_SP_err1_REG_V_eff6 M4s27_NOTCH_REGION_V  
  M4s27_SP_err1_REG_H_eff6a = M4s27_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M4s27_CHECK_REGION
  M4s27_SP_err1_REG_V_eff6a = M4s27_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M4s27_CHECK_REGION
  M4s27_S3C_NH_H = (EXT M4s27_SP_err1_REG_H_eff6a < M4_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M4
  M4s27_S3C_NH_V = (EXT M4s27_SP_err1_REG_V_eff6a < M4_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M4

M4.S.27 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.1 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.19 um (S1B) region >= 0.3 
  ((M4s27_SP_err1_REG_H_eff INTERACT M4s27_S3C_NNH_H) OR M4s27_S3C_NNH_H) INTERACT M4s27_R1_CHK
  ((M4s27_SP_err1_REG_H_eff INTERACT M4s27_S3C_NH_H) OR M4s27_S3C_NH_H) INTERACT M4s27_R1_CHK
  ((M4s27_SP_err1_REG_V_eff INTERACT M4s27_S3C_NNH_V) OR M4s27_S3C_NNH_V) INTERACT M4s27_R1_CHK
  ((M4s27_SP_err1_REG_V_eff INTERACT M4s27_S3C_NH_V) OR M4s27_S3C_NH_V) INTERACT M4s27_R1_CHK
}


// Wide M5s27 space error in OPC region checking
//====================================================

Wide_M5s27 = ENCLOSE RECTANGLE (SIZE M5 BY M5_S_27_W1B/2 UNDEROVER) M5_S_27_W1B+GRID M5_S_27_L1B+GRID ORTHOGONAL ONLY
M5s27_CHECK_REGION = M5 AND (SIZE Wide_M5s27 BY M5_S_27_S1B + GRID)
M5s27_OPC_REGION_pre1 = EXT [Wide_M5s27] M5s27_CHECK_REGION < M5_S_27_S1B OPPOSITE MEASURE ALL
M5s27_OPC_REGION_pre1_H = ANGLE M5s27_OPC_REGION_pre1 == 0
M5s27_OPC_REGION_pre1_V = ANGLE M5s27_OPC_REGION_pre1 == 90
M5s27_OPC_REGION_pre0_V = INT M5s27_OPC_REGION_pre1_H [Wide_M5s27] < GRID ABUT == 90 INTERSECTING ONLY
M5s27_OPC_REGION_pre3_V = EXT M5s27_OPC_REGION_pre1_H [Wide_M5s27] < GRID ABUT == 90 INTERSECTING ONLY
M5s27_OPC_REGION_pre4_V = (M5s27_CHECK_REGION TOUCH INSIDE EDGE M5s27_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M5s27_OPC_REGION_pre3_V
M5s27_OPC_REGION_pre0_H = INT M5s27_OPC_REGION_pre1_V [Wide_M5s27] < GRID ABUT == 90 INTERSECTING ONLY
M5s27_OPC_REGION_pre3_H = EXT M5s27_OPC_REGION_pre1_V [Wide_M5s27] < GRID ABUT == 90 INTERSECTING ONLY
M5s27_OPC_REGION_pre4_H = (M5s27_CHECK_REGION TOUCH INSIDE EDGE M5s27_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M5s27_OPC_REGION_pre3_H
M5s27_OPC_REGION_pre5_H = (EXPAND EDGE M5s27_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M5s27_OPC_REGION_pre4_V BY GRID)
M5s27_OPC_REGION_pre5_V = (EXPAND EDGE M5s27_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M5s27_OPC_REGION_pre4_H BY GRID)
M5s27_OPC_REGION_pre6_H = DFM PROPERTY M5s27_OPC_REGION_pre5_H M5s27_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M5s27_OPC_REGION_pre1_H)] > M5_S_27_L1B
M5s27_OPC_REGION_pre6_V = DFM PROPERTY M5s27_OPC_REGION_pre5_V M5s27_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M5s27_OPC_REGION_pre1_V)] > M5_S_27_L1B
M5s27_OPC_REGION_pre7_H = M5s27_OPC_REGION_pre1_H INSIDE EDGE M5s27_OPC_REGION_pre6_H
M5s27_OPC_REGION_pre7_V = M5s27_OPC_REGION_pre1_V INSIDE EDGE M5s27_OPC_REGION_pre6_V
M5s27_OPC_REGION_pre2_H = EXT M5s27_OPC_REGION_pre7_H M5s27_CHECK_REGION < M5_S_27_S1B OPPOSITE REGION MEASURE ALL
M5s27_OPC_REGION_pre2_V = EXT M5s27_OPC_REGION_pre7_V M5s27_CHECK_REGION < M5_S_27_S1B OPPOSITE REGION MEASURE ALL

M5s27_M5_H = M5 INTERACT M5s27_OPC_REGION_pre2_H
M5s27_M5_V = M5 INTERACT M5s27_OPC_REGION_pre2_V
M5s27_M5_ALL = M5s27_M5_H OR M5s27_M5_V
M5s27_OPC_EDGE_H = ANGLE (M5s27_M5_H NOT OUTSIDE EDGE M5s27_OPC_REGION_pre2_H) == 0
M5s27_OPC_EDGE_V = ANGLE (M5s27_M5_V NOT OUTSIDE EDGE M5s27_OPC_REGION_pre2_V) == 90

Wide_M5s27_H = Wide_M5s27 INTERACT M5s27_OPC_REGION_pre2_H
Wide_M5s27_V = Wide_M5s27 INTERACT M5s27_OPC_REGION_pre2_V
Wide_M5s27_WI_JOG_H = (M5 AND (Wide_M5s27_H OR M5s27_OPC_REGION_pre2_H)) INTERACT Wide_M5s27_H
Wide_M5s27_WI_JOG_V = (M5 AND (Wide_M5s27_V OR M5s27_OPC_REGION_pre2_V)) INTERACT Wide_M5s27_V

Wide_M5s27_WI_EXT_EDGE_H = M5s27_OPC_EDGE_H NOT COIN EDGE (INT [M5s27_OPC_EDGE_H] M5s27_M5_H <= M5_S_27_W1B OPPOSITE)
Wide_M5s27_WI_EXT_EDGE_V = M5s27_OPC_EDGE_V NOT COIN EDGE (INT [M5s27_OPC_EDGE_V] M5s27_M5_V <= M5_S_27_W1B OPPOSITE)

M5s27_OPC_REGION_H = (EXT Wide_M5s27_WI_JOG_H M5s27_OPC_EDGE_H < M5_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s27_OPC_REGION_pre2_H
M5s27_OPC_REGION_V = (EXT Wide_M5s27_WI_JOG_V M5s27_OPC_EDGE_V < M5_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s27_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M5s27_SP_err1_REG_H = (EXT Wide_M5s27_WI_EXT_EDGE_H M5s27_M5_H < M5_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s27_OPC_REGION_H
M5s27_SP_err1_REG_V = (EXT Wide_M5s27_WI_EXT_EDGE_V M5s27_M5_V < M5_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M5s27_OPC_REGION_V

M5s27_EDGE_H_err3 = ANGLE M5s27_SP_err1_REG_H == 0
M5s27_EDGE_V_err3 = ANGLE M5s27_SP_err1_REG_V == 90
M5s27_SP_err1_REG_H_eff = DFM PROPERTY M5s27_SP_err1_REG_H M5s27_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M5s27_EDGE_H_err3)] <= 2*M5_S_27_L2A
M5s27_SP_err1_REG_V_eff = DFM PROPERTY M5s27_SP_err1_REG_V M5s27_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M5s27_EDGE_V_err3)] <= 2*M5_S_27_L2A
			       
  M5s27_R1_CHK = EXT Wide_M5s27 M5s27_M5_ALL < M5_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M5s27_NOTCH_EDGE_H = ANGLE (EXT [Wide_M5s27_WI_JOG_H] < M5_S_27_S1B OPPOSITE NOTCH) == 0
  M5s27_NOTCH_EDGE_V = ANGLE (EXT [Wide_M5s27_WI_JOG_V] < M5_S_27_S1B OPPOSITE NOTCH) == 90
  M5s27_NOTCH_REGION_H = (EXT M5s27_NOTCH_EDGE_H < M5_S_27_S1B OPPOSITE REGION) AND M5s27_OPC_REGION_H
  M5s27_NOTCH_REGION_V = (EXT M5s27_NOTCH_EDGE_V < M5_S_27_S1B OPPOSITE REGION) AND M5s27_OPC_REGION_V
  
// Check NON-Notch region
  M5s27_SP_err1_REG_H_eff5 = M5s27_SP_err1_REG_H_eff NOT M5s27_NOTCH_REGION_H
  M5s27_SP_err1_REG_V_eff5 = M5s27_SP_err1_REG_V_eff NOT M5s27_NOTCH_REGION_V
  CONNECT M5s27_SP_err1_REG_H_eff5 (M5s27_OPC_REGION_H NOT M5s27_NOTCH_REGION_H)
  CONNECT M5s27_SP_err1_REG_V_eff5 (M5s27_OPC_REGION_V NOT M5s27_NOTCH_REGION_V)
  M5s27_SP_err1_REG_H_eff5a = M5s27_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M5s27_CHECK_REGION
  M5s27_SP_err1_REG_V_eff5a = M5s27_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M5s27_CHECK_REGION
  M5s27_S3C_NNH_H = (EXT M5s27_SP_err1_REG_H_eff5a < M5_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M5
  M5s27_S3C_NNH_V = (EXT M5s27_SP_err1_REG_V_eff5a < M5_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M5

// Check Notch H region
  M5s27_SP_err1_REG_H_eff6 = M5s27_SP_err1_REG_H_eff INSIDE M5s27_NOTCH_REGION_H
  M5s27_SP_err1_REG_V_eff6 = M5s27_SP_err1_REG_V_eff INSIDE M5s27_NOTCH_REGION_V
  CONNECT M5s27_SP_err1_REG_H_eff6 M5s27_NOTCH_REGION_H
  CONNECT M5s27_SP_err1_REG_V_eff6 M5s27_NOTCH_REGION_V  
  M5s27_SP_err1_REG_H_eff6a = M5s27_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M5s27_CHECK_REGION
  M5s27_SP_err1_REG_V_eff6a = M5s27_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M5s27_CHECK_REGION
  M5s27_S3C_NH_H = (EXT M5s27_SP_err1_REG_H_eff6a < M5_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M5
  M5s27_S3C_NH_V = (EXT M5s27_SP_err1_REG_V_eff6a < M5_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M5

M5.S.27 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.1 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.19 um (S1B) region >= 0.3 
  ((M5s27_SP_err1_REG_H_eff INTERACT M5s27_S3C_NNH_H) OR M5s27_S3C_NNH_H) INTERACT M5s27_R1_CHK
  ((M5s27_SP_err1_REG_H_eff INTERACT M5s27_S3C_NH_H) OR M5s27_S3C_NH_H) INTERACT M5s27_R1_CHK
  ((M5s27_SP_err1_REG_V_eff INTERACT M5s27_S3C_NNH_V) OR M5s27_S3C_NNH_V) INTERACT M5s27_R1_CHK
  ((M5s27_SP_err1_REG_V_eff INTERACT M5s27_S3C_NH_V) OR M5s27_S3C_NH_V) INTERACT M5s27_R1_CHK
}


// Wide M6s27 space error in OPC region checking
//====================================================

Wide_M6s27 = ENCLOSE RECTANGLE (SIZE M6 BY M6_S_27_W1B/2 UNDEROVER) M6_S_27_W1B+GRID M6_S_27_L1B+GRID ORTHOGONAL ONLY
M6s27_CHECK_REGION = M6 AND (SIZE Wide_M6s27 BY M6_S_27_S1B + GRID)
M6s27_OPC_REGION_pre1 = EXT [Wide_M6s27] M6s27_CHECK_REGION < M6_S_27_S1B OPPOSITE MEASURE ALL
M6s27_OPC_REGION_pre1_H = ANGLE M6s27_OPC_REGION_pre1 == 0
M6s27_OPC_REGION_pre1_V = ANGLE M6s27_OPC_REGION_pre1 == 90
M6s27_OPC_REGION_pre0_V = INT M6s27_OPC_REGION_pre1_H [Wide_M6s27] < GRID ABUT == 90 INTERSECTING ONLY
M6s27_OPC_REGION_pre3_V = EXT M6s27_OPC_REGION_pre1_H [Wide_M6s27] < GRID ABUT == 90 INTERSECTING ONLY
M6s27_OPC_REGION_pre4_V = (M6s27_CHECK_REGION TOUCH INSIDE EDGE M6s27_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M6s27_OPC_REGION_pre3_V
M6s27_OPC_REGION_pre0_H = INT M6s27_OPC_REGION_pre1_V [Wide_M6s27] < GRID ABUT == 90 INTERSECTING ONLY
M6s27_OPC_REGION_pre3_H = EXT M6s27_OPC_REGION_pre1_V [Wide_M6s27] < GRID ABUT == 90 INTERSECTING ONLY
M6s27_OPC_REGION_pre4_H = (M6s27_CHECK_REGION TOUCH INSIDE EDGE M6s27_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M6s27_OPC_REGION_pre3_H
M6s27_OPC_REGION_pre5_H = (EXPAND EDGE M6s27_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M6s27_OPC_REGION_pre4_V BY GRID)
M6s27_OPC_REGION_pre5_V = (EXPAND EDGE M6s27_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M6s27_OPC_REGION_pre4_H BY GRID)
M6s27_OPC_REGION_pre6_H = DFM PROPERTY M6s27_OPC_REGION_pre5_H M6s27_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M6s27_OPC_REGION_pre1_H)] > M6_S_27_L1B
M6s27_OPC_REGION_pre6_V = DFM PROPERTY M6s27_OPC_REGION_pre5_V M6s27_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M6s27_OPC_REGION_pre1_V)] > M6_S_27_L1B
M6s27_OPC_REGION_pre7_H = M6s27_OPC_REGION_pre1_H INSIDE EDGE M6s27_OPC_REGION_pre6_H
M6s27_OPC_REGION_pre7_V = M6s27_OPC_REGION_pre1_V INSIDE EDGE M6s27_OPC_REGION_pre6_V
M6s27_OPC_REGION_pre2_H = EXT M6s27_OPC_REGION_pre7_H M6s27_CHECK_REGION < M6_S_27_S1B OPPOSITE REGION MEASURE ALL
M6s27_OPC_REGION_pre2_V = EXT M6s27_OPC_REGION_pre7_V M6s27_CHECK_REGION < M6_S_27_S1B OPPOSITE REGION MEASURE ALL

M6s27_M6_H = M6 INTERACT M6s27_OPC_REGION_pre2_H
M6s27_M6_V = M6 INTERACT M6s27_OPC_REGION_pre2_V
M6s27_M6_ALL = M6s27_M6_H OR M6s27_M6_V
M6s27_OPC_EDGE_H = ANGLE (M6s27_M6_H NOT OUTSIDE EDGE M6s27_OPC_REGION_pre2_H) == 0
M6s27_OPC_EDGE_V = ANGLE (M6s27_M6_V NOT OUTSIDE EDGE M6s27_OPC_REGION_pre2_V) == 90

Wide_M6s27_H = Wide_M6s27 INTERACT M6s27_OPC_REGION_pre2_H
Wide_M6s27_V = Wide_M6s27 INTERACT M6s27_OPC_REGION_pre2_V
Wide_M6s27_WI_JOG_H = (M6 AND (Wide_M6s27_H OR M6s27_OPC_REGION_pre2_H)) INTERACT Wide_M6s27_H
Wide_M6s27_WI_JOG_V = (M6 AND (Wide_M6s27_V OR M6s27_OPC_REGION_pre2_V)) INTERACT Wide_M6s27_V

Wide_M6s27_WI_EXT_EDGE_H = M6s27_OPC_EDGE_H NOT COIN EDGE (INT [M6s27_OPC_EDGE_H] M6s27_M6_H <= M6_S_27_W1B OPPOSITE)
Wide_M6s27_WI_EXT_EDGE_V = M6s27_OPC_EDGE_V NOT COIN EDGE (INT [M6s27_OPC_EDGE_V] M6s27_M6_V <= M6_S_27_W1B OPPOSITE)

M6s27_OPC_REGION_H = (EXT Wide_M6s27_WI_JOG_H M6s27_OPC_EDGE_H < M6_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s27_OPC_REGION_pre2_H
M6s27_OPC_REGION_V = (EXT Wide_M6s27_WI_JOG_V M6s27_OPC_EDGE_V < M6_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s27_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M6s27_SP_err1_REG_H = (EXT Wide_M6s27_WI_EXT_EDGE_H M6s27_M6_H < M6_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s27_OPC_REGION_H
M6s27_SP_err1_REG_V = (EXT Wide_M6s27_WI_EXT_EDGE_V M6s27_M6_V < M6_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M6s27_OPC_REGION_V

M6s27_EDGE_H_err3 = ANGLE M6s27_SP_err1_REG_H == 0
M6s27_EDGE_V_err3 = ANGLE M6s27_SP_err1_REG_V == 90
M6s27_SP_err1_REG_H_eff = DFM PROPERTY M6s27_SP_err1_REG_H M6s27_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M6s27_EDGE_H_err3)] <= 2*M6_S_27_L2A
M6s27_SP_err1_REG_V_eff = DFM PROPERTY M6s27_SP_err1_REG_V M6s27_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M6s27_EDGE_V_err3)] <= 2*M6_S_27_L2A
			       
  M6s27_R1_CHK = EXT Wide_M6s27 M6s27_M6_ALL < M6_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M6s27_NOTCH_EDGE_H = ANGLE (EXT [Wide_M6s27_WI_JOG_H] < M6_S_27_S1B OPPOSITE NOTCH) == 0
  M6s27_NOTCH_EDGE_V = ANGLE (EXT [Wide_M6s27_WI_JOG_V] < M6_S_27_S1B OPPOSITE NOTCH) == 90
  M6s27_NOTCH_REGION_H = (EXT M6s27_NOTCH_EDGE_H < M6_S_27_S1B OPPOSITE REGION) AND M6s27_OPC_REGION_H
  M6s27_NOTCH_REGION_V = (EXT M6s27_NOTCH_EDGE_V < M6_S_27_S1B OPPOSITE REGION) AND M6s27_OPC_REGION_V
  
// Check NON-Notch region
  M6s27_SP_err1_REG_H_eff5 = M6s27_SP_err1_REG_H_eff NOT M6s27_NOTCH_REGION_H
  M6s27_SP_err1_REG_V_eff5 = M6s27_SP_err1_REG_V_eff NOT M6s27_NOTCH_REGION_V
  CONNECT M6s27_SP_err1_REG_H_eff5 (M6s27_OPC_REGION_H NOT M6s27_NOTCH_REGION_H)
  CONNECT M6s27_SP_err1_REG_V_eff5 (M6s27_OPC_REGION_V NOT M6s27_NOTCH_REGION_V)
  M6s27_SP_err1_REG_H_eff5a = M6s27_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M6s27_CHECK_REGION
  M6s27_SP_err1_REG_V_eff5a = M6s27_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M6s27_CHECK_REGION
  M6s27_S3C_NNH_H = (EXT M6s27_SP_err1_REG_H_eff5a < M6_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M6
  M6s27_S3C_NNH_V = (EXT M6s27_SP_err1_REG_V_eff5a < M6_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M6

// Check Notch H region
  M6s27_SP_err1_REG_H_eff6 = M6s27_SP_err1_REG_H_eff INSIDE M6s27_NOTCH_REGION_H
  M6s27_SP_err1_REG_V_eff6 = M6s27_SP_err1_REG_V_eff INSIDE M6s27_NOTCH_REGION_V
  CONNECT M6s27_SP_err1_REG_H_eff6 M6s27_NOTCH_REGION_H
  CONNECT M6s27_SP_err1_REG_V_eff6 M6s27_NOTCH_REGION_V  
  M6s27_SP_err1_REG_H_eff6a = M6s27_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M6s27_CHECK_REGION
  M6s27_SP_err1_REG_V_eff6a = M6s27_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M6s27_CHECK_REGION
  M6s27_S3C_NH_H = (EXT M6s27_SP_err1_REG_H_eff6a < M6_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M6
  M6s27_S3C_NH_V = (EXT M6s27_SP_err1_REG_V_eff6a < M6_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M6

M6.S.27 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.1 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.19 um (S1B) region >= 0.3 
  ((M6s27_SP_err1_REG_H_eff INTERACT M6s27_S3C_NNH_H) OR M6s27_S3C_NNH_H) INTERACT M6s27_R1_CHK
  ((M6s27_SP_err1_REG_H_eff INTERACT M6s27_S3C_NH_H) OR M6s27_S3C_NH_H) INTERACT M6s27_R1_CHK
  ((M6s27_SP_err1_REG_V_eff INTERACT M6s27_S3C_NNH_V) OR M6s27_S3C_NNH_V) INTERACT M6s27_R1_CHK
  ((M6s27_SP_err1_REG_V_eff INTERACT M6s27_S3C_NH_V) OR M6s27_S3C_NH_V) INTERACT M6s27_R1_CHK
}


// Wide M7s27 space error in OPC region checking
//====================================================

Wide_M7s27 = ENCLOSE RECTANGLE (SIZE M7 BY M7_S_27_W1B/2 UNDEROVER) M7_S_27_W1B+GRID M7_S_27_L1B+GRID ORTHOGONAL ONLY
M7s27_CHECK_REGION = M7 AND (SIZE Wide_M7s27 BY M7_S_27_S1B + GRID)
M7s27_OPC_REGION_pre1 = EXT [Wide_M7s27] M7s27_CHECK_REGION < M7_S_27_S1B OPPOSITE MEASURE ALL
M7s27_OPC_REGION_pre1_H = ANGLE M7s27_OPC_REGION_pre1 == 0
M7s27_OPC_REGION_pre1_V = ANGLE M7s27_OPC_REGION_pre1 == 90
M7s27_OPC_REGION_pre0_V = INT M7s27_OPC_REGION_pre1_H [Wide_M7s27] < GRID ABUT == 90 INTERSECTING ONLY
M7s27_OPC_REGION_pre3_V = EXT M7s27_OPC_REGION_pre1_H [Wide_M7s27] < GRID ABUT == 90 INTERSECTING ONLY
M7s27_OPC_REGION_pre4_V = (M7s27_CHECK_REGION TOUCH INSIDE EDGE M7s27_OPC_REGION_pre0_V) TOUCH INSIDE EDGE M7s27_OPC_REGION_pre3_V
M7s27_OPC_REGION_pre0_H = INT M7s27_OPC_REGION_pre1_V [Wide_M7s27] < GRID ABUT == 90 INTERSECTING ONLY
M7s27_OPC_REGION_pre3_H = EXT M7s27_OPC_REGION_pre1_V [Wide_M7s27] < GRID ABUT == 90 INTERSECTING ONLY
M7s27_OPC_REGION_pre4_H = (M7s27_CHECK_REGION TOUCH INSIDE EDGE M7s27_OPC_REGION_pre0_H) TOUCH INSIDE EDGE M7s27_OPC_REGION_pre3_H
M7s27_OPC_REGION_pre5_H = (EXPAND EDGE M7s27_OPC_REGION_pre1_H BY GRID) OR (EXPAND EDGE M7s27_OPC_REGION_pre4_V BY GRID)
M7s27_OPC_REGION_pre5_V = (EXPAND EDGE M7s27_OPC_REGION_pre1_V BY GRID) OR (EXPAND EDGE M7s27_OPC_REGION_pre4_H BY GRID)
M7s27_OPC_REGION_pre6_H = DFM PROPERTY M7s27_OPC_REGION_pre5_H M7s27_OPC_REGION_pre1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(M7s27_OPC_REGION_pre1_H)] > M7_S_27_L1B
M7s27_OPC_REGION_pre6_V = DFM PROPERTY M7s27_OPC_REGION_pre5_V M7s27_OPC_REGION_pre1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(M7s27_OPC_REGION_pre1_V)] > M7_S_27_L1B
M7s27_OPC_REGION_pre7_H = M7s27_OPC_REGION_pre1_H INSIDE EDGE M7s27_OPC_REGION_pre6_H
M7s27_OPC_REGION_pre7_V = M7s27_OPC_REGION_pre1_V INSIDE EDGE M7s27_OPC_REGION_pre6_V
M7s27_OPC_REGION_pre2_H = EXT M7s27_OPC_REGION_pre7_H M7s27_CHECK_REGION < M7_S_27_S1B OPPOSITE REGION MEASURE ALL
M7s27_OPC_REGION_pre2_V = EXT M7s27_OPC_REGION_pre7_V M7s27_CHECK_REGION < M7_S_27_S1B OPPOSITE REGION MEASURE ALL

M7s27_M7_H = M7 INTERACT M7s27_OPC_REGION_pre2_H
M7s27_M7_V = M7 INTERACT M7s27_OPC_REGION_pre2_V
M7s27_M7_ALL = M7s27_M7_H OR M7s27_M7_V
M7s27_OPC_EDGE_H = ANGLE (M7s27_M7_H NOT OUTSIDE EDGE M7s27_OPC_REGION_pre2_H) == 0
M7s27_OPC_EDGE_V = ANGLE (M7s27_M7_V NOT OUTSIDE EDGE M7s27_OPC_REGION_pre2_V) == 90

Wide_M7s27_H = Wide_M7s27 INTERACT M7s27_OPC_REGION_pre2_H
Wide_M7s27_V = Wide_M7s27 INTERACT M7s27_OPC_REGION_pre2_V
Wide_M7s27_WI_JOG_H = (M7 AND (Wide_M7s27_H OR M7s27_OPC_REGION_pre2_H)) INTERACT Wide_M7s27_H
Wide_M7s27_WI_JOG_V = (M7 AND (Wide_M7s27_V OR M7s27_OPC_REGION_pre2_V)) INTERACT Wide_M7s27_V

Wide_M7s27_WI_EXT_EDGE_H = M7s27_OPC_EDGE_H NOT COIN EDGE (INT [M7s27_OPC_EDGE_H] M7s27_M7_H <= M7_S_27_W1B OPPOSITE)
Wide_M7s27_WI_EXT_EDGE_V = M7s27_OPC_EDGE_V NOT COIN EDGE (INT [M7s27_OPC_EDGE_V] M7s27_M7_V <= M7_S_27_W1B OPPOSITE)

M7s27_OPC_REGION_H = (EXT Wide_M7s27_WI_JOG_H M7s27_OPC_EDGE_H < M7_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s27_OPC_REGION_pre2_H
M7s27_OPC_REGION_V = (EXT Wide_M7s27_WI_JOG_V M7s27_OPC_EDGE_V < M7_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s27_OPC_REGION_pre2_V

// Find Space error region (Relax large space S2A1)
M7s27_SP_err1_REG_H = (EXT Wide_M7s27_WI_EXT_EDGE_H M7s27_M7_H < M7_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s27_OPC_REGION_H
M7s27_SP_err1_REG_V = (EXT Wide_M7s27_WI_EXT_EDGE_V M7s27_M7_V < M7_S_27_S2A1 EXCLUDE SHIELDED 4 OPPOSITE REGION) INSIDE M7s27_OPC_REGION_V

M7s27_EDGE_H_err3 = ANGLE M7s27_SP_err1_REG_H == 0
M7s27_EDGE_V_err3 = ANGLE M7s27_SP_err1_REG_V == 90
M7s27_SP_err1_REG_H_eff = DFM PROPERTY M7s27_SP_err1_REG_H M7s27_EDGE_H_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M7s27_EDGE_H_err3)] <= 2*M7_S_27_L2A
M7s27_SP_err1_REG_V_eff = DFM PROPERTY M7s27_SP_err1_REG_V M7s27_EDGE_V_err3 OVERLAP ABUT ALSO MULTI
                               [-= LENGTH(M7s27_EDGE_V_err3)] <= 2*M7_S_27_L2A
			       
  M7s27_R1_CHK = EXT Wide_M7s27 M7s27_M7_ALL < M7_S_27_S1B EXCLUDE SHIELDED 4 OPPOSITE REGION

  M7s27_NOTCH_EDGE_H = ANGLE (EXT [Wide_M7s27_WI_JOG_H] < M7_S_27_S1B OPPOSITE NOTCH) == 0
  M7s27_NOTCH_EDGE_V = ANGLE (EXT [Wide_M7s27_WI_JOG_V] < M7_S_27_S1B OPPOSITE NOTCH) == 90
  M7s27_NOTCH_REGION_H = (EXT M7s27_NOTCH_EDGE_H < M7_S_27_S1B OPPOSITE REGION) AND M7s27_OPC_REGION_H
  M7s27_NOTCH_REGION_V = (EXT M7s27_NOTCH_EDGE_V < M7_S_27_S1B OPPOSITE REGION) AND M7s27_OPC_REGION_V
  
// Check NON-Notch region
  M7s27_SP_err1_REG_H_eff5 = M7s27_SP_err1_REG_H_eff NOT M7s27_NOTCH_REGION_H
  M7s27_SP_err1_REG_V_eff5 = M7s27_SP_err1_REG_V_eff NOT M7s27_NOTCH_REGION_V
  CONNECT M7s27_SP_err1_REG_H_eff5 (M7s27_OPC_REGION_H NOT M7s27_NOTCH_REGION_H)
  CONNECT M7s27_SP_err1_REG_V_eff5 (M7s27_OPC_REGION_V NOT M7s27_NOTCH_REGION_V)
  M7s27_SP_err1_REG_H_eff5a = M7s27_SP_err1_REG_H_eff5 NOT COIN OUTSIDE EDGE M7s27_CHECK_REGION
  M7s27_SP_err1_REG_V_eff5a = M7s27_SP_err1_REG_V_eff5 NOT COIN OUTSIDE EDGE M7s27_CHECK_REGION
  M7s27_S3C_NNH_H = (EXT M7s27_SP_err1_REG_H_eff5a < M7_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M7
  M7s27_S3C_NNH_V = (EXT M7s27_SP_err1_REG_V_eff5a < M7_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M7

// Check Notch H region
  M7s27_SP_err1_REG_H_eff6 = M7s27_SP_err1_REG_H_eff INSIDE M7s27_NOTCH_REGION_H
  M7s27_SP_err1_REG_V_eff6 = M7s27_SP_err1_REG_V_eff INSIDE M7s27_NOTCH_REGION_V
  CONNECT M7s27_SP_err1_REG_H_eff6 M7s27_NOTCH_REGION_H
  CONNECT M7s27_SP_err1_REG_V_eff6 M7s27_NOTCH_REGION_V  
  M7s27_SP_err1_REG_H_eff6a = M7s27_SP_err1_REG_H_eff6 NOT COIN OUTSIDE EDGE M7s27_CHECK_REGION
  M7s27_SP_err1_REG_V_eff6a = M7s27_SP_err1_REG_V_eff6 NOT COIN OUTSIDE EDGE M7s27_CHECK_REGION
  M7s27_S3C_NH_H = (EXT M7s27_SP_err1_REG_H_eff6a < M7_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M7
  M7s27_S3C_NH_V = (EXT M7s27_SP_err1_REG_V_eff6a < M7_S_27_S3C ABUT < 90 REGION CONNECTED) NOT M7

M7.S.27 { @ Space between "wide metal space regionA" in "wide metal space regionB". 1. Definition of "wide metal space regionA" At least one metal line width > 0.25 um (W1B) and the parallel run length <= 0.22 um (L2A) in metal space < 0.1 um (S2A) region. 2. Definition of "wide metal space regionB": At least one metal line width > 0.25 um (W1B) and the parallel run length > 0.3 um (L1B) in metal space < 0.19 um (S1B) region >= 0.3 
  ((M7s27_SP_err1_REG_H_eff INTERACT M7s27_S3C_NNH_H) OR M7s27_S3C_NNH_H) INTERACT M7s27_R1_CHK
  ((M7s27_SP_err1_REG_H_eff INTERACT M7s27_S3C_NH_H) OR M7s27_S3C_NH_H) INTERACT M7s27_R1_CHK
  ((M7s27_SP_err1_REG_V_eff INTERACT M7s27_S3C_NNH_V) OR M7s27_S3C_NNH_V) INTERACT M7s27_R1_CHK
  ((M7s27_SP_err1_REG_V_eff INTERACT M7s27_S3C_NH_V) OR M7s27_S3C_NH_V) INTERACT M7s27_R1_CHK
}

#ENDIF //BACK_END






// PIN CHECKS
