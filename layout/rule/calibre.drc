  A = DENSITY DUVIA2 DUM2 < DVIA2_R_3 INSIDE OF LAYER DVIAxR3_CHECK PRINT DVIA2DM2.R.3.density
    	[AREA(DUVIA2)/AREA(DUM2)]
  B = DENSITY DUVIA2 DUM3 < DVIA2_R_3 INSIDE OF LAYER DVIAxR3_CHECK PRINT DVIA2DM3.R.3.density
    	[AREA(DUVIA2)/AREA(DUM3)]
  (CHIPx INTERACT A) INTERACT B
