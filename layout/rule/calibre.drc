#IFDEF FRONT_END


//NW CHECKS
//=========

NW2V = NWEL AND OD2
NW1V = NWEL NOT OD2


//SWAP NW Definition HP/LP
NW_DF = COPY NW

NW.W.1 { @ Width >= 0.24 
  (INT NW_DF < NW_W_1 ABUT < 90 OPPOSITE SYMMETRIC REGION) NOT INSIDE SRAM_WAIVE_N28
  (INT NW_DF < NW_W_1 ABUT < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (INT NW_DF < NW_W_1 ABUT < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28
}

NW.S.1 { @ Space >= 0.24 
  EXT NWEL < NW_S_1 ABUT < 90 SINGULAR REGION
}
NW.S.2 { @ Space of 2 NW1V with different potentials >= 0.8 
  NW1V_NODAL = STAMP NW1V BY NWi
  EXT NW1V_NODAL < NW_S_2 ABUT < 90 NOT CONNECTED SINGULAR REGION
}
NW.S.3 { @ NW1V space to NW2V with different potentials >= 1 
  NW1V_NODAL = STAMP NW1V BY NWi
  NW2V_NODAL = STAMP NW2V BY NWi
  EXT NW1V_NODAL NW2V_NODAL < NW_S_3 ABUT < 90 NOT CONNECTED SINGULAR REGION
}
NW.S.4 { @ Space of 2 NW2V with different potentials >= 1 
  NW2V_NODAL = STAMP NW2V BY NWi
  EXT NW2V_NODAL < NW_S_4 ABUT < 90 NOT CONNECTED SINGULAR REGION
}

#IFDEF NW_SUGGESTED

NW.S.3__NW.S.4:SUGGESTED { @ A more conservative way to check NW.S.3, NW.S.4 with 
		          @ varied operating voltages determination of nwels.
  NW1V = NWEL OUTSIDE OD2
  NW2V = NWEL NOT OUTSIDE OD2
  NW1Vc = STAMP NW1V BY NWi
  NW2Vc = STAMP NW2V BY NWi
  EXT NW1Vc NW2Vc < NW_S_3 ABUT < 90 > 0 NOT CONNECTED SINGULAR REGION
  NW2V_NODAL = STAMP NW2V BY NWi
  EXT NW2V_NODAL < NW_S_4 ABUT < 90 NOT CONNECTED SINGULAR REGION
}
#ENDIF

NW.S.5 { @ Space to PW STRAP >= 0.065 
  (EXT NWi PPOD < NW_S_5 ABUT < 90 SINGULAR REGION) NOT INSIDE (SRAM_WAIVE_N28 OR LDMOS)
  (PPOD CUT NWi) NOT INSIDE (SRAM_WAIVE_N28 OR LDMOS)
}
NW.S.6 { @ Space to N+ ACTIVE >= 0.065 
  A = NPOD NOT INTERACT RNWEL
  (EXT NWi A < NW_S_6 ABUT < 90 SINGULAR REGION) NOT INSIDE (SRAM_WAIVE_N28 OR LDMOS)
  (A CUT NWi) NOT INSIDE (SRAM_WAIVE_N28 OR LDMOS) 
}
NW.S.7 { @ At least one edge of NW inner vertex space to N+ ACTIVE >= 0.105 
  NACTx = (NPOD NOT INTERACT RNWEL) NOT NWi 
  OD_CONVEX_CORNER = INT [NACTx] <  GRID ABUT == 90 INTERSECTING ONLY 
  NW_CONCAVE_CORNER = EXT [NWi] <   (NW_S_7-NW_S_6+GRID)  ABUT == 90 INTERSECTING ONLY 
  X1 = ANGLE  OD_CONVEX_CORNER == 0
  X2 = ANGLE  NW_CONCAVE_CORNER == 0
  A = EXT [X1] X2 < NW_S_7 OPPOSITE EXTENDED NW_S_6
  X3 = ANGLE  OD_CONVEX_CORNER == 90
  X4 = ANGLE  NW_CONCAVE_CORNER == 90
  B = EXT [X3] X4 < NW_S_7 OPPOSITE EXTENDED NW_S_6  
  INT A B < GRID ABUT == 90 INTERSECTING ONLY
  OD_CONCAVE_CORNER = EXT [NACTx] <  (NW_S_7-NW_S_6+GRID) ABUT == 90 INTERSECTING ONLY 
  NW_CONVEX_CORNER = INT [NWi] <  GRID ABUT == 90 INTERSECTING ONLY 
  Y1 = ANGLE  OD_CONCAVE_CORNER == 0
  Y2 = ANGLE  NW_CONVEX_CORNER == 0
  C = EXT Y1 [Y2] < NW_S_7 OPPOSITE EXTENDED NW_S_6  
  Y3 = ANGLE  OD_CONCAVE_CORNER == 90
  Y4 = ANGLE  NW_CONVEX_CORNER == 90
  D = EXT Y3 [Y4] < NW_S_7 OPPOSITE EXTENDED NW_S_6  
  INT C D < GRID ABUT == 90 INTERSECTING ONLY
}
NW.S.8 { @ Space to {N+ ACTIVE INTERACT OD2} >= 0.18 
  (EXT NWi NACT2 < NW_S_8 ABUT < 90 SINGULAR REGION) NOT INSIDE LDMOS
}
NW.S.9 { @ Space [parallel run length > 0.5 um, NW space without INTERACT {{OD OR SR_DOD} OR DOD}] >= 0.3 
  X = EXT NWi < NW_S_9 OPPOSITE REGION
  Y = X NOT INTERACT ((OD OR DOD) OR SRDOD)
  ENCLOSE RECTANGLE Y GRID NW_S_9_L+GRID ORTHOGONAL ONLY
}

NW.EN.1 { @ Enclosure of NW STRAP >= 0.065 
  (ENC NPOD NONWR < NW_EN_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}
NW.EN.2 { @ Enclosure of P+ ACTIVE >= 0.065 
  (ENC PPOD NONWR < NW_EN_2 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}

NONWR_NWii = NW NOT RNWEL		// NW exclude resistor area (Within OD)

NW.EN.3 { @ At least one edge of NW outer vertex enclosure of P+ ACTIVE >= 0.105 
  OD_CONVEX_CORNER = INT [PACT] < GRID ABUT == 90 INTERSECTING ONLY 
  NW_CONVEX_CORNER = INT [NONWR_NWii] < (NW_EN_3-NW_EN_2+GRID)  ABUT == 90 INTERSECTING ONLY 
  X1 = ANGLE OD_CONVEX_CORNER == 0
  X2 = ANGLE NW_CONVEX_CORNER == 0
  A = ENC [X1] X2 < NW_EN_3 OPPOSITE EXTENDED NW_EN_2  
  X3 = ANGLE OD_CONVEX_CORNER == 90
  X4 = ANGLE NW_CONVEX_CORNER == 90
  B = ENC [X3] X4 < NW_EN_3 OPPOSITE EXTENDED NW_EN_2    
  INT A B < GRID ABUT == 90 INTERSECTING ONLY
  
  OD_CONCAVE_CORNER = EXT [PACT] < (NW_EN_3-NW_EN_2+GRID) ABUT == 90 INTERSECTING ONLY 
  NW_CONCAVE_CORNER = EXT [NONWR_NWii] < GRID ABUT == 90 INTERSECTING ONLY 
  Y1 = ANGLE OD_CONCAVE_CORNER == 0
  Y2 = ANGLE NW_CONCAVE_CORNER == 0
  C = ENC Y1 [Y2] < NW_EN_3 OPPOSITE EXTENDED NW_EN_2  
  Y3 = ANGLE OD_CONCAVE_CORNER == 90
  Y4 = ANGLE NW_CONCAVE_CORNER == 90
  D = ENC Y3 [Y4] < NW_EN_3 OPPOSITE EXTENDED NW_EN_2  
  EXT C D < GRID ABUT == 90 INTERSECTING ONLY
}

NW.EN.4 { @ Enclosure of {P+ ACTIVE INTERACT OD2} >= 0.18 
  (ENC PACT2 NWii < NW_EN_4 ABUT < 90 SINGULAR REGION) NOT INSIDE LDMOS
}
NW.A.1 { @ Area >= 0.4 
  AREA NW < NW_A_1
}

NW.A.2 { @ Area of {OD2 OR {NW OR NT_N}}, {NW NOT OD2}, {OD2 NOT NW}, {OD2 AND NW} >= 0.4 
  AREA (OD2 OR (NW OR NTN)) < NW_A_2
  AREA (NW NOT OD2) < NW_A_2
  AREA (OD2 NOT NW) < NW_A_2
  AREA (OD2 AND NW) < NW_A_2
}

NW.A.6 { @ Enclosed area >= 0.4 
  A = HOLES NW INNER
  B = A NOT NW
  AREA B < NW_A_6
}

NW.A.7 { @ Enclosed area of {OD2 OR {NW OR NT_N}}, {NW NOT OD2}, {OD2 NOT NW}, {OD2 AND NW} >= 0.4 
  A1 = OD2 OR (NW OR NTN)
  B1 = (HOLES A1 INNER) NOT A1
  AREA B1 < NW_A_7
  A2 = NW NOT OD2
  B2 = (HOLES A2 INNER) NOT A2
  AREA B2 < NW_A_7
  A3 = OD2 NOT NW
  B3 = (HOLES A3 INNER) NOT A3
  AREA B3 < NW_A_7
  A4 = OD2 AND NW
  B4 = (HOLES A4 INNER) NOT A4
  AREA B4 < NW_A_7
}
NW.R.8 { @ NW ABUT NWDMY from outside is not allowed   
  NWi COIN OUTSIDE EDGE NWDMY
}


//NWROD CHECKS
//=============

NWROD.W.1 { @ Width >= 1.8 
  INT RNWEL < NWROD_W_1 ABUT < 90 SINGULAR REGION
}
NWROD.S.1 { @ Space to NWROD or to NW >= 1 
  EXT RNWEL < NWROD_S_1 ABUT < 90 NOTCH SINGULAR REGION
  EXT RNWEL NWEL < NWROD_S_1 ABUT < 90 SINGULAR REGION 
}  
NWROD.S.2 { @ Space to RPO >= 0.3 
  EXT NWRES RPO < NWROD_S_2 ABUT < 90 SINGULAR REGION
  (NWRES AND RPO) NOT INTERACT NWDMY
  A = RPO INSIDE EDGE NWRES
  EXT A < RPO_W_1 ABUT == 90 REGION INTERSECTING ONLY
}
NWROD.EN.1 { @ Enclosure by OD >= 1 
  ENC NWRES ODWR < NWROD_EN_1 ABUT < 90 SINGULAR REGION
  NWRES CUT ODWR
}
NWROD.EN.2 { @ Enclosure of CO >= 0.3 
  X = RHWR AND NWRES	// Terminal
  ENC COWR X < NWROD_EN_2 ABUT < 90 SINGULAR REGION
  COWR NOT X
}
NWROD.O.1 { @ RPO overlap of NP. Use exact value (0.4 um) on sides touching NWDMY = 0.4 
  INT NPWR RPO < NWROD_O_1 ABUT < 90 SINGULAR REGION
  A = RHWR INSIDE EDGE NWEL
  B = EXPAND EDGE A OUTSIDE BY NWROD_O_1
  ((NPWR AND RPO) AND NWRES) NOT B
  RHWR NOT NPWR
}
NWROD.O.2 { @ {OD AND NWDMY} overlap of NP, PP, VTH_N, VTH_P, UHVT_N, UHVT_P, EHVT_N, EHVT_P, VTL_N, VTL_P, VTUL_N, and VTUL_P (all implant layers except NW) is not allowed   
  A = OD AND NWDMY
  A AND NP
  A AND PP
  A AND VTHN
  A AND VTHP
  A AND VTLN
  A AND VTLP
  A AND VTULN
  A AND VTULP  
  A AND VTUHN
  A AND VTUHP
  A AND EHVT_N
  A AND EHVT_P
  A AND VTLNIO
}


NWROD.R.4 { @ Only one NW in NWROD is allowed in one OD   
  A = OD INTERACT (RNWEL AND OD) > 1
  RNWEL INTERACT A
}
NWROD.R.5 { @ Only 2 NPs in NWROD are allowed in one OD   
  A = OD INTERACT (NP INTERACT NWRES) != 2
  NP INTERACT A
}
NWROD.R.6 { @ Only 2 RPO holes (Salicide) in NWROD are allowed in same OD   
  A = (OD INTERACT RNWEL) INTERACT (HOLES RPO) != 2
  B = (OD INTERACT RNWEL) NOT INTERACT (HOLES RPO)
  RPO INTERACT (A OR B)
}
NWROD.R.7 { @ For U-shape or S-shape NWROD, both OD and NW must be U-shape or S-shape and the OD edge must be parallel to the NW edge. DRC can only flag the pattern without OD space when 2 edges of NW [NW notch or space <= 5 um] parallel run length > 0 um   
  ((EXT RNWEL <= 5 NOTCH OPPOSITE REGION) NOT RNWEL) INSIDE OD
}
NWROD.R.8 { @ NWDMY intersecting NW must form two or more NWs
  NWR_BODY = NWEL AND NWDMY
  NWR_END = (NWEL INTERACT NWR_BODY) NOT NWR_BODY     
  NWR_BODY NOT INTERACT NWR_END >= 2
}

//NWRSTI CHECKS
//=============

//NWRSTI.W.1 is checked by NWROD.W.1
//NWRSTI.S.1 is checked by NWROD.S.1

NWRSTI.EN.1 { @ NP enclosure of {OD INTERACT NWRSTI} >= 0.4 
  ENC ODWR_STI NPWR_STI < NWRSTI_EN_1 ABUT < 90 SINGULAR REGION
  ODWR_STI NOT NPWR_STI
}
NWRSTI.EN.2 { @ OD enclosure of {CO INTERACT NWRSTI} >= 0.3 
  X = ODWR_STI AND NWRES_STI	// Terminal
  ENC COWR_STI X < NWRSTI_EN_2 ABUT < 90 SINGULAR REGION
  COWR_STI NOT X
}

// NWRSTI.EN.3 is checked by NWRSTI.EN.2

NWRSTI.EX.1 { @ OD extension on NWRSTI >= 0.3 
  ENC NWRES_STI ODWR_STI < NWRSTI_EX_1 ABUT < 90 SINGULAR REGION
  A = ODWR_STI INSIDE EDGE NWRES_STI
  INT A < OD_W_1 ABUT == 90 REGION INTERSECTING ONLY
  ANGLE A == 45
  (NWRES_STI NOT NWDMY) NOT OD
}
NWRSTI.O.1 { @ {NP INTERACT NWDMY} overlap of PP, VTH_P, VTL_P, UHVT_P, EHVT_P, and VTUL_P (all p-type implant layers) is not allowed   
  A = NP INTERACT NWDMY
  A AND PP
  A AND VTLP
  A AND VTULP
  A AND VTHP
  A AND VTUHP
  A AND EHVT_P
}





//NT_N RULES CHECK
//================

NTN_GATE = GATE NOT OUTSIDE NTN
NTN_GATE_W = NTN_GATE TOUCH EDGE GATE_W
NTN_GATE_L = NTN_GATE NOT TOUCH EDGE GATE_W

VTZ_GATE = GATE NOT OUTSIDE VTZ_N
VTZ_GATE_W = VTZ_GATE TOUCH EDGE GATE_W
VTZ_GATE_L = VTZ_GATE NOT TOUCH EDGE GATE_W

NET_GATE = NTN_GATE NOT VTZ_GATE
NET_GATE_W = NET_GATE TOUCH EDGE GATE_W
NET_GATE_L = NET_GATE NOT TOUCH EDGE GATE_W

NT_N.W.1 { @ Width >= 0.24 
  INT NTN < NTN_W_1 ABUT < 90 SINGULAR REGION
}

NT_N.W.3 { @ Channel length of core native device = 0.3~1 
  NTN_LV_GATE_L = NTN_GATE_L NOT INSIDE EDGE (OD2 OR OTP)
  LENGTH NTN_LV_GATE_L < NTN_W_3A
  LENGTH NTN_LV_GATE_L > NTN_W_3B
}


NT_N.W.4 { @ Channel length of 2.5V native device = 1.2~2 
  NTN_25V_GATE_L = NTN_GATE_L INSIDE EDGE OD25
  LENGTH NTN_25V_GATE_L < NTN_W_4A
  LENGTH NTN_25V_GATE_L > NTN_W_4B
}

NT_N.W.5 { @ Channel length of 1.8V native device = 0.8~2 
  NTN_18V_GATE_L = (NTN_GATE_L INSIDE EDGE OD18) NOT INSIDE EDGE OTP
  LENGTH NTN_18V_GATE_L < NTN_W_5A
  LENGTH NTN_18V_GATE_L > NTN_W_5B
}

NT_N.W.6 { @ Channel width of native device >= 0.5 
  LENGTH (NTN_GATE_W NOT INSIDE EDGE OTP) < NTN_W_6 
}


NT_N.S.1 { @ Space >= 0.24 
  EXT NTN < NTN_S_1 ABUT < 90 SINGULAR REGION
}

NTN_exc_ind = NTN NOT INDDMY

NT_N.S.2 { @ Space to [ACTIVE OUTSIDE NT_N] >= 0.38 
  A = DACT OUTSIDE NTN
  EXT NTN_exc_ind A < NTN_S_2 ABUT < 90 SINGULAR REGION
}

NT_N.S.3 { @ Space to NW >= 0.8 
  EXT NTN NWi < NTN_S_3 ABUT < 90 SINGULAR REGION
}

NT_N.EN.1 { @ Enclosure range of N+OD = 0.16 
  CHECK_NPOD = NPOD NOT INSIDE OTP
  A = NTN_exc_ind INTERACT CHECK_NPOD
  B = CHECK_NPOD INTERACT NTN_exc_ind
  ENC B A < NTN_EN_1 ABUT < 90 SINGULAR REGION
  B CUT A
  A NOT (SIZE B BY NTN_EN_1)
}

// 002  >=0.24
NT_N.EX.1 { @ PO extension on {OD INSIDE NT_N} (PO ENDCAP) >= 0.24 
  NTN_OD = OD INSIDE NTN
  ENC NTN_OD POLY < NTN_EX_1 ABUT < 90 SINGULAR REGION
}


NT_N.A.1 { @ Area >= 0.4 
  AREA NTN < NTN_A_1
}
NT_N.A.2 { @ Enclosed area >= 0.4 
  A = HOLES NTN INNER
  B = A NOT NTN
  AREA B < NTN_A_2
}
NT_N.R.1 { @ Overlap of {NW OR DNW} is not allowed   
  NTN AND DNW
  NTN AND NWEL
}
NT_N.R.2 { @ Only one OD region is allowed in NT_N (This check doesn't include the region covered by NMOS capacitor with same potential, pickup, and MOMDMY (155;21) region.)   
  A = NTN_exc_ind CUT (DACT NOT INSIDE OTP) > 1
  A NOT INTERACT (NCapNTN OR MOMDMY)
  B = A INTERACT NCapNTN
  C = OD INTERACT B
  NCapNTN NOT OD // OD of NMOS cap sould be exactly covered by NCapNTN
  C NOT NCapNTN  // Mixture of NMOS cap and normal device is not allowed
  NCapNTN NOT NTN // NCapNTN must be fully inside NTN 
  A INTERACT NSDc > 1 BY NET // all source and drain of all Nmos caps in the same NT_N must be connected together

}

NT_N.R.3 { @ P+ GATE is not allowed in NT_N   
  GATE_PP AND NTN
}




//DNW CHECKS
//==========

DNW.W.1 { @ Width >= 3 
  INT DNW < DNW_W_1 ABUT < 90 SINGULAR REGION
}
DNW.S.1 { @ Space >= ^DNW_S_1
  EXT DNW < DNW_S_1 ABUT < 90 SINGULAR REGION
}
DNW.S.2 { @ Space to NW with different potentials >= 2.5 
  (EXT DNWi NWi < DNW_S_2 ABUT < 90 NOT CONNECTED SINGULAR REGION MEASURE ALL) NOT INSIDE TCDDMY
}
DNW.S.3 { @ Space to {N+ ACTIVE OUTSIDE DNW} >= ^DNW_S_3 
  A = NACT OUTSIDE DNW
  EXT DNW A < DNW_S_3 ABUT < 90 SINGULAR REGION
}
DNW_NW = NW INTERACT DNW
RW = ((HOLES DNW_NW) NOT DNW_NW) INSIDE DNW
RW1V = RW OUTSIDE OD2
RW2V = RW NOT OUTSIDE OD2
RW55V = (RW NOT OUTSIDE OD2) INTERACT DNW55V
RW55V_NODAL = STAMP RW55V BY RWi
RW65V = (RW NOT OUTSIDE OD2) INTERACT DNW65V
RW65V_NODAL = STAMP RW65V BY RWi
PWEL2x = PWELx INTERACT OD2
PWEL2_NODAL = STAMP PWEL2x BY PWELi
RW1V_NODAL = STAMP RW1V BY RWi
RW2V_NODAL = STAMP RW2V BY RWi
PWELx = PWEL NOT INSIDE DNW
PWEL_NODAL = STAMP PWELx BY PWELi
DNW.S.4 { @ RW space to {RW OR PW} with different potential >= ^DNW_S_4 um 
  EXT RW1V_NODAL < DNW_S_4 ABUT < 90 NOT CONNECTED SINGULAR REGION
  EXT RW1V_NODAL PWEL_NODAL < DNW_S_4 ABUT < 90 NOT CONNECTED SINGULAR REGION
}

DNW.S.5 { @ RW space to {{RW OR PW} INTERACT OD2} with different potential >= 1 
  EXT RW2V_NODAL < DNW_S_5 ABUT < 90 NOT CONNECTED SINGULAR REGION
  EXT RW2V_NODAL RW1V_NODAL < DNW_S_5 ABUT < 90 NOT CONNECTED SINGULAR REGION
  EXT RW2V_NODAL PWEL_NODAL < DNW_S_5 ABUT < 90 NOT CONNECTED SINGULAR REGION
}
DNW.EN.1 { @ Enclosure of N+ ACTIVE >= 0.465 
  ENC NACT DNW < DNW_EN_1 ABUT < 90 SINGULAR REGION
}
DNW.O.1 { @ Overlap of NW >= 0.4 
  INT DNW NWEL < DNW_O_1 ABUT < 90 SINGULAR REGION
}
DNW.R.4 { @ N+ ACTIVE cut DNW is not allowed   
    NACT CUT DNW
}


#ENDIF  //FRONT_END
#ENDIF // ESD_LUP_RULE_CHECK_ONLY
#ENDIF // VOLTAGE_RULE_CHECK_ONLY
#ENDIF // EFP_ONLY
#ENDIF // DFM_ONLY
//////////////////////////////



#IFNDEF DFM_ONLY
#IFNDEF EFP_ONLY
#IFNDEF VOLTAGE_RULE_CHECK_ONLY
#IFNDEF ESD_LUP_RULE_CHECK_ONLY
#IFDEF FRONT_END


//OD CHECKS
//=========

OD.W.1 { @ Width >= 0.05 
  (INT OD < OD_W_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}

ODW2_NOTCHECK = NTNi OR VAR
ODW3_NOTCHECK = (((ODW2_NOTCHECK OR LOGO) OR TCDDMY) OR SRESD) OR SDI
ODW4_NOTCHECK = (ODW2_NOTCHECK OR LOGO) OR TCDDMY


OD.W.2 { @ Channel width of core device (This check doesn't include the regions covered by NT_N, and VAR) >= 0.1 
  LV_GATE_W_C = LV_GATE_W NOT INSIDE EDGE ODW2_NOTCHECK
  (LENGTH LV_GATE_W_C < OD_W_2) NOT INSIDE EDGE SRAM_WAIVE_N28
}

OD.W.3 { @ Maximum channel width of core NMOS device (This check doesn't include the regions covered by NT_N, VAR, SDI, and SR_ESD) <= 3 
  LV_GATE_W_C = (LV_GATE_W NOT INSIDE EDGE ODW3_NOTCHECK) INSIDE EDGE NP
  LENGTH LV_GATE_W_C > OD_W_3
}
OD.W.4 { @ Maximum channel width of core PMOS device (This check doesn't include the regions covered by NT_N and VAR) <= 3 
  LV_GATE_W_C = (LV_GATE_W NOT INSIDE EDGE ODW4_NOTCHECK) INSIDE EDGE PP
  (LENGTH LV_GATE_W_C > OD_W_4) NOT INSIDE EDGE ICOVL
}

OD.W.5 { @ Channel width of MOS [I/O device] >= 0.27 
  LENGTH HV_GATE_W < OD_W_5
}

OD_EDGE_45 = OD ANGLE == 45

OD.W.6 { @ Width of 45-degree bent OD. (Please make sure the vertex of 45-degree pattern is on 0.005 um grid. Please refer to G.6gU in section XXX) >= 0.4 
  INT OD_EDGE_45 < OD_W_6 ABUT < 90 REGION
}

OD.S.1 { @ Space >= 0.07 
  (EXT OD < OD_S_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}

HV_OD_E = (OD INSIDE EDGE OD2) NOT INSIDE EDGE LDMOS
OD.S.2 { @ Space [INSIDE OD2] >= 0.15 
  EXT HV_OD_E < OD_S_2 ABUT < 90 REGION
}



OD.S.3 { @ Space to OD [width > 0.09 um] if the parallel run length > 0 um. (P) >= 0.08 
  Wide_OD = OD WITH WIDTH > OD_S_3_W
  (EXT Wide_OD OD < OD_S_3 OPPOSITE REGION MEASURE ALL) NOT INSIDE SRAM_WAIVE_N28
}
OD.S.3.1 { @ At least one side space of {OD OR SR_DOD} [width = 0.05 um] to {OD OR SR_DOD} [width > 0.09 um] if the parallel run lengths > 0 um (width is measured in parallel to space direction) >= 0.09 
  Wide_OD1 = INT [OD_SRDOD] == OD_S_3_1_W1 OPPOSITE
  Wide_OD2 = INT (OD_SRDOD) <= OD_S_3_1_W2 OPPOSITE
  X = EXT [Wide_OD1] Wide_OD2 < OD_S_3_1 OPPOSITE
  (INT X == OD_S_3_1_W1 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28
}
OD.S.4 { @ Space to 45-degree bent OD >= 0.17 
  X = EXPAND EDGE OD_EDGE_45 OUTSIDE BY OD_S_4
  X AND OD
}

OD.S.5 { @ Space between 2 segments of a U-shape or an O-shape OD (notch only) >= 0.13 
  CONVEX EDGE OD ANGLE1 == 270 ANGLE2 == 270 WITH LENGTH < OD_S_5
}
OD.S.6 { @ OD space between 2 segments of a U-shape {OD INTERACT PO} >= 0.21 
  OD_CHECK = OD INTERACT POLY
  CONVEX EDGE OD_CHECK ANGLE1 == 270 ANGLE2 == 270 WITH LENGTH < OD_S_6
}
OD.S.9 { @ OD space to {OD INTERACT PO} in PO ENDCAP direction [channel width < 0.15 um, OD area < 0.0465 um2] >= 0.09 
  GATE_15 = GATE WITH EDGE (LENGTH GATE_W < OD_S_9_W)
  OD_CHK = AREA (OD INTERACT GATE_15) < OD_S_9_A
  OD_CHK_CAP_E = OD_CHK TOUCH EDGE GATE_L
  ((EXPAND EDGE OD_CHK_CAP_E OUTSIDE BY OD_S_9) AND OD) NOT INSIDE SRAM_WAIVE_N28
}


Wide_OD_1 = (OD OR SRDOD) WITH WIDTH > OD_S_10_W1
Wide_OD_2 = (OD OR SRDOD) WITH WIDTH < OD_S_10_W2
Wide_OD_3 = (OD OR SRDOD) WITH WIDTH < OD_S_11_W2

OD.S.10 { @ Space [one {OD OR SRDOD} width > 0.09 um (W1), the other {OD OR SRDOD} width < 0.09 um (W3), and the parallel metal run length > 0.3 um (L3)] >= 0.09 
  A = (EXT Wide_OD_1 Wide_OD_2 < OD_S_10 OPPOSITE REGION MEASURE ALL) NOT (OD OR SRDOD)
  (ENCLOSE RECTANGLE A (OD_S_10_L + GRID) GRID ORTHOGONAL ONLY) NOT INSIDE SRAM_WAIVE_N28
}
OD.S.11 { @ Space [one {OD OR SRDOD} width > 0.09 um (W1), the other {OD OR SRDOD} width < 0.07 um (W4), and the parallel metal run length > 0.3 um (L4)] >= 0.1 
  A = (EXT Wide_OD_1 Wide_OD_3 < OD_S_11 OPPOSITE REGION MEASURE ALL) NOT (OD OR SRDOD)
  (ENCLOSE RECTANGLE A (OD_S_11_L + GRID) GRID ORTHOGONAL ONLY) NOT INSIDE SRAM_WAIVE_N28
}


#IFDEF CHECK_LOW_DENSITY
OD.S.14 { @ Maximum space between {{OD OR SR_DOD} OR DOD} (Except ICOVL) <= 10 
   (((CHIP NOT (SIZE ALL_OD BY OD_S_14/2)) NOT EMPTY_AREA_P4) NOT (EXPAND EDGE CHIP_CHAMFERED_P4 INSIDE BY OD_S_14/2)) NOT INSIDE ICOVL
}

#ENDIF
OD.A.1 { @ Area >= 0.018 
  (AREA OD < OD_A_1) NOT INSIDE SRAM_WAIVE_N28
}
OD.A.2 { @ Area [with all of edge length < 0.13 um] (This check doesn't include the patterns filling 0.1 um x 0.3 um rectangular tiles) >= 0.035 
  A = LENGTH OD >= OD_A_2_L1
  B = OD NOT WITH EDGE A
  C = AREA B < OD_A_2
  NOT ENCLOSE RECTANGLE C OD_A_2_W OD_A_2_L2 ORTHOGONAL ONLY
}
OD.A.3 { @ Area [with any edge length < 0.1 um] >= 0.03 
  A = LENGTH (OD NOT INSIDE LOGO) < OD_A_3_L
  (AREA (OD WITH EDGE A) < OD_A_3) NOT INSIDE SRAM_WAIVE_N28
}
OD.A.4 { @ Enclosed area >= 0.0288 
  A = HOLES OD INNER
  B = A NOT OD
  AREA B < OD_A_4
}
OD.A.5 { @ Enclosed area [with all of inner edge lengths < 0.13 um] >= 0.04 
  A = HOLES OD INNER
  B = LENGTH A >= OD_A_5_L
  C = A NOT WITH EDGE B
  D = C NOT OD
  AREA D < OD_A_5
}
OD.A.6 { @ Maximum ACTIVE area sum of core PMOS device in the same OD. (Not including the gate area) DRC methodology: Maximum area sum of ({Core P+ ACTIVE INTERACT PO} NOT {PO OR SR_DPO}) in the same checking area of OD <= 300 
  PACT_SD_OD = ((PACT INTERACT POLY) NOT OD2) NOT SR_POLY
  DFM PROPERTY OD PACT_SD_OD OVERLAP ABUT ALSO MULTI
  [-= AREA(PACT_SD_OD) ] > OD_A_6
}
OD.L.1 { @ Maximum OD length [OD width < 0.1 um] between 2 CO as well as between one CO and the OD line-end (This check doesn't include the regions covered by {RFDMY AND RFIP_DMY}, and {MOMDMY (155;21) SIZING 0.9 um}.) <= 18 
  EXCEPT_REGION = RFIP OR (SIZE MOMDMY BY OD_L_1_S)
  OD_CHECK = (INOD NOT EXCEPT_REGION) NOT INSIDE SRAM_WAIVE_N28
  LONGP = AREA OD_CHECK > OD_W_1 * OD_L_1	
  X = LONGP INTERACT COOD
  CHECK_COOD = COOD INTERACT X
  A = SIZE CHECK_COOD BY OD_L_1 / 2 INSIDE OF X STEP OD_S_1*0.7
  LINEN = X INTERACT A == 1
  P2P = X INTERACT A > 1
  B = A INTERACT LINEN
  C = SIZE B BY OD_L_1 / 2 INSIDE OF LINEN STEP OD_S_1*0.7
  BAD = (LINEN NOT C) OR (P2P NOT A)
  BAD_EDGE = BAD COIN INSIDE EDGE OD
  ERR = INT BAD_EDGE < OD_L_1_W ABUT < 90 REGION
  X INTERACT ERR
}
OD.L.2 { @ Length of 45-degree bent OD (minimum edge length) >= 0.3 
    LENGTH OD_EDGE_45 < OD_L_2
}
OD.L.5 { @ Max. L-leg length of {OD INTERACT PO} [OD width of L-leg in S/D direction < 0.18 um] <= 0.29 
  CHECK_OD = OD INTERACT POLY
  ERROR_EDGE = (CONVEX EDGE CHECK_OD ANGLE1 == 270 ANGLE2 == 90 WITH LENGTH > OD_L_5) NOT TOUCH EDGE GATE_L
  A = INT ERROR_EDGE CHECK_OD < OD_L_5_W OPPOSITE REGION
  OD_ERROR_EDGE = LENGTH (ERROR_EDGE COIN EDGE A) > OD_L_5
  (ANGLE OD_ERROR_EDGE == 90) COIN EDGE OD_WI_V_POLY
  (ANGLE OD_ERROR_EDGE == 0) COIN EDGE OD_WI_H_POLY
}
OD.R.1 { @ OD must be fully covered by {NP OR PP} (This check doesn't include DOD, SR_DOD, and NWDMY)   
  (((OD NOT INTERACT NWDMY) NOT LOGO) NOT IMP) NOT INSIDE (N1VNIX OR P1VNIX)
}


#ENDIF // FRONT_END
#ENDIF // ESD_LUP_RULE_CHECK_ONLY
#ENDIF // VOLTAGE_RULE_CHECK_ONLY
#ENDIF // EFP_ONLY
#ENDIF // DFM_ONLY

#IFNDEF DFM_ONLY
#IFNDEF EFP_ONLY
#IFNDEF VOLTAGE_RULE_CHECK_ONLY
#IFNDEF ESD_LUP_RULE_CHECK_ONLY
#IFDEF FRONT_END


//DUMMY OD RULE
//================

DOD.W.1 { @ Width >= ^DOD_W_1 um
  INT DOD < DOD_W_1 ABUT < 90 SINGULAR REGION
}
DOD.S.1 { @ Space >= ^DOD_S_1 um
  (EXT DOD < DOD_S_1 ABUT < 90 SINGULAR REGION) NOT INSIDE SEALRING_ALL
}
DOD.S.2 { @ Space to OD (overlap is not allowed) >= 0.34 
  EXT ODi DOD < DOD_S_2 ABUT < 90 SINGULAR REGION INSIDE ALSO
}
DOD.S.3 { @ Space to {PO OR SR_DPO} (Overlap is not allowed) >= ^DOD_S_3 um
  (EXT (POi OR SRDPO) DOD < DOD_S_3 ABUT < 90 SINGULAR REGION INSIDE ALSO) NOT INSIDE SEALRING_ALL
  ((POi OR SRDPO) AND DOD) NOT INSIDE SEALRING_ALL
}
DOD.S.4 { @ Space to NW >= 0.15 
  EXT NWi DOD < DOD_S_4 ABUT < 90 SINGULAR REGION 
}
DOD.S.5 { @ Space to NWDMY (overlap is not allowed) >= 0.6 
  EXT NWDMY DOD < DOD_S_5 ABUT < 90 SINGULAR REGION 
  NWDMY AND DOD
}

DOD.S.8 { @ Space to OD2 ({DOD CUT OD2} is not allowed) >= 0.08 
  EXT DOD OD2 < DOD_S_8 ABUT < 90 SINGULAR REGION 
  DOD CUT OD2
}
DOD.S.9 { @ Space to PP ({DOD CUT PP} is not allowed) >= 0.065 
  EXT DOD PP < DOD_S_9 ABUT < 90 SINGULAR REGION 
  DOD CUT PP
}

DOD.EN.1 { @ Enclosure by NW >= 0.15 
  ENC DOD NWi < DOD_EN_1 ABUT < 90 SINGULAR REGION
  DOD CUT NWi
}

DOD.EN.3 { @ Enclosure by OD2 >= 0.08 
  ENC DOD OD2 < DOD_EN_3 ABUT < 90 SINGULAR REGION
  DOD CUT OD2
}
DOD.EN.4 { @ Enclosure by PP >= 0.065 
  (ENC DOD PP < DOD_EN_4 ABUT < 90 SINGULAR REGION) NOT INSIDE SEALRING_ALL
  (DOD CUT PP) NOT INSIDE SEALRING_ALL
}
DOD.L.1 { @ Length [width < 0.39 um] >= 1 
  DOD_CHK = DOD WITH WIDTH < DOD_L_1_W
  NOT ENCLOSE RECTANGLE DOD_CHK GRID DOD_L_1 ORTHOGONAL ONLY
}

#IFDEF FULL_CHIP
// OD.DN.0 is checked by [OD.DN.3 ~ OD.DN.5]
OD.DN.1 { @ Minimum {{OD OR DOD} OR SR_DOD} density across full chip >= 25% 
  DENSITY ALL_OD CHIP < OD_DN_1 INSIDE OF LAYER CHIPx [ AREA(ALL_OD)/AREA(CHIP) ] PRINT OD.DN.1.density
}
OD.DN.2 { @ Maximum {{OD OR DOD} OR SR_DOD} density across full chip <= 75% 
  DENSITY ALL_OD CHIP > OD_DN_2 INSIDE OF LAYER CHIPx [ AREA(ALL_OD)/AREA(CHIP) ] PRINT OD.DN.2.density
}
#ENDIF

#IFDEF CHECK_LOW_DENSITY


OD.DN.3 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum {{OD OR DOD} OR SR_DOD} local density [window 20 um x 20 um, stepping 10*20% um] (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 20%+3%
#ELSE
@ Minimum {{OD OR DOD} OR SR_DOD} local density [window 20 um x 20 um, stepping 10 um] (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 20% 
#ENDIF
	EXC = (NWDMY OR SEALRING_SIZE_1) OR ICOVL
  N = ALL_OD NOT EXC
  D = CHIP NOT EXC 
  A = CHIPx NOT EXC
  X = DENSITY A ALL_OD CHIP N D < OD_DN_3 WINDOW OD_DN_3_W STEP OD_DN_3_S BACKUP INSIDE OF LAYER CHIPx PRINT OD.DN.3.density RDB OD.DN.3.RDB.density
          [~(AREA(A)-OD_DN_3_E)*!!(AREA(A)-OD_DN_3_E)+AREA(N)/AREA(D)+!~(AREA(ALL_OD)/AREA(CHIP)-OD_DN_3)+!(AREA(ALL_OD)/AREA(CHIP)-OD_DN_3)]


  COPY X    
}
#ENDIF
OD.DN.4 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum {{OD OR DOD} OR SR_DOD} local density [exclude OD2, window 150 um x 150 um, stepping 75*20% um] (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 80%-3% 
#ELSE
@ Maximum {{OD OR DOD} OR SR_DOD} local density [exclude OD2, window 150 um x 150 um, stepping 75 um] (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 80% 
#ENDIF
  EXC = ((NWDMY OR SEALRING_SIZE_1) OR OD2) OR ICOVL
  N = ALL_OD NOT EXC
  D = CHIP NOT EXC 
  A = CHIPx NOT EXC
  X = DENSITY A ALL_OD CHIP N D > OD_DN_4 WINDOW OD_DN_4_W STEP OD_DN_4_S BACKUP INSIDE OF LAYER CHIPx PRINT OD.DN.4.density RDB OD.DN.4.RDB.density
          [~(OD_DN_4_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(ALL_OD)/AREA(CHIP)-OD_DN_4)]


  COPY X  
}
OD.DN.5 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum {{OD OR DOD} OR SR_DOD} local density [window 150 um x 150 um, stepping 75*20% um] (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 90%-3% 
#ELSE
@ Maximum {{OD OR DOD} OR SR_DOD} local density [window 150 um x 150 um, stepping 75 um] (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 90% 
#ENDIF

  EXC = (NWDMY OR SEALRING_SIZE_1) OR ICOVL
  N = ALL_OD NOT EXC
  D = CHIP NOT EXC 
  A = CHIPx NOT EXC
  X = DENSITY A ALL_OD CHIP N D > OD_DN_5 WINDOW OD_DN_5_W STEP OD_DN_5_S BACKUP INSIDE OF LAYER CHIPx PRINT OD.DN.5.density RDB OD.DN.5.RDB.density
          [~(OD_DN_5_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(ALL_OD)/AREA(CHIP)-OD_DN_5)]


  COPY X   
}

#IFDEF FULL_CHIP
DOD.R.1 { @ DOD is must. DOD must be an individual CAD layer (datatype 1 as default, like 6;1)
  MERGE (CHIP NOT INTERACT DOD)
}
#ENDIF

// DOD.R.2 is checked by CSR.R.1:DOD

DOD.R.3 { @ Only square (or rectangular) and solid shapes are allowed. A 45-degree shape is not allowed   
  (NOT RECTANGLE DOD ORTHOGONAL ONLY) NOT INSIDE SEALRING_ALL
}




//THICK OXIDE CHECKS
//==================


OD2.W.1 { @ Width >= 0.32 
  INT OD2 < OD2_W_1 ABUT < 90 SINGULAR REGION
}
OD2.W.2 { @ Width of {OD2 OR {NW OR NT_N}} >= 0.24 
  A = (OD2i OR NWi) OR NTNi
  (INT A < OD2_W_2 ABUT < 90 OPPOSITE SYMMETRIC REGION) NOT INSIDE SRAM_WAIVE_N28
  (INT A < OD2_W_2 ABUT < 90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (INT A < OD2_W_2 ABUT < 90 PROJ == 0 REGION) NOT INSIDE SRAM_WAIVE_N28
}

VARIABLE OD2_W_2_1_90 90 // user value
VARIABLE OD2_W_2_1_0 0 // user value
VARIABLE OD2_W_2_1_0.16 0.16
OD2.W.2.1 { @ Width of {{OD2 OR {NW OR NT_N}} OR AVT} >= 0.16 
  A = (OD2i OR (NWi OR NTNi)) OR AVT
  (INT A < OD2_W_2_1_0.16 ABUT < OD2_W_2_1_90 OPPOSITE SYMMETRIC REGION) NOT INSIDE SRAM_WAIVE_N28
  (INT A < OD2_W_2_1_0.16 ABUT < OD2_W_2_1_90 CORNER SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
  (INT A < OD2_W_2_1_0.16 ABUT < OD2_W_2_1_90 PROJ == OD2_W_2_1_0 REGION) NOT INSIDE SRAM_WAIVE_N28
}



OD2.S.1 { @ Space >= 0.32 
  EXT OD2 < OD2_S_1 ABUT < 90 SINGULAR REGION
}





OD2.S.2 { @ Space to {ACTIVE OR GATE} ({ACTIVE OR GATE} cut OD2 is not allowed) >= 0.13 
  DACTG = (DACT OR GATE) NOT INSIDE OTP  
  EXT OD2 DACTG < OD2_S_2 ABUT < 90 SINGULAR REGION
  DACTG CUT OD2
}

OD2.S.3 { @ Space to core GATE in S/D direction >= 0.24 
  (EXT OD2 GATE_W < OD2_S_3 ABUT < 90 OPPOSITE REGION) NOT INSIDE OTP
  (GATE CUT OD2) NOT INSIDE OTP
}
OD2.S.4 { @ Space to NW. Space = 0 um is allowed >= 0.24 
  EXT OD2 NWEL < OD2_S_4 ABUT < 90 > 0 SINGULAR REGION
}
OD2.S.5 { @ Space of {NW NOT OD2} >= 0.24 
  X = NWi NOT OD2i
  EXT X < OD2_S_5 ABUT < 90 SINGULAR REGION
}
OD2.S.6 { @ Space of {OD2 AND NW} >= 0.24 
  X = NWi AND OD2i
  EXT X < OD2_S_6 ABUT < 90 SINGULAR REGION
}

OD2.S.7 { @ Space of {{OD2 NOT {NW OR NT_N}} OR AVT} (except 0.16 um <= violation space of AVT < 0.24 um) >= 0.24 
    EXT (OD2i NOT (NWi OR NTNi)) AVT < OD2_S_7 ABUT >0 < 90 SINGULAR REGION
    EXT (OD2i NOT (NWi OR NTNi))  < OD2_S_7 ABUT < 90 SINGULAR REGION
    EXT AVT < OD2_S_7A ABUT < 90 SINGULAR REGION
}





OD2.EN.1 { @ Enclosure of 1.8V/2.5V GATE in S/D direction >= 0.24 
  ENC GATE_W OD18 < OD2_EN_1 ABUT < 90 OPPOSITE REGION
  ENC GATE_W OD25 < OD2_EN_1 ABUT < 90 OPPOSITE REGION    
}

OD2.EX.1 { @ NW extension on OD2. Extension = 0 um is allowed >= 0.24 
  ENC OD2 NWEL < OD2_EX_1 ABUT < 90 > 0 SINGULAR REGION
}
OD2.EX.2 { @ Extension on NW. Extension = 0 um is allowed >= 0.24 
  ENC NWEL OD2 < OD2_EX_2 ABUT < 90 > 0 SINGULAR REGION
}
OD2.EX.3 { @ Extension on {ACTIVE OR GATE} >= 0.13 
   // This only applies to active OD or gate
   DACTG = DACT OR GATE  
   CHECK_EDGE = ENC [DACTG] OD2 < OD2_EX_3 ABUT < 90 SINGULAR
   CHECK_EDGE NOT COIN OUTSIDE EDGE DSTP
}
OD2.O.1 { @ Overlap of NW. Overlap = 0 um is allowed >= 0.24 
  X = OD2 AND NWEL
  INT X < OD2_O_1 ABUT < 89.5 SINGULAR REGION
}

OD2.A.1 { @ Area >= 0.4 
  AREA OD2 < OD2_A_1
}
OD2.A.2 { @ Enclosed area >= 0.4 
  A = HOLES OD2 INNER
  B = A NOT OD2
  AREA B < OD2_A_2
}
OD2.R.1 { @ OD_18 and OD_25 can't be used on same die   
  X = CHIP INTERACT OD25
  X INTERACT OD18
}

WEL_CHK1 = SIZE (SIZE (SIZE ((OD2 OR NWEL) OR NTN) BY 0.08) BY -0.16) BY 0.08
WEL_CHK2 = SIZE (SIZE (SIZE ((OD2 NOT NWEL) NOT NTN) BY 0.08) BY -0.16) BY 0.08
WEL_CHK3 = SIZE (SIZE (SIZE (NWEL NOT OD2) BY 0.08) BY -0.16) BY 0.08
WEL_CHK4 = SIZE (SIZE (SIZE (NWEL AND OD2) BY 0.08) BY -0.16) BY 0.08

WEL.A.1 { @ Area of {{{{{OD2 OR NW} OR NT_N} SIZING 0.08 um} SIZING -0.16 um} SIZING 0.08 um}, {{{{{OD2 NOT NW} NOT NT_N} SIZING 0.08 um} SIZING -0.16 um} SIZING 0.08 um}, {{{{NW NOT OD2} SIZING 0.08 um} SIZING -0.16 um} SIZING 0.08 um}, {{{{NW AND OD2} SIZING 0.08 um} SIZING -0.16 um} SIZING 0.08 um} >= 0.4 
  AREA WEL_CHK1 < WEL_A_1
  AREA WEL_CHK2 < WEL_A_1
  AREA WEL_CHK3 < WEL_A_1
  AREA WEL_CHK4 < WEL_A_1
}

WEL.A.2 { @ Enclosed area of {{{{{OD2 OR NW} OR NT_N} SIZING 0.08 um} SIZING -0.16 um} SIZING 0.08 um}, {{{{{OD2 NOT NW} NOT NT_N} SIZING 0.08 um} SIZING -0.16 um} SIZING 0.08 um}, {{{{NW NOT OD2} SIZING 0.08 um} SIZING -0.16 um} SIZING 0.08 um}, {{{{NW AND OD2} SIZING 0.08 um} SIZING -0.16 um} SIZING 0.08 um} >= 0.4 
  AREA ((HOLES WEL_CHK1 INNER) NOT WEL_CHK1) < WEL_A_2
  AREA ((HOLES WEL_CHK2 INNER) NOT WEL_CHK2) < WEL_A_2
  AREA ((HOLES WEL_CHK3 INNER) NOT WEL_CHK3) < WEL_A_2
  AREA ((HOLES WEL_CHK4 INNER) NOT WEL_CHK4) < WEL_A_2
}


//OD25_33 CHECKS
//==============
25_33V_GATE_L = HV_GATE_L INSIDE EDGE OD2533

OD25_33.W.1 { @ Channel length of 2.5V NMOS overdrive to 3.3V {NMOS GATE AND OD25_33} = 0.55~2 
  25_33V_GATE_L_NP = 25_33V_GATE_L INSIDE EDGE NP
  LENGTH 25_33V_GATE_L_NP < OD25_33_W_1A
  LENGTH 25_33V_GATE_L_NP > OD25_33_W_1B
}
OD25_33.W.2 { @ Channel length of 2.5V PMOS overdrive to 3.3V {PMOS GATE AND OD25_33} = 0.44~2 
  25_33V_GATE_L_PP = 25_33V_GATE_L INSIDE EDGE PP
  LENGTH 25_33V_GATE_L_PP < OD25_33_W_2A
  LENGTH 25_33V_GATE_L_PP > OD25_33_W_2B
}
OD25_33.W.3 { @ Channel length of 2.5V native NMOS overdrive to 3.3V. {{GATE AND NT_N} AND OD25_33} = 1.2~2 
  25_33V_GATE_L_NP_NTN = (25_33V_GATE_L INSIDE EDGE NP) INSIDE EDGE NTN
  LENGTH 25_33V_GATE_L_NP_NTN < OD25_33_W_3A
  LENGTH 25_33V_GATE_L_NP_NTN > OD25_33_W_3B
}
OD25_33.R.1 { @ {GATE AND OD25_33} can't overlap OD_18, OD18_12, OD18_15 or OD25_18. {GATE AND OD25_33} must be covered by OD_25. GATE cut OD25_33 is not allowed   
  25_33V_GATE = GATE AND OD2533
  25_33V_GATE AND OD18
  25_33V_GATE AND OD1812
  25_33V_GATE AND OD1815
  25_33V_GATE AND OD2518
  25_33V_GATE AND OD15
  25_33V_GATE AND OD1518
  25_33V_GATE NOT OD25
  GATE CUT OD2533
}
OD25_33.R.2 { @ 2.5V GATE, 1.8V GATE or 3.3V GATE can't share same NW   
 25_GATE = ((HV_GATE AND OD25) NOT OD2533) NOT OD2518
 2533_GATE = HV_GATE AND OD2533
 2518_GATE = HV_GATE AND OD2518
 (NWEL INTERACT 25_GATE) INTERACT 2533_GATE
 (NWEL INTERACT 25_GATE) INTERACT 2518_GATE
 (NWEL INTERACT 2533_GATE) INTERACT 2518_GATE
}


OD25_33P_LL.R.1 { @ OD25_33_LL must be drawn identically to OD25_33   
    OD25_33P_LL XOR (OD2533 INTERACT OD25_33P_LL)
}





//OD25_18 CHECKS
//==============
25_18V_GATE_L = HV_GATE_L NOT OUTSIDE EDGE OD2518

OD25_18.W.1 { @ Channel length of 2.5V MOS underdrive to 1.8V {GATE AND OD25_18} = 0.25~2 
  LENGTH 25_18V_GATE_L < OD25_18_W_1A
  LENGTH 25_18V_GATE_L > OD25_18_W_1B
}
OD25_18.W.2 { @ Channel length of 2.5V native NMOS underdrive to 1.8V {{GATE AND NT_N} AND OD25_18} = 1.2~2 
  25_18V_GATE_L_NP_NTN = 25_18V_GATE_L INSIDE EDGE NTN
  LENGTH 25_18V_GATE_L_NP_NTN < OD25_18_W_2A
  LENGTH 25_18V_GATE_L_NP_NTN > OD25_18_W_2B
}
OD25_18.R.1 { @ {GATE AND OD25_18} can't overlap OD_18, OD18_12, OD18_15, or OD25_33. {GATE AND OD25_18} must be covered by OD_25. GATE cut OD25_18 is not allowed   
  25_18V_GATE = GATE AND OD2518
  25_18V_GATE AND OD15
  25_18V_GATE AND OD1518
  25_18V_GATE AND OD1815
  25_18V_GATE AND OD1812  
  25_18V_GATE AND OD18
  25_18V_GATE AND OD2533  
  25_18V_GATE NOT OD25
  GATE CUT OD2518
}



//OD18_15 CHECKS
//==============
18_15V_GATE_L = HV_GATE_L NOT OUTSIDE EDGE OD1815
18_15V_POLY = POLY NOT OUTSIDE OD1815

OD18_15.W.1 { @ Channel length of 1.8V MOS underdrive to 1.5V {GATE AND OD18_15} = 0.105~2 
  LENGTH 18_15V_GATE_L < OD18_15_W_1A
  LENGTH 18_15V_GATE_L > OD18_15_W_1B
}
OD18_15.W.2 { @ PO width of 1.8V MOS underdrive to 1.5V (PO AND OD18_15) = ^OD18_15_W_2A ~ ^OD18_15_W_2B
  INT 18_15V_POLY < OD18_15_W_2A ABUT < 90 SINGULAR REGION
  18_15V_POLY WITH WIDTH > OD18_15_W_2B
}
OD18_15.R.1 { @ {GATE AND OD18_15} can't overlap OD18_12, OD_25, OD25_18, or OD25_33. {GATE AND OD18_15} must be covered by OD_18. GATE cut OD18_15 is not allowed   
  18_15V_GATE = GATE AND OD1815
  18_15V_GATE AND OD15
  18_15V_GATE AND OD1518
  18_15V_GATE AND OD1812  
  18_15V_GATE AND OD25
  18_15V_GATE AND OD2518  
  18_15V_GATE AND OD2533
  18_15V_GATE NOT OD18
  GATE CUT OD1815
}

OD18_15.R.2 { @ 1.8V GATE, 1.5V GATE or 1.2V GATE can't share same NW   
 18_GATE = ((HV_GATE AND OD18) NOT OD1815) NOT OD1812
 1815_GATE = HV_GATE AND OD1815
 1812_GATE = HV_GATE AND OD1812
 (NWEL INTERACT 18_GATE) INTERACT 1815_GATE
 (NWEL INTERACT 18_GATE) INTERACT 1812_GATE
 (NWEL INTERACT 1815_GATE) INTERACT 1812_GATE
}



//OD18_12 CHECKS
//==============

18_12V_GATE_L = HV_GATE_L NOT OUTSIDE EDGE OD1812
18_12V_GATE = GATE AND OD1812

OD18_12.W.1 { @ Channel length of 1.8V MOS underdrive to 1.2V {GATE AND OD18_12} = 0.09~2 
  LENGTH 18_12V_GATE_L < OD18_12_W_1A
  LENGTH 18_12V_GATE_L > OD18_12_W_1B
}

OD18_12.W.1.1 { @ Channel length of 1.8V MOS underdrive to 1.2V {GATE AND OD18_12} [for horizontal poly] = 0.1~2 
  A = ANGLE 18_12V_GATE_L == 90 
  LENGTH A < OD18_12_W_1_1
}

OD18_12.W.2 { @ PO width of 1.8V MOS underdrive to 1.2V {PO AND OD18_12} (This check doesn't include the regions covered by RH_PO) = 0.09~2 
  POLY_CHK = (POLY AND OD1812) NOT INSIDE RHPO
  POLY_CHK WITH WIDTH < OD18_12_W_2A
  POLY_CHK WITH WIDTH > OD18_12_W_2B
}





OD18_12.W.2.1 { @ PO width of 1.8V MOS underdrive to 1.2V {PO AND OD18_12} [for horizontal poly] = 0.1~2 
  POLY_CHK = POLY AND OD1812
  X = ANGLE POLY_CHK == 0
  INT POLY_CHK X < OD18_12_W_2_1 ABUT < 90 REGION
}

OD18_12.R.1 { @ {GATE AND OD18_12} can't overlap NT_N, OD18_15, OD_25, OD25_18, OD25_33 or VAR. {GATE AND OD18_12} must be covered by OD_18. GATE cut OD18_12 is not allowed   
  18_12V_GATE AND NTNi
  18_12V_GATE AND OD1815
  18_12V_GATE AND OD25
  18_12V_GATE AND OD2518
  18_12V_GATE AND OD2533 
  18_12V_GATE AND OD15
  18_12V_GATE AND OD1518
  18_12V_GATE AND VARi
  18_12V_GATE NOT OD18
  GATE CUT OD1812
}





//PO CHECKS
//=========
POW_EXCLUDE = ((NTNi OR SRESD) OR SDI) OR VAR
POS_EXCLUDE = SDI OR SRESD
POR_EXCLUDE = COPY CSRDMY

POS_EXCLUDE_1 = ((SDI OR SRESD) OR VAR) OR LOGO
POS_EXCLUDE_S4 = (((SDI OR SRESD) OR VAR) OR LOGO) OR SRAM_WAIVE_N28
POS_EXCLUDE_S16 = (((SDI OR SRESD) OR VAR) OR NTNi) OR SRAM_WAIVE_N28
POS_EXCLUDE_EX2 = ((SDI OR SRESD) OR LOGO) OR SRAM_WAIVE_N28

RFPP_EXC = OR RF_PP (RF_PP AND RF_SL1)
POS_EXCLUDE_S4_new = ((((SDI OR SRESD) OR VAR) OR LOGO) OR SRAM_WAIVE_N28) OR RFPP_EXC
POS_EXCLUDE_1_new = (((SDI OR SRESD) OR VAR) OR LOGO) OR RFPP_EXC
POS_EXCLUDE_new = (SDI OR SRESD) OR RFPP_EXC
PO.W.1 { @ Width >= 0.03 
  INT POLY < PO_W_1 ABUT < 90 SINGULAR REGION
}

SR_POLY_HORIZONTAL = ANGLE SR_POLY == 0  

PO.W.2 { @ Width of horizontal {PO OR SR_DPO} (This check doesn't include {RH_PO INTERACT RPO}) >= 0.08 
  (INT SR_POLY SR_POLY_HORIZONTAL < PO_W_2 ABUT < 90 OPPOSITE REGION) NOT INSIDE (OR (RHPO INTERACT RPO) SRAM_WAIVE_N28) 
}

PO.W.3 { @ Width of {PO NOT INTERACT OD2} (This check doesn't include the regions covered by NT_N, SR_ESD, SDI, VAR, RFDMY and RH_PO.) = 0.03/0.035/0.04/0.05/0.06/0.08/0.09~1 
  POLY_CHECK = (((((POLY NOT INTERACT OD2) NOT INSIDE POW_EXCLUDE) NOT INSIDE RHPO) NOT INSIDE RFDMY) NOT INSIDE LOGO) NOT INSIDE SRAM_WAIVE_N28
  POLY_CHECK WITH WIDTH < PO_W_3A
  POLY_CHECK WITH WIDTH > PO_W_3A < PO_W_3B
  POLY_CHECK WITH WIDTH > PO_W_3B < PO_W_3C
  POLY_CHECK WITH WIDTH > PO_W_3C < PO_W_3D
  POLY_CHECK WITH WIDTH > PO_W_3D < PO_W_3E
  POLY_CHECK WITH WIDTH > PO_W_3E < PO_W_3F
  POLY_CHECK WITH WIDTH > PO_W_3F < PO_W_3G
  POLY_CHECK WITH WIDTH > PO_W_3H
}


PO.W.8 { @ Channel length of core device (This check doesn't include the regions covered by OD2, NT_N, SR_ESD, SDI, RFDMY and VAR) = 0.03/0.035/0.04/0.05/0.06/0.08/0.09~1 
  GATE_L_CHECK = GATE_L OUTSIDE EDGE ((((OD2 OR POW_EXCLUDE) OR RFDMY) OR LOGO) OR SRAM_WAIVE_N28)
  GATE_L_CHECK LENGTH < PO_W_3A
  GATE_L_CHECK LENGTH > PO_W_3A < PO_W_3B
  GATE_L_CHECK LENGTH > PO_W_3B < PO_W_3C
  GATE_L_CHECK LENGTH > PO_W_3C < PO_W_3D
  GATE_L_CHECK LENGTH > PO_W_3D < PO_W_3E
  GATE_L_CHECK LENGTH > PO_W_3E < PO_W_3F
  GATE_L_CHECK LENGTH > PO_W_3F < PO_W_3G
  GATE_L_CHECK LENGTH > PO_W_3H
}







PO.W.4 { @ Width of {{PO NOT OUTSIDE OD2} NOT INTERACT {OD18_15 OR OD18_12}} (for 1.8V underdrive to 1.5V/1.2V, please refer to section on OD18_15/OD18_12 layout rules.) (This check doesn't include the regions covered by VAR, RH_PO) = 0.15~2 
  CHECK1 = OR VAR RHPO
  POLY_CHK = (((POLY NOT OUTSIDE OD2) NOT INTERACT OD1815) NOT INTERACT (OD15 OR (OD1518 OR OD1812))) NOT INSIDE CHECK1
  INT POLY_CHK < PO_W_4A ABUT < 90 SINGULAR REGION
  POLY_CHK WITH WIDTH > PO_W_4B
}





PO.W.5 { @ Channel length of 2.5V MOS (for 2.5V overdrive to 3.3V, please refer to section on OD25_33 layout rules; for 2.5V underdrive to 1.8V, please refer to section on OD25_18 layout rules.) (This check doesn't include the regions covered by VAR) = 0.27~2 
  25V_GATE_CHECK = (HV_GATE INSIDE OD25) NOT INSIDE (((OD2518 OR OD2533) OR GATED) OR VAR)
  25V_GATE_L_CHECK = 25V_GATE_CHECK TOUCH EDGE GATE_L
  LENGTH 25V_GATE_L_CHECK < PO_W_5A
  LENGTH 25V_GATE_L_CHECK > PO_W_5B
}

PO.W.6 { @ Channel length of 1.8V MOS (for 1.8V underdrive to 1.5V/1.2V, please refer to section on OD18_15/OD18_12 layout rules.) (This check doesn't include the regions covered by VAR) = 0.15~2 
  18V_GATE_CHECK = (HV_GATE INSIDE OD18) NOT INSIDE ((OD1815 OR OD1812) OR VAR)
  18V_GATE_L_CHECK = 18V_GATE_CHECK TOUCH EDGE GATE_L
  LENGTH 18V_GATE_L_CHECK < PO_W_6A
  LENGTH 18V_GATE_L_CHECK > PO_W_6B
}
PO.W.7 { @ Maximum poly width (This check doesn't include the regions covered by VAR) <= 2 
  (POLY WITH WIDTH > PO_W_7) NOT INSIDE VAR
}

//   POLY CDU Rules
////////////////////////////////

PO_CDU_WAIVE = ((LOGO OR OD2) OR SRAM_WAIVE_N28) OR (SRESD OR SDI)
GATE_L030 = GATE WITH EDGE (LENGTH GATE_L == PO_W_15_W)
GATE_L035_045 = GATE WITH EDGE (LENGTH GATE_L >= PO_W_16_W1 <= PO_W_16_W2)
GATE_L050_090 = GATE WITH EDGE (LENGTH GATE_L >= PO_W_17_W1 <= PO_W_17_W2)
GATE_L095 = GATE WITH EDGE (LENGTH GATE_L > PO_W_18_W)

SDx = (OD INTERACT GATE) NOT GATE     
NO_LAST_GATE = RECTANGLE (SDx INTERACT GATE > 1) ORTHOGONAL ONLY
SOME_LAST_GATE = NOT RECTANGLE (SDx INTERACT GATE > 1) ORTHOGONAL ONLY
MUST_LAST_GATE = SDx INTERACT GATE == 1
GATE_W_CDU = (GATE_W NOT INSIDE EDGE PO_CDU_WAIVE) NOT COIN OUTSIDE EDGE NO_LAST_GATE
GATE_W_CDU1 = GATE_W_CDU COIN OUTSIDE EDGE SOME_LAST_GATE
GATE_W_CDU2 = GATE_W_CDU COIN OUTSIDE EDGE MUST_LAST_GATE

CHECK_LAST_GATE_EDGE_pre = ENC [GATE_W_CDU1] OD < PO_S_5 OPPOSITE
CHECK_LAST_GATE_EDGE = GATE_W_CDU TOUCH EDGE (CHECK_LAST_GATE_EDGE_pre OR EDGE GATE_W_CDU2)

GATE_L030_CHK = (GATE_L030 COIN EDGE CHECK_LAST_GATE_EDGE) NOT INSIDE EDGE RFPP_EXC
GATE_L035_045_CHK = GATE_L035_045 COIN EDGE CHECK_LAST_GATE_EDGE
GATE_L050_090_CHK = GATE_L050_090 COIN EDGE CHECK_LAST_GATE_EDGE
GATE_L095_CHK = (GATE_L095 COIN EDGE CHECK_LAST_GATE_EDGE) NOT INSIDE EDGE VAR

// for 060 waive DMY_SCH
GATE_W_CDU_NSCH = ((GATE_W NOT INSIDE EDGE PO_CDU_WAIVE) NOT COIN OUTSIDE EDGE NO_LAST_GATE) NOT INSIDE EDGE DMY_SCH
GATE_W_CDU1_NSCH = GATE_W_CDU_NSCH COIN OUTSIDE EDGE SOME_LAST_GATE
GATE_W_CDU2_NSCH = GATE_W_CDU_NSCH COIN OUTSIDE EDGE MUST_LAST_GATE
CHECK_LAST_GATE_EDGE_pre_NSCH = ENC [GATE_W_CDU1_NSCH] OD < PO_S_5 OPPOSITE
CHECK_LAST_GATE_EDGE_NSCH = GATE_W_CDU_NSCH TOUCH EDGE (CHECK_LAST_GATE_EDGE_pre_NSCH OR EDGE GATE_W_CDU2_NSCH)
GATE_L030_CHK_NSCH = GATE_L030 COIN EDGE CHECK_LAST_GATE_EDGE_NSCH

// for 060 inside DMY_SCH
GATE_W_CDU_SCH = ((GATE_W NOT INSIDE EDGE PO_CDU_WAIVE) NOT COIN OUTSIDE EDGE NO_LAST_GATE) INSIDE EDGE DMY_SCH
GATE_W_CDU1_SCH = GATE_W_CDU_SCH COIN OUTSIDE EDGE SOME_LAST_GATE
GATE_W_CDU2_SCH = GATE_W_CDU_SCH COIN OUTSIDE EDGE MUST_LAST_GATE
CHECK_LAST_GATE_EDGE_pre_SCH = ENC [GATE_W_CDU1_SCH] OD < PO_S_5 OPPOSITE
CHECK_LAST_GATE_EDGE_SCH = GATE_W_CDU_SCH TOUCH EDGE (CHECK_LAST_GATE_EDGE_pre_SCH OR EDGE GATE_W_CDU2_SCH)
GATE_L030_CHK_SCH = GATE_L030 COIN EDGE CHECK_LAST_GATE_EDGE_SCH

PO.W.15 { @ Width of {PO OR SR_DPO} [in S/D and outside OD direction] neighboring to LAST GATE [channel length = 0.03 um, {PO OR SR_DPO} to LAST GATE space < 0.23 um] (This check doesn't include the region covered by OD2, SR_ESD, SDI and DMY_SCH) = 0.03 
  A = EXT GATE_L030_CHK_NSCH [SR_POLY] < PO_W_15_S OPPOSITE
  B = INT [A] SR_POLY == PO_W_15 OPPOSITE
  C = EXT [GATE_L030_CHK_NSCH] B < PO_W_15_S OPPOSITE
#IFDEF SKIP_CELL_BOUNDARY
  D = ENC [GATE_L030_CHK_NSCH] PRBOUNDARY < PO_W_15_S EXCLUDE SHIELDED 4 OPPOSITE
  E = C OR EDGE D
#ELSE
  E = COPY C
#ENDIF
  GATE_L030_CHK_NSCH NOT COIN EDGE E

}
PO.W.15.1 { @ Width of {PO OR SR_DPO} [in S/D and outside OD direction] neighboring to LAST GATE [channel length = 0.03 um, {PO OR SR_DPO} to LAST GATE space < 0.23 um, INSIDE DMY_SCH (255;52)] (Except OD2, SR_ESD and SDI) = 0.03, 0.035 
	A = EXT GATE_L030_CHK_SCH [SR_POLY] < PO_W_15_S OPPOSITE
	B = INT [A] SR_POLY >= PO_W_15 <= PO_W_15B OPPOSITE
  C = EXT [GATE_L030_CHK_SCH] B < PO_W_15_S OPPOSITE
#IFDEF SKIP_CELL_BOUNDARY
  D = ENC [GATE_L030_CHK_SCH] PRBOUNDARY < PO_W_15_S EXCLUDE SHIELDED 4 OPPOSITE
  E = C OR EDGE D
#ELSE
  E = COPY C
#ENDIF
  GATE_L030_CHK_SCH NOT COIN EDGE E
}
PO.W.16 { @ Width of {PO OR SR_DPO} [in S/D and outside OD direction] neighboring to LAST GATE [channel length= 0.035 um ~ 0.045 um, {PO OR SR_DPO} to LAST GATE space < 0.23 um] (This check doesn't include the region covered by OD2, SR_ESD and SDI) = 0.03~0.05 
  A = EXT GATE_L035_045_CHK [SR_POLY] < PO_W_16_S OPPOSITE
  B = INT [A] SR_POLY >= PO_W_16A <= PO_W_16B OPPOSITE
  C = EXT [GATE_L035_045_CHK] B < PO_W_16_S OPPOSITE
#IFDEF SKIP_CELL_BOUNDARY
  D = ENC [GATE_L035_045_CHK] PRBOUNDARY < PO_W_16_S EXCLUDE SHIELDED 4 OPPOSITE
  E = C OR EDGE D
#ELSE
  E = COPY C
#ENDIF
  GATE_L035_045_CHK NOT COIN EDGE E

}
PO.W.17 { @ Width of {PO OR SR_DPO} [in S/D and outside OD direction] neighboring to LAST GATE [channel length = 0.05 um ~ 0.09 um, {PO OR SR_DPO} to LAST GATE space < 0.23 um] (This check doesn't include the region covered by OD2, SR_ESD and SDI) = 0.04~0.09 
  A = EXT GATE_L050_090_CHK [SR_POLY] < PO_W_17_S OPPOSITE
  B = INT [A] SR_POLY >= PO_W_17A <= PO_W_17B OPPOSITE
  C = EXT [GATE_L050_090_CHK] B < PO_W_17_S OPPOSITE
#IFDEF SKIP_CELL_BOUNDARY
  D = ENC [GATE_L050_090_CHK] PRBOUNDARY < PO_W_17_S EXCLUDE SHIELDED 4 OPPOSITE
  E = C OR EDGE D
#ELSE
  E = COPY C
#ENDIF
  GATE_L050_090_CHK NOT COIN EDGE E

}
PO.W.18 { @ Width of {PO OR SR_DPO} [in S/D and outside OD direction] neighboring to LAST GATE [channel length > 0.09 um, {PO OR SR_DPO} to LAST GATE space < 0.23 um] (This check doesn't include the region covered by OD2, VAR, SR_ESD and SDI) >= 0.04 
  A = EXT GATE_L095_CHK [SR_POLY] < PO_W_18_S OPPOSITE
  B0 = INT [A] SR_POLY < PO_W_18A OPPOSITE
  B = A NOT COIN EDGE B0
  C = EXT [GATE_L095_CHK] B < PO_W_18_S OPPOSITE
#IFDEF SKIP_CELL_BOUNDARY
  D = ENC [GATE_L095_CHK] PRBOUNDARY < PO_W_18_S EXCLUDE SHIELDED 4 OPPOSITE
  E = C OR EDGE D
#ELSE
  E = COPY C
#ENDIF
  GATE_L095_CHK NOT COIN EDGE E

}
PO.W.19__PO.S.43 { @ Width of 2nd {PO OR SR_DPO} [in S/D and outside OD direction] from LAST GATE [channel length = 0.03 um, 2nd {PO OR SR_DPO} to LAST GATE space = 0.23 um ~ 0.26 um (E1)], and the violation with length ratio < 10% is allowed. Definition of length ratio = violation length / device width (This check doesn't include the region covered by OD2, SR_ESD, SDI, RF_PP, {RF_PP AND RF_SL1}) = 0.03~0.12 
  A = EXT GATE_L030_CHK [SR_POLY] >= PO_W_19_S1 <= PO_W_19_S2 MEASURE ALL OPPOSITE
  B = INT [A] SR_POLY >= PO_W_19A <= PO_W_19B OPPOSITE
  C = EXT [GATE_L030_CHK] B >= PO_W_19_S1 <= PO_W_19_S2 MEASURE ALL OPPOSITE
#IFDEF SKIP_CELL_BOUNDARY
  D = ENC [GATE_L030_CHK] PRBOUNDARY <= PO_W_19_S2 EXCLUDE SHIELDED 4 OPPOSITE
  E = C OR EDGE D
#ELSE
  E = COPY C
#ENDIF
  DFM PROPERTY GATE_L030_CHK E OVERLAP ABUT ALSO MULTI
  [ -= LENGTH(E) / LENGTH(GATE_L030_CHK)] <= (1 - PO_W_19_R)

}
PO.W.20__PO.S.44 { @ Width of 2nd {PO OR SR_DPO} [in S/D and outside OD direction] from LAST GATE [channel length = 0.035 um ~ 0.045 um, 2nd {PO OR SR_DPO} to LAST GATE space = 0.23 um ~ 0.28 um (E1)], and the violation with length ratio < 10% is allowed. Definition of length ratio follows PO.W.19 (This check doesn't include the region covered by OD2, SR_ESD, SDI, RF_PP, {RF_PP AND RF_SL1}) = 0.03~0.12 
  GATE_L035_045_CHKx = GATE_L035_045_CHK NOT INSIDE EDGE RFPP_EXC
  A = EXT GATE_L035_045_CHKx [SR_POLY] >= PO_W_20_S1 <= PO_W_20_S2 MEASURE ALL OPPOSITE
  B = INT [A] SR_POLY >= PO_W_20A <= PO_W_20B OPPOSITE
  C = EXT [GATE_L035_045_CHKx] B >= PO_W_20_S1 <= PO_W_20_S2 MEASURE ALL OPPOSITE
#IFDEF SKIP_CELL_BOUNDARY
  D = ENC [GATE_L035_045_CHKx] PRBOUNDARY <= PO_W_20_S2 EXCLUDE SHIELDED 4 OPPOSITE
  E = C OR EDGE D
#ELSE
  E = COPY C
#ENDIF
  DFM PROPERTY GATE_L035_045_CHKx E OVERLAP ABUT ALSO MULTI
  [ -= LENGTH(E) / LENGTH(GATE_L035_045_CHKx)] <= (1 - PO_W_20_R)

}


//   POLY SPACE Rules
////////////////////////////////
PO.S.3 { @ Space >= 0.08 
  (EXT POLY < PO_S_3 ABUT < 90 SINGULAR REGION) NOT INSIDE LOGO
}

PO.S.4 { @ The {{GATE SIZING 0.06 um} AND PO} space to neighboring poly {PO OR SR_DPO} of core device [channel length <= 0.09 um]. (This check doesn't include the regions covered by VAR, SR_ESD, SDI, DMY_SCH, RF_PP, {RF_PP AND RF_SL1}) = 0.1 
  GATE_CHECK = ((LV_GATE NOT INSIDE (POS_EXCLUDE_S4 OR ANALOG_DEVICE)) NOT INSIDE (OR DMY_SCH RFPP_EXC)) WITH EDGE (LENGTH GATE_L <= PO_S_4_L)
  PO_CHECK = ((SIZE GATE_CHECK BY PO_S_4_S) AND POLY) TOUCH EDGE GATE_W
  EXT (PO_CHECK) SR_POLY == PO_S_4 OPPOSITE  
}
PO.S.4.1 { @ The {{GATE SIZING 0.06 um} AND PO} space to neighboring poly {PO OR SR_DPO} of core device [0.04 um <= channel length <= 0.09 um, INSIDE DMY_SCH (255;52)] (Except VAR, SR_ESD, and SDI) = 0.1 
  GATE_CHECK = ((LV_GATE NOT INSIDE POS_EXCLUDE_S4)INSIDE DMY_SCH) WITH EDGE (LENGTH GATE_L >= PO_S_4_LC <= PO_S_4_L)
  PO_CHECK = ((SIZE GATE_CHECK BY PO_S_4_S) AND POLY) TOUCH EDGE GATE_W
  EXT (PO_CHECK) SR_POLY == PO_S_4 OPPOSITE  
}
PO.S.4.2 { @ The {{GATE SIZING 0.06 um} AND PO} space to neighboring poly {PO OR SR_DPO} of core device [channel length = 0.03 um, INSIDE DMY_SCH (255;52)] 1. For individual {{GATE SIZING 0.06 um} AND PO}, the both spaces to neighboring poly {PO OR SR_DPO} must be the same. 2. Except VAR, SR_ESD, and SDI = 0.1, 0.11 
  GATE_CHECK = ((LV_GATE NOT INSIDE POS_EXCLUDE_S4)INSIDE DMY_SCH) WITH EDGE (LENGTH GATE_L == PO_S_38_L)  
  PO_CHECK = ((SIZE GATE_CHECK BY PO_S_38_S) AND POLY) TOUCH EDGE GATE_W
  GOOD_EDGEA = EXT [PO_CHECK] SR_POLY == PO_S_38A OPPOSITE
  GOOD_EDGEB = EXT [PO_CHECK] SR_POLY == PO_S_38B OPPOSITE
  (PO_CHECK NOT COIN INSIDE EDGE GOOD_EDGEA) NOT COIN INSIDE EDGE GOOD_EDGEB
  ((GATE_CHECK WITH EDGE GOOD_EDGEA) WITH EDGE GOOD_EDGEB) INSIDE DMY_SCH
}
PO.S.4.3 { @ The {{GATE SIZING 0.06 um} AND PO} space to neighboring poly {PO OR SR_DPO} of core device [channel length = 0.035 um, INSIDE DMY_SCH (255;52)] 1. For individual {{GATE SIZING 0.06 um} AND PO}, the both spaces to neighboring poly {PO OR SR_DPO} must be the same. 2. Except VAR, SR_ESD, and SDI = 0.1, 0.105 
  GATE_CHECK = ((LV_GATE NOT INSIDE POS_EXCLUDE_S4)INSIDE DMY_SCH) WITH EDGE (LENGTH GATE_L == PO_S_49_L)  
  PO_CHECK = ((SIZE GATE_CHECK BY PO_S_49_S) AND POLY) TOUCH EDGE GATE_W
  GOOD_EDGEA = EXT [PO_CHECK] SR_POLY == PO_S_49A OPPOSITE
  GOOD_EDGEB = EXT [PO_CHECK] SR_POLY == PO_S_49B OPPOSITE
  (PO_CHECK NOT COIN INSIDE EDGE GOOD_EDGEA) NOT COIN INSIDE EDGE GOOD_EDGEB
  (GATE_CHECK WITH EDGE GOOD_EDGEA) WITH EDGE GOOD_EDGEB
}

PO.S.5 { @ The {{GATE SIZING 0.06 um} AND PO} space to neighboring poly {PO OR SR_DPO} of core device [channel length > 0.09 um]. (This check doesn't include the regions covered by VAR, SR_ESD, SDI, RF_PP, {RF_PP AND RF_SL1}) = 0.12 
  GATE_CHECK = (LV_GATE NOT INSIDE (POS_EXCLUDE_S4_new OR ANALOG_DEVICE)) WITH EDGE (LENGTH GATE_L > PO_S_5_L)
  PO_CHECK = (SIZE GATE_CHECK BY PO_S_5_S) AND POLY
  GOOD_EDGE = EXT [PO_CHECK] SR_POLY == PO_S_5 EXCLUDE SHIELDED 4 OPPOSITE
  (PO_CHECK TOUCH EDGE GATE_W) NOT COIN INSIDE EDGE GOOD_EDGE
}

PO.S.9 { @ The {{GATE SIZING 0.06 um} AND PO} space to neighboring poly {PO OR SR_DPO} [INSIDE OD2] (This check doesn't include the regions covered by {HVN_65 OR HVP_65}, {HVN25_65 OR HVP25_65}, VAR, SR_ESD and SDI) = 0.18 
  GATE_CHECK = (HV_GATE NOT INSIDE (POS_EXCLUDE_1 OR (RPO_DEVICE OR LDMOS)) ) NOT INSIDE GATED
  PO_CHECK = (SIZE GATE_CHECK BY PO_S_9_S) AND POLY
  GOOD_EDGE = EXT [PO_CHECK] SR_POLY == PO_S_9 EXCLUDE SHIELDED 4 OPPOSITE
  ((PO_CHECK TOUCH EDGE GATE_W) NOT COIN INSIDE EDGE GOOD_EDGE) NOT INSIDE EDGE (OR HVD HVD_65)
}

PO.S.10 { @ PO [INSIDE OD2] space to PO >= 0.18 
  EXT POLY (POLY INSIDE EDGE OD2) < PO_S_10 ABUT < 90 REGION
}

PO.S.12 { @ PO space to OD >= 0.025 
  (EXT POLY OD < PO_S_12 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}


POLY_OD = POLY OR OD
CONNECT POLY_OD OD

PO.S.13 { @ L-shape {PO INSIDE OD2} space to OD when PO and OD are in the same MOS [L-shape PO (R2) length <= 0.08 um] >= 0.25 
  L_GATE_L = ((EXPAND EDGE HV_GATE_L INSIDE BY GRID EXTEND BY PO_S_13_L) NOT GATE) TOUCH EDGE OD
  L_POLY = EXT L_GATE_L [FPO1] < PO_S_13 ABUT < 90 OPPOSITE
  L_POLY_C = POLY_OD COIN INSIDE EDGE L_POLY
  EXT L_POLY_C OD < PO_S_13 ABUT < 90 OPPOSITE REGION CONNECTED
}

PO.S.17 { @ Space if at least one PO width >= 0.03 um, and the PO parallel run length > 0.09 um >= 0.1 
  Wide_POLY = POLY WITH WIDTH >= PO_S_17_W  
  E1 = EXT Wide_POLY [POLY] < PO_S_17 ABUT < 90 OPPOSITE MEASURE ALL
  E2_pre1 = EXT [POLY] E1 < GRID ABUT == 90 INTERSECTING ONLY
  E2_pre2 = POLY TOUCH EDGE E2_pre1
  E2 = (CONVEX EDGE POLY ANGLE1 == 90 ANGLE2 == 270) TOUCH EDGE E2_pre2
  A1 = EXPAND EDGE (OR EDGE E1 E2) BY GRID

  E1_H = ANGLE E1 == 0
  E1_V = ANGLE E1 == 90  
  DFM PROPERTY A1 E1_H OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1_H) ] > PO_S_17_L
  DFM PROPERTY A1 E1_V OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1_V) ] > PO_S_17_L
}

PO.S.18 { @ Space if at least one PO width > 0.09 um, and the PO parallel run length > 0.09 um >= 0.12 
  Wide_POLY = POLY WITH WIDTH > PO_S_18_W  
  E1 = EXT Wide_POLY [POLY] < PO_S_18 ABUT < 90 OPPOSITE MEASURE ALL
  E2_pre1 = EXT [POLY] E1 < GRID ABUT == 90 INTERSECTING ONLY
  E2_pre2 = POLY TOUCH EDGE E2_pre1
  E2 = (CONVEX EDGE POLY ANGLE1 == 90 ANGLE2 == 270) TOUCH EDGE E2_pre2
  A1 = EXPAND EDGE (OR EDGE E1 E2) BY GRID

  E1_H = ANGLE E1 == 0
  E1_V = ANGLE E1 == 90  
  DFM PROPERTY A1 E1_H OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1_H) ] > PO_S_18_L
  DFM PROPERTY A1 E1_V OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1_V) ] > PO_S_18_L
}

PO.S.21 { @ {{PO OR SR_DPO} OR DPO} space to {{{PO OR SR_DPO} OR DPO} AND RPO} >= 0.16
  A = SR_POLY OR DPO
  B = A AND RPO     
  EXT A B < PO_S_21 ABUT < 90 SINGULAR REGION MEASURE ALL
}

PO.S.23 { @ Space to L-shape {PO NOT CPO} in vertical direction >= 0.18 
  PO_NOT_RECT = NOT RECTANGLE (POLY NOT CPO) ORTHOGONAL ONLY
  L_POLY = (VERTEX PO_NOT_RECT == 6) WITH EDGE (CONVEX EDGE PO_NOT_RECT ANGLE1 == 270 ANGLE2 == 90)  
  L_POLY_HORIZONTAL = ANGLE L_POLY == 0
  EXT POLY L_POLY_HORIZONTAL < PO_S_23 ABUT < 90 REGION
}


SR_OD = OD OR SRDOD

PO.S.24 { @ {{{PO OR SR_DPO} NOT CPO} INTERACT OD} space to {{OD OR SR_DOD} NOT INTERACT PO}[width < 0.07 um], and the PO and OD parallel run length > 0.09 um >= 0.05 
  SR_POLY_S24 = (SR_POLY NOT CPO) INTERACT OD
  THIN_OD_CHK = (SR_OD NOT INTERACT POLY) NOT WITH WIDTH >= PO_S_24_W      
  A = EXT SR_POLY_S24 THIN_OD_CHK < PO_S_24 ABUT < 90 OPPOSITE REGION
  E1 = SR_POLY_S24 COIN EDGE A
  DFM PROPERTY A E1 OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1) ] > PO_S_24_L
}


PO.S.28 { @ {PO OR SR_DPO} space to OD [space of {PO OR SR_DPO} > 0.27 um], and the {PO OR SR_DPO} and OD parallel run length > 0.09 um (This check doesn't include the regions covered by SR_ESD and SDI.) >= 0.035 
  DENSE_POLY = EXT [SR_POLY] <= PO_S_28_S ABUT < 90 OPPOSITE
  ISO_SR_POLY = SR_POLY NOT COIN INSIDE EDGE DENSE_POLY
  A = ((EXT ISO_SR_POLY OD < PO_S_28 ABUT < 90 OPPOSITE REGION) NOT INSIDE POS_EXCLUDE) NOT INSIDE SRAM_WAIVE_N28
  E1 = ISO_SR_POLY COIN EDGE A  
  DFM PROPERTY A E1 OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1) ] > PO_S_28_L
}

PO.S.30 { @ {PO OR SR_DPO} space to {OD OR SR_DOD} [width < 0.07 um], and the PO and OD parallel run length <= 0.09 um >= 0.05 
  THIN_OD = SR_OD NOT WITH WIDTH >= PO_S_30_W    
  A = EXT SR_POLY THIN_OD < PO_S_30 ABUT < 90 OPPOSITE REGION
  SR_POLY_L = LENGTH (A COIN EDGE SR_POLY) <= PO_S_30_L
  B= EXPAND EDGE SR_POLY_L OUTSIDE BY GRID
  (EXT B THIN_OD < PO_S_30 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28
}

PO.S.34 { @ PO space to {OD OR SR_DOD} [space of {PO OR SR_DPO} > 0.27 um], and the PO and OD parallel run length > 0.09 um (This check doesn't include the regions covered by SR_ESD, and SDI) >= 0.035 
  DENSE_POLY = EXT [SR_POLY] <= PO_S_34_S ABUT < 90 OPPOSITE
  ISO_POLY = POLY NOT COIN INSIDE EDGE DENSE_POLY
  A = ((EXT ISO_POLY SR_OD < PO_S_34 ABUT < 90 OPPOSITE REGION)NOT INSIDE POS_EXCLUDE) NOT INSIDE SRAM_WAIVE_N28
  E1 = ISO_POLY COIN EDGE A  
  DFM PROPERTY A E1 OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1) ] > PO_S_34_L
}

PO.S.35 { @ {{GATE SIZING 0.06 um} AND PO} space to {PO OR SR_DPO} of core device [in VAR] = 0.12~0.8 
  GATE_CHECK = (LV_GATE INSIDE VAR) NOT INSIDE ((LOGO OR VAR_DEVICE) OR DVAR_F )
  PO_CHECK = (SIZE GATE_CHECK BY PO_S_35_S) AND POLY
  EXT [PO_CHECK] SR_POLY < PO_S_35A ABUT < 90 OPPOSITE  
  GOOD_EDGE = EXT [PO_CHECK] SR_POLY <= PO_S_35B OPPOSITE  
  (PO_CHECK TOUCH EDGE GATE_W) NOT COIN INSIDE EDGE GOOD_EDGE
}

PO.S.36 { @ {{GATE SIZING 0.06 um} AND PO} space to {PO OR SR_DPO} of I/O device [in VAR] = 0.18~0.8 
  GATE_CHECK = (HV_GATE INSIDE VAR) NOT INSIDE LOGO
  PO_CHECK = (SIZE GATE_CHECK BY PO_S_36_S) AND POLY
  EXT [PO_CHECK] SR_POLY < PO_S_36A ABUT < 90 OPPOSITE  
  GOOD_EDGE = EXT [PO_CHECK] SR_POLY <= PO_S_36B OPPOSITE  
  (PO_CHECK TOUCH EDGE GATE_W) NOT COIN INSIDE EDGE GOOD_EDGE
}

PO_W_40 = SR_POLY WITH WIDTH < PO_S_45_W1
PO_W_60 = SR_POLY WITH WIDTH >= PO_S_45_W2

PO.S.45 { @ At least one side space of vertical {PO OR SR_DPO} [width < 0.04 um (T1)] to {PO OR SR_DPO} [width >= 0.06 um (T2)]. DRC only flag when 2 {PO OR SR_DPO} [width >= 0.06 um (T2) and parallel run length > 0.07 um] >= 0.12 
  ERROR_EDGE_A =  ANGLE (EXT PO_W_60 [PO_W_40] < PO_S_45 ABUT < 90 OPPOSITE) == 90
  E1 = INT [ERROR_EDGE_A] < PO_S_45_W1 ABUT < 90 OPPOSITE
  E2_pre1 = EXT [SR_POLY] E1 < GRID ABUT == 90 INTERSECTING ONLY
  E2_pre2 = SR_POLY TOUCH EDGE E2_pre1 
  E2 = (CONVEX EDGE SR_POLY ANGLE1 == 90 ANGLE2 == 270) TOUCH EDGE E2_pre2
  A1 =  (EXPAND EDGE E1 BY GRID) OR (EXPAND EDGE E2 BY GRID)  
  DFM PROPERTY A1 E1 OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1) ] > PO_S_45_L
}


PO.EX.1 { @ PO extension on OD (ENDCAP) >= 0.08 
  ((ENC OD POLY < PO_EX_1 ABUT < 90 OPPOSITE SINGULAR REGION) NOT INSIDE LOGO) NOT INSIDE (SRAM_WAIVE_N28 OR LDMOS)
}

PO.EX.2 { @ OD extension on PO of core device [channel length <= 0.09 um], except for the PO edge space to neighboring {{PO OR SR_DPO} AND OD} following PO.S.4 (This check doesn't include the regions covered by SR_ESD, SDI, DMY_SCH, VAR, RF_PP, {RF_PP AND RF_SL1}) = 0.075 
  GATE_CHECK = ((LV_GATE NOT INSIDE (POS_EXCLUDE_EX2 OR (VAR_DEVICE OR DVAR_F))) NOT INSIDE (OR DMY_SCH VAR RFPP_EXC)) WITH EDGE (LENGTH GATE_L <= PO_EX_2_L)
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE GATE_W_CDU
  GOOD_EDGE2 = ENC [GATE_W_CHECK] OD == PO_EX_2 EXCLUDE SHIELDED 4 OPPOSITE
  EXCLUDE_SPACE = EXT [GATE_W_CHECK] SRPO_GATE_W <= PO_S_5 ABUT < 90 OPPOSITE
  (GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE2) NOT COIN INSIDE EDGE EXCLUDE_SPACE
}

PO.EX.2.1 { @ OD extension on PO of core device [0.04 um <= channel length <= 0.09 um, INSIDE DMY_SCH (255;52)] , except for the PO edge space to neighboring {{PO OR SR_DPO} AND OD} following PO.S.4.1. (Except SR_ESD, and SDI.) = 0.075 
  GATE_CHECK = ((LV_GATE NOT INSIDE (POS_EXCLUDE_EX2 OR (VAR_DEVICE OR DVAR_F))) INSIDE DMY_SCH) WITH EDGE (LENGTH GATE_L >= PO_EX_2_LC <= PO_EX_2_L)
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE GATE_W_CDU_SCH
  GOOD_EDGE = ENC [GATE_W_CHECK] OD == PO_EX_2 EXCLUDE SHIELDED 4 OPPOSITE
  EXCLUDE_SPACE = EXT [GATE_W_CHECK] SRPO_GATE_W <= PO_S_5 ABUT < 90 OPPOSITE
  (GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE) NOT COIN INSIDE EDGE EXCLUDE_SPACE
}
PO.EX.2.2 { @ OD extension on PO of core device [channel length = 0.03 um, INSIDE DMY_SCH (255;52)] , except for the PO edge space to neighboring {{PO OR SR_DPO} AND OD} following PO.S.4.2, (Except SR_ESD, and SDI.) = 0.075, 0.080, 0.085 
  GATE_CHECK = ((LV_GATE NOT INSIDE (POS_EXCLUDE_EX2 OR (VAR_DEVICE OR DVAR_F))) INSIDE DMY_SCH) WITH EDGE (LENGTH GATE_L == PO_EX_2_LA)
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE GATE_W_CDU_SCH
  GOOD_EDGE2 = ENC [GATE_W_CHECK] OD == PO_EX_2 EXCLUDE SHIELDED 4 OPPOSITE
  GOOD_EDGE1 = ENC [GATE_W_CHECK] OD == PO_EX_2_A EXCLUDE SHIELDED 4 OPPOSITE
  GOOD_EDGE0 = ENC [GATE_W_CHECK] OD == PO_EX_2_B EXCLUDE SHIELDED 4 OPPOSITE
  GOOD_EDGE = (GOOD_EDGE1 OR EDGE GOOD_EDGE0) OR EDGE GOOD_EDGE2
  EXCLUDE_SPACE = EXT [GATE_W_CHECK] SRPO_GATE_W <= PO_S_5 ABUT < 90 OPPOSITE
  (GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE) NOT COIN INSIDE EDGE EXCLUDE_SPACE
}
PO.EX.2.3 { @ OD extension on PO of core device [channel length = 0.035 um, INSIDE DMY_SCH (255;52)] , except for the PO edge space to neighboring {{PO OR SR_DPO} AND OD} following 4.3. (Except SR_ESD, and SDI.) 0.075, 0.08  
  GATE_CHECK = ((LV_GATE NOT INSIDE (POS_EXCLUDE_EX2 OR (VAR_DEVICE OR DVAR_F))) INSIDE DMY_SCH) WITH EDGE (LENGTH GATE_L == PO_EX_2_LB)
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE GATE_W_CDU_SCH
  GOOD_EDGE1 = ENC [GATE_W_CHECK] OD == PO_EX_2 EXCLUDE SHIELDED 4 OPPOSITE
  GOOD_EDGE0 = ENC [GATE_W_CHECK] OD == PO_EX_2_A EXCLUDE SHIELDED 4 OPPOSITE
  GOOD_EDGE = GOOD_EDGE1 OR EDGE GOOD_EDGE0
  EXCLUDE_SPACE = EXT [GATE_W_CHECK] SRPO_GATE_W <= PO_S_5 ABUT < 90 OPPOSITE
  (GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE) NOT COIN INSIDE EDGE EXCLUDE_SPACE
}
PO.EX.3 { @ OD extension on PO of core device [channel length > 0.09 um], except for the PO edge space to neighboring {{PO OR SR_DPO} AND OD} following PO.S.5 (This check doesn't include the regions covered by SR_ESD, SDI, VAR, RF_PP, {RF_PP AND RF_SL1}) = 0.095 
  GATE_CHECK = (LV_GATE NOT INSIDE POS_EXCLUDE_S4_new) WITH EDGE (LENGTH GATE_L > PO_EX_3_L)
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE GATE_W_CDU
  GOOD_EDGE2 = ENC [GATE_W_CHECK] OD == PO_EX_3 EXCLUDE SHIELDED 4 OPPOSITE
  EXCLUDE_SPACE = EXT [GATE_W_CHECK] SRPO_GATE_W <= PO_S_5 ABUT < 90 OPPOSITE  
  (GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE2) NOT COIN INSIDE EDGE EXCLUDE_SPACE
}

PO.EX.4 { @ OD extension on PO of core device [in SR_ESD, SDI, and VAR] >= 0.095 
  GATE_CHECK = (LV_GATE INSIDE (OR POS_EXCLUDE VAR)) NOT INSIDE LOGO
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE GATE_W
  ENC GATE_W_CHECK OD < PO_EX_4 ABUT < 90 REGION
}

PO.EX.5 { @ OD extension on PO of I/O device, except for the PO edge space to neighboring {{PO OR SR_DPO} AND OD} following PO.S.9 (This check doesn't include the regions covered by {HVN_65 OR HVP_65}, {HVN25_65 OR HVP25_65}, SR_ESD, SDI, and VAR.) = 0.155 
  GATE_W_CHECK = HV_GATE_W NOT INSIDE EDGE ((POS_EXCLUDE_1 OR RPO_DEVICE) OR (OR GATED HVD HVD_65))
  GOOD_EDGE1 = EXT [GATE_W_CHECK] SRPO_GATE == PO_S_9 EXCLUDE SHIELDED 4 OPPOSITE
  GOOD_EDGE2 = ENC [GATE_W_CHECK] OD == PO_EX_5 EXCLUDE SHIELDED 4 OPPOSITE
  (GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE1) NOT COIN INSIDE EDGE GOOD_EDGE2
}

PO.EX.6 { @ Extension on OD (ENDCAP) when the PO to L-shape OD (in the same MOS) space < 0.1 um >= 0.095 
  A = (CONVEX EDGE OD ANGLE1 == 90 ANGLE2 == 270) NOT TOUCH EDGE GATE_L
  B = OD COIN EDGE (EXPAND EDGE A OUTSIDE BY PO_EX_6_S)
  ((ENC B POLY < PO_EX_6 ABUT < 90 REGION) NOT INSIDE LOGO) NOT INSIDE SRAM_WAIVE_N28
}

PO.EX.7 { @ OD extension on PO of I/O device [in SR_ESD and SDI] >= 0.155 
  GATE_CHECK = (HV_GATE INSIDE (POS_EXCLUDE OR RPO_DEVICE)) NOT INSIDE LOGO
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE GATE_W
  ENC GATE_W_CHECK OD < PO_EX_7 ABUT < 90 REGION
}

PO.EX.8 { @ OD extension on PO of core device [in VAR] = 0.095~0.8 
  GATE_CHECK = (LV_GATE INSIDE VAR) NOT INSIDE (LOGO OR (VAR_DEVICE OR DVAR_F))
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE GATE_W
  ENC GATE_W_CHECK OD < PO_EX_8A ABUT < 90 OPPOSITE REGION
  GOOD_EDGE1 = EXT [GATE_W_CHECK] SRPO_GATE <= PO_S_35B EXCLUDE SHIELDED 4 OPPOSITE  
  GOOD_EDGE2 = ENC GATE_W_CHECK OD <= PO_EX_8B ABUT < 90 EXCLUDE SHIELDED 4 OPPOSITE REGION
  (GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE1) NOT COIN OUTSIDE EDGE GOOD_EDGE2
}

PO.EX.9 { @ OD extension on PO of I/O device [in VAR] = 0.155~0.8 
  GATE_CHECK = (HV_GATE INSIDE VAR) NOT INSIDE LOGO
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE GATE_W
  ENC GATE_W_CHECK OD < PO_EX_9A ABUT < 90 OPPOSITE REGION
  GOOD_EDGE1 = EXT [GATE_W_CHECK] SRPO_GATE <= PO_S_36B EXCLUDE SHIELDED 4 OPPOSITE  
  GOOD_EDGE2 = ENC GATE_W_CHECK OD <= PO_EX_9B ABUT < 90 EXCLUDE SHIELDED 4 OPPOSITE REGION
  (GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE1) NOT COIN OUTSIDE EDGE GOOD_EDGE2
}

PO.L.1 { @ Maximum {PO NOT CPO} length between 2 contacts, as well as the length from any point inside PO GATE to nearest CO when the PO width < 0.06 um. (This check doesn't include ESD protection devices.) <= 18 
  ILP2 = (ILP1 NOT SDI) NOT CPO
  LONGP = AREA ILP2 > PO_W_3A * PO_L_1
  X = LONGP INTERACT COPO
  CHECK_COPO = COPO INTERACT X
  A = SIZE CHECK_COPO BY PO_L_1 / 2 INSIDE OF X STEP PO_S_3*0.7
  P2P = X INTERACT A > 1
  BAD = P2P NOT A
  BAD_EDGE = BAD COIN INSIDE EDGE POLY
  ERR = INT BAD_EDGE < PO_L_1_W ABUT < 90 REGION
  X1 = (X INTERACT ERR) NOT GATE
  CHECK_COPO1 = CHECK_COPO INTERACT X1
  A1 = SIZE CHECK_COPO1 BY PO_L_1 / 2 INSIDE OF X1 STEP PO_S_3*0.7
  P2P1 = X1 INTERACT A1 > 1
  BAD1 = (P2P1 NOT A1) INTERACT A1 > 1
  BAD_EDGE1 = BAD1 COIN INSIDE EDGE POLY
  ERR1 = INT BAD_EDGE1 < PO_L_1_W ABUT < 90 REGION
  (X1 INTERACT ERR1) NOT INSIDE SRAM_WAIVE_N28
  NARROW_GATE = (GATE WITH EDGE (LENGTH GATE_L < PO_L_1_W)) AND X
  B = SIZE A BY PO_L_1 / 2 INSIDE OF X STEP PO_S_3*0.7
  (NARROW_GATE NOT B) NOT INSIDE SRAM_WAIVE_N28
}

PO.L.2 { @ Length of rectangular PO >= 0.26 
  A = RECTANGLE POLY
  A NOT WITH EDGE (LENGTH A >= PO_L_2)
}


PO.L.3 { @ Maximum {{PO OR SR_DPO} NOT CPO} length when the width < 0.05 um. DRC flags the patternsfilling 0.005 um x 200 um rectangular tile < 200 
  PO_THIN = (SR_POLY NOT CPO) NOT WITH WIDTH >= PO_L_3_W 
  (ENCLOSE RECTANGLE PO_THIN PO_L_3 GRID ORTHOGONAL ONLY) NOT INSIDE SRAM_WAIVE_N28
}

PO.A.1 { @ Area (This check doesn't include rectangle {PO INTERACT OD} with length >= 0.305 um) >= 0.0115 
  A = POLY INTERACT OD
  B = RECTANGLE A
  C = LENGTH B >= PO_A_1_L
  D = B WITH EDGE C
  E = POLY NOT D
  AREA E < PO_A_1
}

PO.A.3 { @ Area of {{{PO OR SR_DPO} OR DPO} NOT CPO} This check doesn't include 1. {{{PO OR SR_DPO} INTERACT RPO} AND RH_PO}, {SR_DPO AND RH_OD}, and BJTDMY 2. {{{PO OR SR_DPO} OR DPO} NOT CPO} [width <= 0.035 um] NOT INTERACT "High Density Region" 3. {{{PO OR SR_DPO} OR DPO} NOT CPO} [width = 0.1 um ~ 0.3 um, length <= 30 um] NOT INTERACT "High Density Region" Definition of "High Density Region": Poly density [10 um x 10 um window, stepping 5 um] inside {{{{PO OR SR_DPO} OR DPO} NOT CPO} [(width <= 0.035 um and area > 3 um2) or (width = 0.1 um ~ 0.3 um, length <= 30 um, and area > 3 um2)] SIZING 5 um} is > 50% <= 3 
  PO_A3_EXC = (((SR_POLY INTERACT RPO) AND RHPO) OR (SRDPO AND RHOD)) OR (OR BJTDMY SRAM_WAIVE_N28) // HVD Waive should be final shape filter --> NOT INTERACT HVD
  BIG_PO = AREA (ALL_POLY NOT PO_A3_EXC) > PO_A_3
  THIN_BIG_PO = BIG_PO WITH WIDTH <= PO_A_3_W1
  WIDE_SHORT_BIG_PO = NOT ENCLOSE RECTANGLE (BIG_PO WITH WIDTH >= PO_A_3_W2 <= PO_A_3_W3) GRID PO_A_3_L1+GRID
  BIG_PO_PRE = THIN_BIG_PO OR WIDE_SHORT_BIG_PO

  HIGH_DEN_REG_pre0 =DENSITY ALL_POLY CHIP > PO_A_3_DN WINDOW PO_A_3_W STEP 1 BACKUP INSIDE OF LAYER CHIPx
  [ AREA(ALL_POLY)/AREA(CHIP) ]
  DEN_CHK_REG = SIZE (BIG_PO_PRE INTERACT HIGH_DEN_REG_pre0) BY PO_A_3_S2
  PODN_CHK = ALL_POLY AND DEN_CHK_REG
  DEN_CHK_REG_CHK = COPY DEN_CHK_REG
  HIGH_DEN_REG_pre = DENSITY ALL_POLY DEN_CHK_REG_CHK > PO_A_3_DN WINDOW PO_A_3_W STEP 1 INSIDE OF LAYER DEN_CHK_REG BACKUP 
   [!(AREA()-AREA(DEN_CHK_REG_CHK))*AREA(ALL_POLY)/AREA()]
  DEN_CHK_REG2 = DEN_CHK_REG INTERACT HIGH_DEN_REG_pre 
  HIGH_DEN_REG = DENSITY  HIGH_DEN_REG_pre ALL_POLY PODN_CHK DEN_CHK_REG_CHK > PO_A_3_DN WINDOW PO_A_3_W STEP PO_A_3_S INSIDE OF LAYER DEN_CHK_REG2 BACKUP PRINT PO.A.3.density RDB PO.A.3.RDB.density
  [AREA(PODN_CHK)/AREA(DEN_CHK_REG_CHK)*!~(AREA(ALL_POLY)/AREA()-PO_A_3_DN)*!!AREA(HIGH_DEN_REG_pre)]
  
  GOOD_PO = BIG_PO_PRE NOT INTERACT HIGH_DEN_REG
  BIG_PO NOT GOOD_PO

}


PO.A.4 { @ Maximum area of High_PMET_DN_region1 Definition of High_PMET_DN_region1: 50% <= {{{{{PO OR SR_DPO} OR DPO} NOT CPO} AND PMET} NOT {RH_PO AND RPO}} density < 55% by window 20 um x 20 um, stepping 10 um <= 500000 
   PMET_Ax = (ALL_POLY AND PMET) NOT (RHPO AND RPO)
   X = DENSITY PMET_Ax CHIP >= PO_A_4_DN1 < PO_A_4_DN2 WINDOW PO_A_4_W STEP PO_A_4_S BACKUP INSIDE OF LAYER CHIPx PRINT PO.A.4.density RDB PO.A.4.RDB.density
   [ AREA(PMET_Ax)/AREA(CHIP) ]
   AREA X > PO_A_4
}







PO.A.5 { @ Maximum area of High_PMET_DN_region2 Definition of High_PMET_DN_region2: 55% <= {{{{{PO OR SR_DPO} OR DPO} NOT CPO} AND PMET} NOT {RH_PO AND RPO}} density by window 20 um x 20 um, stepping 10 um <= 300000 
   PMET_Ax = (ALL_POLY AND PMET) NOT (RHPO AND RPO)
   X = DENSITY PMET_Ax CHIP >= PO_A_5_DN1 WINDOW PO_A_5_W STEP PO_A_5_S BACKUP INSIDE OF LAYER CHIPx PRINT PO.A.5.density RDB PO.A.5.RDB.density
   [ AREA(PMET_Ax)/AREA(CHIP) ]
    AREA X > PO_A_5
}

 VARIABLE  PO_A_6       1000000
 VARIABLE  PO_A_6_DN1   0.50
 VARIABLE  PO_A_6_W     20
 VARIABLE  PO_A_6_S     10 
 
PO.A.6 { @ Maximum area of High_PMET_DN_region3 Definition of High_PMET_DN_region3: 50% <= {{{{{PO OR SR_DPO} OR DPO} NOT CPO} AND PMET} NOT {RH_PO AND RPO}} density by window 20 um x 20 um, stepping 10 um <= 1000000 
   PMET_Ax = (ALL_POLY AND PMET) NOT (RHPO AND RPO)
   X = DENSITY PMET_Ax CHIP >= PO_A_6_DN1 WINDOW PO_A_6_W STEP PO_A_6_S BACKUP INSIDE OF LAYER CHIPx PRINT PO.A.6.density RDB PO.A.6.RDB.density
   [ AREA(PMET_Ax)/AREA(CHIP) ]
     AREA X > PO_A_6
}









#IFDEF FULL_CHIP
PO.DN.1 { @ Minimum {{{PO OR SR_DPO} OR DPO} NOT CPO} density across full chip >= 14% 
  DENSITY ALL_POLY CHIP < PO_DN_1 INSIDE OF LAYER CHIPx [ AREA(ALL_POLY)/AREA(CHIP) ] PRINT PO.DN.1.density
}

PO.DN.2 { @ Maximum {{{PO OR SR_DPO} OR DPO} NOT CPO} density across full chip <= 40% 
  DENSITY ALL_POLY CHIP > PO_DN_2 INSIDE OF LAYER CHIPx [ AREA(ALL_POLY)/AREA(CHIP) ] PRINT PO.DN.2.density
}
#ENDIF

#IFDEF CHECK_LOW_DENSITY
PO.DN.3 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1. PO.DN.3 rule checks over any 20 um x 20 um area, stepping 10*20% um. 2. For PO.DN.3 rule, the following regions can be excluded: (1) {Chip corner triangle empty areas SIZING 1 um} if sealring is added by tsmc. (2) {SEALRING_ALL SIZING 1 um} if sealring is added by customer. (3) ICOVL 3. The rule is applied while width of (checking window NOT ((item 2 SIZING 2.5 um) SIZING -2.5 um)) >= 5 um >= 10%+3% 
#ELSE
@ Minimum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1. PO.DN.3 rule checks over any 20 um x 20 um area, stepping 10 um. 2. For PO.DN.3 rule, the following regions can be excluded: (1) {Chip corner triangle empty areas SIZING 1 um} if sealring is added by tsmc. (2) {SEALRING_ALL SIZING 1 um} if sealring is added by customer. (3) ICOVL 3. The rule is applied while width of (checking window NOT ((item 2 SIZING 2.5 um) SIZING -2.5 um)) >= 5 um >= 10% 
#ENDIF
  EXC = SEALRING_SIZE_1 OR ICOVL
  N = ALL_POLY NOT EXC
  D = CHIP NOT EXC 
  EXC_M = SIZE EXC BY PO_DN_3_E/2 OVERUNDER TRUNCATE PO_DN_3_E/2
  A = CHIPx NOT EXC
  B1 = EXC_M NOT WITH EDGE (EXT [EXC_M] < PO_DN_3_E*2 SQUARE )
  B = CHIPx NOT (SIZE B1 BY PO_DN_3_E-0.001)
  ERR_WIN = DENSITY A B ALL_POLY CHIP N D < PO_DN_3 WINDOW PO_DN_3_W STEP PO_DN_3_S BACKUP INSIDE OF LAYER CHIPx 
          [!AREA(B)+~(AREA(A)-PO_DN_3_E*PO_DN_3_E)*!!(AREA(A)-PO_DN_3_E*PO_DN_3_E)+AREA(N)/AREA(D)+!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3)+!(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3)]
  F = PUSH (WITH WIDTH (ERR_WIN NOT EXC_M) >= PO_DN_3_E)
  X = DENSITY A B F ALL_POLY CHIP N D < PO_DN_3 WINDOW PO_DN_3_W STEP PO_DN_3_S BACKUP INSIDE OF LAYER CHIPx PRINT PO.DN.3.density RDB PO.DN.3.RDB.density
          [!AREA(F)+!AREA(B)+~(AREA(A)-PO_DN_3_E*PO_DN_3_E)*!!(AREA(A)-PO_DN_3_E*PO_DN_3_E)+AREA(N)/AREA(D)+!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3)+!(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3)]



  COPY X    
}
PO.DN.3.1 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1. PO.DN.3.1 rule checks over any 10 um x 10 um area, stepping 5*20% um. 2. For PO.DN.3.1 rule, the following regions can be excluded: (1) {Chip corner triangle empty areas SIZING 1 um} if sealring is added by tsmc. (2) {SEALRING_ALL SIZING 1 um} if sealring is added by customer. (3) {INDDMY SIZING 2 um}, MOMDMY, BJTDMY, RH_OD, LOGO, ICOVL and {DIODMY AND OD} 3. The rule is applied while width of (checking window NOT ((item 2 SIZING 1.25 um) SIZING -1.25 um)) >= 2.5 um >= 10%+3% 
#ELSE
@ Minimum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1. PO.DN.3.1 rule checks over any 10 um x 10 um area, stepping 5 um. 2. For PO.DN.3.1 rule, the following regions can be excluded: (1) {Chip corner triangle empty areas SIZING 1 um} if sealring is added by tsmc. (2) {SEALRING_ALL SIZING 1 um} if sealring is added by customer. (3) {INDDMY SIZING 2 um}, MOMDMY, BJTDMY, RH_OD, LOGO, ICOVL and {DIODMY AND OD} 3. The rule is applied while width of (checking window NOT ((item 2 SIZING 1.25 um) SIZING -1.25 um)) >= 2.5 um >= 10% 
#ENDIF
  EXC = (((((SIZE INDDMY BY 2) OR MOMDMY) OR (BJTDMY OR LOGO)) OR RHOD) OR (DIODMY AND OD)) OR (SEALRING_SIZE_1 OR ICOVL)
  N = ALL_POLY NOT EXC
  D = CHIP NOT EXC 
  EXC_M = SIZE EXC BY PO_DN_3_1_E/2 OVERUNDER TRUNCATE PO_DN_3_1_E/2
  A = CHIPx NOT EXC
  B1 = EXC_M NOT WITH EDGE (EXT [EXC_M] < PO_DN_3_1_E*2 SQUARE )
  B = CHIPx NOT (SIZE B1 BY PO_DN_3_1_E-0.001)
  ERR_WIN = DENSITY A B ALL_POLY CHIP N D < PO_DN_3_1 WINDOW PO_DN_3_1_W STEP PO_DN_3_1_S BACKUP INSIDE OF LAYER CHIPx 
          [!AREA(B)+~(AREA(A)-PO_DN_3_1_E*PO_DN_3_1_E)*!!(AREA(A)-PO_DN_3_1_E*PO_DN_3_1_E)+AREA(N)/AREA(D)+!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_1)+!(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_1)]
  F = PUSH (WITH WIDTH (ERR_WIN NOT EXC_M) >= PO_DN_3_1_E)
  X = DENSITY A B F ALL_POLY CHIP N D < PO_DN_3_1 WINDOW PO_DN_3_1_W STEP PO_DN_3_1_S BACKUP INSIDE OF LAYER CHIPx PRINT PO.DN.3.1.density RDB PO.DN.3.1.RDB.density
          [!AREA(F)+!AREA(B)+~(AREA(A)-PO_DN_3_1_E*PO_DN_3_1_E)*!!(AREA(A)-PO_DN_3_1_E*PO_DN_3_1_E)+AREA(N)/AREA(D)+!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_1)+!(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_3_1)]



  COPY X      
}
#ENDIF
PO.DN.4 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1.PO.DN.4 checks over any 20 um x 20 um area, stepping 10*20% um. (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 65%-3% 
#ELSE
@ Maximum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1.PO.DN.4 checks over any 20 um x 20 um area, stepping 10 um. (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 65% 
#ENDIF
  EXC = COPY ICOVL 
  N = ALL_POLY NOT EXC
  D = CHIP NOT EXC 
  A = CHIPx NOT EXC
  X = DENSITY A ALL_POLY CHIP N D > PO_DN_4 WINDOW PO_DN_4_W STEP PO_DN_4_S BACKUP INSIDE OF LAYER CHIPx PRINT PO.DN.4.density RDB PO.DN.4.RDB.density
          [~(PO_DN_4_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_4)]


  COPY X    
}

 
 
PO.DN.4.1 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1.PO.DN.4.1 checks over any 10 um x 10 um area, stepping 5*20% um. 2. This check doesn't include {RH_PO INTERACT RPO}, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 65%-3% 
#ELSE
@ Maximum {{{PO OR SR_DPO} OR DPO} NOT CPO} local density 1.PO.DN.4.1 checks over any 10 um x 10 um area, stepping 5 um. 2. This check doesn't include {RH_PO INTERACT RPO}, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) <= 65% 
#ENDIF
  EXC = (RHPO INTERACT RPO) OR ICOVL
  N = ALL_POLY NOT EXC
  D = CHIP NOT EXC 
  A = CHIPx NOT EXC
  X = DENSITY A ALL_POLY CHIP N D > PO_DN_4_1 WINDOW PO_DN_4_1_W STEP PO_DN_4_1_S BACKUP INSIDE OF LAYER CHIPx PRINT PO.DN.4.1.density RDB PO.DN.4.1.RDB.density
          [~(PO_DN_4_1_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_4_1)]


  COPY X    
}

PO.DN.11 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ "Sensitive GATE" interact the region of {(PO local density > 45%) SIZING 5 um} is not allowed. The definition of "sensitive GATE": 1. Channel length < 0.04 um2. {{{{{{{GATE INTERACT SENDMY} NOT LOGO} NOT VAR} NOT CAPDMY} NOT DECAPDMY} NOT TCDDMY} NOT {SRAMDMY AND RODMY}} The definition of the region (PO local density): {{{PO OR DPO} OR SR_DPO} NOT CPO} local density (window 20 um x 20 um, stepping 10*20% um)    
#ELSE
@ "Sensitive GATE" interact the region of {(PO local density > 45%) SIZING 5 um} is not allowed. The definition of "sensitive GATE": 1. Channel length < 0.04 um2. {{{{{{{GATE INTERACT SENDMY} NOT LOGO} NOT VAR} NOT CAPDMY} NOT DECAPDMY} NOT TCDDMY} NOT {SRAMDMY AND RODMY}} The definition of the region (PO local density): {{{PO OR DPO} OR SR_DPO} NOT CPO} local density (window 20 um x 20 um, stepping 10 um)   
#ENDIF
  PO_GATE_SEN = (((((((GATE INTERACT SENDMY) NOT LOGO) NOT VAR) NOT CAPDMY) NOT DECAPDMY) NOT TCDDMY) NOT (SRAMDMY AND RODMY)) WITH EDGE (LENGTH GATE_L < PO_DN_11_L)
  PO_GATE_SEN INTERACT (SIZE PO_DENSITY_HIGH BY PO_DN_11_S2)
}

PO.DN.13 { @ "Sensitive metal gate resistor" interact the region of {(PO local density > 45%) SIZING 5 um} is not allowed. The definition of "sensitive metal gate resistor": {{{{RH_PO AND PO} NOT INTERACT RPO} AND RPDMY} INTERACT SENDMY} The definition of the region (PO local density): 1. {{{PO OR DPO} OR SR_DPO} NOT CPO} local density (window 20 um x 20 um, stepping 10 um) 2. This rule is only applied while the width of {checking window NOT {{"sensitive metal gate resistor" SIZING 0.3 um} SIZING -0.3 um}} >= 5 um   
  A = WITH WIDTH (PO_DENSITY_HIGH NOT (SIZE RES_Metal_GATE BY PO_DN_13_S1 OVERUNDER TRUNCATE PO_DN_13_S1)) >= PO_DN_13_W2
  (RES_Metal_GATE INTERACT SENDMY) INTERACT (SIZE (PO_DENSITY_HIGH INTERACT A) BY PO_DN_13_S2)
}
PO.DN.16 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum PMET_PO local density in {{{MATCHING OR ANARRAY_H} OR ANARRAY_M} SIZING 10 um} , by checking window 10 um x 10 um, stepping 5*20% um Definition of PMET_PO: {{{{{PO OR SR_DPO} OR DPO} NOT CPO} AND PMET} NOT {RH_PO AND RPO}} <= 50%-3% 
#ELSE
@ Maximum PMET_PO local density in {{{MATCHING OR ANARRAY_H} OR ANARRAY_M} SIZING 10 um} , by checking window 10 um x 10 um, stepping 5 um Definition of PMET_PO: {{{{{PO OR SR_DPO} OR DPO} NOT CPO} AND PMET} NOT {RH_PO AND RPO}} <= 50% 
#ENDIF
   DENSITY PMET_PO MATCHING_S10 > PO_DN_16 WINDOW PO_DN_16_W STEP PO_DN_16_S BACKUP INSIDE OF LAYER MATCHING_S10x PRINT PO.DN.16.density RDB PO.DN.16.RDB.density
          [!(AREA()-AREA(MATCHING_S10))*AREA(PMET_PO)/AREA(MATCHING_S10)]
}
PO.R.28 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum width or length of high {{{{PO OR SR_DPO} OR DPO} NOT CPO} NOT {RH_PO AND RPO}} density region >= 65% in {{{MATCHING OR ANARRAY_H} OR ANARRAY_M} SIZING 10 um}, by checking window 3 um x 10 um, stepping 1.5*20% um x 5*20% um, and 10*20% um x 3*20% um, stepping 5*20% um x 1.5*20% um respectively <= 60-3%  
#ELSE
@ Maximum width or length of high {{{{PO OR SR_DPO} OR DPO} NOT CPO} NOT {RH_PO AND RPO}} density region >= 65% in {{{MATCHING OR ANARRAY_H} OR ANARRAY_M} SIZING 10 um}, by checking window 3 um x 10 um, stepping 1.5 um x 5 um, and 10 um x 3 um, stepping 5 um x 1.5 um respectively <= 60 
#ENDIF
   X = DENSITY MET_PO MATCHING_S10 >= PO_R_28_DN WINDOW PO_R_28_DN_W PO_R_28_DN_L STEP PO_R_28_DN_WS PO_R_28_DN_LS BACKUP INSIDE OF LAYER MATCHING_S10x PRINT PO.R.28:X.density RDB PO.R.28:X.RDB.density
          [!(AREA()-AREA(MATCHING_S10))*AREA(MET_PO)/AREA(MATCHING_S10)]
   Y = DENSITY MET_PO MATCHING_S10 >= PO_R_28_DN WINDOW PO_R_28_DN_L PO_R_28_DN_W STEP PO_R_28_DN_LS PO_R_28_DN_WS BACKUP INSIDE OF LAYER MATCHING_S10x PRINT PO.R.28:Y.density RDB PO.R.28:Y.RDB.density
          [!(AREA()-AREA(MATCHING_S10))*AREA(MET_PO)/AREA(MATCHING_S10)]
   ENCLOSE RECTANGLE (X OR Y) 0.001 PO_R_28+0.001 ORTHOGONAL ONLY
}
#IFDEF FULL_CHIP
MATCH.WARN.1 {@ Warning: MOSFET matching performance degradation at least by 3X may appear when violating PO.DN.16, PO.R.28 or MOS array matching rule (AN.R.80.2mg and AN.R.79.2mg). Note: CAD layer MATCHING (205;8), ANARRAY_H (255;20) or ANARRAY_M (255;21) are required to flag mismatch related rules checking in MOS matching pairs. In case of absence of MATCHING (205;8), ANARRAY_H (255;20) and ANARRAY_M (255;21) in MOS matching pairs, MOS array matching rule like PO.DN.16, PO.R.28, AN.R.80.2mg, AN.R.79.2mg or DFM will not be flagged. Customers can bypass this warning message if they ensure no circuits concerning MOS mismatch in the sign off flow of circuit design. DRC only flags this warning in chip level   
  CHIPx NOT INTERACT MATCHING_ARRAY
}
#ENDIF

PO.R.1 { @ 45-degree PO is not allowed. (This check doesn't include the regions covered by CSRDMY.)   
  POLY_CHECK = (POLY NOT INSIDE POR_EXCLUDE) NOT INSIDE LOGO
  POLY_CHECK ANGLE == 45
}

PO.R.2 { @ {PO NOT INSIDE OD2} NOT CPO must be a rectangle or L-shape (45-degree edge is not allowed). (This check doesn't include the regions covered by layer CSRDMY)   
  POLY_CHECK = ((((POLY NOT CPO) NOT INSIDE OD2) NOT INSIDE POR_EXCLUDE) NOT INSIDE LOGO) NOT INSIDE (SRAM_WAIVE_N28 OR ICOVL)
  VERTEX (VERTEX POLY_CHECK != 4) != 6
  ANGLE (POLY_CHECK ANGLE != 0) != 90
}


PO.R.4 { @ PO intersecting OD must form 2 or more diffusions   
  GATEW = GATE INSIDE EDGE OD
  X = GATE NOT WITH EDGE GATEW == 2
  A = INT GATEW < GRID ABUT == 90 INTERSECTING ONLY REGION
  ((X OR (GATE INTERACT A)) NOT LOGO) NOT INSIDE ((SRAM_WAIVE_N28 OR ICOVL) OR (DVAR_F OR (OTP OR LDMOS)))
}

POR5_GATE = GATEi NOT INSIDE ((((((OD2 OR CSRDMY) OR BJTDMY) OR DIODMY) OR LOGO) OR OD_HG) OR VAR)
POR5_GATE_W = POi COIN INSIDE EDGE POR5_GATE
PO.R.5 { @ PO GATE OUTSIDE OD2 must be in vertical direction (This check doesn't include the regions covered by layer VAR, CSRDMY, BJTDMY, DIODMY, and LOGO.)   
  (ANGLE POR5_GATE_W != 90) NOT INSIDE EDGE ICOVL
}


PO_R_6_EXCL = OR OD OD2 CSRDMY BJTDMY DIODMY LOGO OD_HG (RHPO AND (RPO AND POLY)) (RES_Metal_GATE WITH WIDTH >= PO_R_6_L) MOMDMY


PO.R.6 { @ Rectangle {PO NOT INTERACT [OR OD CSRDMY BJTDMY DIODMY LOGO (high R resistor) (metal gate resistor) [width >= 0.15 um] MOMDMY (155;21) OD2]} must be vertical direction same with the GATE width direction of core area in a chip [PO with Length/Width > 1]   
   A = (RECTANGLE (POLY NOT INTERACT PO_R_6_EXCL) ASPECT > 1) NOT INSIDE SRAM_WAIVE_N28
   A_H = ANGLE A  == 0
   A_V = ANGLE A  == 90
   DFM PROPERTY A A_H A_V OVERLAP ABUT ALSO MULTI
   [ -= LENGTH(A_H) - LENGTH(A_V)] > 0
 }

PO.R.7 { @ Floating {{PO NOT CPO} doesn't INTERACT CO} must be a rectangle. (45-degree edge is not allowed) (Floating PO has jog is not allowed). (This check doesn't include PO width >= 0.13 um)   
  POLY_R7 = POLY NOT CPO
  fPOLY = POLY_R7 INTERACT ((POLY_R7 NOT INTERACT COi) WITH WIDTH < PO_R_7_W)   
  ((NOT RECTANGLE fPOLY ORTHOGONAL ONLY) NOT INSIDE LOGO) NOT INSIDE SRAM_WAIVE_N28
}

PO.R.8 { @ OD INTERACT PO must be a rectangle, single L-, single T-, or single U-shape. (45-degree edge is not allowed) (This check doesn't include the region covered by SRAMDMY;7. Please refer to Table "Special Layer Summary" for the CAD layer purpose)   
  OD_CHECK = (NOT RECTANGLE (OD INTERACT POLY)) NOT INSIDE LOGO
  L_OD = VERTEX OD_CHECK == 6
  X_OD = VERTEX OD_CHECK == 8
  U_CONVEX = CONVEX EDGE X_OD ANGLE1 == 270 ANGLE2 == 270
  T_CONVEX = CONVEX EDGE X_OD ANGLE1 == 90 ANGLE2 == 90
  U_EXP = RECTANGLE (EXPAND EDGE U_CONVEX BY GRID)
  T_EXP = RECTANGLE (EXPAND EDGE T_CONVEX BY GRID)
  U_EDGE = U_CONVEX INSIDE EDGE U_EXP
  T_EDGE = T_CONVEX INSIDE EDGE T_EXP
  HU_OD = (OD_CHECK WITH EDGE (ANGLE GATE_L == 0)) WITH EDGE (ANGLE U_EDGE == 0)
  VU_OD = (OD_CHECK WITH EDGE (ANGLE GATE_L == 90)) WITH EDGE (ANGLE U_EDGE == 90)
  HT_OD = (OD_CHECK WITH EDGE (ANGLE GATE_L == 0)) WITH EDGE (ANGLE T_EDGE == 0)
  VT_OD = (OD_CHECK WITH EDGE (ANGLE GATE_L == 90)) WITH EDGE (ANGLE T_EDGE == 90)
  (((((OD_CHECK NOT L_OD) NOT HU_OD) NOT VU_OD) NOT HT_OD) NOT VT_OD) NOT INSIDE (SRAM_WAIVE_N28 OR SRAMDMY_7)
  (ANGLE OD_CHECK == 45) NOT INSIDE EDGE (SRAM_WAIVE_N28 OR SRAMDMY_7)
}
PO.R.26 { @ Only 2 different OD widths in multiple U shape {{OD INTERACT PO} INSIDE SRAMDMY;7} is allowed. DRC can flag different edge lengths beside inner vertex of {{OD INTERACT PO} INSIDE SRAMDMY;7} in GATE width direction   
  OD_R8_pre = (OD INTERACT POLY) INSIDE SRAMDMY_7
  OD_R8 = VERTEX (VERTEX OD_R8_pre != 4) != 6      
  ANGLE OD_R8_pre == 45                       // Forbidden 45-degree sharp
  OD_R8 INTERACT (HOLES OD_R8 INNER)          // Forbidden O,R,A sharp
  
  U_CONVEX_90a = ANGLE (CONVEX EDGE OD_R8 ANGLE1 == 90 ANGLE2 == 90) == 90
  U_CONVEX_00a = ANGLE (CONVEX EDGE OD_R8 ANGLE1 == 90 ANGLE2 == 90) == 0
  U_LONG_EDGE_EXPAND_00a = (EXPAND EDGE U_CONVEX_00a BY GRID) INTERACT (EXPAND EDGE U_CONVEX_90a BY GRID) == 2
  U_LONG_EDGE_EXPAND_90a = (EXPAND EDGE U_CONVEX_90a BY GRID) INTERACT (EXPAND EDGE U_CONVEX_00a BY GRID) == 2
  OD_GOOD_00a = (OD_R8 INTERACT U_LONG_EDGE_EXPAND_00a == 1) WITH EDGE U_CONVEX_90a == 2
  OD_GOOD_90a = (OD_R8 INTERACT U_LONG_EDGE_EXPAND_90a == 1) WITH EDGE U_CONVEX_00a == 2
  (OD_R8 NOT OD_GOOD_00a) NOT OD_GOOD_90a  
  GATE_W_EXP_00 = EXPAND EDGE (ANGLE GATE_W == 0) BY GRID
  GATE_W_EXP_90 = EXPAND EDGE (ANGLE GATE_W == 90) BY GRID
  WAIVED_OD_R8 = OD_GOOD_00a AND OD_GOOD_90a              // Waived special shape for two direction pattern
  (OD_GOOD_00a NOT WAIVED_OD_R8) INTERACT GATE_W_EXP_00  // L-Sharp allowed two direction
  (OD_GOOD_90a NOT WAIVED_OD_R8) INTERACT GATE_W_EXP_90  // L-Sharp allowed two direction
  
  V8_OD = VERTEX OD_R8_pre == 8
  STEP_CONVEX_EDGE = CONVEX EDGE V8_OD ANGLE1 == 90 ANGLE2 == 270
  STEP_OD_pre = VERTEX (EXPAND EDGE STEP_CONVEX_EDGE INSIDE BY 0.001) == 6
  T_U_OD = V8_OD NOT INTERACT STEP_OD_pre
  OD_R26 = OD_R8 NOT T_U_OD
//  
  U_CONVEX_90 = ANGLE (CONVEX EDGE OD_R26 ANGLE1 == 90 ANGLE2 == 90) == 90
  U_CONVEX_00 = ANGLE (CONVEX EDGE OD_R26 ANGLE1 == 90 ANGLE2 == 90) == 0
  U_LONG_EDGE_EXPAND_00 = (EXPAND EDGE U_CONVEX_00 BY GRID) INTERACT (EXPAND EDGE U_CONVEX_90 BY GRID) == 2
  U_LONG_EDGE_EXPAND_90 = (EXPAND EDGE U_CONVEX_90 BY GRID) INTERACT (EXPAND EDGE U_CONVEX_00 BY GRID) == 2
  OD_GOOD_00 = (OD_R26 INTERACT U_LONG_EDGE_EXPAND_00 == 1) WITH EDGE U_CONVEX_90 == 2
  OD_GOOD_90 = (OD_R26 INTERACT U_LONG_EDGE_EXPAND_90 == 1) WITH EDGE U_CONVEX_00 == 2

// To make sure all wall length are the same
  OD_CHK = ((OD_R26 VERTEX == 4) OR (OD_GOOD_00 OR OD_GOOD_90)) NOT INTERACT (HOLES OD_R26 INNER)
  EDGE_90 = (ANGLE OD_CHK == 90) NOT TOUCH EDGE U_CONVEX_90
  EDGE_00 = (ANGLE OD_CHK ==  0) NOT TOUCH EDGE U_CONVEX_00
  DFM PROPERTY OD_GOOD_00 EDGE_90 OVERLAP ABUT ALSO MULTI
  [-= MAX(LENGTH(EDGE_90)) - MIN(LENGTH(EDGE_90)) ] != 0
  DFM PROPERTY OD_GOOD_90 EDGE_00 OVERLAP ABUT ALSO MULTI
  [-= MAX(LENGTH(EDGE_00)) - MIN(LENGTH(EDGE_00)) ] != 0

// To make only one wall, not stagger wall (with same length)
  OD_GOOD_00 INTERACT ((EXPAND EDGE (EDGE_90 COIN EDGE OD_GOOD_00) BY GRID) NOT WITH EDGE U_CONVEX_00)  
  OD_GOOD_90 INTERACT ((EXPAND EDGE (EDGE_00 COIN EDGE OD_GOOD_90) BY GRID) NOT WITH EDGE U_CONVEX_90)
}


PO.R.9 { @ For the {OD INTERACT PO} layer, any edge of length < 0.13 um width can't have another adjacent edge of length < 0.13 um   
  A = EXPAND EDGE (LENGTH (OD INTERACT POLY) < PO_R_9_L1) BY 0.001
  ((OD OUTSIDE LOGO)INSIDE EDGE ( VERTEX A > 4 )) NOT INSIDE EDGE SRAM_WAIVE_N28
}

PO.R.10 { @ {{PO NOT CPO} OUTSIDE OD2} INTERACT OD must be rectangle. (45-degree edge is not allowed)   
  ((NOT RECTANGLE (((POLY NOT CPO) OUTSIDE OD2) INTERACT OD) ORTHOGONAL ONLY) OUTSIDE LOGO) NOT INSIDE (SRAM_WAIVE_N28 OR ICOVL)
}

PO.R.11 { @ O-shape PO is not allowed   
  (((HOLES POLY) OUTSIDE BJTDMY ) OUTSIDE LOGO) NOT INSIDE (SRAM_WAIVE_N28 OR (SEALRING_ALL OR ICOVL))
}

PO.R.12 { @ Width of {{PO OR SR_DPO} INTERACT same OD} must be the same [OUTSIDE OD2, channel length < 0.15 um](This check doesn't include the regions covered by SR_ESD, and SDI.)   
  GATE_L150 = LENGTH GATE_L < PO_R_12_L2
  OD_CHECK = (((((OD WITH EDGE GATE_L150) NOT INSIDE (POS_EXCLUDE OR ANALOG_DEVICE)) OUTSIDE OD2) NOT INSIDE LOGO) NOT INSIDE SRAM_WAIVE_N28) INTERACT SRPO_GATE >= 2
  DFM PROPERTY OD_CHECK SRPO_GATE_L OVERLAP ABUT ALSO MULTI
  [-= MAX(LENGTH(SRPO_GATE_L)) - MIN(LENGTH(SRPO_GATE_L)) ] != 0
}

PO.R.33 { @ Logic PO can't connect with SRAM PO exclude SRM;3
    LOGIC_PO INTERACT SRAM_PO
}

PO_W_50 = SR_POLY WITH WIDTH < PO_R_22_W1













PO.S.53 { @ {{PO NOT CPO} INTERACT CO} space to OD [width = 0.07 um ~ 0.1 um (W1), >= 0.4 um (L3) edge space to neighboring {{OD OR DOD} OR SR_DOD} >= 0.4 um (S1), INTERACT CO] This check doesn't include 1. SRAMDMY 2. PO space to L-shape OD edge [width = 0.07 um] 3. {CO INTERACT PO} enclosure by PO edge [opposite to OD] >= 0.08 um (E2) DRC flags {{PO NOT CPO} NOT OD} enclosure CO < 0.08 um 4. PO line-end [edge length <= 0.04 um (L2)] space to OD 5. PO and OD are same net [CO enclosure by PO >= 0.015 um] >= 0.04 
  POLY_CHK = (POLY NOT CPO) INTERACT CO
  OD_CHK = OD INTERACT CO
  EXC = (SRAMDMY OR ROM) OR M_ROM

  OD_S53_EDGE_CHK0 = INT [OD_CHK] >= PO_S_53_W1 <= PO_S_53_W2 OPPOSITE
  OD_S53_EDGE_CHK2 = OD_CHK TOUCH INSIDE EDGE OD_S53_EDGE_CHK0
  OD_S53_EDGE_iso = LENGTH (EXT (OD_S53_EDGE_CHK2) ALL_OD < PO_S_53_S ABUT < 90 OPPOSITE) >= PO_S_53_S
  OD_S53_EDGE_CHK1 = OD_S53_EDGE_CHK0 COIN INSIDE EDGE OD_S53_EDGE_iso 

  OD_S53_U_EDGE_1 = CONVEX EDGE (OD OR POLY_CHK) ANGLE1 == 270 ANGLE2 == 270 WITH LENGTH < PO_S_53
  OD_S53_U_EDGE_2 = EXT [OD] OD_S53_U_EDGE_1 < GRID ABUT == 90 INTERSECTING ONLY
  OD_S53_EDGE_WAIVE1 = LENGTH (OD TOUCH EDGE OD_S53_U_EDGE_2) <= PO_S_53_L
  OD_S53_EDGE_WAIVE2 = INT [OD] OD_S53_EDGE_WAIVE1 == PO_S_53_W1 OPPOSITE
  OD_S53_EDGE_CHK = (OD_S53_EDGE_CHK1 NOT COIN EDGE OD_S53_EDGE_WAIVE2) NOT COIN EDGE OD_S53_EDGE_WAIVE1

  PO_S53_EDGE_WAIVE = CONVEX EDGE POLY_CHK ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH <= PO_S_53_L2
  PO_S53_EDGE_CHK = ((EXT OD_S53_EDGE_CHK [POLY_CHK] < PO_S_53 ABUT < 90 OPPOSITE) NOT INSIDE EDGE EXC) NOT COIN EDGE PO_S53_EDGE_WAIVE
    
  PO_S53_EDGE_CHK4 = ENC CO [PO_S53_EDGE_CHK] < PO_S_53_EN ABUT < 90 OPPOSITE
  PO_S53_EDGE_CHK5 = PO_S53_EDGE_CHK TOUCH EDGE PO_S53_EDGE_CHK4
  PO_S53_EDGE_CHK2 = ENC CO [PO_S53_EDGE_CHK] < PO_S_53_EN1 ABUT < 90 OPPOSITE
  PO_S53_EDGE_CHK3 = PO_S53_EDGE_CHK TOUCH EDGE PO_S53_EDGE_CHK2
  
  EXT OD_S53_EDGE_CHK PO_S53_EDGE_CHK3 < PO_S_53 ABUT < 90 OPPOSITE REGION

  PSD_CHECK  = PSDc COIN INSIDE EDGE OD_S53_EDGE_CHK  
  NSD_CHECK  = NSDc COIN INSIDE EDGE OD_S53_EDGE_CHK 
  PSTP_CHECK = PSTPi COIN INSIDE EDGE OD_S53_EDGE_CHK
  NSTP_CHECK = NSTPi COIN INSIDE EDGE OD_S53_EDGE_CHK
  PO_CHECK   = ILP1i COIN INSIDE EDGE PO_S53_EDGE_CHK5
 
  EXT PSD_CHECK PO_CHECK < PO_S_53 ABUT < 90 OPPOSITE REGION NOT CONNECTED
  EXT NSD_CHECK PO_CHECK < PO_S_53 ABUT < 90 OPPOSITE REGION NOT CONNECTED
  EXT PSTP_CHECK PO_CHECK < PO_S_53 ABUT < 90 OPPOSITE REGION NOT CONNECTED
  EXT NSTP_CHECK PO_CHECK < PO_S_53 ABUT < 90 OPPOSITE REGION NOT CONNECTED
}



//FLOATING GATE CHECK
//===================
Float_GATE = NET AREA RATIO GATEu PSTPu NSTPu PSDu_g NSDu_g PADu COu > 0 
  [!AREA(PSTPu)*!AREA(NSTPu)*!AREA(PSDu_g)*!AREA(NSDu_g)*!AREA(PADu)+!AREA(COu)]
Float_NSD = NET AREA RATIO NSDu_g PSDu_g GATEu PSTPu NSTPu PADu > 0
  [~(COUNT(NSDu_g)-1)*!AREA(PSDu_g)*!AREA(GATEu)*!AREA(PSTPu)*!AREA(NSTPu)*!AREA(PADu)]
Float_PSD = NET AREA RATIO PSDu_g NSDu_g GATEu PSTPu NSTPu PADu > 0
  [~(COUNT(PSDu_g)-1)*!AREA(NSDu_g)*!AREA(GATEu)*!AREA(PSTPu)*!AREA(NSTPu)*!AREA(PADu)]

effective_NSD = NSDu_g NOT Float_NSD
effective_PSD = PSDu_g NOT Float_PSD

Float_NSD_a = Float_NSD NOT ((Float_NSD OR GATE) INTERACT effective_NSD > 1 BY NET)
Float_PSD_a = Float_PSD NOT ((Float_PSD OR GATE) INTERACT effective_PSD > 1 BY NET)


#IFDEF CHECK_FLOATING_GATE_BY_PRIMARY_TEXT

IP_PIN_M1u_BY_TEXT = M1u WITH TEXT IP_PIN_TEXT M1_PIN_TEXT PRIMARY ONLY
IP_PIN_M2u_BY_TEXT = M2u WITH TEXT IP_PIN_TEXT M2_PIN_TEXT PRIMARY ONLY
IP_PIN_M3u_BY_TEXT = M3u WITH TEXT IP_PIN_TEXT M3_PIN_TEXT PRIMARY ONLY
IP_PIN_M4u_BY_TEXT = M4u WITH TEXT IP_PIN_TEXT M4_PIN_TEXT PRIMARY ONLY
IP_PIN_M5u_BY_TEXT = M5u WITH TEXT IP_PIN_TEXT M5_PIN_TEXT PRIMARY ONLY
IP_PIN_M6u_BY_TEXT = M6u WITH TEXT IP_PIN_TEXT M6_PIN_TEXT PRIMARY ONLY
IP_PIN_M7u_BY_TEXT = M7u WITH TEXT IP_PIN_TEXT M7_PIN_TEXT PRIMARY ONLY
IP_PIN_M8u_BY_TEXT = M8u WITH TEXT IP_PIN_TEXT M8_PIN_TEXT PRIMARY ONLY
IP_PIN_M9u_BY_TEXT = M9u WITH TEXT IP_PIN_TEXT M9_PIN_TEXT PRIMARY ONLY
IP_PIN_APu_BY_TEXT = APu WITH TEXT IP_PIN_TEXT AP_PIN_TEXT PRIMARY ONLY
IP_PIN_WAIVE = NET AREA RATIO GATEu OVER IP_PIN_M9u_BY_TEXT IP_PIN_M8u_BY_TEXT IP_PIN_M7u_BY_TEXT IP_PIN_M6u_BY_TEXT IP_PIN_M5u_BY_TEXT IP_PIN_M4u_BY_TEXT IP_PIN_M3u_BY_TEXT IP_PIN_M2u_BY_TEXT IP_PIN_M1u_BY_TEXT IP_PIN_APu_BY_TEXT > 0

Float_GATE_check = (Float_GATE NOT INTERACT (Float_NSD_a OR Float_PSD_a)) NOT INTERACT IP_PIN_WAIVE
#ELSE
#IFDEF CHECK_FLOATING_GATE_BY_TEXT

IP_PIN_M1u_BY_TEXT = M1u WITH TEXT IP_PIN_TEXT M1_PIN_TEXT
IP_PIN_M2u_BY_TEXT = M2u WITH TEXT IP_PIN_TEXT M2_PIN_TEXT
IP_PIN_M3u_BY_TEXT = M3u WITH TEXT IP_PIN_TEXT M3_PIN_TEXT
IP_PIN_M4u_BY_TEXT = M4u WITH TEXT IP_PIN_TEXT M4_PIN_TEXT
IP_PIN_M5u_BY_TEXT = M5u WITH TEXT IP_PIN_TEXT M5_PIN_TEXT
IP_PIN_M6u_BY_TEXT = M6u WITH TEXT IP_PIN_TEXT M6_PIN_TEXT
IP_PIN_M7u_BY_TEXT = M7u WITH TEXT IP_PIN_TEXT M7_PIN_TEXT
IP_PIN_M8u_BY_TEXT = M8u WITH TEXT IP_PIN_TEXT M8_PIN_TEXT
IP_PIN_M9u_BY_TEXT = M9u WITH TEXT IP_PIN_TEXT M9_PIN_TEXT
IP_PIN_APu_BY_TEXT = APu WITH TEXT IP_PIN_TEXT AP_PIN_TEXT
IP_PIN_WAIVE = NET AREA RATIO GATEu OVER IP_PIN_M9u_BY_TEXT IP_PIN_M8u_BY_TEXT IP_PIN_M7u_BY_TEXT IP_PIN_M6u_BY_TEXT IP_PIN_M5u_BY_TEXT IP_PIN_M4u_BY_TEXT IP_PIN_M3u_BY_TEXT IP_PIN_M2u_BY_TEXT IP_PIN_M1u_BY_TEXT IP_PIN_APu_BY_TEXT > 0

Float_GATE_check = (Float_GATE NOT INTERACT (Float_NSD_a OR Float_PSD_a)) NOT INTERACT IP_PIN_WAIVE
#ELSE
Float_GATE_check = Float_GATE NOT INTERACT (Float_NSD_a OR Float_PSD_a)
#ENDIF
#ENDIF

#IFDEF CHECK_FLOATING_GATE_BY_PRIMARY_TEXT
#DEFINE CHECK_POR19
#ELSE
#IFDEF CHECK_FLOATING_GATE_BY_TEXT
#DEFINE CHECK_POR19
#ENDIF
#ENDIF
#IFDEF FULL_CHIP
#DEFINE CHECK_POR19
#ENDIF

#IFDEF CHECK_POR19
PO.R.19 { @ Floating gate is prohibited if the effective source/drain are not connected together. Floating gate in the DRC is as follows: (1) GATE without Poly CO (2) GATE with Poly CO but not connected to MOS OD, STRAP or PAD. (3) It is not a floating gate if the GATE is connected to OD by butted CO in SRAM bit cell. The effective source/drain in DRC is as follows: (1)Source/drain is connected to different {MOSOD NOT PO}, STRAP, Gate, or PAD. This rule is only checked on the whole chip, not on the IP level   
  (Float_GATE_check INTERACT NSDu > 1 BY NET) NOT INSIDE SRAM_WAIVE_N28
  (Float_GATE_check INTERACT PSDu > 1 BY NET) NOT INSIDE SRAM_WAIVE_N28
}
#ENDIF




// GB_ALL CHECKS
//===============

SR_POLY_NOT_CPO = SR_POLY NOT CPO
SR_POLY_NOT_CPO_15 = SR_POLY_NOT_CPO AND GB1_5
SR_POLY_NOT_CPO_D2 = SR_POLY_NOT_CPO AND GB_D2


GB_ALL.W.1 { @ {{PO OR SR_DPO} NOT CPO} width of GB_D2 = 0.035 
  A = INT SR_POLY_NOT_CPO_D2 == GB_ALL_W_1 REGION
  SR_POLY_NOT_CPO_D2 NOT A
}

GATE_L035 = (GATE WITH EDGE (LENGTH GATE_L == GB_ALL_W_2_W1)) INSIDE GB_D2
GATE_L035_CHK = GATE_L035 COIN EDGE CHECK_LAST_GATE_EDGE

GB_ALL.W.2 { @ Width of {PO OR SR_DPO} [in S/D and outside OD direction] neighboring to LAST GATE inside GB_D2 [GATE width = 0.035 um, {PO OR SR_DPO} to LAST GATE space < 0.23 um] (This check doesn't include the region covered by OD2, SR_ESD and SDI) = 0.03~0.04 
  A = EXT GATE_L035_CHK [SR_POLY] < GB_ALL_W_2_S OPPOSITE
  B = INT [A] SR_POLY >= GB_ALL_W_2A <= GB_ALL_W_2B OPPOSITE
  C = EXT [GATE_L035_CHK] B < GB_ALL_W_2_S OPPOSITE
#IFDEF SKIP_CELL_BOUNDARY
  D = ENC [GATE_L035_CHK] PRBOUNDARY < GB_ALL_W_2_S EXCLUDE SHIELDED 4 OPPOSITE
  E = C OR EDGE D
#ELSE
  E = COPY C
#ENDIF
  GATE_L035_CHK NOT COIN EDGE E

}

GB_ALL.S.1 { @ Space to {OD INTERACT {PO OR SR_DPO}} >= 0.06 
  CHECK_OD = OD INTERACT SR_POLY  
  EXT GB_ALL CHECK_OD < GB_ALL_S_1 ABUT < 90 SINGULAR REGION
}

GB_ALL.S.2 { @ Space to {GATE NOT INTERACT GB_D2} in PO ENDCAP direction >= 0.065 
  GATE_L_NOT_GB_ALL = GATE_L OUTSIDE EDGE GB_D2
  EXT GB_ALL GATE_L_NOT_GB_ALL < GB_ALL_S_2 ABUT < 90 REGION
}

GB_ALL.EN.1 { @ Enclosure of OD >= 0.02 
  ENC OD GB_ALL < GB_ALL_EN_1 ABUT < 90 SINGULAR REGION
}

GB_ALL.EN.2 { @ Enclosure of GATE in ENDCAP direction >= 0.065 
  GATE_L_GB_ALL = GATE_L INSIDE EDGE GB_ALL
  ENC GATE_L_GB_ALL GB_ALL < GB_ALL_EN_2 OPPOSITE REGION
}

GB_ALL.EN.3 { @ Enclosure of {PO NOT CPO} in ENDCAP direction [{PO NOT CPO} ENDCAP < 0.12 um] (GB_D2 must fully cover {PO NOT CPO} ENDCAP < 0.12 um) >= 0.005 
   REAL_PO = POLY NOT CPO
   GATE_L_GB_ALL = GATE_L COIN INSIDE EDGE (GATE INTERACT GB_ALL)
   A = ENC GATE_L_GB_ALL REAL_PO < GB_ALL_EN_3_L OPPOSITE REGION
   ENC A GB_ALL < GB_ALL_EN_3 ABUT < 90 SINGULAR REGION
   A NOT GB_D2
}

GB_ALL.R.1 { @ {OD INTERACT PO} cut GB_D2 is not allowed   
  (OD INTERACT POLY) CUT GB_D2
}

GB_ALL.R.2 { @ GB_D2 must be a rectangle   
  NOT RECTANGLE GB_D2 ORTHOGONAL ONLY
}

GB_ALL.R.3 { @ GB_D2 must fully cover {GATE INTERACT GB_D2}. {GB_D2 NOT INTERACT GATE} is not allowed   
  GB_D2 NOT ENCLOSE GATE
  GATE CUT GB_D2
}

GATE_GB_ALL = GATE INSIDE GB_ALL
GATE_GB_15 = GATE INSIDE GB1_5
GATE_GB_D2 = GATE INSIDE GB_D2

GB_ALL.R.4 { @ GATE [INSIDE GB_D2] overlaps VTH_N, VTH_P, UHVT_N, UHVT_P, SR_ESD and SDI is not allowed.
  GATE_GB_D2 AND VTHNi
  GATE_GB_D2 AND VTHPi
  GATE_GB_D2 AND SRESD
  GATE_GB_D2 AND SDI
  GATE_GB_D2 AND VTUHNi
  GATE_GB_D2 AND VTUHPi
  GATE_GB_D2 AND EHVT_N
  GATE_GB_D2 AND EHVT_P
}

GB_ALL.R.5 { @ GB1_5 interact with GATE is not allow   
  GB1_5 INTERACT GATE
}



//CPO CHECKS
//=========

CPO_W = ANGLE CPO == 90
CPO_L = ANGLE CPO == 0

CPO.W.1 { @ CPO width = 0.08 
  LENGTH CPO_W != CPO_W_1
}

CPO.W.2 { @ Maximum width of {PO AND CPO} in CPO length direction <= 0.1 
  LENGTH (CPO INSIDE EDGE POLY) > CPO_W_2
}
CPO.S.1 { @ CPO space >= 0.09 
  EXT CPO < CPO_S_1 ABUT < 90 SINGULAR REGION
}
CPO.S.2 { @ CPO space to {PO OR SR_DPO} in CPO length direction >= 0.04 
  EXT CPO_W SR_POLY < CPO_S_2 ABUT < 90 REGION
}
CPO.S.3 { @ CPO space to OD (overlap is not allowed) >= 0.035 
  EXT CPO OD < CPO_S_3 ABUT < 90 SINGULAR REGION INSIDE ALSO
}
CPO.S.4 { @ CPO space to CO (overlap is not allowed) >= 0.02 
  (EXT CPO CO < CPO_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO) NOT INSIDE SRM_3
}
CPO.S.5 { @ CPO space to GATE in CPO width direction (overlap is not allowed) when the PO to L-shape OD (in the same MOS) space < 0.1 um >= 0.05 
  A = (CONVEX EDGE OD ANGLE1 == 90 ANGLE2 == 270) NOT TOUCH EDGE GATE_L
  B = GATE TOUCH EDGE (EXPAND EDGE A OUTSIDE BY CPO_S_5_S)    
  EXT B CPO < CPO_S_5 ABUT < 90 REGION
}
CPO.S.6 { @ CPO space to {PO OR SR_DPO} >= 0.02 
  EXT CPO SR_POLY < CPO_S_6 ABUT < 90 SINGULAR REGION
}
CPO.EX.1 { @ CPO extension on {PO OR SR_DPO} in CPO length direction >= 0.05 
  ENC SR_POLY CPO_W < CPO_EX_1 ABUT < 90 OPPOSITE REGION
}
CPO.EX.3 { @ {PO OR SR_DPO} extension on CPO >= 0.1 
  ENC CPO SR_POLY < CPO_EX_3 ABUT < 90 SINGULAR REGION
}
CPO.L.1 { @ CPO length >= 0.15 
  LENGTH CPO_L < CPO_L_1
}
CPO.O.1 { @ Overlap of {PO OR SR_DPO} in CPO width direction = 0.045 or 0.05 or 0.08 
  CPO_PO = CPO INSIDE EDGE SR_POLY
  A = SR_POLY AND CPO
  B = EXPAND EDGE CPO_PO INSIDE BY CPO_O_1A
  C = EXPAND EDGE CPO_PO INSIDE BY CPO_O_1B
  D = XOR A B
  E = A INTERACT D
  F = C INTERACT D
  E XOR F
}
CPO.A.1 { @ Area of {{PO OR SR_DPO} NOT CPO} (This check doesn't include rectangle {{{PO OR SR_DPO} NOT CPO} INTERACT OD} with length >= 0.23 um) >= 0.009 
  A = SR_POLY NOT CPO
  B = (RECTANGLE A) INTERACT OD
  C = LENGTH B >= CPO_A_1_L
  D = B WITH EDGE C
  E = A NOT D
  AREA E < CPO_A_1
}

CPO.R.1 { @ CPO must be a rectangle (45-degree edge is not allowed)   
  NOT RECTANGLE CPO ORTHOGONAL ONLY
}
CPO.R.2 { @ {{PO OR SR_DPO} AND CPO} must be rectangular except small jogs (jog = 0.005 um)   
  A = NOT RECTANGLE (SR_POLY AND CPO)
  B = CONVEX EDGE (A INSIDE EDGE CPO) ANGLE1 == 90 ANGLE2 == 270
  A WITH EDGE (LENGTH B > CPO_R_2)
}
CPO.R.3 { @ Overlap of {OD2 OR NT_N} is not allowed   
  CPO AND (OD2 OR NTN)
}
CPO.R.4 { @ CPO must INTERACT {PO OR SR_DPO}   
  CPO NOT INTERACT (SR_POLY AND CPO)
}
CPO.R.5 { @ CPO must be in the horizontal direction which is perpendicular to the core gate length direction in a chip (This check doesn't include the regions covered by CSRDMY, and LOGO)   
  CPO_CHECK = CPO NOT INSIDE (CSRDMY OR LOGO)  
  DFM PROPERTY CPO_CHECK CPO_W CPO_L OVERLAP ABUT ALSO MULTI
  [ -= LENGTH(CPO_W) - LENGTH(CPO_L)] > 0
}

CPO.R.6 { @ Any vertex of CPO inside {PO OR SR_DPO} is not allowed   
  (INT CPO < GRID ABUT == 90 INTERSECTING ONLY REGION) INSIDE SR_POLY
  (EXT CPO < GRID ABUT == 90 INTERSECTING ONLY REGION) INSIDE SR_POLY
}
CPO.R.7 { @ Floating {SR_DPO OR PO} must be placed before CPO edge if CPO length >= 20 um. Floating {SR_DPO OR PO} is defined as: {{{SR_DPO OR PO} NOT {{{SR_DPO OR PO} AND CPO} not beside long (>= 20 um) CPO edge}} NOT INTERACT CO}   
  LONG_CPO = CPO WITH EDGE (LENGTH CPO >= CPO_R_7_L)
  EDGE_CPO = (LONG_CPO NOT SR_POLY) INTERACT (SR_POLY AND CPO) == 1
  CUT_POLY = (SR_POLY AND CPO) NOT INTERACT EDGE_CPO
  FLOATING_SR_POLY = (SR_POLY NOT CUT_POLY) NOT INTERACT COi
  EDGE_CPO NOT INTERACT FLOATING_SR_POLY
}


//SR_DPO CHECKS
//=============

FIELD_SRDPO = SRDPO NOT INTERACT OD
LVF_SRDPO = FIELD_SRDPO NOT INSIDE OD2
HVF_SRDPO = FIELD_SRDPO INSIDE OD2
EDGE_SD = SD INTERACT GATE == 1
LV_GATE_EDGE = LV_GATE TOUCH EDGE EDGE_SD
HV_GATE_EDGE = HV_GATE TOUCH EDGE EDGE_SD
ESD_SDI = SRESD OR SDI

SR_DPO.W.2 { @ Width of {{SR_DPO NOT INTERACT OD} OUTSIDE OD2}[the {GATE SIZING 0.12 um} NOT INTERACT SR_DPO in S/D direction] >= 0.03 
  LV_GATE_EXP = EXPAND EDGE LV_GATE_EDGE OUTSIDE BY SRDPO_W_2_S
  LVF_SRDPO_CHECK = LVF_SRDPO NOT INTERACT LV_GATE_EXP
  INT LVF_SRDPO_CHECK < SRDPO_W_2 ABUT < 90 SINGULAR REGION
}
SR_DPO.W.4 { @ Width of {{SR_DPO NOT INTERACT OD} INSIDE OD2} [the {GATE SIZING 0.32 um} INTERACT SR_DPO in S/D direction][in SR_ESD, SDI] = 0.1 
  HV_GATE_EXP = EXPAND EDGE HV_GATE_EDGE OUTSIDE BY SRDPO_W_4_S
  HVF_SRDPO_CHECK = (HVF_SRDPO INSIDE ESD_SDI) INTERACT HV_GATE_EXP
  HVF_SRDPO_CHECK NOT WITH WIDTH == SRDPO_W_4
}

SR_DPO.W.6 { @ Width >= 0.03 
  INT SRDPO < SRDPO_W_6 ABUT < 90 SINGULAR REGION
}


SR_DPO.W.7 { @ Width [INSIDE OD2] (for 1.8V underdrive to 1.2V, please refer to SR_DPO.W.14.) (This check doesn't include the regions covered by RH_PO) = 0.1~2 
  SRDPO_CHK = ((SRDPO INSIDE OD2) OUTSIDE OD1812) NOT INSIDE RHPO
  INT SRDPO_CHK < SRDPO_W_7A ABUT < 90 SINGULAR REGION
  SRDPO_CHK WITH WIDTH > SRDPO_W_7B
}


SR_DPO.W.7.1 { @ Width of horizontal SR_DPO [NOT OUTSIDE OD2] >= 0.1 
  SRDPO_HORIZONTAL = ANGLE (SRDPO NOT OUTSIDE OD2) == 0  
  INT SRDPO_HORIZONTAL < SRDPO_W_7_1 ABUT < 90 REGION
}
SR_DPO.W.8 { @ Maximum SR_DPO width <= 2 
  SRDPO WITH WIDTH > SRDPO_W_8
}

SR_DPO.W.9 { @ Width of {{PO OR SR_DPO} AND OD}[INSIDE OD_18, in channel length direction] (for 1.8V underdrive to 1.5V/1.2V, please refer to SR_DPO.W.11, and OD18_12.) (This check doesn't include the regions covered by {HVN_65 OR HVP_65}, {HVN25_65 OR HVP25_65}) = 0.15~2 
  W_CHK = (SRPO_GATE_L INSIDE EDGE OD18) NOT INSIDE EDGE ((OD1815 OR OD1812) OR (OR HVD HVD_65))
  LENGTH W_CHK < SRDPO_W_9A 
  LENGTH W_CHK > SRDPO_W_9B
}

SR_DPO.W.10 { @ Width of {{PO OR SR_DPO} AND OD}[INSIDE OD_25, in channel length direction] (for 2.5V underdrive to 1.8V, please refer to OD25_18 rules.) (This check doesn't include the regions covered by VAR) = 0.27~2 
  W_CHK = (SRPO_GATE_L INSIDE EDGE OD25) NOT INSIDE EDGE (OR OD2518 GATED VAR HVD_65)
  LENGTH W_CHK < SRDPO_W_10A 
  LENGTH W_CHK > SRDPO_W_10B
}

SR_DPO.W.11 { @ Width of {{PO OR SR_DPO} AND OD}[INSIDE OD18_15, in channel length direction] = 0.105~2 
  W_CHK = SRPO_GATE_L INSIDE EDGE OD1815
  LENGTH W_CHK < SRDPO_W_11A
  LENGTH W_CHK > SRDPO_W_11B
}

SR_DPO.W.13 { @ Width of {{PO OR SR_DPO} AND OD} [INSIDE OD18_12, in channel length direction] = 0.09~2 
  W_CHK = SRPO_GATE_L INSIDE EDGE OD1812
  LENGTH W_CHK < SRDPO_W_13A
  LENGTH W_CHK > SRDPO_W_13B
}
SR_DPO.W.13.1 { @ Width of {{PO OR SR_DPO} AND OD} [INSIDE OD18_12, in channel length direction, for horizontal poly] = 0.1~2 
  W_CHK = ANGLE (SRPO_GATE_L INSIDE EDGE OD1812) == 90
  LENGTH W_CHK < SRDPO_W_13_1
}
SR_DPO.W.14 { @ Width [INSIDE OD2, NOT OUTSIDE OD18_12] (This check doesn't include the regions covered by RH_PO) = 0.09~2 
  SRDPO_CHK = ((SRDPO INSIDE OD2) NOT OUTSIDE OD1812) NOT INSIDE RHPO
  INT SRDPO_CHK < SRDPO_W_14A ABUT < 90 SINGULAR REGION
  SRDPO_CHK WITH WIDTH > SRDPO_W_14B
}

SR_DPO.W.14.1 { @ Width [INSIDE OD2, NOT OUTSIDE OD18_12, for horizontal poly] = 0.1~2 
  SRDPO_CHK = (SRDPO INSIDE OD2) NOT OUTSIDE OD1812
  X = ANGLE SRDPO_CHK == 0
  INT SRDPO_CHK X < SRDPO_W_14_1 ABUT < 90 REGION
}


SR_DPO.S.1 { @ Space to {PO OR SR_DPO} ({{SR_DPO OVERLAP PO} OUTSIDE CPO} and {{SR_DPO ABUT PO} OUTSIDE CPO} are not allowed) >= 0.08 
  EXT SRDPO < SRDPO_S_1 ABUT < 90 SINGULAR REGION
  EXT POLY SRDPO < GRID ABUT < 90 > 0 SINGULAR REGION  
  EXT SRDPO POLY < SRDPO_S_1 ABUT < 90 > 0 REGION
  (SRDPO NOT CPO) AND (POLY NOT CPO)
  (SRDPO NOT CPO) COIN EDGE (POLY NOT CPO)  
}

HV_DACT = DACT AND OD2
CONNECT HV_DACT

SR_DPO.S.3 { @ {{SR_DPO AND OD} INSIDE OD2} space in the same OD (This check doesn't include the regions covered by {HVN_65 OR HVP_65}, {HVN25_65 OR HVP25_65}) >= 0.18 
  HV_GATE_C = STAMP HV_GATE BY HV_DACT
  SR_HV_GATE_C = (STAMP SR_HV_GATE BY HV_DACT) NOT INSIDE (OR HVD HVD_65)
  EXT SR_HV_GATE_C < SRDPO_S_3 ABUT < 90 SINGULAR REGION CONNECTED
  EXT SR_HV_GATE_C HV_GATE_C < SRDPO_S_3 ABUT < 90 SINGULAR REGION CONNECTED
}

SR_DPO.S.4 { @ Space to OD >= 0.025 
  EXT SRDPO OD < SRDPO_S_4 ABUT < 90 SINGULAR REGION
}

SR_DPO.S.5 { @ Space if at least one {PO OR SR_DPO} width >= 0.03 um, and the {PO OR SR_DPO} parallel run length > 0.09 um >= 0.1 
  Wide_SR_DPO_POLY = SR_POLY WITH WIDTH >= SRDPO_S_5_W
  E1 = EXT Wide_SR_DPO_POLY [SR_POLY] < SRDPO_S_5 ABUT < 90 OPPOSITE MEASURE ALL
  E2_pre1 = EXT [SR_POLY] E1 < GRID ABUT == 90 INTERSECTING ONLY
  E2_pre2 = SR_POLY TOUCH EDGE E2_pre1
  E2 = (CONVEX EDGE SR_POLY ANGLE1 == 90 ANGLE2 == 270) TOUCH EDGE E2_pre2
  A1 = EXPAND EDGE (OR EDGE E1 E2) BY GRID

  E1_H = ANGLE E1 == 0
  E1_V = ANGLE E1 == 90  
  DFM PROPERTY A1 E1_H OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1_H) ] > SRDPO_S_5_L
  DFM PROPERTY A1 E1_V OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1_V) ] > SRDPO_S_5_L
}
SR_DPO.S.6 { @ Space if at least one {PO OR SR_DPO} width > 0.09 um, and the {PO OR SR_DPO} parallel run length > 0.09 um. (This check doesn't include the regions covered by {HVN_65 OR HVP_65}, {HVN25_65 OR HVP25_65}) >= 0.12 
  Wide_SR_DPO_POLY = (SR_POLY WITH WIDTH > SRDPO_S_6_W) NOT INTERACT (OR HVD HVD_65)
  E1 = EXT Wide_SR_DPO_POLY [SR_POLY] < SRDPO_S_6 ABUT < 90 OPPOSITE MEASURE ALL
  E2_pre1 = EXT [SR_POLY] E1 < GRID ABUT == 90 INTERSECTING ONLY
  E2_pre2 = SR_POLY TOUCH EDGE E2_pre1
  E2 = (CONVEX EDGE SR_POLY ANGLE1 == 90 ANGLE2 == 270) TOUCH EDGE E2_pre2
  A1 = EXPAND EDGE (OR EDGE E1 E2) BY GRID
  
  E1_H = ANGLE E1 == 0
  E1_V = ANGLE E1 == 90  
  DFM PROPERTY A1 E1_H OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1_H) ] > SRDPO_S_6_L
  DFM PROPERTY A1 E1_V OVERLAP ABUT ALSO MULTI
  [-= LENGTH(E1_V) ] > SRDPO_S_6_L
}


SR_DPO.S.8 { @ Space to INDDMY >= 1.2 
  EXT INDDMY SRDPO < SRDPO_S_8 ABUT < 90 SINGULAR REGION
}

SR_DPO.S.9 { @ Space to DPO (overlap is not allowed) >= ^SRDPO_S_9 um
  EXT SRDPO DPO < SRDPO_S_9 ABUT < 90 SINGULAR REGION
  DPO AND SRDPO
}





SR_DPO.S.12 { @ {SR_DPO AND OD} space to RPO (overlap is not allowed) >= 0.38 
  EXT SR_GATE RPO < SRDPO_S_12 ABUT < 90 SINGULAR REGION
  SR_GATE AND RPO
}

SR_DPO.S.13 { @ {SR_DPO AND OD} space to CO (overlap is not allowed) >= 0.03 
  EXT SR_GATE CO < SRDPO_S_13 ABUT < 90 SINGULAR REGION
  SR_GATE AND CO
}

SR_DPO.S.14 { @ {SR_DPO AND OD} space to CO [SR_DPO width > 0.09 um] (overlap is not allowed) >= 0.04 
  WSR_GATE = (SRDPO WITH WIDTH > SRDPO_S_14_W ) AND OD
  EXT WSR_GATE CO < SRDPO_S_14 ABUT < 90 SINGULAR REGION
}

SR_DPO.S.15 { @ {{SR_DPO AND OD} AND OD2} space to {CO INSIDE OD} (overlap is not allowed) >= 0.07 
  EXT SR_HV_GATE COOD < SRDPO_S_15 ABUT < 90 SINGULAR REGION
// overlap is checked by SR_DPO.S.13
}

SR_DPO.S.16 { @ The {{{SR_DPO AND OD} SIZING 0.06 um} AND SR_DPO} space to neighboring poly {PO OR SR_DPO} of core device [channel length > 0.09 um]. (This check doesn't include the regions covered by SR_ESD, SDI, RF_PP, {RF_PP AND RF_SL1}) = 0.12 
  SR_GATE_CHECK = ((LV_SR_GATE NOT INSIDE POS_EXCLUDE_new) NOT INSIDE LOGO) WITH EDGE (LENGTH SR_GATE_L > SRDPO_S_16_L)
  SRPO_CHECK = (SIZE SR_GATE_CHECK BY SRDPO_S_16_S) AND SRDPO
  GOOD_EDGE = EXT [SRPO_CHECK] SR_POLY == SRDPO_S_16 EXCLUDE SHIELDED 4 OPPOSITE
  (SRPO_CHECK TOUCH EDGE SR_GATE_W) NOT COIN INSIDE EDGE GOOD_EDGE
}
SR_DPO.S.17 { @ The {{{SR_DPO AND OD} SIZING 0.06 um} AND SR_DPO} space to neighboring poly {PO OR SR_DPO} [INSIDE OD2] (This check doesn't include the regions covered by {HVN_65 OR HVP_65}, {HVN25_65 OR HVP25_65}, SR_ESD and SDI) = 0.18 
  IO_SR_GATE = SR_GATE AND OD2    
  SR_GATE_CHECK = (IO_SR_GATE NOT INSIDE POS_EXCLUDE) NOT INSIDE (OR LOGO HVD HVD_65)
  SRPO_CHECK = (SIZE SR_GATE_CHECK BY SRDPO_S_17_S) AND SRDPO
  GOOD_EDGE = EXT [SRPO_CHECK] SR_POLY == SRDPO_S_17 EXCLUDE SHIELDED 4 OPPOSITE
  (SRPO_CHECK TOUCH EDGE SR_GATE_W) NOT COIN INSIDE EDGE GOOD_EDGE
}

SR_DUMMY_MOS = (OD NOT INTERACT POLY) INTERACT SRDPO  


SR_DPO.S.18 { @ The {{{SR_DPO AND {OD INTERACT PO}} SIZING 0.06 um} AND SR_DPO} space to neighboring poly {PO OR SR_DPO} of core device [channel length <= 0.09 um]. (This check doesn't include the regions covered by layers of SR_ESD, SDI, DMY_SCH, RF_PP, {RF_PP AND RF_SL1}) = 0.1 
  SR_GATE_CHECK = (((LV_SR_GATE NOT INSIDE (POS_EXCLUDE OR SR_DUMMY_MOS) ) NOT INSIDE LOGO) NOT INSIDE (OR DMY_SCH RFPP_EXC)) WITH EDGE (LENGTH SR_GATE_L <= SRDPO_S_18_L)
  SRPO_CHECK = (SIZE SR_GATE_CHECK BY SRDPO_S_18_S) AND SRDPO  
  GOOD_EDGE = EXT [SRPO_CHECK] SR_POLY == SRDPO_S_18 EXCLUDE SHIELDED 4 OPPOSITE
  (SRPO_CHECK TOUCH EDGE SR_GATE_W) NOT COIN INSIDE EDGE GOOD_EDGE
}
SR_DPO.S.18.1 { @ The {{{SR_DPO AND {OD INTERACT PO}} SIZING 0.06 um} AND SR_DPO} space to neighboring poly {PO OR SR_DPO} of core device [channel length >= 0.04 um and <= 0.09 um, INSIDE DMY_SCH (255;52)]. (Except SR_ESD and SDI) = 0.1 
  SR_GATE_CHECK = (((LV_SR_GATE NOT INSIDE (POS_EXCLUDE OR SR_DUMMY_MOS) ) NOT INSIDE LOGO) INSIDE DMY_SCH) WITH EDGE (LENGTH SR_GATE_L >= SRDPO_S_18_LC <= SRDPO_S_18_L)
  SRPO_CHECK = (SIZE SR_GATE_CHECK BY SRDPO_S_18_S) AND SRDPO  
  GOOD_EDGE = EXT [SRPO_CHECK] SR_POLY == SRDPO_S_18 EXCLUDE SHIELDED 4 OPPOSITE
  (SRPO_CHECK TOUCH EDGE SR_GATE_W) NOT COIN INSIDE EDGE GOOD_EDGE
}
SR_DPO.S.18.2 { @ The {{{SR_DPO AND {OD INTERACT PO}} SIZING 0.06 um} AND SR_DPO} space to neighboring poly {PO OR SR_DPO} of core device [channel length = 0.03 um, INSIDE DMY_SCH (255;52)] 1. For individual {{{SR_DPO AND {OD INTERACT PO}} SIZING 0.06 um} AND SR_DPO}, the both spaces to neighboring poly {PO OR SR_DPO} must be the same. 2. Except VAR, SR_ESD, and SDI = 0.1, 0.11 
  SR_GATE_CHECK = ((LV_SR_GATE NOT INSIDE (POS_EXCLUDE_1 OR SR_DUMMY_MOS)) INSIDE DMY_SCH) WITH EDGE (LENGTH SR_GATE_L == SRDPO_S_19_L)     
  SRPO_CHECK = (SIZE SR_GATE_CHECK BY SRDPO_S_19_S) AND SRDPO  
  GOOD_EDGEA = EXT [SRPO_CHECK] SR_POLY == SRDPO_S_19A EXCLUDE SHIELDED 4 OPPOSITE
  GOOD_EDGEB = EXT [SRPO_CHECK] SR_POLY == SRDPO_S_19B EXCLUDE SHIELDED 4 OPPOSITE  
  ((SRPO_CHECK TOUCH EDGE SR_GATE_W) NOT COIN INSIDE EDGE GOOD_EDGEA) NOT COIN INSIDE EDGE GOOD_EDGEB
  (SRPO_CHECK WITH EDGE GOOD_EDGEA) WITH EDGE GOOD_EDGEB
}
SR_DPO.S.18.3 { @ The {{{SR_DPO AND {OD INTERACT PO}} SIZING 0.06 um} AND SR_DPO} space to neighboring poly {PO OR SR_DPO} of core device [channel length = 0.035 um, INSIDE DMY_SCH (255;52)]. 1. For individual {{{SR_DPO AND {OD INTERACT PO}} SIZING 0.06 um} AND SR_DPO}, the both spaces to neighboring poly {PO OR SR_DPO} must be the same. 2. Except VAR, SR_ESD, and SDI = 0.1, 0.105 
  SR_GATE_CHECK = ((LV_SR_GATE NOT INSIDE (POS_EXCLUDE_1 OR SR_DUMMY_MOS)) INSIDE DMY_SCH) WITH EDGE (LENGTH SR_GATE_L == SRDPO_S_20_L)      
  SRPO_CHECK = (SIZE SR_GATE_CHECK BY SRDPO_S_20_S) AND SRDPO  
  GOOD_EDGEA = EXT [SRPO_CHECK] SR_POLY == SRDPO_S_20A EXCLUDE SHIELDED 4 OPPOSITE
  GOOD_EDGEB = EXT [SRPO_CHECK] SR_POLY == SRDPO_S_20B EXCLUDE SHIELDED 4 OPPOSITE  
  ((SRPO_CHECK TOUCH EDGE SR_GATE_W) NOT COIN INSIDE EDGE GOOD_EDGEA) NOT COIN INSIDE EDGE GOOD_EDGEB
  (SRPO_CHECK WITH EDGE GOOD_EDGEA) WITH EDGE GOOD_EDGEB
}


SR_DPO.EX.1 { @ {PO OR SR_DPO} extension on OD (ENDCAP) >= 0.08 
  ((ENC OD SR_POLY < SRDPO_EX_1 ABUT < 90 OPPOSITE SINGULAR REGION) NOT INSIDE LOGO) NOT INSIDE (SRAM_WAIVE_N28 OR LDMOS)
}

SR_DPO.EX.2 { @ SR_DPO extension on SR_DOD (ENDCAP) >= 0.08 
  ENC SRDOD SRDPO < SRDPO_EX_2 ABUT < 90 SINGULAR REGION
}

OD_SA_NON_CHK = COPY EMPTYi

SR_DPO.EX.3 { @ OD extension on SR_DPO of core device [channel length <= 0.09 um], except for the SR_DPO edge space to neighboring {{PO OR SR_DPO} AND OD} following PO.S.4. (This check doesn't include the regions covered by SR_ESD, SDI, DMY_SCH, RF_PP, {RF_PP AND RF_SL1}) = 0.075 
  SR_GATE_CHECK = (((LV_SR_GATE NOT INSIDE POS_EXCLUDE) NOT INSIDE LOGO) NOT INSIDE (OR DMY_SCH RFPP_EXC)) WITH EDGE (LENGTH SR_GATE_L <= SRDPO_EX_3_L)
  SR_GATE_W_CHECK = SR_GATE_CHECK TOUCH EDGE SR_GATE_W
  GOOD_EDGE2 = ENC [SR_GATE_W_CHECK] OD == SRDPO_EX_3 EXCLUDE SHIELDED 4 OPPOSITE  
  EXCLUDE_SPACE = EXT [SR_GATE_W_CHECK] SRPO_GATE_W <= PO_S_5 ABUT < 90 OPPOSITE
  ((SR_GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE2) NOT COIN EDGE EXCLUDE_SPACE) OUTSIDE EDGE OD_SA_NON_CHK
}

SR_DPO.EX.3.2 { @ OD extension on SR_DPO of core device [0.04 um <= channel length <= 0.09 um, INSIDE DMY_SCH (255;52)] (Except SR_DPO [edge space to neighboring {{PO OR SR_DPO} AND OD} following PO.S.4.1], SR_ESD, and SDI) = 0.075 
  SR_GATE_CHECK = (((LV_SR_GATE NOT INSIDE POS_EXCLUDE) NOT INSIDE LOGO) INSIDE DMY_SCH) WITH EDGE (LENGTH SR_GATE_L >= SRDPO_EX_3_LC <= SRDPO_EX_3_L)
  SR_GATE_W_CHECK = SR_GATE_CHECK TOUCH EDGE SR_GATE_W
  GOOD_EDGE = ENC [SR_GATE_W_CHECK] OD == SRDPO_EX_3 EXCLUDE SHIELDED 4 OPPOSITE  
  EXCLUDE_SPACE = EXT [SR_GATE_W_CHECK] SRPO_GATE_W <= PO_S_5 ABUT < 90 OPPOSITE
  ((SR_GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE) NOT COIN EDGE EXCLUDE_SPACE) OUTSIDE EDGE OD_SA_NON_CHK
}
SR_DPO.EX.3.3 { @ OD extension on SR_DPO of core device [channel length = 0.03 um, INSIDE DMY_SCH (255;52)] (Except SR_DPO [edge space to neighboring {{PO OR SR_DPO} AND OD} following PO.S.4.2], SR_ESD, and SDI) = 0.075, 0.085 
  SR_GATE_CHECK = (((LV_SR_GATE NOT INSIDE POS_EXCLUDE) NOT INSIDE LOGO) INSIDE DMY_SCH) WITH EDGE (LENGTH SR_GATE_L == SRDPO_EX_3_LA)
  SR_GATE_W_CHECK = SR_GATE_CHECK TOUCH EDGE SR_GATE_W
  GOOD_EDGE1 = ENC [SR_GATE_W_CHECK] OD == SRDPO_EX_3 EXCLUDE SHIELDED 4 OPPOSITE  
  GOOD_EDGE0 = ENC [SR_GATE_W_CHECK] OD == SRDPO_EX_3B EXCLUDE SHIELDED 4 OPPOSITE
  GOOD_EDGE = GOOD_EDGE1 OR EDGE GOOD_EDGE0 
  EXCLUDE_SPACE = EXT [SR_GATE_W_CHECK] SRPO_GATE_W <= PO_S_5 ABUT < 90 OPPOSITE
  ((SR_GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE) NOT COIN EDGE EXCLUDE_SPACE) OUTSIDE EDGE OD_SA_NON_CHK
}
SR_DPO.EX.3.4 { @ OD extension on SR_DPO of core device [channel length = 0.035 um, INSIDE DMY_SCH (255;52)] (Except SR_DPO [edge space to neighboring {{PO OR SR_DPO} AND OD} following PO.S.4.3], SR_ESD, and SDI) = 0.075, 0.08 
  SR_GATE_CHECK = (((LV_SR_GATE NOT INSIDE POS_EXCLUDE) NOT INSIDE LOGO) INSIDE DMY_SCH) WITH EDGE (LENGTH SR_GATE_L == SRDPO_EX_3_LB)
  SR_GATE_W_CHECK = SR_GATE_CHECK TOUCH EDGE SR_GATE_W
  GOOD_EDGE1 = ENC [SR_GATE_W_CHECK] OD == SRDPO_EX_3 EXCLUDE SHIELDED 4 OPPOSITE  
  GOOD_EDGE0 = ENC [SR_GATE_W_CHECK] OD == SRDPO_EX_3A EXCLUDE SHIELDED 4 OPPOSITE
  GOOD_EDGE = GOOD_EDGE1 OR EDGE GOOD_EDGE0 
  EXCLUDE_SPACE = EXT [SR_GATE_W_CHECK] SRPO_GATE_W <= PO_S_5 ABUT < 90 OPPOSITE
  ((SR_GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE) NOT COIN EDGE EXCLUDE_SPACE) OUTSIDE EDGE OD_SA_NON_CHK
}

SR_DPO.EX.4 { @ OD extension on SR_DPO of core device [channel length > 0.09 um], except for the SR_DPO edge space to neighboring {{PO OR SR_DPO} AND OD} following PO.S.5. (This check doesn't include the regions covered by SR_ESD, SDI, VAR, RF_PP, {RF_PP AND RF_SL1}) = 0.095 
  LV_SR_GATE_CHK = LV_SR_GATE NOT INSIDE POS_EXCLUDE_1_new
  SR_GATE_CHECK = LV_SR_GATE_CHK WITH EDGE (LENGTH SR_GATE_L > SRDPO_EX_4_L)
  SR_GATE_W_CHECK = SR_GATE_CHECK TOUCH EDGE SR_GATE_W
  GOOD_EDGE2 = ENC [SR_GATE_W_CHECK] OD == SRDPO_EX_4 EXCLUDE SHIELDED 4 OPPOSITE

  EXCLUDE_SPACE = EXT [SR_GATE_W_CHECK] SRPO_GATE_W <= PO_S_5 ABUT < 90 OPPOSITE
  ((SR_GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE2) NOT COIN EDGE EXCLUDE_SPACE) OUTSIDE EDGE OD_SA_NON_CHK
}


SR_DPO.EX.5 { @ OD extension on SR_DPO of core device [in SR_ESD and SDI] >= 0.095 
  SR_GATE_CHECK = (LV_SR_GATE INSIDE POS_EXCLUDE) NOT INSIDE LOGO
  SR_GATE_W_CHECK = SR_GATE_CHECK TOUCH EDGE SR_GATE_W
  ENC SR_GATE_W_CHECK OD < SRDPO_EX_5 ABUT < 90 REGION
}

SR_DPO.EX.6 { @ OD extension on SR_DPO of I/O device (This check doesn't include the regions covered by {HVN_65 OR HVP_65}, {HVN25_65 OR HVP25_65}, SR_ESD, SDI, and VAR.) = 0.155 
  SR_GATE_CHECK = SR_HV_GATE NOT INSIDE (OR POS_EXCLUDE_1 HVD HVD_65)
  SR_GATE_W_CHECK = SR_GATE_CHECK TOUCH EDGE SR_GATE_W
  GOOD_EDGE2 = ENC [SR_GATE_W_CHECK] OD == SRDPO_EX_6 EXCLUDE SHIELDED 4 OPPOSITE

  EXCLUDE_SPACE = EXT [SR_GATE_W_CHECK] SRPO_GATE_W <= PO_S_9 ABUT < 90 OPPOSITE
  ((SR_GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE2) NOT COIN EDGE EXCLUDE_SPACE) OUTSIDE EDGE OD_SA_NON_CHK
}

SR_DPO.EX.7 { @ OD extension on SR_DPO of I/O device [in SR_ESD and SDI] >= 0.155 
  SR_GATE_CHECK = (SR_HV_GATE INSIDE POS_EXCLUDE) NOT INSIDE LOGO
  SR_GATE_W_CHECK = SR_GATE_CHECK TOUCH EDGE SR_GATE_W
  ENC SR_GATE_W_CHECK OD < SRDPO_EX_7 ABUT < 90 REGION
}

SR_DPO.EX.8 { @ OD extension on SR_DPO of core device [in VAR] = 0.095~0.8 
  GATE_CHECK = (LV_SR_GATE INSIDE VAR) NOT INSIDE LOGO
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE SR_GATE_W
  ENC GATE_W_CHECK OD < SRDPO_EX_8A ABUT < 90 OPPOSITE REGION

  GOOD_EDGE1 = EXT [GATE_W_CHECK] SRPO_GATE <= PO_S_35B EXCLUDE SHIELDED 4 OPPOSITE  
  GOOD_EDGE2 = ENC GATE_W_CHECK OD <= SRDPO_EX_8B ABUT < 90 EXCLUDE SHIELDED 4 OPPOSITE REGION
  (GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE1) NOT COIN OUTSIDE EDGE GOOD_EDGE2
}

SR_DPO.EX.9 { @ OD extension on SR_DPO of I/O device [in VAR] = 0.155~0.8 
  GATE_CHECK = (SR_HV_GATE INSIDE VAR) NOT INSIDE LOGO
  GATE_W_CHECK = GATE_CHECK TOUCH EDGE SR_GATE_W
  ENC GATE_W_CHECK OD < SRDPO_EX_9A ABUT < 90 OPPOSITE REGION

  GOOD_EDGE1 = EXT [GATE_W_CHECK] SRPO_GATE <= PO_S_36B EXCLUDE SHIELDED 4 OPPOSITE  
  GOOD_EDGE2 = ENC GATE_W_CHECK OD <= SRDPO_EX_9B ABUT < 90 EXCLUDE SHIELDED 4 OPPOSITE REGION
  (GATE_W_CHECK NOT COIN INSIDE EDGE GOOD_EDGE1) NOT COIN OUTSIDE EDGE GOOD_EDGE2
}

SR_DPO.EX.10 { @ SR_DOD extension on SR_DPO >= 0.075 
  ENC SRDPO SRDOD < SRDPO_EX_10 ABUT < 90 SINGULAR REGION
}

SR_DPO.L.1 { @ Length of rectangular SR_DPO >= 0.26 
  A = RECTANGLE SRDPO
  A NOT WITH EDGE (LENGTH A >= SRDPO_L_1)
}

SR_DPO.A.1 { @ Area (This check doesn't include rectangle {SR_DPO INTERACT OD} with length >= 0.305 um) >= 0.0115 
  AREA (SRDPO NOT INTERACT OD) < SRDPO_A_1
  A = SRDPO INTERACT OD
  B = RECTANGLE A
  C = LENGTH B >= SRDPO_A_1_L
  D = B WITH EDGE C
  E = A NOT D
  AREA E < SRDPO_A_1
}


SR_DPO.R.1 { @ {SR_DPO NOT CPO} must be a rectangle. (45-degree edge is not allowed)   
  NOT RECTANGLE (SRDPO NOT CPO) ORTHOGONAL ONLY
}

SR_DPO.R.3 { @ SR_DPO intersecting OD must form 2 or more diffusions (This check doesn't include the regions covered by MOMDMY (155;21) region)   
  SR_GATEW = SR_GATE INSIDE EDGE OD
  X = SR_GATE NOT WITH EDGE SR_GATEW == 2
  Y = INT SR_GATEW < GRID ABUT == 90 INTERSECTING ONLY REGION
  (X OR (SR_GATE INTERACT Y)) NOT MOMDMY
}


SR_DPO.R.4 { @ {PO OR SR_DPO} GATE OUTSIDE OD2 must be vertical direction (This check doesn't include the regions covered by VAR, CSRDMY, BJTDMY, DIODMY, and LOGO.)   
  GATE_CHECK = SRPO_GATE OUTSIDE ((((((((OD2 OR CSRDMY) OR BJTDMY) OR DIODMY) OR LOGO) OR OD_HG) OR ICOVL) OR DVAR_F) OR VAR)
  GATE_CHECK_W = GATE_CHECK COIN INSIDE EDGE SR_POLY
  GATE_CHECK WITH EDGE (ANGLE GATE_CHECK_W == 0)
}

SRDPO_R_5_EXCL = ((((((OD OR OD2) OR CSRDMY) OR BJTDMY) OR DIODMY) OR LOGO) OR OD_HG) OR ((RHPO AND RPO) AND POLY)
SR_DPO.R.5 { @ Rectangle {SR_DPO NOT INTERACT OD} length OUTSIDE OD2 direction must be vertical direction and the same with the device GATE width direction of core area in a chip (This check doesn't include the regions covered by CSRDMY, BJTDMY, DIODMY, LOGO, high R resistor, and OD2.) [SR_DPO with Length/Width > 1 and Width < 0.1 um]   
  A = RECTANGLE (SRDPO NOT INTERACT SRDPO_R_5_EXCL) ASPECT > 1
  A_H = ANGLE A == 0
  A_V = ANGLE A == 90
  DFM PROPERTY A A_H A_V OVERLAP ABUT ALSO MULTI
  [ -= LENGTH(A_H) - LENGTH(A_V)] > 0
  [ -= LENGTH(A_V)] < 0.1*2
}

SR_DPO.R.7 { @ SR_DPO (17;7) can't form device. Maximum2 SR_DPOs must be placed beside OD edge [OD INTERACT PO] CO is not allowed to be placed between SR_DPO and OD edge, and 2 SR_DPOs. (This check doesn't include the regions covered by {HVN_65 OR HVP_65}, {HVN25_65 OR HVP25_65}, MOMDMY (155;21) region)   
  OD_EDGE_BLOCK = ((OD NOT SR_POLY) NOT INTERACT CO) INTERACT SRPO_GATE == 1
  OD_INTER_BLOCK = (OD NOT SR_POLY) INTERACT SR_GATE == 2    
  GOOD_SR_GATE_1 = SR_GATE INTERACT OD_EDGE_BLOCK
  GOOD_SR_GATE_2 = SR_GATE INTERACT ((OD_INTER_BLOCK INTERACT GOOD_SR_GATE_1) NOT INTERACT CO)
  (((SR_GATE INTERACT (OD INTERACT POLY)) NOT GOOD_SR_GATE_1) NOT GOOD_SR_GATE_2) NOT ((MOMDMY OR POC) OR (OD INTERACT (OR HVD HVD_65)))
}

#IFDEF FULL_CHIP
SR_DPO.R.9 { @ SR_DPO is a must. SR_DPO CAD layer (TSMC default, 17;7) must be a different layer from the PO CAD layer.
  MERGE (CHIP NOT INTERACT SRDPO)
}
#ENDIF

SRODPO_DEN_EXC_1 = ((VAR OR TCDDMY) OR ICOVL) OR CSRDMY
SRODPO_DEN_EXC_2 = SRM OR OD2
OD_PO = OD OR POLY
CHIP_ODPO_RING = ((SIZE (OD_PO INTERACT (GATE NOT INTERACT SRODPO_DEN_EXC_1)) BY SRDOD_DN_1_S1) NOT (SIZE OD_PO BY SRDOD_DN_1_S2)) NOT SRODPO_DEN_EXC_2





#IFDEF FULL_CHIP
SR_DOD.DN.1 { @ Minimum SR_DOD density inside {{{{{{OD OR PO} INTERACT GATE} SIZING 2.5 um} NOT {{OD OR PO} SIZING 0.4 um}} NOT SRM} NOT OD2} (The GATE doesn't include the regions cover by layer VAR, TCDDMY, ICOVL, and CSRDMY) >= 10% 
  SRDODx = SRDOD AND CHIP_ODPO_RING
  A = DENSITY SRDODx CHIP_ODPO_RING < SRDOD_DN_1 INSIDE OF LAYER CHIPx PRINT SR_DOD.DN.1.density RDB SR_DOD.DN.1.RDB.density
      [ AREA(SRDODx)/AREA(CHIP_ODPO_RING) ]
  A AND CHIP_ODPO_RING
}


SR_DPO.DN.1 { @ Minimum SR_DPO density inside {{{{{{OD OR PO} INTERACT GATE} SIZING 2.5 um} NOT {{OD OR PO} SIZING 0.4 um}} NOT SRM} NOT OD2} (The GATE doesn't include the regions cover by layer VAR, TCDDMY, ICOVL, and CSRDMY) >= 6% 
  SRDPOx = SRDPO AND CHIP_ODPO_RING
  A = DENSITY SRDPOx CHIP_ODPO_RING < SRDPO_DN_1 INSIDE OF LAYER CHIPx PRINT SR_DPO.DN.1.density RDB SR_DPO.DN.1.RDB.density
      [ AREA(SRDPOx)/AREA(CHIP_ODPO_RING) ]
  A AND CHIP_ODPO_RING
}
#ENDIF



//DUMMY POLY RULE
//================
    
DPO.W.1 { @ Width >= ^DPO_W_1 um
  INT DPO < DPO_W_1 ABUT < 90 SINGULAR REGION
}
DPO.W.2 { @ Maximum width <= 2 
  DPO WITH WIDTH > DPO_W_2
}
DPO.S.1 { @ Space >= ^DPO_S_1 um
  EXT DPO < DPO_S_1 ABUT < 90 SINGULAR REGION
}
DPO.S.2 { @ Space to OD (overlap is not allowed) >= 0.2 
  EXT ODi DPO < DPO_S_2 ABUT < 90 SINGULAR REGION INSIDE ALSO
}
DPO.S.3 { @ Space to PO (overlap is not allowed) >= 0.5 
  EXT POi DPO < DPO_S_3 ABUT < 90 SINGULAR REGION INSIDE ALSO
}
DPO.S.6 { @ Space to CPO (overlap is not allowed) >= 0.3 
  EXT DPO CPO < DPO_S_6 ABUT < 90 SINGULAR REGION INSIDE ALSO
}
DPO.S.7 { @ Space to RPO >= 0.3 
  (EXT DPO RPO < DPO_S_7 ABUT < 90 SINGULAR REGION) NOT INSIDE SEALRING_ALL
}
DPO.EX.1 { @ DPO extension on DOD (ENDCAP) >= 0.08 
  ENC DOD DPO < DPO_EX_1 ABUT < 90 SINGULAR REGION
}

DPO.EX.2 { @ DOD extension on DPO >= 0.075 
  ENC DPO DOD < DPO_EX_2 ABUT < 90 SINGULAR REGION
}
#IFDEF FULL_CHIP
DPO.R.1 { @ DPO is must. DPO must be an individual CAD layer (datatype 1 as default, like 17;1)
  MERGE (CHIP NOT INTERACT DPO)
}
#ENDIF

DPO.EN.2 { @ Enclosure by RPO >= 0.3 
  ENC DPO RPO < DPO_EN_2 ABUT < 90 SINGULAR REGION
  DPO CUT RPO
}

// DPO.R.2 is checked by CSR.R.1:DPO

DPO.R.3 { @ Only square (or rectangular) and solid shapes are allowed. A 45-degree shape is not allowed   
  NOT RECTANGLE DPO ORTHOGONAL ONLY
}




// SR_ESD CHECK
//--------------

SRESD_GATE = GATE NOT OUTSIDE SRESD
SRESD_GATE_W = SRESD_GATE TOUCH EDGE GATE_W
SRESD_GATE_L = SRESD_GATE NOT TOUCH EDGE GATE_W

SR_ESD.W.1 { @ Width >= 0.21 
  INT SRESD < SRESD_W_1 ABUT < 90 SINGULAR REGION
}
SR_ESD.W.2 { @  Unit finger width of {core NMOS INTERACT SR_ESD}
  GATE_CHK = (GATE_NP NOT OD2) INTERACT SRESD
	GATE_W_CHK = GATE_W COIN EDGE GATE_CHK
  PATH LENGTH GATE_W_CHK > SRESD_W_2
}
SR_ESD.S.1 { @ Space >= 0.21 
  EXT SRESD < SRESD_S_1 ABUT < 90 SINGULAR REGION
}
SR_ESD.S.2 { @ The {{GATE SIZING 0.06 um} AND PO} space range to neighboring poly {PO OR SR_DPO} of core device in SR_ESD regions = 0.12~0.64 
  GATE_CHECK = SRESD_GATE NOT INSIDE OD2
  PO_CHECK = (SIZE GATE_CHECK BY SRESD_S_2_S) AND POLY
  GOOD_EDGE1 = EXT [PO_CHECK] SR_POLY >= SRESD_S_2A <= SRESD_S_2B EXCLUDE SHIELDED 4 OPPOSITE
  (PO_CHECK TOUCH EDGE GATE_W ) NOT COIN INSIDE EDGE GOOD_EDGE1
}
SR_ESD.S.3 { @ The {{GATE SIZING 0.06 um} AND PO} space range to neighboring poly {PO OR SR_DPO} [INSIDE OD2] in SR_ESD regions = 0.18~3.5 
  GATE_CHECK = SRESD_GATE INSIDE OD2
  PO_CHECK = (SIZE GATE_CHECK BY SRESD_S_3_S) AND POLY
  
  GOOD_EDGE_B = EXT [PO_CHECK] SR_POLY <= SRESD_S_3B OPPOSITE
  (PO_CHECK TOUCH EDGE GATE_W) NOT COIN INSIDE EDGE GOOD_EDGE_B

  GOOD_EDGE_A = EXT [PO_CHECK] SR_POLY < SRESD_S_3A EXCLUDE SHIELDED 4 OPPOSITE
  (PO_CHECK TOUCH EDGE GATE_W) COIN INSIDE EDGE GOOD_EDGE_A
}
SR_ESD.EX.1 { @ Extension on ACTIVE >= 0.065 
  ENC DACT SRESD < SRESD_EX_1 ABUT < 90 SINGULAR REGION
}
SR_ESD.L.1 { @ Maximum ACTIVE length of core device in SR_ESD regions <= 60 
  DACT_G = ((DACT NOT OD2i) ENCLOSE GATE) NOT OUTSIDE SRESD // cut SR_ESD is checked by OD.L.4
  // rectangle active
  DACT_G_R = RECTANGLE DACT_G
  ENCLOSE RECTANGLE DACT_G_R GRID SRESD_L_1+GRID ORTHOGONAL ONLY
  // not rectangle active
  
  DACT_G_NR = AREA (DACT_G NOT DACT_G_R) > SRESD_L_1 * SRESD_W_1 // suspected active  
  DACT_G_NR_EX = EXTENTS DACT_G_NR
  DACT_G_NR_EX_ERR = ENCLOSE RECTANGLE DACT_G_NR_EX GRID SRESD_L_1+GRID ORTHOGONAL ONLY
  DACT_G_NR_EX_ERR AND DACT_G_NR
}
SR_ESD.R.1 { @ SR_ESD must be fully covered by SDI
  SRESD NOT SDI
}
SR_ESD.R.2 { @ {core PMOS INTERACT SR_ESD} is not allowed
	PACT_CHK = PACT INTERACT GATE_PP
  ((OR GATE_PP PACT_CHK) NOT OD2) INTERACT SRESD
}
SR_ESD.R.3 { @ {core PMOS INTERACT SDI} is not allowed
  PACT_CHK = PACT INTERACT GATE_PP
  ((OR GATE_PP PACT_CHK) NOT OD2) INTERACT SDI
}




//VTH_N CHECKS
//============

VTH_N.W.1 { @ Width >= ^VTHN_W_1  
  A = INT VTHN < VTHN_W_1 ABUT < 90 REGION PROJ==0
  B = EXT [VTHN] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = INT B >= VTHN_R_3_A < VTHN_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = INT B >= VTHN_R_3_B < VTHN_W_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = INT VTHN < VTHN_W_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
VTH_N.S.1 { @ Space >= ^VTHN_S_1 
  A = EXT VTHN < VTHN_S_1 ABUT < 90 REGION PROJ==0
  B = INT [VTHN] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = EXT B >= VTHN_R_3_A < VTHN_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = EXT B >= VTHN_R_3_B < VTHN_S_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = EXT VTHN < VTHN_S_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
VTH_N.S.2__VTH_N.S.3 { @ Space to gate in PO endcap direction >= ^VTHN_S_2 & in S/D direction >= ^VTHN_S_3, VTHN cut {ACTIVE OR GATE} is not allowed.
  A = GATE NOT INTERACT VTHN
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (VTHN_S_3 - VTHN_S_2)) OR A
  C = SIZE B BY VTHN_S_2
  (VTHN AND C) NOT INSIDE SRAM_WAIVE_N28
  (DACT CUT VTHN) NOT INSIDE SRAM_WAIVE_N28
  (GATE CUT VTHN) NOT INSIDE SRAM_WAIVE_N28
}
VTH_N.S.4 { @ Space to unsilicided OD or high R resistor >= 0.15 
  EXT VTHN AYRE < VTHN_S_4 ABUT < 90 SINGULAR REGION
  AND VTHN AYRE    
}  
VTH_N.S.5 { @ Space [parallel run length > 0.33 um, VTH_N space without INTERACT {{OD OR SR_DOD} OR DOD}] >= 0.25 
  X = EXT VTHN < VTHN_S_5 OPPOSITE REGION
  Y = X NOT INTERACT ALL_OD
  ENCLOSE RECTANGLE Y GRID VTHN_S_5_L+GRID ORTHOGONAL ONLY
}
VTH_N.EN.1__VTH_N.EN.2 { @ Enclosure of gate in S/D direction >= ^VTHN_EN_1 & in PO endcap direction >= ^VTHN_EN_2 
  A = GATE INTERACT VTHN
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (VTHN_EN_1 - VTHN_EN_2)) OR A
  C = SIZE B BY VTHN_EN_2
  C NOT VTHN
}
VTH_N.L.1 { @ 45-degree edge length >= ^VTHN_L_1 
  VTHN_EDGE_45 = VTHN ANGLE == 45
  LENGTH VTHN_EDGE_45 < VTHN_L_1  
}
VTH_N.A.1 { @ Area >= ^VTHN_A_1
  AREA (VTHN NOT INSIDE DMY_SCH) < VTHN_A_1
}
VTH_N.A.1.1 { @ Area >= ^VTHN_A_1_1
  AREA (VTHN INSIDE DMY_SCH) < VTHN_A_1_1
}
VTH_N.A.2 { @ Enclosed area >= ^VTHN_A_2
  A = HOLES VTHN INNER
  B = A NOT VTHN
  AREA (B NOT INSIDE DMY_SCH) < VTHN_A_2
}
VTH_N.A.2.1 { @ Enclosed area >= ^VTHN_A_2_1
  A = HOLES VTHN INNER
  B = A NOT VTHN
  AREA (B INSIDE DMY_SCH) < VTHN_A_2_1
}

