#ENDIF
#IFDEF ESD_LUP_RULE_CHECK
#DEFINE VOLTAGE_ANNOTATE
#ENDIF






LAYER RESOLUTION COii 1	// inside SRAM periphrial regions only
LAYER RESOLUTION POi 1	// inside SRAM periphrial regions only

// DRAWN LAYER DEFINITIONS
//------------------------

LAYER DNWi       10000     // deep-nwell
LAYER MAP 1 DATATYPE 0 10000
LAYER NWii       3000    // nwell technology
LAYER MAP 3 DATATYPE 0 3000
NWi = COPY NWii
LAYER NWiOTHERS  3001     
LAYER MAP 3 DATATYPE >=1   <=129 3001
LAYER MAP 3 DATATYPE >=150 <=169 3001
LAYER MAP 3 DATATYPE >=180 <=255 3001
LAYER OD12i      1401    // define 1.2V thin gate oxides
LAYER MAP 14 DATATYPE 1 1401
LAYER OD15i      2100      // define 1.5V thick gate oxides
LAYER MAP 21 DATATYPE 0 2100
LAYER OD1518     2130      // define 1.5V thick gate oxides overdrive 1.8v
LAYER MAP 21 DATATYPE 3 2130
LAYER OD18i      1600      // define 1.8V thick gate oxides
LAYER MAP 16 DATATYPE 0 1600
LAYER OD1812     11601       // define 1.8V thick gate oxides underdrive 1.2v
LAYER MAP 16 DATATYPE 1 11601
LAYER OD1815     11604      // define 1.8V thick gate oxides underdrive 1.5v
LAYER MAP 16 DATATYPE 4 11604
LAYER OD25i      1800      // define 2.5V thick gate oxides
LAYER MAP 18 DATATYPE 0 1800
LAYER OD2533     11803     // define 2.5V thick gate oxides overdrive 3.3v
LAYER MAP 18 DATATYPE 3 11803
LAYER OD2518     11804     // define 2.5V thick gate oxides underdrive 1.8v
LAYER MAP 18 DATATYPE 4 11804
LAYER OD2528     11810    // define 2.5V thick gate oxides overdrive 2.8v
LAYER MAP 18 DATATYPE 10 11810
LAYER OD25_33P_LL     1811     // define 
LAYER MAP 18 DATATYPE 11 1811
LAYER OD33i      1500    // define 3.3V thick gate oxides
LAYER MAP 15 DATATYPE 0 1500
LAYER OD_HG      16111   // define Horizontal gate devices
LAYER MAP 161 DATATYPE 11 16111
LAYER HVD_N  9101      // define HV NMOS drain side
LAYER MAP 91 DATATYPE 1 9101
LAYER HVD_P  9102      // define HV PMOS drain side
LAYER MAP 91 DATATYPE 2 9102
LAYER HVN_65  9131      // define 6.5V HV NMOS drain side
LAYER MAP 91 DATATYPE 31 9131
LAYER HVP_65  9132      // define 6.5V HV PMOS drain side
LAYER MAP 91 DATATYPE 32 9132
LAYER HVD65_55  9133      // define 6.5V ud 5.5V HV MOS 
LAYER MAP 91 DATATYPE 33 9133
LAYER HVN25_65  9134      // define IO25 6.5V HV NMOS drain side
LAYER MAP 91 DATATYPE 34 9134
LAYER HVP25_65  9135      // define IO25 6.5V HV PMOS drain side
LAYER MAP 91 DATATYPE 35 9135
LAYER HVD_33  9136      // define IO18 3.3V HV NMOS drain side
LAYER MAP 91 DATATYPE 36 9136
LAYER EHVT_N  9121      // EHVT_N implant
LAYER MAP 91 DATATYPE 21 9121
LAYER EHVT_P  9122      // EHVT_P implant
LAYER MAP 91 DATATYPE 22 9122
LAYER TGO_EHVT 25599
LAYER MAP 255 DATATYPE 99 25599
LAYER PMET	2056
LAYER MAP 205 DATATYPE 6 2056
LAYER GB1_5	2547     // Use for GATE CD size-up 1.5nm/side
LAYER MAP 254 DATATYPE 7 2547
LAYER GB_D2	25402     // Use for GATE CD size-down 2nm/side
LAYER MAP 254 DATATYPE 102 25402
LAYER SPS1	25421     // Use for GATE CD size-down 2nm/side for Lg=40nm
LAYER MAP 254 DATATYPE 201 25421
LAYER SPS2	25422     // Use for GATE CD size-down 2nm/side for Lg=35nm
LAYER MAP 254 DATATYPE 202 25422
LAYER DMY_SCH     25552     // DRC dummy layer for TSMC N28 140 pitch standard cell recognition
LAYER MAP 255 DATATYPE 52 25552
LAYER CHVT_N      7902      // CRAM HV NMOS
LAYER MAP 79 DATATYPE 2 7902
LAYER CRAM      25507       // CRAM waive rule layer
LAYER MAP 255 DATATYPE 7 25507
LAYER PPi        2500      // P+ S/D implant
LAYER MAP 25 DATATYPE 0 2500
LAYER NPi        2600      // N+ S/D implant
LAYER MAP 26 DATATYPE 0 2600
LAYER COii       3010      // Define connect for M1 to S/D and Gate
LAYER MAP 30 DATATYPE 0 3010
LAYER COPUSH     3011    // rule pushed contact in SRAM cell
LAYER MAP 30 DATATYPE 11 3011  
LAYER COiSRAM 3012
LAYER MAP 30 DATATYPE >=11 <=22 3012
LAYER CO_VIRT 3030
LAYER MAP 30 DATATYPE 30 3030
LAYER COiOTHERS 3013
LAYER MAP 30 DATATYPE >=1   <=10  3013
LAYER MAP 30 DATATYPE >=23  <=29  3013
LAYER MAP 30 DATATYPE >=31  <=129 3013
LAYER MAP 30 DATATYPE >=150 <=169 3013
LAYER MAP 30 DATATYPE >=180 <=255 3013
LAYER CBi        7600    // Passivation opening for Bond Pad
LAYER MAP 76 DATATYPE 0 7600 
LAYER CB2Fi      8600    // Passivation-2 opening for Flip-Chip
LAYER MAP 86 DATATYPE 0  8600
LAYER CB2Wi      8620    // Passivation-2 opening for Wire-Bond
LAYER MAP 86 DATATYPE 20 8620
LAYER RPOi       2900    // Silicided Block Layer
LAYER MAP 29 DATATYPE 0 2900 
LAYER UDM        2901    // SiGe Block Layer
LAYER MAP 29 DATATYPE 1 2901 
LAYER PM0i        5100    // Cu via between AP and Cu_PPI
LAYER MAP 5 DATATYPE 10 5100 
LAYER RPO_DEVICE 2902    // Special RPO DEVICE
LAYER MAP 29 DATATYPE 2 2902 
LAYER TN2        2083    // Speed push transistor implant
LAYER MAP 208 DATATYPE 3 2083 
LAYER TN3        2084    // Speed push transistor gate oxide
LAYER MAP 208 DATATYPE 4 2084 
LAYER TN_WCL    2085    // A waiver layer for channel length in TN2/TN3
LAYER MAP 208 DATATYPE 5  2085
LAYER eVTLN      1512   // extreme Low Vt NMOS Implant
LAYER MAP 151 DATATYPE 2 1512
LAYER eVTLP      1522   // extreme Low Vt PMOS Implant
LAYER MAP 152 DATATYPE 2 1522
LAYER NTNi       11000   // Native NMOS blocked implant
LAYER MAP 11 DATATYPE 0  11000
LAYER NCapNTNi   11020   // connected NMOS capacitors within same NT_N region
LAYER MAP 11 DATATYPE 20 11020
LAYER VTZ_N	11200	// NT_N region
LAYER MAP 11 DATATYPE 200 11200
LAYER POFUSE     25600     // Poly fuse implant layer    
LAYER MAP 156 DATATYPE 0 25600
LAYER FUSELINK 25601       // Dummy layer to cover poly fuse link region.   
LAYER MAP 156 DATATYPE 1 25601
LAYER POFUSE2 1564      // POFUSE_CO layer
LAYER MAP 156 DATATYPE 4 1564
