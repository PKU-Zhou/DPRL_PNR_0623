  INT X1 > VIA6_W_2 < VIA6_W_2*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > VIA6_W_2+GRID < VIA6_W_2*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  (WITH WIDTH SR_VIA6_BAR >= VIA6_W_2*2) ENCLOSE RECTANGLE 2 GRID
  INT X1 < VIA6_W_2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < VIA6_W_2-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'VIAx.W.2' is checked by VIA6.W.2__VIA6.W.4
//'VIAx.W.4' is checked by VIA6.W.2__VIA6.W.4
// VIA6.W.2 and VIA6.W.4 are checked by VIA6.W.2__VIA6.W.4
VIA6.W.3__VIA6.W.5 { @ Width of VIA6(VIAx) hole of sealring/SLDB = ^VIA6_W_3/^VIA6_W_5
  X1 = ANGLE SR_VIA6_HOLE != 45
  X2 = ANGLE SR_VIA6_HOLE == 45
  INT X1 > VIA6_W_3 < VIA6_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > VIA6_W_3+GRID < VIA6_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  WITH WIDTH SR_VIA6_HOLE >= VIA6_W_3*2
  INT X1 < VIA6_W_3 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < VIA6_W_3-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'VIAx.W.3' is checked by VIA6.W.3__VIA6.W.5
//'VIAx.W.5' is checked by VIA6.W.3__VIA6.W.5
// VIA6.W.3 and VIA6.W.5 are checked by VIA6.W.3__VIA6.W.5

VIA6.EN.25 { @ Enclosure of VIAx bar by Mx in seal-ring >= 0.21 
  ENC SR_VIA6_BAR_SR M6 < VIA6_EN_25 ABUT < 90 SINGULAR REGION
}
VIA6.EN.26 { @ Enclosure of VIAx hole by Mx in seal-ring >= 0.23 
  ENC SR_VIA6_HOLE_SR M6 < VIA6_EN_26 ABUT < 90 SINGULAR REGION
}
VIA6.EN.27 { @ Enclosure of VIAx hole by Mx in SLDB >= 0.03 
  ENC SR_VIA6_HOLE_SLDB M6 < VIA6_EN_27 ABUT < 90 SINGULAR REGION
}


VIA6.S.24 { @ Space of VIAx hole in seal-ring >= 0.375 
  EXT SR_VIA6_HOLE_SR < VIA6_S_24 ABUT < 90 SINGULAR REGION
}

VIA6.S.25 { @ Space of VIAx hole to VIAx bar in seal-ring >= 0.35 
  EXT SR_VIA6_HOLE_SR SR_VIA6_BAR_SR < VIA6_S_25 ABUT < 90 SINGULAR REGION
}

VIA6.S.26 { @ Opposite space of VIAx hole in SLDB >= 0.2 
  EXT SR_VIA6_HOLE_SLDB < VIA6_S_26 ABUT < 90 OPPOSITE REGION
}

VIA6.S.27 { @ Space of VIAx hole in SLDB >= 0.1 
  EXT SR_VIA6_HOLE_SLDB < VIA6_S_27 ABUT < 90 SINGULAR REGION
}

M7.W.7 { @ Width of Mx metal line in outer seal-ring. (DRC tolerance at 45-degree turning: +-0.02 um) = 2 
  X1 = ANGLE SR_M7_OUTER != 45
  X2 = ANGLE SR_M7_OUTER == 45
  WITH WIDTH SR_M7_OUTER >= M7_W_7*2
  INT X1 > M7_W_7 < M7_W_7*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M7_W_7+4*GRID < M7_W_7*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M7_W_7 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M7_W_7-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
M7.W.8 { @ Width of Mx metal line in inner seal-ring. (DRC tolerance at 45-degree turning: +-0.02 um) = 6 
  X1 = ANGLE SR_M7_INNER != 45
  X2 = ANGLE SR_M7_INNER == 45
  WITH WIDTH SR_M7_INNER >= M7_W_8*2
  INT X1 > M7_W_8 < M7_W_8*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M7_W_8+4*GRID < M7_W_8*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M7_W_8 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M7_W_8-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
M7.W.6 { @ Width of Mx metal line in SLDB. (DRC tolerance at 45-degree turning: +-0.02 um) = 0.5 
  X1 = ANGLE SLDB_M7_LINE != 45
  X2 = ANGLE SLDB_M7_LINE == 45
  WITH WIDTH SLDB_M7_LINE >= M7_W_6*2
  INT X1 > M7_W_6 < M7_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M7_W_6+4*GRID < M7_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M7_W_6 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M7_W_6-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}

M7.S.35 { @ Minimum space of Mx between Mx metal bars in the direction parallel/ vertical to prime chip edge >= 0.5 
  EXT SLDB_M7_LINE < M7_S_35 ABUT < 90 OPPOSITE REGION
}

M7.S.36 { @ Space of Mx between Mx metal bars in the direction parallel to prime chip edge between the same metal bars >= 2.5 
  INT SLDB_M7_DOT_EDGE < M7_S_36 ABUT < 90 OPPOSITE REGION
}



SR_VIA7_BAR_SLDB = SR_VIA7_BAR AND SEALRING_DB	
SR_VIA7_BAR_SR = SR_VIA7_BAR NOT SEALRING_DB	
SR_VIA7_HOLE_SLDB = SR_VIA7_HOLE AND SEALRING_DB
SR_VIA7_HOLE_SR = SR_VIA7_HOLE NOT SEALRING_DB

VIA7.W.2__VIA7.W.4 { @ Width of VIA7(VIAz) bar of sealring/SLDB = ^VIA7_W_2/^VIA7_W_4
  X1 = ANGLE SR_VIA7_BAR != 45
  X2 = ANGLE SR_VIA7_BAR == 45
  INT X1 > VIA7_W_2 < VIA7_W_2*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > VIA7_W_2+GRID < VIA7_W_2*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  (WITH WIDTH SR_VIA7_BAR >= VIA7_W_2*2) ENCLOSE RECTANGLE 2 GRID
  INT X1 < VIA7_W_2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < VIA7_W_2-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'VIAz.W.2' is checked by VIA7.W.2__VIA7.W.4
//'VIAz.W.4' is checked by VIA7.W.2__VIA7.W.4
// VIA7.W.2 and VIA7.W.4 are checked by VIA7.W.2__VIA7.W.4
VIA7.W.3__VIA7.W.5 { @ Width of VIA7(VIAz) hole of sealring/SLDB = ^VIA7_W_3/^VIA7_W_5
  X1 = ANGLE SR_VIA7_HOLE != 45
  X2 = ANGLE SR_VIA7_HOLE == 45
  INT X1 > VIA7_W_3 < VIA7_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > VIA7_W_3+GRID < VIA7_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  WITH WIDTH SR_VIA7_HOLE >= VIA7_W_3*2
  INT X1 < VIA7_W_3 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < VIA7_W_3-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'VIAz.W.3' is checked by VIA7.W.3__VIA7.W.5
//'VIAz.W.5' is checked by VIA7.W.3__VIA7.W.5
// VIA7.W.3 and VIA7.W.5 are checked by VIA7.W.3__VIA7.W.5

//'VIAz.EN.5' is checked by VIA7.EN.5
VIA7.EN.5 { @ Enclosure of VIAz bar by Mz in seal-ring, except Mu design >= 0.21 
  ENC SR_VIA7_BAR_SR M7 < VIA7_EN_5 ABUT < 90 SINGULAR REGION
}
//'VIAz.EN.6' is checked by VIA7.EN.6
VIA7.EN.6 { @ Enclosure of VIAz hole by Mz in seal-ring >= 0.21 
  ENC SR_VIA7_HOLE_SR M7 < VIA7_EN_6 ABUT < 90 SINGULAR REGION
}
//'VIAz.S.4' is checked by VIA7.S.4
VIA7.S.4 { @ Space of VIAz hole in seal-ring >= 0.54 
  EXT SR_VIA7_HOLE_SR < VIA7_S_4 ABUT < 90 SINGULAR REGION
}
//'VIAz.S.5' is checked by VIA7.S.5
VIA7.S.5 { @ Space of VIAz hole to VIAz bar in seal-ring >= 0.34 
  EXT SR_VIA7_HOLE_SR SR_VIA7_BAR_SR < VIA7_S_5 ABUT < 90 SINGULAR REGION
}
//'VIAz.S.6' is checked by VIA7.S.6
VIA7.S.6 { @ Space of VIAz hole in SLDB >= 0.54 
  EXT SR_VIA7_HOLE_SLDB < VIA7_S_6 ABUT < 90 SINGULAR REGION
}
//'VIAz.S.7' is checked by VIA7.S.7
VIA7.S.7 { @ Space of VIAz hole to VIAz bar in SLDB >= 0.54 
  EXT SR_VIA7_HOLE_SLDB SR_VIA7_BAR_SLDB < VIA7_S_7 ABUT < 90 SINGULAR REGION
}

//'Mz.W.4' is checked by M8.W.4
M8.W.4 { @ Width of Mz metal line in outer seal-ring. (DRC tolerance at 45-degree turning: +-0.02 um) = 2 
  X1 = ANGLE SR_M8_OUTER != 45
  X2 = ANGLE SR_M8_OUTER == 45
  WITH WIDTH SR_M8_OUTER >= M8_W_4*2
  INT X1 > M8_W_4 < M8_W_4*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M8_W_4+4*GRID < M8_W_4*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M8_W_4 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M8_W_4-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'Mz.W.5' is checked by M8.W.5
M8.W.5 { @ Width of Mz metal line in inner seal-ring. (DRC tolerance at 45-degree turning: +-0.02 um) = 6 
  X1 = ANGLE SR_M8_INNER != 45
  X2 = ANGLE SR_M8_INNER == 45
  WITH WIDTH SR_M8_INNER >= M8_W_5*2
  INT X1 > M8_W_5 < M8_W_5*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M8_W_5+4*GRID < M8_W_5*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M8_W_5 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M8_W_5-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'Mz.W.6' is checked by M8.W.6
M8.W.6 { @ Width of Mz metal line in SLDB. (DRC tolerance at 45-degree turning: +-0.02 um) = 3.5 
  X1 = ANGLE SLDB_M8_LINE != 45
  X2 = ANGLE SLDB_M8_LINE == 45
  WITH WIDTH SLDB_M8_LINE >= M8_W_6*2
  INT X1 > M8_W_6 < M8_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M8_W_6+4*GRID < M8_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M8_W_6 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M8_W_6-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'Mz.S.6' is checked by M8.S.6
M8.S.6 { @ Minimum space between Mz metal bars >= 0.5 
  EXT SLDB_M8_LINE < M8_S_6 ABUT < 90 OPPOSITE REGION
}
SR_VIA8_BAR_SLDB = SR_VIA8_BAR AND SEALRING_DB	
SR_VIA8_BAR_SR = SR_VIA8_BAR NOT SEALRING_DB	
SR_VIA8_HOLE_SLDB = SR_VIA8_HOLE AND SEALRING_DB
SR_VIA8_HOLE_SR = SR_VIA8_HOLE NOT SEALRING_DB

VIA8.W.2__VIA8.W.4 { @ Width of VIA8(VIAu) bar of sealring/SLDB = ^VIA8_W_2/^VIA8_W_4
  X1 = ANGLE SR_VIA8_BAR != 45
  X2 = ANGLE SR_VIA8_BAR == 45
  INT X1 > VIA8_W_2 < VIA8_W_2*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > VIA8_W_2+GRID < VIA8_W_2*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  (WITH WIDTH SR_VIA8_BAR >= VIA8_W_2*2) ENCLOSE RECTANGLE 2 GRID
  INT X1 < VIA8_W_2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < VIA8_W_2-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'VIAu.W.2' is checked by VIA8.W.2__VIA8.W.4
//'VIAu.W.4' is checked by VIA8.W.2__VIA8.W.4
// VIA8.W.2 and VIA8.W.4 are checked by VIA8.W.2__VIA8.W.4
VIA8.W.3__VIA8.W.5 { @ Width of VIA8(VIAu) hole of sealring/SLDB = ^VIA8_W_3/^VIA8_W_5
  X1 = ANGLE SR_VIA8_HOLE != 45
  X2 = ANGLE SR_VIA8_HOLE == 45
  INT X1 > VIA8_W_3 < VIA8_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > VIA8_W_3+GRID < VIA8_W_3*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  WITH WIDTH SR_VIA8_HOLE >= VIA8_W_3*2
  INT X1 < VIA8_W_3 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < VIA8_W_3-GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'VIAu.W.3' is checked by VIA8.W.3__VIA8.W.5
//'VIAu.W.5' is checked by VIA8.W.3__VIA8.W.5
// VIA8.W.3 and VIA8.W.5 are checked by VIA8.W.3__VIA8.W.5

//'VIAu.EN.5' is checked by VIA8.EN.5
VIA8.EN.5 { @ Enclosure of VIAu bar by Mu in seal-ring >= 0.3 
  ENC SR_VIA8_BAR_SR M8 < VIA8_EN_5 ABUT < 90 SINGULAR REGION
}
//'VIAu.EN.6' is checked by VIA8.EN.6
VIA8.EN.6 { @ Enclosure of VIAu hole by Mu in seal-ring >= 0.23 
  ENC SR_VIA8_HOLE_SR M8 < VIA8_EN_6 ABUT < 90 SINGULAR REGION
}
//'VIAu.EN.7' is checked by VIA8.EN.7
VIA8.EN.7 { @ Enclosure of VIAu hole by Mu in SLDB >= 0.3 
  ENC SR_VIA8_HOLE_SLDB M9 < VIA8_EN_7 ABUT < 90 SINGULAR REGION
}
//'VIAu.S.4' is checked by VIA8.S.4
VIA8.S.4 { @ Space of VIAu hole in seal-ring >= 0.6 
  EXT SR_VIA8_HOLE_SR < VIA8_S_4 ABUT < 90 SINGULAR REGION
}
//'VIAu.S.5' is checked by VIA8.S.5
VIA8.S.5 { @ Space of VIAu hole to VIAu bar in seal-ring >= 0.4 
  EXT SR_VIA8_HOLE_SR SR_VIA8_BAR_SR < VIA8_S_5 ABUT < 90 SINGULAR REGION
}
//'VIAu.S.6' is checked by VIA8.S.6
VIA8.S.6 { @ Space of VIAu hole in SLDB >= 0.54 
  EXT SR_VIA8_HOLE_SLDB < VIA8_S_6 ABUT < 90 SINGULAR REGION
}
//'VIAu.S.7' is checked by VIA8.S.7
VIA8.S.7 { @ Space of VIAu hole to VIAu bar in SLDB >= 0.54 
  EXT SR_VIA8_HOLE_SLDB SR_VIA8_BAR_SLDB < VIA8_S_7 ABUT < 90 SINGULAR REGION
}
//'Mu.W.4' is checked by M9.W.4
M9.W.4 { @ Width of Mu metal line in outer seal-ring. (DRC tolerance at 45-degree turning: +-0.02 um) = 2 
  X1 = ANGLE SR_M9_OUTER != 45
  X2 = ANGLE SR_M9_OUTER == 45
  WITH WIDTH SR_M9_OUTER >= M9_W_4*2
  INT X1 > M9_W_4 < M9_W_4*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M9_W_4+4*GRID < M9_W_4*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M9_W_4 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M9_W_4-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'Mu.W.5' is checked by M9.W.5
M9.W.5 { @ Width of Mu metal line in inner seal-ring. (DRC tolerance at 45-degree turning: +-0.02 um) = 6 
  X1 = ANGLE SR_M9_INNER != 45
  X2 = ANGLE SR_M9_INNER == 45
  WITH WIDTH SR_M9_INNER >= M9_W_5*2
  INT X1 > M9_W_5 < M9_W_5*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M9_W_5+4*GRID < M9_W_5*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M9_W_5 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M9_W_5-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'Mu.W.6' is checked by M9.W.6
M9.W.6 { @ Width of Mu metal line in SLDB (DRC tolerance at 45-degree turning: +-0.02 um) = 6 
  X1 = ANGLE SLDB_M9_LINE != 45
  X2 = ANGLE SLDB_M9_LINE == 45
  WITH WIDTH SLDB_M9_LINE >= M9_W_6*2
  INT X1 > M9_W_6 < M9_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 > M9_W_6+4*GRID < M9_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X1 < M9_W_6 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < M9_W_6-4*GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
//'Mu.S.6' is checked by M9.S.6
M9.S.6 { @ Minimum space between Mu metal bars >= 0.5 
  EXT SLDB_M9_LINE < M9_S_6 ABUT < 90 OPPOSITE REGION
}

//'VIAy.W.2' is not necessary to check
//'VIAy.W.3' is not necessary to check
//'VIAy.W.4' is not necessary to check
