  EXT POST_DRIVER_PINJ_NW_25V_NG BESIDE_POST_DRIVER_NMOS_PW < LUP_5_3_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_PINJ_NW_25V_NG BESIDE_POST_DRIVER_NMOS_RW < LUP_5_3_2 ABUT < 90 SINGULAR CONNECTED
  EXT POST_DRIVER_PINJ_NWi_25V_NG BESIDE_POST_DRIVER_NMOS_RWi < LUP_5_3_2 ABUT < 90 SINGULAR NOT CONNECTED
  EXT POST_DRIVER_NINJ_PW_NG BESIDE_POST_DRIVER_PMOS_NW_25V < LUP_5_3_2 ABUT < 90 SINGULAR
  EXT POST_DRIVER_NINJ_RW_NG BESIDE_POST_DRIVER_PMOS_NW_25V < LUP_5_3_2 ABUT < 90 SINGULAR CONNECTED
