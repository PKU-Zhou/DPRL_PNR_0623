  M6_TypeBRS3_CACB_S3_11_1 = EXPAND EDGE M6_TypeBRS3_CACB_S3_9 OUTSIDE BY TypeBRS3_S3
  M6_TypeBRS3_CACB_S3_12_1 = EXPAND EDGE M6_TypeBRS3_CACB_S3_10 OUTSIDE BY TypeBRS3_S3-GRID
  M6_TypeBRS3_CACB_S3_11 = M6_TypeBRS3_CACB_S3_11_1 WITH EDGE ((M6_TypeBRS3_CACB_S3_11_1 AND M6) COIN EDGE M6_TypeBRS3_CACB_S3_11_1) >= 4
  M6_TypeBRS3_CACB_S3_12  = M6_TypeBRS3_CACB_S3_12_1 WITH EDGE ((M6_TypeBRS3_CACB_S3_12_1 AND M6) COIN EDGE M6_TypeBRS3_CACB_S3_12_1) >= 4
  M6_TypeBRS3_CACB_S3_13 = M6_TypeBRS3_CACB_S6_7 OR (M6_TypeBRS3_CACB_S3_11 OR M6_TypeBRS3_CACB_S3_12)
  M6_TypeBRS3_CACB_S3_14 = (M6_TypeBRS3_CACB_S3_13 AND M6i) COIN EDGE M6_TypeBRS3_CACB_S3_13
  M6_TypeBRS3_CACB_S3_15 = ENCLOSE RECTANGLE (M6_TypeBRS3_CACB_S3_13 WITH EDGE M6_TypeBRS3_CACB_S3_14 >= 4) TypeBRS3_S2 2*TypeBRS3_S3
  
  M6_TypeBRS3_CACB_S45_1 = EXPAND EDGE M6_TypeBRS3_CACB_S3_7 OUTSIDE BY 2*GRID 
