SR_VIA1_P4 = VIA1 INTERACT ((SEALRING_ORI OR SEALRING_DB) OR Reinforced_M1)
SR_VIA1_TMP = NOT ENCLOSE RECTANGLE SR_VIA1_P4 VIA1_W_3+GRID VIA1_W_3+GRID
SR_VIA1_BAR = (NOT RECTANGLE SR_VIA1_P4 == VIA1_W_3 BY == VIA1_W_3 ORTHOGONAL ONLY) NOT SR_VIA1_TMP
SR_VIA1_HOLE = SR_VIA1_P4 NOT SR_VIA1_BAR
SR_VIA2_P4 = VIA2 INTERACT ((SEALRING_ORI OR SEALRING_DB) OR Reinforced_M2)
SR_VIA2_TMP = NOT ENCLOSE RECTANGLE SR_VIA2_P4 VIA2_W_3+GRID VIA2_W_3+GRID
SR_VIA2_BAR = (NOT RECTANGLE SR_VIA2_P4 == VIA2_W_3 BY == VIA2_W_3 ORTHOGONAL ONLY) NOT SR_VIA2_TMP
SR_VIA2_HOLE = SR_VIA2_P4 NOT SR_VIA2_BAR
SR_VIA3_P4 = VIA3 INTERACT ((SEALRING_ORI OR SEALRING_DB) OR Reinforced_M3)
SR_VIA3_TMP = NOT ENCLOSE RECTANGLE SR_VIA3_P4 VIA3_W_3+GRID VIA3_W_3+GRID
SR_VIA3_BAR = (NOT RECTANGLE SR_VIA3_P4 == VIA3_W_3 BY == VIA3_W_3 ORTHOGONAL ONLY) NOT SR_VIA3_TMP
SR_VIA3_HOLE = SR_VIA3_P4 NOT SR_VIA3_BAR
SR_VIA4_P4 = VIA4 INTERACT ((SEALRING_ORI OR SEALRING_DB) OR Reinforced_M4)
SR_VIA4_TMP = NOT ENCLOSE RECTANGLE SR_VIA4_P4 VIA4_W_3+GRID VIA4_W_3+GRID
SR_VIA4_BAR = (NOT RECTANGLE SR_VIA4_P4 == VIA4_W_3 BY == VIA4_W_3 ORTHOGONAL ONLY) NOT SR_VIA4_TMP
SR_VIA4_HOLE = SR_VIA4_P4 NOT SR_VIA4_BAR
SR_VIA5_P4 = VIA5 INTERACT ((SEALRING_ORI OR SEALRING_DB) OR Reinforced_M5)
SR_VIA5_TMP = NOT ENCLOSE RECTANGLE SR_VIA5_P4 VIA5_W_3+GRID VIA5_W_3+GRID
SR_VIA5_BAR = (NOT RECTANGLE SR_VIA5_P4 == VIA5_W_3 BY == VIA5_W_3 ORTHOGONAL ONLY) NOT SR_VIA5_TMP
SR_VIA5_HOLE = SR_VIA5_P4 NOT SR_VIA5_BAR
SR_VIA6_P4 = VIA6 INTERACT ((SEALRING_ORI OR SEALRING_DB) OR Reinforced_M6)
SR_VIA6_TMP = NOT ENCLOSE RECTANGLE SR_VIA6_P4 VIA6_W_3+GRID VIA6_W_3+GRID
SR_VIA6_BAR = (NOT RECTANGLE SR_VIA6_P4 == VIA6_W_3 BY == VIA6_W_3 ORTHOGONAL ONLY) NOT SR_VIA6_TMP
SR_VIA6_HOLE = SR_VIA6_P4 NOT SR_VIA6_BAR
SR_VIA7_P4 = VIA7 INTERACT ((SEALRING_ORI OR SEALRING_DB) OR Reinforced_M7)
SR_VIA7_TMP = NOT ENCLOSE RECTANGLE SR_VIA7_P4 VIA7_W_3+GRID VIA7_W_3+GRID
SR_VIA7_BAR = (NOT RECTANGLE SR_VIA7_P4 == VIA7_W_3 BY == VIA7_W_3 ORTHOGONAL ONLY) NOT SR_VIA7_TMP
SR_VIA7_HOLE = SR_VIA7_P4 NOT SR_VIA7_BAR
SR_VIA8_P4 = VIA8 INTERACT ((SEALRING_ORI OR SEALRING_DB) OR Reinforced_M8)
SR_VIA8_TMP = NOT ENCLOSE RECTANGLE SR_VIA8_P4 VIA8_W_3+GRID VIA8_W_3+GRID
SR_VIA8_BAR = (NOT RECTANGLE SR_VIA8_P4 == VIA8_W_3 BY == VIA8_W_3 ORTHOGONAL ONLY) NOT SR_VIA8_TMP
SR_VIA8_HOLE = SR_VIA8_P4 NOT SR_VIA8_BAR

#IFDEF WITH_APRDL
CB1_SR = CB1i OR RV
#ELSE
CB1_SR = COPY CB1i
#ENDIF

SR_CB1_BAR_INNER = CB1_SR INTERACT SR_M1_INNER
SR_CB1_BAR_SLDB = CB1_SR INTERACT SEALRING_DB
SR_AP_BAR_INNER = (AP AND SEALRING_INNER) AND CHIP_AP
SR_AP_BAR_SLDB = (AP INTERACT SEALRING_DB) AND CHIP_AP
SR_CB2_BAR_OUTER = CB2i INTERACT SR_M1_OUTER
SR_CB2_BAR_SLDB =  CB2i INTERACT SEALRING_DB


//CSR CHECKS
//==========
#IFDEF DBOC
CSR.R.7 { @ The CSR structure must include PM, CBD, Mtop~M1, VIAtop~VIA1, CO, PP, PO, DOD, DPO layers.
#ELSE
CSR.R.7 { @ The CSR structure must include PM, CB2_FC or CB2_WB, AP, CB or CBD or RV, Mtop~M1, VIAtop~VIA1, CO, PP, PO, DOD, DPO layers.
#ENDIF
  CSRDMY NOT PPi
  CSRDMY NOT INTERACT POLY
  CSRDMY NOT INTERACT DPO
  CSRDMY NOT INTERACT COi
  CSRDMY NOT INTERACT DOD
  SEALRING_ORI NOT M1x
  SEALRING_ORI NOT M2x
  SEALRING_ORI NOT M3x
  SEALRING_ORI NOT M4x
  SEALRING_ORI NOT M5x
  SEALRING_ORI NOT M6x
  SEALRING_ORI NOT M7x
  SEALRING_ORI NOT M8x
  SEALRING_ORI NOT M9x
  (SR_M1_P4 AND CSRDMY) NOT ENCLOSE (SR_CO_P4 AND CSRDMY)
  (SR_M1_P4 NOT CSRDMY) NOT ENCLOSE (SR_CO_P4 NOT CSRDMY)
  (SR_M2_P4 AND CSRDMY) NOT ENCLOSE (SR_VIA1_P4 AND CSRDMY)
  (SR_M2_P4 NOT CSRDMY) NOT ENCLOSE (SR_VIA1_P4 NOT CSRDMY)
  (SR_M3_P4 AND CSRDMY) NOT ENCLOSE (SR_VIA2_P4 AND CSRDMY)
  (SR_M3_P4 NOT CSRDMY) NOT ENCLOSE (SR_VIA2_P4 NOT CSRDMY)
  (SR_M4_P4 AND CSRDMY) NOT ENCLOSE (SR_VIA3_P4 AND CSRDMY)
  (SR_M4_P4 NOT CSRDMY) NOT ENCLOSE (SR_VIA3_P4 NOT CSRDMY)
  (SR_M5_P4 AND CSRDMY) NOT ENCLOSE (SR_VIA4_P4 AND CSRDMY)
  (SR_M5_P4 NOT CSRDMY) NOT ENCLOSE (SR_VIA4_P4 NOT CSRDMY)
  (SR_M6_P4 AND CSRDMY) NOT ENCLOSE (SR_VIA5_P4 AND CSRDMY)
  (SR_M6_P4 NOT CSRDMY) NOT ENCLOSE (SR_VIA5_P4 NOT CSRDMY)
  (SR_M7_P4 AND CSRDMY) NOT ENCLOSE (SR_VIA6_P4 AND CSRDMY)
  (SR_M7_P4 NOT CSRDMY) NOT ENCLOSE (SR_VIA6_P4 NOT CSRDMY)
  (SR_M8_P4 AND CSRDMY) NOT ENCLOSE (SR_VIA7_P4 AND CSRDMY)
  (SR_M8_P4 NOT CSRDMY) NOT ENCLOSE (SR_VIA7_P4 NOT CSRDMY)
  (SR_M9_P4 AND CSRDMY) NOT ENCLOSE (SR_VIA8_P4 AND CSRDMY)
  (SR_M9_P4 NOT CSRDMY) NOT ENCLOSE (SR_VIA8_P4 NOT CSRDMY)
  ((SEALRING_ORI_INNER AND CSRDMY) AND CHIP_AP) NOT INTERACT (APi AND CSRDMY)
  ((SEALRING_ORI_INNER NOT CSRDMY) AND CHIP_AP) NOT INTERACT (APi NOT CSRDMY)
#IFNDEF DBOC 
  (SEALRING_ORI_INNER AND CSRDMY) NOT ENCLOSE (CB1_SR AND CSRDMY)
  (SEALRING_ORI_INNER NOT CSRDMY) NOT ENCLOSE (CB1_SR NOT CSRDMY)
  (SEALRING_ORI_OUTER AND CSRDMY) NOT ENCLOSE (CB2i AND CSRDMY)
  (SEALRING_ORI_OUTER NOT CSRDMY) NOT ENCLOSE (CB2i NOT CSRDMY)
#ELSE
  (SEALRING_ORI_INNER AND CSRDMY) INTERACT (CB1_SR AND CSRDMY)
  (SEALRING_ORI_INNER NOT CSRDMY) INTERACT (CB1_SR NOT CSRDMY)
  (SEALRING_ORI_OUTER AND CSRDMY) NOT INTERACT (CB1_SR AND CSRDMY)
  (SEALRING_ORI_OUTER NOT CSRDMY) NOT INTERACT (CB1_SR NOT CSRDMY)
  APi AND CSRDMY
  CB2Fi AND CSRDMY
  CB2Wi AND CSRDMY
  SEALRING_ALL INTERACT APi
  SEALRING_ALL INTERACT CB2Fi
  SEALRING_ALL INTERACT CB2Wi
#ENDIF 
  // PM is checked by PM.R.3
}


// CSR.R.2 is checked by related rules

CSR.R.3 { @ Distance between 45-degree outer seal-ring and seal-ring corner = 18~20 Distance between 45 degree 1st seal ring and seal ring corner >= ^CSR_R_3A um <= ^CSR_R_3B um
  CHIP_WISR_WOSLDB = SIZE CHIP_WISR_P4 BY -8
  CHIP_CORNER_A = INT CHIP_WISR_WOSLDB <= CSR_R_3A ABUT == 90 REGION INTERSECTING ONLY
  CHIP_CORNER_B = INT CHIP_WISR_WOSLDB <= CSR_R_3B ABUT == 90 REGION INTERSECTING ONLY
  CHIP_CORNER_A AND SEALRING_ORI
  CHIP_CORNER_B NOT INTERACT SEALRING_ORI
}

CSR.R.4 { @ CSRDMY layer (CAD layer: 166;0), CSRBIB1DMY (CAD layer: 166;1), and CSRBIB2DMY (CAD layer: 166;2) is must if customers add seal-ring by themselves. DRC doesn't check CSR and BiB related rules without these dummy layers   
  CHIP_WISR_P4 NOT INTERACT CSRDMY
  CHIP_WISR_P4 NOT INTERACT CSRBIB1DMY
  CHIP_WISR_P4 NOT INTERACT CSRBIB2DMY
}

CSR.W.1:M1 { @ Width of reinforced metal structure = 9~10 Width of reinforced metal structure >= ^CSR_W_1A um <= ^CSR_W_1B um
  Reinforced_M1_CHK = ((CSR_M1_P4 NOT SEALRING_ORI) NOT CSR_M1_D) INTERACT CSR_M1_HOLE
  E = Reinforced_M1_CHK NOT WITH WIDTH >= CSR_W_1A <= CSR_W_1B
  CSR_M1_HOLE_R = HOLES CSR_M1_P4  
  A = Reinforced_M1_CHK COIN OUTSIDE EDGE CSR_M1_HOLE_R
  B = (Reinforced_M1_CHK NOT COIN OUTSIDE EDGE CSR_M1_HOLE_R)COIN INSIDE EDGE CSR_M1_P4  
  X1 = ANGLE A != 45
  X2 = ANGLE A == 45
  Y1 = ANGLE B != 45
  Y2 = ANGLE B == 45
  C1 = INT X1 Y1 > CSR_W_1B < CSR_W_1B*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  D1 = INT X1 Y1 >=CSR_W_1A <= CSR_W_1B ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  C2 = INT X2 Y2 > CSR_W_1B+GRID < CSR_W_1B*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  D2 = INT X2 Y2 >CSR_W_1A-GRID < CSR_W_1B+GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  C =C1 OR C2
  D =D1 OR D2
  F = RECTANGLE C >= CSR_W_1A BY >= CSR_W_1B ORTHOGONAL ONLY
  (F OR E)NOT D
}
CSR.L.1:M1 { @ Length of reinforced metal structure = 24~25 Length of reinforced metal structure >= ^CSR_L_1A um <= ^CSR_L_1B um
  CSR_M1_HOLE_R = HOLES CSR_M1_P4
  X1 = ANGLE CSR_M1_HOLE_R == 45
  X2 = ANGLE CSR_M1_HOLE_R != 45
  B = WITH WIDTH CSR_M1_HOLE_R >= CSR_L_1B*2
  ANGLE B != 45
  INT X2 > CSR_L_1B < CSR_L_1B*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < CSR_L_1A ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
