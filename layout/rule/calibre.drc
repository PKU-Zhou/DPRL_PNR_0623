VARIABLE  M6_S_38_A 0.180
// 'Mx.S.38.a' is checked by M6.S.38.a
M6.S.38.a { @ Space of Mx line to line [maximum delta V > 5V] Definition of "Mx line-end": Mx edge with length < 0.08 um (W) between 2 outer vertex. Definition of "Mx line" : Mx edge NOT Mx line-end >= 0.18 
  err_1 = DFM DV DV_M6_LINE  < M6_S_38_A ABUT < 90  NOT CONNECTED  
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > M6_S_38_A_V   ANNOTATE
  err_1_f =  DFM PROPERTY err_1 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_1, "SECOND_VMAX")]
  [ DELTA_V = property(err_1, "DELTA_V")]
  [ SYNC = property(err_1, "SYNC")]  
  DFM COPY err_1_f
  DFM RDB err_1_f "M6.S.38.a.rep" NOEMPTY NOPSEUDO
  err_dmy1 = DFM DV DV_M6_LINE DV_DM6_O_LINE WITH DEFAULT VOLTAGES < M6_S_38_A ABUT < 90  MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > M6_S_38_A_V   ANNOTATE
  err_dmy1_f =  DFM PROPERTY err_dmy1 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_dmy1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_dmy1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_dmy1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_dmy1, "SECOND_VMAX")]
  [ DELTA_V = property(err_dmy1, "DELTA_V")]
  [ SYNC = property(err_dmy1, "SYNC")]  
  DFM COPY err_dmy1_f
  DFM RDB err_dmy1_f "M6.S.38.a.rep" NOEMPTY NOPSEUDO

}

