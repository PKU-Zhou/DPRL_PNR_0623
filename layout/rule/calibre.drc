CSR_VIA8_D = VIA8 INSIDE (CSR_2_M8_HOLE OR CHIP_CORNER_C)
ISO_VIA8_D = (VIA8 INSIDE ISOR_P4) NOT CDUDMY

SEALRING_DBx = (EXT SEALRING_DB < 0.6 ABUT < 90 SINGULAR REGION) OR SEALRING_DB

SR_M1_P4 = M1i AND SEALRING_ORI 
SR_M1_INNER = (SR_M1_P4 INSIDE (HOLES SR_M1_P4)) NOT Reinforced_M1
SR_M1_OUTER = (SR_M1_P4 NOT SR_M1_INNER) NOT Reinforced_M1

SLDB_M1 = M1 AND SEALRING_DBx                            // Metal1 in SLDB
SLDB_M1_HOLE = (HOLES SLDB_M1) NOT SLDB_M1
SLDB_M1_DOT_EDGE = CONVEX EDGE SLDB_M1_HOLE ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH <= M1_W_6+2*GRID
SLDB_M1_DOT = EXT SLDB_M1_DOT_EDGE <= M1_W_6 OPPOSITE PARALLEL ONLY REGION
SLDB_M1_LINE = (SLDB_M1 NOT SLDB_M1_HOLE) NOT SLDB_M1_DOT    // Metal1 Bar in SLDB

SR_M2_P4 = M2i AND SEALRING_ORI 
SR_M2_INNER = (SR_M2_P4 INSIDE (HOLES SR_M2_P4)) NOT Reinforced_M2
SR_M2_OUTER = (SR_M2_P4 NOT SR_M2_INNER) NOT Reinforced_M2

SLDB_M2 = M2 AND SEALRING_DBx                            // Metal2 in SLDB
SLDB_M2_HOLE = (HOLES SLDB_M2) NOT SLDB_M2
SLDB_M2_DOT_EDGE = CONVEX EDGE SLDB_M2_HOLE ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH <= M2_W_6+2*GRID
SLDB_M2_DOT = EXT SLDB_M2_DOT_EDGE <= M2_W_6 OPPOSITE PARALLEL ONLY REGION
SLDB_M2_LINE = (SLDB_M2 NOT SLDB_M2_HOLE) NOT SLDB_M2_DOT    // Metal2 Bar in SLDB

SR_M3_P4 = M3i AND SEALRING_ORI 
SR_M3_INNER = (SR_M3_P4 INSIDE (HOLES SR_M3_P4)) NOT Reinforced_M3
SR_M3_OUTER = (SR_M3_P4 NOT SR_M3_INNER) NOT Reinforced_M3

