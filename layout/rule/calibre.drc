#IFDEF FULL_CHIP
BDTCD.DN.1 { @ Density of {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} (2000 um X 2000 um is one unit) >= 50% 
  ALL_WIN = DENSITY CHIP == BDTCD_DN_1_W*BDTCD_DN_1_W WINDOW BDTCD_DN_1_W STEP BDTCD_DN_1_W INSIDE OF LAYER CHIPx [AREA(CHIP)]
  BAD_WIN = DENSITY TCDDMY_BM1 == 0 WINDOW BDTCD_DN_1_W STEP BDTCD_DN_1_W INSIDE OF LAYER ALL_WIN PRINT BDTCD.DN.1.NO_TCDDMY
  GOOD_WIN = ALL_WIN NOT BAD_WIN
  ERR = DENSITY GOOD_WIN INSIDE OF LAYER ALL_WIN < BDTCD_DN_1 PRINT BDTCD.DN.1.density
  ERR AND BAD_WIN
}
BDTCD.DN.2:M2 { @ Density of {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} (2000 um X 2000 um is one unit) >= 50% 
  ALL_WIN = DENSITY CHIP == BDTCD_DN_2_W*BDTCD_DN_2_W WINDOW BDTCD_DN_2_W STEP BDTCD_DN_2_W INSIDE OF LAYER CHIPx [AREA(CHIP)]
  M2_BAD_WIN = DENSITY TCDDMY_BM2 == 0 WINDOW BDTCD_DN_2_W STEP BDTCD_DN_2_W INSIDE OF LAYER ALL_WIN PRINT BDTCD.DN.2.NO_TCDDMY2
  M2_GOOD_WIN = ALL_WIN NOT M2_BAD_WIN
  M2_ERR = DENSITY M2_GOOD_WIN INSIDE OF LAYER ALL_WIN < BDTCD_DN_2 PRINT BDTCD.DN.2.M2.density
  M2_ERR AND M2_BAD_WIN
}
