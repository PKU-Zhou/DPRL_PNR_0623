}
// LUP.5.3.0 is checked by LUP.5.3.1 and LUP.5.3.2

LUP.5.3.1 { @ If all of guard-ring width >= 0.2 um (e.g. width of guard-ring of LUP.1 and LUP.2) >= 2.6 
  EXT POST_DRIVER_PINJ_NW_25V BESIDE_POST_DRIVER_NMOS_PW < LUP_5_3_1 ABUT < 90 SINGULAR
