RR:RE:M6.EN.2__M6.EN.3 { @ Recommended M6 enclosure of square VIA5 >= ^M6_EN_3_R, OR at least two opposite sides >= ^M6_EN_2_R um
  CHECK_VIA = SQR_VIA5 INTERACT M6EN2_M6EN3_VIA5      
  A = RECTANGLE ENCLOSURE CHECK_VIA M6 ABUT < 90 SINGULAR GOOD 0 M6_EN_2_R OPPOSITE 0 M6_EN_2_R OPPOSITE
  ENC A M6 < M6_EN_3_R ABUT < 90 SINGULAR REGION
}
// M6.EN.2.R and M6.EN.3.R are checked by RR:RE:M6.EN.2__M6.EN.3
