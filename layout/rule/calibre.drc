  M6_TypeBRS3_CACB_S3_2 = M6i COIN EDGE M6_TypeBRS3_CACB_S6_7
  M6_TypeBRS3_CACB_S3_3 = LENGTH M6_TypeBRS3_CACB_S3_2 == GRID
  M6_TypeBRS3_CACB_S3_4 = (((M6_CORNER COIN EDGE M6i) NOT COIN EDGE M6_TypeBRS3_CACB_S3_3) NOT COIN EDGE M6_TypeBRS3_CACB_S3_1 ) TOUCH EDGE M6_TypeBRS3_CACB_S6_7
  M6_TypeBRS3_CACB_S3_5 = EXPAND EDGE M6_TypeBRS3_CACB_S3_3 OUTSIDE BY GRID EXTEND BY GRID
