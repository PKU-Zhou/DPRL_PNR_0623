M5_NOTCH_candidate8 = EXT M5_NOTCH_candidate7 M5i <= Mx_S ABUT < 90 OPPOSITE REGION
M5_NOTCH_candidate9 = ENCLOSE RECTANGLE M5_NOTCH_candidate8 COMB_LL+GRID GRID
M5_NOTCH_candidate10 = M5_NOTCH_candidate5 NOT INTERACT M5_NOTCH_candidate9

M5_NOTCH_candidate11_1 = EXT M5_L_END_edge M5i <= COMB_S2 ABUT < 90 OPPOSITE REGION
