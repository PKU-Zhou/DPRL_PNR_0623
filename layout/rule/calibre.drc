                         (COUNT(M3_lv_id_top)>0) ? MIN(property(M3_lv_id_top , M3_mlv )) : 
                         (COUNT(M2_lv_id_top)>0) ? MIN(property(M2_lv_id_top , M2_mlv )) : 
                         (COUNT(M1_lv_id_top)>0) ? MIN(property(M1_lv_id_top , M1_mlv )) : 
                         FMIN(((COUNT(OD_lv_id)>0) ? MIN(property(OD_lv_id , OD_mlv )) : 100),
                         FMIN(((COUNT(PO_lv_id)>0) ? MIN(property(PO_lv_id , PO_mlv )) : 100),
                         FMIN(((COUNT(M1_lv_id)>0) ? MIN(property(M1_lv_id , M1_mlv )) : 100), 
                         FMIN(((COUNT(M2_lv_id)>0) ? MIN(property(M2_lv_id , M2_mlv )) : 100), 
                         FMIN(((COUNT(M3_lv_id)>0) ? MIN(property(M3_lv_id , M3_mlv )) : 100), 
                         FMIN(((COUNT(M4_lv_id)>0) ? MIN(property(M4_lv_id , M4_mlv )) : 100), 
                         FMIN(((COUNT(M5_lv_id)>0) ? MIN(property(M5_lv_id , M5_mlv )) : 100), 
                         FMIN(((COUNT(M6_lv_id)>0) ? MIN(property(M6_lv_id , M6_mlv )) : 100), 
                         FMIN(((COUNT(M7_lv_id)>0) ? MIN(property(M7_lv_id , M7_mlv )) : 100), 
                         FMIN(((COUNT(M8_lv_id)>0) ? MIN(property(M8_lv_id , M8_mlv )) : 100), 
                         FMIN(((COUNT(M9_lv_id)>0) ? MIN(property(M9_lv_id , M9_mlv )) : 100), 
                         (COUNT(AP_lv_id)>0) ? MIN(property(AP_lv_id , AP_mlv )) : 100 ) ) ) ) ) ) ) ) ) ) ) ]
DMACRO VOLTAGE_ANNOTATE_2 Mx_in MxV_in Mx_out {
   Mx_out = DFM PROPERTY Mx_in MxV_in NODAL MULTI  
        [ Volt_High = property(MxV_in,"Volt_High")]
        [ Volt_Low  = property(MxV_in,"Volt_Low")]
}
DMACRO DELTA_WARNING1 Mx Mx_n NET_P_LAYER {
  Mx_warn = DFM PROPERTY Mx_n NET_P_LAYER NODAL MULTI
  [ -= (property(NET_P_LAYER,"Volt_Low") - property(NET_P_LAYER,"Volt_High"))] > 0
  NET AREA RATIO Mx Mx_warn > 0
}



