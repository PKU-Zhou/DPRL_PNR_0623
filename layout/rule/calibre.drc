  M3_PIN NOT INTERACT M3i == 1
}

//'Mx.R.3' is checked by M4.R.3
M4.R.3 {@ Metal (pin) layers must be drawn only interact with one related Metal (drawing) layers   
  M4_PIN NOT INTERACT M4i == 1
}

