#IFDEF M1_V1_M2_CHECKS
M1.R.3 {@ Metal (pin) layers must be drawn only interact with one related Metal (drawing) layers   
  M1_PIN NOT INTERACT M1i == 1
}
//'Mx.R.3' is checked by M2.R.3
M2.R.3 {@ Metal (pin) layers must be drawn only interact with one related Metal (drawing) layers   
  M2_PIN NOT INTERACT M2i == 1
}
#ENDIF // M1_V1_M2_CHECKS

