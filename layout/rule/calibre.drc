CSR_VIA1_D = VIA1 INSIDE (CSR_2_M1_HOLE OR CHIP_CORNER_C)
ISO_VIA1_D = (VIA1 INSIDE ISOR_P4) NOT CDUDMY
CSR_VIA2_D = VIA2 INSIDE (CSR_2_M2_HOLE OR CHIP_CORNER_C)
ISO_VIA2_D = (VIA2 INSIDE ISOR_P4) NOT CDUDMY
CSR_VIA3_D = VIA3 INSIDE (CSR_2_M3_HOLE OR CHIP_CORNER_C)
ISO_VIA3_D = (VIA3 INSIDE ISOR_P4) NOT CDUDMY
CSR_VIA4_D = VIA4 INSIDE (CSR_2_M4_HOLE OR CHIP_CORNER_C)
ISO_VIA4_D = (VIA4 INSIDE ISOR_P4) NOT CDUDMY
CSR_VIA5_D = VIA5 INSIDE (CSR_2_M5_HOLE OR CHIP_CORNER_C)
ISO_VIA5_D = (VIA5 INSIDE ISOR_P4) NOT CDUDMY
CSR_VIA6_D = VIA6 INSIDE (CSR_2_M6_HOLE OR CHIP_CORNER_C)
ISO_VIA6_D = (VIA6 INSIDE ISOR_P4) NOT CDUDMY
