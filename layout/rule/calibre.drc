  M6_TypeBRS3_prefilter_6 = M6_TypeBRS3_prefilter_4 NOT M6_TypeBRS3_prefilter_5
  M6_TypeBRS3_prefilter_7_1 = M6_TypeBRS3_prefilter_6 INTERACT (M6_TypeBRS3_prefilter_6 AND M6i) > 1
  M6_TypeBRS3_prefilter_7 = (M6_TypeBRS3_prefilter_5_1 INTERACT M6_TypeBRS3_prefilter_7_1) OR M6_TypeBRS3_prefilter_7_1
  M6_TypeBRS3_prefilter_8 = EXTENTS M6_TypeBRS3_prefilter_7
  
  M6_TypeBRS3_prefilter_9 = M6_TypeBRS3_prefilter_3 COIN EDGE (M6_CORNER INTERACT M6_TypeBRS3_prefilter_8)
  M6_TypeBRS3_prefilter_10 = EXT M6_TypeBRS3_prefilter_9 M6_TypeBRS3_prefilter_2 == TypeBRS3_S2 OPPOSITE REGION
  M6_TypeBRS3_prefilter_11 = M6_TypeBRS3_prefilter_10 INTERACT (M6_TypeBRS3_prefilter_10 AND M6i) > 1
  M6_TypeBRS3_prefilter_12 = (EXPAND EDGE M6_TypeBRS3_prefilter_3 OUTSIDE BY GRID) NOT INTERACT M6_TypeBRS3_prefilter_11
  M6_TypeBRS3_prefilter_13 = (EXPAND EDGE (M6_TypeBRS3_prefilter_12 NOT COIN EDGE M6i) OUTSIDE BY GRID) OR M6_TypeBRS3_prefilter_12 
