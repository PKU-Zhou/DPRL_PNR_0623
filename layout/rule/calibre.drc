RR:RE:EFP.M1.S.7 { @ Metal bridge recommendation type-3: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3 and Region B4] when neighboring Mx (polygon3/4) with parallel run length > 0 um and there is no other Mx interact Region B1/B2 Definitions: 1. Region B3/B4 = 0.25 um * 0.09 um (L1), generated from vertex CB and CA respectively. 2. L2 = height difference of vertex CA project to vertex CB <= 0.05 um. 3. Region B1/B2 = 0.16 um * 0.115 um, generated from Mx (polygon3/4) line-end with vertex CA and CB respectively >= 0.055 
  M1_TypeBRS3_prefilter_1 = EXT [M1i] == TypeBRS3_S2 ABUT < 90 OPPOSITE
  M1_TypeBRS3_prefilter_2 = M1i TOUCH EDGE M1_TypeBRS3_prefilter_1
  M1_TypeBRS3_prefilter_3 = (M1_CORNER WITH EDGE M1_TypeBRS3_prefilter_2) COIN EDGE M1i
  
  M1_TypeBRS3_prefilter_4_1 = EXT M1_TypeBRS3_prefilter_3 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
  M1_TypeBRS3_prefilter_4_2 = M1i AND M1_TypeBRS3_prefilter_4_1
  M1_TypeBRS3_prefilter_4_3 = EXT [M1_TypeBRS3_prefilter_3] M1_TypeBRS3_prefilter_4_2 <= Mx_S OPPOSITE EXTENDED TypeBRS3_S6
  M1_TypeBRS3_prefilter_4_4 = M1_TypeBRS3_prefilter_3 TOUCH EDGE M1_TypeBRS3_prefilter_4_3 
  M1_TypeBRS3_prefilter_4_5 = EXT [M1_TypeBRS3_prefilter_3] M1_TypeBRS3_prefilter_4_2 > Mx_S+Mx_W <= 2*Mx_S+Mx_W OPPOSITE EXTENDED TypeBRS3_S6
  M1_TypeBRS3_prefilter_4_6 = M1_TypeBRS3_prefilter_4_4 TOUCH EDGE M1_TypeBRS3_prefilter_4_5
  M1_TypeBRS3_prefilter_4 =  EXT M1_TypeBRS3_prefilter_4_6 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
  M1_TypeBRS3_prefilter_5_1 = EXPAND EDGE (M1_TypeBRS3_prefilter_3 COIN EDGE M1_TypeBRS3_prefilter_4) OUTSIDE BY 2*GRID
  M1_TypeBRS3_prefilter_5_2 = INT [M1_TypeBRS3_prefilter_5_1] == GRID OPPOSITE
  M1_TypeBRS3_prefilter_5_3 = EXPAND EDGE M1_TypeBRS3_prefilter_5_2 OUTSIDE BY GRID EXTEND BY GRID
