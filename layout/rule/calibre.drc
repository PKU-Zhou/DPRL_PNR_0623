M5A1_M5Marker = M5i AND RRuleRecommended
M5A1_M5 = ((M5A1_M5Cell OR M5A1_M5Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:M5.A.1 { @ Recommended area (except DMx_O) >= 0.022 
  (AREA M5A1_M5 < M5_A_1_R) NOT INSIDE TCDDMY_BM5
}
#ENDIF
#ENDIF

// VIA5.EN.0.R is checked by either {VIA5.EN.1.R/VIA5.EN.2.R} or VIA5.EN.3.R
#IFDEF CHECK_VIA5EN1_
#IFDEF _VIA5EN1_
VIA5EN1_VIA5CellIn1 = INSIDE CELL VIA5ii CellsForRRuleRecommended  
VIA5EN1_VIA5CellOut1 = NOT INSIDE CELL VIA5ii ExclCellsForRRuleRecommended 
VIA5EN1_VIA5CellIn2 = INSIDE CELL VIA5_VIRT CellsForRRuleRecommended  
VIA5EN1_VIA5CellOut2 = NOT INSIDE CELL VIA5_VIRT ExclCellsForRRuleRecommended 
VIA5EN1_VIA5Cell = (VIA5EN1_VIA5CellIn1 AND VIA5EN1_VIA5CellOut1) OR (VIA5EN1_VIA5CellIn2 AND VIA5EN1_VIA5CellOut2)
VIA5EN1_VIA5Marker = (VIA5ii OR VIA5_VIRT) AND RRuleRecommended
VIA5EN1_VIA5 = ((VIA5EN1_VIA5Cell OR VIA5EN1_VIA5Marker) NOT Block ) NOT excludeRRuleRecommended

// VIAx.EN.1.R is checked by RR:RE:VIA5.EN.1 
RR:RE:VIA5.EN.1 { @ Recommended enclosure by M1 or Mx to avoid high Rc. (for square VIA) >= 0.01 
   CHECK_VIA = SQR_VIA5 INTERACT VIA5EN1_VIA5
   ENC CHECK_VIA M5 < VIA5_EN_1_R ABUT < 90 SINGULAR REGION
}
#ENDIF
#ENDIF

#IFDEF CHECK_VIA5EN2_VIA5EN3_
#IFDEF _VIA5EN2_VIA5EN3_
VIA5EN2_VIA5EN3_VIA5CellIn1 = INSIDE CELL VIA5ii CellsForRRuleRecommended  
VIA5EN2_VIA5EN3_VIA5CellOut1 = NOT INSIDE CELL VIA5ii ExclCellsForRRuleRecommended 
VIA5EN2_VIA5EN3_VIA5CellIn2 = INSIDE CELL VIA5_VIRT CellsForRRuleRecommended  
VIA5EN2_VIA5EN3_VIA5CellOut2 = NOT INSIDE CELL VIA5_VIRT ExclCellsForRRuleRecommended 
VIA5EN2_VIA5EN3_VIA5Cell = (VIA5EN2_VIA5EN3_VIA5CellIn1 AND VIA5EN2_VIA5EN3_VIA5CellOut1) OR (VIA5EN2_VIA5EN3_VIA5CellIn2 AND VIA5EN2_VIA5EN3_VIA5CellOut2)
VIA5EN2_VIA5EN3_VIA5Marker = (VIA5ii OR VIA5_VIRT) AND RRuleRecommended
VIA5EN2_VIA5EN3_VIA5 = ((VIA5EN2_VIA5EN3_VIA5Cell OR VIA5EN2_VIA5EN3_VIA5Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:VIA5.EN.2__VIA5.EN.3 { @ Recommended enclosure of {M1 OR Mx} [at least two opposite sides] to avoid high Rc.(for square VIA) >= 0.05
                        @ Recommended enclosure of {M1 OR Mx} to avoid high Rc. [all sides] (for square VIA) >= 0.025       
   CHECK_VIA = SQR_VIA5 INTERACT VIA5EN2_VIA5EN3_VIA5       
   X = RECTANGLE ENCLOSURE CHECK_VIA M5 ABUT < 90 SINGULAR GOOD 0 VIA5_EN_2_R OPPOSITE 0 VIA5_EN_2_R OPPOSITE
   ENC X M5 < VIA5_EN_3_R ABUT < 90 SINGULAR REGION
}
// VIA5.EN.2.R and VIA5.EN.3.R are checked by RR:RE:VIA5.EN.2__VIA5.EN.3
#ENDIF
#ENDIF

#IFDEF CHECK_VIA5R10_
#IFDEF _VIA5R10_
VIA5R10_VIA5CellIn = INSIDE CELL VIA5ii CellsForRRuleRecommended  
VIA5R10_VIA5CellOut = NOT INSIDE CELL VIA5ii ExclCellsForRRuleRecommended 
