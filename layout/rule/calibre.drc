VIA5_S_20_A_CHECK = VIA5ii NOT COIN INSIDE EDGE M6i
// 'VIAx.S.20.a' is checked by VIA5.S.20.a
VIA5.S.20.a { @ Space of VIAx [Mx+1 enclosure of VIAx > 0 um] to VIAx-1 [parallel run length > 0 um] [maximum delta V > 5V] >= 0.22 
  err_1 = DFM DV VIA5_S_20_A_CHECK VIA4ii < VIA5_S_20_A ABUT < 90 OPPOSITE  NOT CONNECTED MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > VIA5_S_20_A_V   ANNOTATE
  err_1_f =  DFM PROPERTY err_1 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_1, "SECOND_VMAX")]
  [ DELTA_V = property(err_1, "DELTA_V")]
  [ SYNC = property(err_1, "SYNC")]  
  DFM COPY err_1_f
  DFM RDB err_1_f "VIA5.S.20.a.rep" NOEMPTY NOPSEUDO

}



VARIABLE  VIA5_S_21_A_V 5
VARIABLE  VIA5_S_21_A 0.210
VARIABLE  VIA5_S_21_A_EN 0.010
VIA5_S_21_AA_CHECK = VIA5ii WITH EDGE (ENC [VIA5ii] M6i < VIA5_S_21_A_EN ABUT < 90 OPPOSITE)
VIA5_S_21_AB_CHECK = M5i WITH EDGE (EXT [M5i] VIA5_S_21_AA_CHECK <= VIA5_S_21_A  ABUT < 90 OPPOSITE  MEASURE ALL)
VIA5_S_21_AA_DUMMYOPC = VIA5ii WITH EDGE (ENC [VIA5ii] DM6_O < VIA5_S_21_A_EN ABUT < 90 OPPOSITE)
VIA5_S_21_AB_DUMMYOPC = DM5_O WITH EDGE (EXT [DM5_O] VIA5_S_21_AA_DUMMYOPC <= VIA5_S_21_A  ABUT < 90 OPPOSITE  MEASURE ALL)
// 'VIAx.S.21.a' is checked by VIA5.S.21.a
VIA5.S.21.a { @ Space of VIAx [Mx+1 enclosure of VIAx < 0.01 um] to Mx [parallel run length > 0 um] [maximum delta V > 5V] >= 0.21 
  err_1 = DFM DV VIA5_S_21_AA_CHECK VIA5_S_21_AB_CHECK < VIA5_S_21_A ABUT < 90 SINGULAR NOT CONNECTED MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > VIA5_S_21_A_V   ANNOTATE
  err_1_f =  DFM PROPERTY err_1 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_1, "SECOND_VMAX")]
  [ DELTA_V = property(err_1, "DELTA_V")]
  [ SYNC = property(err_1, "SYNC")]  
  DFM COPY err_1_f
  DFM RDB err_1_f "VIA5.S.21.a.rep" NOEMPTY NOPSEUDO
  err_dmy1 = DFM DV VIA5_S_21_AA_CHECK VIA5_S_21_AB_DUMMYOPC WITH DEFAULT VOLTAGES < VIA5_S_21_A ABUT < 90 SINGULAR MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > VIA5_S_21_A_V   ANNOTATE
  err_dmy1_f =  DFM PROPERTY err_dmy1 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_dmy1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_dmy1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_dmy1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_dmy1, "SECOND_VMAX")]
  [ DELTA_V = property(err_dmy1, "DELTA_V")]
  [ SYNC = property(err_dmy1, "SYNC")]  
  DFM COPY err_dmy1_f
  DFM RDB err_dmy1_f "VIA5.S.21.a.rep" NOEMPTY NOPSEUDO

}



