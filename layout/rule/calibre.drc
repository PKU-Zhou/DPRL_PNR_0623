#IFDEF FRONT_END
#IFDEF N22_ULL
// <TGO_EHVT.R.1> is checked by TGO_EHVT.R.1.a
DRC UNSELECT CHECK TGO_EHVT.R.1
TGO_EHVT.R.1.a { @ Overlap of VTH_N, VTH_P, VTL_N, VTL_P, VTUL_N, VTUL_P, UHVT_N, UHVT_P, VTSUH_N, VTSUH_P, NT_N, or OD2 is not allowed    
  TGO_EHVT AND VTHN
  TGO_EHVT AND VTHP
  TGO_EHVT AND VTLN
  TGO_EHVT AND VTLP
  TGO_EHVT AND VTULN
  TGO_EHVT AND VTULP
  TGO_EHVT AND VTUHN
  TGO_EHVT AND VTUHP
  TGO_EHVT AND VTSUH_N
  TGO_EHVT AND VTSUH_P
  TGO_EHVT AND NTN
  TGO_EHVT AND OD2
}
#ENDIF
