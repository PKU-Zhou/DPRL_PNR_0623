RR:RE:EFP.M3.EN.1 { @ Mx/VIAx-1 recommendation: Recommended Mx_A enclosure VIAx-1 [in {VIAx-1 AND Mx_A} space to Mx (SP3+SE) <= 0.06 um side] Definition of Mx_A: Mx with consecutive edge length (L1) <= 0.12 um, (L2) <= 0.06 um, (L3) >= 0.1 um, L1/L3 edge is between 2 outer vertex. L1/L3 space to adjacent Mx (SP3/SP4) = 0.05 um [parallel run length > 0 from VIAx-1] >= 0.01 
   L1_pre = CONVEX EDGE EFPM3EN1_M3i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L2 LENGTH2>=EFP_Mx_EN_1_L3 WITH LENGTH<=EFP_Mx_EN_1_L1
   L2_pre = CONVEX EDGE EFPM3EN1_M3i ANGLE1==90 ANGLE2==90 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH<=EFP_Mx_EN_1_L2
   L3_pre = CONVEX EDGE EFPM3EN1_M3i ANGLE1==90 ANGLE2>=90 <=270 LENGTH1<=EFP_Mx_EN_1_L1 WITH LENGTH>=EFP_Mx_EN_1_L3
   L1_L2_V = INT L1_pre L2_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1_L3_V = INT L1_pre L3_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
   L1 = (L1_pre TOUCH INSIDE EDGE L1_L2_V) TOUCH INSIDE EDGE L1_L3_V
   L3 = L3_pre TOUCH INSIDE EDGE (L1_L3_V WITH EDGE L1)
   L1_DENSE = EXT [L1] M3 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA2_L1_DENSE = VIA2i TOUCH INSIDE EDGE (ENC [VIA2i] L1_DENSE < EFP_Mx_EN_1_SE ABUT<90 OPPOSITE)
   L3_DENSE = EXT [L3] M3 == EFP_Mx_EN_1_SP ABUT<90 OPPOSITE 
   VIA2_L3_DENSE = VIA2i TOUCH INSIDE EDGE (ENC [VIA2i] L3_DENSE <= EFP_Mx_EN_1_L1-VIA2_W_1-VIA2_EN_2 ABUT<90 OPPOSITE)
   X = INT VIA2_L1_DENSE VIA2_L3_DENSE <= GRID ABUT==90 INTERSECTING ONLY REGION
   VIA2i INTERACT X  
}
// EFP.Mx.EN.1.R is checked by RR:RE:EFP.M3.EN.1
#ENDIF
