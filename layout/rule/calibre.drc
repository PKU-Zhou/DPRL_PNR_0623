LONG_M7_TCD_100 = INT [LONGEDGE_M7_TCD] == BDTCD_W_3B OPPOSITE
LONG_M7_TCD_200 = INT [LONGEDGE_M7_TCD] == BDTCD_W_3C OPPOSITE

BDTCD.W.1 { @ Dimension of TCDDMY_FDM1 or TCDDMY_FDMx or TCDDMY_FM1 or TCDDMY_FMx = 4X4 
  NOT RECTANGLE TCDDMY_FM1 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY
  NOT RECTANGLE TCDDMY_FDM1 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY    
  NOT RECTANGLE TCDDMY_FM2 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY
  NOT RECTANGLE TCDDMY_FDM2 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY    
  NOT RECTANGLE TCDDMY_FM3 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY
  NOT RECTANGLE TCDDMY_FDM3 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY    
  NOT RECTANGLE TCDDMY_FM4 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY
  NOT RECTANGLE TCDDMY_FDM4 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY    
  NOT RECTANGLE TCDDMY_FM5 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY
  NOT RECTANGLE TCDDMY_FDM5 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY    
  NOT RECTANGLE TCDDMY_FM6 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY
  NOT RECTANGLE TCDDMY_FDM6 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY    
  NOT RECTANGLE TCDDMY_FM7 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY
  NOT RECTANGLE TCDDMY_FDM7 == BDTCD_W_1 BY == BDTCD_W_1 ORTHOGONAL ONLY    
}

BDTCD.W.2:M1 { @ Dimension of TCDDMY_M1 or TCDDMY_Mx = 3.45X3.55 
  A = RECTANGLE TCDDMY_M1 == BDTCD_W_2A BY == BDTCD_W_2B ORTHOGONAL ONLY
  TCDDMY_M1 NOT A
  B = LENGTH (ANGLE A == 0) == BDTCD_W_2B
  A WITH EDGE B
}

BDTCD.W.3:M1 { @ Width of M1 inside {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} or Mx inside {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} [M1/Mx length >= 1.2 um] = 0.05, 0.1, 0.2 
  ((LONGEDGE_M1_TCD NOT COIN INSIDE EDGE LONG_M1_TCD_050) NOT COIN INSIDE EDGE LONG_M1_TCD_100) NOT COIN INSIDE EDGE LONG_M1_TCD_200
}
BDTCD.S.1__BDTCD.S.2:M1 { @ Space between 2 M1 inside {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} or 2 Mx inside {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} [M1/Mx [edge length >= 1.2 um] width = 0.05 um] = 0.05 
                          @ Space between 2 M1 inside {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} or 2 Mx inside {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} [M1/Mx [edge length >= 1.2 um] width = 0.05 um space to M1/Mx [edge length >= 1.2 um] width = 0.1 um or M1/Mx [edge length >= 1.2 um] width = 0.05 um space to M1/Mx [edge length >= 1.2 um] width = 0.2 um] = 0.1 
  GOOD_REGION1 = EXT LONG_M1_TCD_050 == BDTCD_S_1 ABUT < 90 OPPOSITE REGION
  GOOD_REGION2 = EXT LONG_M1_TCD_050 LONG_M1_TCD_100 == BDTCD_S_2 ABUT < 90 OPPOSITE REGION
  GOOD_REGION3 = EXT LONG_M1_TCD_050 LONG_M1_TCD_200 == BDTCD_S_2 ABUT < 90 OPPOSITE REGION
  LONG_M1_TCD_050 NOT TOUCH EDGE ((GOOD_REGION1 OR GOOD_REGION2) OR GOOD_REGION3) 
}

BDTCD.W.2:M2 { @ Dimension of TCDDMY_M1 or TCDDMY_Mx = 3.45X3.55 
  A = RECTANGLE TCDDMY_M2 == BDTCD_W_2A BY == BDTCD_W_2B ORTHOGONAL ONLY
  TCDDMY_M2 NOT A
  B = LENGTH (ANGLE A == 0) == BDTCD_W_2B
  A WITH EDGE B
}

BDTCD.W.3:M2 { @ Width of M1 inside {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} or Mx inside {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} [M1/Mx length >= 1.2 um] = 0.05, 0.1, 0.2 
  ((LONGEDGE_M2_TCD NOT COIN INSIDE EDGE LONG_M2_TCD_050) NOT COIN INSIDE EDGE LONG_M2_TCD_100) NOT COIN INSIDE EDGE LONG_M2_TCD_200
}
BDTCD.S.1__BDTCD.S.2:M2 { @ Space between 2 M1 inside {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} or 2 Mx inside {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} [M1/Mx [edge length >= 1.2 um] width = 0.05 um] = 0.05 
                          @ Space between 2 M1 inside {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} or 2 Mx inside {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} [M1/Mx [edge length >= 1.2 um] width = 0.05 um space to M1/Mx [edge length >= 1.2 um] width = 0.1 um or M1/Mx [edge length >= 1.2 um] width = 0.05 um space to M1/Mx [edge length >= 1.2 um] width = 0.2 um] = 0.1 
  GOOD_REGION1 = EXT LONG_M2_TCD_050 == BDTCD_S_1 ABUT < 90 OPPOSITE REGION
  GOOD_REGION2 = EXT LONG_M2_TCD_050 LONG_M2_TCD_100 == BDTCD_S_2 ABUT < 90 OPPOSITE REGION
  GOOD_REGION3 = EXT LONG_M2_TCD_050 LONG_M2_TCD_200 == BDTCD_S_2 ABUT < 90 OPPOSITE REGION
  LONG_M2_TCD_050 NOT TOUCH EDGE ((GOOD_REGION1 OR GOOD_REGION2) OR GOOD_REGION3) 
}

BDTCD.W.2:M3 { @ Dimension of TCDDMY_M1 or TCDDMY_Mx = 3.45X3.55 
  A = RECTANGLE TCDDMY_M3 == BDTCD_W_2A BY == BDTCD_W_2B ORTHOGONAL ONLY
  TCDDMY_M3 NOT A
  B = LENGTH (ANGLE A == 0) == BDTCD_W_2B
  A WITH EDGE B
}

BDTCD.W.3:M3 { @ Width of M1 inside {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} or Mx inside {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} [M1/Mx length >= 1.2 um] = 0.05, 0.1, 0.2 
  ((LONGEDGE_M3_TCD NOT COIN INSIDE EDGE LONG_M3_TCD_050) NOT COIN INSIDE EDGE LONG_M3_TCD_100) NOT COIN INSIDE EDGE LONG_M3_TCD_200
}
BDTCD.S.1__BDTCD.S.2:M3 { @ Space between 2 M1 inside {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} or 2 Mx inside {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} [M1/Mx [edge length >= 1.2 um] width = 0.05 um] = 0.05 
                          @ Space between 2 M1 inside {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} or 2 Mx inside {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} [M1/Mx [edge length >= 1.2 um] width = 0.05 um space to M1/Mx [edge length >= 1.2 um] width = 0.1 um or M1/Mx [edge length >= 1.2 um] width = 0.05 um space to M1/Mx [edge length >= 1.2 um] width = 0.2 um] = 0.1 
  GOOD_REGION1 = EXT LONG_M3_TCD_050 == BDTCD_S_1 ABUT < 90 OPPOSITE REGION
  GOOD_REGION2 = EXT LONG_M3_TCD_050 LONG_M3_TCD_100 == BDTCD_S_2 ABUT < 90 OPPOSITE REGION
  GOOD_REGION3 = EXT LONG_M3_TCD_050 LONG_M3_TCD_200 == BDTCD_S_2 ABUT < 90 OPPOSITE REGION
  LONG_M3_TCD_050 NOT TOUCH EDGE ((GOOD_REGION1 OR GOOD_REGION2) OR GOOD_REGION3) 
}

BDTCD.W.2:M4 { @ Dimension of TCDDMY_M1 or TCDDMY_Mx = 3.45X3.55 
  A = RECTANGLE TCDDMY_M4 == BDTCD_W_2A BY == BDTCD_W_2B ORTHOGONAL ONLY
  TCDDMY_M4 NOT A
  B = LENGTH (ANGLE A == 0) == BDTCD_W_2B
  A WITH EDGE B
}

BDTCD.W.3:M4 { @ Width of M1 inside {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} or Mx inside {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} [M1/Mx length >= 1.2 um] = 0.05, 0.1, 0.2 
  ((LONGEDGE_M4_TCD NOT COIN INSIDE EDGE LONG_M4_TCD_050) NOT COIN INSIDE EDGE LONG_M4_TCD_100) NOT COIN INSIDE EDGE LONG_M4_TCD_200
}
BDTCD.S.1__BDTCD.S.2:M4 { @ Space between 2 M1 inside {TCDDMY_FDM1 OR {TCDDMY_FM1 OR TCDDMY_M1}} or 2 Mx inside {TCDDMY_FDMx OR {TCDDMY_FMx OR TCDDMY_Mx}} [M1/Mx [edge length >= 1.2 um] width = 0.05 um] = 0.05 
