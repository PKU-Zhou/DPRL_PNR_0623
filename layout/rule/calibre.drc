HVN25_65.A.1 { @ Area >= ^HVN25_65_A_1
   AREA HVN25_65 < HVN25_65_A_1
}
HVN25_65.A.2 { @ Enclosed area >= ^HVN25_65_A_2
   A = HOLES HVN25_65 INNER
   B = A NOT HVN25_65
   AREA B < HVN25_65_A_2
}
HVN25_65.R.1 { @ HVN25_65 edge landing on OD without landing on GATE is not allowed
   (HVN25_65 INSIDE EDGE OD_HVDN25_65) NOT INSIDE EDGE GATE_HVDN25_65
}
HVN25_65.R.2 { @ HVN25__65 must be fully inside OD_25
