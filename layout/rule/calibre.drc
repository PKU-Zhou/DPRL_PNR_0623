  M3_GOOD_WIN = ALL_WIN NOT M3_BAD_WIN
  M3_ERR = DENSITY M3_GOOD_WIN INSIDE OF LAYER ALL_WIN < BDTCD_DN_2 PRINT BDTCD.DN.2.M3.density
  M3_ERR AND M3_BAD_WIN
}
