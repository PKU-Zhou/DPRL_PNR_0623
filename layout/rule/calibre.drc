  [ DELTA_V = property(err_dmy1, "DELTA_V")]
  [ SYNC = property(err_dmy1, "SYNC")]  
  DFM COPY err_dmy1_f
  DFM RDB err_dmy1_f "M1.S.37.a.rep" NOEMPTY NOPSEUDO

}

