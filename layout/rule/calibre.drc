DOD_edge_nw_en_6 = ENC [DOD] NWi < NW_EN_6 ABUT < 90 MEASURE ALL
NWi_enc_edge_nw_en_6 = NWi_exp TOUCH OUTSIDE EDGE NW_edge_nw_en_6
DOD_enc_edge_nw_en_6 = DOD TOUCH INSIDE EDGE DOD_edge_nw_en_6
NW.EN.6 { @ Enclosure of DOD [maximum delta V > 5V] >= 0.16 
  err_dmy2 = DFM DV NWi_enc_edge_nw_en_6 DOD_enc_edge_nw_en_6 WITH DEFAULT VOLTAGES < NW_EN_6 ABUT < 90  MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > NW_EN_6_V   ANNOTATE
  err_dmy2_f =  DFM PROPERTY err_dmy2 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_dmy2, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_dmy2, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_dmy2, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_dmy2, "SECOND_VMAX")]
  [ DELTA_V = property(err_dmy2, "DELTA_V")]
  [ SYNC = property(err_dmy2, "SYNC")]  
  DFM COPY err_dmy2_f
  DFM RDB err_dmy2_f "NW.EN.6.rep" NOEMPTY NOPSEUDO

}



