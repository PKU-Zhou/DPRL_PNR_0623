MET_PO = ALL_POLY NOT (RHPO AND RPO)
MATCHING_S10  = (SIZE MATCHING_ARRAY BY 10) AND CHIP
MATCHING_S10x = MERGE MATCHING_S10


PO_65V = NET AREA RATIO ILP1i OVER M9_HV_65V M8_HV_65V M7_HV_65V M6_HV_65V M5_HV_65V M4_HV_65V M3_HV_65V M2_HV_65V M1_HV_65V PO_HV_65V NW_HV_65V DNW_HV_65V > 0
PO_5V = NET AREA RATIO ILP1i OVER M9_HV_5V M8_HV_5V M7_HV_5V M6_HV_5V M5_HV_5V M4_HV_5V M3_HV_5V M2_HV_5V M1_HV_5V > 0
PO_1233V = NET AREA RATIO ILP1i OVER M9_HV_1233V M8_HV_1233V M7_HV_1233V M6_HV_1233V M5_HV_1233V M4_HV_1233V M3_HV_1233V M2_HV_1233V M1_HV_1233V > 0
PO_LV_NV = NET AREA RATIO ILP1i OVER M9_LV_0011V M8_LV_0011V M7_LV_0011V M6_LV_0011V M5_LV_0011V M4_LV_0011V M3_LV_0011V M2_LV_0011V M1_LV_0011V M9_NV M8_NV M7_NV M6_NV M5_NV M4_NV M3_NV M2_NV M1_NV M9_VNV M8_VNV M7_VNV M6_VNV M5_VNV M4_VNV M3_VNV M2_VNV M1_VNV > 0

PO_NOMARK = (((ILP1i NOT PO_65V )NOT PO_5V) NOT PO_1233V) NOT PO_LV_NV

#IFDEF USE_IO_VOLTAGE_ON_CORE_TO_IO_NET
PO_NOMARK_65V = NET AREA RATIO PO_NOMARK PSD_65 NSD_65 PSTPix > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSTPix)]
PO_NOMARK_5V = NET AREA RATIO PO_NOMARK PSD_50 NSD_50 PSTPix > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)]
PO_NOMARK_1233V = NET AREA RATIO PO_NOMARK PSD_12_33 NSD_12_33 GATE_12_33 PSTPix > 0
    [(!!AREA(PSD_12_33)+!!AREA(NSD_12_33)+!!AREA(GATE_12_33))*!AREA(PSTPix)]
#ELSE

PO_NOMARK_65V = NET AREA RATIO PO_NOMARK PSD_65 NSD_65 PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSD_50)*!AREA(NSD_50)*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
PO_NOMARK_5V = NET AREA RATIO PO_NOMARK PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
PO_NOMARK_1233V = NET AREA RATIO PO_NOMARK PSD_12_33 NSD_12_33 GATE_12_33 PSTPix PSD_00_11 NSD_00_11 GATE_00_11 > 0
    [(!!AREA(PSD_12_33)+!!AREA(NSD_12_33)+!!AREA(GATE_12_33))*!AREA(PSTPix)*!AREA(PSD_00_11)*!AREA(NSD_00_11)*!AREA(GATE_00_11)]
#ENDIF
PO_65V_ALL = PO_65V OR PO_NOMARK_65V 
PO_5V_ALL = PO_5V OR PO_NOMARK_5V 
PO_1233V_ALL = PO_1233V OR PO_NOMARK_1233V
ILP1i_CO = ILP1i INTERACT CO
PO_1233V_CHK = ILP1i_CO AND PO_1233V_ALL









PSDc_edge = PSDc COIN INSIDE EDGE PACTi
NSDc_edge = NSDc COIN INSIDE EDGE NACTi
ODc_edge = ODc COIN INSIDE EDGE ODi
ODc_wi_CO_edge  = (ODc INTERACT CO) COIN INSIDE EDGE ODi
ODc_wo_CO_edge  = (ODc NOT INTERACT CO) COIN INSIDE EDGE ODi
ODc_NOTRHPO_edge = (ODc NOT INSIDE RHPO) COIN INSIDE EDGE ODi
ODc_NOTCO_RHPO_edge = ((ODc NOT INTERACT CO) INSIDE RHPO) COIN INSIDE EDGE ODi
ODc_RHPO_edge = (ODc INSIDE RHPO) COIN INSIDE EDGE ODi

POi_all = POi NOT (CPO OR CPO_SRM)
ILP1i_edge = ILP1i COIN INSIDE EDGE POi_all
ILP1i_wi_CO_edge = (ILP1i INTERACT CO) COIN INSIDE EDGE POi_all
ILP1i_RHPO_RPO = POi_all INTERACT (RHPO INTERACT RPOi)
ILP1i_RHPO_RPO_edge = (ILP1i INTERACT (RHPO INTERACT RPOi)) COIN INSIDE EDGE ILP1i_RHPO_RPO
POi_all_RHPO_RPO1 = POi_all AND (RHPO INTERACT RPO)
ILP1i_RHPO_RPO1_edge = (ILP1i AND (RHPO INTERACT RPO)) COIN INSIDE EDGE POi_all_RHPO_RPO1
SRDPO_RHPO_RPO  = SRDPO AND (RHPO INTERACT RPO)

VARIABLE DV_M_PRL_LENGTH 0.08
DV_M1_END = CONVEX EDGE M1i ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_M1_LINE = M1i NOT COIN INSIDE EDGE DV_M1_END
DV_DM1_O_END = CONVEX EDGE DM1_O ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_DM1_O_LINE = DM1_O NOT COIN INSIDE EDGE DV_DM1_O_END

DV_M2_END = CONVEX EDGE M2i ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_M2_LINE = M2i NOT COIN INSIDE EDGE DV_M2_END
DV_DM2_O_END = CONVEX EDGE DM2_O ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_DM2_O_LINE = DM2_O NOT COIN INSIDE EDGE DV_DM2_O_END

DV_M3_END = CONVEX EDGE M3i ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_M3_LINE = M3i NOT COIN INSIDE EDGE DV_M3_END
DV_DM3_O_END = CONVEX EDGE DM3_O ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_DM3_O_LINE = DM3_O NOT COIN INSIDE EDGE DV_DM3_O_END

DV_M4_END = CONVEX EDGE M4i ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_M4_LINE = M4i NOT COIN INSIDE EDGE DV_M4_END
DV_DM4_O_END = CONVEX EDGE DM4_O ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_DM4_O_LINE = DM4_O NOT COIN INSIDE EDGE DV_DM4_O_END

DV_M5_END = CONVEX EDGE M5i ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_M5_LINE = M5i NOT COIN INSIDE EDGE DV_M5_END
DV_DM5_O_END = CONVEX EDGE DM5_O ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_DM5_O_LINE = DM5_O NOT COIN INSIDE EDGE DV_DM5_O_END

DV_M6_END = CONVEX EDGE M6i ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_M6_LINE = M6i NOT COIN INSIDE EDGE DV_M6_END
DV_DM6_O_END = CONVEX EDGE DM6_O ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_DM6_O_LINE = DM6_O NOT COIN INSIDE EDGE DV_DM6_O_END

DV_M7_END = CONVEX EDGE M7i ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_M7_LINE = M7i NOT COIN INSIDE EDGE DV_M7_END
DV_DM7_O_END = CONVEX EDGE DM7_O ANGLE1==90 ANGLE2==90 WITH LENGTH < DV_M_PRL_LENGTH
DV_DM7_O_LINE = DM7_O NOT COIN INSIDE EDGE DV_DM7_O_END







NW55V = NWi INTERACT NW55
DNW55V = DNWi INTERACT NW55V

NW65V = NWi INTERACT NW65
DNW65V = DNWi INTERACT NW65V





OD12x = OD12 AND ODi
OD15x = OD15 AND ODi
OD18x = OD18 AND ODi
OD25x = OD25 AND ODi
OD33x = OD33 AND ODi

OD12x_18UnD = OD18x NOT OUTSIDE OD1812
OD15x_18UnD = OD18x NOT OUTSIDE OD1815
OD18x_15OvD = OD15x NOT OUTSIDE OD1518
OD18x_25UnD = OD25x NOT OUTSIDE OD2518
OD28x_25OvD = OD25x NOT OUTSIDE OD2528
OD33x_25OvD = OD25x NOT OUTSIDE OD2533



HVDRAIN33x = NSDi AND (HVD_33 AND HVN_65)

HVDRAIN50x = (HVD_N AND NSDi) OR (HVD_P AND PSDi)

HVDRAIN65x_pre = OR (HVN_65 AND NSDi) (HVP_65 AND PSDi) (HVN25_65 AND NSDi) (HVP25_65 AND PSDi)

HVDRAIN55x = HVDRAIN65x_pre AND HVD65_55
HVDRAIN65x = HVDRAIN65x_pre NOT INTERACT (OR HVD65_55 HVD_33)

DV_VOL_12  = OD12x OR OD12x_18UnD
DV_VOL_15  = (OD15x OUTSIDE OD1518) OR OD15x_18UnD

DV_VOL_18  = ((OD18x OUTSIDE (OR OD1815 OD1812)) NOT (OR HVDRAIN33x HVDRAIN50x HVDRAIN55x HVDRAIN65x)) OR (OR OD18x_15OvD OD18x_25UnD)
DV_VOL_25  = (OD25x OUTSIDE (OR OD2533 OD2528 OD2518)) NOT (OR HVDRAIN33x HVDRAIN50x HVDRAIN55x HVDRAIN65x)
DV_VOL_28  = COPY OD28x_25OvD
DV_VOL_33  = OR OD33x OD33x_25OvD HVDRAIN33x 
DV_VOL_50  = COPY HVDRAIN50x
DV_VOL_55  = COPY HVDRAIN55x 
DV_VOL_65  = COPY HVDRAIN65x


MRAM_RRAM_WAIVE = OR MRAM_MTJ_LVSi MRAM_N_CORE_OD22i MRAM_P_CORE_OD22i RRDMY_4i RRVDUHi

//core MOS
DV_PSD_CORE_device_pre = PSDc AND ((PSDc INTERACT (OD INTERACT GATE)) OUTSIDE OD2)
DV_PSD_CORE_device = DV_PSD_CORE_device_pre OUTSIDE MRAM_RRAM_WAIVE
DV_NSD_CORE_device_pre = NSDc AND ((NSDc INTERACT (OD INTERACT GATE)) OUTSIDE OD2)
DV_NSD_CORE_device = DV_NSD_CORE_device_pre OUTSIDE MRAM_RRAM_WAIVE

//core diode
DV_PSD_COREDIODE_device = PSDc AND ((PSDc NOT OUTSIDE DIODMY) OUTSIDE OD2)
DV_NSD_COREDIODE_device = NSDc AND ((NSDc NOT OUTSIDE DIODMY) OUTSIDE OD2)

//IO MOS and IO diode
//N/PSDc AND XXX for connect
DV_PSD_device =  PSDc AND  ((OR (PSDc INTERACT (OD INTERACT GATE)) (PSDc NOT OUTSIDE DIODMY)) NOT OUTSIDE OD2)
DV_NSD_device =  NSDc AND  ((OR (NSDc INTERACT (OD INTERACT GATE)) (NSDc NOT OUTSIDE DIODMY)) NOT OUTSIDE OD2)

//core gate
DV_GATE_device_CORE_pre = GATE AND (GATE NOT OD2)
DV_GATE_device_CORE = DV_GATE_device_CORE_pre NOT MRAM_RRAM_WAIVE

//IO gate
DV_GATE_device = GATE AND (GATE AND OD2)

//core VAR
DV_NVAR_device_CORE = NSTPi AND ((NSTPi NOT OUTSIDE VAR) OUTSIDE OD2)
DV_PVAR_device_WIRW_CORE = PSTPi AND (((PSTPi NOT OUTSIDE VAR) INSIDE RWi) OUTSIDE OD2)

//IO VAR
DV_NVAR_device = NSTPi AND ((NSTPi NOT OUTSIDE VAR) NOT OUTSIDE OD2)
DV_PVAR_device_WIRW = PSTPi AND (((PSTPi NOT OUTSIDE VAR) INSIDE RWi) NOT OUTSIDE OD2)

//core MOS
DV_PSD_core = COPY DV_PSD_CORE_device
//core diode
DV_PSD_DIODE_core = COPY DV_PSD_COREDIODE_device
//core MOS
DV_NSD_core = COPY DV_NSD_CORE_device
//core diode
DV_NSD_DIODE_core = COPY DV_NSD_COREDIODE_device

//core gate
DV_GATE_core = COPY DV_GATE_device_CORE

//IO MOS and IO diode
DV_PSD_12 = DV_PSD_device NOT OUTSIDE  DV_VOL_12
DV_PSD_15 = DV_PSD_device NOT OUTSIDE  DV_VOL_15
DV_PSD_18 = DV_PSD_device NOT OUTSIDE  DV_VOL_18
DV_PSD_25 = DV_PSD_device NOT OUTSIDE  DV_VOL_25
DV_PSD_28 = DV_PSD_device NOT OUTSIDE  DV_VOL_28
DV_PSD_33 = DV_PSD_device NOT OUTSIDE  DV_VOL_33
DV_PSD_50 = DV_PSD_device NOT OUTSIDE  DV_VOL_50
DV_PSD_55 = DV_PSD_device NOT OUTSIDE  DV_VOL_55
DV_PSD_65 = DV_PSD_device NOT OUTSIDE  DV_VOL_65

DV_NSD_12 = DV_NSD_device NOT OUTSIDE  DV_VOL_12
DV_NSD_15 = DV_NSD_device NOT OUTSIDE  DV_VOL_15
DV_NSD_18 = DV_NSD_device NOT OUTSIDE  DV_VOL_18
DV_NSD_25 = DV_NSD_device NOT OUTSIDE  DV_VOL_25
DV_NSD_28 = DV_NSD_device NOT OUTSIDE  DV_VOL_28
DV_NSD_33 = DV_NSD_device NOT OUTSIDE  DV_VOL_33
DV_NSD_50 = DV_NSD_device NOT OUTSIDE  DV_VOL_50
DV_NSD_55 = DV_NSD_device NOT OUTSIDE  DV_VOL_55
DV_NSD_65 = DV_NSD_device NOT OUTSIDE  DV_VOL_65

DV_GATE_12 = DV_GATE_device AND  DV_VOL_12
DV_GATE_15 = DV_GATE_device AND  DV_VOL_15
DV_GATE_18 = DV_GATE_device AND  DV_VOL_18
DV_GATE_25 = DV_GATE_device AND  DV_VOL_25
DV_GATE_28 = DV_GATE_device AND  DV_VOL_28
DV_GATE_33 = DV_GATE_device AND  DV_VOL_33
DV_GATE_50 = DV_GATE_device AND  DV_VOL_50
DV_GATE_55 = DV_GATE_device AND  DV_VOL_55
DV_GATE_65 = DV_GATE_device AND  DV_VOL_65


//core VAR
DV_NVAR_core  = COPY DV_NVAR_device_CORE
DV_PVAR_core_WIRW = COPY DV_PVAR_device_WIRW_CORE

//IO VAR
DV_NVAR_18  = DV_NVAR_device NOT OUTSIDE OD18i
DV_PVAR_18_WIRW = DV_PVAR_device_WIRW NOT OUTSIDE OD18i
DV_NVAR_25  = DV_NVAR_device NOT OUTSIDE OD25i
DV_PVAR_25_WIRW = DV_PVAR_device_WIRW NOT OUTSIDE OD25i

//MRAM
DV_NSD_MRAM_1T_22 = DV_NSD_CORE_device_pre NOT OUTSIDE MRAM_MTJ_LVSi
DV_GATE_MRAM_1T_22 = DV_GATE_device_CORE_pre AND MRAM_MTJ_LVSi

DV_NSD_MRAM_22 = DV_NSD_CORE_device_pre NOT OUTSIDE MRAM_N_CORE_OD22i
DV_PSD_MRAM_22 = DV_PSD_CORE_device_pre NOT OUTSIDE MRAM_P_CORE_OD22i
DV_GATE_MRAM_22 = DV_GATE_device_CORE_pre AND (OR MRAM_N_CORE_OD22i MRAM_P_CORE_OD22i)

//RRAM
DV_NSD_RRAM_1T_29_25 = DV_NSD_CORE_device_pre NOT OUTSIDE RRDMY_4i
DV_GATE_RRAM_1T_29 = DV_GATE_device_CORE_pre AND RRDMY_4i

DV_NSD_RRAM_18 = DV_NSD_CORE_device_pre NOT OUTSIDE RRVDUHi
DV_PSD_RRAM_18 = DV_PSD_CORE_device_pre NOT OUTSIDE RRVDUHi
DV_GATE_RRAM_18 = DV_GATE_device_CORE_pre AND RRVDUHi





















PSTP_00 = PSTPi NOT INSIDE RWi

