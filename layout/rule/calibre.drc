VIA5R10_VIA5Marker = VIA5ii AND RRuleRecommended
VIA5R10_VIA5 = ((VIA5R10_VIA5Cell OR VIA5R10_VIA5Marker) NOT Block ) NOT excludeRRuleRecommended

//'VIAx.R.10.R' is checked by RR:RE:VIA5.R.10
RR:RE:VIA5.R.10 { @ Recommended VIAx space to VIAx+1 [different net and parallel run length > 0.02 um] >= 0.06 
  CHECK_VIA =  VIA5ii INTERACT VIA5R10_VIA5   
  X = EXT [CHECK_VIA] VIA6ii < VIA5_R_10_R ABUT < 90 OPPOSITE NOT CONNECTED
  LENGTH X > VIA5_R_10_L_R
}
#ENDIF
#ENDIF

