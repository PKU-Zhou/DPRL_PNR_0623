VARIABLE  PO_S_50_2_V 5
VARIABLE  PO_S_50_2 0.105
PO_S_50_2_CHECK2 = COPY ILP1i_wi_CO_edge
PO_S_50_2_CHECK  = COPY ODc_wi_CO_edge
PO.S.50.2 { @ {{PO NOT CPO} INTERACT CO} space to OD [INTERACT CO] [maximum delta V >= 5V] >= 0.105 
  err_1 = DFM DV PO_S_50_2_CHECK2 PO_S_50_2_CHECK < PO_S_50_2 ABUT < 90  NOT CONNECTED MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" >= PO_S_50_2_V   ANNOTATE
  err_1_f =  DFM PROPERTY err_1 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_1, "SECOND_VMAX")]
  [ DELTA_V = property(err_1, "DELTA_V")]
  [ SYNC = property(err_1, "SYNC")]  
  DFM COPY err_1_f
  DFM RDB err_1_f "PO.S.50.2.rep" NOEMPTY NOPSEUDO

}

VARIABLE  PO_S_54_A_V 3.300
VARIABLE  PO_S_54_A 0.070
PO_S_54_A_ACT_IMP = (PP AND NW) OR (NP NOT NW)
PO_S_54_A_EXCEPT = (OR SRDOD (ODc NOT INTERACT CO)) INSIDE PO_S_54_A_ACT_IMP
PO_S_54_A_CHECK2 = COPY ILP1i_wi_CO_edge
PO.S.54.a { @ {{PO NOT CPO} INTERACT CO} space to {OD OR SR_DOD} [maximum delta V > 3.3V] (except ACTIVE dummy OD) Definition of ACTIVE dummy OD: {SR_DOD OR {OD NOT INTERACT CO}} inside {PP AND NW} or {NP NOT NW} >= 0.07 
  err_1 = DFM DV PO_S_54_A_CHECK2 ODc_edge < PO_S_54_A ABUT < 90  NOT CONNECTED MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > PO_S_54_A_V   ANNOTATE
  err_1_f =  DFM PROPERTY err_1 PO_S_54_A_EXCEPT OVERLAP ABUT ALSO MULTI
  [ -= COUNT(PO_S_54_A_EXCEPT) ] == 0
  [ FIRST_VMIN = property(err_1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_1, "SECOND_VMAX")]
  [ DELTA_V = property(err_1, "DELTA_V")]
  [ SYNC = property(err_1, "SYNC")]  
  DFM COPY err_1_f
  DFM RDB err_1_f "PO.S.54.a.rep" NOEMPTY NOPSEUDO
  err_dmy1 = DFM DV PO_S_54_A_CHECK2 SRDOD WITH DEFAULT VOLTAGES < PO_S_54_A ABUT < 90  MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > PO_S_54_A_V   ANNOTATE
  err_dmy1_f =  DFM PROPERTY err_dmy1 PO_S_54_A_EXCEPT OVERLAP ABUT ALSO MULTI
  [ -= COUNT(PO_S_54_A_EXCEPT) ] == 0
  [ FIRST_VMIN = property(err_dmy1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_dmy1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_dmy1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_dmy1, "SECOND_VMAX")]
  [ DELTA_V = property(err_dmy1, "DELTA_V")]
  [ SYNC = property(err_dmy1, "SYNC")]  
  DFM COPY err_dmy1_f
  DFM RDB err_dmy1_f "PO.S.54.a.rep" NOEMPTY NOPSEUDO

}


