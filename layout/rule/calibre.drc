#IFDEF CHECK_EFPM7S2_
#IFDEF _EFPM7S2_
EFPM7S2_M7iCellIn = INSIDE CELL M7i CellsForRRuleRecommended  
EFPM7S2_M7iCellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
EFPM7S2_M7iCell = EFPM7S2_M7iCellIn AND EFPM7S2_M7iCellOut
EFPM7S2_M7iMarker = M7i AND RRuleRecommended
EFPM7S2_M7i = ((EFPM7S2_M7iCell OR EFPM7S2_M7iMarker) NOT Block ) NOT excludeRRuleRecommended

// M7 Type Cap
//=============
RR:RE:EFP.M7.S.2 { @ Cap recommendation: Recommended the line-end space at Mx [line width (W2) = 0.05 um, length (L3) >= 0.15 um] in a line-end configuration: If both longer edges of Mx line-end have parallel run length [0.005 um ~ 0.115 um (L2)] to Mx [space to Mx line-end 0.05 um (S1), and both Mxs are part of one polygon] >= 0.115 
  M7_NOTCH_LL = (((EXPAND EDGE M7_L_END_edge INSIDE BY TypeLEH_LL-GRID) AND M7i) WITH EDGE M7_L_END_edge) INTERACT M7_jog_CORNER_waive

  M7_NOTCH_pre = EXT M7i < TypeLEH_NOTCH ABUT < 90 NOTCH OPPOSITE REGION
  M7_NOTCH = (ENCLOSE RECTANGLE M7_NOTCH_pre TypeLEH_NOTCH-3*GRID GRID) INTERACT M7i > 1
  M7_NOTCH_candidate1 = ENCLOSE RECTANGLE (M7i INTERACT M7_NOTCH) TypeLEH_LL Mx_W
  M7_NOTCH_candidate2 = EXT M7_NOTCH_candidate1 <= TypeLEH_S2 ABUT < 90 OPPOSITE REGION
  M7_NOTCH_candidate3 = (M7_L_END_edge TOUCH EDGE M7_NOTCH_candidate2) INSIDE EDGE M7_NOTCH
  M7_NOTCH_candidate4 = EXPAND EDGE M7_NOTCH_candidate3 INSIDE BY GRID
  M7_NOTCH_candidate5 = (VERTEX (SIZE M7_NOTCH_candidate4 BY TypeLEH_marker-GRID INSIDE OF M7_NOTCH_candidate1 STEP Mx_S *0.7) == 4) INTERACT M7_NOTCH
  M7_NOTCH_candidate6 = EXT [M7_NOTCH_candidate5] M7i <= Mx_S+GRID ABUT < 90 OPPOSITE
  M7_NOTCH_candidate7 = INT (M7_NOTCH_candidate5 NOT COIN EDGE M7_NOTCH_candidate6) <= Mx_W ABUT < 90 OPPOSITE REGION
  M7_NOTCH_candidate = (M7_NOTCH_candidate5 INTERACT M7_NOTCH_candidate7) NOT INTERACT M7_NOTCH_LL
  M7_NOTCH_candidate INTERACT EFPM7S2_M7i
}
#ENDIF
#ENDIF
// EFP.Mx.S.2.R is checked by RR:RE:EFP.M7.S.2

#IFDEF CHECK_EFPM7S3_
#IFDEF _EFPM7S3_
EFPM7S3_M7iCellIn = INSIDE CELL M7i CellsForRRuleRecommended  
EFPM7S3_M7iCellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
EFPM7S3_M7iCell = EFPM7S3_M7iCellIn AND EFPM7S3_M7iCellOut
EFPM7S3_M7iMarker = M7i AND RRuleRecommended
EFPM7S3_M7i = ((EFPM7S3_M7iCell OR EFPM7S3_M7iMarker) NOT Block ) NOT excludeRRuleRecommended

// M7 Type Hook 
//=============
TypeHook_M7_H2		  = CONVEX EDGE EFPM7S3_M7i ANGLE1==270 ANGLE2==270 WITH LENGTH <= TypeH_LB
TypeHook_M7_H2_corner	  = EXT TypeHook_M7_H2 [M7] < TypeH_LB ABUT==90 
TypeHook_M7_H2_W	  = INT EFPM7S3_M7i (EFPM7S3_M7i TOUCH EDGE TypeHook_M7_H2_corner) <= TypeH_W ABUT<90 REGION
TypeHook_M7_H2_W_out	  = TypeHook_M7_H2_W NOT TOUCH EDGE TypeHook_M7_H2_corner
TypeHook_M7_H2_L_chk	  = TypeHook_M7_H2_corner TOUCH EDGE TypeHook_M7_H2_W 
TypeHook_M7_H2_OC_pre1	  = (CONVEX EDGE EFPM7S3_M7i ANGLE1==270 ANGLE2==90 ) TOUCH EDGE TypeHook_M7_H2_L_chk
TypeHook_M7_H2_OC_pre2	  = EXT [TypeHook_M7_H2_OC_pre1] TypeHook_M7_H2 <= TypeH_LB ABUT==90 
TypeHook_M7_H2_OC	  = TypeHook_M7_H2_OC_pre2 NOT COIN EDGE (INT EFPM7S3_M7i TypeHook_M7_H2_OC_pre2 < DB_GRID ABUT ==90 REGION)
TypeHook_M7_H2_OC_chk	  = EXT [TypeHook_M7_H2_L_chk] TypeHook_M7_H2_OC < TypeH_S2 ABUT<90 OPPOSITE
TypeHook_M7_H2_IC_OClng  = TypeHook_M7_H2 NOT TOUCH EDGE (TypeHook_M7_H2 NOT COIN EDGE TypeHook_M7_H2_OC_chk)
TypeHook_M7_H2_corner_L  = EXT TypeHook_M7_H2_L_chk [TypeHook_M7_H2] < DB_GRID ABUT==90
TypeHook_M7_H2_corner_IC = EXT [TypeHook_M7_H2] <DB_GRID ABUT==90 
TypeHook_M7_H2_corner_IC_OClng = EXT [TypeHook_M7_H2] TypeHook_M7_H2_IC_OClng <DB_GRID ABUT==90 
TypeHook_M7_H2_short	  = LENGTH TypeHook_M7_H2 < TypeH_S2
TypeHook_M7_H2_corner_err = DFM PROPERTY TypeHook_M7_H2 TypeHook_M7_H2_corner_L TypeHook_M7_H2_corner_IC TypeHook_M7_H2_corner_IC_OClng TypeHook_M7_H2_short OVERLAP ABUT ALSO MULTI
				    [ -= COUNT(TypeHook_M7_H2_short)] >0
				    [ -= COUNT(TypeHook_M7_H2_corner_IC)] >0
				    [ -= COUNT(TypeHook_M7_H2_corner_IC_OClng)] >0
				    [ -= COUNT(TypeHook_M7_H2_corner_L)] >1
TypeHook_M7_H2_err	  = EXPAND EDGE (TypeHook_M7_H2 TOUCH EDGE TypeHook_M7_H2_corner_err) BY 0.001
TypeHook_M7		  = COPY TypeHook_M7_H2_err
RR:RE:EFP.M7.S.3 { @ Hook recommendation: Recommended space from the edge [length <= 0.065 um (L4) between the edges of line width <= 0.055 um (W3 and W3') and either one of the edges >= 0.15 um (L5)] of Mx pattern [with 3 consecutive 270-270-270 degree inner angles] to opposite edge of the same Mx >= 0.155 
   COPY TypeHook_M7 
}
#ENDIF
#ENDIF
// EFP.Mx.S.3.R is checked by RR:RE:EFP.M7.S.3

#IFDEF CHECK_EFPM7S5_
#IFDEF _EFPM7S5_
EFPM7S5_M7iCellIn = INSIDE CELL M7i CellsForRRuleRecommended  
EFPM7S5_M7iCellOut = NOT INSIDE CELL M7i ExclCellsForRRuleRecommended 
EFPM7S5_M7iCell = EFPM7S5_M7iCellIn AND EFPM7S5_M7iCellOut
EFPM7S5_M7iMarker = M7i AND RRuleRecommended
EFPM7S5_M7i = ((EFPM7S5_M7iCell OR EFPM7S5_M7iMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:EFP.M7.S.5 { @ Metal bridge recommendation type-1: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3] when there is no other Mx cut Region B1/B2 Definitions: 1. Region B3 = 0.25 um * S2, generated from vertex CA/CB. 2. S2 = 2 Mx (polygon3/4) with parallel run length 0 um > S2 >= 0.235 um 3. Region B1/B2 = 0.16 um * 0.23 um, generated from Mx (polygon3/4) metal line-end with vertex CA/CB respectively >= 0.055 
  M7_TypeBRS1_prefilter_1 = EXT [M7i] == TypeBRS1_S2 ABUT < 90 OPPOSITE EXTENDED TypeBRS1_S3+NANO
  M7_TypeBRS1_CORNER_pre_1_1 = M7_CORNER_S1 WITH EDGE M7_TypeBRS1_prefilter_1
  M7_TypeBRS1_CORNER_pre_1_2 = EXT [M7_L_END_edge] M7i < TypeBRS1_S5 OPPOSITE
  M7_TypeBRS1_CORNER_pre_1 = M7_TypeBRS1_CORNER_pre_1_1 NOT WITH EDGE M7_TypeBRS1_CORNER_pre_1_2
  M7_TypeBRS1_CORNER_pre_2 = EXT M7_TypeBRS1_CORNER_pre_1 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION
  M7_TypeBRS1_CORNER_pre_3 = M7_TypeBRS1_CORNER_pre_2 INTERACT (M7_TypeBRS1_CORNER_pre_2 AND M7i) > 1
  M7_TypeBRS1_CORNER_pre_4 = M7_TypeBRS1_CORNER_pre_1 INTERACT M7_TypeBRS1_CORNER_pre_3
  
  M7_TypeBRS1_CACB_S23 = EXT M7_TypeBRS1_CORNER_pre_4 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M7_TypeBRS1_CACB_S23_1_1 = M7_TypeBRS1_CACB_S23 INTERACT M7_CORNER_S1 >= 2
  
  M7_TypeBRS1_CACB_S23_1_2 = INT (M7i AND M7_TypeBRS1_CACB_S23_1_1) == Mx_W OPPOSITE REGION
  M7_TypeBRS1_CACB_S23_1_3 = EXPAND EDGE (M7i COIN INSIDE EDGE M7_TypeBRS1_CACB_S23_1_2) OUTSIDE BY Mx_S
  M7_TypeBRS1_CACB_S23_1_4 = M7_TypeBRS1_CACB_S23_1_2 OR M7_TypeBRS1_CACB_S23_1_3
  M7_TypeBRS1_CACB_S23_1_5 = (EXT (M7_TypeBRS1_CORNER_pre_4 INTERACT M7_TypeBRS1_CACB_S23_1_1) >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION) AND M7_TypeBRS1_CACB_S23_1_4
  M7_TypeBRS1_CACB_S23_1_6 = (M7_TypeBRS1_CORNER_pre_4 INTERACT M7_TypeBRS1_CACB_S23_1_1) INTERACT (SIZE M7_TypeBRS1_CACB_S23_1_5 BY GRID)
  M7_TypeBRS1_CACB_S23_1_7 = EXT M7_TypeBRS1_CACB_S23_1_6 >= TypeBRS1_S2 <= TypeBRS1_S2S3 CORNER TO CORNER REGION EXTENTS
  M7_TypeBRS1_CACB_S23_1 = M7_TypeBRS1_CACB_S23_1_7 INTERACT M7_TypeBRS1_CACB_S23_1_6 >= 2
  
  M7_TypeBRS1_CACB_S23_2 = ((EXPAND EDGE (LENGTH ((SIZE M7_TypeBRS1_CACB_S23_1 BY -NANO) AND M7i) == Mx_W) OUTSIDE BY 2*NANO) OR (M7_TypeBRS1_CACB_S23_1 AND M7i)) AND M7_TypeBRS1_CACB_S23_1
  M7_TypeBRS1_CACB_S23_3 = (M7_TypeBRS1_CACB_S23_2 AND M7_TypeBRS1_CACB_S23_1) COIN EDGE M7_TypeBRS1_CACB_S23_1
  M7_TypeBRS1_CACB_S23_4 = M7_TypeBRS1_CACB_S23_1 INTERACT (M7_TypeBRS1_CACB_S23_1 AND M7i) == 2
  M7_TypeBRS1_CACB_S23_5 = M7_TypeBRS1_CACB_S23_4 WITH EDGE M7_TypeBRS1_CACB_S23_3 == 4
  M7_TypeBRS1_CACB_EDGE1 = M7i TOUCH OUTSIDE EDGE M7_TypeBRS1_CACB_S23_5	//CA and CB EDGE
  M7_TypeBRS1_CACB_EDGE2 = EXPAND EDGE M7_TypeBRS1_CACB_EDGE1 OUTSIDE BY GRID			
  M7_TypeBRS1_CACB_EDGE3_1 = EXT M7_TypeBRS1_CACB_EDGE1 M7i == Mx_S OPPOSITE REGION
  M7_TypeBRS1_CACB_EDGE3_2 = EXT M7_TypeBRS1_CACB_EDGE1 M7_TypeBRS1_CACB_S23_2 == Mx_S OPPOSITE REGION
  M7_TypeBRS1_CACB_EDGE4 = M7_TypeBRS1_CACB_EDGE2 NOT M7_TypeBRS1_CACB_EDGE3_1
  M7_TypeBRS1_CACB_EDGE5 = LENGTH M7_TypeBRS1_CACB_EDGE4 == GRID
  M7_TypeBRS1_CACB_EDGE6 = EXPAND EDGE M7_TypeBRS1_CACB_EDGE5 OUTSIDE BY GRID
  M7_TypeBRS1_CACB_EDGE7 = (M7_TypeBRS1_CACB_EDGE6 TOUCH M7_TypeBRS1_CACB_EDGE3_1) OR (M7_TypeBRS1_CACB_EDGE6 TOUCH M7_TypeBRS1_CACB_EDGE3_2)
  
   
  M7_TypeBRS1_CACB_EDGE8_1 = M7_TypeBRS1_CACB_EDGE7 COIN OUTSIDE EDGE M7_TypeBRS1_CACB_EDGE4
  M7_TypeBRS1_CACB_EDGE8 = M7_TypeBRS1_CACB_EDGE8_1 NOT TOUCH EDGE (EXT [M7_TypeBRS1_CACB_EDGE8_1] M7i < TypeBRS1_S4 OPPOSITE)
  
  M7_TypeBRS1_CACB_EDGE9 = EXPAND EDGE M7_TypeBRS1_CACB_EDGE8 OUTSIDE BY TypeBRS1_S4
  M7_TypeBRS1_CACB_EDGE10 = M7_CORNER TOUCH M7_TypeBRS1_CACB_EDGE4
  
  M7_TypeBRS1_CACB_EDGE11_1 = M7_TypeBRS1_CACB_EDGE9 TOUCH OUTSIDE EDGE M7_TypeBRS1_CACB_EDGE10
  M7_TypeBRS1_CACB_EDGE11 = M7_TypeBRS1_CACB_EDGE11_1 NOT TOUCH EDGE (ENC M7i [M7_TypeBRS1_CACB_EDGE11_1] < TypeBRS1_S5 OPPOSITE)
  
  M7_TypeBRS1_CACB_EDGE12 = ENCLOSE RECTANGLE (EXPAND EDGE M7_TypeBRS1_CACB_EDGE11 INSIDE BY TypeBRS1_S5) TypeBRS1_S4 TypeBRS1_S5
  M7_TypeBRS1_CACB_ERROR1 = M7_TypeBRS1_CACB_EDGE12 AND M7i
  M7_TypeBRS1_CACB_ERROR2 = (ENC M7_TypeBRS1_CACB_ERROR1 [M7_TypeBRS1_CACB_EDGE11] <= TypeBRS1_S5 OPPOSITE) OR EDGE (M7_TypeBRS1_CACB_EDGE11 TOUCH EDGE M7_TypeBRS1_CACB_ERROR1)
  M7_TypeBRS1_CACB_ERROR3 = (M7_TypeBRS1_CACB_EDGE11 NOT TOUCH EDGE M7_TypeBRS1_CACB_ERROR2) TOUCH EDGE M7_TypeBRS1_CACB_EDGE12
  M7_TypeBRS1_CACB_ERROR4 = EXPAND EDGE M7_TypeBRS1_CACB_ERROR3 INSIDE BY TypeBRS1_S5
  M7_TypeBRS1_CACB_ERROR5 = ENCLOSE RECTANGLE (M7_TypeBRS1_CACB_ERROR4 NOT ENCLOSE M7_TypeBRS1_CACB_ERROR1) TypeBRS1_S4 TypeBRS1_S5
