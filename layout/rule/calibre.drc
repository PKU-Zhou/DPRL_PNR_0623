  B = EXT [VTULP] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = INT B >= VTULP_R_3_A < VTULP_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = INT B >= VTULP_R_3_B < VTULP_W_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = INT VTULP < VTULP_W_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
VTUL_P.S.1 { @ Space >= ^VTULP_S_1 
  A = EXT VTULP < VTULP_S_1 ABUT < 90 REGION PROJ==0
  B = INT [VTULP] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = EXT B >= VTULP_R_3_A < VTULP_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = EXT B >= VTULP_R_3_B < VTULP_S_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = EXT VTULP < VTULP_S_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
VTUL_P.S.2__VTUL_P.S.3 { @ Space to gate in PO endcap direction >= ^VTULP_S_2 & in S/D direction >= ^VTULP_S_3, VTULP cut {ACTIVE OR GATE} is not allowed.
  A = GATE NOT INTERACT VTULP
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (VTULP_S_3 - VTULP_S_2)) OR A
  C = SIZE B BY VTULP_S_2
  VTULP AND C
  DACT CUT VTULP
  GATE CUT VTULP
}
VTUL_P.S.4 { @ Space to unsilicided OD or high R resistor >= 0.15 
  EXT VTULP AYRE < VTULP_S_4 ABUT < 90 SINGULAR REGION
  AND VTULP AYRE    
}  
VTUL_P.S.5 { @ Space [parallel run length > 0.33 um, VTUL_P space without INTERACT {{OD OR SR_DOD} OR DOD}] >= 0.25 
  X = EXT VTULP < VTULP_S_5 OPPOSITE REGION
  Y = X NOT INTERACT ALL_OD
  ENCLOSE RECTANGLE Y GRID VTULP_S_5_L+GRID ORTHOGONAL ONLY
}
VTUL_P.EN.1__VTUL_P.EN.2 { @ Enclosure of gate in S/D direction >= ^VTULP_EN_1 & in PO endcap direction >= ^VTULP_EN_2 
  A = GATE INTERACT VTULP
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (VTULP_EN_1 - VTULP_EN_2)) OR A
  C = SIZE B BY VTULP_EN_2
  C NOT VTULP
}

VTUL_P.L.1 { @ 45-degree edge length >= ^VTULP_L_1 
  VTULP_EDGE_45 = VTULP ANGLE == 45
  LENGTH VTULP_EDGE_45 < VTULP_L_1  
}
VTUL_P.A.1 { @ Area >= ^VTULP_A_1
  AREA (VTULP NOT INSIDE DMY_SCH) < VTULP_A_1
}
VTUL_P.A.1.1 { @ Area >= ^VTULP_A_1_1
  AREA (VTULP INSIDE DMY_SCH) < VTULP_A_1_1
}
VTUL_P.A.2 { @ Enclosed area >= ^VTULP_A_2
  A = HOLES VTULP INNER
  B = A NOT VTULP
  AREA (B NOT INSIDE DMY_SCH) < VTULP_A_2
}
VTUL_P.A.2.1 { @ Enclosed area >= ^VTULP_A_2_1
  A = HOLES VTULP INNER
  B = A NOT VTULP
  AREA (B  INSIDE DMY_SCH) < VTULP_A_2_1
}

// VTUL_P.R.2 and VTUL_P.R.3 are checked by VTUL_P.W.1 and VTUL_P.S.1
VTUL_P.R.1 { @ Overlap of N+ACTIVE (including varactor GATE), VTH_P, VTH_N, VTL_N, VTL_P, VTUL_N, NT_N or OD2 is not allowed.   
  VTULP AND OD2
  VTULP AND NTN
  VTULP AND NACT  
  VTULP AND VTLN
  VTULP AND VTLP
  VTULP AND VTULN
  VTULP AND VTHN
  VTULP AND VTHP
  VTULP AND VTUHN
  VTULP AND VTUHP
  VTULP AND EHVT_N
  VTULP AND EHVT_P
}



//UHVT_N CHECKS
//============

UHVT_N.W.1 { @ Width >= ^VTUHN_W_1  
  A = INT VTUHN < VTUHN_W_1 ABUT < 90 REGION PROJ==0
  B = EXT [VTUHN] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = INT B >= VTUHN_R_3_A < VTUHN_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = INT B >= VTUHN_R_3_B < VTUHN_W_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = INT VTUHN < VTUHN_W_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
UHVT_N.S.1 { @ Space >= ^VTUHN_S_1 
  A = EXT VTUHN < VTUHN_S_1 ABUT < 90 REGION PROJ==0
  B = INT [VTUHN] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = EXT B >= VTUHN_R_3_A < VTUHN_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = EXT B >= VTUHN_R_3_B < VTUHN_S_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = EXT VTUHN < VTUHN_S_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
UHVT_N.S.2__UHVT_N.S.3 { @ Space to gate in PO endcap direction >= ^VTUHN_S_2 & in S/D direction >= ^VTUHN_S_3, VTUHN cut {ACTIVE OR GATE} is not allowed.
  A = GATE NOT INTERACT VTUHN
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (VTUHN_S_3 - VTUHN_S_2)) OR A
  C = SIZE B BY VTUHN_S_2
  (VTUHN AND C) NOT INSIDE SRAM_WAIVE_N28
  (DACT CUT VTUHN) NOT INSIDE SRAM_WAIVE_N28
  (GATE CUT VTUHN) NOT INSIDE SRAM_WAIVE_N28
}
UHVT_N.S.4 { @ Space to unsilicided OD or high R resistor >= 0.15 
  EXT VTUHN AYRE < VTUHN_S_4 ABUT < 90 SINGULAR REGION
  AND VTUHN AYRE    
}  
UHVT_N.S.5 { @ Space [parallel run length > 0.33 um, UHVT_N space without INTERACT {{OD OR SR_DOD} OR DOD}] >= 0.25 
  X = EXT VTUHN < VTUHN_S_5 OPPOSITE REGION
  Y = X NOT INTERACT ALL_OD
  ENCLOSE RECTANGLE Y GRID VTUHN_S_5_L+GRID ORTHOGONAL ONLY
}
UHVT_N.EN.1__UHVT_N.EN.2 { @ Enclosure of gate in S/D direction >= ^VTUHN_EN_1 & in PO endcap direction >= ^VTUHN_EN_2 
  A = GATE INTERACT VTUHN
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (VTUHN_EN_1 - VTUHN_EN_2)) OR A
  C = SIZE B BY VTUHN_EN_2
  C NOT VTUHN
}
UHVT_N.L.1 { @ 45-degree edge length >= ^VTUHN_L_1 
  VTUHN_EDGE_45 = VTUHN ANGLE == 45
  LENGTH VTUHN_EDGE_45 < VTUHN_L_1  
}
UHVT_N.A.1 { @ Area >= ^VTUHN_A_1
  AREA (VTUHN NOT INSIDE DMY_SCH) < VTUHN_A_1
}
UHVT_N.A.1.1 { @ Area >= ^VTUHN_A_1_1
  AREA (VTUHN INSIDE DMY_SCH) < VTUHN_A_1_1
}
UHVT_N.A.2 { @ Enclosed area >= ^VTUHN_A_2
  A = HOLES VTUHN INNER
  B = A NOT VTUHN
  AREA (B NOT INSIDE DMY_SCH) < VTUHN_A_2
}
UHVT_N.A.2.1 { @ Enclosed area >= ^VTUHN_A_2_1
  A = HOLES VTUHN INNER
  B = A NOT VTUHN
  AREA (B INSIDE DMY_SCH) < VTUHN_A_2_1
}

// UHVT_N.R.2 and UHVT_N.R.3 are checked by UHVT_N.W.1 and UHVT_N.S.1
UHVT_N.R.1 { @ Overlap of P+ ACTIVE, VAR, UHVT_P, VTH_N, VTH_P, VTL_N, VTL_P, VTUL_N, VTUL_P, EHVT_N, EHVT_P, NT_N, or OD2 is not allowed   
  VTUHN AND VAR
  VTUHN AND OD2
  VTUHN AND NTN
  VTUHN AND PACT
  VTUHN AND VTHN
  VTUHN AND VTHP
  VTUHN AND VTLN
  VTUHN AND VTLP
  VTUHN AND VTUHP
  VTUHN AND VTULN
  VTUHN AND VTULP
	VTUHN AND EHVT_N
  VTUHN AND EHVT_P
}
UHVT_N.R.4 { @ At CHIP level, only 4 or fewer of the following 5 device types are allowed. LOGIC (4 VT types): (1) ultra low Vt = {VTUL_N OR VTUL_P} (2) low Vt = {VTL_N OR VTL_P} (3) high Vt = {VTH_N OR VTH_P} (4) ultra high Vt = {UHVT_N OR UHVT_P} SRAM (1 cell implant types): (5) standard = {SRM}   
  VT_UL = VTULN OR VTULP 
  VT_L = VTLN OR VTLP
  VT_H = VTHN OR VTHP
  VT_UH = VTUHN OR VTUHP
  STD     = COPY SRM

	CHIP_DV = DFM PROPERTY CHIP VT_UH VT_H VT_L VT_UL STD OVERLAP ABUT ALSO MULTI
   [ DV1 = (AREA(VT_UH)>0) ? 1 : 0 ]
   [ DV2 = (AREA(VT_H)>0) ? 1 : 0 ]
   [ DV3 = (AREA(VT_L)>0) ? 1 : 0 ]
   [ DV4 = (AREA(VT_UL)>0) ? 1 : 0 ]
   [ DV5 = (AREA(STD)>0) ? 1 : 0 ]

  DFM PROPERTY CHIP_DV 
  [-= PROPERTY(CHIP_DV,DV1)+PROPERTY(CHIP_DV,DV2)+PROPERTY(CHIP_DV,DV3)+PROPERTY(CHIP_DV,DV4)+PROPERTY(CHIP_DV,DV5)] >4
}


