  INT X2 < CSR_L_1A ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
// CSR.W.1 is checked by CSR.W.1:M8
// CSR.L.1 is checked by CSR.L.1:M8
CSR.W.1:M9 { @ Width of reinforced metal structure = 9~10 Width of reinforced metal structure >= ^CSR_W_1A um <= ^CSR_W_1B um
  Reinforced_M9_CHK = ((CSR_M9_P4 NOT SEALRING_ORI) NOT CSR_M9_D) INTERACT CSR_M9_HOLE
  E = Reinforced_M9_CHK NOT WITH WIDTH >= CSR_W_1A <= CSR_W_1B
  CSR_M9_HOLE_R = HOLES CSR_M9_P4  
  A = Reinforced_M9_CHK COIN OUTSIDE EDGE CSR_M9_HOLE_R
  B = (Reinforced_M9_CHK NOT COIN OUTSIDE EDGE CSR_M9_HOLE_R)COIN INSIDE EDGE CSR_M9_P4  
  X1 = ANGLE A != 45
  X2 = ANGLE A == 45
  Y1 = ANGLE B != 45
  Y2 = ANGLE B == 45
  C1 = INT X1 Y1 > CSR_W_1B < CSR_W_1B*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  D1 = INT X1 Y1 >=CSR_W_1A <= CSR_W_1B ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  C2 = INT X2 Y2 > CSR_W_1B+GRID < CSR_W_1B*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  D2 = INT X2 Y2 >CSR_W_1A-GRID < CSR_W_1B+GRID ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  C =C1 OR C2
  D =D1 OR D2
  F = RECTANGLE C >= CSR_W_1A BY >= CSR_W_1B ORTHOGONAL ONLY
  (F OR E)NOT D
}
CSR.L.1:M9 { @ Length of reinforced metal structure = 24~25 Length of reinforced metal structure >= ^CSR_L_1A um <= ^CSR_L_1B um
  CSR_M9_HOLE_R = HOLES CSR_M9_P4
  X1 = ANGLE CSR_M9_HOLE_R == 45
  X2 = ANGLE CSR_M9_HOLE_R != 45
  B = WITH WIDTH CSR_M9_HOLE_R >= CSR_L_1B*2
  ANGLE B != 45
  INT X2 > CSR_L_1B < CSR_L_1B*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  INT X2 < CSR_L_1A ABUT < 90 OPPOSITE PARALLEL ONLY REGION
}
// CSR.W.1 is checked by CSR.W.1:M9
// CSR.L.1 is checked by CSR.L.1:M9

// 'CSR.R.5' is not necessary to check
CSR.R.6 { @ For Mu design, DMV pattern in CSRmust include Mtop-1/Mtop-2/VIAtop-2/.../V1/M1, not including Mtop (Mu), VIAtop, and VIAtop-1.
    CSRDMY NOT INTERACT CSR_M1_D
    CSRDMY NOT INTERACT CSR_M2_D
    CSRDMY NOT INTERACT CSR_M3_D
    CSRDMY NOT INTERACT CSR_M4_D
    CSRDMY NOT INTERACT CSR_M5_D
    CSRDMY NOT INTERACT CSR_M6_D
    CSRDMY NOT INTERACT CSR_M7_D
    CSRDMY NOT INTERACT CSR_M8_D
    CSRDMY NOT INTERACT CSR_VIA1_D
    CSRDMY NOT INTERACT CSR_VIA2_D
    CSRDMY NOT INTERACT CSR_VIA3_D
    CSRDMY NOT INTERACT CSR_VIA4_D
    CSRDMY NOT INTERACT CSR_VIA5_D
    CSRDMY NOT INTERACT CSR_VIA6_D
}


SR.R.3 { @ For Mu design, DMV pattern in seal-ring enhanced zone region must include Mtop-1/Mtop-2/VIAtop-2/.../V1/M1, not including Mtop (Mu), VIAtop, and VIAtop-1. (DMV pattern: metal/via dummy pattern)   
    ISOR_P4 NOT INTERACT ISO_M1_D
    ISOR_P4 NOT INTERACT ISO_M2_D
    ISOR_P4 NOT INTERACT ISO_M3_D
    ISOR_P4 NOT INTERACT ISO_M4_D
    ISOR_P4 NOT INTERACT ISO_M5_D
    ISOR_P4 NOT INTERACT ISO_M6_D
    ISOR_P4 NOT INTERACT ISO_M7_D
