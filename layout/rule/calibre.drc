//LOWMEDN CHECKS
//==============

LOWMEDN.W.1 { @ Width of {{M1 OR DM1_O} AND LOWMEDN} >= 0.14
  A = M1 AND LOWMEDN
  INT A < LOWMEDN_W_1 ABUT < 90 SINGULAR REGION
}

LOWMEDN.W.2 { @ Width of {DM1 AND LOWMEDN} >= 0.12
  A = DUM1 AND LOWMEDN
  INT A < LOWMEDN_W_2 ABUT < 90 SINGULAR REGION
}

// LOWMEDN.W.3 is checked by LOWMEDN.W.3:M2
// LOWMEDN.W.4 is checked by LOWMEDN.W.4:DM2

LOWMEDN.W.3:M2 { @ Width of {{Mx OR DMx_O} AND LOWMEDN}	>= 0.14
  A = M2 AND LOWMEDN
  INT A < LOWMEDN_W_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.W.4:DM2 { @ Width of {DMx AND LOWMEDN} >= 0.12
  A = DUM2 AND LOWMEDN
  INT A < LOWMEDN_W_4 ABUT < 90 SINGULAR REGION
}
// LOWMEDN.W.3 is checked by LOWMEDN.W.3:M3
// LOWMEDN.W.4 is checked by LOWMEDN.W.4:DM3

LOWMEDN.W.3:M3 { @ Width of {{Mx OR DMx_O} AND LOWMEDN}	>= 0.14
  A = M3 AND LOWMEDN
  INT A < LOWMEDN_W_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.W.4:DM3 { @ Width of {DMx AND LOWMEDN} >= 0.12
  A = DUM3 AND LOWMEDN
  INT A < LOWMEDN_W_4 ABUT < 90 SINGULAR REGION
}
// LOWMEDN.W.3 is checked by LOWMEDN.W.3:M4
// LOWMEDN.W.4 is checked by LOWMEDN.W.4:DM4

LOWMEDN.W.3:M4 { @ Width of {{Mx OR DMx_O} AND LOWMEDN}	>= 0.14
  A = M4 AND LOWMEDN
  INT A < LOWMEDN_W_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.W.4:DM4 { @ Width of {DMx AND LOWMEDN} >= 0.12
  A = DUM4 AND LOWMEDN
  INT A < LOWMEDN_W_4 ABUT < 90 SINGULAR REGION
}
// LOWMEDN.W.3 is checked by LOWMEDN.W.3:M5
// LOWMEDN.W.4 is checked by LOWMEDN.W.4:DM5

LOWMEDN.W.3:M5 { @ Width of {{Mx OR DMx_O} AND LOWMEDN}	>= 0.14
  A = M5 AND LOWMEDN
  INT A < LOWMEDN_W_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.W.4:DM5 { @ Width of {DMx AND LOWMEDN} >= 0.12
  A = DUM5 AND LOWMEDN
  INT A < LOWMEDN_W_4 ABUT < 90 SINGULAR REGION
}
// LOWMEDN.W.3 is checked by LOWMEDN.W.3:M6
// LOWMEDN.W.4 is checked by LOWMEDN.W.4:DM6

LOWMEDN.W.3:M6 { @ Width of {{Mx OR DMx_O} AND LOWMEDN}	>= 0.14
  A = M6 AND LOWMEDN
  INT A < LOWMEDN_W_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.W.4:DM6 { @ Width of {DMx AND LOWMEDN} >= 0.12
  A = DUM6 AND LOWMEDN
  INT A < LOWMEDN_W_4 ABUT < 90 SINGULAR REGION
}
// LOWMEDN.W.3 is checked by LOWMEDN.W.3:M7
// LOWMEDN.W.4 is checked by LOWMEDN.W.4:DM7

LOWMEDN.W.3:M7 { @ Width of {{Mx OR DMx_O} AND LOWMEDN}	>= 0.14
  A = M7 AND LOWMEDN
  INT A < LOWMEDN_W_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.W.4:DM7 { @ Width of {DMx AND LOWMEDN} >= 0.12
  A = DUM7 AND LOWMEDN
  INT A < LOWMEDN_W_4 ABUT < 90 SINGULAR REGION
}

LOWMEDN.S.1 { @ Space of {{M1 OR DM1_O} AND LOWMEDN} >= 0.14
  A = M1 AND LOWMEDN
  EXT A < LOWMEDN_S_1 ABUT < 90 SINGULAR REGION
}

LOWMEDN.S.2 { @ Space of {DM1 AND LOWMEDN} >= 0.12
  A = DUM1 AND LOWMEDN
  EXT A < LOWMEDN_S_2 ABUT < 90 SINGULAR REGION
}

// LOWMEDN.S.3 is checked by LOWMEDN.S.3:M2
// LOWMEDN.S.4 is checked by LOWMEDN.S.4:DM2

LOWMEDN.S.3:M2 { @ Space of {{Mx OR DMx_O} AND LOWMEDN} >= 0.14
  A = M2 AND LOWMEDN
  EXT A < LOWMEDN_S_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.S.4:DM2 { @ Space of {DMx AND LOWMEDN} >= 0.12
  A = DUM2 AND LOWMEDN
  EXT A < LOWMEDN_S_4 ABUT < 90 SINGULAR REGION
}
// LOWMEDN.S.3 is checked by LOWMEDN.S.3:M3
// LOWMEDN.S.4 is checked by LOWMEDN.S.4:DM3

LOWMEDN.S.3:M3 { @ Space of {{Mx OR DMx_O} AND LOWMEDN} >= 0.14
  A = M3 AND LOWMEDN
  EXT A < LOWMEDN_S_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.S.4:DM3 { @ Space of {DMx AND LOWMEDN} >= 0.12
  A = DUM3 AND LOWMEDN
  EXT A < LOWMEDN_S_4 ABUT < 90 SINGULAR REGION
}
// LOWMEDN.S.3 is checked by LOWMEDN.S.3:M4
// LOWMEDN.S.4 is checked by LOWMEDN.S.4:DM4

LOWMEDN.S.3:M4 { @ Space of {{Mx OR DMx_O} AND LOWMEDN} >= 0.14
  A = M4 AND LOWMEDN
  EXT A < LOWMEDN_S_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.S.4:DM4 { @ Space of {DMx AND LOWMEDN} >= 0.12
  A = DUM4 AND LOWMEDN
  EXT A < LOWMEDN_S_4 ABUT < 90 SINGULAR REGION
}
// LOWMEDN.S.3 is checked by LOWMEDN.S.3:M5
// LOWMEDN.S.4 is checked by LOWMEDN.S.4:DM5

LOWMEDN.S.3:M5 { @ Space of {{Mx OR DMx_O} AND LOWMEDN} >= 0.14
  A = M5 AND LOWMEDN
  EXT A < LOWMEDN_S_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.S.4:DM5 { @ Space of {DMx AND LOWMEDN} >= 0.12
  A = DUM5 AND LOWMEDN
  EXT A < LOWMEDN_S_4 ABUT < 90 SINGULAR REGION
}
// LOWMEDN.S.3 is checked by LOWMEDN.S.3:M6
// LOWMEDN.S.4 is checked by LOWMEDN.S.4:DM6

LOWMEDN.S.3:M6 { @ Space of {{Mx OR DMx_O} AND LOWMEDN} >= 0.14
  A = M6 AND LOWMEDN
  EXT A < LOWMEDN_S_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.S.4:DM6 { @ Space of {DMx AND LOWMEDN} >= 0.12
  A = DUM6 AND LOWMEDN
  EXT A < LOWMEDN_S_4 ABUT < 90 SINGULAR REGION
}
// LOWMEDN.S.3 is checked by LOWMEDN.S.3:M7
// LOWMEDN.S.4 is checked by LOWMEDN.S.4:DM7

LOWMEDN.S.3:M7 { @ Space of {{Mx OR DMx_O} AND LOWMEDN} >= 0.14
  A = M7 AND LOWMEDN
  EXT A < LOWMEDN_S_3 ABUT < 90 SINGULAR REGION
}

LOWMEDN.S.4:DM7 { @ Space of {DMx AND LOWMEDN} >= 0.12
  A = DUM7 AND LOWMEDN
  EXT A < LOWMEDN_S_4 ABUT < 90 SINGULAR REGION
}

LOWMEDN.R.1 { @ Protection ring must exist in {LOWMEDN NOT {LOWMEDN SIZING -1 um}}. The protection ring must include all Mx/all VIAx/.../V1/M1 layers   
  P_RING_REGION1 NOT ENCLOSE P_RING_VIA1
  P_RING_VIA1_end = CONVEX EDGE P_RING_VIA1 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA1_W_6+2*GRID
  P_RING_VIA1_c = EXT P_RING_VIA1_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA1_o = P_RING_VIA1_c OR P_RING_VIA1
  LOWMEDN_CORE1 NOT INSIDE (HOLES P_RING_VIA1_o)
  P_RING_REGION1 NOT ENCLOSE P_RING_VIA2
  P_RING_VIA2_end = CONVEX EDGE P_RING_VIA2 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA2_W_6+2*GRID
  P_RING_VIA2_c = EXT P_RING_VIA2_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA2_o = P_RING_VIA2_c OR P_RING_VIA2
  LOWMEDN_CORE1 NOT INSIDE (HOLES P_RING_VIA2_o)
  P_RING_REGION1 NOT ENCLOSE P_RING_VIA3
  P_RING_VIA3_end = CONVEX EDGE P_RING_VIA3 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA3_W_6+2*GRID
  P_RING_VIA3_c = EXT P_RING_VIA3_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA3_o = P_RING_VIA3_c OR P_RING_VIA3
  LOWMEDN_CORE1 NOT INSIDE (HOLES P_RING_VIA3_o)
  P_RING_REGION1 NOT ENCLOSE P_RING_VIA4
  P_RING_VIA4_end = CONVEX EDGE P_RING_VIA4 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA4_W_6+2*GRID
  P_RING_VIA4_c = EXT P_RING_VIA4_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA4_o = P_RING_VIA4_c OR P_RING_VIA4
  LOWMEDN_CORE1 NOT INSIDE (HOLES P_RING_VIA4_o)
  P_RING_REGION1 NOT ENCLOSE P_RING_VIA5
  P_RING_VIA5_end = CONVEX EDGE P_RING_VIA5 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA5_W_6+2*GRID
  P_RING_VIA5_c = EXT P_RING_VIA5_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA5_o = P_RING_VIA5_c OR P_RING_VIA5
  LOWMEDN_CORE1 NOT INSIDE (HOLES P_RING_VIA5_o)
  P_RING_REGION1 NOT ENCLOSE P_RING_VIA6
  P_RING_VIA6_end = CONVEX EDGE P_RING_VIA6 ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA6_W_6+2*GRID
  P_RING_VIA6_c = EXT P_RING_VIA6_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA6_o = P_RING_VIA6_c OR P_RING_VIA6
  LOWMEDN_CORE1 NOT INSIDE (HOLES P_RING_VIA6_o)
}

LOWMEDN.R.2 { @ VIAx bar in {LOWMEDN NOT {LOWMEDN SIZING -4 um}} must be continuous as a ring. (except {LOWMEDN INTERACT INDDMY})   
  CONVEX EDGE P_RING_VIA1_noIND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA1_W_6+2*GRID
  NOT DONUT P_RING_VIA1_noIND
  CONVEX EDGE P_RING_VIA2_noIND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA2_W_6+2*GRID
  NOT DONUT P_RING_VIA2_noIND
  CONVEX EDGE P_RING_VIA3_noIND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA3_W_6+2*GRID
  NOT DONUT P_RING_VIA3_noIND
  CONVEX EDGE P_RING_VIA4_noIND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA4_W_6+2*GRID
  NOT DONUT P_RING_VIA4_noIND
  CONVEX EDGE P_RING_VIA5_noIND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA5_W_6+2*GRID
  NOT DONUT P_RING_VIA5_noIND
  CONVEX EDGE P_RING_VIA6_noIND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA6_W_6+2*GRID
  NOT DONUT P_RING_VIA6_noIND
}

// 'LOWMEDN.R.3' is checked by 'VIAx.W.1'
// 'LOWMEDN.R.4' is checked by 'VIAx.W.6', 'VIAx.EN.13', and 'Mx.EN.13'

LOWMEDN.R.5 { @ For {LOWMEDN interact INDDMY}, there must be either only one breach (C-shape ring) of metal/Via with via space <= 4um or VIAx bar must be continuous within {LOWMEDN NOT (LOWMEDN SIZING -4 um)}. 
  P_RING_VIA1_IND_end = CONVEX EDGE P_RING_VIA1_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA1_W_6+2*GRID
  P_RING_VIA1_IND_c = EXT P_RING_VIA1_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA1_IND_end NOT COIN OUTSIDE EDGE P_RING_VIA1_IND_c 
  P_RING_VIA1_IND_c INTERACT P_RING_VIA1_IND > 1
  P_RING_VIA1_IND INTERACT P_RING_VIA1_IND_c > 1
  P_RING_VIA1_IND_o = P_RING_VIA1_IND_c OR P_RING_VIA1_IND
  NOT DONUT P_RING_VIA1_IND_o
  P_RING_VIA2_IND_end = CONVEX EDGE P_RING_VIA2_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA2_W_6+2*GRID
  P_RING_VIA2_IND_c = EXT P_RING_VIA2_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA2_IND_end NOT COIN OUTSIDE EDGE P_RING_VIA2_IND_c 
  P_RING_VIA2_IND_c INTERACT P_RING_VIA2_IND > 1
  P_RING_VIA2_IND INTERACT P_RING_VIA2_IND_c > 1
  P_RING_VIA2_IND_o = P_RING_VIA2_IND_c OR P_RING_VIA2_IND
  NOT DONUT P_RING_VIA2_IND_o
  P_RING_VIA3_IND_end = CONVEX EDGE P_RING_VIA3_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA3_W_6+2*GRID
  P_RING_VIA3_IND_c = EXT P_RING_VIA3_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA3_IND_end NOT COIN OUTSIDE EDGE P_RING_VIA3_IND_c 
  P_RING_VIA3_IND_c INTERACT P_RING_VIA3_IND > 1
  P_RING_VIA3_IND INTERACT P_RING_VIA3_IND_c > 1
  P_RING_VIA3_IND_o = P_RING_VIA3_IND_c OR P_RING_VIA3_IND
  NOT DONUT P_RING_VIA3_IND_o
  P_RING_VIA4_IND_end = CONVEX EDGE P_RING_VIA4_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA4_W_6+2*GRID
  P_RING_VIA4_IND_c = EXT P_RING_VIA4_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA4_IND_end NOT COIN OUTSIDE EDGE P_RING_VIA4_IND_c 
  P_RING_VIA4_IND_c INTERACT P_RING_VIA4_IND > 1
  P_RING_VIA4_IND INTERACT P_RING_VIA4_IND_c > 1
  P_RING_VIA4_IND_o = P_RING_VIA4_IND_c OR P_RING_VIA4_IND
  NOT DONUT P_RING_VIA4_IND_o
  P_RING_VIA5_IND_end = CONVEX EDGE P_RING_VIA5_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA5_W_6+2*GRID
  P_RING_VIA5_IND_c = EXT P_RING_VIA5_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA5_IND_end NOT COIN OUTSIDE EDGE P_RING_VIA5_IND_c 
  P_RING_VIA5_IND_c INTERACT P_RING_VIA5_IND > 1
  P_RING_VIA5_IND INTERACT P_RING_VIA5_IND_c > 1
  P_RING_VIA5_IND_o = P_RING_VIA5_IND_c OR P_RING_VIA5_IND
  NOT DONUT P_RING_VIA5_IND_o
  P_RING_VIA6_IND_end = CONVEX EDGE P_RING_VIA6_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA6_W_6+2*GRID
  P_RING_VIA6_IND_c = EXT P_RING_VIA6_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA6_IND_end NOT COIN OUTSIDE EDGE P_RING_VIA6_IND_c 
  P_RING_VIA6_IND_c INTERACT P_RING_VIA6_IND > 1
  P_RING_VIA6_IND INTERACT P_RING_VIA6_IND_c > 1
  P_RING_VIA6_IND_o = P_RING_VIA6_IND_c OR P_RING_VIA6_IND
  NOT DONUT P_RING_VIA6_IND_o
}

LOWMEDN.R.6 { @ For C-shape ring, at least >= 2 protection rings are must in {LOWMEDN INTERACT INDDMY}. At least 2 VIAx bar in {LOWMEDN NOT (LOWMEDN SIZING -4 um)} are must for the protection ring with the breach.
  P_RING_REGION_IND = P_RING_REGION INTERACT LOWMEDN_IND 
  P_RING_VIA1_IND_end = CONVEX EDGE P_RING_VIA1_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA1_W_6+2*GRID
  P_RING_VIA1_IND_c = EXT P_RING_VIA1_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA1_IND_o = (P_RING_VIA1_IND_c OR P_RING_VIA1_IND) INTERACT P_RING_VIA1_IND_c
  P_RING_VIA1_IND_ox = HOLES P_RING_VIA1_IND_o
  LOWMEDN_CORE2_IND_VIA1 = LOWMEDN_CORE2 INTERACT (LOWMEDN_IND INTERACT P_RING_VIA1_IND_c)
  LOWMEDN_CORE2_IND_VIA1 NOT INSIDE P_RING_VIA1_IND_ox
  P_RING_VIA1_IND_o2 = P_RING_VIA1_IND_o INSIDE P_RING_VIA1_IND_ox
  P_RING_VIA1_IND_o2x = HOLES P_RING_VIA1_IND_o2
  LOWMEDN_CORE2_IND_VIA1 NOT INSIDE P_RING_VIA1_IND_o2x
  P_RING_VIA2_IND_end = CONVEX EDGE P_RING_VIA2_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA2_W_6+2*GRID
  P_RING_VIA2_IND_c = EXT P_RING_VIA2_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA2_IND_o = (P_RING_VIA2_IND_c OR P_RING_VIA2_IND) INTERACT P_RING_VIA2_IND_c
  P_RING_VIA2_IND_ox = HOLES P_RING_VIA2_IND_o
  LOWMEDN_CORE2_IND_VIA2 = LOWMEDN_CORE2 INTERACT (LOWMEDN_IND INTERACT P_RING_VIA2_IND_c)
  LOWMEDN_CORE2_IND_VIA2 NOT INSIDE P_RING_VIA2_IND_ox
  P_RING_VIA2_IND_o2 = P_RING_VIA2_IND_o INSIDE P_RING_VIA2_IND_ox
  P_RING_VIA2_IND_o2x = HOLES P_RING_VIA2_IND_o2
  LOWMEDN_CORE2_IND_VIA2 NOT INSIDE P_RING_VIA2_IND_o2x
  P_RING_VIA3_IND_end = CONVEX EDGE P_RING_VIA3_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA3_W_6+2*GRID
  P_RING_VIA3_IND_c = EXT P_RING_VIA3_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA3_IND_o = (P_RING_VIA3_IND_c OR P_RING_VIA3_IND) INTERACT P_RING_VIA3_IND_c
  P_RING_VIA3_IND_ox = HOLES P_RING_VIA3_IND_o
  LOWMEDN_CORE2_IND_VIA3 = LOWMEDN_CORE2 INTERACT (LOWMEDN_IND INTERACT P_RING_VIA3_IND_c)
  LOWMEDN_CORE2_IND_VIA3 NOT INSIDE P_RING_VIA3_IND_ox
  P_RING_VIA3_IND_o2 = P_RING_VIA3_IND_o INSIDE P_RING_VIA3_IND_ox
  P_RING_VIA3_IND_o2x = HOLES P_RING_VIA3_IND_o2
  LOWMEDN_CORE2_IND_VIA3 NOT INSIDE P_RING_VIA3_IND_o2x
  P_RING_VIA4_IND_end = CONVEX EDGE P_RING_VIA4_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA4_W_6+2*GRID
  P_RING_VIA4_IND_c = EXT P_RING_VIA4_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA4_IND_o = (P_RING_VIA4_IND_c OR P_RING_VIA4_IND) INTERACT P_RING_VIA4_IND_c
  P_RING_VIA4_IND_ox = HOLES P_RING_VIA4_IND_o
  LOWMEDN_CORE2_IND_VIA4 = LOWMEDN_CORE2 INTERACT (LOWMEDN_IND INTERACT P_RING_VIA4_IND_c)
  LOWMEDN_CORE2_IND_VIA4 NOT INSIDE P_RING_VIA4_IND_ox
  P_RING_VIA4_IND_o2 = P_RING_VIA4_IND_o INSIDE P_RING_VIA4_IND_ox
  P_RING_VIA4_IND_o2x = HOLES P_RING_VIA4_IND_o2
  LOWMEDN_CORE2_IND_VIA4 NOT INSIDE P_RING_VIA4_IND_o2x
  P_RING_VIA5_IND_end = CONVEX EDGE P_RING_VIA5_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA5_W_6+2*GRID
  P_RING_VIA5_IND_c = EXT P_RING_VIA5_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA5_IND_o = (P_RING_VIA5_IND_c OR P_RING_VIA5_IND) INTERACT P_RING_VIA5_IND_c
  P_RING_VIA5_IND_ox = HOLES P_RING_VIA5_IND_o
  LOWMEDN_CORE2_IND_VIA5 = LOWMEDN_CORE2 INTERACT (LOWMEDN_IND INTERACT P_RING_VIA5_IND_c)
  LOWMEDN_CORE2_IND_VIA5 NOT INSIDE P_RING_VIA5_IND_ox
  P_RING_VIA5_IND_o2 = P_RING_VIA5_IND_o INSIDE P_RING_VIA5_IND_ox
  P_RING_VIA5_IND_o2x = HOLES P_RING_VIA5_IND_o2
  LOWMEDN_CORE2_IND_VIA5 NOT INSIDE P_RING_VIA5_IND_o2x
  P_RING_VIA6_IND_end = CONVEX EDGE P_RING_VIA6_IND ANGLE1 <= 90 ANGLE2 < 180 WITH LENGTH <= VIA6_W_6+2*GRID
  P_RING_VIA6_IND_c = EXT P_RING_VIA6_IND_end <= LOWMEDN_R_5 ABUT< 90 OPPOSITE NOTCH REGION
  P_RING_VIA6_IND_o = (P_RING_VIA6_IND_c OR P_RING_VIA6_IND) INTERACT P_RING_VIA6_IND_c
  P_RING_VIA6_IND_ox = HOLES P_RING_VIA6_IND_o
  LOWMEDN_CORE2_IND_VIA6 = LOWMEDN_CORE2 INTERACT (LOWMEDN_IND INTERACT P_RING_VIA6_IND_c)
  LOWMEDN_CORE2_IND_VIA6 NOT INSIDE P_RING_VIA6_IND_ox
  P_RING_VIA6_IND_o2 = P_RING_VIA6_IND_o INSIDE P_RING_VIA6_IND_ox
  P_RING_VIA6_IND_o2x = HOLES P_RING_VIA6_IND_o2
  LOWMEDN_CORE2_IND_VIA6 NOT INSIDE P_RING_VIA6_IND_o2x
}



//VIA1 CHECKS
//===========
VIA1.W.1 { @  Width x Length = 0.05 x 0.05, 0.05 x 0.13 (Except seal-ring (162,2) and {LOWMEDN NOT {LOWMEDN SIZING -4 m}})
  A = NOT RECTANGLE VIA1i == VIA1_W_1 BY == VIA1_L_1 ORTHOGONAL ONLY
  B = NOT RECTANGLE A == VIA1_W_1 BY == VIA1_L_2 ORTHOGONAL ONLY    
  B NOT (VIA_EXD OR P_RING_REGION)
}

// 'VIAx.W.6' is checked by VIA1.W.6
VIA1.W.6 { @ Width of VIAx bar in protection ring [INSIDE LOWMEDN] = 0.15 
  INT P_RING_VIA1 > VIA1_W_6+2*GRID < VIA1_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  WITH WIDTH P_RING_VIA1 >= VIA1_W_6*2
  INT P_RING_VIA1 < VIA1_W_6-2*GRID ABUT < 90 REGION
}
SAME_NET_VIA1 = M1i AND M2i

VIA1.S.1 { @ Square VIAx space >= 0.07 
  EXT VIA1i < VIA1_S_1 ABUT < 90 SINGULAR REGION
}

VIA1.S.3 { @ Square VIAx space to rectangular VIAx >= 0.075 
  EXT SQR_VIA1 REC_VIA1 < VIA1_S_3 ABUT < 90 SINGULAR REGION
}
VIA1.S.4 { @ Rectangular VIAx space to rectangular VIAx >= 0.08 
  EXT REC_VIA1 < VIA1_S_4 ABUT < 90 SINGULAR REGION
}
VIA1.S.5 { @ VIAx space [parallel run length > -0.04 um] >= 0.08 
   EXT VIA1i < VIA1_S_5 ABUT < 90 OPPOSITE EXTENDED VIA1_S_5_L REGION
}





VIA1.S.18 { @ Space of VIAx bar in LOWMEDN to VIAx hole >= 0.35 
  EXT P_RING_VIA1 VIA1_EXD < VIA1_S_18 ABUT < 90 SINGULAR REGION
}

VIA1.S.19 { @ Space of VIAx bar in LOWMEDN >= 0.6 
  EXT P_RING_VIA1 < VIA1_S_19 ABUT < 90 SINGULAR REGION
}





// VIA1.EN.0 is checked by either {VIA1.EN.1/VIA1.EN.2} or VIA1.EN.3

VIA1.EN.1 { @ Enclosure by M1 or Mx >= 0 
  VIA1i NOT M1i
}
VIA1.EN.2__VIA1.EN.3__VIA1.EN.14__VIA1.EN.15 { @ Enclosure by M1 [at least two opposite sides] >= ^VIA1_EN_2 um OR [all sides] >= ^VIA1_EN_3 OR [all side] >= ^VIA1_EN_14 / [at least two opposite sides] >= ^VIA1_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA1 M1i ABUT < 90 SINGULAR GOOD 0 VIA1_EN_2 OPPOSITE 0 VIA1_EN_2 OPPOSITE GOOD VIA1_EN_14 VIA1_EN_15 OPPOSITE VIA1_EN_14 VIA1_EN_15 OPPOSITE
  (ENC X M1i < VIA1_EN_3 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}


// VIA1.EN.4,	Rectangular VIAx enclosure by M1 or Mx is defined by either {VIAx.EN.5/VIAx.EN.7} or {VIAx.EN.6/VIAx.EN.8} or VIAx.EN.3
// VIA1.EN.4 is checked by either {VIA1.EN.5/VIA1.EN.7} or VIA1.EN.3

VIA1.EN.3__VIA1.EN.5__VIA1.EN.6__VIA1.EN.7 { @ Enclosure by M1 [two opposite direction >= ^VIA1_EN_7 and all side >= ^VIA1_EN_5], OR Enclosure by M1 [at rectangular VIA1 end direction] >= ^VIA1_EN_6, OR Enclosure by M1 [all sides] >= ^VIA1_EN_3    
  A = RECTANGLE ENCLOSURE REC_VIA1 M1i ABUT < 90 SINGULAR GOOD VIA1_EN_5 VIA1_EN_7 OPPOSITE VIA1_EN_5 VIA1_EN_7 OPPOSITE GOOD VIA1_EN_3 VIA1_EN_3 VIA1_EN_3 VIA1_EN_3
  B = LENGTH A == VIA1_W_1
  C = ENC [B] M1i < VIA1_EN_6 ABUT < 90 OPPOSITE
  (A WITH EDGE C) NOT INSIDE SRAM_WAIVE_N28

}
// VIA1.EN.3, VIA1.EN.5, VIA1.EN.6 and VIA1.EN.7 are checked by VIA1.EN.3__VIA1.EN.5__VIA1.EN.6__VIA1.EN.7
// VIA1.EN.8 is checked by VIA1.EN.1

M1_W_55 = M1 WITH WIDTH == VIA1_EN_9_W 
M1_W_70 = M1 WITH WIDTH > VIA1_EN_9_W <= VIA1_EN_10_W 
M1_W_160 = M1 WITH WIDTH > VIA1_EN_10_W <=VIA1_EN_11W
M1_W_450 = M1 WITH WIDTH > VIA1_EN_11W <=VIA1_EN_12W

//VIA1.EN.9 is not necessary to check
//VIA1.EN.10 is not necessary to check
//VIA1.EN.11 is not necessary to check
VIA1.EN.12 { @ Enclosure by M1 or Mx [4.5 um >= metal width > 0.16 um, space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M1_W_450 [M1] < VIA1_EN_12D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M1i] < VIA1_EN_12D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M1i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M1i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M1i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M1i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M1i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M1i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA1_EN_12L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA1_EN_12L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  (ENC VIA1i S7_H < VIA1_EN_12 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28
  (ENC VIA1i S7_V < VIA1_EN_12 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28

}
// 'VIAx.EN.13' is checked by VIA1.EN.13
VIA1.EN.13 { @ VIAx bar enclosure by M1/Mx in LOWMEDN >= 0.1 
  ENC P_RING_VIA1 M1 < VIA1_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}

// VIA1.L.1 is checked by VIA1.W.1
// VIA1.L.2 is checked by VIA1.W.1

// VIA1.R.0 is checked by VIA1.W.1
// VIA1.R.1 is checked by [VIA1.R.2 ~ VIA1.R.6]

//'VIAx.R.2' is checked by VIA1.R.2__VIA1.R.3
//'VIAx.R.3' is checked by VIA1.R.2__VIA1.R.3
VIA1.R.2__VIA1.R.3 { @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S1) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W1) > 0.18 um]. (Except VIA bar region) 1. at least one rectangular VIAx, or 2. at least 2 square VIAx with space <= 0.1 um (S1), or 3. at least 4 square VIAx with space <= 0.65 um (S1')   
                     @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S2) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W2) > 0.44 um]. Please refer to VIAx.R.3 table behind. (Except VIA bar region)   
   MupOvpMdn_W3  = (M1Wide_R3_VIA1 AND M2i) OR (M2Wide_R3_VIA1 AND M1i)
   MupOvpMdn_R3  = MupOvpMdn_W3 NOT OUTSIDE VIA1_EXD
   Checked_Vx_R3 = VIA1_EXD NOT OUTSIDE MupOvpMdn_W3

   MupOvpMdn_W2      = (M1Wide_R2_VIA1 AND M2i) OR (M2Wide_R2_VIA1 AND M1i)
   MupOvpMdn_R2_pre  = MupOvpMdn_W2 NOT OUTSIDE VIA1_EXD
   MupOvpMdn_R2      = MupOvpMdn_R2_pre NOT MupOvpMdn_R3
   Checked_Vx_R2 = (VIA1_EXD NOT OUTSIDE MupOvpMdn_W2) NOT Checked_Vx_R3
   
   Mdn_effect = M1i INTERACT MupOvpMdn_R2_pre
   Mup_effect = M2i INTERACT MupOvpMdn_R2_pre
   effect_MupOvpMdn_ = Mdn_effect AND Mup_effect
   
   effect_MupOvpMdn_R = SIZE MupOvpMdn_R2_pre BY (VIA1_W_1+VIA1_R_3_S2)*8+GRID
   effect_MupOvpMdn = effect_MupOvpMdn_ AND effect_MupOvpMdn_R
   effect_VIA = VIA1_EXD INTERACT effect_MupOvpMdn

   VxMerged_A = SIZE effect_VIA BY VIA1_R_2_S1/2              INSIDE OF effect_MupOvpMdn STEP M1_S_1*0.7
   VxMerged_B = SIZE VxMerged_A BY (VIA1_R_2_S2 - VIA1_R_2_S1)/2 INSIDE OF effect_MupOvpMdn STEP M1_S_1*0.7
   effect_MupOvpMdn_R3 = effect_MupOvpMdn INTERACT MupOvpMdn_R3
   VxMerged_A_R3 = VxMerged_A INTERACT effect_MupOvpMdn_R3 
   VxMerged_D = SIZE VxMerged_A_R3 BY (VIA1_R_3_S3 - VIA1_R_2_S1)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M1_S_1*0.7
   VxMerged_C = SIZE VxMerged_D    BY (VIA1_R_3_S2 - VIA1_R_3_S3)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M1_S_1*0.7
   
// Pass VIAx.R.2 (2 eff. square Via)
   G1_A2R = VxMerged_A INTERACT SQR_VIA1 >=2
   G2_A2R = VxMerged_A INTERACT REC_VIA1 >=1
   VxMerged_A2 = G1_A2R OR G2_A2R
// Pass VIAx.R.2 (4 eff. square Via)
   G1_B4R =  VxMerged_B INTERACT SQR_VIA1 >=4
   G2_B4R = (VxMerged_B INTERACT SQR_VIA1 >=2 <=3) AND (VxMerged_B INTERACT REC_VIA1 ==1)
   G3_B4R =  VxMerged_B INTERACT REC_VIA1 >=2
   VxMerged_B4 = (G1_B4R OR G2_B4R) OR G3_B4R

// Pass VIAx.R.3 (4 eff. square + slot Via)
   G1_A4_13 =  VxMerged_D INTERACT REC_VIA1 >=2
   G2_A4_13 = (VxMerged_D INTERACT REC_VIA1 ==1) AND (VxMerged_D INTERACT SQR_VIA1 >=2)
   VxMerged_A4_13 = G1_A4_13 OR G2_A4_13
// Pass VIAx.R.3 (4 eff. square Via only)
   G1_A4_10 = VxMerged_A INTERACT SQR_VIA1 >=4   
   VxMerged_A4 = VxMerged_A4_13 OR G1_A4_10

// Pass VIAx.R.3 (9 eff. square Via)
   G1_C9 =  VxMerged_C INTERACT SQR_VIA1 >=9
   G2_C9 = (VxMerged_C INTERACT SQR_VIA1 >=7 <=8) AND (VxMerged_C INTERACT REC_VIA1 >=1)
   G3_C9 = (VxMerged_C INTERACT SQR_VIA1 >=5 <=6) AND (VxMerged_C INTERACT REC_VIA1 >=2)
   G4_C9 = (VxMerged_C INTERACT SQR_VIA1 >=3 <=4) AND (VxMerged_C INTERACT REC_VIA1 >=3)
   G5_C9 = (VxMerged_C INTERACT SQR_VIA1 >=1 <=2) AND (VxMerged_C INTERACT REC_VIA1 >=4)
   G6_C9 =  VxMerged_C INTERACT REC_VIA1 >=5
   VxMerged_C9 = ((G1_C9 OR G2_C9) OR (G3_C9 OR G4_C9)) OR (G5_C9 OR G6_C9) 

   Checked_Vx_R2 OUTSIDE (MupOvpMdn_R2 INTERACT (VxMerged_A2 OR VxMerged_B4))
   Checked_Vx_R3 OUTSIDE (MupOvpMdn_R3 INTERACT (VxMerged_A4 OR VxMerged_C9))
}

VIA1.R.4:M1 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA1_R_4_L um (L) and width > ^VIA1_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M1Wide_R4_VIA1 BY VIA1_R_4_D + GRID) NOT M1Wide_R4_VIA1) AND M1
  Branch1HasVia = (Branch1 INTERACT M1Wide_R4_VIA1) INTERACT VIA1_EXD
  Branch1Edge = M1Wide_R4_VIA1 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA1_R_4_D INSIDE OF Branch1HasVia STEP M1_S_1*0.4
  GoodBranch = ((Branch AND M2) INTERACT VIA1i > 1) OR ((Branch AND M2) INTERACT (REC_VIA1 OR P_RING_VIA1))
  BranchSingleVia = (VIA1i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M2 INTERACT BranchSingleVia) AND M1) INTERACT BranchSingleVia) INTERACT VIA1i == 1
  ((BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD) NOT INSIDE SRAM_WAIVE_N28
}


VIA1.R.4:M2 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA1_R_4_L um (L) and width > ^VIA1_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M2Wide_R4_VIA1 BY VIA1_R_4_D + GRID) NOT M2Wide_R4_VIA1) AND M2
  Branch1HasVia = (Branch1 INTERACT M2Wide_R4_VIA1) INTERACT VIA1_EXD
  Branch1Edge = M2Wide_R4_VIA1 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA1_R_4_D INSIDE OF Branch1HasVia STEP M2_S_1*0.4
  GoodBranch = ((Branch AND M1) INTERACT VIA1i > 1) OR ((Branch AND M1) INTERACT (REC_VIA1 OR P_RING_VIA1))
  BranchSingleVia = (VIA1i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M1 INTERACT BranchSingleVia) AND M2) INTERACT BranchSingleVia) INTERACT VIA1i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


// VIA1.R.4 is checked by VIA1.R.4:M1 and VIA1.R.4:M2
// VIA1.R.5 is checked by VIA1.R.5:M1 and VIA1.R.5:M2
// VIA1.R.6 is checked by VIA1.R.6:M1 and VIA1.R.6:M2

//'VIAy.R.13' is not necessary to check
//'VIAr.R.13' is not necessary to check


VIA1.R.5:M1 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M1Wide_R5_VIA1 BY VIA1_R_5_D + GRID) NOT M1Wide_R5_VIA1) AND M1
  Branch1HasVia = (Branch1 INTERACT M1Wide_R5_VIA1) INTERACT VIA1_EXD
  Branch1Edge = M1Wide_R5_VIA1 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA1_R_5_D INSIDE OF Branch1HasVia STEP M1_S_1*0.6
  GoodBranch = ((Branch AND M2) INTERACT VIA1i > 1) OR ((Branch AND M2) INTERACT (REC_VIA1 OR P_RING_VIA1))
  BranchSingleVia = (VIA1i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M2 INTERACT BranchSingleVia) AND M1) INTERACT BranchSingleVia) INTERACT VIA1i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
VIA1.R.5:M2 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M2Wide_R5_VIA1 BY VIA1_R_5_D + GRID) NOT M2Wide_R5_VIA1) AND M2
  Branch1HasVia = (Branch1 INTERACT M2Wide_R5_VIA1) INTERACT VIA1_EXD
  Branch1Edge = M2Wide_R5_VIA1 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA1_R_5_D INSIDE OF Branch1HasVia STEP M2_S_1*0.6
  GoodBranch = ((Branch AND M1) INTERACT VIA1i > 1) OR ((Branch AND M1) INTERACT (REC_VIA1 OR P_RING_VIA1))
  BranchSingleVia = (VIA1i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M1 INTERACT BranchSingleVia) AND M2) INTERACT BranchSingleVia) INTERACT VIA1i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


M1Big_R6_VIA1 = ENCLOSE RECTANGLE M1Wide_R6_VIA1 VIA1_R_6_W VIA1_R_6_L+GRID
M2Big_R6_VIA1 = ENCLOSE RECTANGLE M2Wide_R6_VIA1 VIA1_R_6_W VIA1_R_6_L+GRID

VIA1.R.6:M1 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M1Big_R6_VIA1 BY VIA1_R_6_D + GRID) NOT M1Big_R6_VIA1) AND M1
  Branch1HasVia = (Branch1 INTERACT M1Big_R6_VIA1) INTERACT VIA1_EXD
  Branch1Edge = M1Big_R6_VIA1 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA1_R_6_D INSIDE OF Branch1HasVia STEP M1_S_1*0.6
  GoodBranch = ((Branch AND M2) INTERACT VIA1i > 1) OR ((Branch AND M2) INTERACT (REC_VIA1 OR P_RING_VIA1))
  BranchSingleVia = (VIA1i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M2 INTERACT BranchSingleVia) AND M1) INTERACT BranchSingleVia) INTERACT VIA1i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}

VIA1.R.6:M2 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M2Big_R6_VIA1 BY VIA1_R_6_D + GRID) NOT M2Big_R6_VIA1) AND M2
  Branch1HasVia = (Branch1 INTERACT M2Big_R6_VIA1) INTERACT VIA1_EXD
  Branch1Edge = M2Big_R6_VIA1 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA1_R_6_D INSIDE OF Branch1HasVia STEP M2_S_1*0.6
  GoodBranch = ((Branch AND M1) INTERACT VIA1i > 1) OR ((Branch AND M1) INTERACT (REC_VIA1 OR P_RING_VIA1))
  BranchSingleVia = (VIA1i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M1 INTERACT BranchSingleVia) AND M2) INTERACT BranchSingleVia) INTERACT VIA1i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
// VIA1.R.7 is checked by VIA1.EN.1

VIA1.R.8 { @ Single VIAx is not allowed for H-shape Mx+1 when all of the following conditions come into existence: 1. The Mx+1 has H-shape interact with two metal holes: two metal hole length(L2) <= ^VIA1_R_8_L1 um and both two metal hole area <= ^VIA1_R_8_A um2 2. The VIAx overlaps on the center metal bar of this H-shape Mx+1 3. The length (L) of the center metal bar <= ^VIA1_R_8_L2 um and the width of metal bar is <= ^VIA1_R_8_W um.
  W = M2i WITH WIDTH <= VIA1_R_8_W   
  H_HOLE = (HOLES M2i INNER <= VIA1_R_8_A) INTERACT W
  A0 = M2i INTERACT H_HOLE
  A = A0 COIN OUTSIDE EDGE H_HOLE
  B0 = ((INT A <= VIA1_R_8_W ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) INTERACT H_HOLE == 2 
  B1 = (((INT A <= VIA1_R_8_L2 ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) AND W) INTERACT H_HOLE == 2
  HOLE_NOTCH = EXT H_HOLE <= VIA1_R_8_W ABUT<90 OPPOSITE NOTCH REGION  
  B2 = (B1 NOT HOLE_NOTCH) OR B0
  CORNER_M = ((EXT B2 <= VIA1_R_8_W ABUT == 90 INTERSECTING ONLY REGION EXTENTS) TOUCH B2 == 2) AND W
  B = B2 OR CORNER_M
  CENTER_BAR1 = NOT ENCLOSE RECTANGLE B GRID VIA1_R_8_L2+GRID
  CENTER_BAR2 = (CENTER_BAR1 INTERACT H_HOLE == 2) INTERACT VIA1i
  C = CENTER_BAR2 COIN OUTSIDE EDGE H_HOLE 
  D = EXT [C] A <= VIA1_R_8_L1 OPPOSITE
  E = C NOT COIN INSIDE EDGE D
  CENTER_BAR3 = CENTER_BAR2 NOT WITH EDGE E
  CHECK_VIA = VIA1i NOT OUTSIDE CENTER_BAR3
  CHECK_VIA AND (((A0 INTERACT CHECK_VIA) AND (M1i INTERACT CHECK_VIA)) INTERACT VIA1i == 1)
}





#IFDEF CHECK_VIRTUAL_VIAx

//VIAx_VIRT.R.1 is checked by related rules (VIA1 rules)
//'VIAx_VIRT.R.2' is checked by VIA1_VIRT.R.2
VIA1_VIRT.R.2 {@ VIAx_VIRT must be 0.05 um x 0.05 um   
   NOT RECTANGLE VIA1_VIRT == VIA1_W_1 BY == VIA1_W_1 ORTHOGONAL ONLY 
}
//'VIAx_VIRT.R.3' is checked by VIA1_VIRT.R.3
VIA1_VIRT.R.3 {@ VIAx_VIRT interact VIAx is not allowed   
   VIA1_VIRT INTERACT VIA1ii
}
//'VIAx_VIRT.R.4' is checked by VIA1_VIRT.R.4
VIA1_VIRT.R.4 {@ VIAx _VIRT must be fully covered by ROM (50;6)   
   VIA1_VIRT NOT ROM
}
#ENDIF




//M2 CHECKS
//=========
M2_EDGE_45 = M2 ANGLE == 45

M2.W.1 { @ Width >= 0.05 
  INT M2 < M2_W_1 ABUT < 90 SINGULAR REGION
}
M2.W.2 { @ Width of 45-degree bent Mx. (Please make sure the vertex of 45-degree pattern is on 0.005 um grid (refer to the guideline, G.6gU, in section XXX)) >= 0.17 
  INT M2_EDGE_45 < M2_W_2 ABUT < 90 REGION
}


// 'Mx.W.3' is checked by M2.W.3
M2.W.3 { @ Maximum width Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING, or 4. {{INDDMY OR INDDMY_MD} SIZING 16 um}, or 5. CSRDMY, or 6. PADDMY (255;16) <= 4.5 
  M2_MAX_WIDTH WITH WIDTH > M2_W_3
}



 

M2.W.4 { @ Length of the edge with adjacent edge < 0.05 um [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex-270 degree inner vertex; DRC doesn't flag if there is Mx within the area formed by 0.16 um extension from these 2 edges and the 90 degree outer vertex.] (This check doesn't include the region covered by MetalFuse (156;2)) >= 0.065 
  E1 = CONVEX EDGE M2 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH < M2_W_4_L1
  E2 = CONVEX EDGE M2 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH >= M2_W_4_L1 < M2_W_4_L2
  A = INT [E1]    < M2_W_4_L2 ABUT == 90 INTERSECTING ONLY
  B = INT [E2] E1 < M2_W_4_L2 ABUT == 90 INTERSECTING ONLY
  C = INT [E1] E2 < M2_W_4_L2 ABUT == 90 INTERSECTING ONLY
  D = OR EDGE  B (OR EDGE A C)
  CORNER_BAD_pre = (EXPAND EDGE D INSIDE BY 0.001) NOT INSIDE MFUSE
  W = EXT [D] M2 < 0.16
  CORNER_BAD_pre NOT WITH EDGE W
}
M2.S.1 { @ Space >= 0.05 
  EXT M2 < M2_S_1 ABUT < 90 SINGULAR REGION
}

M2.S.2 { @ Space [at least one metal line width > 0.09 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.06 
  X = EXT M2_20 M2 < M2_S_2 OPPOSITE REGION MEASURE ALL
  Y = X NOT M2
  (ENCLOSE RECTANGLE Y GRID M2_S_2_L+GRID) NOT INSIDE SRAM_WAIVE_N28 
}
M2.S.3 { @ Space [at least one metal line width > 0.16 um (W2) and the parallel run length > 0.22 um (L2)] >= 0.1 
  X = EXT M2_21 M2 < M2_S_3 OPPOSITE REGION MEASURE ALL
  Y = X NOT M2
  ENCLOSE RECTANGLE Y GRID M2_S_3_L+GRID
}
M2.S.4 { @ Space [at least one metal line width > 0.47 um (W3) and the parallel run length > 0.47 um (L3)] >= 0.13 
  X = EXT M2_22 M2 < M2_S_4 OPPOSITE REGION MEASURE ALL
  Y = X NOT M2
  ENCLOSE RECTANGLE Y GRID M2_S_4_L+GRID
}
M2.S.5 { @ Space [at least one metal line width > 0.63 um (W4) and the parallel run length > 0.63 um (L4)] >= 0.15 
  X = EXT M2_23 M2 < M2_S_5 OPPOSITE REGION MEASURE ALL
  Y = X NOT M2
  ENCLOSE RECTANGLE Y GRID M2_S_5_L+GRID
}
M2.S.6 { @ Space [at least one metal line width > 1.5 um (W5) and the parallel run length > 1.5 um (L5)] >= 0.5 
  X = EXT M2_30 M2 < M2_S_6 OPPOSITE REGION MEASURE ALL
  Y = X NOT M2
  ENCLOSE RECTANGLE Y 0.001 M2_S_6_L+0.001
}


M2.S.7 { @ Space to Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.07 
  A = CONVEX EDGE M2 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M2_S_7_W
  (EXT A M2 < M2_S_7 ABUT < 90 OPPOSITE EXTENDED M2_S_7_T REGION) NOT INSIDE SRAM_WAIVE_N28
}

M2.S.8 { @ Mx line space (S1) to dense Mx line-end [parallel run length > -0.025 um (T)], and dense Mx line-end enclosure of Vx-1 (V). Definition of dense Mx line-end: 1. Mx line-end: Mx edge with length < 0.07 um (W) between 2 outer vertex. 2. Other metal INTERACT Region 1. Region 1 = (T+Q) x S2. (W+S2) < 0.115 um. This check doesn't include small jog with edge length < 0.05 um (R) >= 0.08/0.05 or 0.1/0.03 
  M2_END = CONVEX EDGE M2 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M2_S_8_W
  M2_REGION = EXPAND EDGE M2_END OUTSIDE BY M2_S_8_SB + GRID EXTEND BY M2_S_8_T + GRID  // for data reduction
  M2_LINE = (M2 INSIDE EDGE M2_REGION) NOT TOUCH EDGE M2_END
  M2_EA = ENC VIA1i [M2_END] < M2_S_8_EA ABUT < 90 OPPOSITE
  M2_EB = ENC VIA1i [M2_END] < M2_S_8_EB ABUT < 90 OPPOSITE
  M2_SA = EXT [M2_END] M2_LINE < M2_S_8_SA ABUT < 90 OPPOSITE EXTENDED M2_S_8_T
  M2_SB = EXT [M2_END] M2_LINE < M2_S_8_SB ABUT < 90 OPPOSITE EXTENDED M2_S_8_T
  M2_PASS_A = (M2_END NOT TOUCH INSIDE EDGE M2_EA) NOT TOUCH INSIDE EDGE M2_SA
  M2_PASS_B = (M2_END NOT TOUCH INSIDE EDGE M2_EB) NOT TOUCH INSIDE EDGE M2_SB
  M2_CHECK = (M2_END NOT TOUCH INSIDE EDGE M2_PASS_A) NOT TOUCH INSIDE EDGE M2_PASS_B

  M2_Long_side = LENGTH M2 >= M2_W_1
  O = INT M2_CHECK [M2_Long_side] < M2_S_8_Q-M2_S_8_T ABUT == 90 INTERSECTING ONLY  
  PW = INT O M2 < (M2_S_8_P - M2_S_1) ABUT < 90 OPPOSITE EXTENDED M2_S_8_T
  PS = EXT O M2 < (M2_S_8_P - M2_W_1) ABUT < 90 OPPOSITE EXTENDED M2_S_8_T
  Q = DFM PROPERTY O PS PW OVERLAP ABUT ALSO MULTI
  [-= MIN(EW(PW)) + MIN(EW(PS))] < M2_S_8_P
  R = M2_CHECK TOUCH EDGE (EXPAND EDGE Q INSIDE BY 0.001)
  (ENC VIA1i R < M2_S_8_EA ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28
  (EXT R M2 < M2_S_8_SB ABUT < 90 OPPOSITE EXTENDED M2_S_8_T REGION) NOT INSIDE SRAM_WAIVE_N28
}


M2.S.9 { @ Space to 45-degree bent Mx >= 0.17 
  X = EXPAND EDGE M2_EDGE_45 OUTSIDE BY M2_S_9
  X AND M2
}


M2_HVN_65V = NET AREA RATIO M2i OVER M9_HV_65V M8_HV_65V M7_HV_65V M6_HV_65V M5_HV_65V M4_HV_65V M3_HV_65V M2_HV_65V M1_HV_65V PO_HV_65V NW_HV_65V DNW_HV_65V > 0
M2_HVN_5V = NET AREA RATIO M2i OVER M9_HV_5V M8_HV_5V M7_HV_5V M6_HV_5V M5_HV_5V M4_HV_5V M3_HV_5V M2_HV_5V M1_HV_5V > 0
M2_HVN = NET AREA RATIO M2i OVER M9_HV M8_HV M7_HV M6_HV M5_HV M4_HV M3_HV M2_HV M1_HV > 0
M2_MVN = NET AREA RATIO M2i OVER M9_MV M8_MV M7_MV M6_MV M5_MV M4_MV M3_MV M2_MV M1_MV > 0
M2_MLVN = NET AREA RATIO M2i OVER M9_MLV M8_MLV M7_MLV M6_MLV M5_MLV M4_MLV M3_MLV M2_MLV M1_MLV > 0
M2_LVN = NET AREA RATIO M2i OVER M9_LV M8_LV M7_LV M6_LV M5_LV M4_LV M3_LV M2_LV M1_LV > 0
M2_VNVN_pre = NET AREA RATIO M2i OVER M9_VNV M8_VNV M7_VNV M6_VNV M5_VNV M4_VNV M3_VNV M2_VNV M1_VNV > 0
M2_NVN = NET AREA RATIO M2i OVER M9_NV M8_NV M7_NV M6_NV M5_NV M4_NV M3_NV M2_NV M1_NV > 0
M2_VNVN = M2_VNVN_pre NOT M2_NVN
M2_NOMARK = (((((((M2i NOT M2_HVN_65V) NOT M2_HVN_5V) NOT M2_HVN) NOT M2_MVN) NOT M2_MLVN) NOT M2_LVN) NOT M2_NVN) NOT M2_VNVN



#IFDEF USE_IO_VOLTAGE_ON_CORE_TO_IO_NET
  M2_NOMARK_65V = NET AREA RATIO M2_NOMARK PSD_65 NSD_65 PSTPix > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSTPix)]
  M2_NOMARK_5V = NET AREA RATIO M2_NOMARK PSD_50 NSD_50 PSTPix > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)]
  M2_NOMARK_HV = NET AREA RATIO M2_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)]
  M2_NOMARK_MV = NET AREA RATIO M2_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)]
  M2_NOMARK_MLV = NET AREA RATIO M2_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)]
  M2_NOMARK_LV = NET AREA RATIO M2_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]  



#ELSE
  M2_NOMARK_65V = NET AREA RATIO M2_NOMARK PSD_65 NSD_65 PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSD_50)*!AREA(NSD_50)*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M2_NOMARK_5V = NET AREA RATIO M2_NOMARK PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M2_NOMARK_HV = NET AREA RATIO M2_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M2_NOMARK_MV = NET AREA RATIO M2_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M2_NOMARK_MLV = NET AREA RATIO M2_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M2_NOMARK_LV = NET AREA RATIO M2_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]


#ENDIF

M2_HV_65V_ALL = M2_HVN_65V OR M2_NOMARK_65V
M2_HV_5V_ALL = M2_HVN_5V OR M2_NOMARK_5V
M2_HV_ALL = M2_HVN OR M2_NOMARK_HV
M2_MV_ALL = M2_MVN OR M2_NOMARK_MV
M2_MLV_ALL = M2_MLVN OR M2_NOMARK_MLV
M2_LV_ALL = M2_LVN OR M2_NOMARK_LV
M2_NV_ALL = COPY M2_NVN
M2_VNV_ALL = COPY M2_VNVN

M2_VNV_CHK = STAMP M2_VNV_ALL BY M2i
VIA2_VNV_CHK = STAMP (VIA2ii AND M2_VNV_ALL) BY M2i
M2_NV_CHK = STAMP M2_NV_ALL BY M2i
VIA2_NV_CHK = STAMP (VIA2ii AND M2_NV_ALL) BY M2i  
M2_LV_CHK = STAMP M2_LV_ALL BY M2i
VIA2_LV_CHK = STAMP (VIA2ii AND M2_LV_ALL) BY M2i
M2_MLV_CHK = STAMP M2_MLV_ALL BY M2i
VIA2_MLV_CHK = STAMP (VIA2ii AND M2_MLV_ALL) BY M2i
M2_MV_CHK = STAMP M2_MV_ALL BY M2i
VIA2_MV_CHK = STAMP (VIA2ii AND M2_MV_ALL) BY M2i

M2_HV_CHK = STAMP M2_HV_ALL BY M2i
VIA2_HV_CHK = STAMP (VIA2ii AND M2_HV_ALL) BY M2i
M2_HV_5V_CHK = STAMP M2_HV_5V_ALL BY M2i
VIA2_HV_5V_CHK = STAMP (VIA2ii AND M2_HV_5V_ALL) BY M2i
M2_HV_65V_CHK = STAMP M2_HV_65V_ALL BY M2i
VIA2_HV_65V_CHK = STAMP (VIA2ii AND M2_HV_65V_ALL) BY M2i























M2.S.12 { @ Space of Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.08 
  A = CONVEX EDGE M2 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M2_S_12_W
  (EXT A < M2_S_12 ABUT < 90 OPPOSITE EXTENDED M2_S_12_T REGION) NOT INSIDE SRAM_WAIVE_N28
}

M2.S.13 { @ Space [at least one metal line width > 0.13 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.08 
  X = EXT M2_201 M2 < M2_S_13 OPPOSITE REGION MEASURE ALL
  Y = X NOT M2
  ENCLOSE RECTANGLE Y GRID M2_S_13_L+GRID
}


// M2.EN.0,enclosure of square VIAx-1 is defined by either {Mx.EN.1/Mx.EN.2} or Mx.EN.3
// M2.EN.0 is checked by either {M2.EN.1/M2.EN.2} or M2.EN.3

M2.EN.1 { @ Enclosure of square VIAx-1 >= 0 
  VIA1i NOT M2i
}
M2.EN.2__M2.EN.3__M2.EN.14__M2.EN.15 { @ Enclosure of VIA1 [at least two opposite sides] >= ^M2_EN_2 um OR [all sides] >= ^M2_EN_3 OR [all side] >= ^M2_EN_14 / [at least two opposite sides] >= ^M2_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA1 M2i ABUT < 90 SINGULAR GOOD 0 M2_EN_2 OPPOSITE 0 M2_EN_2 OPPOSITE GOOD M2_EN_14 M2_EN_15 OPPOSITE M2_EN_14 M2_EN_15 OPPOSITE
  (ENC X M2i < M2_EN_3 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}

// M2.EN.4, Enclosure of rectangular VIAx-1 is defined by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3
// M2.EN.4 is checked by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3

M2.EN.3__M2.EN.5__M2.EN.6__M2.EN.7 { @ Enclosure of rectangular VIA1 [two opposite side >= ^M2_EN_7 and all side >= ^M2_EN_5], OR Enclosure of rectangular VIA1 [at rectangular VIA1 end direction] >= ^M2_EN_6, OR Enclosure of rectangular VIA1 [all sides] >= ^M2_EN_3
  A = RECTANGLE ENCLOSURE REC_VIA1 M2i ABUT < 90 SINGULAR GOOD M2_EN_5 M2_EN_7 OPPOSITE M2_EN_5 M2_EN_7 OPPOSITE GOOD M2_EN_3 M2_EN_3 M2_EN_3 M2_EN_3
  B = LENGTH A == VIA1_W_1
  C = ENC [B] M2i < M2_EN_6 ABUT < 90 OPPOSITE
  (A WITH EDGE C) NOT INSIDE SRAM_WAIVE_N28
}

// M2.EN.3, M2.EN.5, M2.EN.6 and M2.EN.7 are checked by M2.EN.3__M2.EN.5__M2.EN.6__M2.EN.7
// M2.EN.8 is checked by M2.EN.1

M2_W_55b = M2 WITH WIDTH == M2_EN_9_W 
M2_W_70b = M2 WITH WIDTH > M2_EN_9_W <= M2_EN_10_W 
M2_W_160b = M2 WITH WIDTH > M2_EN_10_W <=M2_EN_11W
M2_W_450b = M2 WITH WIDTH > M2_EN_11W <=M2_EN_12W

M2.EN.9 { @ Enclosure of VIAx-1 [0.055 um >= metal width > 0.05 um, metal space < 0.06 um (D1) and the other side space >= 0.06 um (D1'), parallel run length > 0.1 um] >= 0.005 
  A0 = M2_W_55b INTERACT VIA1i 
  A = EXT A0 [M2] < M2_EN_9_S1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A M2 < M2_EN_9_S1 ABUT < 90 OPPOSITE REGION
  C = EXT A M2 < M2_EN_9_S1 ABUT < 90 OPPOSITE
  D = EXT A [M2] < M2_EN_9_S1 ABUT < 90 OPPOSITE
  E0 = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
  [-= EC(C) ] > M2_EN_9_L
  E1 = E0 NOT WITH EDGE (ANGLE M2 >0 < 90) 
  E = E0 NOT (E1 NOT ENCLOSE RECTANGLE M2_EN_9_L+GRID GRID ORTHOGONAL ONLY)  
  F = D COIN OUTSIDE EDGE E
  G = (EXPAND EDGE F INSIDE BY M2_EN_9_W) INTERACT E != 2  
  H = F COIN INSIDE EDGE G 
  ENC VIA1i H < M2_EN_9 ABUT < 90 OPPOSITE REGION
}
M2.EN.10 { @ Enclosure of VIAx-1 [0.07 um >= metal width > 0.055 um, metal space < 0.065 um (D1) and parallel run length > 0.1 um] >= 0.005 
  W = EXT M2_W_70b [M2] < M2_EN_10_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M2i] < M2_EN_10_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M2i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M2i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M2_EN_10_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M2_EN_10_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA1i S7_H < M2_EN_10 ABUT < 90 OPPOSITE REGION
  ENC VIA1i S7_V < M2_EN_10 ABUT < 90 OPPOSITE REGION

}
M2.EN.11 { @ Enclosure of VIAx-1 [0.16 um >= metal width > 0.07 um, metal space < 0.1 um (D1) and parallel run length > 0.1 um] (For Mx.EN.11, the rule check is not included same VIAx group, which is defined as below.) 1. VIAx space <= 0.11 um2. Mx is same net 3. Mx+1 is same net >= 0.01 
  VIA1_M = SIZE VIA1i BY M2_EN_11_S/2 INSIDE OF SAME_NET_VIA1 STEP M1_S_1*0.6
  VIA1_C = VIA1i NOT INTERACT (VIA1_M INTERACT VIA1i >= 2)
  W = EXT M2_W_160b [M2] < M2_EN_11_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M2i] < M2_EN_11_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M2i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M2i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M2_EN_11_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M2_EN_11_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  (ENC VIA1_C S7_H < M2_EN_11 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28
  (ENC VIA1_C S7_V < M2_EN_11 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28

}
// 'Mx.EN.12' is checked by M2.EN.12
M2.EN.12 { @ Enclosure of VIAx-1 [4.5 um >= metal width > 0.16 um, metal space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M2_W_450b [M2] < M2_EN_12_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M2i] < M2_EN_12_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M2i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M2i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M2_EN_12_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M2_EN_12_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA1i S7_H < M2_EN_12 ABUT < 90 OPPOSITE REGION
  ENC VIA1i S7_V < M2_EN_12 ABUT < 90 OPPOSITE REGION

}
// 'Mx.EN.13' is checked by M2.EN.13
M2.EN.13 { @ Enclosure of VIAx-1 bar in LOWMEDN >= 0.1 
  ENC P_RING_VIA1 M2 < M2_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}
// 'Mx.L.1' is checked by M2.L.1
M2.L.1 { @ Length of 45-degree bent Mx (minimum edge length) >= 0.5 
  (LENGTH M2_EDGE_45 < M2_L_1) NOT INSIDE EDGE SEALRING_ALL
}

M2.A.2 { @ M2 area (Except SRAMDMY;0) >= 0.014 
  (AREA M2 < M2_A_2) NOT INSIDE SRAM_WAIVE_N28
}
//'Mx.A.2' is checked by M2.A.2
M2.A.3 { @ Area [with all of edge lengths < 0.13 um] (Except M2 inside SRAMDMY;0) (This check doesn't include the patterns filling 0.05 um x 0.13 um rectangular tile) >= 0.044 
  A = AREA M2 < M2_A_3
  B = LENGTH A >= M2_A_3_L1
  C = A NOT WITH EDGE B
  (NOT ENCLOSE RECTANGLE C M2_A_3_W M2_A_3_L2 ORTHOGONAL ONLY) NOT INSIDE SRAM_WAIVE_N28
}

VARIABLE M2_A_4pre ((M2_A_4 + (M2_S_1 * M2_S_1 * 3.142))/(2 * M2_S_1))*((M2_A_4 + (M2_S_1 * M2_S_1 * 3.142))/(2 * M2_S_1))/3.141 // user value

M2.A.4 { @ Enclosed area >= 0.2 
  X = HOLES M2 INNER < M2_A_4pre
  AREA ( X NOT M2 ) < M2_A_4
}

//'DMx_O.R.1' is checked by DM2_O.R.1
DM2_O.R.1 { @ DMx_O INTERACT Mx is not allowed. [Mx, and My only]   
  DM2_O INTERACT M2i
}






// 'Mx.DN.0.1' is checked by related rules




//'My.DN.0' is not necessary to check
//'My.DN.1' is not necessary to check
//'My.DN.2' is not necessary to check
//'My.DN.3' is not necessary to check

//'Mr.DN.0' is not necessary to check
//'Mr.DN.1' is not necessary to check
//'Mr.DN.2' is not necessary to check
//'Mr.DN.3' is not necessary to check



//'Mx.DN.1' is checked by M2.DN.1
#IFDEF CHECK_LOW_DENSITY
M2.DN.1 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum metal density in window 125 um x 125 um, stepping 62.5*20% um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10%+3% 
#ELSE
@ Minimum metal density in window 125 um x 125 um, stepping 62.5 um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10% 
#ENDIF
  EXC_LOW = M2_EXC_LOW OR ICOVL
  N = M2x NOT EXC_LOW
  D = CHIP NOT EXC_LOW 
  A = CHIP_M2 NOT EXC_LOW
  X = DENSITY A M2x CHIP N D < M2_DN_1 WINDOW M2_DN_1_W STEP M2_DN_1_S BACKUP INSIDE OF LAYER CHIP_M2 PRINT M2.DN.1.density RDB M2.DN.1.RDB.density
          [~(AREA(A)-M2_DN_1_E)*!!(AREA(A)-M2_DN_1_E)+AREA(N)/AREA(D)+!~(AREA(M2x)/AREA(CHIP)-M2_DN_1)+!(AREA(M2x)/AREA(CHIP)-M2_DN_1)]


  COPY X    
}
#ENDIF



//'Mx.DN.2' is checked by M2.DN.2
M2.DN.2 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum metal density in window 125 um x 125 um, stepping 62.5*20% um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85%-3% 
#ELSE
@ Maximum metal density in window 125 um x 125 um, stepping 62.5 um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85% 
#ENDIF
  EXC_HIGH = M2_EXC_HIGH OR ICOVL
  N = M2x NOT EXC_HIGH
  D = CHIP NOT EXC_HIGH 
  A = CHIPx NOT EXC_HIGH
  X = DENSITY A M2x CHIP N D > M2_DN_2 WINDOW M2_DN_2_W STEP M2_DN_2_S BACKUP INSIDE OF LAYER CHIPx PRINT M2.DN.2.density RDB M2.DN.2.RDB.density
          [~(M2_DN_2_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M2x)/AREA(CHIP)-M2_DN_2)]


  COPY X    
}

//'Mx.DN.3' is checked by M2.DN.3
M2.DN.3 { @ The metal density difference between any 2 neighboring checking windows including DMxEXCL [window 200 um x 200 um, stepping 200 um]. Anticipate metal density gradient from layout of small cell by targeting density ~50% (this way, it will limit the risk of low density and of high gradient).(Except ICOVL) <= 50% 
   EXCEPT =  COPY ICOVL
   M2x_Chk = M2x NOT EXCEPT
   DENSITY M2x_Chk EXCEPT CHIP <=1 WINDOW M2_DN_3_W BACKUP GRADIENT > M2_DN_3 ABSOLUTE CORNER INSIDE OF LAYER CHIPx PRINT M2.DN.3.density RDB M2.DN.3.RDB.density
    [ (AREA(M2x_Chk)+AREA(EXCEPT)*M2_DN_3_V)/AREA(CHIP) ] 
}

M2_CORE = M2x NOT SRCSR_P4


#IFDEF CHECK_LOW_DENSITY
M2.DN.6 { @ Metal Density >= ^M2_DN_6 must be followed for item(A) to (C)
@ (A) Metal density [checking window ^M2_DN_6_W_A um x ^M2_DN_6_W_A um, stepping ^M2_DN_6_S_A um] >= ^M2_DN_6
@ (B) Maximum area of merged low density windows [checking window ^M2_DN_6_W_BC um x ^M2_DN_6_W_BC um, stepping ^M2_DN_6_S_BC um, density < ^M2_DN_6] <= ^M2_DN_6_A_B um2. Merged low density windows width <= ^M2_DN_6_U um is except.
@ (C) Maximum area of merged low density windows [checking window ^M2_DN_6_W_BC um x ^M2_DN_6_W_BC um, stepping ^M2_DN_6_S_BC um, density < ^M2_DN_6] <= ^M2_DN_6_A_C um2
@ 1. The following special regions are excluded
@    Chip corner triangle empty areas if sealring is added by tsmc. 
@    LOWMEDN
@ 2. This rule is applied while the width of (checking window NOT above excluding region) >= ^M2_DN_6_E_A um for (A) and >= ^M2_DN_6_E_BC um for both (B)/(C) 
  M2_CHECK = M2x NOT (NEW_DEN_EXC OR ICOVL)
  CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
  // Condition-A
  ERR_WIN_A = DENSITY M2_CHECK CHIP_CHECK < M2_DN_6 WINDOW M2_DN_6_W_A STEP M2_DN_6_S_A INSIDE OF LAYER CHIP_M2 BACKUP 
	[ AREA(M2_CHECK)/AREA(CHIP_CHECK) ]
  F_A = WITH WIDTH (ERR_WIN_A NOT (NEW_DEN_EXC OR ICOVL)) >= M2_DN_6_E_A
  DENSITY F_A M2_CHECK CHIP_CHECK < M2_DN_6 WINDOW M2_DN_6_W_A STEP M2_DN_6_S_A INSIDE OF LAYER CHIP_M2 BACKUP PRINT M2.DN.6_A.density
         [ !AREA(F_A)+AREA(M2_CHECK)/AREA(CHIP_CHECK) ]
  // Condition-B 
  ERR_WIN_B = DENSITY M2_CHECK CHIP_CHECK < M2_DN_6 WINDOW M2_DN_6_W_BC STEP M2_DN_6_S_BC INSIDE OF LAYER CHIP_M2 BACKUP 
	[ AREA(M2_CHECK)/AREA(CHIP_CHECK) ]
  F_B = WITH WIDTH (ERR_WIN_B NOT (NEW_DEN_EXC OR ICOVL)) >= M2_DN_6_E_BC
  A = DENSITY F_B M2_CHECK CHIP_CHECK < M2_DN_6 WINDOW M2_DN_6_W_BC STEP M2_DN_6_S_BC INSIDE OF LAYER CHIP_M2 BACKUP PRINT M2.DN.6_BC.density
         [ !AREA(F_B)+AREA(M2_CHECK)/AREA(CHIP_CHECK) ]
  B = AREA A > M2_DN_6_A_B
  C = SIZE B BY M2_DN_6_U/2 UNDEROVER
  B INTERACT C
  // Condition-C
  AREA B > M2_DN_6_A_C
}
#ENDIF





#ENDIF //M1_V1_M2_CHECKS

#IFDEF BACK_END
//VIA2 CHECKS
//===========
VIA2.W.1 { @  Width x Length = 0.05 x 0.05, 0.05 x 0.13 (Except seal-ring (162,2) and {LOWMEDN NOT {LOWMEDN SIZING -4 m}})
  A = NOT RECTANGLE VIA2i == VIA2_W_1 BY == VIA2_L_1 ORTHOGONAL ONLY
  B = NOT RECTANGLE A == VIA2_W_1 BY == VIA2_L_2 ORTHOGONAL ONLY    
  B NOT (VIA_EXD OR P_RING_REGION)
}

// 'VIAx.W.6' is checked by VIA2.W.6
VIA2.W.6 { @ Width of VIAx bar in protection ring [INSIDE LOWMEDN] = 0.15 
  INT P_RING_VIA2 > VIA2_W_6+2*GRID < VIA2_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  WITH WIDTH P_RING_VIA2 >= VIA2_W_6*2
  INT P_RING_VIA2 < VIA2_W_6-2*GRID ABUT < 90 REGION
}
SAME_NET_VIA2 = M2i AND M3i

VIA2.S.1 { @ Square VIAx space >= 0.07 
  EXT VIA2i < VIA2_S_1 ABUT < 90 SINGULAR REGION
}

VIA2.S.3 { @ Square VIAx space to rectangular VIAx >= 0.075 
  EXT SQR_VIA2 REC_VIA2 < VIA2_S_3 ABUT < 90 SINGULAR REGION
}
VIA2.S.4 { @ Rectangular VIAx space to rectangular VIAx >= 0.08 
  EXT REC_VIA2 < VIA2_S_4 ABUT < 90 SINGULAR REGION
}
VIA2.S.5 { @ VIAx space [parallel run length > -0.04 um] >= 0.08 
   EXT VIA2i < VIA2_S_5 ABUT < 90 OPPOSITE EXTENDED VIA2_S_5_L REGION
}





VIA2.S.18 { @ Space of VIAx bar in LOWMEDN to VIAx hole >= 0.35 
  EXT P_RING_VIA2 VIA2_EXD < VIA2_S_18 ABUT < 90 SINGULAR REGION
}

VIA2.S.19 { @ Space of VIAx bar in LOWMEDN >= 0.6 
  EXT P_RING_VIA2 < VIA2_S_19 ABUT < 90 SINGULAR REGION
}









// VIA2.EN.0 is checked by either {VIA2.EN.1/VIA2.EN.2} or VIA2.EN.3

VIA2.EN.1 { @ Enclosure by M1 or Mx >= 0 
  VIA2i NOT M2i
}
VIA2.EN.2__VIA2.EN.3__VIA2.EN.14__VIA2.EN.15 { @ Enclosure by M2 [at least two opposite sides] >= ^VIA2_EN_2 um OR [all sides] >= ^VIA2_EN_3 OR [all side] >= ^VIA2_EN_14 / [at least two opposite sides] >= ^VIA2_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA2 M2i ABUT < 90 SINGULAR GOOD 0 VIA2_EN_2 OPPOSITE 0 VIA2_EN_2 OPPOSITE GOOD VIA2_EN_14 VIA2_EN_15 OPPOSITE VIA2_EN_14 VIA2_EN_15 OPPOSITE
  (ENC X M2i < VIA2_EN_3 ABUT < 90 SINGULAR REGION) NOT INSIDE SRAM_WAIVE_N28
}


// VIA2.EN.4,	Rectangular VIAx enclosure by M1 or Mx is defined by either {VIAx.EN.5/VIAx.EN.7} or {VIAx.EN.6/VIAx.EN.8} or VIAx.EN.3
// VIA2.EN.4 is checked by either {VIA2.EN.5/VIA2.EN.7} or VIA2.EN.3

VIA2.EN.3__VIA2.EN.5__VIA2.EN.6__VIA2.EN.7 { @ Enclosure by M2 [two opposite direction >= ^VIA2_EN_7 and all side >= ^VIA2_EN_5], OR Enclosure by M2 [at rectangular VIA2 end direction] >= ^VIA2_EN_6, OR Enclosure by M2 [all sides] >= ^VIA2_EN_3    
  A = RECTANGLE ENCLOSURE REC_VIA2 M2i ABUT < 90 SINGULAR GOOD VIA2_EN_5 VIA2_EN_7 OPPOSITE VIA2_EN_5 VIA2_EN_7 OPPOSITE GOOD VIA2_EN_3 VIA2_EN_3 VIA2_EN_3 VIA2_EN_3
  B = LENGTH A == VIA2_W_1
  C = ENC [B] M2i < VIA2_EN_6 ABUT < 90 OPPOSITE
  (A WITH EDGE C) NOT INSIDE SRAM_WAIVE_N28

}
// VIA2.EN.3, VIA2.EN.5, VIA2.EN.6 and VIA2.EN.7 are checked by VIA2.EN.3__VIA2.EN.5__VIA2.EN.6__VIA2.EN.7
// VIA2.EN.8 is checked by VIA2.EN.1

M2_W_55 = M2 WITH WIDTH == VIA2_EN_9_W 
M2_W_70 = M2 WITH WIDTH > VIA2_EN_9_W <= VIA2_EN_10_W 
M2_W_160 = M2 WITH WIDTH > VIA2_EN_10_W <=VIA2_EN_11W
M2_W_450 = M2 WITH WIDTH > VIA2_EN_11W <=VIA2_EN_12W

//'VIAx.EN.9' is checked by VIA2.EN.9
VIA2.EN.9 { @ Enclosure by Mx [0.055 um >= metal width > 0.05 um, space < 0.06 um (D1) and the other side space >= 0.06 um (D1'), parallel run length > 0.1 um] >= 0.005 
  A0 = M2_W_55 INTERACT VIA2i 
  A = EXT A0 [M2] < VIA2_EN_9_S1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A M2 < VIA2_EN_9_S1 ABUT < 90 OPPOSITE REGION
  C = EXT A M2 < VIA2_EN_9_S1 ABUT < 90 OPPOSITE
  D = EXT A [M2] < VIA2_EN_9_S1 ABUT < 90 OPPOSITE
  E0 = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
  [-= EC(C) ] > VIA2_EN_9_L
  E1 = E0 NOT WITH EDGE (ANGLE M2 >0 < 90) 
  E = E0 NOT (E1 NOT ENCLOSE RECTANGLE VIA2_EN_9_L+GRID GRID ORTHOGONAL ONLY)  
  F = D COIN OUTSIDE EDGE E
  G = (EXPAND EDGE F INSIDE BY VIA2_EN_9_W) INTERACT E != 2  
  H = F COIN INSIDE EDGE G 
  ENC VIA2i H < VIA2_EN_9 ABUT < 90 OPPOSITE REGION
}
//'VIAx.EN.10' is checked by VIA2.EN.10
VIA2.EN.10 { @ Enclosure by Mx [0.07 um >= metal width > 0.055 um, space < 0.065 um (D1) and parallel run length > 0.1 um] >= 0.005 
  W = EXT M2_W_70 [M2] < VIA2_EN_10_S ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M2i] < VIA2_EN_10_S ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M2i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M2i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA2_EN_10_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA2_EN_10_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA2i S7_H < VIA2_EN_10 ABUT < 90 OPPOSITE REGION
  ENC VIA2i S7_V < VIA2_EN_10 ABUT < 90 OPPOSITE REGION

}
//'VIAx.EN.11' is checked by VIA2.EN.11
VIA2.EN.11 { @ Enclosure by Mx [0.16 um >= metal width > 0.07 um, space < 0.1 um (D1) and parallel run length > 0.1 um] (For VIAx.EN.11, the rule check is not included same VIAx group, which is defined as below). 1. VIAx space <= 0.11 um2. Mx is same net 3. Mx+1 is same net >= 0.01 
  VIA2_M = SIZE VIA2i BY VIA2_EN_11_S/2 INSIDE OF SAME_NET_VIA2 STEP M2_S_1*0.6
  VIA2_C = VIA2i NOT INTERACT (VIA2_M INTERACT VIA2i >= 2)
  W = EXT M2_W_160 [M2] < VIA2_EN_11D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M2i] < VIA2_EN_11D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M2i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M2i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA2_EN_11L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA2_EN_11L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  (ENC VIA2_C S7_H < VIA2_EN_11 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28
  (ENC VIA2_C S7_V < VIA2_EN_11 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28

}
VIA2.EN.12 { @ Enclosure by M1 or Mx [4.5 um >= metal width > 0.16 um, space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M2_W_450 [M2] < VIA2_EN_12D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M2i] < VIA2_EN_12D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M2i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M2i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M2i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA2_EN_12L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA2_EN_12L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA2i S7_H < VIA2_EN_12 ABUT < 90 OPPOSITE REGION
  ENC VIA2i S7_V < VIA2_EN_12 ABUT < 90 OPPOSITE REGION

}
// 'VIAx.EN.13' is checked by VIA2.EN.13
VIA2.EN.13 { @ VIAx bar enclosure by M1/Mx in LOWMEDN >= 0.1 
  ENC P_RING_VIA2 M2 < VIA2_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}

// VIA2.L.1 is checked by VIA2.W.1
// VIA2.L.2 is checked by VIA2.W.1

// VIA2.R.0 is checked by VIA2.W.1
// VIA2.R.1 is checked by [VIA2.R.2 ~ VIA2.R.6]

//'VIAx.R.2' is checked by VIA2.R.2__VIA2.R.3
//'VIAx.R.3' is checked by VIA2.R.2__VIA2.R.3
VIA2.R.2__VIA2.R.3 { @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S1) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W1) > 0.18 um]. (Except VIA bar region) 1. at least one rectangular VIAx, or 2. at least 2 square VIAx with space <= 0.1 um (S1), or 3. at least 4 square VIAx with space <= 0.65 um (S1')   
                     @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S2) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W2) > 0.44 um]. Please refer to VIAx.R.3 table behind. (Except VIA bar region)   
   MupOvpMdn_W3  = (M2Wide_R3_VIA2 AND M3i) OR (M3Wide_R3_VIA2 AND M2i)
   MupOvpMdn_R3  = MupOvpMdn_W3 NOT OUTSIDE VIA2_EXD
   Checked_Vx_R3 = VIA2_EXD NOT OUTSIDE MupOvpMdn_W3

   MupOvpMdn_W2      = (M2Wide_R2_VIA2 AND M3i) OR (M3Wide_R2_VIA2 AND M2i)
   MupOvpMdn_R2_pre  = MupOvpMdn_W2 NOT OUTSIDE VIA2_EXD
   MupOvpMdn_R2      = MupOvpMdn_R2_pre NOT MupOvpMdn_R3
   Checked_Vx_R2 = (VIA2_EXD NOT OUTSIDE MupOvpMdn_W2) NOT Checked_Vx_R3
   
   Mdn_effect = M2i INTERACT MupOvpMdn_R2_pre
   Mup_effect = M3i INTERACT MupOvpMdn_R2_pre
   effect_MupOvpMdn_ = Mdn_effect AND Mup_effect
   
   effect_MupOvpMdn_R = SIZE MupOvpMdn_R2_pre BY (VIA2_W_1+VIA2_R_3_S2)*8+GRID
   effect_MupOvpMdn = effect_MupOvpMdn_ AND effect_MupOvpMdn_R
   effect_VIA = VIA2_EXD INTERACT effect_MupOvpMdn

   VxMerged_A = SIZE effect_VIA BY VIA2_R_2_S1/2              INSIDE OF effect_MupOvpMdn STEP M2_S_1*0.7
   VxMerged_B = SIZE VxMerged_A BY (VIA2_R_2_S2 - VIA2_R_2_S1)/2 INSIDE OF effect_MupOvpMdn STEP M2_S_1*0.7
   effect_MupOvpMdn_R3 = effect_MupOvpMdn INTERACT MupOvpMdn_R3
   VxMerged_A_R3 = VxMerged_A INTERACT effect_MupOvpMdn_R3 
   VxMerged_D = SIZE VxMerged_A_R3 BY (VIA2_R_3_S3 - VIA2_R_2_S1)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M2_S_1*0.7
   VxMerged_C = SIZE VxMerged_D    BY (VIA2_R_3_S2 - VIA2_R_3_S3)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M2_S_1*0.7
   
// Pass VIAx.R.2 (2 eff. square Via)
   G1_A2R = VxMerged_A INTERACT SQR_VIA2 >=2
   G2_A2R = VxMerged_A INTERACT REC_VIA2 >=1
   VxMerged_A2 = G1_A2R OR G2_A2R
// Pass VIAx.R.2 (4 eff. square Via)
   G1_B4R =  VxMerged_B INTERACT SQR_VIA2 >=4
   G2_B4R = (VxMerged_B INTERACT SQR_VIA2 >=2 <=3) AND (VxMerged_B INTERACT REC_VIA2 ==1)
   G3_B4R =  VxMerged_B INTERACT REC_VIA2 >=2
   VxMerged_B4 = (G1_B4R OR G2_B4R) OR G3_B4R

// Pass VIAx.R.3 (4 eff. square + slot Via)
   G1_A4_13 =  VxMerged_D INTERACT REC_VIA2 >=2
   G2_A4_13 = (VxMerged_D INTERACT REC_VIA2 ==1) AND (VxMerged_D INTERACT SQR_VIA2 >=2)
   VxMerged_A4_13 = G1_A4_13 OR G2_A4_13
// Pass VIAx.R.3 (4 eff. square Via only)
   G1_A4_10 = VxMerged_A INTERACT SQR_VIA2 >=4   
   VxMerged_A4 = VxMerged_A4_13 OR G1_A4_10

// Pass VIAx.R.3 (9 eff. square Via)
   G1_C9 =  VxMerged_C INTERACT SQR_VIA2 >=9
   G2_C9 = (VxMerged_C INTERACT SQR_VIA2 >=7 <=8) AND (VxMerged_C INTERACT REC_VIA2 >=1)
   G3_C9 = (VxMerged_C INTERACT SQR_VIA2 >=5 <=6) AND (VxMerged_C INTERACT REC_VIA2 >=2)
   G4_C9 = (VxMerged_C INTERACT SQR_VIA2 >=3 <=4) AND (VxMerged_C INTERACT REC_VIA2 >=3)
   G5_C9 = (VxMerged_C INTERACT SQR_VIA2 >=1 <=2) AND (VxMerged_C INTERACT REC_VIA2 >=4)
   G6_C9 =  VxMerged_C INTERACT REC_VIA2 >=5
   VxMerged_C9 = ((G1_C9 OR G2_C9) OR (G3_C9 OR G4_C9)) OR (G5_C9 OR G6_C9) 

   Checked_Vx_R2 OUTSIDE (MupOvpMdn_R2 INTERACT (VxMerged_A2 OR VxMerged_B4))
   Checked_Vx_R3 OUTSIDE (MupOvpMdn_R3 INTERACT (VxMerged_A4 OR VxMerged_C9))
}

VIA2.R.4:M2 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA2_R_4_L um (L) and width > ^VIA2_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M2Wide_R4_VIA2 BY VIA2_R_4_D + GRID) NOT M2Wide_R4_VIA2) AND M2
  Branch1HasVia = (Branch1 INTERACT M2Wide_R4_VIA2) INTERACT VIA2_EXD
  Branch1Edge = M2Wide_R4_VIA2 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA2_R_4_D INSIDE OF Branch1HasVia STEP M2_S_1*0.4
  GoodBranch = ((Branch AND M3) INTERACT VIA2i > 1) OR ((Branch AND M3) INTERACT (REC_VIA2 OR P_RING_VIA2))
  BranchSingleVia = (VIA2i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M3 INTERACT BranchSingleVia) AND M2) INTERACT BranchSingleVia) INTERACT VIA2i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


VIA2.R.4:M3 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA2_R_4_L um (L) and width > ^VIA2_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M3Wide_R4_VIA2 BY VIA2_R_4_D + GRID) NOT M3Wide_R4_VIA2) AND M3
  Branch1HasVia = (Branch1 INTERACT M3Wide_R4_VIA2) INTERACT VIA2_EXD
  Branch1Edge = M3Wide_R4_VIA2 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA2_R_4_D INSIDE OF Branch1HasVia STEP M3_S_1*0.4
  GoodBranch = ((Branch AND M2) INTERACT VIA2i > 1) OR ((Branch AND M2) INTERACT (REC_VIA2 OR P_RING_VIA2))
  BranchSingleVia = (VIA2i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M2 INTERACT BranchSingleVia) AND M3) INTERACT BranchSingleVia) INTERACT VIA2i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


// VIA2.R.4 is checked by VIA2.R.4:M2 and VIA2.R.4:M3
// VIA2.R.5 is checked by VIA2.R.5:M2 and VIA2.R.5:M3
// VIA2.R.6 is checked by VIA2.R.6:M2 and VIA2.R.6:M3

//'VIAy.R.13' is not necessary to check
//'VIAr.R.13' is not necessary to check


VIA2.R.5:M2 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M2Wide_R5_VIA2 BY VIA2_R_5_D + GRID) NOT M2Wide_R5_VIA2) AND M2
  Branch1HasVia = (Branch1 INTERACT M2Wide_R5_VIA2) INTERACT VIA2_EXD
  Branch1Edge = M2Wide_R5_VIA2 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA2_R_5_D INSIDE OF Branch1HasVia STEP M2_S_1*0.6
  GoodBranch = ((Branch AND M3) INTERACT VIA2i > 1) OR ((Branch AND M3) INTERACT (REC_VIA2 OR P_RING_VIA2))
  BranchSingleVia = (VIA2i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M3 INTERACT BranchSingleVia) AND M2) INTERACT BranchSingleVia) INTERACT VIA2i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
VIA2.R.5:M3 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M3Wide_R5_VIA2 BY VIA2_R_5_D + GRID) NOT M3Wide_R5_VIA2) AND M3
  Branch1HasVia = (Branch1 INTERACT M3Wide_R5_VIA2) INTERACT VIA2_EXD
  Branch1Edge = M3Wide_R5_VIA2 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA2_R_5_D INSIDE OF Branch1HasVia STEP M3_S_1*0.6
  GoodBranch = ((Branch AND M2) INTERACT VIA2i > 1) OR ((Branch AND M2) INTERACT (REC_VIA2 OR P_RING_VIA2))
  BranchSingleVia = (VIA2i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M2 INTERACT BranchSingleVia) AND M3) INTERACT BranchSingleVia) INTERACT VIA2i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


M2Big_R6_VIA2 = ENCLOSE RECTANGLE M2Wide_R6_VIA2 VIA2_R_6_W VIA2_R_6_L+GRID
M3Big_R6_VIA2 = ENCLOSE RECTANGLE M3Wide_R6_VIA2 VIA2_R_6_W VIA2_R_6_L+GRID

VIA2.R.6:M2 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M2Big_R6_VIA2 BY VIA2_R_6_D + GRID) NOT M2Big_R6_VIA2) AND M2
  Branch1HasVia = (Branch1 INTERACT M2Big_R6_VIA2) INTERACT VIA2_EXD
  Branch1Edge = M2Big_R6_VIA2 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA2_R_6_D INSIDE OF Branch1HasVia STEP M2_S_1*0.6
  GoodBranch = ((Branch AND M3) INTERACT VIA2i > 1) OR ((Branch AND M3) INTERACT (REC_VIA2 OR P_RING_VIA2))
  BranchSingleVia = (VIA2i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M3 INTERACT BranchSingleVia) AND M2) INTERACT BranchSingleVia) INTERACT VIA2i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}

VIA2.R.6:M3 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M3Big_R6_VIA2 BY VIA2_R_6_D + GRID) NOT M3Big_R6_VIA2) AND M3
  Branch1HasVia = (Branch1 INTERACT M3Big_R6_VIA2) INTERACT VIA2_EXD
  Branch1Edge = M3Big_R6_VIA2 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA2_R_6_D INSIDE OF Branch1HasVia STEP M3_S_1*0.6
  GoodBranch = ((Branch AND M2) INTERACT VIA2i > 1) OR ((Branch AND M2) INTERACT (REC_VIA2 OR P_RING_VIA2))
  BranchSingleVia = (VIA2i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M2 INTERACT BranchSingleVia) AND M3) INTERACT BranchSingleVia) INTERACT VIA2i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
// VIA2.R.7 is checked by VIA2.EN.1

VIA2.R.8 { @ Single VIAx is not allowed for H-shape Mx+1 when all of the following conditions come into existence: 1. The Mx+1 has H-shape interact with two metal holes: two metal hole length(L2) <= ^VIA2_R_8_L1 um and both two metal hole area <= ^VIA2_R_8_A um2 2. The VIAx overlaps on the center metal bar of this H-shape Mx+1 3. The length (L) of the center metal bar <= ^VIA2_R_8_L2 um and the width of metal bar is <= ^VIA2_R_8_W um.
  W = M3i WITH WIDTH <= VIA2_R_8_W   
  H_HOLE = (HOLES M3i INNER <= VIA2_R_8_A) INTERACT W
  A0 = M3i INTERACT H_HOLE
  A = A0 COIN OUTSIDE EDGE H_HOLE
  B0 = ((INT A <= VIA2_R_8_W ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) INTERACT H_HOLE == 2 
  B1 = (((INT A <= VIA2_R_8_L2 ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) AND W) INTERACT H_HOLE == 2
  HOLE_NOTCH = EXT H_HOLE <= VIA2_R_8_W ABUT<90 OPPOSITE NOTCH REGION  
  B2 = (B1 NOT HOLE_NOTCH) OR B0
  CORNER_M = ((EXT B2 <= VIA2_R_8_W ABUT == 90 INTERSECTING ONLY REGION EXTENTS) TOUCH B2 == 2) AND W
  B = B2 OR CORNER_M
  CENTER_BAR1 = NOT ENCLOSE RECTANGLE B GRID VIA2_R_8_L2+GRID
  CENTER_BAR2 = (CENTER_BAR1 INTERACT H_HOLE == 2) INTERACT VIA2i
  C = CENTER_BAR2 COIN OUTSIDE EDGE H_HOLE 
  D = EXT [C] A <= VIA2_R_8_L1 OPPOSITE
  E = C NOT COIN INSIDE EDGE D
  CENTER_BAR3 = CENTER_BAR2 NOT WITH EDGE E
  CHECK_VIA = VIA2i NOT OUTSIDE CENTER_BAR3
  CHECK_VIA AND (((A0 INTERACT CHECK_VIA) AND (M2i INTERACT CHECK_VIA)) INTERACT VIA2i == 1)
}





#IFDEF CHECK_VIRTUAL_VIAx

//VIAx_VIRT.R.1 is checked by related rules (VIA2 rules)
//'VIAx_VIRT.R.2' is checked by VIA2_VIRT.R.2
VIA2_VIRT.R.2 {@ VIAx_VIRT must be 0.05 um x 0.05 um   
   NOT RECTANGLE VIA2_VIRT == VIA2_W_1 BY == VIA2_W_1 ORTHOGONAL ONLY 
}
//'VIAx_VIRT.R.3' is checked by VIA2_VIRT.R.3
VIA2_VIRT.R.3 {@ VIAx_VIRT interact VIAx is not allowed   
   VIA2_VIRT INTERACT VIA2ii
}
//'VIAx_VIRT.R.4' is checked by VIA2_VIRT.R.4
VIA2_VIRT.R.4 {@ VIAx _VIRT must be fully covered by ROM (50;6)   
   VIA2_VIRT NOT ROM
}
#ENDIF




//M3 CHECKS
//=========
M3_EDGE_45 = M3 ANGLE == 45

M3.W.1 { @ Width >= 0.05 
  INT M3 < M3_W_1 ABUT < 90 SINGULAR REGION
}
M3.W.2 { @ Width of 45-degree bent Mx. (Please make sure the vertex of 45-degree pattern is on 0.005 um grid (refer to the guideline, G.6gU, in section XXX)) >= 0.17 
  INT M3_EDGE_45 < M3_W_2 ABUT < 90 REGION
}


// 'Mx.W.3' is checked by M3.W.3
M3.W.3 { @ Maximum width Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING, or 4. {{INDDMY OR INDDMY_MD} SIZING 16 um}, or 5. CSRDMY, or 6. PADDMY (255;16) <= 4.5 
  M3_MAX_WIDTH WITH WIDTH > M3_W_3
}



 

M3.W.4 { @ Length of the edge with adjacent edge < 0.05 um [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex-270 degree inner vertex; DRC doesn't flag if there is Mx within the area formed by 0.16 um extension from these 2 edges and the 90 degree outer vertex.] (This check doesn't include the region covered by MetalFuse (156;2)) >= 0.065 
  E1 = CONVEX EDGE M3 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH < M3_W_4_L1
  E2 = CONVEX EDGE M3 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH >= M3_W_4_L1 < M3_W_4_L2
  A = INT [E1]    < M3_W_4_L2 ABUT == 90 INTERSECTING ONLY
  B = INT [E2] E1 < M3_W_4_L2 ABUT == 90 INTERSECTING ONLY
  C = INT [E1] E2 < M3_W_4_L2 ABUT == 90 INTERSECTING ONLY
  D = OR EDGE  B (OR EDGE A C)
  CORNER_BAD_pre = (EXPAND EDGE D INSIDE BY 0.001) NOT INSIDE MFUSE
  W = EXT [D] M3 < 0.16
  CORNER_BAD_pre NOT WITH EDGE W
}
M3.S.1 { @ Space >= 0.05 
  EXT M3 < M3_S_1 ABUT < 90 SINGULAR REGION
}

M3.S.2 { @ Space [at least one metal line width > 0.09 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.06 
  X = EXT M3_20 M3 < M3_S_2 OPPOSITE REGION MEASURE ALL
  Y = X NOT M3
  ENCLOSE RECTANGLE Y GRID M3_S_2_L+GRID
}
M3.S.3 { @ Space [at least one metal line width > 0.16 um (W2) and the parallel run length > 0.22 um (L2)] >= 0.1 
  X = EXT M3_21 M3 < M3_S_3 OPPOSITE REGION MEASURE ALL
  Y = X NOT M3
  (ENCLOSE RECTANGLE Y GRID M3_S_3_L+GRID) NOT INSIDE SRAM_WAIVE_N28 
}
M3.S.4 { @ Space [at least one metal line width > 0.47 um (W3) and the parallel run length > 0.47 um (L3)] >= 0.13 
  X = EXT M3_22 M3 < M3_S_4 OPPOSITE REGION MEASURE ALL
  Y = X NOT M3
  ENCLOSE RECTANGLE Y GRID M3_S_4_L+GRID
}
M3.S.5 { @ Space [at least one metal line width > 0.63 um (W4) and the parallel run length > 0.63 um (L4)] >= 0.15 
  X = EXT M3_23 M3 < M3_S_5 OPPOSITE REGION MEASURE ALL
  Y = X NOT M3
  ENCLOSE RECTANGLE Y GRID M3_S_5_L+GRID
}
M3.S.6 { @ Space [at least one metal line width > 1.5 um (W5) and the parallel run length > 1.5 um (L5)] >= 0.5 
  X = EXT M3_30 M3 < M3_S_6 OPPOSITE REGION MEASURE ALL
  Y = X NOT M3
  ENCLOSE RECTANGLE Y 0.001 M3_S_6_L+0.001
}


M3.S.7 { @ Space to Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.07 
  A = CONVEX EDGE M3 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M3_S_7_W
  EXT A M3 < M3_S_7 ABUT < 90 OPPOSITE EXTENDED M3_S_7_T REGION
}

M3.S.8 { @ Mx line space (S1) to dense Mx line-end [parallel run length > -0.025 um (T)], and dense Mx line-end enclosure of Vx-1 (V). Definition of dense Mx line-end: 1. Mx line-end: Mx edge with length < 0.07 um (W) between 2 outer vertex. 2. Other metal INTERACT Region 1. Region 1 = (T+Q) x S2. (W+S2) < 0.115 um. This check doesn't include small jog with edge length < 0.05 um (R) >= 0.08/0.05 or 0.1/0.03 
  M3_END = CONVEX EDGE M3 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M3_S_8_W
  M3_REGION = EXPAND EDGE M3_END OUTSIDE BY M3_S_8_SB + GRID EXTEND BY M3_S_8_T + GRID  // for data reduction
  M3_LINE = (M3 INSIDE EDGE M3_REGION) NOT TOUCH EDGE M3_END
  M3_EA = ENC VIA2i [M3_END] < M3_S_8_EA ABUT < 90 OPPOSITE
  M3_EB = ENC VIA2i [M3_END] < M3_S_8_EB ABUT < 90 OPPOSITE
  M3_SA = EXT [M3_END] M3_LINE < M3_S_8_SA ABUT < 90 OPPOSITE EXTENDED M3_S_8_T
  M3_SB = EXT [M3_END] M3_LINE < M3_S_8_SB ABUT < 90 OPPOSITE EXTENDED M3_S_8_T
  M3_PASS_A = (M3_END NOT TOUCH INSIDE EDGE M3_EA) NOT TOUCH INSIDE EDGE M3_SA
  M3_PASS_B = (M3_END NOT TOUCH INSIDE EDGE M3_EB) NOT TOUCH INSIDE EDGE M3_SB
  M3_CHECK = (M3_END NOT TOUCH INSIDE EDGE M3_PASS_A) NOT TOUCH INSIDE EDGE M3_PASS_B

  M3_Long_side = LENGTH M3 >= M3_W_1
  O = INT M3_CHECK [M3_Long_side] < M3_S_8_Q-M3_S_8_T ABUT == 90 INTERSECTING ONLY  
  PW = INT O M3 < (M3_S_8_P - M3_S_1) ABUT < 90 OPPOSITE EXTENDED M3_S_8_T
  PS = EXT O M3 < (M3_S_8_P - M3_W_1) ABUT < 90 OPPOSITE EXTENDED M3_S_8_T
  Q = DFM PROPERTY O PS PW OVERLAP ABUT ALSO MULTI
  [-= MIN(EW(PW)) + MIN(EW(PS))] < M3_S_8_P
  R = M3_CHECK TOUCH EDGE (EXPAND EDGE Q INSIDE BY 0.001)
  ENC VIA2i R < M3_S_8_EA ABUT < 90 OPPOSITE REGION
  EXT R M3 < M3_S_8_SB ABUT < 90 OPPOSITE EXTENDED M3_S_8_T REGION
}


M3.S.9 { @ Space to 45-degree bent Mx >= 0.17 
  X = EXPAND EDGE M3_EDGE_45 OUTSIDE BY M3_S_9
  X AND M3
}


M3_HVN_65V = NET AREA RATIO M3i OVER M9_HV_65V M8_HV_65V M7_HV_65V M6_HV_65V M5_HV_65V M4_HV_65V M3_HV_65V M2_HV_65V M1_HV_65V PO_HV_65V NW_HV_65V DNW_HV_65V > 0
M3_HVN_5V = NET AREA RATIO M3i OVER M9_HV_5V M8_HV_5V M7_HV_5V M6_HV_5V M5_HV_5V M4_HV_5V M3_HV_5V M2_HV_5V M1_HV_5V > 0
M3_HVN = NET AREA RATIO M3i OVER M9_HV M8_HV M7_HV M6_HV M5_HV M4_HV M3_HV M2_HV M1_HV > 0
M3_MVN = NET AREA RATIO M3i OVER M9_MV M8_MV M7_MV M6_MV M5_MV M4_MV M3_MV M2_MV M1_MV > 0
M3_MLVN = NET AREA RATIO M3i OVER M9_MLV M8_MLV M7_MLV M6_MLV M5_MLV M4_MLV M3_MLV M2_MLV M1_MLV > 0
M3_LVN = NET AREA RATIO M3i OVER M9_LV M8_LV M7_LV M6_LV M5_LV M4_LV M3_LV M2_LV M1_LV > 0
M3_VNVN_pre = NET AREA RATIO M3i OVER M9_VNV M8_VNV M7_VNV M6_VNV M5_VNV M4_VNV M3_VNV M2_VNV M1_VNV > 0
M3_NVN = NET AREA RATIO M3i OVER M9_NV M8_NV M7_NV M6_NV M5_NV M4_NV M3_NV M2_NV M1_NV > 0
M3_VNVN = M3_VNVN_pre NOT M3_NVN
M3_NOMARK = (((((((M3i NOT M3_HVN_65V) NOT M3_HVN_5V) NOT M3_HVN) NOT M3_MVN) NOT M3_MLVN) NOT M3_LVN) NOT M3_NVN) NOT M3_VNVN



#IFDEF USE_IO_VOLTAGE_ON_CORE_TO_IO_NET
  M3_NOMARK_65V = NET AREA RATIO M3_NOMARK PSD_65 NSD_65 PSTPix > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSTPix)]
  M3_NOMARK_5V = NET AREA RATIO M3_NOMARK PSD_50 NSD_50 PSTPix > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)]
  M3_NOMARK_HV = NET AREA RATIO M3_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)]
  M3_NOMARK_MV = NET AREA RATIO M3_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)]
  M3_NOMARK_MLV = NET AREA RATIO M3_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)]
  M3_NOMARK_LV = NET AREA RATIO M3_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]  



#ELSE
  M3_NOMARK_65V = NET AREA RATIO M3_NOMARK PSD_65 NSD_65 PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSD_50)*!AREA(NSD_50)*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M3_NOMARK_5V = NET AREA RATIO M3_NOMARK PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M3_NOMARK_HV = NET AREA RATIO M3_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M3_NOMARK_MV = NET AREA RATIO M3_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M3_NOMARK_MLV = NET AREA RATIO M3_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M3_NOMARK_LV = NET AREA RATIO M3_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]


#ENDIF

M3_HV_65V_ALL = M3_HVN_65V OR M3_NOMARK_65V
M3_HV_5V_ALL = M3_HVN_5V OR M3_NOMARK_5V
M3_HV_ALL = M3_HVN OR M3_NOMARK_HV
M3_MV_ALL = M3_MVN OR M3_NOMARK_MV
M3_MLV_ALL = M3_MLVN OR M3_NOMARK_MLV
M3_LV_ALL = M3_LVN OR M3_NOMARK_LV
M3_NV_ALL = COPY M3_NVN
M3_VNV_ALL = COPY M3_VNVN

M3_VNV_CHK = STAMP M3_VNV_ALL BY M3i
VIA3_VNV_CHK = STAMP (VIA3ii AND M3_VNV_ALL) BY M3i
M3_NV_CHK = STAMP M3_NV_ALL BY M3i
VIA3_NV_CHK = STAMP (VIA3ii AND M3_NV_ALL) BY M3i  
M3_LV_CHK = STAMP M3_LV_ALL BY M3i
VIA3_LV_CHK = STAMP (VIA3ii AND M3_LV_ALL) BY M3i
M3_MLV_CHK = STAMP M3_MLV_ALL BY M3i
VIA3_MLV_CHK = STAMP (VIA3ii AND M3_MLV_ALL) BY M3i
M3_MV_CHK = STAMP M3_MV_ALL BY M3i
VIA3_MV_CHK = STAMP (VIA3ii AND M3_MV_ALL) BY M3i

M3_HV_CHK = STAMP M3_HV_ALL BY M3i
VIA3_HV_CHK = STAMP (VIA3ii AND M3_HV_ALL) BY M3i
M3_HV_5V_CHK = STAMP M3_HV_5V_ALL BY M3i
VIA3_HV_5V_CHK = STAMP (VIA3ii AND M3_HV_5V_ALL) BY M3i
M3_HV_65V_CHK = STAMP M3_HV_65V_ALL BY M3i
VIA3_HV_65V_CHK = STAMP (VIA3ii AND M3_HV_65V_ALL) BY M3i























M3.S.12 { @ Space of Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.08 
  A = CONVEX EDGE M3 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M3_S_12_W
  EXT A < M3_S_12 ABUT < 90 OPPOSITE EXTENDED M3_S_12_T REGION
}

M3.S.13 { @ Space [at least one metal line width > 0.13 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.08 
  X = EXT M3_201 M3 < M3_S_13 OPPOSITE REGION MEASURE ALL
  Y = X NOT M3
  ENCLOSE RECTANGLE Y GRID M3_S_13_L+GRID
}


// M3.EN.0,enclosure of square VIAx-1 is defined by either {Mx.EN.1/Mx.EN.2} or Mx.EN.3
// M3.EN.0 is checked by either {M3.EN.1/M3.EN.2} or M3.EN.3

M3.EN.1 { @ Enclosure of square VIAx-1 >= 0 
  VIA2i NOT M3i
}
M3.EN.2__M3.EN.3__M3.EN.14__M3.EN.15 { @ Enclosure of VIA2 [at least two opposite sides] >= ^M3_EN_2 um OR [all sides] >= ^M3_EN_3 OR [all side] >= ^M3_EN_14 / [at least two opposite sides] >= ^M3_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA2 M3i ABUT < 90 SINGULAR GOOD 0 M3_EN_2 OPPOSITE 0 M3_EN_2 OPPOSITE GOOD M3_EN_14 M3_EN_15 OPPOSITE M3_EN_14 M3_EN_15 OPPOSITE
  ENC X M3i < M3_EN_3 ABUT < 90 SINGULAR REGION
}

// M3.EN.4, Enclosure of rectangular VIAx-1 is defined by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3
// M3.EN.4 is checked by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3

M3.EN.3__M3.EN.5__M3.EN.6__M3.EN.7 { @ Enclosure of rectangular VIA2 [two opposite side >= ^M3_EN_7 and all side >= ^M3_EN_5], OR Enclosure of rectangular VIA2 [at rectangular VIA2 end direction] >= ^M3_EN_6, OR Enclosure of rectangular VIA2 [all sides] >= ^M3_EN_3
  A = RECTANGLE ENCLOSURE REC_VIA2 M3i ABUT < 90 SINGULAR GOOD M3_EN_5 M3_EN_7 OPPOSITE M3_EN_5 M3_EN_7 OPPOSITE GOOD M3_EN_3 M3_EN_3 M3_EN_3 M3_EN_3
  B = LENGTH A == VIA2_W_1
  C = ENC [B] M3i < M3_EN_6 ABUT < 90 OPPOSITE
  A WITH EDGE C
}

// M3.EN.3, M3.EN.5, M3.EN.6 and M3.EN.7 are checked by M3.EN.3__M3.EN.5__M3.EN.6__M3.EN.7
// M3.EN.8 is checked by M3.EN.1

M3_W_55b = M3 WITH WIDTH == M3_EN_9_W 
M3_W_70b = M3 WITH WIDTH > M3_EN_9_W <= M3_EN_10_W 
M3_W_160b = M3 WITH WIDTH > M3_EN_10_W <=M3_EN_11W
M3_W_450b = M3 WITH WIDTH > M3_EN_11W <=M3_EN_12W

M3.EN.9 { @ Enclosure of VIAx-1 [0.055 um >= metal width > 0.05 um, metal space < 0.06 um (D1) and the other side space >= 0.06 um (D1'), parallel run length > 0.1 um] >= 0.005 
  A0 = M3_W_55b INTERACT VIA2i 
  A = EXT A0 [M3] < M3_EN_9_S1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A M3 < M3_EN_9_S1 ABUT < 90 OPPOSITE REGION
  C = EXT A M3 < M3_EN_9_S1 ABUT < 90 OPPOSITE
  D = EXT A [M3] < M3_EN_9_S1 ABUT < 90 OPPOSITE
  E0 = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
  [-= EC(C) ] > M3_EN_9_L
  E1 = E0 NOT WITH EDGE (ANGLE M3 >0 < 90) 
  E = E0 NOT (E1 NOT ENCLOSE RECTANGLE M3_EN_9_L+GRID GRID ORTHOGONAL ONLY)  
  F = D COIN OUTSIDE EDGE E
  G = (EXPAND EDGE F INSIDE BY M3_EN_9_W) INTERACT E != 2  
  H = F COIN INSIDE EDGE G 
  ENC VIA2i H < M3_EN_9 ABUT < 90 OPPOSITE REGION
}
M3.EN.10 { @ Enclosure of VIAx-1 [0.07 um >= metal width > 0.055 um, metal space < 0.065 um (D1) and parallel run length > 0.1 um] >= 0.005 
  W = EXT M3_W_70b [M3] < M3_EN_10_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M3i] < M3_EN_10_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M3i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M3i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M3_EN_10_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M3_EN_10_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA2i S7_H < M3_EN_10 ABUT < 90 OPPOSITE REGION
  ENC VIA2i S7_V < M3_EN_10 ABUT < 90 OPPOSITE REGION

}
M3.EN.11 { @ Enclosure of VIAx-1 [0.16 um >= metal width > 0.07 um, metal space < 0.1 um (D1) and parallel run length > 0.1 um] (For Mx.EN.11, the rule check is not included same VIAx group, which is defined as below.) 1. VIAx space <= 0.11 um2. Mx is same net 3. Mx+1 is same net >= 0.01 
  VIA2_M = SIZE VIA2i BY M3_EN_11_S/2 INSIDE OF SAME_NET_VIA2 STEP M2_S_1*0.6
  VIA2_C = VIA2i NOT INTERACT (VIA2_M INTERACT VIA2i >= 2)
  W = EXT M3_W_160b [M3] < M3_EN_11_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M3i] < M3_EN_11_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M3i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M3i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M3_EN_11_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M3_EN_11_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  (ENC VIA2_C S7_H < M3_EN_11 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28
  (ENC VIA2_C S7_V < M3_EN_11 ABUT < 90 OPPOSITE REGION) NOT INSIDE SRAM_WAIVE_N28

}
// 'Mx.EN.12' is checked by M3.EN.12
M3.EN.12 { @ Enclosure of VIAx-1 [4.5 um >= metal width > 0.16 um, metal space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M3_W_450b [M3] < M3_EN_12_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M3i] < M3_EN_12_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M3i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M3i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M3_EN_12_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M3_EN_12_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA2i S7_H < M3_EN_12 ABUT < 90 OPPOSITE REGION
  ENC VIA2i S7_V < M3_EN_12 ABUT < 90 OPPOSITE REGION

}
// 'Mx.EN.13' is checked by M3.EN.13
M3.EN.13 { @ Enclosure of VIAx-1 bar in LOWMEDN >= 0.1 
  ENC P_RING_VIA2 M3 < M3_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}
// 'Mx.L.1' is checked by M3.L.1
M3.L.1 { @ Length of 45-degree bent Mx (minimum edge length) >= 0.5 
  (LENGTH M3_EDGE_45 < M3_L_1) NOT INSIDE EDGE SEALRING_ALL
}

M3.A.1 { @ Area (except M2) >= 0.017 
  AREA M3 < M3_A_1
}
//'Mx.A.1' is checked by M3.A.1
M3.A.3 { @ Area [with all of edge lengths < 0.13 um] (Except M2 inside SRAMDMY;0) (This check doesn't include the patterns filling 0.05 um x 0.13 um rectangular tile) >= 0.044 
  A = AREA M3 < M3_A_3
  B = LENGTH A >= M3_A_3_L1
  C = A NOT WITH EDGE B
  NOT ENCLOSE RECTANGLE C M3_A_3_W M3_A_3_L2 ORTHOGONAL ONLY
}

VARIABLE M3_A_4pre ((M3_A_4 + (M3_S_1 * M3_S_1 * 3.142))/(2 * M3_S_1))*((M3_A_4 + (M3_S_1 * M3_S_1 * 3.142))/(2 * M3_S_1))/3.141 // user value

M3.A.4 { @ Enclosed area >= 0.2 
  X = HOLES M3 INNER < M3_A_4pre
  AREA ( X NOT M3 ) < M3_A_4
}

//'DMx_O.R.1' is checked by DM3_O.R.1
DM3_O.R.1 { @ DMx_O INTERACT Mx is not allowed. [Mx, and My only]   
  DM3_O INTERACT M3i
}






// 'Mx.DN.0.1' is checked by related rules




//'My.DN.0' is not necessary to check
//'My.DN.1' is not necessary to check
//'My.DN.2' is not necessary to check
//'My.DN.3' is not necessary to check

//'Mr.DN.0' is not necessary to check
//'Mr.DN.1' is not necessary to check
//'Mr.DN.2' is not necessary to check
//'Mr.DN.3' is not necessary to check



//'Mx.DN.1' is checked by M3.DN.1
#IFDEF CHECK_LOW_DENSITY
M3.DN.1 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum metal density in window 125 um x 125 um, stepping 62.5*20% um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10%+3% 
#ELSE
@ Minimum metal density in window 125 um x 125 um, stepping 62.5 um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10% 
#ENDIF
  EXC_LOW = M3_EXC_LOW OR ICOVL
  N = M3x NOT EXC_LOW
  D = CHIP NOT EXC_LOW 
  A = CHIP_M3 NOT EXC_LOW
  X = DENSITY A M3x CHIP N D < M3_DN_1 WINDOW M3_DN_1_W STEP M3_DN_1_S BACKUP INSIDE OF LAYER CHIP_M3 PRINT M3.DN.1.density RDB M3.DN.1.RDB.density
          [~(AREA(A)-M3_DN_1_E)*!!(AREA(A)-M3_DN_1_E)+AREA(N)/AREA(D)+!~(AREA(M3x)/AREA(CHIP)-M3_DN_1)+!(AREA(M3x)/AREA(CHIP)-M3_DN_1)]


  COPY X    
}
#ENDIF



//'Mx.DN.2' is checked by M3.DN.2
M3.DN.2 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum metal density in window 125 um x 125 um, stepping 62.5*20% um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85%-3% 
#ELSE
@ Maximum metal density in window 125 um x 125 um, stepping 62.5 um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85% 
#ENDIF
  EXC_HIGH = M3_EXC_HIGH OR ICOVL
  N = M3x NOT EXC_HIGH
  D = CHIP NOT EXC_HIGH 
  A = CHIPx NOT EXC_HIGH
  X = DENSITY A M3x CHIP N D > M3_DN_2 WINDOW M3_DN_2_W STEP M3_DN_2_S BACKUP INSIDE OF LAYER CHIPx PRINT M3.DN.2.density RDB M3.DN.2.RDB.density
          [~(M3_DN_2_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M3x)/AREA(CHIP)-M3_DN_2)]


  COPY X    
}

//'Mx.DN.3' is checked by M3.DN.3
M3.DN.3 { @ The metal density difference between any 2 neighboring checking windows including DMxEXCL [window 200 um x 200 um, stepping 200 um]. Anticipate metal density gradient from layout of small cell by targeting density ~50% (this way, it will limit the risk of low density and of high gradient).(Except ICOVL) <= 50% 
   EXCEPT =  COPY ICOVL
   M3x_Chk = M3x NOT EXCEPT
   DENSITY M3x_Chk EXCEPT CHIP <=1 WINDOW M3_DN_3_W BACKUP GRADIENT > M3_DN_3 ABSOLUTE CORNER INSIDE OF LAYER CHIPx PRINT M3.DN.3.density RDB M3.DN.3.RDB.density
    [ (AREA(M3x_Chk)+AREA(EXCEPT)*M3_DN_3_V)/AREA(CHIP) ] 
}

M3_CORE = M3x NOT SRCSR_P4
//'Mx.DN.4' is checked by Mx.DN.4:M1_M2_M3 
Mx.DN.4:M1_M2_M3 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ It is not allowed to have local density > 85% of all 3 consecutive metal (Mx, Mx+1 and Mx+2) over any window 62.5 um x 62.5 um (stepping 31.25*20% um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density > 85%+3%. 1. The metal layers include M1/Mx and dummy metals. 2. Except following condition: (1). Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or (2). Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or (3). SEALRING_ALL, or (4) Chip corner triangle empty areas
#ELSE
@ It is not allowed to have local density > 85% of all 3 consecutive metal (Mx, Mx+1 and Mx+2) over any window 62.5 um x 62.5 um (stepping 31.25 um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density > 85%. 1. The metal layers include M1/Mx and dummy metals. 2. Except following condition: (1). Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or (2). Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or (3). SEALRING_ALL, or (4) Chip corner triangle empty areas   
#ENDIF
 DENSITY  M1_CORE M2_CORE M3_CORE >0 WINDOW M1_DN_4_W STEP M1_DN_4_S BACKUP INSIDE OF LAYER CHIPx 
      [ !~(AREA(M1_CORE)/AREA()- M1_DN_4)*!~(AREA(M2_CORE)/AREA()- M1_DN_4)*!~(AREA(M3_CORE)/AREA()- M1_DN_4) ]
      RDB Mx.DN.4:M1_M2_M3.density
}


#IFDEF CHECK_LOW_DENSITY
M3.DN.6 { @ Metal Density >= ^M3_DN_6 must be followed for item(A) to (C)
@ (A) Metal density [checking window ^M3_DN_6_W_A um x ^M3_DN_6_W_A um, stepping ^M3_DN_6_S_A um] >= ^M3_DN_6
@ (B) Maximum area of merged low density windows [checking window ^M3_DN_6_W_BC um x ^M3_DN_6_W_BC um, stepping ^M3_DN_6_S_BC um, density < ^M3_DN_6] <= ^M3_DN_6_A_B um2. Merged low density windows width <= ^M3_DN_6_U um is except.
@ (C) Maximum area of merged low density windows [checking window ^M3_DN_6_W_BC um x ^M3_DN_6_W_BC um, stepping ^M3_DN_6_S_BC um, density < ^M3_DN_6] <= ^M3_DN_6_A_C um2
@ 1. The following special regions are excluded
@    Chip corner triangle empty areas if sealring is added by tsmc. 
@    LOWMEDN
@ 2. This rule is applied while the width of (checking window NOT above excluding region) >= ^M3_DN_6_E_A um for (A) and >= ^M3_DN_6_E_BC um for both (B)/(C) 
  M3_CHECK = M3x NOT (NEW_DEN_EXC OR ICOVL)
  CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
  // Condition-A
  ERR_WIN_A = DENSITY M3_CHECK CHIP_CHECK < M3_DN_6 WINDOW M3_DN_6_W_A STEP M3_DN_6_S_A INSIDE OF LAYER CHIP_M3 BACKUP 
	[ AREA(M3_CHECK)/AREA(CHIP_CHECK) ]
  F_A = WITH WIDTH (ERR_WIN_A NOT (NEW_DEN_EXC OR ICOVL)) >= M3_DN_6_E_A
  DENSITY F_A M3_CHECK CHIP_CHECK < M3_DN_6 WINDOW M3_DN_6_W_A STEP M3_DN_6_S_A INSIDE OF LAYER CHIP_M3 BACKUP PRINT M3.DN.6_A.density
         [ !AREA(F_A)+AREA(M3_CHECK)/AREA(CHIP_CHECK) ]
  // Condition-B 
  ERR_WIN_B = DENSITY M3_CHECK CHIP_CHECK < M3_DN_6 WINDOW M3_DN_6_W_BC STEP M3_DN_6_S_BC INSIDE OF LAYER CHIP_M3 BACKUP 
	[ AREA(M3_CHECK)/AREA(CHIP_CHECK) ]
  F_B = WITH WIDTH (ERR_WIN_B NOT (NEW_DEN_EXC OR ICOVL)) >= M3_DN_6_E_BC
  A = DENSITY F_B M3_CHECK CHIP_CHECK < M3_DN_6 WINDOW M3_DN_6_W_BC STEP M3_DN_6_S_BC INSIDE OF LAYER CHIP_M3 BACKUP PRINT M3.DN.6_BC.density
         [ !AREA(F_B)+AREA(M3_CHECK)/AREA(CHIP_CHECK) ]
  B = AREA A > M3_DN_6_A_B
  C = SIZE B BY M3_DN_6_U/2 UNDEROVER
  B INTERACT C
  // Condition-C
  AREA B > M3_DN_6_A_C
}
#ENDIF

#IFDEF CHECK_LOW_DENSITY
//'Mx.DN.7' is checked by Mx.DN.7:M1_M2_M3
Mx.DN.7:M1_M2_M3 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ It is not allowed to have local density < 5% of all 3 consecutive metal (Mx, Mx+1, and Mx+2) over any 30 um x 30 um (stepping 15*20% um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density >= 5+3%. 1. The metal layers include M1/Mx and dummy metals for ELK film. 2. The following special regions are excluded while the density checking: - Chip corner triangle empty areas if seal-ring is added by tsmc. - LOWMEDN, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area)    
#ELSE
@ It is not allowed to have local density < 5% of all 3 consecutive metal (Mx, Mx+1, and Mx+2) over any 30 um x 30 um (stepping 15 um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density >= 5%. 1. The metal layers include M1/Mx and dummy metals for ELK film. 2. The following special regions are excluded while the density checking: - Chip corner triangle empty areas if seal-ring is added by tsmc. - LOWMEDN, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area)   
#ENDIF
   M1_CHECK = M1x NOT (NEW_DEN_EXC OR ICOVL)
   M2_CHECK = M2x NOT (NEW_DEN_EXC OR ICOVL)
   M3_CHECK = M3x NOT (NEW_DEN_EXC OR ICOVL)
   CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
   DENSITY M1_CHECK M2_CHECK M3_CHECK CHIP_CHECK >0 WINDOW M1_DN_7_W STEP M1_DN_7_S BACKUP INSIDE OF LAYER CHIP_M3
   [ ~(M1_DN_7_E-AREA(CHIP_CHECK))*!~(M1_DN_7-(AREA(M1_CHECK)/AREA(CHIP_CHECK)))*!~(M1_DN_7-(AREA(M2_CHECK)/AREA(CHIP_CHECK)))*!~(M1_DN_7-(AREA(M3_CHECK)/AREA(CHIP_CHECK))) ]
   RDB Mx.DN.7:M1_M2_M3.density
}
#ENDIF





//VIA3 CHECKS
//===========
VIA3.W.1 { @  Width x Length = 0.05 x 0.05, 0.05 x 0.13 (Except seal-ring (162,2) and {LOWMEDN NOT {LOWMEDN SIZING -4 m}})
  A = NOT RECTANGLE VIA3i == VIA3_W_1 BY == VIA3_L_1 ORTHOGONAL ONLY
  B = NOT RECTANGLE A == VIA3_W_1 BY == VIA3_L_2 ORTHOGONAL ONLY    
  B NOT (VIA_EXD OR P_RING_REGION)
}

// 'VIAx.W.6' is checked by VIA3.W.6
VIA3.W.6 { @ Width of VIAx bar in protection ring [INSIDE LOWMEDN] = 0.15 
  INT P_RING_VIA3 > VIA3_W_6+2*GRID < VIA3_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  WITH WIDTH P_RING_VIA3 >= VIA3_W_6*2
  INT P_RING_VIA3 < VIA3_W_6-2*GRID ABUT < 90 REGION
}
SAME_NET_VIA3 = M3i AND M4i

VIA3.S.1 { @ Square VIAx space >= 0.07 
  EXT VIA3i < VIA3_S_1 ABUT < 90 SINGULAR REGION
}

VIA3.S.3 { @ Square VIAx space to rectangular VIAx >= 0.075 
  EXT SQR_VIA3 REC_VIA3 < VIA3_S_3 ABUT < 90 SINGULAR REGION
}
VIA3.S.4 { @ Rectangular VIAx space to rectangular VIAx >= 0.08 
  EXT REC_VIA3 < VIA3_S_4 ABUT < 90 SINGULAR REGION
}
VIA3.S.5 { @ VIAx space [parallel run length > -0.04 um] >= 0.08 
   EXT VIA3i < VIA3_S_5 ABUT < 90 OPPOSITE EXTENDED VIA3_S_5_L REGION
}





VIA3.S.18 { @ Space of VIAx bar in LOWMEDN to VIAx hole >= 0.35 
  EXT P_RING_VIA3 VIA3_EXD < VIA3_S_18 ABUT < 90 SINGULAR REGION
}

VIA3.S.19 { @ Space of VIAx bar in LOWMEDN >= 0.6 
  EXT P_RING_VIA3 < VIA3_S_19 ABUT < 90 SINGULAR REGION
}









// VIA3.EN.0 is checked by either {VIA3.EN.1/VIA3.EN.2} or VIA3.EN.3

VIA3.EN.1 { @ Enclosure by M1 or Mx >= 0 
  VIA3i NOT M3i
}
VIA3.EN.2__VIA3.EN.3__VIA3.EN.14__VIA3.EN.15 { @ Enclosure by M3 [at least two opposite sides] >= ^VIA3_EN_2 um OR [all sides] >= ^VIA3_EN_3 OR [all side] >= ^VIA3_EN_14 / [at least two opposite sides] >= ^VIA3_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA3 M3i ABUT < 90 SINGULAR GOOD 0 VIA3_EN_2 OPPOSITE 0 VIA3_EN_2 OPPOSITE GOOD VIA3_EN_14 VIA3_EN_15 OPPOSITE VIA3_EN_14 VIA3_EN_15 OPPOSITE
  ENC X M3i < VIA3_EN_3 ABUT < 90 SINGULAR REGION
}


// VIA3.EN.4,	Rectangular VIAx enclosure by M1 or Mx is defined by either {VIAx.EN.5/VIAx.EN.7} or {VIAx.EN.6/VIAx.EN.8} or VIAx.EN.3
// VIA3.EN.4 is checked by either {VIA3.EN.5/VIA3.EN.7} or VIA3.EN.3

VIA3.EN.3__VIA3.EN.5__VIA3.EN.6__VIA3.EN.7 { @ Enclosure by M3 [two opposite direction >= ^VIA3_EN_7 and all side >= ^VIA3_EN_5], OR Enclosure by M3 [at rectangular VIA3 end direction] >= ^VIA3_EN_6, OR Enclosure by M3 [all sides] >= ^VIA3_EN_3    
  A = RECTANGLE ENCLOSURE REC_VIA3 M3i ABUT < 90 SINGULAR GOOD VIA3_EN_5 VIA3_EN_7 OPPOSITE VIA3_EN_5 VIA3_EN_7 OPPOSITE GOOD VIA3_EN_3 VIA3_EN_3 VIA3_EN_3 VIA3_EN_3
  B = LENGTH A == VIA3_W_1
  C = ENC [B] M3i < VIA3_EN_6 ABUT < 90 OPPOSITE
  A WITH EDGE C

}
// VIA3.EN.3, VIA3.EN.5, VIA3.EN.6 and VIA3.EN.7 are checked by VIA3.EN.3__VIA3.EN.5__VIA3.EN.6__VIA3.EN.7
// VIA3.EN.8 is checked by VIA3.EN.1

M3_W_55 = M3 WITH WIDTH == VIA3_EN_9_W 
M3_W_70 = M3 WITH WIDTH > VIA3_EN_9_W <= VIA3_EN_10_W 
M3_W_160 = M3 WITH WIDTH > VIA3_EN_10_W <=VIA3_EN_11W
M3_W_450 = M3 WITH WIDTH > VIA3_EN_11W <=VIA3_EN_12W

//'VIAx.EN.9' is checked by VIA3.EN.9
VIA3.EN.9 { @ Enclosure by Mx [0.055 um >= metal width > 0.05 um, space < 0.06 um (D1) and the other side space >= 0.06 um (D1'), parallel run length > 0.1 um] >= 0.005 
  A0 = M3_W_55 INTERACT VIA3i 
  A = EXT A0 [M3] < VIA3_EN_9_S1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A M3 < VIA3_EN_9_S1 ABUT < 90 OPPOSITE REGION
  C = EXT A M3 < VIA3_EN_9_S1 ABUT < 90 OPPOSITE
  D = EXT A [M3] < VIA3_EN_9_S1 ABUT < 90 OPPOSITE
  E0 = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
  [-= EC(C) ] > VIA3_EN_9_L
  E1 = E0 NOT WITH EDGE (ANGLE M3 >0 < 90) 
  E = E0 NOT (E1 NOT ENCLOSE RECTANGLE VIA3_EN_9_L+GRID GRID ORTHOGONAL ONLY)  
  F = D COIN OUTSIDE EDGE E
  G = (EXPAND EDGE F INSIDE BY VIA3_EN_9_W) INTERACT E != 2  
  H = F COIN INSIDE EDGE G 
  ENC VIA3i H < VIA3_EN_9 ABUT < 90 OPPOSITE REGION
}
//'VIAx.EN.10' is checked by VIA3.EN.10
VIA3.EN.10 { @ Enclosure by Mx [0.07 um >= metal width > 0.055 um, space < 0.065 um (D1) and parallel run length > 0.1 um] >= 0.005 
  W = EXT M3_W_70 [M3] < VIA3_EN_10_S ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M3i] < VIA3_EN_10_S ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M3i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M3i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA3_EN_10_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA3_EN_10_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA3i S7_H < VIA3_EN_10 ABUT < 90 OPPOSITE REGION
  ENC VIA3i S7_V < VIA3_EN_10 ABUT < 90 OPPOSITE REGION

}
//'VIAx.EN.11' is checked by VIA3.EN.11
VIA3.EN.11 { @ Enclosure by Mx [0.16 um >= metal width > 0.07 um, space < 0.1 um (D1) and parallel run length > 0.1 um] (For VIAx.EN.11, the rule check is not included same VIAx group, which is defined as below). 1. VIAx space <= 0.11 um2. Mx is same net 3. Mx+1 is same net >= 0.01 
  VIA3_M = SIZE VIA3i BY VIA3_EN_11_S/2 INSIDE OF SAME_NET_VIA3 STEP M3_S_1*0.6
  VIA3_C = VIA3i NOT INTERACT (VIA3_M INTERACT VIA3i >= 2)
  W = EXT M3_W_160 [M3] < VIA3_EN_11D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M3i] < VIA3_EN_11D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M3i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M3i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA3_EN_11L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA3_EN_11L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA3_C S7_H < VIA3_EN_11 ABUT < 90 OPPOSITE REGION
  ENC VIA3_C S7_V < VIA3_EN_11 ABUT < 90 OPPOSITE REGION

}
VIA3.EN.12 { @ Enclosure by M1 or Mx [4.5 um >= metal width > 0.16 um, space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M3_W_450 [M3] < VIA3_EN_12D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M3i] < VIA3_EN_12D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M3i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M3i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M3i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA3_EN_12L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA3_EN_12L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA3i S7_H < VIA3_EN_12 ABUT < 90 OPPOSITE REGION
  ENC VIA3i S7_V < VIA3_EN_12 ABUT < 90 OPPOSITE REGION

}
// 'VIAx.EN.13' is checked by VIA3.EN.13
VIA3.EN.13 { @ VIAx bar enclosure by M1/Mx in LOWMEDN >= 0.1 
  ENC P_RING_VIA3 M3 < VIA3_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}

// VIA3.L.1 is checked by VIA3.W.1
// VIA3.L.2 is checked by VIA3.W.1

// VIA3.R.0 is checked by VIA3.W.1
// VIA3.R.1 is checked by [VIA3.R.2 ~ VIA3.R.6]

//'VIAx.R.2' is checked by VIA3.R.2__VIA3.R.3
//'VIAx.R.3' is checked by VIA3.R.2__VIA3.R.3
VIA3.R.2__VIA3.R.3 { @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S1) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W1) > 0.18 um]. (Except VIA bar region) 1. at least one rectangular VIAx, or 2. at least 2 square VIAx with space <= 0.1 um (S1), or 3. at least 4 square VIAx with space <= 0.65 um (S1')   
                     @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S2) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W2) > 0.44 um]. Please refer to VIAx.R.3 table behind. (Except VIA bar region)   
   MupOvpMdn_W3  = (M3Wide_R3_VIA3 AND M4i) OR (M4Wide_R3_VIA3 AND M3i)
   MupOvpMdn_R3  = MupOvpMdn_W3 NOT OUTSIDE VIA3_EXD
   Checked_Vx_R3 = VIA3_EXD NOT OUTSIDE MupOvpMdn_W3

   MupOvpMdn_W2      = (M3Wide_R2_VIA3 AND M4i) OR (M4Wide_R2_VIA3 AND M3i)
   MupOvpMdn_R2_pre  = MupOvpMdn_W2 NOT OUTSIDE VIA3_EXD
   MupOvpMdn_R2      = MupOvpMdn_R2_pre NOT MupOvpMdn_R3
   Checked_Vx_R2 = (VIA3_EXD NOT OUTSIDE MupOvpMdn_W2) NOT Checked_Vx_R3
   
   Mdn_effect = M3i INTERACT MupOvpMdn_R2_pre
   Mup_effect = M4i INTERACT MupOvpMdn_R2_pre
   effect_MupOvpMdn_ = Mdn_effect AND Mup_effect
   
   effect_MupOvpMdn_R = SIZE MupOvpMdn_R2_pre BY (VIA3_W_1+VIA3_R_3_S2)*8+GRID
   effect_MupOvpMdn = effect_MupOvpMdn_ AND effect_MupOvpMdn_R
   effect_VIA = VIA3_EXD INTERACT effect_MupOvpMdn

   VxMerged_A = SIZE effect_VIA BY VIA3_R_2_S1/2              INSIDE OF effect_MupOvpMdn STEP M3_S_1*0.7
   VxMerged_B = SIZE VxMerged_A BY (VIA3_R_2_S2 - VIA3_R_2_S1)/2 INSIDE OF effect_MupOvpMdn STEP M3_S_1*0.7
   effect_MupOvpMdn_R3 = effect_MupOvpMdn INTERACT MupOvpMdn_R3
   VxMerged_A_R3 = VxMerged_A INTERACT effect_MupOvpMdn_R3 
   VxMerged_D = SIZE VxMerged_A_R3 BY (VIA3_R_3_S3 - VIA3_R_2_S1)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M3_S_1*0.7
   VxMerged_C = SIZE VxMerged_D    BY (VIA3_R_3_S2 - VIA3_R_3_S3)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M3_S_1*0.7
   
// Pass VIAx.R.2 (2 eff. square Via)
   G1_A2R = VxMerged_A INTERACT SQR_VIA3 >=2
   G2_A2R = VxMerged_A INTERACT REC_VIA3 >=1
   VxMerged_A2 = G1_A2R OR G2_A2R
// Pass VIAx.R.2 (4 eff. square Via)
   G1_B4R =  VxMerged_B INTERACT SQR_VIA3 >=4
   G2_B4R = (VxMerged_B INTERACT SQR_VIA3 >=2 <=3) AND (VxMerged_B INTERACT REC_VIA3 ==1)
   G3_B4R =  VxMerged_B INTERACT REC_VIA3 >=2
   VxMerged_B4 = (G1_B4R OR G2_B4R) OR G3_B4R

// Pass VIAx.R.3 (4 eff. square + slot Via)
   G1_A4_13 =  VxMerged_D INTERACT REC_VIA3 >=2
   G2_A4_13 = (VxMerged_D INTERACT REC_VIA3 ==1) AND (VxMerged_D INTERACT SQR_VIA3 >=2)
   VxMerged_A4_13 = G1_A4_13 OR G2_A4_13
// Pass VIAx.R.3 (4 eff. square Via only)
   G1_A4_10 = VxMerged_A INTERACT SQR_VIA3 >=4   
   VxMerged_A4 = VxMerged_A4_13 OR G1_A4_10

// Pass VIAx.R.3 (9 eff. square Via)
   G1_C9 =  VxMerged_C INTERACT SQR_VIA3 >=9
   G2_C9 = (VxMerged_C INTERACT SQR_VIA3 >=7 <=8) AND (VxMerged_C INTERACT REC_VIA3 >=1)
   G3_C9 = (VxMerged_C INTERACT SQR_VIA3 >=5 <=6) AND (VxMerged_C INTERACT REC_VIA3 >=2)
   G4_C9 = (VxMerged_C INTERACT SQR_VIA3 >=3 <=4) AND (VxMerged_C INTERACT REC_VIA3 >=3)
   G5_C9 = (VxMerged_C INTERACT SQR_VIA3 >=1 <=2) AND (VxMerged_C INTERACT REC_VIA3 >=4)
   G6_C9 =  VxMerged_C INTERACT REC_VIA3 >=5
   VxMerged_C9 = ((G1_C9 OR G2_C9) OR (G3_C9 OR G4_C9)) OR (G5_C9 OR G6_C9) 

   Checked_Vx_R2 OUTSIDE (MupOvpMdn_R2 INTERACT (VxMerged_A2 OR VxMerged_B4))
   Checked_Vx_R3 OUTSIDE (MupOvpMdn_R3 INTERACT (VxMerged_A4 OR VxMerged_C9))
}

VIA3.R.4:M3 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA3_R_4_L um (L) and width > ^VIA3_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M3Wide_R4_VIA3 BY VIA3_R_4_D + GRID) NOT M3Wide_R4_VIA3) AND M3
  Branch1HasVia = (Branch1 INTERACT M3Wide_R4_VIA3) INTERACT VIA3_EXD
  Branch1Edge = M3Wide_R4_VIA3 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA3_R_4_D INSIDE OF Branch1HasVia STEP M3_S_1*0.4
  GoodBranch = ((Branch AND M4) INTERACT VIA3i > 1) OR ((Branch AND M4) INTERACT (REC_VIA3 OR P_RING_VIA3))
  BranchSingleVia = (VIA3i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M4 INTERACT BranchSingleVia) AND M3) INTERACT BranchSingleVia) INTERACT VIA3i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


VIA3.R.4:M4 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA3_R_4_L um (L) and width > ^VIA3_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M4Wide_R4_VIA3 BY VIA3_R_4_D + GRID) NOT M4Wide_R4_VIA3) AND M4
  Branch1HasVia = (Branch1 INTERACT M4Wide_R4_VIA3) INTERACT VIA3_EXD
  Branch1Edge = M4Wide_R4_VIA3 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA3_R_4_D INSIDE OF Branch1HasVia STEP M4_S_1*0.4
  GoodBranch = ((Branch AND M3) INTERACT VIA3i > 1) OR ((Branch AND M3) INTERACT (REC_VIA3 OR P_RING_VIA3))
  BranchSingleVia = (VIA3i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M3 INTERACT BranchSingleVia) AND M4) INTERACT BranchSingleVia) INTERACT VIA3i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


// VIA3.R.4 is checked by VIA3.R.4:M3 and VIA3.R.4:M4
// VIA3.R.5 is checked by VIA3.R.5:M3 and VIA3.R.5:M4
// VIA3.R.6 is checked by VIA3.R.6:M3 and VIA3.R.6:M4

//'VIAy.R.13' is not necessary to check
//'VIAr.R.13' is not necessary to check


VIA3.R.5:M3 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M3Wide_R5_VIA3 BY VIA3_R_5_D + GRID) NOT M3Wide_R5_VIA3) AND M3
  Branch1HasVia = (Branch1 INTERACT M3Wide_R5_VIA3) INTERACT VIA3_EXD
  Branch1Edge = M3Wide_R5_VIA3 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA3_R_5_D INSIDE OF Branch1HasVia STEP M3_S_1*0.6
  GoodBranch = ((Branch AND M4) INTERACT VIA3i > 1) OR ((Branch AND M4) INTERACT (REC_VIA3 OR P_RING_VIA3))
  BranchSingleVia = (VIA3i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M4 INTERACT BranchSingleVia) AND M3) INTERACT BranchSingleVia) INTERACT VIA3i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
VIA3.R.5:M4 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M4Wide_R5_VIA3 BY VIA3_R_5_D + GRID) NOT M4Wide_R5_VIA3) AND M4
  Branch1HasVia = (Branch1 INTERACT M4Wide_R5_VIA3) INTERACT VIA3_EXD
  Branch1Edge = M4Wide_R5_VIA3 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA3_R_5_D INSIDE OF Branch1HasVia STEP M4_S_1*0.6
  GoodBranch = ((Branch AND M3) INTERACT VIA3i > 1) OR ((Branch AND M3) INTERACT (REC_VIA3 OR P_RING_VIA3))
  BranchSingleVia = (VIA3i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M3 INTERACT BranchSingleVia) AND M4) INTERACT BranchSingleVia) INTERACT VIA3i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


M3Big_R6_VIA3 = ENCLOSE RECTANGLE M3Wide_R6_VIA3 VIA3_R_6_W VIA3_R_6_L+GRID
M4Big_R6_VIA3 = ENCLOSE RECTANGLE M4Wide_R6_VIA3 VIA3_R_6_W VIA3_R_6_L+GRID

VIA3.R.6:M3 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M3Big_R6_VIA3 BY VIA3_R_6_D + GRID) NOT M3Big_R6_VIA3) AND M3
  Branch1HasVia = (Branch1 INTERACT M3Big_R6_VIA3) INTERACT VIA3_EXD
  Branch1Edge = M3Big_R6_VIA3 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA3_R_6_D INSIDE OF Branch1HasVia STEP M3_S_1*0.6
  GoodBranch = ((Branch AND M4) INTERACT VIA3i > 1) OR ((Branch AND M4) INTERACT (REC_VIA3 OR P_RING_VIA3))
  BranchSingleVia = (VIA3i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M4 INTERACT BranchSingleVia) AND M3) INTERACT BranchSingleVia) INTERACT VIA3i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}

VIA3.R.6:M4 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M4Big_R6_VIA3 BY VIA3_R_6_D + GRID) NOT M4Big_R6_VIA3) AND M4
  Branch1HasVia = (Branch1 INTERACT M4Big_R6_VIA3) INTERACT VIA3_EXD
  Branch1Edge = M4Big_R6_VIA3 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA3_R_6_D INSIDE OF Branch1HasVia STEP M4_S_1*0.6
  GoodBranch = ((Branch AND M3) INTERACT VIA3i > 1) OR ((Branch AND M3) INTERACT (REC_VIA3 OR P_RING_VIA3))
  BranchSingleVia = (VIA3i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M3 INTERACT BranchSingleVia) AND M4) INTERACT BranchSingleVia) INTERACT VIA3i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
// VIA3.R.7 is checked by VIA3.EN.1

VIA3.R.8 { @ Single VIAx is not allowed for H-shape Mx+1 when all of the following conditions come into existence: 1. The Mx+1 has H-shape interact with two metal holes: two metal hole length(L2) <= ^VIA3_R_8_L1 um and both two metal hole area <= ^VIA3_R_8_A um2 2. The VIAx overlaps on the center metal bar of this H-shape Mx+1 3. The length (L) of the center metal bar <= ^VIA3_R_8_L2 um and the width of metal bar is <= ^VIA3_R_8_W um.
  W = M4i WITH WIDTH <= VIA3_R_8_W   
  H_HOLE = (HOLES M4i INNER <= VIA3_R_8_A) INTERACT W
  A0 = M4i INTERACT H_HOLE
  A = A0 COIN OUTSIDE EDGE H_HOLE
  B0 = ((INT A <= VIA3_R_8_W ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) INTERACT H_HOLE == 2 
  B1 = (((INT A <= VIA3_R_8_L2 ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) AND W) INTERACT H_HOLE == 2
  HOLE_NOTCH = EXT H_HOLE <= VIA3_R_8_W ABUT<90 OPPOSITE NOTCH REGION  
  B2 = (B1 NOT HOLE_NOTCH) OR B0
  CORNER_M = ((EXT B2 <= VIA3_R_8_W ABUT == 90 INTERSECTING ONLY REGION EXTENTS) TOUCH B2 == 2) AND W
  B = B2 OR CORNER_M
  CENTER_BAR1 = NOT ENCLOSE RECTANGLE B GRID VIA3_R_8_L2+GRID
  CENTER_BAR2 = (CENTER_BAR1 INTERACT H_HOLE == 2) INTERACT VIA3i
  C = CENTER_BAR2 COIN OUTSIDE EDGE H_HOLE 
  D = EXT [C] A <= VIA3_R_8_L1 OPPOSITE
  E = C NOT COIN INSIDE EDGE D
  CENTER_BAR3 = CENTER_BAR2 NOT WITH EDGE E
  CHECK_VIA = VIA3i NOT OUTSIDE CENTER_BAR3
  CHECK_VIA AND (((A0 INTERACT CHECK_VIA) AND (M3i INTERACT CHECK_VIA)) INTERACT VIA3i == 1)
}





#IFDEF CHECK_VIRTUAL_VIAx

//VIAx_VIRT.R.1 is checked by related rules (VIA3 rules)
//'VIAx_VIRT.R.2' is checked by VIA3_VIRT.R.2
VIA3_VIRT.R.2 {@ VIAx_VIRT must be 0.05 um x 0.05 um   
   NOT RECTANGLE VIA3_VIRT == VIA3_W_1 BY == VIA3_W_1 ORTHOGONAL ONLY 
}
//'VIAx_VIRT.R.3' is checked by VIA3_VIRT.R.3
VIA3_VIRT.R.3 {@ VIAx_VIRT interact VIAx is not allowed   
   VIA3_VIRT INTERACT VIA3ii
}
//'VIAx_VIRT.R.4' is checked by VIA3_VIRT.R.4
VIA3_VIRT.R.4 {@ VIAx _VIRT must be fully covered by ROM (50;6)   
   VIA3_VIRT NOT ROM
}
#ENDIF




//M4 CHECKS
//=========
M4_EDGE_45 = M4 ANGLE == 45

M4.W.1 { @ Width >= 0.05 
  INT M4 < M4_W_1 ABUT < 90 SINGULAR REGION
}
M4.W.2 { @ Width of 45-degree bent Mx. (Please make sure the vertex of 45-degree pattern is on 0.005 um grid (refer to the guideline, G.6gU, in section XXX)) >= 0.17 
  INT M4_EDGE_45 < M4_W_2 ABUT < 90 REGION
}


// 'Mx.W.3' is checked by M4.W.3
M4.W.3 { @ Maximum width Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING, or 4. {{INDDMY OR INDDMY_MD} SIZING 16 um}, or 5. CSRDMY, or 6. PADDMY (255;16) <= 4.5 
  M4_MAX_WIDTH WITH WIDTH > M4_W_3
}



 

M4.W.4 { @ Length of the edge with adjacent edge < 0.05 um [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex-270 degree inner vertex; DRC doesn't flag if there is Mx within the area formed by 0.16 um extension from these 2 edges and the 90 degree outer vertex.] (This check doesn't include the region covered by MetalFuse (156;2)) >= 0.065 
  E1 = CONVEX EDGE M4 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH < M4_W_4_L1
  E2 = CONVEX EDGE M4 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH >= M4_W_4_L1 < M4_W_4_L2
  A = INT [E1]    < M4_W_4_L2 ABUT == 90 INTERSECTING ONLY
  B = INT [E2] E1 < M4_W_4_L2 ABUT == 90 INTERSECTING ONLY
  C = INT [E1] E2 < M4_W_4_L2 ABUT == 90 INTERSECTING ONLY
  D = OR EDGE  B (OR EDGE A C)
  CORNER_BAD_pre = (EXPAND EDGE D INSIDE BY 0.001) NOT INSIDE MFUSE
  W = EXT [D] M4 < 0.16
  CORNER_BAD_pre NOT WITH EDGE W
}
M4.S.1 { @ Space >= 0.05 
  EXT M4 < M4_S_1 ABUT < 90 SINGULAR REGION
}

M4.S.2 { @ Space [at least one metal line width > 0.09 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.06 
  X = EXT M4_20 M4 < M4_S_2 OPPOSITE REGION MEASURE ALL
  Y = X NOT M4
  ENCLOSE RECTANGLE Y GRID M4_S_2_L+GRID
}
M4.S.3 { @ Space [at least one metal line width > 0.16 um (W2) and the parallel run length > 0.22 um (L2)] >= 0.1 
  X = EXT M4_21 M4 < M4_S_3 OPPOSITE REGION MEASURE ALL
  Y = X NOT M4
  ENCLOSE RECTANGLE Y GRID M4_S_3_L+GRID
}
M4.S.4 { @ Space [at least one metal line width > 0.47 um (W3) and the parallel run length > 0.47 um (L3)] >= 0.13 
  X = EXT M4_22 M4 < M4_S_4 OPPOSITE REGION MEASURE ALL
  Y = X NOT M4
  ENCLOSE RECTANGLE Y GRID M4_S_4_L+GRID
}
M4.S.5 { @ Space [at least one metal line width > 0.63 um (W4) and the parallel run length > 0.63 um (L4)] >= 0.15 
  X = EXT M4_23 M4 < M4_S_5 OPPOSITE REGION MEASURE ALL
  Y = X NOT M4
  ENCLOSE RECTANGLE Y GRID M4_S_5_L+GRID
}
M4.S.6 { @ Space [at least one metal line width > 1.5 um (W5) and the parallel run length > 1.5 um (L5)] >= 0.5 
  X = EXT M4_30 M4 < M4_S_6 OPPOSITE REGION MEASURE ALL
  Y = X NOT M4
  ENCLOSE RECTANGLE Y 0.001 M4_S_6_L+0.001
}


M4.S.7 { @ Space to Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.07 
  A = CONVEX EDGE M4 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M4_S_7_W
  EXT A M4 < M4_S_7 ABUT < 90 OPPOSITE EXTENDED M4_S_7_T REGION
}

M4.S.8 { @ Mx line space (S1) to dense Mx line-end [parallel run length > -0.025 um (T)], and dense Mx line-end enclosure of Vx-1 (V). Definition of dense Mx line-end: 1. Mx line-end: Mx edge with length < 0.07 um (W) between 2 outer vertex. 2. Other metal INTERACT Region 1. Region 1 = (T+Q) x S2. (W+S2) < 0.115 um. This check doesn't include small jog with edge length < 0.05 um (R) >= 0.08/0.05 or 0.1/0.03 
  M4_END = CONVEX EDGE M4 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M4_S_8_W
  M4_REGION = EXPAND EDGE M4_END OUTSIDE BY M4_S_8_SB + GRID EXTEND BY M4_S_8_T + GRID  // for data reduction
  M4_LINE = (M4 INSIDE EDGE M4_REGION) NOT TOUCH EDGE M4_END
  M4_EA = ENC VIA3i [M4_END] < M4_S_8_EA ABUT < 90 OPPOSITE
  M4_EB = ENC VIA3i [M4_END] < M4_S_8_EB ABUT < 90 OPPOSITE
  M4_SA = EXT [M4_END] M4_LINE < M4_S_8_SA ABUT < 90 OPPOSITE EXTENDED M4_S_8_T
  M4_SB = EXT [M4_END] M4_LINE < M4_S_8_SB ABUT < 90 OPPOSITE EXTENDED M4_S_8_T
  M4_PASS_A = (M4_END NOT TOUCH INSIDE EDGE M4_EA) NOT TOUCH INSIDE EDGE M4_SA
  M4_PASS_B = (M4_END NOT TOUCH INSIDE EDGE M4_EB) NOT TOUCH INSIDE EDGE M4_SB
  M4_CHECK = (M4_END NOT TOUCH INSIDE EDGE M4_PASS_A) NOT TOUCH INSIDE EDGE M4_PASS_B

  M4_Long_side = LENGTH M4 >= M4_W_1
  O = INT M4_CHECK [M4_Long_side] < M4_S_8_Q-M4_S_8_T ABUT == 90 INTERSECTING ONLY  
  PW = INT O M4 < (M4_S_8_P - M4_S_1) ABUT < 90 OPPOSITE EXTENDED M4_S_8_T
  PS = EXT O M4 < (M4_S_8_P - M4_W_1) ABUT < 90 OPPOSITE EXTENDED M4_S_8_T
  Q = DFM PROPERTY O PS PW OVERLAP ABUT ALSO MULTI
  [-= MIN(EW(PW)) + MIN(EW(PS))] < M4_S_8_P
  R = M4_CHECK TOUCH EDGE (EXPAND EDGE Q INSIDE BY 0.001)
  ENC VIA3i R < M4_S_8_EA ABUT < 90 OPPOSITE REGION
  EXT R M4 < M4_S_8_SB ABUT < 90 OPPOSITE EXTENDED M4_S_8_T REGION
}


M4.S.9 { @ Space to 45-degree bent Mx >= 0.17 
  X = EXPAND EDGE M4_EDGE_45 OUTSIDE BY M4_S_9
  X AND M4
}


M4_HVN_65V = NET AREA RATIO M4i OVER M9_HV_65V M8_HV_65V M7_HV_65V M6_HV_65V M5_HV_65V M4_HV_65V M3_HV_65V M2_HV_65V M1_HV_65V PO_HV_65V NW_HV_65V DNW_HV_65V > 0
M4_HVN_5V = NET AREA RATIO M4i OVER M9_HV_5V M8_HV_5V M7_HV_5V M6_HV_5V M5_HV_5V M4_HV_5V M3_HV_5V M2_HV_5V M1_HV_5V > 0
M4_HVN = NET AREA RATIO M4i OVER M9_HV M8_HV M7_HV M6_HV M5_HV M4_HV M3_HV M2_HV M1_HV > 0
M4_MVN = NET AREA RATIO M4i OVER M9_MV M8_MV M7_MV M6_MV M5_MV M4_MV M3_MV M2_MV M1_MV > 0
M4_MLVN = NET AREA RATIO M4i OVER M9_MLV M8_MLV M7_MLV M6_MLV M5_MLV M4_MLV M3_MLV M2_MLV M1_MLV > 0
M4_LVN = NET AREA RATIO M4i OVER M9_LV M8_LV M7_LV M6_LV M5_LV M4_LV M3_LV M2_LV M1_LV > 0
M4_VNVN_pre = NET AREA RATIO M4i OVER M9_VNV M8_VNV M7_VNV M6_VNV M5_VNV M4_VNV M3_VNV M2_VNV M1_VNV > 0
M4_NVN = NET AREA RATIO M4i OVER M9_NV M8_NV M7_NV M6_NV M5_NV M4_NV M3_NV M2_NV M1_NV > 0
M4_VNVN = M4_VNVN_pre NOT M4_NVN
M4_NOMARK = (((((((M4i NOT M4_HVN_65V) NOT M4_HVN_5V) NOT M4_HVN) NOT M4_MVN) NOT M4_MLVN) NOT M4_LVN) NOT M4_NVN) NOT M4_VNVN



#IFDEF USE_IO_VOLTAGE_ON_CORE_TO_IO_NET
  M4_NOMARK_65V = NET AREA RATIO M4_NOMARK PSD_65 NSD_65 PSTPix > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSTPix)]
  M4_NOMARK_5V = NET AREA RATIO M4_NOMARK PSD_50 NSD_50 PSTPix > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)]
  M4_NOMARK_HV = NET AREA RATIO M4_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)]
  M4_NOMARK_MV = NET AREA RATIO M4_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)]
  M4_NOMARK_MLV = NET AREA RATIO M4_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)]
  M4_NOMARK_LV = NET AREA RATIO M4_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]  



#ELSE
  M4_NOMARK_65V = NET AREA RATIO M4_NOMARK PSD_65 NSD_65 PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSD_50)*!AREA(NSD_50)*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M4_NOMARK_5V = NET AREA RATIO M4_NOMARK PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M4_NOMARK_HV = NET AREA RATIO M4_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M4_NOMARK_MV = NET AREA RATIO M4_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M4_NOMARK_MLV = NET AREA RATIO M4_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M4_NOMARK_LV = NET AREA RATIO M4_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]


#ENDIF

M4_HV_65V_ALL = M4_HVN_65V OR M4_NOMARK_65V
M4_HV_5V_ALL = M4_HVN_5V OR M4_NOMARK_5V
M4_HV_ALL = M4_HVN OR M4_NOMARK_HV
M4_MV_ALL = M4_MVN OR M4_NOMARK_MV
M4_MLV_ALL = M4_MLVN OR M4_NOMARK_MLV
M4_LV_ALL = M4_LVN OR M4_NOMARK_LV
M4_NV_ALL = COPY M4_NVN
M4_VNV_ALL = COPY M4_VNVN

M4_VNV_CHK = STAMP M4_VNV_ALL BY M4i
VIA4_VNV_CHK = STAMP (VIA4ii AND M4_VNV_ALL) BY M4i
M4_NV_CHK = STAMP M4_NV_ALL BY M4i
VIA4_NV_CHK = STAMP (VIA4ii AND M4_NV_ALL) BY M4i  
M4_LV_CHK = STAMP M4_LV_ALL BY M4i
VIA4_LV_CHK = STAMP (VIA4ii AND M4_LV_ALL) BY M4i
M4_MLV_CHK = STAMP M4_MLV_ALL BY M4i
VIA4_MLV_CHK = STAMP (VIA4ii AND M4_MLV_ALL) BY M4i
M4_MV_CHK = STAMP M4_MV_ALL BY M4i
VIA4_MV_CHK = STAMP (VIA4ii AND M4_MV_ALL) BY M4i

M4_HV_CHK = STAMP M4_HV_ALL BY M4i
VIA4_HV_CHK = STAMP (VIA4ii AND M4_HV_ALL) BY M4i
M4_HV_5V_CHK = STAMP M4_HV_5V_ALL BY M4i
VIA4_HV_5V_CHK = STAMP (VIA4ii AND M4_HV_5V_ALL) BY M4i
M4_HV_65V_CHK = STAMP M4_HV_65V_ALL BY M4i
VIA4_HV_65V_CHK = STAMP (VIA4ii AND M4_HV_65V_ALL) BY M4i























M4.S.12 { @ Space of Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.08 
  A = CONVEX EDGE M4 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M4_S_12_W
  EXT A < M4_S_12 ABUT < 90 OPPOSITE EXTENDED M4_S_12_T REGION
}

M4.S.13 { @ Space [at least one metal line width > 0.13 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.08 
  X = EXT M4_201 M4 < M4_S_13 OPPOSITE REGION MEASURE ALL
  Y = X NOT M4
  ENCLOSE RECTANGLE Y GRID M4_S_13_L+GRID
}


// M4.EN.0,enclosure of square VIAx-1 is defined by either {Mx.EN.1/Mx.EN.2} or Mx.EN.3
// M4.EN.0 is checked by either {M4.EN.1/M4.EN.2} or M4.EN.3

M4.EN.1 { @ Enclosure of square VIAx-1 >= 0 
  VIA3i NOT M4i
}
M4.EN.2__M4.EN.3__M4.EN.14__M4.EN.15 { @ Enclosure of VIA3 [at least two opposite sides] >= ^M4_EN_2 um OR [all sides] >= ^M4_EN_3 OR [all side] >= ^M4_EN_14 / [at least two opposite sides] >= ^M4_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA3 M4i ABUT < 90 SINGULAR GOOD 0 M4_EN_2 OPPOSITE 0 M4_EN_2 OPPOSITE GOOD M4_EN_14 M4_EN_15 OPPOSITE M4_EN_14 M4_EN_15 OPPOSITE
  ENC X M4i < M4_EN_3 ABUT < 90 SINGULAR REGION
}

// M4.EN.4, Enclosure of rectangular VIAx-1 is defined by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3
// M4.EN.4 is checked by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3

M4.EN.3__M4.EN.5__M4.EN.6__M4.EN.7 { @ Enclosure of rectangular VIA3 [two opposite side >= ^M4_EN_7 and all side >= ^M4_EN_5], OR Enclosure of rectangular VIA3 [at rectangular VIA3 end direction] >= ^M4_EN_6, OR Enclosure of rectangular VIA3 [all sides] >= ^M4_EN_3
  A = RECTANGLE ENCLOSURE REC_VIA3 M4i ABUT < 90 SINGULAR GOOD M4_EN_5 M4_EN_7 OPPOSITE M4_EN_5 M4_EN_7 OPPOSITE GOOD M4_EN_3 M4_EN_3 M4_EN_3 M4_EN_3
  B = LENGTH A == VIA3_W_1
  C = ENC [B] M4i < M4_EN_6 ABUT < 90 OPPOSITE
  A WITH EDGE C
}

// M4.EN.3, M4.EN.5, M4.EN.6 and M4.EN.7 are checked by M4.EN.3__M4.EN.5__M4.EN.6__M4.EN.7
// M4.EN.8 is checked by M4.EN.1

M4_W_55b = M4 WITH WIDTH == M4_EN_9_W 
M4_W_70b = M4 WITH WIDTH > M4_EN_9_W <= M4_EN_10_W 
M4_W_160b = M4 WITH WIDTH > M4_EN_10_W <=M4_EN_11W
M4_W_450b = M4 WITH WIDTH > M4_EN_11W <=M4_EN_12W

M4.EN.9 { @ Enclosure of VIAx-1 [0.055 um >= metal width > 0.05 um, metal space < 0.06 um (D1) and the other side space >= 0.06 um (D1'), parallel run length > 0.1 um] >= 0.005 
  A0 = M4_W_55b INTERACT VIA3i 
  A = EXT A0 [M4] < M4_EN_9_S1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A M4 < M4_EN_9_S1 ABUT < 90 OPPOSITE REGION
  C = EXT A M4 < M4_EN_9_S1 ABUT < 90 OPPOSITE
  D = EXT A [M4] < M4_EN_9_S1 ABUT < 90 OPPOSITE
  E0 = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
  [-= EC(C) ] > M4_EN_9_L
  E1 = E0 NOT WITH EDGE (ANGLE M4 >0 < 90) 
  E = E0 NOT (E1 NOT ENCLOSE RECTANGLE M4_EN_9_L+GRID GRID ORTHOGONAL ONLY)  
  F = D COIN OUTSIDE EDGE E
  G = (EXPAND EDGE F INSIDE BY M4_EN_9_W) INTERACT E != 2  
  H = F COIN INSIDE EDGE G 
  ENC VIA3i H < M4_EN_9 ABUT < 90 OPPOSITE REGION
}
M4.EN.10 { @ Enclosure of VIAx-1 [0.07 um >= metal width > 0.055 um, metal space < 0.065 um (D1) and parallel run length > 0.1 um] >= 0.005 
  W = EXT M4_W_70b [M4] < M4_EN_10_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M4i] < M4_EN_10_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M4i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M4i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M4_EN_10_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M4_EN_10_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA3i S7_H < M4_EN_10 ABUT < 90 OPPOSITE REGION
  ENC VIA3i S7_V < M4_EN_10 ABUT < 90 OPPOSITE REGION

}
M4.EN.11 { @ Enclosure of VIAx-1 [0.16 um >= metal width > 0.07 um, metal space < 0.1 um (D1) and parallel run length > 0.1 um] (For Mx.EN.11, the rule check is not included same VIAx group, which is defined as below.) 1. VIAx space <= 0.11 um2. Mx is same net 3. Mx+1 is same net >= 0.01 
  VIA3_M = SIZE VIA3i BY M4_EN_11_S/2 INSIDE OF SAME_NET_VIA3 STEP M3_S_1*0.6
  VIA3_C = VIA3i NOT INTERACT (VIA3_M INTERACT VIA3i >= 2)
  W = EXT M4_W_160b [M4] < M4_EN_11_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M4i] < M4_EN_11_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M4i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M4i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M4_EN_11_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M4_EN_11_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA3_C S7_H < M4_EN_11 ABUT < 90 OPPOSITE REGION
  ENC VIA3_C S7_V < M4_EN_11 ABUT < 90 OPPOSITE REGION

}
// 'Mx.EN.12' is checked by M4.EN.12
M4.EN.12 { @ Enclosure of VIAx-1 [4.5 um >= metal width > 0.16 um, metal space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M4_W_450b [M4] < M4_EN_12_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M4i] < M4_EN_12_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M4i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M4i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M4_EN_12_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M4_EN_12_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA3i S7_H < M4_EN_12 ABUT < 90 OPPOSITE REGION
  ENC VIA3i S7_V < M4_EN_12 ABUT < 90 OPPOSITE REGION

}
// 'Mx.EN.13' is checked by M4.EN.13
M4.EN.13 { @ Enclosure of VIAx-1 bar in LOWMEDN >= 0.1 
  ENC P_RING_VIA3 M4 < M4_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}
// 'Mx.L.1' is checked by M4.L.1
M4.L.1 { @ Length of 45-degree bent Mx (minimum edge length) >= 0.5 
  (LENGTH M4_EDGE_45 < M4_L_1) NOT INSIDE EDGE SEALRING_ALL
}

M4.A.1 { @ Area (except M2) >= 0.017 
  AREA M4 < M4_A_1
}
//'Mx.A.1' is checked by M4.A.1
M4.A.3 { @ Area [with all of edge lengths < 0.13 um] (Except M2 inside SRAMDMY;0) (This check doesn't include the patterns filling 0.05 um x 0.13 um rectangular tile) >= 0.044 
  A = AREA M4 < M4_A_3
  B = LENGTH A >= M4_A_3_L1
  C = A NOT WITH EDGE B
  NOT ENCLOSE RECTANGLE C M4_A_3_W M4_A_3_L2 ORTHOGONAL ONLY
}

VARIABLE M4_A_4pre ((M4_A_4 + (M4_S_1 * M4_S_1 * 3.142))/(2 * M4_S_1))*((M4_A_4 + (M4_S_1 * M4_S_1 * 3.142))/(2 * M4_S_1))/3.141 // user value

M4.A.4 { @ Enclosed area >= 0.2 
  X = HOLES M4 INNER < M4_A_4pre
  AREA ( X NOT M4 ) < M4_A_4
}

//'DMx_O.R.1' is checked by DM4_O.R.1
DM4_O.R.1 { @ DMx_O INTERACT Mx is not allowed. [Mx, and My only]   
  DM4_O INTERACT M4i
}






// 'Mx.DN.0.1' is checked by related rules




//'My.DN.0' is not necessary to check
//'My.DN.1' is not necessary to check
//'My.DN.2' is not necessary to check
//'My.DN.3' is not necessary to check

//'Mr.DN.0' is not necessary to check
//'Mr.DN.1' is not necessary to check
//'Mr.DN.2' is not necessary to check
//'Mr.DN.3' is not necessary to check



//'Mx.DN.1' is checked by M4.DN.1
#IFDEF CHECK_LOW_DENSITY
M4.DN.1 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum metal density in window 125 um x 125 um, stepping 62.5*20% um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10%+3% 
#ELSE
@ Minimum metal density in window 125 um x 125 um, stepping 62.5 um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10% 
#ENDIF
  EXC_LOW = M4_EXC_LOW OR ICOVL
  N = M4x NOT EXC_LOW
  D = CHIP NOT EXC_LOW 
  A = CHIP_M4 NOT EXC_LOW
  X = DENSITY A M4x CHIP N D < M4_DN_1 WINDOW M4_DN_1_W STEP M4_DN_1_S BACKUP INSIDE OF LAYER CHIP_M4 PRINT M4.DN.1.density RDB M4.DN.1.RDB.density
          [~(AREA(A)-M4_DN_1_E)*!!(AREA(A)-M4_DN_1_E)+AREA(N)/AREA(D)+!~(AREA(M4x)/AREA(CHIP)-M4_DN_1)+!(AREA(M4x)/AREA(CHIP)-M4_DN_1)]


  COPY X    
}
#ENDIF



//'Mx.DN.2' is checked by M4.DN.2
M4.DN.2 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum metal density in window 125 um x 125 um, stepping 62.5*20% um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85%-3% 
#ELSE
@ Maximum metal density in window 125 um x 125 um, stepping 62.5 um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85% 
#ENDIF
  EXC_HIGH = M4_EXC_HIGH OR ICOVL
  N = M4x NOT EXC_HIGH
  D = CHIP NOT EXC_HIGH 
  A = CHIPx NOT EXC_HIGH
  X = DENSITY A M4x CHIP N D > M4_DN_2 WINDOW M4_DN_2_W STEP M4_DN_2_S BACKUP INSIDE OF LAYER CHIPx PRINT M4.DN.2.density RDB M4.DN.2.RDB.density
          [~(M4_DN_2_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M4x)/AREA(CHIP)-M4_DN_2)]


  COPY X    
}

//'Mx.DN.3' is checked by M4.DN.3
M4.DN.3 { @ The metal density difference between any 2 neighboring checking windows including DMxEXCL [window 200 um x 200 um, stepping 200 um]. Anticipate metal density gradient from layout of small cell by targeting density ~50% (this way, it will limit the risk of low density and of high gradient).(Except ICOVL) <= 50% 
   EXCEPT =  COPY ICOVL
   M4x_Chk = M4x NOT EXCEPT
   DENSITY M4x_Chk EXCEPT CHIP <=1 WINDOW M4_DN_3_W BACKUP GRADIENT > M4_DN_3 ABSOLUTE CORNER INSIDE OF LAYER CHIPx PRINT M4.DN.3.density RDB M4.DN.3.RDB.density
    [ (AREA(M4x_Chk)+AREA(EXCEPT)*M4_DN_3_V)/AREA(CHIP) ] 
}

M4_CORE = M4x NOT SRCSR_P4
//'Mx.DN.4' is checked by Mx.DN.4:M2_M3_M4 
Mx.DN.4:M2_M3_M4 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ It is not allowed to have local density > 85% of all 3 consecutive metal (Mx, Mx+1 and Mx+2) over any window 62.5 um x 62.5 um (stepping 31.25*20% um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density > 85%+3%. 1. The metal layers include M1/Mx and dummy metals. 2. Except following condition: (1). Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or (2). Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or (3). SEALRING_ALL, or (4) Chip corner triangle empty areas
#ELSE
@ It is not allowed to have local density > 85% of all 3 consecutive metal (Mx, Mx+1 and Mx+2) over any window 62.5 um x 62.5 um (stepping 31.25 um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density > 85%. 1. The metal layers include M1/Mx and dummy metals. 2. Except following condition: (1). Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or (2). Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or (3). SEALRING_ALL, or (4) Chip corner triangle empty areas   
#ENDIF
 DENSITY  M2_CORE M3_CORE M4_CORE >0 WINDOW M2_DN_4_W STEP M2_DN_4_S BACKUP INSIDE OF LAYER CHIPx 
      [ !~(AREA(M2_CORE)/AREA()- M2_DN_4)*!~(AREA(M3_CORE)/AREA()- M2_DN_4)*!~(AREA(M4_CORE)/AREA()- M2_DN_4) ]
      RDB Mx.DN.4:M2_M3_M4.density
}


#IFDEF CHECK_LOW_DENSITY
M4.DN.6 { @ Metal Density >= ^M4_DN_6 must be followed for item(A) to (C)
@ (A) Metal density [checking window ^M4_DN_6_W_A um x ^M4_DN_6_W_A um, stepping ^M4_DN_6_S_A um] >= ^M4_DN_6
@ (B) Maximum area of merged low density windows [checking window ^M4_DN_6_W_BC um x ^M4_DN_6_W_BC um, stepping ^M4_DN_6_S_BC um, density < ^M4_DN_6] <= ^M4_DN_6_A_B um2. Merged low density windows width <= ^M4_DN_6_U um is except.
@ (C) Maximum area of merged low density windows [checking window ^M4_DN_6_W_BC um x ^M4_DN_6_W_BC um, stepping ^M4_DN_6_S_BC um, density < ^M4_DN_6] <= ^M4_DN_6_A_C um2
@ 1. The following special regions are excluded
@    Chip corner triangle empty areas if sealring is added by tsmc. 
@    LOWMEDN
@ 2. This rule is applied while the width of (checking window NOT above excluding region) >= ^M4_DN_6_E_A um for (A) and >= ^M4_DN_6_E_BC um for both (B)/(C) 
  M4_CHECK = M4x NOT (NEW_DEN_EXC OR ICOVL)
  CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
  // Condition-A
  ERR_WIN_A = DENSITY M4_CHECK CHIP_CHECK < M4_DN_6 WINDOW M4_DN_6_W_A STEP M4_DN_6_S_A INSIDE OF LAYER CHIP_M4 BACKUP 
	[ AREA(M4_CHECK)/AREA(CHIP_CHECK) ]
  F_A = WITH WIDTH (ERR_WIN_A NOT (NEW_DEN_EXC OR ICOVL)) >= M4_DN_6_E_A
  DENSITY F_A M4_CHECK CHIP_CHECK < M4_DN_6 WINDOW M4_DN_6_W_A STEP M4_DN_6_S_A INSIDE OF LAYER CHIP_M4 BACKUP PRINT M4.DN.6_A.density
         [ !AREA(F_A)+AREA(M4_CHECK)/AREA(CHIP_CHECK) ]
  // Condition-B 
  ERR_WIN_B = DENSITY M4_CHECK CHIP_CHECK < M4_DN_6 WINDOW M4_DN_6_W_BC STEP M4_DN_6_S_BC INSIDE OF LAYER CHIP_M4 BACKUP 
	[ AREA(M4_CHECK)/AREA(CHIP_CHECK) ]
  F_B = WITH WIDTH (ERR_WIN_B NOT (NEW_DEN_EXC OR ICOVL)) >= M4_DN_6_E_BC
  A = DENSITY F_B M4_CHECK CHIP_CHECK < M4_DN_6 WINDOW M4_DN_6_W_BC STEP M4_DN_6_S_BC INSIDE OF LAYER CHIP_M4 BACKUP PRINT M4.DN.6_BC.density
         [ !AREA(F_B)+AREA(M4_CHECK)/AREA(CHIP_CHECK) ]
  B = AREA A > M4_DN_6_A_B
  C = SIZE B BY M4_DN_6_U/2 UNDEROVER
  B INTERACT C
  // Condition-C
  AREA B > M4_DN_6_A_C
}
#ENDIF

#IFDEF CHECK_LOW_DENSITY
//'Mx.DN.7' is checked by Mx.DN.7:M2_M3_M4
Mx.DN.7:M2_M3_M4 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ It is not allowed to have local density < 5% of all 3 consecutive metal (Mx, Mx+1, and Mx+2) over any 30 um x 30 um (stepping 15*20% um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density >= 5+3%. 1. The metal layers include M1/Mx and dummy metals for ELK film. 2. The following special regions are excluded while the density checking: - Chip corner triangle empty areas if seal-ring is added by tsmc. - LOWMEDN, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area)    
#ELSE
@ It is not allowed to have local density < 5% of all 3 consecutive metal (Mx, Mx+1, and Mx+2) over any 30 um x 30 um (stepping 15 um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density >= 5%. 1. The metal layers include M1/Mx and dummy metals for ELK film. 2. The following special regions are excluded while the density checking: - Chip corner triangle empty areas if seal-ring is added by tsmc. - LOWMEDN, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area)   
#ENDIF
   M2_CHECK = M2x NOT (NEW_DEN_EXC OR ICOVL)
   M3_CHECK = M3x NOT (NEW_DEN_EXC OR ICOVL)
   M4_CHECK = M4x NOT (NEW_DEN_EXC OR ICOVL)
   CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
   DENSITY M2_CHECK M3_CHECK M4_CHECK CHIP_CHECK >0 WINDOW M2_DN_7_W STEP M2_DN_7_S BACKUP INSIDE OF LAYER CHIP_M4
   [ ~(M2_DN_7_E-AREA(CHIP_CHECK))*!~(M2_DN_7-(AREA(M2_CHECK)/AREA(CHIP_CHECK)))*!~(M2_DN_7-(AREA(M3_CHECK)/AREA(CHIP_CHECK)))*!~(M2_DN_7-(AREA(M4_CHECK)/AREA(CHIP_CHECK))) ]
   RDB Mx.DN.7:M2_M3_M4.density
}
#ENDIF





//VIA4 CHECKS
//===========
VIA4.W.1 { @  Width x Length = 0.05 x 0.05, 0.05 x 0.13 (Except seal-ring (162,2) and {LOWMEDN NOT {LOWMEDN SIZING -4 m}})
  A = NOT RECTANGLE VIA4i == VIA4_W_1 BY == VIA4_L_1 ORTHOGONAL ONLY
  B = NOT RECTANGLE A == VIA4_W_1 BY == VIA4_L_2 ORTHOGONAL ONLY    
  B NOT (VIA_EXD OR P_RING_REGION)
}

// 'VIAx.W.6' is checked by VIA4.W.6
VIA4.W.6 { @ Width of VIAx bar in protection ring [INSIDE LOWMEDN] = 0.15 
  INT P_RING_VIA4 > VIA4_W_6+2*GRID < VIA4_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  WITH WIDTH P_RING_VIA4 >= VIA4_W_6*2
  INT P_RING_VIA4 < VIA4_W_6-2*GRID ABUT < 90 REGION
}
SAME_NET_VIA4 = M4i AND M5i

VIA4.S.1 { @ Square VIAx space >= 0.07 
  EXT VIA4i < VIA4_S_1 ABUT < 90 SINGULAR REGION
}

VIA4.S.3 { @ Square VIAx space to rectangular VIAx >= 0.075 
  EXT SQR_VIA4 REC_VIA4 < VIA4_S_3 ABUT < 90 SINGULAR REGION
}
VIA4.S.4 { @ Rectangular VIAx space to rectangular VIAx >= 0.08 
  EXT REC_VIA4 < VIA4_S_4 ABUT < 90 SINGULAR REGION
}
VIA4.S.5 { @ VIAx space [parallel run length > -0.04 um] >= 0.08 
   EXT VIA4i < VIA4_S_5 ABUT < 90 OPPOSITE EXTENDED VIA4_S_5_L REGION
}





VIA4.S.18 { @ Space of VIAx bar in LOWMEDN to VIAx hole >= 0.35 
  EXT P_RING_VIA4 VIA4_EXD < VIA4_S_18 ABUT < 90 SINGULAR REGION
}

VIA4.S.19 { @ Space of VIAx bar in LOWMEDN >= 0.6 
  EXT P_RING_VIA4 < VIA4_S_19 ABUT < 90 SINGULAR REGION
}









// VIA4.EN.0 is checked by either {VIA4.EN.1/VIA4.EN.2} or VIA4.EN.3

VIA4.EN.1 { @ Enclosure by M1 or Mx >= 0 
  VIA4i NOT M4i
}
VIA4.EN.2__VIA4.EN.3__VIA4.EN.14__VIA4.EN.15 { @ Enclosure by M4 [at least two opposite sides] >= ^VIA4_EN_2 um OR [all sides] >= ^VIA4_EN_3 OR [all side] >= ^VIA4_EN_14 / [at least two opposite sides] >= ^VIA4_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA4 M4i ABUT < 90 SINGULAR GOOD 0 VIA4_EN_2 OPPOSITE 0 VIA4_EN_2 OPPOSITE GOOD VIA4_EN_14 VIA4_EN_15 OPPOSITE VIA4_EN_14 VIA4_EN_15 OPPOSITE
  ENC X M4i < VIA4_EN_3 ABUT < 90 SINGULAR REGION
}


// VIA4.EN.4,	Rectangular VIAx enclosure by M1 or Mx is defined by either {VIAx.EN.5/VIAx.EN.7} or {VIAx.EN.6/VIAx.EN.8} or VIAx.EN.3
// VIA4.EN.4 is checked by either {VIA4.EN.5/VIA4.EN.7} or VIA4.EN.3

VIA4.EN.3__VIA4.EN.5__VIA4.EN.6__VIA4.EN.7 { @ Enclosure by M4 [two opposite direction >= ^VIA4_EN_7 and all side >= ^VIA4_EN_5], OR Enclosure by M4 [at rectangular VIA4 end direction] >= ^VIA4_EN_6, OR Enclosure by M4 [all sides] >= ^VIA4_EN_3    
  A = RECTANGLE ENCLOSURE REC_VIA4 M4i ABUT < 90 SINGULAR GOOD VIA4_EN_5 VIA4_EN_7 OPPOSITE VIA4_EN_5 VIA4_EN_7 OPPOSITE GOOD VIA4_EN_3 VIA4_EN_3 VIA4_EN_3 VIA4_EN_3
  B = LENGTH A == VIA4_W_1
  C = ENC [B] M4i < VIA4_EN_6 ABUT < 90 OPPOSITE
  A WITH EDGE C

}
// VIA4.EN.3, VIA4.EN.5, VIA4.EN.6 and VIA4.EN.7 are checked by VIA4.EN.3__VIA4.EN.5__VIA4.EN.6__VIA4.EN.7
// VIA4.EN.8 is checked by VIA4.EN.1

M4_W_55 = M4 WITH WIDTH == VIA4_EN_9_W 
M4_W_70 = M4 WITH WIDTH > VIA4_EN_9_W <= VIA4_EN_10_W 
M4_W_160 = M4 WITH WIDTH > VIA4_EN_10_W <=VIA4_EN_11W
M4_W_450 = M4 WITH WIDTH > VIA4_EN_11W <=VIA4_EN_12W

//'VIAx.EN.9' is checked by VIA4.EN.9
VIA4.EN.9 { @ Enclosure by Mx [0.055 um >= metal width > 0.05 um, space < 0.06 um (D1) and the other side space >= 0.06 um (D1'), parallel run length > 0.1 um] >= 0.005 
  A0 = M4_W_55 INTERACT VIA4i 
  A = EXT A0 [M4] < VIA4_EN_9_S1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A M4 < VIA4_EN_9_S1 ABUT < 90 OPPOSITE REGION
  C = EXT A M4 < VIA4_EN_9_S1 ABUT < 90 OPPOSITE
  D = EXT A [M4] < VIA4_EN_9_S1 ABUT < 90 OPPOSITE
  E0 = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
  [-= EC(C) ] > VIA4_EN_9_L
  E1 = E0 NOT WITH EDGE (ANGLE M4 >0 < 90) 
  E = E0 NOT (E1 NOT ENCLOSE RECTANGLE VIA4_EN_9_L+GRID GRID ORTHOGONAL ONLY)  
  F = D COIN OUTSIDE EDGE E
  G = (EXPAND EDGE F INSIDE BY VIA4_EN_9_W) INTERACT E != 2  
  H = F COIN INSIDE EDGE G 
  ENC VIA4i H < VIA4_EN_9 ABUT < 90 OPPOSITE REGION
}
//'VIAx.EN.10' is checked by VIA4.EN.10
VIA4.EN.10 { @ Enclosure by Mx [0.07 um >= metal width > 0.055 um, space < 0.065 um (D1) and parallel run length > 0.1 um] >= 0.005 
  W = EXT M4_W_70 [M4] < VIA4_EN_10_S ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M4i] < VIA4_EN_10_S ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M4i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M4i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA4_EN_10_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA4_EN_10_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA4i S7_H < VIA4_EN_10 ABUT < 90 OPPOSITE REGION
  ENC VIA4i S7_V < VIA4_EN_10 ABUT < 90 OPPOSITE REGION

}
//'VIAx.EN.11' is checked by VIA4.EN.11
VIA4.EN.11 { @ Enclosure by Mx [0.16 um >= metal width > 0.07 um, space < 0.1 um (D1) and parallel run length > 0.1 um] (For VIAx.EN.11, the rule check is not included same VIAx group, which is defined as below). 1. VIAx space <= 0.11 um2. Mx is same net 3. Mx+1 is same net >= 0.01 
  VIA4_M = SIZE VIA4i BY VIA4_EN_11_S/2 INSIDE OF SAME_NET_VIA4 STEP M4_S_1*0.6
  VIA4_C = VIA4i NOT INTERACT (VIA4_M INTERACT VIA4i >= 2)
  W = EXT M4_W_160 [M4] < VIA4_EN_11D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M4i] < VIA4_EN_11D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M4i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M4i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA4_EN_11L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA4_EN_11L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA4_C S7_H < VIA4_EN_11 ABUT < 90 OPPOSITE REGION
  ENC VIA4_C S7_V < VIA4_EN_11 ABUT < 90 OPPOSITE REGION

}
VIA4.EN.12 { @ Enclosure by M1 or Mx [4.5 um >= metal width > 0.16 um, space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M4_W_450 [M4] < VIA4_EN_12D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M4i] < VIA4_EN_12D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M4i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M4i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M4i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA4_EN_12L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA4_EN_12L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA4i S7_H < VIA4_EN_12 ABUT < 90 OPPOSITE REGION
  ENC VIA4i S7_V < VIA4_EN_12 ABUT < 90 OPPOSITE REGION

}
// 'VIAx.EN.13' is checked by VIA4.EN.13
VIA4.EN.13 { @ VIAx bar enclosure by M1/Mx in LOWMEDN >= 0.1 
  ENC P_RING_VIA4 M4 < VIA4_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}

// VIA4.L.1 is checked by VIA4.W.1
// VIA4.L.2 is checked by VIA4.W.1

// VIA4.R.0 is checked by VIA4.W.1
// VIA4.R.1 is checked by [VIA4.R.2 ~ VIA4.R.6]

//'VIAx.R.2' is checked by VIA4.R.2__VIA4.R.3
//'VIAx.R.3' is checked by VIA4.R.2__VIA4.R.3
VIA4.R.2__VIA4.R.3 { @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S1) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W1) > 0.18 um]. (Except VIA bar region) 1. at least one rectangular VIAx, or 2. at least 2 square VIAx with space <= 0.1 um (S1), or 3. at least 4 square VIAx with space <= 0.65 um (S1')   
                     @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S2) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W2) > 0.44 um]. Please refer to VIAx.R.3 table behind. (Except VIA bar region)   
   MupOvpMdn_W3  = (M4Wide_R3_VIA4 AND M5i) OR (M5Wide_R3_VIA4 AND M4i)
   MupOvpMdn_R3  = MupOvpMdn_W3 NOT OUTSIDE VIA4_EXD
   Checked_Vx_R3 = VIA4_EXD NOT OUTSIDE MupOvpMdn_W3

   MupOvpMdn_W2      = (M4Wide_R2_VIA4 AND M5i) OR (M5Wide_R2_VIA4 AND M4i)
   MupOvpMdn_R2_pre  = MupOvpMdn_W2 NOT OUTSIDE VIA4_EXD
   MupOvpMdn_R2      = MupOvpMdn_R2_pre NOT MupOvpMdn_R3
   Checked_Vx_R2 = (VIA4_EXD NOT OUTSIDE MupOvpMdn_W2) NOT Checked_Vx_R3
   
   Mdn_effect = M4i INTERACT MupOvpMdn_R2_pre
   Mup_effect = M5i INTERACT MupOvpMdn_R2_pre
   effect_MupOvpMdn_ = Mdn_effect AND Mup_effect
   
   effect_MupOvpMdn_R = SIZE MupOvpMdn_R2_pre BY (VIA4_W_1+VIA4_R_3_S2)*8+GRID
   effect_MupOvpMdn = effect_MupOvpMdn_ AND effect_MupOvpMdn_R
   effect_VIA = VIA4_EXD INTERACT effect_MupOvpMdn

   VxMerged_A = SIZE effect_VIA BY VIA4_R_2_S1/2              INSIDE OF effect_MupOvpMdn STEP M4_S_1*0.7
   VxMerged_B = SIZE VxMerged_A BY (VIA4_R_2_S2 - VIA4_R_2_S1)/2 INSIDE OF effect_MupOvpMdn STEP M4_S_1*0.7
   effect_MupOvpMdn_R3 = effect_MupOvpMdn INTERACT MupOvpMdn_R3
   VxMerged_A_R3 = VxMerged_A INTERACT effect_MupOvpMdn_R3 
   VxMerged_D = SIZE VxMerged_A_R3 BY (VIA4_R_3_S3 - VIA4_R_2_S1)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M4_S_1*0.7
   VxMerged_C = SIZE VxMerged_D    BY (VIA4_R_3_S2 - VIA4_R_3_S3)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M4_S_1*0.7
   
// Pass VIAx.R.2 (2 eff. square Via)
   G1_A2R = VxMerged_A INTERACT SQR_VIA4 >=2
   G2_A2R = VxMerged_A INTERACT REC_VIA4 >=1
   VxMerged_A2 = G1_A2R OR G2_A2R
// Pass VIAx.R.2 (4 eff. square Via)
   G1_B4R =  VxMerged_B INTERACT SQR_VIA4 >=4
   G2_B4R = (VxMerged_B INTERACT SQR_VIA4 >=2 <=3) AND (VxMerged_B INTERACT REC_VIA4 ==1)
   G3_B4R =  VxMerged_B INTERACT REC_VIA4 >=2
   VxMerged_B4 = (G1_B4R OR G2_B4R) OR G3_B4R

// Pass VIAx.R.3 (4 eff. square + slot Via)
   G1_A4_13 =  VxMerged_D INTERACT REC_VIA4 >=2
   G2_A4_13 = (VxMerged_D INTERACT REC_VIA4 ==1) AND (VxMerged_D INTERACT SQR_VIA4 >=2)
   VxMerged_A4_13 = G1_A4_13 OR G2_A4_13
// Pass VIAx.R.3 (4 eff. square Via only)
   G1_A4_10 = VxMerged_A INTERACT SQR_VIA4 >=4   
   VxMerged_A4 = VxMerged_A4_13 OR G1_A4_10

// Pass VIAx.R.3 (9 eff. square Via)
   G1_C9 =  VxMerged_C INTERACT SQR_VIA4 >=9
   G2_C9 = (VxMerged_C INTERACT SQR_VIA4 >=7 <=8) AND (VxMerged_C INTERACT REC_VIA4 >=1)
   G3_C9 = (VxMerged_C INTERACT SQR_VIA4 >=5 <=6) AND (VxMerged_C INTERACT REC_VIA4 >=2)
   G4_C9 = (VxMerged_C INTERACT SQR_VIA4 >=3 <=4) AND (VxMerged_C INTERACT REC_VIA4 >=3)
   G5_C9 = (VxMerged_C INTERACT SQR_VIA4 >=1 <=2) AND (VxMerged_C INTERACT REC_VIA4 >=4)
   G6_C9 =  VxMerged_C INTERACT REC_VIA4 >=5
   VxMerged_C9 = ((G1_C9 OR G2_C9) OR (G3_C9 OR G4_C9)) OR (G5_C9 OR G6_C9) 

   Checked_Vx_R2 OUTSIDE (MupOvpMdn_R2 INTERACT (VxMerged_A2 OR VxMerged_B4))
   Checked_Vx_R3 OUTSIDE (MupOvpMdn_R3 INTERACT (VxMerged_A4 OR VxMerged_C9))
}

VIA4.R.4:M4 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA4_R_4_L um (L) and width > ^VIA4_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M4Wide_R4_VIA4 BY VIA4_R_4_D + GRID) NOT M4Wide_R4_VIA4) AND M4
  Branch1HasVia = (Branch1 INTERACT M4Wide_R4_VIA4) INTERACT VIA4_EXD
  Branch1Edge = M4Wide_R4_VIA4 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA4_R_4_D INSIDE OF Branch1HasVia STEP M4_S_1*0.4
  GoodBranch = ((Branch AND M5) INTERACT VIA4i > 1) OR ((Branch AND M5) INTERACT (REC_VIA4 OR P_RING_VIA4))
  BranchSingleVia = (VIA4i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M5 INTERACT BranchSingleVia) AND M4) INTERACT BranchSingleVia) INTERACT VIA4i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


VIA4.R.4:M5 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA4_R_4_L um (L) and width > ^VIA4_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M5Wide_R4_VIA4 BY VIA4_R_4_D + GRID) NOT M5Wide_R4_VIA4) AND M5
  Branch1HasVia = (Branch1 INTERACT M5Wide_R4_VIA4) INTERACT VIA4_EXD
  Branch1Edge = M5Wide_R4_VIA4 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA4_R_4_D INSIDE OF Branch1HasVia STEP M5_S_1*0.4
  GoodBranch = ((Branch AND M4) INTERACT VIA4i > 1) OR ((Branch AND M4) INTERACT (REC_VIA4 OR P_RING_VIA4))
  BranchSingleVia = (VIA4i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M4 INTERACT BranchSingleVia) AND M5) INTERACT BranchSingleVia) INTERACT VIA4i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


// VIA4.R.4 is checked by VIA4.R.4:M4 and VIA4.R.4:M5
// VIA4.R.5 is checked by VIA4.R.5:M4 and VIA4.R.5:M5
// VIA4.R.6 is checked by VIA4.R.6:M4 and VIA4.R.6:M5

//'VIAy.R.13' is not necessary to check
//'VIAr.R.13' is not necessary to check


VIA4.R.5:M4 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M4Wide_R5_VIA4 BY VIA4_R_5_D + GRID) NOT M4Wide_R5_VIA4) AND M4
  Branch1HasVia = (Branch1 INTERACT M4Wide_R5_VIA4) INTERACT VIA4_EXD
  Branch1Edge = M4Wide_R5_VIA4 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA4_R_5_D INSIDE OF Branch1HasVia STEP M4_S_1*0.6
  GoodBranch = ((Branch AND M5) INTERACT VIA4i > 1) OR ((Branch AND M5) INTERACT (REC_VIA4 OR P_RING_VIA4))
  BranchSingleVia = (VIA4i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M5 INTERACT BranchSingleVia) AND M4) INTERACT BranchSingleVia) INTERACT VIA4i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
VIA4.R.5:M5 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M5Wide_R5_VIA4 BY VIA4_R_5_D + GRID) NOT M5Wide_R5_VIA4) AND M5
  Branch1HasVia = (Branch1 INTERACT M5Wide_R5_VIA4) INTERACT VIA4_EXD
  Branch1Edge = M5Wide_R5_VIA4 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA4_R_5_D INSIDE OF Branch1HasVia STEP M5_S_1*0.6
  GoodBranch = ((Branch AND M4) INTERACT VIA4i > 1) OR ((Branch AND M4) INTERACT (REC_VIA4 OR P_RING_VIA4))
  BranchSingleVia = (VIA4i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M4 INTERACT BranchSingleVia) AND M5) INTERACT BranchSingleVia) INTERACT VIA4i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


M4Big_R6_VIA4 = ENCLOSE RECTANGLE M4Wide_R6_VIA4 VIA4_R_6_W VIA4_R_6_L+GRID
M5Big_R6_VIA4 = ENCLOSE RECTANGLE M5Wide_R6_VIA4 VIA4_R_6_W VIA4_R_6_L+GRID

VIA4.R.6:M4 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M4Big_R6_VIA4 BY VIA4_R_6_D + GRID) NOT M4Big_R6_VIA4) AND M4
  Branch1HasVia = (Branch1 INTERACT M4Big_R6_VIA4) INTERACT VIA4_EXD
  Branch1Edge = M4Big_R6_VIA4 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA4_R_6_D INSIDE OF Branch1HasVia STEP M4_S_1*0.6
  GoodBranch = ((Branch AND M5) INTERACT VIA4i > 1) OR ((Branch AND M5) INTERACT (REC_VIA4 OR P_RING_VIA4))
  BranchSingleVia = (VIA4i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M5 INTERACT BranchSingleVia) AND M4) INTERACT BranchSingleVia) INTERACT VIA4i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}

VIA4.R.6:M5 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M5Big_R6_VIA4 BY VIA4_R_6_D + GRID) NOT M5Big_R6_VIA4) AND M5
  Branch1HasVia = (Branch1 INTERACT M5Big_R6_VIA4) INTERACT VIA4_EXD
  Branch1Edge = M5Big_R6_VIA4 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA4_R_6_D INSIDE OF Branch1HasVia STEP M5_S_1*0.6
  GoodBranch = ((Branch AND M4) INTERACT VIA4i > 1) OR ((Branch AND M4) INTERACT (REC_VIA4 OR P_RING_VIA4))
  BranchSingleVia = (VIA4i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M4 INTERACT BranchSingleVia) AND M5) INTERACT BranchSingleVia) INTERACT VIA4i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
// VIA4.R.7 is checked by VIA4.EN.1

VIA4.R.8 { @ Single VIAx is not allowed for H-shape Mx+1 when all of the following conditions come into existence: 1. The Mx+1 has H-shape interact with two metal holes: two metal hole length(L2) <= ^VIA4_R_8_L1 um and both two metal hole area <= ^VIA4_R_8_A um2 2. The VIAx overlaps on the center metal bar of this H-shape Mx+1 3. The length (L) of the center metal bar <= ^VIA4_R_8_L2 um and the width of metal bar is <= ^VIA4_R_8_W um.
  W = M5i WITH WIDTH <= VIA4_R_8_W   
  H_HOLE = (HOLES M5i INNER <= VIA4_R_8_A) INTERACT W
  A0 = M5i INTERACT H_HOLE
  A = A0 COIN OUTSIDE EDGE H_HOLE
  B0 = ((INT A <= VIA4_R_8_W ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) INTERACT H_HOLE == 2 
  B1 = (((INT A <= VIA4_R_8_L2 ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) AND W) INTERACT H_HOLE == 2
  HOLE_NOTCH = EXT H_HOLE <= VIA4_R_8_W ABUT<90 OPPOSITE NOTCH REGION  
  B2 = (B1 NOT HOLE_NOTCH) OR B0
  CORNER_M = ((EXT B2 <= VIA4_R_8_W ABUT == 90 INTERSECTING ONLY REGION EXTENTS) TOUCH B2 == 2) AND W
  B = B2 OR CORNER_M
  CENTER_BAR1 = NOT ENCLOSE RECTANGLE B GRID VIA4_R_8_L2+GRID
  CENTER_BAR2 = (CENTER_BAR1 INTERACT H_HOLE == 2) INTERACT VIA4i
  C = CENTER_BAR2 COIN OUTSIDE EDGE H_HOLE 
  D = EXT [C] A <= VIA4_R_8_L1 OPPOSITE
  E = C NOT COIN INSIDE EDGE D
  CENTER_BAR3 = CENTER_BAR2 NOT WITH EDGE E
  CHECK_VIA = VIA4i NOT OUTSIDE CENTER_BAR3
  CHECK_VIA AND (((A0 INTERACT CHECK_VIA) AND (M4i INTERACT CHECK_VIA)) INTERACT VIA4i == 1)
}





#IFDEF CHECK_VIRTUAL_VIAx

//VIAx_VIRT.R.1 is checked by related rules (VIA4 rules)
//'VIAx_VIRT.R.2' is checked by VIA4_VIRT.R.2
VIA4_VIRT.R.2 {@ VIAx_VIRT must be 0.05 um x 0.05 um   
   NOT RECTANGLE VIA4_VIRT == VIA4_W_1 BY == VIA4_W_1 ORTHOGONAL ONLY 
}
//'VIAx_VIRT.R.3' is checked by VIA4_VIRT.R.3
VIA4_VIRT.R.3 {@ VIAx_VIRT interact VIAx is not allowed   
   VIA4_VIRT INTERACT VIA4ii
}
//'VIAx_VIRT.R.4' is checked by VIA4_VIRT.R.4
VIA4_VIRT.R.4 {@ VIAx _VIRT must be fully covered by ROM (50;6)   
   VIA4_VIRT NOT ROM
}
#ENDIF




//M5 CHECKS
//=========
M5_EDGE_45 = M5 ANGLE == 45

M5.W.1 { @ Width >= 0.05 
  INT M5 < M5_W_1 ABUT < 90 SINGULAR REGION
}
M5.W.2 { @ Width of 45-degree bent Mx. (Please make sure the vertex of 45-degree pattern is on 0.005 um grid (refer to the guideline, G.6gU, in section XXX)) >= 0.17 
  INT M5_EDGE_45 < M5_W_2 ABUT < 90 REGION
}


// 'Mx.W.3' is checked by M5.W.3
M5.W.3 { @ Maximum width Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING, or 4. {{INDDMY OR INDDMY_MD} SIZING 16 um}, or 5. CSRDMY, or 6. PADDMY (255;16) <= 4.5 
  M5_MAX_WIDTH WITH WIDTH > M5_W_3
}



 

M5.W.4 { @ Length of the edge with adjacent edge < 0.05 um [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex-270 degree inner vertex; DRC doesn't flag if there is Mx within the area formed by 0.16 um extension from these 2 edges and the 90 degree outer vertex.] (This check doesn't include the region covered by MetalFuse (156;2)) >= 0.065 
  E1 = CONVEX EDGE M5 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH < M5_W_4_L1
  E2 = CONVEX EDGE M5 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH >= M5_W_4_L1 < M5_W_4_L2
  A = INT [E1]    < M5_W_4_L2 ABUT == 90 INTERSECTING ONLY
  B = INT [E2] E1 < M5_W_4_L2 ABUT == 90 INTERSECTING ONLY
  C = INT [E1] E2 < M5_W_4_L2 ABUT == 90 INTERSECTING ONLY
  D = OR EDGE  B (OR EDGE A C)
  CORNER_BAD_pre = (EXPAND EDGE D INSIDE BY 0.001) NOT INSIDE MFUSE
  W = EXT [D] M5 < 0.16
  CORNER_BAD_pre NOT WITH EDGE W
}
M5.S.1 { @ Space >= 0.05 
  EXT M5 < M5_S_1 ABUT < 90 SINGULAR REGION
}

M5.S.2 { @ Space [at least one metal line width > 0.09 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.06 
  X = EXT M5_20 M5 < M5_S_2 OPPOSITE REGION MEASURE ALL
  Y = X NOT M5
  ENCLOSE RECTANGLE Y GRID M5_S_2_L+GRID
}
M5.S.3 { @ Space [at least one metal line width > 0.16 um (W2) and the parallel run length > 0.22 um (L2)] >= 0.1 
  X = EXT M5_21 M5 < M5_S_3 OPPOSITE REGION MEASURE ALL
  Y = X NOT M5
  ENCLOSE RECTANGLE Y GRID M5_S_3_L+GRID
}
M5.S.4 { @ Space [at least one metal line width > 0.47 um (W3) and the parallel run length > 0.47 um (L3)] >= 0.13 
  X = EXT M5_22 M5 < M5_S_4 OPPOSITE REGION MEASURE ALL
  Y = X NOT M5
  ENCLOSE RECTANGLE Y GRID M5_S_4_L+GRID
}
M5.S.5 { @ Space [at least one metal line width > 0.63 um (W4) and the parallel run length > 0.63 um (L4)] >= 0.15 
  X = EXT M5_23 M5 < M5_S_5 OPPOSITE REGION MEASURE ALL
  Y = X NOT M5
  ENCLOSE RECTANGLE Y GRID M5_S_5_L+GRID
}
M5.S.6 { @ Space [at least one metal line width > 1.5 um (W5) and the parallel run length > 1.5 um (L5)] >= 0.5 
  X = EXT M5_30 M5 < M5_S_6 OPPOSITE REGION MEASURE ALL
  Y = X NOT M5
  ENCLOSE RECTANGLE Y 0.001 M5_S_6_L+0.001
}


M5.S.7 { @ Space to Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.07 
  A = CONVEX EDGE M5 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M5_S_7_W
  EXT A M5 < M5_S_7 ABUT < 90 OPPOSITE EXTENDED M5_S_7_T REGION
}

M5.S.8 { @ Mx line space (S1) to dense Mx line-end [parallel run length > -0.025 um (T)], and dense Mx line-end enclosure of Vx-1 (V). Definition of dense Mx line-end: 1. Mx line-end: Mx edge with length < 0.07 um (W) between 2 outer vertex. 2. Other metal INTERACT Region 1. Region 1 = (T+Q) x S2. (W+S2) < 0.115 um. This check doesn't include small jog with edge length < 0.05 um (R) >= 0.08/0.05 or 0.1/0.03 
  M5_END = CONVEX EDGE M5 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M5_S_8_W
  M5_REGION = EXPAND EDGE M5_END OUTSIDE BY M5_S_8_SB + GRID EXTEND BY M5_S_8_T + GRID  // for data reduction
  M5_LINE = (M5 INSIDE EDGE M5_REGION) NOT TOUCH EDGE M5_END
  M5_EA = ENC VIA4i [M5_END] < M5_S_8_EA ABUT < 90 OPPOSITE
  M5_EB = ENC VIA4i [M5_END] < M5_S_8_EB ABUT < 90 OPPOSITE
  M5_SA = EXT [M5_END] M5_LINE < M5_S_8_SA ABUT < 90 OPPOSITE EXTENDED M5_S_8_T
  M5_SB = EXT [M5_END] M5_LINE < M5_S_8_SB ABUT < 90 OPPOSITE EXTENDED M5_S_8_T
  M5_PASS_A = (M5_END NOT TOUCH INSIDE EDGE M5_EA) NOT TOUCH INSIDE EDGE M5_SA
  M5_PASS_B = (M5_END NOT TOUCH INSIDE EDGE M5_EB) NOT TOUCH INSIDE EDGE M5_SB
  M5_CHECK = (M5_END NOT TOUCH INSIDE EDGE M5_PASS_A) NOT TOUCH INSIDE EDGE M5_PASS_B

  M5_Long_side = LENGTH M5 >= M5_W_1
  O = INT M5_CHECK [M5_Long_side] < M5_S_8_Q-M5_S_8_T ABUT == 90 INTERSECTING ONLY  
  PW = INT O M5 < (M5_S_8_P - M5_S_1) ABUT < 90 OPPOSITE EXTENDED M5_S_8_T
  PS = EXT O M5 < (M5_S_8_P - M5_W_1) ABUT < 90 OPPOSITE EXTENDED M5_S_8_T
  Q = DFM PROPERTY O PS PW OVERLAP ABUT ALSO MULTI
  [-= MIN(EW(PW)) + MIN(EW(PS))] < M5_S_8_P
  R = M5_CHECK TOUCH EDGE (EXPAND EDGE Q INSIDE BY 0.001)
  ENC VIA4i R < M5_S_8_EA ABUT < 90 OPPOSITE REGION
  EXT R M5 < M5_S_8_SB ABUT < 90 OPPOSITE EXTENDED M5_S_8_T REGION
}


M5.S.9 { @ Space to 45-degree bent Mx >= 0.17 
  X = EXPAND EDGE M5_EDGE_45 OUTSIDE BY M5_S_9
  X AND M5
}


M5_HVN_65V = NET AREA RATIO M5i OVER M9_HV_65V M8_HV_65V M7_HV_65V M6_HV_65V M5_HV_65V M4_HV_65V M3_HV_65V M2_HV_65V M1_HV_65V PO_HV_65V NW_HV_65V DNW_HV_65V > 0
M5_HVN_5V = NET AREA RATIO M5i OVER M9_HV_5V M8_HV_5V M7_HV_5V M6_HV_5V M5_HV_5V M4_HV_5V M3_HV_5V M2_HV_5V M1_HV_5V > 0
M5_HVN = NET AREA RATIO M5i OVER M9_HV M8_HV M7_HV M6_HV M5_HV M4_HV M3_HV M2_HV M1_HV > 0
M5_MVN = NET AREA RATIO M5i OVER M9_MV M8_MV M7_MV M6_MV M5_MV M4_MV M3_MV M2_MV M1_MV > 0
M5_MLVN = NET AREA RATIO M5i OVER M9_MLV M8_MLV M7_MLV M6_MLV M5_MLV M4_MLV M3_MLV M2_MLV M1_MLV > 0
M5_LVN = NET AREA RATIO M5i OVER M9_LV M8_LV M7_LV M6_LV M5_LV M4_LV M3_LV M2_LV M1_LV > 0
M5_VNVN_pre = NET AREA RATIO M5i OVER M9_VNV M8_VNV M7_VNV M6_VNV M5_VNV M4_VNV M3_VNV M2_VNV M1_VNV > 0
M5_NVN = NET AREA RATIO M5i OVER M9_NV M8_NV M7_NV M6_NV M5_NV M4_NV M3_NV M2_NV M1_NV > 0
M5_VNVN = M5_VNVN_pre NOT M5_NVN
M5_NOMARK = (((((((M5i NOT M5_HVN_65V) NOT M5_HVN_5V) NOT M5_HVN) NOT M5_MVN) NOT M5_MLVN) NOT M5_LVN) NOT M5_NVN) NOT M5_VNVN



#IFDEF USE_IO_VOLTAGE_ON_CORE_TO_IO_NET
  M5_NOMARK_65V = NET AREA RATIO M5_NOMARK PSD_65 NSD_65 PSTPix > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSTPix)]
  M5_NOMARK_5V = NET AREA RATIO M5_NOMARK PSD_50 NSD_50 PSTPix > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)]
  M5_NOMARK_HV = NET AREA RATIO M5_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)]
  M5_NOMARK_MV = NET AREA RATIO M5_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)]
  M5_NOMARK_MLV = NET AREA RATIO M5_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)]
  M5_NOMARK_LV = NET AREA RATIO M5_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]  



#ELSE
  M5_NOMARK_65V = NET AREA RATIO M5_NOMARK PSD_65 NSD_65 PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSD_50)*!AREA(NSD_50)*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M5_NOMARK_5V = NET AREA RATIO M5_NOMARK PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M5_NOMARK_HV = NET AREA RATIO M5_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M5_NOMARK_MV = NET AREA RATIO M5_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M5_NOMARK_MLV = NET AREA RATIO M5_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M5_NOMARK_LV = NET AREA RATIO M5_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]


#ENDIF

M5_HV_65V_ALL = M5_HVN_65V OR M5_NOMARK_65V
M5_HV_5V_ALL = M5_HVN_5V OR M5_NOMARK_5V
M5_HV_ALL = M5_HVN OR M5_NOMARK_HV
M5_MV_ALL = M5_MVN OR M5_NOMARK_MV
M5_MLV_ALL = M5_MLVN OR M5_NOMARK_MLV
M5_LV_ALL = M5_LVN OR M5_NOMARK_LV
M5_NV_ALL = COPY M5_NVN
M5_VNV_ALL = COPY M5_VNVN

M5_VNV_CHK = STAMP M5_VNV_ALL BY M5i
VIA5_VNV_CHK = STAMP (VIA5ii AND M5_VNV_ALL) BY M5i
M5_NV_CHK = STAMP M5_NV_ALL BY M5i
VIA5_NV_CHK = STAMP (VIA5ii AND M5_NV_ALL) BY M5i  
M5_LV_CHK = STAMP M5_LV_ALL BY M5i
VIA5_LV_CHK = STAMP (VIA5ii AND M5_LV_ALL) BY M5i
M5_MLV_CHK = STAMP M5_MLV_ALL BY M5i
VIA5_MLV_CHK = STAMP (VIA5ii AND M5_MLV_ALL) BY M5i
M5_MV_CHK = STAMP M5_MV_ALL BY M5i
VIA5_MV_CHK = STAMP (VIA5ii AND M5_MV_ALL) BY M5i

M5_HV_CHK = STAMP M5_HV_ALL BY M5i
VIA5_HV_CHK = STAMP (VIA5ii AND M5_HV_ALL) BY M5i
M5_HV_5V_CHK = STAMP M5_HV_5V_ALL BY M5i
VIA5_HV_5V_CHK = STAMP (VIA5ii AND M5_HV_5V_ALL) BY M5i
M5_HV_65V_CHK = STAMP M5_HV_65V_ALL BY M5i
VIA5_HV_65V_CHK = STAMP (VIA5ii AND M5_HV_65V_ALL) BY M5i























M5.S.12 { @ Space of Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.08 
  A = CONVEX EDGE M5 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M5_S_12_W
  EXT A < M5_S_12 ABUT < 90 OPPOSITE EXTENDED M5_S_12_T REGION
}

M5.S.13 { @ Space [at least one metal line width > 0.13 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.08 
  X = EXT M5_201 M5 < M5_S_13 OPPOSITE REGION MEASURE ALL
  Y = X NOT M5
  ENCLOSE RECTANGLE Y GRID M5_S_13_L+GRID
}


// M5.EN.0,enclosure of square VIAx-1 is defined by either {Mx.EN.1/Mx.EN.2} or Mx.EN.3
// M5.EN.0 is checked by either {M5.EN.1/M5.EN.2} or M5.EN.3

M5.EN.1 { @ Enclosure of square VIAx-1 >= 0 
  VIA4i NOT M5i
}
M5.EN.2__M5.EN.3__M5.EN.14__M5.EN.15 { @ Enclosure of VIA4 [at least two opposite sides] >= ^M5_EN_2 um OR [all sides] >= ^M5_EN_3 OR [all side] >= ^M5_EN_14 / [at least two opposite sides] >= ^M5_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA4 M5i ABUT < 90 SINGULAR GOOD 0 M5_EN_2 OPPOSITE 0 M5_EN_2 OPPOSITE GOOD M5_EN_14 M5_EN_15 OPPOSITE M5_EN_14 M5_EN_15 OPPOSITE
  ENC X M5i < M5_EN_3 ABUT < 90 SINGULAR REGION
}

// M5.EN.4, Enclosure of rectangular VIAx-1 is defined by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3
// M5.EN.4 is checked by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3

M5.EN.3__M5.EN.5__M5.EN.6__M5.EN.7 { @ Enclosure of rectangular VIA4 [two opposite side >= ^M5_EN_7 and all side >= ^M5_EN_5], OR Enclosure of rectangular VIA4 [at rectangular VIA4 end direction] >= ^M5_EN_6, OR Enclosure of rectangular VIA4 [all sides] >= ^M5_EN_3
  A = RECTANGLE ENCLOSURE REC_VIA4 M5i ABUT < 90 SINGULAR GOOD M5_EN_5 M5_EN_7 OPPOSITE M5_EN_5 M5_EN_7 OPPOSITE GOOD M5_EN_3 M5_EN_3 M5_EN_3 M5_EN_3
  B = LENGTH A == VIA4_W_1
  C = ENC [B] M5i < M5_EN_6 ABUT < 90 OPPOSITE
  A WITH EDGE C
}

// M5.EN.3, M5.EN.5, M5.EN.6 and M5.EN.7 are checked by M5.EN.3__M5.EN.5__M5.EN.6__M5.EN.7
// M5.EN.8 is checked by M5.EN.1

M5_W_55b = M5 WITH WIDTH == M5_EN_9_W 
M5_W_70b = M5 WITH WIDTH > M5_EN_9_W <= M5_EN_10_W 
M5_W_160b = M5 WITH WIDTH > M5_EN_10_W <=M5_EN_11W
M5_W_450b = M5 WITH WIDTH > M5_EN_11W <=M5_EN_12W

M5.EN.9 { @ Enclosure of VIAx-1 [0.055 um >= metal width > 0.05 um, metal space < 0.06 um (D1) and the other side space >= 0.06 um (D1'), parallel run length > 0.1 um] >= 0.005 
  A0 = M5_W_55b INTERACT VIA4i 
  A = EXT A0 [M5] < M5_EN_9_S1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A M5 < M5_EN_9_S1 ABUT < 90 OPPOSITE REGION
  C = EXT A M5 < M5_EN_9_S1 ABUT < 90 OPPOSITE
  D = EXT A [M5] < M5_EN_9_S1 ABUT < 90 OPPOSITE
  E0 = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
  [-= EC(C) ] > M5_EN_9_L
  E1 = E0 NOT WITH EDGE (ANGLE M5 >0 < 90) 
  E = E0 NOT (E1 NOT ENCLOSE RECTANGLE M5_EN_9_L+GRID GRID ORTHOGONAL ONLY)  
  F = D COIN OUTSIDE EDGE E
  G = (EXPAND EDGE F INSIDE BY M5_EN_9_W) INTERACT E != 2  
  H = F COIN INSIDE EDGE G 
  ENC VIA4i H < M5_EN_9 ABUT < 90 OPPOSITE REGION
}
M5.EN.10 { @ Enclosure of VIAx-1 [0.07 um >= metal width > 0.055 um, metal space < 0.065 um (D1) and parallel run length > 0.1 um] >= 0.005 
  W = EXT M5_W_70b [M5] < M5_EN_10_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M5i] < M5_EN_10_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M5i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M5i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M5_EN_10_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M5_EN_10_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA4i S7_H < M5_EN_10 ABUT < 90 OPPOSITE REGION
  ENC VIA4i S7_V < M5_EN_10 ABUT < 90 OPPOSITE REGION

}
M5.EN.11 { @ Enclosure of VIAx-1 [0.16 um >= metal width > 0.07 um, metal space < 0.1 um (D1) and parallel run length > 0.1 um] (For Mx.EN.11, the rule check is not included same VIAx group, which is defined as below.) 1. VIAx space <= 0.11 um2. Mx is same net 3. Mx+1 is same net >= 0.01 
  VIA4_M = SIZE VIA4i BY M5_EN_11_S/2 INSIDE OF SAME_NET_VIA4 STEP M4_S_1*0.6
  VIA4_C = VIA4i NOT INTERACT (VIA4_M INTERACT VIA4i >= 2)
  W = EXT M5_W_160b [M5] < M5_EN_11_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M5i] < M5_EN_11_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M5i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M5i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M5_EN_11_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M5_EN_11_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA4_C S7_H < M5_EN_11 ABUT < 90 OPPOSITE REGION
  ENC VIA4_C S7_V < M5_EN_11 ABUT < 90 OPPOSITE REGION

}
// 'Mx.EN.12' is checked by M5.EN.12
M5.EN.12 { @ Enclosure of VIAx-1 [4.5 um >= metal width > 0.16 um, metal space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M5_W_450b [M5] < M5_EN_12_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M5i] < M5_EN_12_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M5i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M5i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M5_EN_12_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M5_EN_12_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA4i S7_H < M5_EN_12 ABUT < 90 OPPOSITE REGION
  ENC VIA4i S7_V < M5_EN_12 ABUT < 90 OPPOSITE REGION

}
// 'Mx.EN.13' is checked by M5.EN.13
M5.EN.13 { @ Enclosure of VIAx-1 bar in LOWMEDN >= 0.1 
  ENC P_RING_VIA4 M5 < M5_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}
// 'Mx.L.1' is checked by M5.L.1
M5.L.1 { @ Length of 45-degree bent Mx (minimum edge length) >= 0.5 
  (LENGTH M5_EDGE_45 < M5_L_1) NOT INSIDE EDGE SEALRING_ALL
}

M5.A.1 { @ Area (except M2) >= 0.017 
  AREA M5 < M5_A_1
}
//'Mx.A.1' is checked by M5.A.1
M5.A.3 { @ Area [with all of edge lengths < 0.13 um] (Except M2 inside SRAMDMY;0) (This check doesn't include the patterns filling 0.05 um x 0.13 um rectangular tile) >= 0.044 
  A = AREA M5 < M5_A_3
  B = LENGTH A >= M5_A_3_L1
  C = A NOT WITH EDGE B
  NOT ENCLOSE RECTANGLE C M5_A_3_W M5_A_3_L2 ORTHOGONAL ONLY
}

VARIABLE M5_A_4pre ((M5_A_4 + (M5_S_1 * M5_S_1 * 3.142))/(2 * M5_S_1))*((M5_A_4 + (M5_S_1 * M5_S_1 * 3.142))/(2 * M5_S_1))/3.141 // user value

M5.A.4 { @ Enclosed area >= 0.2 
  X = HOLES M5 INNER < M5_A_4pre
  AREA ( X NOT M5 ) < M5_A_4
}

//'DMx_O.R.1' is checked by DM5_O.R.1
DM5_O.R.1 { @ DMx_O INTERACT Mx is not allowed. [Mx, and My only]   
  DM5_O INTERACT M5i
}






// 'Mx.DN.0.1' is checked by related rules




//'My.DN.0' is not necessary to check
//'My.DN.1' is not necessary to check
//'My.DN.2' is not necessary to check
//'My.DN.3' is not necessary to check

//'Mr.DN.0' is not necessary to check
//'Mr.DN.1' is not necessary to check
//'Mr.DN.2' is not necessary to check
//'Mr.DN.3' is not necessary to check



//'Mx.DN.1' is checked by M5.DN.1
#IFDEF CHECK_LOW_DENSITY
M5.DN.1 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum metal density in window 125 um x 125 um, stepping 62.5*20% um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10%+3% 
#ELSE
@ Minimum metal density in window 125 um x 125 um, stepping 62.5 um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10% 
#ENDIF
  EXC_LOW = M5_EXC_LOW OR ICOVL
  N = M5x NOT EXC_LOW
  D = CHIP NOT EXC_LOW 
  A = CHIP_M5 NOT EXC_LOW
  X = DENSITY A M5x CHIP N D < M5_DN_1 WINDOW M5_DN_1_W STEP M5_DN_1_S BACKUP INSIDE OF LAYER CHIP_M5 PRINT M5.DN.1.density RDB M5.DN.1.RDB.density
          [~(AREA(A)-M5_DN_1_E)*!!(AREA(A)-M5_DN_1_E)+AREA(N)/AREA(D)+!~(AREA(M5x)/AREA(CHIP)-M5_DN_1)+!(AREA(M5x)/AREA(CHIP)-M5_DN_1)]


  COPY X    
}
#ENDIF



//'Mx.DN.2' is checked by M5.DN.2
M5.DN.2 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum metal density in window 125 um x 125 um, stepping 62.5*20% um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85%-3% 
#ELSE
@ Maximum metal density in window 125 um x 125 um, stepping 62.5 um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85% 
#ENDIF
  EXC_HIGH = M5_EXC_HIGH OR ICOVL
  N = M5x NOT EXC_HIGH
  D = CHIP NOT EXC_HIGH 
  A = CHIPx NOT EXC_HIGH
  X = DENSITY A M5x CHIP N D > M5_DN_2 WINDOW M5_DN_2_W STEP M5_DN_2_S BACKUP INSIDE OF LAYER CHIPx PRINT M5.DN.2.density RDB M5.DN.2.RDB.density
          [~(M5_DN_2_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M5x)/AREA(CHIP)-M5_DN_2)]


  COPY X    
}

//'Mx.DN.3' is checked by M5.DN.3
M5.DN.3 { @ The metal density difference between any 2 neighboring checking windows including DMxEXCL [window 200 um x 200 um, stepping 200 um]. Anticipate metal density gradient from layout of small cell by targeting density ~50% (this way, it will limit the risk of low density and of high gradient).(Except ICOVL) <= 50% 
   EXCEPT =  COPY ICOVL
   M5x_Chk = M5x NOT EXCEPT
   DENSITY M5x_Chk EXCEPT CHIP <=1 WINDOW M5_DN_3_W BACKUP GRADIENT > M5_DN_3 ABSOLUTE CORNER INSIDE OF LAYER CHIPx PRINT M5.DN.3.density RDB M5.DN.3.RDB.density
    [ (AREA(M5x_Chk)+AREA(EXCEPT)*M5_DN_3_V)/AREA(CHIP) ] 
}

M5_CORE = M5x NOT SRCSR_P4
//'Mx.DN.4' is checked by Mx.DN.4:M3_M4_M5 
Mx.DN.4:M3_M4_M5 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ It is not allowed to have local density > 85% of all 3 consecutive metal (Mx, Mx+1 and Mx+2) over any window 62.5 um x 62.5 um (stepping 31.25*20% um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density > 85%+3%. 1. The metal layers include M1/Mx and dummy metals. 2. Except following condition: (1). Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or (2). Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or (3). SEALRING_ALL, or (4) Chip corner triangle empty areas
#ELSE
@ It is not allowed to have local density > 85% of all 3 consecutive metal (Mx, Mx+1 and Mx+2) over any window 62.5 um x 62.5 um (stepping 31.25 um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density > 85%. 1. The metal layers include M1/Mx and dummy metals. 2. Except following condition: (1). Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or (2). Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or (3). SEALRING_ALL, or (4) Chip corner triangle empty areas   
#ENDIF
 DENSITY  M3_CORE M4_CORE M5_CORE >0 WINDOW M3_DN_4_W STEP M3_DN_4_S BACKUP INSIDE OF LAYER CHIPx 
      [ !~(AREA(M3_CORE)/AREA()- M3_DN_4)*!~(AREA(M4_CORE)/AREA()- M3_DN_4)*!~(AREA(M5_CORE)/AREA()- M3_DN_4) ]
      RDB Mx.DN.4:M3_M4_M5.density
}


#IFDEF CHECK_LOW_DENSITY
M5.DN.6 { @ Metal Density >= ^M5_DN_6 must be followed for item(A) to (C)
@ (A) Metal density [checking window ^M5_DN_6_W_A um x ^M5_DN_6_W_A um, stepping ^M5_DN_6_S_A um] >= ^M5_DN_6
@ (B) Maximum area of merged low density windows [checking window ^M5_DN_6_W_BC um x ^M5_DN_6_W_BC um, stepping ^M5_DN_6_S_BC um, density < ^M5_DN_6] <= ^M5_DN_6_A_B um2. Merged low density windows width <= ^M5_DN_6_U um is except.
@ (C) Maximum area of merged low density windows [checking window ^M5_DN_6_W_BC um x ^M5_DN_6_W_BC um, stepping ^M5_DN_6_S_BC um, density < ^M5_DN_6] <= ^M5_DN_6_A_C um2
@ 1. The following special regions are excluded
@    Chip corner triangle empty areas if sealring is added by tsmc. 
@    LOWMEDN
@ 2. This rule is applied while the width of (checking window NOT above excluding region) >= ^M5_DN_6_E_A um for (A) and >= ^M5_DN_6_E_BC um for both (B)/(C) 
  M5_CHECK = M5x NOT (NEW_DEN_EXC OR ICOVL)
  CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
  // Condition-A
  ERR_WIN_A = DENSITY M5_CHECK CHIP_CHECK < M5_DN_6 WINDOW M5_DN_6_W_A STEP M5_DN_6_S_A INSIDE OF LAYER CHIP_M5 BACKUP 
	[ AREA(M5_CHECK)/AREA(CHIP_CHECK) ]
  F_A = WITH WIDTH (ERR_WIN_A NOT (NEW_DEN_EXC OR ICOVL)) >= M5_DN_6_E_A
  DENSITY F_A M5_CHECK CHIP_CHECK < M5_DN_6 WINDOW M5_DN_6_W_A STEP M5_DN_6_S_A INSIDE OF LAYER CHIP_M5 BACKUP PRINT M5.DN.6_A.density
         [ !AREA(F_A)+AREA(M5_CHECK)/AREA(CHIP_CHECK) ]
  // Condition-B 
  ERR_WIN_B = DENSITY M5_CHECK CHIP_CHECK < M5_DN_6 WINDOW M5_DN_6_W_BC STEP M5_DN_6_S_BC INSIDE OF LAYER CHIP_M5 BACKUP 
	[ AREA(M5_CHECK)/AREA(CHIP_CHECK) ]
  F_B = WITH WIDTH (ERR_WIN_B NOT (NEW_DEN_EXC OR ICOVL)) >= M5_DN_6_E_BC
  A = DENSITY F_B M5_CHECK CHIP_CHECK < M5_DN_6 WINDOW M5_DN_6_W_BC STEP M5_DN_6_S_BC INSIDE OF LAYER CHIP_M5 BACKUP PRINT M5.DN.6_BC.density
         [ !AREA(F_B)+AREA(M5_CHECK)/AREA(CHIP_CHECK) ]
  B = AREA A > M5_DN_6_A_B
  C = SIZE B BY M5_DN_6_U/2 UNDEROVER
  B INTERACT C
  // Condition-C
  AREA B > M5_DN_6_A_C
}
#ENDIF

#IFDEF CHECK_LOW_DENSITY
//'Mx.DN.7' is checked by Mx.DN.7:M3_M4_M5
Mx.DN.7:M3_M4_M5 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ It is not allowed to have local density < 5% of all 3 consecutive metal (Mx, Mx+1, and Mx+2) over any 30 um x 30 um (stepping 15*20% um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density >= 5+3%. 1. The metal layers include M1/Mx and dummy metals for ELK film. 2. The following special regions are excluded while the density checking: - Chip corner triangle empty areas if seal-ring is added by tsmc. - LOWMEDN, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area)    
#ELSE
@ It is not allowed to have local density < 5% of all 3 consecutive metal (Mx, Mx+1, and Mx+2) over any 30 um x 30 um (stepping 15 um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density >= 5%. 1. The metal layers include M1/Mx and dummy metals for ELK film. 2. The following special regions are excluded while the density checking: - Chip corner triangle empty areas if seal-ring is added by tsmc. - LOWMEDN, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area)   
#ENDIF
   M3_CHECK = M3x NOT (NEW_DEN_EXC OR ICOVL)
   M4_CHECK = M4x NOT (NEW_DEN_EXC OR ICOVL)
   M5_CHECK = M5x NOT (NEW_DEN_EXC OR ICOVL)
   CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
   DENSITY M3_CHECK M4_CHECK M5_CHECK CHIP_CHECK >0 WINDOW M3_DN_7_W STEP M3_DN_7_S BACKUP INSIDE OF LAYER CHIP_M5
   [ ~(M3_DN_7_E-AREA(CHIP_CHECK))*!~(M3_DN_7-(AREA(M3_CHECK)/AREA(CHIP_CHECK)))*!~(M3_DN_7-(AREA(M4_CHECK)/AREA(CHIP_CHECK)))*!~(M3_DN_7-(AREA(M5_CHECK)/AREA(CHIP_CHECK))) ]
   RDB Mx.DN.7:M3_M4_M5.density
}
#ENDIF





//VIA5 CHECKS
//===========
VIA5.W.1 { @  Width x Length = 0.05 x 0.05, 0.05 x 0.13 (Except seal-ring (162,2) and {LOWMEDN NOT {LOWMEDN SIZING -4 m}})
  A = NOT RECTANGLE VIA5i == VIA5_W_1 BY == VIA5_L_1 ORTHOGONAL ONLY
  B = NOT RECTANGLE A == VIA5_W_1 BY == VIA5_L_2 ORTHOGONAL ONLY    
  B NOT (VIA_EXD OR P_RING_REGION)
}

// 'VIAx.W.6' is checked by VIA5.W.6
VIA5.W.6 { @ Width of VIAx bar in protection ring [INSIDE LOWMEDN] = 0.15 
  INT P_RING_VIA5 > VIA5_W_6+2*GRID < VIA5_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  WITH WIDTH P_RING_VIA5 >= VIA5_W_6*2
  INT P_RING_VIA5 < VIA5_W_6-2*GRID ABUT < 90 REGION
}
SAME_NET_VIA5 = M5i AND M6i

VIA5.S.1 { @ Square VIAx space >= 0.07 
  EXT VIA5i < VIA5_S_1 ABUT < 90 SINGULAR REGION
}

VIA5.S.3 { @ Square VIAx space to rectangular VIAx >= 0.075 
  EXT SQR_VIA5 REC_VIA5 < VIA5_S_3 ABUT < 90 SINGULAR REGION
}
VIA5.S.4 { @ Rectangular VIAx space to rectangular VIAx >= 0.08 
  EXT REC_VIA5 < VIA5_S_4 ABUT < 90 SINGULAR REGION
}
VIA5.S.5 { @ VIAx space [parallel run length > -0.04 um] >= 0.08 
   EXT VIA5i < VIA5_S_5 ABUT < 90 OPPOSITE EXTENDED VIA5_S_5_L REGION
}





VIA5.S.18 { @ Space of VIAx bar in LOWMEDN to VIAx hole >= 0.35 
  EXT P_RING_VIA5 VIA5_EXD < VIA5_S_18 ABUT < 90 SINGULAR REGION
}

VIA5.S.19 { @ Space of VIAx bar in LOWMEDN >= 0.6 
  EXT P_RING_VIA5 < VIA5_S_19 ABUT < 90 SINGULAR REGION
}









// VIA5.EN.0 is checked by either {VIA5.EN.1/VIA5.EN.2} or VIA5.EN.3

VIA5.EN.1 { @ Enclosure by M1 or Mx >= 0 
  VIA5i NOT M5i
}
VIA5.EN.2__VIA5.EN.3__VIA5.EN.14__VIA5.EN.15 { @ Enclosure by M5 [at least two opposite sides] >= ^VIA5_EN_2 um OR [all sides] >= ^VIA5_EN_3 OR [all side] >= ^VIA5_EN_14 / [at least two opposite sides] >= ^VIA5_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA5 M5i ABUT < 90 SINGULAR GOOD 0 VIA5_EN_2 OPPOSITE 0 VIA5_EN_2 OPPOSITE GOOD VIA5_EN_14 VIA5_EN_15 OPPOSITE VIA5_EN_14 VIA5_EN_15 OPPOSITE
  ENC X M5i < VIA5_EN_3 ABUT < 90 SINGULAR REGION
}


// VIA5.EN.4,	Rectangular VIAx enclosure by M1 or Mx is defined by either {VIAx.EN.5/VIAx.EN.7} or {VIAx.EN.6/VIAx.EN.8} or VIAx.EN.3
// VIA5.EN.4 is checked by either {VIA5.EN.5/VIA5.EN.7} or VIA5.EN.3

VIA5.EN.3__VIA5.EN.5__VIA5.EN.6__VIA5.EN.7 { @ Enclosure by M5 [two opposite direction >= ^VIA5_EN_7 and all side >= ^VIA5_EN_5], OR Enclosure by M5 [at rectangular VIA5 end direction] >= ^VIA5_EN_6, OR Enclosure by M5 [all sides] >= ^VIA5_EN_3    
  A = RECTANGLE ENCLOSURE REC_VIA5 M5i ABUT < 90 SINGULAR GOOD VIA5_EN_5 VIA5_EN_7 OPPOSITE VIA5_EN_5 VIA5_EN_7 OPPOSITE GOOD VIA5_EN_3 VIA5_EN_3 VIA5_EN_3 VIA5_EN_3
  B = LENGTH A == VIA5_W_1
  C = ENC [B] M5i < VIA5_EN_6 ABUT < 90 OPPOSITE
  A WITH EDGE C

}
// VIA5.EN.3, VIA5.EN.5, VIA5.EN.6 and VIA5.EN.7 are checked by VIA5.EN.3__VIA5.EN.5__VIA5.EN.6__VIA5.EN.7
// VIA5.EN.8 is checked by VIA5.EN.1

M5_W_55 = M5 WITH WIDTH == VIA5_EN_9_W 
M5_W_70 = M5 WITH WIDTH > VIA5_EN_9_W <= VIA5_EN_10_W 
M5_W_160 = M5 WITH WIDTH > VIA5_EN_10_W <=VIA5_EN_11W
M5_W_450 = M5 WITH WIDTH > VIA5_EN_11W <=VIA5_EN_12W

//'VIAx.EN.9' is checked by VIA5.EN.9
VIA5.EN.9 { @ Enclosure by Mx [0.055 um >= metal width > 0.05 um, space < 0.06 um (D1) and the other side space >= 0.06 um (D1'), parallel run length > 0.1 um] >= 0.005 
  A0 = M5_W_55 INTERACT VIA5i 
  A = EXT A0 [M5] < VIA5_EN_9_S1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A M5 < VIA5_EN_9_S1 ABUT < 90 OPPOSITE REGION
  C = EXT A M5 < VIA5_EN_9_S1 ABUT < 90 OPPOSITE
  D = EXT A [M5] < VIA5_EN_9_S1 ABUT < 90 OPPOSITE
  E0 = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
  [-= EC(C) ] > VIA5_EN_9_L
  E1 = E0 NOT WITH EDGE (ANGLE M5 >0 < 90) 
  E = E0 NOT (E1 NOT ENCLOSE RECTANGLE VIA5_EN_9_L+GRID GRID ORTHOGONAL ONLY)  
  F = D COIN OUTSIDE EDGE E
  G = (EXPAND EDGE F INSIDE BY VIA5_EN_9_W) INTERACT E != 2  
  H = F COIN INSIDE EDGE G 
  ENC VIA5i H < VIA5_EN_9 ABUT < 90 OPPOSITE REGION
}
//'VIAx.EN.10' is checked by VIA5.EN.10
VIA5.EN.10 { @ Enclosure by Mx [0.07 um >= metal width > 0.055 um, space < 0.065 um (D1) and parallel run length > 0.1 um] >= 0.005 
  W = EXT M5_W_70 [M5] < VIA5_EN_10_S ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M5i] < VIA5_EN_10_S ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M5i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M5i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA5_EN_10_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA5_EN_10_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA5i S7_H < VIA5_EN_10 ABUT < 90 OPPOSITE REGION
  ENC VIA5i S7_V < VIA5_EN_10 ABUT < 90 OPPOSITE REGION

}
//'VIAx.EN.11' is checked by VIA5.EN.11
VIA5.EN.11 { @ Enclosure by Mx [0.16 um >= metal width > 0.07 um, space < 0.1 um (D1) and parallel run length > 0.1 um] (For VIAx.EN.11, the rule check is not included same VIAx group, which is defined as below). 1. VIAx space <= 0.11 um2. Mx is same net 3. Mx+1 is same net >= 0.01 
  VIA5_M = SIZE VIA5i BY VIA5_EN_11_S/2 INSIDE OF SAME_NET_VIA5 STEP M5_S_1*0.6
  VIA5_C = VIA5i NOT INTERACT (VIA5_M INTERACT VIA5i >= 2)
  W = EXT M5_W_160 [M5] < VIA5_EN_11D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M5i] < VIA5_EN_11D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M5i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M5i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA5_EN_11L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA5_EN_11L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA5_C S7_H < VIA5_EN_11 ABUT < 90 OPPOSITE REGION
  ENC VIA5_C S7_V < VIA5_EN_11 ABUT < 90 OPPOSITE REGION

}
VIA5.EN.12 { @ Enclosure by M1 or Mx [4.5 um >= metal width > 0.16 um, space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M5_W_450 [M5] < VIA5_EN_12D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M5i] < VIA5_EN_12D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M5i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M5i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M5i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA5_EN_12L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA5_EN_12L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA5i S7_H < VIA5_EN_12 ABUT < 90 OPPOSITE REGION
  ENC VIA5i S7_V < VIA5_EN_12 ABUT < 90 OPPOSITE REGION

}
// 'VIAx.EN.13' is checked by VIA5.EN.13
VIA5.EN.13 { @ VIAx bar enclosure by M1/Mx in LOWMEDN >= 0.1 
  ENC P_RING_VIA5 M5 < VIA5_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}

// VIA5.L.1 is checked by VIA5.W.1
// VIA5.L.2 is checked by VIA5.W.1

// VIA5.R.0 is checked by VIA5.W.1
// VIA5.R.1 is checked by [VIA5.R.2 ~ VIA5.R.6]

//'VIAx.R.2' is checked by VIA5.R.2__VIA5.R.3
//'VIAx.R.3' is checked by VIA5.R.2__VIA5.R.3
VIA5.R.2__VIA5.R.3 { @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S1) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W1) > 0.18 um]. (Except VIA bar region) 1. at least one rectangular VIAx, or 2. at least 2 square VIAx with space <= 0.1 um (S1), or 3. at least 4 square VIAx with space <= 0.65 um (S1')   
                     @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S2) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W2) > 0.44 um]. Please refer to VIAx.R.3 table behind. (Except VIA bar region)   
   MupOvpMdn_W3  = (M5Wide_R3_VIA5 AND M6i) OR (M6Wide_R3_VIA5 AND M5i)
   MupOvpMdn_R3  = MupOvpMdn_W3 NOT OUTSIDE VIA5_EXD
   Checked_Vx_R3 = VIA5_EXD NOT OUTSIDE MupOvpMdn_W3

   MupOvpMdn_W2      = (M5Wide_R2_VIA5 AND M6i) OR (M6Wide_R2_VIA5 AND M5i)
   MupOvpMdn_R2_pre  = MupOvpMdn_W2 NOT OUTSIDE VIA5_EXD
   MupOvpMdn_R2      = MupOvpMdn_R2_pre NOT MupOvpMdn_R3
   Checked_Vx_R2 = (VIA5_EXD NOT OUTSIDE MupOvpMdn_W2) NOT Checked_Vx_R3
   
   Mdn_effect = M5i INTERACT MupOvpMdn_R2_pre
   Mup_effect = M6i INTERACT MupOvpMdn_R2_pre
   effect_MupOvpMdn_ = Mdn_effect AND Mup_effect
   
   effect_MupOvpMdn_R = SIZE MupOvpMdn_R2_pre BY (VIA5_W_1+VIA5_R_3_S2)*8+GRID
   effect_MupOvpMdn = effect_MupOvpMdn_ AND effect_MupOvpMdn_R
   effect_VIA = VIA5_EXD INTERACT effect_MupOvpMdn

   VxMerged_A = SIZE effect_VIA BY VIA5_R_2_S1/2              INSIDE OF effect_MupOvpMdn STEP M5_S_1*0.7
   VxMerged_B = SIZE VxMerged_A BY (VIA5_R_2_S2 - VIA5_R_2_S1)/2 INSIDE OF effect_MupOvpMdn STEP M5_S_1*0.7
   effect_MupOvpMdn_R3 = effect_MupOvpMdn INTERACT MupOvpMdn_R3
   VxMerged_A_R3 = VxMerged_A INTERACT effect_MupOvpMdn_R3 
   VxMerged_D = SIZE VxMerged_A_R3 BY (VIA5_R_3_S3 - VIA5_R_2_S1)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M5_S_1*0.7
   VxMerged_C = SIZE VxMerged_D    BY (VIA5_R_3_S2 - VIA5_R_3_S3)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M5_S_1*0.7
   
// Pass VIAx.R.2 (2 eff. square Via)
   G1_A2R = VxMerged_A INTERACT SQR_VIA5 >=2
   G2_A2R = VxMerged_A INTERACT REC_VIA5 >=1
   VxMerged_A2 = G1_A2R OR G2_A2R
// Pass VIAx.R.2 (4 eff. square Via)
   G1_B4R =  VxMerged_B INTERACT SQR_VIA5 >=4
   G2_B4R = (VxMerged_B INTERACT SQR_VIA5 >=2 <=3) AND (VxMerged_B INTERACT REC_VIA5 ==1)
   G3_B4R =  VxMerged_B INTERACT REC_VIA5 >=2
   VxMerged_B4 = (G1_B4R OR G2_B4R) OR G3_B4R

// Pass VIAx.R.3 (4 eff. square + slot Via)
   G1_A4_13 =  VxMerged_D INTERACT REC_VIA5 >=2
   G2_A4_13 = (VxMerged_D INTERACT REC_VIA5 ==1) AND (VxMerged_D INTERACT SQR_VIA5 >=2)
   VxMerged_A4_13 = G1_A4_13 OR G2_A4_13
// Pass VIAx.R.3 (4 eff. square Via only)
   G1_A4_10 = VxMerged_A INTERACT SQR_VIA5 >=4   
   VxMerged_A4 = VxMerged_A4_13 OR G1_A4_10

// Pass VIAx.R.3 (9 eff. square Via)
   G1_C9 =  VxMerged_C INTERACT SQR_VIA5 >=9
   G2_C9 = (VxMerged_C INTERACT SQR_VIA5 >=7 <=8) AND (VxMerged_C INTERACT REC_VIA5 >=1)
   G3_C9 = (VxMerged_C INTERACT SQR_VIA5 >=5 <=6) AND (VxMerged_C INTERACT REC_VIA5 >=2)
   G4_C9 = (VxMerged_C INTERACT SQR_VIA5 >=3 <=4) AND (VxMerged_C INTERACT REC_VIA5 >=3)
   G5_C9 = (VxMerged_C INTERACT SQR_VIA5 >=1 <=2) AND (VxMerged_C INTERACT REC_VIA5 >=4)
   G6_C9 =  VxMerged_C INTERACT REC_VIA5 >=5
   VxMerged_C9 = ((G1_C9 OR G2_C9) OR (G3_C9 OR G4_C9)) OR (G5_C9 OR G6_C9) 

   Checked_Vx_R2 OUTSIDE (MupOvpMdn_R2 INTERACT (VxMerged_A2 OR VxMerged_B4))
   Checked_Vx_R3 OUTSIDE (MupOvpMdn_R3 INTERACT (VxMerged_A4 OR VxMerged_C9))
}

VIA5.R.4:M5 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA5_R_4_L um (L) and width > ^VIA5_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M5Wide_R4_VIA5 BY VIA5_R_4_D + GRID) NOT M5Wide_R4_VIA5) AND M5
  Branch1HasVia = (Branch1 INTERACT M5Wide_R4_VIA5) INTERACT VIA5_EXD
  Branch1Edge = M5Wide_R4_VIA5 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA5_R_4_D INSIDE OF Branch1HasVia STEP M5_S_1*0.4
  GoodBranch = ((Branch AND M6) INTERACT VIA5i > 1) OR ((Branch AND M6) INTERACT (REC_VIA5 OR P_RING_VIA5))
  BranchSingleVia = (VIA5i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M6 INTERACT BranchSingleVia) AND M5) INTERACT BranchSingleVia) INTERACT VIA5i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


VIA5.R.4:M6 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA5_R_4_L um (L) and width > ^VIA5_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M6Wide_R4_VIA5 BY VIA5_R_4_D + GRID) NOT M6Wide_R4_VIA5) AND M6
  Branch1HasVia = (Branch1 INTERACT M6Wide_R4_VIA5) INTERACT VIA5_EXD
  Branch1Edge = M6Wide_R4_VIA5 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA5_R_4_D INSIDE OF Branch1HasVia STEP M6_S_1*0.4
  GoodBranch = ((Branch AND M5) INTERACT VIA5i > 1) OR ((Branch AND M5) INTERACT (REC_VIA5 OR P_RING_VIA5))
  BranchSingleVia = (VIA5i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M5 INTERACT BranchSingleVia) AND M6) INTERACT BranchSingleVia) INTERACT VIA5i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


// VIA5.R.4 is checked by VIA5.R.4:M5 and VIA5.R.4:M6
// VIA5.R.5 is checked by VIA5.R.5:M5 and VIA5.R.5:M6
// VIA5.R.6 is checked by VIA5.R.6:M5 and VIA5.R.6:M6

//'VIAy.R.13' is not necessary to check
//'VIAr.R.13' is not necessary to check


VIA5.R.5:M5 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M5Wide_R5_VIA5 BY VIA5_R_5_D + GRID) NOT M5Wide_R5_VIA5) AND M5
  Branch1HasVia = (Branch1 INTERACT M5Wide_R5_VIA5) INTERACT VIA5_EXD
  Branch1Edge = M5Wide_R5_VIA5 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA5_R_5_D INSIDE OF Branch1HasVia STEP M5_S_1*0.6
  GoodBranch = ((Branch AND M6) INTERACT VIA5i > 1) OR ((Branch AND M6) INTERACT (REC_VIA5 OR P_RING_VIA5))
  BranchSingleVia = (VIA5i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M6 INTERACT BranchSingleVia) AND M5) INTERACT BranchSingleVia) INTERACT VIA5i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
VIA5.R.5:M6 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M6Wide_R5_VIA5 BY VIA5_R_5_D + GRID) NOT M6Wide_R5_VIA5) AND M6
  Branch1HasVia = (Branch1 INTERACT M6Wide_R5_VIA5) INTERACT VIA5_EXD
  Branch1Edge = M6Wide_R5_VIA5 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA5_R_5_D INSIDE OF Branch1HasVia STEP M6_S_1*0.6
  GoodBranch = ((Branch AND M5) INTERACT VIA5i > 1) OR ((Branch AND M5) INTERACT (REC_VIA5 OR P_RING_VIA5))
  BranchSingleVia = (VIA5i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M5 INTERACT BranchSingleVia) AND M6) INTERACT BranchSingleVia) INTERACT VIA5i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


M5Big_R6_VIA5 = ENCLOSE RECTANGLE M5Wide_R6_VIA5 VIA5_R_6_W VIA5_R_6_L+GRID
M6Big_R6_VIA5 = ENCLOSE RECTANGLE M6Wide_R6_VIA5 VIA5_R_6_W VIA5_R_6_L+GRID

VIA5.R.6:M5 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M5Big_R6_VIA5 BY VIA5_R_6_D + GRID) NOT M5Big_R6_VIA5) AND M5
  Branch1HasVia = (Branch1 INTERACT M5Big_R6_VIA5) INTERACT VIA5_EXD
  Branch1Edge = M5Big_R6_VIA5 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA5_R_6_D INSIDE OF Branch1HasVia STEP M5_S_1*0.6
  GoodBranch = ((Branch AND M6) INTERACT VIA5i > 1) OR ((Branch AND M6) INTERACT (REC_VIA5 OR P_RING_VIA5))
  BranchSingleVia = (VIA5i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M6 INTERACT BranchSingleVia) AND M5) INTERACT BranchSingleVia) INTERACT VIA5i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}

VIA5.R.6:M6 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M6Big_R6_VIA5 BY VIA5_R_6_D + GRID) NOT M6Big_R6_VIA5) AND M6
  Branch1HasVia = (Branch1 INTERACT M6Big_R6_VIA5) INTERACT VIA5_EXD
  Branch1Edge = M6Big_R6_VIA5 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA5_R_6_D INSIDE OF Branch1HasVia STEP M6_S_1*0.6
  GoodBranch = ((Branch AND M5) INTERACT VIA5i > 1) OR ((Branch AND M5) INTERACT (REC_VIA5 OR P_RING_VIA5))
  BranchSingleVia = (VIA5i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M5 INTERACT BranchSingleVia) AND M6) INTERACT BranchSingleVia) INTERACT VIA5i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
// VIA5.R.7 is checked by VIA5.EN.1

VIA5.R.8 { @ Single VIAx is not allowed for H-shape Mx+1 when all of the following conditions come into existence: 1. The Mx+1 has H-shape interact with two metal holes: two metal hole length(L2) <= ^VIA5_R_8_L1 um and both two metal hole area <= ^VIA5_R_8_A um2 2. The VIAx overlaps on the center metal bar of this H-shape Mx+1 3. The length (L) of the center metal bar <= ^VIA5_R_8_L2 um and the width of metal bar is <= ^VIA5_R_8_W um.
  W = M6i WITH WIDTH <= VIA5_R_8_W   
  H_HOLE = (HOLES M6i INNER <= VIA5_R_8_A) INTERACT W
  A0 = M6i INTERACT H_HOLE
  A = A0 COIN OUTSIDE EDGE H_HOLE
  B0 = ((INT A <= VIA5_R_8_W ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) INTERACT H_HOLE == 2 
  B1 = (((INT A <= VIA5_R_8_L2 ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) AND W) INTERACT H_HOLE == 2
  HOLE_NOTCH = EXT H_HOLE <= VIA5_R_8_W ABUT<90 OPPOSITE NOTCH REGION  
  B2 = (B1 NOT HOLE_NOTCH) OR B0
  CORNER_M = ((EXT B2 <= VIA5_R_8_W ABUT == 90 INTERSECTING ONLY REGION EXTENTS) TOUCH B2 == 2) AND W
  B = B2 OR CORNER_M
  CENTER_BAR1 = NOT ENCLOSE RECTANGLE B GRID VIA5_R_8_L2+GRID
  CENTER_BAR2 = (CENTER_BAR1 INTERACT H_HOLE == 2) INTERACT VIA5i
  C = CENTER_BAR2 COIN OUTSIDE EDGE H_HOLE 
  D = EXT [C] A <= VIA5_R_8_L1 OPPOSITE
  E = C NOT COIN INSIDE EDGE D
  CENTER_BAR3 = CENTER_BAR2 NOT WITH EDGE E
  CHECK_VIA = VIA5i NOT OUTSIDE CENTER_BAR3
  CHECK_VIA AND (((A0 INTERACT CHECK_VIA) AND (M5i INTERACT CHECK_VIA)) INTERACT VIA5i == 1)
}





#IFDEF CHECK_VIRTUAL_VIAx

//VIAx_VIRT.R.1 is checked by related rules (VIA5 rules)
//'VIAx_VIRT.R.2' is checked by VIA5_VIRT.R.2
VIA5_VIRT.R.2 {@ VIAx_VIRT must be 0.05 um x 0.05 um   
   NOT RECTANGLE VIA5_VIRT == VIA5_W_1 BY == VIA5_W_1 ORTHOGONAL ONLY 
}
//'VIAx_VIRT.R.3' is checked by VIA5_VIRT.R.3
VIA5_VIRT.R.3 {@ VIAx_VIRT interact VIAx is not allowed   
   VIA5_VIRT INTERACT VIA5ii
}
//'VIAx_VIRT.R.4' is checked by VIA5_VIRT.R.4
VIA5_VIRT.R.4 {@ VIAx _VIRT must be fully covered by ROM (50;6)   
   VIA5_VIRT NOT ROM
}
#ENDIF




//M6 CHECKS
//=========
M6_EDGE_45 = M6 ANGLE == 45

M6.W.1 { @ Width >= 0.05 
  INT M6 < M6_W_1 ABUT < 90 SINGULAR REGION
}
M6.W.2 { @ Width of 45-degree bent Mx. (Please make sure the vertex of 45-degree pattern is on 0.005 um grid (refer to the guideline, G.6gU, in section XXX)) >= 0.17 
  INT M6_EDGE_45 < M6_W_2 ABUT < 90 REGION
}


// 'Mx.W.3' is checked by M6.W.3
M6.W.3 { @ Maximum width Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING, or 4. {{INDDMY OR INDDMY_MD} SIZING 16 um}, or 5. CSRDMY, or 6. PADDMY (255;16) <= 4.5 
  M6_MAX_WIDTH WITH WIDTH > M6_W_3
}



 

M6.W.4 { @ Length of the edge with adjacent edge < 0.05 um [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex-270 degree inner vertex; DRC doesn't flag if there is Mx within the area formed by 0.16 um extension from these 2 edges and the 90 degree outer vertex.] (This check doesn't include the region covered by MetalFuse (156;2)) >= 0.065 
  E1 = CONVEX EDGE M6 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH < M6_W_4_L1
  E2 = CONVEX EDGE M6 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH >= M6_W_4_L1 < M6_W_4_L2
  A = INT [E1]    < M6_W_4_L2 ABUT == 90 INTERSECTING ONLY
  B = INT [E2] E1 < M6_W_4_L2 ABUT == 90 INTERSECTING ONLY
  C = INT [E1] E2 < M6_W_4_L2 ABUT == 90 INTERSECTING ONLY
  D = OR EDGE  B (OR EDGE A C)
  CORNER_BAD_pre = (EXPAND EDGE D INSIDE BY 0.001) NOT INSIDE MFUSE
  W = EXT [D] M6 < 0.16
  CORNER_BAD_pre NOT WITH EDGE W
}
M6.S.1 { @ Space >= 0.05 
  EXT M6 < M6_S_1 ABUT < 90 SINGULAR REGION
}

M6.S.2 { @ Space [at least one metal line width > 0.09 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.06 
  X = EXT M6_20 M6 < M6_S_2 OPPOSITE REGION MEASURE ALL
  Y = X NOT M6
  ENCLOSE RECTANGLE Y GRID M6_S_2_L+GRID
}
M6.S.3 { @ Space [at least one metal line width > 0.16 um (W2) and the parallel run length > 0.22 um (L2)] >= 0.1 
  X = EXT M6_21 M6 < M6_S_3 OPPOSITE REGION MEASURE ALL
  Y = X NOT M6
  ENCLOSE RECTANGLE Y GRID M6_S_3_L+GRID
}
M6.S.4 { @ Space [at least one metal line width > 0.47 um (W3) and the parallel run length > 0.47 um (L3)] >= 0.13 
  X = EXT M6_22 M6 < M6_S_4 OPPOSITE REGION MEASURE ALL
  Y = X NOT M6
  ENCLOSE RECTANGLE Y GRID M6_S_4_L+GRID
}
M6.S.5 { @ Space [at least one metal line width > 0.63 um (W4) and the parallel run length > 0.63 um (L4)] >= 0.15 
  X = EXT M6_23 M6 < M6_S_5 OPPOSITE REGION MEASURE ALL
  Y = X NOT M6
  ENCLOSE RECTANGLE Y GRID M6_S_5_L+GRID
}
M6.S.6 { @ Space [at least one metal line width > 1.5 um (W5) and the parallel run length > 1.5 um (L5)] >= 0.5 
  X = EXT M6_30 M6 < M6_S_6 OPPOSITE REGION MEASURE ALL
  Y = X NOT M6
  ENCLOSE RECTANGLE Y 0.001 M6_S_6_L+0.001
}


M6.S.7 { @ Space to Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.07 
  A = CONVEX EDGE M6 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M6_S_7_W
  EXT A M6 < M6_S_7 ABUT < 90 OPPOSITE EXTENDED M6_S_7_T REGION
}

M6.S.8 { @ Mx line space (S1) to dense Mx line-end [parallel run length > -0.025 um (T)], and dense Mx line-end enclosure of Vx-1 (V). Definition of dense Mx line-end: 1. Mx line-end: Mx edge with length < 0.07 um (W) between 2 outer vertex. 2. Other metal INTERACT Region 1. Region 1 = (T+Q) x S2. (W+S2) < 0.115 um. This check doesn't include small jog with edge length < 0.05 um (R) >= 0.08/0.05 or 0.1/0.03 
  M6_END = CONVEX EDGE M6 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M6_S_8_W
  M6_REGION = EXPAND EDGE M6_END OUTSIDE BY M6_S_8_SB + GRID EXTEND BY M6_S_8_T + GRID  // for data reduction
  M6_LINE = (M6 INSIDE EDGE M6_REGION) NOT TOUCH EDGE M6_END
  M6_EA = ENC VIA5i [M6_END] < M6_S_8_EA ABUT < 90 OPPOSITE
  M6_EB = ENC VIA5i [M6_END] < M6_S_8_EB ABUT < 90 OPPOSITE
  M6_SA = EXT [M6_END] M6_LINE < M6_S_8_SA ABUT < 90 OPPOSITE EXTENDED M6_S_8_T
  M6_SB = EXT [M6_END] M6_LINE < M6_S_8_SB ABUT < 90 OPPOSITE EXTENDED M6_S_8_T
  M6_PASS_A = (M6_END NOT TOUCH INSIDE EDGE M6_EA) NOT TOUCH INSIDE EDGE M6_SA
  M6_PASS_B = (M6_END NOT TOUCH INSIDE EDGE M6_EB) NOT TOUCH INSIDE EDGE M6_SB
  M6_CHECK = (M6_END NOT TOUCH INSIDE EDGE M6_PASS_A) NOT TOUCH INSIDE EDGE M6_PASS_B

  M6_Long_side = LENGTH M6 >= M6_W_1
  O = INT M6_CHECK [M6_Long_side] < M6_S_8_Q-M6_S_8_T ABUT == 90 INTERSECTING ONLY  
  PW = INT O M6 < (M6_S_8_P - M6_S_1) ABUT < 90 OPPOSITE EXTENDED M6_S_8_T
  PS = EXT O M6 < (M6_S_8_P - M6_W_1) ABUT < 90 OPPOSITE EXTENDED M6_S_8_T
  Q = DFM PROPERTY O PS PW OVERLAP ABUT ALSO MULTI
  [-= MIN(EW(PW)) + MIN(EW(PS))] < M6_S_8_P
  R = M6_CHECK TOUCH EDGE (EXPAND EDGE Q INSIDE BY 0.001)
  ENC VIA5i R < M6_S_8_EA ABUT < 90 OPPOSITE REGION
  EXT R M6 < M6_S_8_SB ABUT < 90 OPPOSITE EXTENDED M6_S_8_T REGION
}


M6.S.9 { @ Space to 45-degree bent Mx >= 0.17 
  X = EXPAND EDGE M6_EDGE_45 OUTSIDE BY M6_S_9
  X AND M6
}


M6_HVN_65V = NET AREA RATIO M6i OVER M9_HV_65V M8_HV_65V M7_HV_65V M6_HV_65V M5_HV_65V M4_HV_65V M3_HV_65V M2_HV_65V M1_HV_65V PO_HV_65V NW_HV_65V DNW_HV_65V > 0
M6_HVN_5V = NET AREA RATIO M6i OVER M9_HV_5V M8_HV_5V M7_HV_5V M6_HV_5V M5_HV_5V M4_HV_5V M3_HV_5V M2_HV_5V M1_HV_5V > 0
M6_HVN = NET AREA RATIO M6i OVER M9_HV M8_HV M7_HV M6_HV M5_HV M4_HV M3_HV M2_HV M1_HV > 0
M6_MVN = NET AREA RATIO M6i OVER M9_MV M8_MV M7_MV M6_MV M5_MV M4_MV M3_MV M2_MV M1_MV > 0
M6_MLVN = NET AREA RATIO M6i OVER M9_MLV M8_MLV M7_MLV M6_MLV M5_MLV M4_MLV M3_MLV M2_MLV M1_MLV > 0
M6_LVN = NET AREA RATIO M6i OVER M9_LV M8_LV M7_LV M6_LV M5_LV M4_LV M3_LV M2_LV M1_LV > 0
M6_VNVN_pre = NET AREA RATIO M6i OVER M9_VNV M8_VNV M7_VNV M6_VNV M5_VNV M4_VNV M3_VNV M2_VNV M1_VNV > 0
M6_NVN = NET AREA RATIO M6i OVER M9_NV M8_NV M7_NV M6_NV M5_NV M4_NV M3_NV M2_NV M1_NV > 0
M6_VNVN = M6_VNVN_pre NOT M6_NVN
M6_NOMARK = (((((((M6i NOT M6_HVN_65V) NOT M6_HVN_5V) NOT M6_HVN) NOT M6_MVN) NOT M6_MLVN) NOT M6_LVN) NOT M6_NVN) NOT M6_VNVN



#IFDEF USE_IO_VOLTAGE_ON_CORE_TO_IO_NET
  M6_NOMARK_65V = NET AREA RATIO M6_NOMARK PSD_65 NSD_65 PSTPix > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSTPix)]
  M6_NOMARK_5V = NET AREA RATIO M6_NOMARK PSD_50 NSD_50 PSTPix > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)]
  M6_NOMARK_HV = NET AREA RATIO M6_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)]
  M6_NOMARK_MV = NET AREA RATIO M6_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)]
  M6_NOMARK_MLV = NET AREA RATIO M6_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)]
  M6_NOMARK_LV = NET AREA RATIO M6_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]  



#ELSE
  M6_NOMARK_65V = NET AREA RATIO M6_NOMARK PSD_65 NSD_65 PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSD_50)*!AREA(NSD_50)*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M6_NOMARK_5V = NET AREA RATIO M6_NOMARK PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M6_NOMARK_HV = NET AREA RATIO M6_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M6_NOMARK_MV = NET AREA RATIO M6_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M6_NOMARK_MLV = NET AREA RATIO M6_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M6_NOMARK_LV = NET AREA RATIO M6_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]


#ENDIF

M6_HV_65V_ALL = M6_HVN_65V OR M6_NOMARK_65V
M6_HV_5V_ALL = M6_HVN_5V OR M6_NOMARK_5V
M6_HV_ALL = M6_HVN OR M6_NOMARK_HV
M6_MV_ALL = M6_MVN OR M6_NOMARK_MV
M6_MLV_ALL = M6_MLVN OR M6_NOMARK_MLV
M6_LV_ALL = M6_LVN OR M6_NOMARK_LV
M6_NV_ALL = COPY M6_NVN
M6_VNV_ALL = COPY M6_VNVN

M6_VNV_CHK = STAMP M6_VNV_ALL BY M6i
VIA6_VNV_CHK = STAMP (VIA6ii AND M6_VNV_ALL) BY M6i
M6_NV_CHK = STAMP M6_NV_ALL BY M6i
VIA6_NV_CHK = STAMP (VIA6ii AND M6_NV_ALL) BY M6i  
M6_LV_CHK = STAMP M6_LV_ALL BY M6i
VIA6_LV_CHK = STAMP (VIA6ii AND M6_LV_ALL) BY M6i
M6_MLV_CHK = STAMP M6_MLV_ALL BY M6i
VIA6_MLV_CHK = STAMP (VIA6ii AND M6_MLV_ALL) BY M6i
M6_MV_CHK = STAMP M6_MV_ALL BY M6i
VIA6_MV_CHK = STAMP (VIA6ii AND M6_MV_ALL) BY M6i

M6_HV_CHK = STAMP M6_HV_ALL BY M6i
VIA6_HV_CHK = STAMP (VIA6ii AND M6_HV_ALL) BY M6i
M6_HV_5V_CHK = STAMP M6_HV_5V_ALL BY M6i
VIA6_HV_5V_CHK = STAMP (VIA6ii AND M6_HV_5V_ALL) BY M6i
M6_HV_65V_CHK = STAMP M6_HV_65V_ALL BY M6i
VIA6_HV_65V_CHK = STAMP (VIA6ii AND M6_HV_65V_ALL) BY M6i























M6.S.12 { @ Space of Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.08 
  A = CONVEX EDGE M6 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M6_S_12_W
  EXT A < M6_S_12 ABUT < 90 OPPOSITE EXTENDED M6_S_12_T REGION
}

M6.S.13 { @ Space [at least one metal line width > 0.13 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.08 
  X = EXT M6_201 M6 < M6_S_13 OPPOSITE REGION MEASURE ALL
  Y = X NOT M6
  ENCLOSE RECTANGLE Y GRID M6_S_13_L+GRID
}


// M6.EN.0,enclosure of square VIAx-1 is defined by either {Mx.EN.1/Mx.EN.2} or Mx.EN.3
// M6.EN.0 is checked by either {M6.EN.1/M6.EN.2} or M6.EN.3

M6.EN.1 { @ Enclosure of square VIAx-1 >= 0 
  VIA5i NOT M6i
}
M6.EN.2__M6.EN.3__M6.EN.14__M6.EN.15 { @ Enclosure of VIA5 [at least two opposite sides] >= ^M6_EN_2 um OR [all sides] >= ^M6_EN_3 OR [all side] >= ^M6_EN_14 / [at least two opposite sides] >= ^M6_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA5 M6i ABUT < 90 SINGULAR GOOD 0 M6_EN_2 OPPOSITE 0 M6_EN_2 OPPOSITE GOOD M6_EN_14 M6_EN_15 OPPOSITE M6_EN_14 M6_EN_15 OPPOSITE
  ENC X M6i < M6_EN_3 ABUT < 90 SINGULAR REGION
}

// M6.EN.4, Enclosure of rectangular VIAx-1 is defined by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3
// M6.EN.4 is checked by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3

M6.EN.3__M6.EN.5__M6.EN.6__M6.EN.7 { @ Enclosure of rectangular VIA5 [two opposite side >= ^M6_EN_7 and all side >= ^M6_EN_5], OR Enclosure of rectangular VIA5 [at rectangular VIA5 end direction] >= ^M6_EN_6, OR Enclosure of rectangular VIA5 [all sides] >= ^M6_EN_3
  A = RECTANGLE ENCLOSURE REC_VIA5 M6i ABUT < 90 SINGULAR GOOD M6_EN_5 M6_EN_7 OPPOSITE M6_EN_5 M6_EN_7 OPPOSITE GOOD M6_EN_3 M6_EN_3 M6_EN_3 M6_EN_3
  B = LENGTH A == VIA5_W_1
  C = ENC [B] M6i < M6_EN_6 ABUT < 90 OPPOSITE
  A WITH EDGE C
}

// M6.EN.3, M6.EN.5, M6.EN.6 and M6.EN.7 are checked by M6.EN.3__M6.EN.5__M6.EN.6__M6.EN.7
// M6.EN.8 is checked by M6.EN.1

M6_W_55b = M6 WITH WIDTH == M6_EN_9_W 
M6_W_70b = M6 WITH WIDTH > M6_EN_9_W <= M6_EN_10_W 
M6_W_160b = M6 WITH WIDTH > M6_EN_10_W <=M6_EN_11W
M6_W_450b = M6 WITH WIDTH > M6_EN_11W <=M6_EN_12W

M6.EN.9 { @ Enclosure of VIAx-1 [0.055 um >= metal width > 0.05 um, metal space < 0.06 um (D1) and the other side space >= 0.06 um (D1'), parallel run length > 0.1 um] >= 0.005 
  A0 = M6_W_55b INTERACT VIA5i 
  A = EXT A0 [M6] < M6_EN_9_S1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A M6 < M6_EN_9_S1 ABUT < 90 OPPOSITE REGION
  C = EXT A M6 < M6_EN_9_S1 ABUT < 90 OPPOSITE
  D = EXT A [M6] < M6_EN_9_S1 ABUT < 90 OPPOSITE
  E0 = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
  [-= EC(C) ] > M6_EN_9_L
  E1 = E0 NOT WITH EDGE (ANGLE M6 >0 < 90) 
  E = E0 NOT (E1 NOT ENCLOSE RECTANGLE M6_EN_9_L+GRID GRID ORTHOGONAL ONLY)  
  F = D COIN OUTSIDE EDGE E
  G = (EXPAND EDGE F INSIDE BY M6_EN_9_W) INTERACT E != 2  
  H = F COIN INSIDE EDGE G 
  ENC VIA5i H < M6_EN_9 ABUT < 90 OPPOSITE REGION
}
M6.EN.10 { @ Enclosure of VIAx-1 [0.07 um >= metal width > 0.055 um, metal space < 0.065 um (D1) and parallel run length > 0.1 um] >= 0.005 
  W = EXT M6_W_70b [M6] < M6_EN_10_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M6i] < M6_EN_10_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M6i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M6i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M6_EN_10_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M6_EN_10_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA5i S7_H < M6_EN_10 ABUT < 90 OPPOSITE REGION
  ENC VIA5i S7_V < M6_EN_10 ABUT < 90 OPPOSITE REGION

}
M6.EN.11 { @ Enclosure of VIAx-1 [0.16 um >= metal width > 0.07 um, metal space < 0.1 um (D1) and parallel run length > 0.1 um] (For Mx.EN.11, the rule check is not included same VIAx group, which is defined as below.) 1. VIAx space <= 0.11 um2. Mx is same net 3. Mx+1 is same net >= 0.01 
  VIA5_M = SIZE VIA5i BY M6_EN_11_S/2 INSIDE OF SAME_NET_VIA5 STEP M5_S_1*0.6
  VIA5_C = VIA5i NOT INTERACT (VIA5_M INTERACT VIA5i >= 2)
  W = EXT M6_W_160b [M6] < M6_EN_11_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M6i] < M6_EN_11_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M6i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M6i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M6_EN_11_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M6_EN_11_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA5_C S7_H < M6_EN_11 ABUT < 90 OPPOSITE REGION
  ENC VIA5_C S7_V < M6_EN_11 ABUT < 90 OPPOSITE REGION

}
// 'Mx.EN.12' is checked by M6.EN.12
M6.EN.12 { @ Enclosure of VIAx-1 [4.5 um >= metal width > 0.16 um, metal space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M6_W_450b [M6] < M6_EN_12_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M6i] < M6_EN_12_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M6i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M6i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M6_EN_12_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M6_EN_12_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA5i S7_H < M6_EN_12 ABUT < 90 OPPOSITE REGION
  ENC VIA5i S7_V < M6_EN_12 ABUT < 90 OPPOSITE REGION

}
// 'Mx.EN.13' is checked by M6.EN.13
M6.EN.13 { @ Enclosure of VIAx-1 bar in LOWMEDN >= 0.1 
  ENC P_RING_VIA5 M6 < M6_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}
// 'Mx.L.1' is checked by M6.L.1
M6.L.1 { @ Length of 45-degree bent Mx (minimum edge length) >= 0.5 
  (LENGTH M6_EDGE_45 < M6_L_1) NOT INSIDE EDGE SEALRING_ALL
}

M6.A.1 { @ Area (except M2) >= 0.017 
  AREA M6 < M6_A_1
}
//'Mx.A.1' is checked by M6.A.1
M6.A.3 { @ Area [with all of edge lengths < 0.13 um] (Except M2 inside SRAMDMY;0) (This check doesn't include the patterns filling 0.05 um x 0.13 um rectangular tile) >= 0.044 
  A = AREA M6 < M6_A_3
  B = LENGTH A >= M6_A_3_L1
  C = A NOT WITH EDGE B
  NOT ENCLOSE RECTANGLE C M6_A_3_W M6_A_3_L2 ORTHOGONAL ONLY
}

VARIABLE M6_A_4pre ((M6_A_4 + (M6_S_1 * M6_S_1 * 3.142))/(2 * M6_S_1))*((M6_A_4 + (M6_S_1 * M6_S_1 * 3.142))/(2 * M6_S_1))/3.141 // user value

M6.A.4 { @ Enclosed area >= 0.2 
  X = HOLES M6 INNER < M6_A_4pre
  AREA ( X NOT M6 ) < M6_A_4
}

//'DMx_O.R.1' is checked by DM6_O.R.1
DM6_O.R.1 { @ DMx_O INTERACT Mx is not allowed. [Mx, and My only]   
  DM6_O INTERACT M6i
}






// 'Mx.DN.0.1' is checked by related rules




//'My.DN.0' is not necessary to check
//'My.DN.1' is not necessary to check
//'My.DN.2' is not necessary to check
//'My.DN.3' is not necessary to check

//'Mr.DN.0' is not necessary to check
//'Mr.DN.1' is not necessary to check
//'Mr.DN.2' is not necessary to check
//'Mr.DN.3' is not necessary to check



//'Mx.DN.1' is checked by M6.DN.1
#IFDEF CHECK_LOW_DENSITY
M6.DN.1 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum metal density in window 125 um x 125 um, stepping 62.5*20% um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10%+3% 
#ELSE
@ Minimum metal density in window 125 um x 125 um, stepping 62.5 um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10% 
#ENDIF
  EXC_LOW = M6_EXC_LOW OR ICOVL
  N = M6x NOT EXC_LOW
  D = CHIP NOT EXC_LOW 
  A = CHIP_M6 NOT EXC_LOW
  X = DENSITY A M6x CHIP N D < M6_DN_1 WINDOW M6_DN_1_W STEP M6_DN_1_S BACKUP INSIDE OF LAYER CHIP_M6 PRINT M6.DN.1.density RDB M6.DN.1.RDB.density
          [~(AREA(A)-M6_DN_1_E)*!!(AREA(A)-M6_DN_1_E)+AREA(N)/AREA(D)+!~(AREA(M6x)/AREA(CHIP)-M6_DN_1)+!(AREA(M6x)/AREA(CHIP)-M6_DN_1)]


  COPY X    
}
#ENDIF



//'Mx.DN.2' is checked by M6.DN.2
M6.DN.2 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum metal density in window 125 um x 125 um, stepping 62.5*20% um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85%-3% 
#ELSE
@ Maximum metal density in window 125 um x 125 um, stepping 62.5 um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85% 
#ENDIF
  EXC_HIGH = M6_EXC_HIGH OR ICOVL
  N = M6x NOT EXC_HIGH
  D = CHIP NOT EXC_HIGH 
  A = CHIPx NOT EXC_HIGH
  X = DENSITY A M6x CHIP N D > M6_DN_2 WINDOW M6_DN_2_W STEP M6_DN_2_S BACKUP INSIDE OF LAYER CHIPx PRINT M6.DN.2.density RDB M6.DN.2.RDB.density
          [~(M6_DN_2_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M6x)/AREA(CHIP)-M6_DN_2)]


  COPY X    
}

//'Mx.DN.3' is checked by M6.DN.3
M6.DN.3 { @ The metal density difference between any 2 neighboring checking windows including DMxEXCL [window 200 um x 200 um, stepping 200 um]. Anticipate metal density gradient from layout of small cell by targeting density ~50% (this way, it will limit the risk of low density and of high gradient).(Except ICOVL) <= 50% 
   EXCEPT =  COPY ICOVL
   M6x_Chk = M6x NOT EXCEPT
   DENSITY M6x_Chk EXCEPT CHIP <=1 WINDOW M6_DN_3_W BACKUP GRADIENT > M6_DN_3 ABSOLUTE CORNER INSIDE OF LAYER CHIPx PRINT M6.DN.3.density RDB M6.DN.3.RDB.density
    [ (AREA(M6x_Chk)+AREA(EXCEPT)*M6_DN_3_V)/AREA(CHIP) ] 
}

M6_CORE = M6x NOT SRCSR_P4
//'Mx.DN.4' is checked by Mx.DN.4:M4_M5_M6 
Mx.DN.4:M4_M5_M6 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ It is not allowed to have local density > 85% of all 3 consecutive metal (Mx, Mx+1 and Mx+2) over any window 62.5 um x 62.5 um (stepping 31.25*20% um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density > 85%+3%. 1. The metal layers include M1/Mx and dummy metals. 2. Except following condition: (1). Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or (2). Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or (3). SEALRING_ALL, or (4) Chip corner triangle empty areas
#ELSE
@ It is not allowed to have local density > 85% of all 3 consecutive metal (Mx, Mx+1 and Mx+2) over any window 62.5 um x 62.5 um (stepping 31.25 um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density > 85%. 1. The metal layers include M1/Mx and dummy metals. 2. Except following condition: (1). Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or (2). Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or (3). SEALRING_ALL, or (4) Chip corner triangle empty areas   
#ENDIF
 DENSITY  M4_CORE M5_CORE M6_CORE >0 WINDOW M4_DN_4_W STEP M4_DN_4_S BACKUP INSIDE OF LAYER CHIPx 
      [ !~(AREA(M4_CORE)/AREA()- M4_DN_4)*!~(AREA(M5_CORE)/AREA()- M4_DN_4)*!~(AREA(M6_CORE)/AREA()- M4_DN_4) ]
      RDB Mx.DN.4:M4_M5_M6.density
}


#IFDEF CHECK_LOW_DENSITY
M6.DN.6 { @ Metal Density >= ^M6_DN_6 must be followed for item(A) to (C)
@ (A) Metal density [checking window ^M6_DN_6_W_A um x ^M6_DN_6_W_A um, stepping ^M6_DN_6_S_A um] >= ^M6_DN_6
@ (B) Maximum area of merged low density windows [checking window ^M6_DN_6_W_BC um x ^M6_DN_6_W_BC um, stepping ^M6_DN_6_S_BC um, density < ^M6_DN_6] <= ^M6_DN_6_A_B um2. Merged low density windows width <= ^M6_DN_6_U um is except.
@ (C) Maximum area of merged low density windows [checking window ^M6_DN_6_W_BC um x ^M6_DN_6_W_BC um, stepping ^M6_DN_6_S_BC um, density < ^M6_DN_6] <= ^M6_DN_6_A_C um2
@ 1. The following special regions are excluded
@    Chip corner triangle empty areas if sealring is added by tsmc. 
@    LOWMEDN
@ 2. This rule is applied while the width of (checking window NOT above excluding region) >= ^M6_DN_6_E_A um for (A) and >= ^M6_DN_6_E_BC um for both (B)/(C) 
  M6_CHECK = M6x NOT (NEW_DEN_EXC OR ICOVL)
  CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
  // Condition-A
  ERR_WIN_A = DENSITY M6_CHECK CHIP_CHECK < M6_DN_6 WINDOW M6_DN_6_W_A STEP M6_DN_6_S_A INSIDE OF LAYER CHIP_M6 BACKUP 
	[ AREA(M6_CHECK)/AREA(CHIP_CHECK) ]
  F_A = WITH WIDTH (ERR_WIN_A NOT (NEW_DEN_EXC OR ICOVL)) >= M6_DN_6_E_A
  DENSITY F_A M6_CHECK CHIP_CHECK < M6_DN_6 WINDOW M6_DN_6_W_A STEP M6_DN_6_S_A INSIDE OF LAYER CHIP_M6 BACKUP PRINT M6.DN.6_A.density
         [ !AREA(F_A)+AREA(M6_CHECK)/AREA(CHIP_CHECK) ]
  // Condition-B 
  ERR_WIN_B = DENSITY M6_CHECK CHIP_CHECK < M6_DN_6 WINDOW M6_DN_6_W_BC STEP M6_DN_6_S_BC INSIDE OF LAYER CHIP_M6 BACKUP 
	[ AREA(M6_CHECK)/AREA(CHIP_CHECK) ]
  F_B = WITH WIDTH (ERR_WIN_B NOT (NEW_DEN_EXC OR ICOVL)) >= M6_DN_6_E_BC
  A = DENSITY F_B M6_CHECK CHIP_CHECK < M6_DN_6 WINDOW M6_DN_6_W_BC STEP M6_DN_6_S_BC INSIDE OF LAYER CHIP_M6 BACKUP PRINT M6.DN.6_BC.density
         [ !AREA(F_B)+AREA(M6_CHECK)/AREA(CHIP_CHECK) ]
  B = AREA A > M6_DN_6_A_B
  C = SIZE B BY M6_DN_6_U/2 UNDEROVER
  B INTERACT C
  // Condition-C
  AREA B > M6_DN_6_A_C
}
#ENDIF

#IFDEF CHECK_LOW_DENSITY
//'Mx.DN.7' is checked by Mx.DN.7:M4_M5_M6
Mx.DN.7:M4_M5_M6 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ It is not allowed to have local density < 5% of all 3 consecutive metal (Mx, Mx+1, and Mx+2) over any 30 um x 30 um (stepping 15*20% um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density >= 5+3%. 1. The metal layers include M1/Mx and dummy metals for ELK film. 2. The following special regions are excluded while the density checking: - Chip corner triangle empty areas if seal-ring is added by tsmc. - LOWMEDN, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area)    
#ELSE
@ It is not allowed to have local density < 5% of all 3 consecutive metal (Mx, Mx+1, and Mx+2) over any 30 um x 30 um (stepping 15 um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density >= 5%. 1. The metal layers include M1/Mx and dummy metals for ELK film. 2. The following special regions are excluded while the density checking: - Chip corner triangle empty areas if seal-ring is added by tsmc. - LOWMEDN, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area)   
#ENDIF
   M4_CHECK = M4x NOT (NEW_DEN_EXC OR ICOVL)
   M5_CHECK = M5x NOT (NEW_DEN_EXC OR ICOVL)
   M6_CHECK = M6x NOT (NEW_DEN_EXC OR ICOVL)
   CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
   DENSITY M4_CHECK M5_CHECK M6_CHECK CHIP_CHECK >0 WINDOW M4_DN_7_W STEP M4_DN_7_S BACKUP INSIDE OF LAYER CHIP_M6
   [ ~(M4_DN_7_E-AREA(CHIP_CHECK))*!~(M4_DN_7-(AREA(M4_CHECK)/AREA(CHIP_CHECK)))*!~(M4_DN_7-(AREA(M5_CHECK)/AREA(CHIP_CHECK)))*!~(M4_DN_7-(AREA(M6_CHECK)/AREA(CHIP_CHECK))) ]
   RDB Mx.DN.7:M4_M5_M6.density
}
#ENDIF





//VIA6 CHECKS
//===========
VIA6.W.1 { @  Width x Length = 0.05 x 0.05, 0.05 x 0.13 (Except seal-ring (162,2) and {LOWMEDN NOT {LOWMEDN SIZING -4 m}})
  A = NOT RECTANGLE VIA6i == VIA6_W_1 BY == VIA6_L_1 ORTHOGONAL ONLY
  B = NOT RECTANGLE A == VIA6_W_1 BY == VIA6_L_2 ORTHOGONAL ONLY    
  B NOT (VIA_EXD OR P_RING_REGION)
}

// 'VIAx.W.6' is checked by VIA6.W.6
VIA6.W.6 { @ Width of VIAx bar in protection ring [INSIDE LOWMEDN] = 0.15 
  INT P_RING_VIA6 > VIA6_W_6+2*GRID < VIA6_W_6*2 ABUT < 90 OPPOSITE PARALLEL ONLY REGION
  WITH WIDTH P_RING_VIA6 >= VIA6_W_6*2
  INT P_RING_VIA6 < VIA6_W_6-2*GRID ABUT < 90 REGION
}
SAME_NET_VIA6 = M6i AND M7i

VIA6.S.1 { @ Square VIAx space >= 0.07 
  EXT VIA6i < VIA6_S_1 ABUT < 90 SINGULAR REGION
}

VIA6.S.3 { @ Square VIAx space to rectangular VIAx >= 0.075 
  EXT SQR_VIA6 REC_VIA6 < VIA6_S_3 ABUT < 90 SINGULAR REGION
}
VIA6.S.4 { @ Rectangular VIAx space to rectangular VIAx >= 0.08 
  EXT REC_VIA6 < VIA6_S_4 ABUT < 90 SINGULAR REGION
}
VIA6.S.5 { @ VIAx space [parallel run length > -0.04 um] >= 0.08 
   EXT VIA6i < VIA6_S_5 ABUT < 90 OPPOSITE EXTENDED VIA6_S_5_L REGION
}





VIA6.S.18 { @ Space of VIAx bar in LOWMEDN to VIAx hole >= 0.35 
  EXT P_RING_VIA6 VIA6_EXD < VIA6_S_18 ABUT < 90 SINGULAR REGION
}

VIA6.S.19 { @ Space of VIAx bar in LOWMEDN >= 0.6 
  EXT P_RING_VIA6 < VIA6_S_19 ABUT < 90 SINGULAR REGION
}









// VIA6.EN.0 is checked by either {VIA6.EN.1/VIA6.EN.2} or VIA6.EN.3

VIA6.EN.1 { @ Enclosure by M1 or Mx >= 0 
  VIA6i NOT M6i
}
VIA6.EN.2__VIA6.EN.3__VIA6.EN.14__VIA6.EN.15 { @ Enclosure by M6 [at least two opposite sides] >= ^VIA6_EN_2 um OR [all sides] >= ^VIA6_EN_3 OR [all side] >= ^VIA6_EN_14 / [at least two opposite sides] >= ^VIA6_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA6 M6i ABUT < 90 SINGULAR GOOD 0 VIA6_EN_2 OPPOSITE 0 VIA6_EN_2 OPPOSITE GOOD VIA6_EN_14 VIA6_EN_15 OPPOSITE VIA6_EN_14 VIA6_EN_15 OPPOSITE
  ENC X M6i < VIA6_EN_3 ABUT < 90 SINGULAR REGION
}


// VIA6.EN.4,	Rectangular VIAx enclosure by M1 or Mx is defined by either {VIAx.EN.5/VIAx.EN.7} or {VIAx.EN.6/VIAx.EN.8} or VIAx.EN.3
// VIA6.EN.4 is checked by either {VIA6.EN.5/VIA6.EN.7} or VIA6.EN.3

VIA6.EN.3__VIA6.EN.5__VIA6.EN.6__VIA6.EN.7 { @ Enclosure by M6 [two opposite direction >= ^VIA6_EN_7 and all side >= ^VIA6_EN_5], OR Enclosure by M6 [at rectangular VIA6 end direction] >= ^VIA6_EN_6, OR Enclosure by M6 [all sides] >= ^VIA6_EN_3    
  A = RECTANGLE ENCLOSURE REC_VIA6 M6i ABUT < 90 SINGULAR GOOD VIA6_EN_5 VIA6_EN_7 OPPOSITE VIA6_EN_5 VIA6_EN_7 OPPOSITE GOOD VIA6_EN_3 VIA6_EN_3 VIA6_EN_3 VIA6_EN_3
  B = LENGTH A == VIA6_W_1
  C = ENC [B] M6i < VIA6_EN_6 ABUT < 90 OPPOSITE
  A WITH EDGE C

}
// VIA6.EN.3, VIA6.EN.5, VIA6.EN.6 and VIA6.EN.7 are checked by VIA6.EN.3__VIA6.EN.5__VIA6.EN.6__VIA6.EN.7
// VIA6.EN.8 is checked by VIA6.EN.1

M6_W_55 = M6 WITH WIDTH == VIA6_EN_9_W 
M6_W_70 = M6 WITH WIDTH > VIA6_EN_9_W <= VIA6_EN_10_W 
M6_W_160 = M6 WITH WIDTH > VIA6_EN_10_W <=VIA6_EN_11W
M6_W_450 = M6 WITH WIDTH > VIA6_EN_11W <=VIA6_EN_12W

//'VIAx.EN.9' is checked by VIA6.EN.9
VIA6.EN.9 { @ Enclosure by Mx [0.055 um >= metal width > 0.05 um, space < 0.06 um (D1) and the other side space >= 0.06 um (D1'), parallel run length > 0.1 um] >= 0.005 
  A0 = M6_W_55 INTERACT VIA6i 
  A = EXT A0 [M6] < VIA6_EN_9_S1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A M6 < VIA6_EN_9_S1 ABUT < 90 OPPOSITE REGION
  C = EXT A M6 < VIA6_EN_9_S1 ABUT < 90 OPPOSITE
  D = EXT A [M6] < VIA6_EN_9_S1 ABUT < 90 OPPOSITE
  E0 = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
  [-= EC(C) ] > VIA6_EN_9_L
  E1 = E0 NOT WITH EDGE (ANGLE M6 >0 < 90) 
  E = E0 NOT (E1 NOT ENCLOSE RECTANGLE VIA6_EN_9_L+GRID GRID ORTHOGONAL ONLY)  
  F = D COIN OUTSIDE EDGE E
  G = (EXPAND EDGE F INSIDE BY VIA6_EN_9_W) INTERACT E != 2  
  H = F COIN INSIDE EDGE G 
  ENC VIA6i H < VIA6_EN_9 ABUT < 90 OPPOSITE REGION
}
//'VIAx.EN.10' is checked by VIA6.EN.10
VIA6.EN.10 { @ Enclosure by Mx [0.07 um >= metal width > 0.055 um, space < 0.065 um (D1) and parallel run length > 0.1 um] >= 0.005 
  W = EXT M6_W_70 [M6] < VIA6_EN_10_S ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M6i] < VIA6_EN_10_S ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M6i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M6i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA6_EN_10_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA6_EN_10_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA6i S7_H < VIA6_EN_10 ABUT < 90 OPPOSITE REGION
  ENC VIA6i S7_V < VIA6_EN_10 ABUT < 90 OPPOSITE REGION

}
//'VIAx.EN.11' is checked by VIA6.EN.11
VIA6.EN.11 { @ Enclosure by Mx [0.16 um >= metal width > 0.07 um, space < 0.1 um (D1) and parallel run length > 0.1 um] (For VIAx.EN.11, the rule check is not included same VIAx group, which is defined as below). 1. VIAx space <= 0.11 um2. Mx is same net 3. Mx+1 is same net >= 0.01 
  VIA6_M = SIZE VIA6i BY VIA6_EN_11_S/2 INSIDE OF SAME_NET_VIA6 STEP M6_S_1*0.6
  VIA6_C = VIA6i NOT INTERACT (VIA6_M INTERACT VIA6i >= 2)
  W = EXT M6_W_160 [M6] < VIA6_EN_11D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M6i] < VIA6_EN_11D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M6i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M6i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA6_EN_11L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA6_EN_11L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA6_C S7_H < VIA6_EN_11 ABUT < 90 OPPOSITE REGION
  ENC VIA6_C S7_V < VIA6_EN_11 ABUT < 90 OPPOSITE REGION

}
VIA6.EN.12 { @ Enclosure by M1 or Mx [4.5 um >= metal width > 0.16 um, space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M6_W_450 [M6] < VIA6_EN_12D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M6i] < VIA6_EN_12D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M6i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M6i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M6i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > VIA6_EN_12L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > VIA6_EN_12L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA6i S7_H < VIA6_EN_12 ABUT < 90 OPPOSITE REGION
  ENC VIA6i S7_V < VIA6_EN_12 ABUT < 90 OPPOSITE REGION

}
// 'VIAx.EN.13' is checked by VIA6.EN.13
VIA6.EN.13 { @ VIAx bar enclosure by M1/Mx in LOWMEDN >= 0.1 
  ENC P_RING_VIA6 M6 < VIA6_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}

// VIA6.L.1 is checked by VIA6.W.1
// VIA6.L.2 is checked by VIA6.W.1

// VIA6.R.0 is checked by VIA6.W.1
// VIA6.R.1 is checked by [VIA6.R.2 ~ VIA6.R.6]

//'VIAx.R.2' is checked by VIA6.R.2__VIA6.R.3
//'VIAx.R.3' is checked by VIA6.R.2__VIA6.R.3
VIA6.R.2__VIA6.R.3 { @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S1) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W1) > 0.18 um]. (Except VIA bar region) 1. at least one rectangular VIAx, or 2. at least 2 square VIAx with space <= 0.1 um (S1), or 3. at least 4 square VIAx with space <= 0.65 um (S1')   
                     @ Redundant via requirement must be obeyed by one of following conditions of VIAx numbers and space (S2) for Mx and Mx+1 connection. [One of Mx or Mx+1 has width and length (W2) > 0.44 um]. Please refer to VIAx.R.3 table behind. (Except VIA bar region)   
   MupOvpMdn_W3  = (M6Wide_R3_VIA6 AND M7i) OR (M7Wide_R3_VIA6 AND M6i)
   MupOvpMdn_R3  = MupOvpMdn_W3 NOT OUTSIDE VIA6_EXD
   Checked_Vx_R3 = VIA6_EXD NOT OUTSIDE MupOvpMdn_W3

   MupOvpMdn_W2      = (M6Wide_R2_VIA6 AND M7i) OR (M7Wide_R2_VIA6 AND M6i)
   MupOvpMdn_R2_pre  = MupOvpMdn_W2 NOT OUTSIDE VIA6_EXD
   MupOvpMdn_R2      = MupOvpMdn_R2_pre NOT MupOvpMdn_R3
   Checked_Vx_R2 = (VIA6_EXD NOT OUTSIDE MupOvpMdn_W2) NOT Checked_Vx_R3
   
   Mdn_effect = M6i INTERACT MupOvpMdn_R2_pre
   Mup_effect = M7i INTERACT MupOvpMdn_R2_pre
   effect_MupOvpMdn_ = Mdn_effect AND Mup_effect
   
   effect_MupOvpMdn_R = SIZE MupOvpMdn_R2_pre BY (VIA6_W_1+VIA6_R_3_S2)*8+GRID
   effect_MupOvpMdn = effect_MupOvpMdn_ AND effect_MupOvpMdn_R
   effect_VIA = VIA6_EXD INTERACT effect_MupOvpMdn

   VxMerged_A = SIZE effect_VIA BY VIA6_R_2_S1/2              INSIDE OF effect_MupOvpMdn STEP M6_S_1*0.7
   VxMerged_B = SIZE VxMerged_A BY (VIA6_R_2_S2 - VIA6_R_2_S1)/2 INSIDE OF effect_MupOvpMdn STEP M6_S_1*0.7
   effect_MupOvpMdn_R3 = effect_MupOvpMdn INTERACT MupOvpMdn_R3
   VxMerged_A_R3 = VxMerged_A INTERACT effect_MupOvpMdn_R3 
   VxMerged_D = SIZE VxMerged_A_R3 BY (VIA6_R_3_S3 - VIA6_R_2_S1)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M6_S_1*0.7
   VxMerged_C = SIZE VxMerged_D    BY (VIA6_R_3_S2 - VIA6_R_3_S3)/2 INSIDE OF effect_MupOvpMdn_R3 STEP M6_S_1*0.7
   
// Pass VIAx.R.2 (2 eff. square Via)
   G1_A2R = VxMerged_A INTERACT SQR_VIA6 >=2
   G2_A2R = VxMerged_A INTERACT REC_VIA6 >=1
   VxMerged_A2 = G1_A2R OR G2_A2R
// Pass VIAx.R.2 (4 eff. square Via)
   G1_B4R =  VxMerged_B INTERACT SQR_VIA6 >=4
   G2_B4R = (VxMerged_B INTERACT SQR_VIA6 >=2 <=3) AND (VxMerged_B INTERACT REC_VIA6 ==1)
   G3_B4R =  VxMerged_B INTERACT REC_VIA6 >=2
   VxMerged_B4 = (G1_B4R OR G2_B4R) OR G3_B4R

// Pass VIAx.R.3 (4 eff. square + slot Via)
   G1_A4_13 =  VxMerged_D INTERACT REC_VIA6 >=2
   G2_A4_13 = (VxMerged_D INTERACT REC_VIA6 ==1) AND (VxMerged_D INTERACT SQR_VIA6 >=2)
   VxMerged_A4_13 = G1_A4_13 OR G2_A4_13
// Pass VIAx.R.3 (4 eff. square Via only)
   G1_A4_10 = VxMerged_A INTERACT SQR_VIA6 >=4   
   VxMerged_A4 = VxMerged_A4_13 OR G1_A4_10

// Pass VIAx.R.3 (9 eff. square Via)
   G1_C9 =  VxMerged_C INTERACT SQR_VIA6 >=9
   G2_C9 = (VxMerged_C INTERACT SQR_VIA6 >=7 <=8) AND (VxMerged_C INTERACT REC_VIA6 >=1)
   G3_C9 = (VxMerged_C INTERACT SQR_VIA6 >=5 <=6) AND (VxMerged_C INTERACT REC_VIA6 >=2)
   G4_C9 = (VxMerged_C INTERACT SQR_VIA6 >=3 <=4) AND (VxMerged_C INTERACT REC_VIA6 >=3)
   G5_C9 = (VxMerged_C INTERACT SQR_VIA6 >=1 <=2) AND (VxMerged_C INTERACT REC_VIA6 >=4)
   G6_C9 =  VxMerged_C INTERACT REC_VIA6 >=5
   VxMerged_C9 = ((G1_C9 OR G2_C9) OR (G3_C9 OR G4_C9)) OR (G5_C9 OR G6_C9) 

   Checked_Vx_R2 OUTSIDE (MupOvpMdn_R2 INTERACT (VxMerged_A2 OR VxMerged_B4))
   Checked_Vx_R3 OUTSIDE (MupOvpMdn_R3 INTERACT (VxMerged_A4 OR VxMerged_C9))
}

VIA6.R.4:M6 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA6_R_4_L um (L) and width > ^VIA6_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M6Wide_R4_VIA6 BY VIA6_R_4_D + GRID) NOT M6Wide_R4_VIA6) AND M6
  Branch1HasVia = (Branch1 INTERACT M6Wide_R4_VIA6) INTERACT VIA6_EXD
  Branch1Edge = M6Wide_R4_VIA6 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA6_R_4_D INSIDE OF Branch1HasVia STEP M6_S_1*0.4
  GoodBranch = ((Branch AND M7) INTERACT VIA6i > 1) OR ((Branch AND M7) INTERACT (REC_VIA6 OR P_RING_VIA6))
  BranchSingleVia = (VIA6i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M7 INTERACT BranchSingleVia) AND M6) INTERACT BranchSingleVia) INTERACT VIA6i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


VIA6.R.4:M7 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 1.65 um (D) away from a metal plate (either Mx or Mx+1) with length > ^VIA6_R_4_L um (L) and width > ^VIA6_R_4_W um (W). (Except VIA bar region)
  Branch1 = ((SIZE M7Wide_R4_VIA6 BY VIA6_R_4_D + GRID) NOT M7Wide_R4_VIA6) AND M7
  Branch1HasVia = (Branch1 INTERACT M7Wide_R4_VIA6) INTERACT VIA6_EXD
  Branch1Edge = M7Wide_R4_VIA6 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA6_R_4_D INSIDE OF Branch1HasVia STEP M7_S_1*0.4
  GoodBranch = ((Branch AND M6) INTERACT VIA6i > 1) OR ((Branch AND M6) INTERACT (REC_VIA6 OR P_RING_VIA6))
  BranchSingleVia = (VIA6i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M6 INTERACT BranchSingleVia) AND M7) INTERACT BranchSingleVia) INTERACT VIA6i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


// VIA6.R.4 is checked by VIA6.R.4:M6 and VIA6.R.4:M7
// VIA6.R.5 is checked by VIA6.R.5:M6 and VIA6.R.5:M7
// VIA6.R.6 is checked by VIA6.R.6:M6 and VIA6.R.6:M7

//'VIAy.R.13' is not necessary to check
//'VIAr.R.13' is not necessary to check


VIA6.R.5:M6 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M6Wide_R5_VIA6 BY VIA6_R_5_D + GRID) NOT M6Wide_R5_VIA6) AND M6
  Branch1HasVia = (Branch1 INTERACT M6Wide_R5_VIA6) INTERACT VIA6_EXD
  Branch1Edge = M6Wide_R5_VIA6 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA6_R_5_D INSIDE OF Branch1HasVia STEP M6_S_1*0.6
  GoodBranch = ((Branch AND M7) INTERACT VIA6i > 1) OR ((Branch AND M7) INTERACT (REC_VIA6 OR P_RING_VIA6))
  BranchSingleVia = (VIA6i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M7 INTERACT BranchSingleVia) AND M6) INTERACT BranchSingleVia) INTERACT VIA6i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
VIA6.R.5:M7 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 4 um (D) away from a metal plate (either Mx or Mx+1) with length > 1 um (L) and width > 1 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M7Wide_R5_VIA6 BY VIA6_R_5_D + GRID) NOT M7Wide_R5_VIA6) AND M7
  Branch1HasVia = (Branch1 INTERACT M7Wide_R5_VIA6) INTERACT VIA6_EXD
  Branch1Edge = M7Wide_R5_VIA6 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA6_R_5_D INSIDE OF Branch1HasVia STEP M7_S_1*0.6
  GoodBranch = ((Branch AND M6) INTERACT VIA6i > 1) OR ((Branch AND M6) INTERACT (REC_VIA6 OR P_RING_VIA6))
  BranchSingleVia = (VIA6i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M6 INTERACT BranchSingleVia) AND M7) INTERACT BranchSingleVia) INTERACT VIA6i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}


M6Big_R6_VIA6 = ENCLOSE RECTANGLE M6Wide_R6_VIA6 VIA6_R_6_W VIA6_R_6_L+GRID
M7Big_R6_VIA6 = ENCLOSE RECTANGLE M7Wide_R6_VIA6 VIA6_R_6_W VIA6_R_6_L+GRID

VIA6.R.6:M6 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M6Big_R6_VIA6 BY VIA6_R_6_D + GRID) NOT M6Big_R6_VIA6) AND M6
  Branch1HasVia = (Branch1 INTERACT M6Big_R6_VIA6) INTERACT VIA6_EXD
  Branch1Edge = M6Big_R6_VIA6 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA6_R_6_D INSIDE OF Branch1HasVia STEP M6_S_1*0.6
  GoodBranch = ((Branch AND M7) INTERACT VIA6i > 1) OR ((Branch AND M7) INTERACT (REC_VIA6 OR P_RING_VIA6))
  BranchSingleVia = (VIA6i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M7 INTERACT BranchSingleVia) AND M6) INTERACT BranchSingleVia) INTERACT VIA6i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}

VIA6.R.6:M7 { @ At least 2 square VIAx or one rectangular VIAx must be used for a connection that distance <= 10 um (D) away from a metal plate (either Mx or Mx+1) with length > 5 um (L) and width > 1.5 um (W). (Except VIA bar region)   
  Branch1 = ((SIZE M7Big_R6_VIA6 BY VIA6_R_6_D + GRID) NOT M7Big_R6_VIA6) AND M7
  Branch1HasVia = (Branch1 INTERACT M7Big_R6_VIA6) INTERACT VIA6_EXD
  Branch1Edge = M7Big_R6_VIA6 COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA6_R_6_D INSIDE OF Branch1HasVia STEP M7_S_1*0.6
  GoodBranch = ((Branch AND M6) INTERACT VIA6i > 1) OR ((Branch AND M6) INTERACT (REC_VIA6 OR P_RING_VIA6))
  BranchSingleVia = (VIA6i NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M6 INTERACT BranchSingleVia) AND M7) INTERACT BranchSingleVia) INTERACT VIA6i == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}
// VIA6.R.7 is checked by VIA6.EN.1

VIA6.R.8 { @ Single VIAx is not allowed for H-shape Mx+1 when all of the following conditions come into existence: 1. The Mx+1 has H-shape interact with two metal holes: two metal hole length(L2) <= ^VIA6_R_8_L1 um and both two metal hole area <= ^VIA6_R_8_A um2 2. The VIAx overlaps on the center metal bar of this H-shape Mx+1 3. The length (L) of the center metal bar <= ^VIA6_R_8_L2 um and the width of metal bar is <= ^VIA6_R_8_W um.
  W = M7i WITH WIDTH <= VIA6_R_8_W   
  H_HOLE = (HOLES M7i INNER <= VIA6_R_8_A) INTERACT W
  A0 = M7i INTERACT H_HOLE
  A = A0 COIN OUTSIDE EDGE H_HOLE
  B0 = ((INT A <= VIA6_R_8_W ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) INTERACT H_HOLE == 2 
  B1 = (((INT A <= VIA6_R_8_L2 ABUT<90 OPPOSITE REGION EXCLUDE SHIELDED 4) INSIDE A0) AND W) INTERACT H_HOLE == 2
  HOLE_NOTCH = EXT H_HOLE <= VIA6_R_8_W ABUT<90 OPPOSITE NOTCH REGION  
  B2 = (B1 NOT HOLE_NOTCH) OR B0
  CORNER_M = ((EXT B2 <= VIA6_R_8_W ABUT == 90 INTERSECTING ONLY REGION EXTENTS) TOUCH B2 == 2) AND W
  B = B2 OR CORNER_M
  CENTER_BAR1 = NOT ENCLOSE RECTANGLE B GRID VIA6_R_8_L2+GRID
  CENTER_BAR2 = (CENTER_BAR1 INTERACT H_HOLE == 2) INTERACT VIA6i
  C = CENTER_BAR2 COIN OUTSIDE EDGE H_HOLE 
  D = EXT [C] A <= VIA6_R_8_L1 OPPOSITE
  E = C NOT COIN INSIDE EDGE D
  CENTER_BAR3 = CENTER_BAR2 NOT WITH EDGE E
  CHECK_VIA = VIA6i NOT OUTSIDE CENTER_BAR3
  CHECK_VIA AND (((A0 INTERACT CHECK_VIA) AND (M6i INTERACT CHECK_VIA)) INTERACT VIA6i == 1)
}





#IFDEF CHECK_VIRTUAL_VIAx

//VIAx_VIRT.R.1 is checked by related rules (VIA6 rules)
//'VIAx_VIRT.R.2' is checked by VIA6_VIRT.R.2
VIA6_VIRT.R.2 {@ VIAx_VIRT must be 0.05 um x 0.05 um   
   NOT RECTANGLE VIA6_VIRT == VIA6_W_1 BY == VIA6_W_1 ORTHOGONAL ONLY 
}
//'VIAx_VIRT.R.3' is checked by VIA6_VIRT.R.3
VIA6_VIRT.R.3 {@ VIAx_VIRT interact VIAx is not allowed   
   VIA6_VIRT INTERACT VIA6ii
}
//'VIAx_VIRT.R.4' is checked by VIA6_VIRT.R.4
VIA6_VIRT.R.4 {@ VIAx _VIRT must be fully covered by ROM (50;6)   
   VIA6_VIRT NOT ROM
}
#ENDIF




//M7 CHECKS
//=========
M7_EDGE_45 = M7 ANGLE == 45

M7.W.1 { @ Width >= 0.05 
  INT M7 < M7_W_1 ABUT < 90 SINGULAR REGION
}
M7.W.2 { @ Width of 45-degree bent Mx. (Please make sure the vertex of 45-degree pattern is on 0.005 um grid (refer to the guideline, G.6gU, in section XXX)) >= 0.17 
  INT M7_EDGE_45 < M7_W_2 ABUT < 90 REGION
}


// 'Mx.W.3' is checked by M7.W.3
M7.W.3 { @ Maximum width Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING, or 4. {{INDDMY OR INDDMY_MD} SIZING 16 um}, or 5. CSRDMY, or 6. PADDMY (255;16) <= 4.5 
  M7_MAX_WIDTH WITH WIDTH > M7_W_3
}



 

M7.W.4 { @ Length of the edge with adjacent edge < 0.05 um [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex-270 degree inner vertex; DRC doesn't flag if there is Mx within the area formed by 0.16 um extension from these 2 edges and the 90 degree outer vertex.] (This check doesn't include the region covered by MetalFuse (156;2)) >= 0.065 
  E1 = CONVEX EDGE M7 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH < M7_W_4_L1
  E2 = CONVEX EDGE M7 ANGLE1 == 90 ANGLE2 == 270 WITH LENGTH >= M7_W_4_L1 < M7_W_4_L2
  A = INT [E1]    < M7_W_4_L2 ABUT == 90 INTERSECTING ONLY
  B = INT [E2] E1 < M7_W_4_L2 ABUT == 90 INTERSECTING ONLY
  C = INT [E1] E2 < M7_W_4_L2 ABUT == 90 INTERSECTING ONLY
  D = OR EDGE  B (OR EDGE A C)
  CORNER_BAD_pre = (EXPAND EDGE D INSIDE BY 0.001) NOT INSIDE MFUSE
  W = EXT [D] M7 < 0.16
  CORNER_BAD_pre NOT WITH EDGE W
}
M7.S.1 { @ Space >= 0.05 
  EXT M7 < M7_S_1 ABUT < 90 SINGULAR REGION
}

M7.S.2 { @ Space [at least one metal line width > 0.09 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.06 
  X = EXT M7_20 M7 < M7_S_2 OPPOSITE REGION MEASURE ALL
  Y = X NOT M7
  ENCLOSE RECTANGLE Y GRID M7_S_2_L+GRID
}
M7.S.3 { @ Space [at least one metal line width > 0.16 um (W2) and the parallel run length > 0.22 um (L2)] >= 0.1 
  X = EXT M7_21 M7 < M7_S_3 OPPOSITE REGION MEASURE ALL
  Y = X NOT M7
  ENCLOSE RECTANGLE Y GRID M7_S_3_L+GRID
}
M7.S.4 { @ Space [at least one metal line width > 0.47 um (W3) and the parallel run length > 0.47 um (L3)] >= 0.13 
  X = EXT M7_22 M7 < M7_S_4 OPPOSITE REGION MEASURE ALL
  Y = X NOT M7
  ENCLOSE RECTANGLE Y GRID M7_S_4_L+GRID
}
M7.S.5 { @ Space [at least one metal line width > 0.63 um (W4) and the parallel run length > 0.63 um (L4)] >= 0.15 
  X = EXT M7_23 M7 < M7_S_5 OPPOSITE REGION MEASURE ALL
  Y = X NOT M7
  ENCLOSE RECTANGLE Y GRID M7_S_5_L+GRID
}
M7.S.6 { @ Space [at least one metal line width > 1.5 um (W5) and the parallel run length > 1.5 um (L5)] >= 0.5 
  X = EXT M7_30 M7 < M7_S_6 OPPOSITE REGION MEASURE ALL
  Y = X NOT M7
  ENCLOSE RECTANGLE Y 0.001 M7_S_6_L+0.001
}


M7.S.7 { @ Space to Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.07 
  A = CONVEX EDGE M7 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M7_S_7_W
  EXT A M7 < M7_S_7 ABUT < 90 OPPOSITE EXTENDED M7_S_7_T REGION
}

M7.S.8 { @ Mx line space (S1) to dense Mx line-end [parallel run length > -0.025 um (T)], and dense Mx line-end enclosure of Vx-1 (V). Definition of dense Mx line-end: 1. Mx line-end: Mx edge with length < 0.07 um (W) between 2 outer vertex. 2. Other metal INTERACT Region 1. Region 1 = (T+Q) x S2. (W+S2) < 0.115 um. This check doesn't include small jog with edge length < 0.05 um (R) >= 0.08/0.05 or 0.1/0.03 
  M7_END = CONVEX EDGE M7 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M7_S_8_W
  M7_REGION = EXPAND EDGE M7_END OUTSIDE BY M7_S_8_SB + GRID EXTEND BY M7_S_8_T + GRID  // for data reduction
  M7_LINE = (M7 INSIDE EDGE M7_REGION) NOT TOUCH EDGE M7_END
  M7_EA = ENC VIA6i [M7_END] < M7_S_8_EA ABUT < 90 OPPOSITE
  M7_EB = ENC VIA6i [M7_END] < M7_S_8_EB ABUT < 90 OPPOSITE
  M7_SA = EXT [M7_END] M7_LINE < M7_S_8_SA ABUT < 90 OPPOSITE EXTENDED M7_S_8_T
  M7_SB = EXT [M7_END] M7_LINE < M7_S_8_SB ABUT < 90 OPPOSITE EXTENDED M7_S_8_T
  M7_PASS_A = (M7_END NOT TOUCH INSIDE EDGE M7_EA) NOT TOUCH INSIDE EDGE M7_SA
  M7_PASS_B = (M7_END NOT TOUCH INSIDE EDGE M7_EB) NOT TOUCH INSIDE EDGE M7_SB
  M7_CHECK = (M7_END NOT TOUCH INSIDE EDGE M7_PASS_A) NOT TOUCH INSIDE EDGE M7_PASS_B

  M7_Long_side = LENGTH M7 >= M7_W_1
  O = INT M7_CHECK [M7_Long_side] < M7_S_8_Q-M7_S_8_T ABUT == 90 INTERSECTING ONLY  
  PW = INT O M7 < (M7_S_8_P - M7_S_1) ABUT < 90 OPPOSITE EXTENDED M7_S_8_T
  PS = EXT O M7 < (M7_S_8_P - M7_W_1) ABUT < 90 OPPOSITE EXTENDED M7_S_8_T
  Q = DFM PROPERTY O PS PW OVERLAP ABUT ALSO MULTI
  [-= MIN(EW(PW)) + MIN(EW(PS))] < M7_S_8_P
  R = M7_CHECK TOUCH EDGE (EXPAND EDGE Q INSIDE BY 0.001)
  ENC VIA6i R < M7_S_8_EA ABUT < 90 OPPOSITE REGION
  EXT R M7 < M7_S_8_SB ABUT < 90 OPPOSITE EXTENDED M7_S_8_T REGION
}


M7.S.9 { @ Space to 45-degree bent Mx >= 0.17 
  X = EXPAND EDGE M7_EDGE_45 OUTSIDE BY M7_S_9
  X AND M7
}


M7_HVN_65V = NET AREA RATIO M7i OVER M9_HV_65V M8_HV_65V M7_HV_65V M6_HV_65V M5_HV_65V M4_HV_65V M3_HV_65V M2_HV_65V M1_HV_65V PO_HV_65V NW_HV_65V DNW_HV_65V > 0
M7_HVN_5V = NET AREA RATIO M7i OVER M9_HV_5V M8_HV_5V M7_HV_5V M6_HV_5V M5_HV_5V M4_HV_5V M3_HV_5V M2_HV_5V M1_HV_5V > 0
M7_HVN = NET AREA RATIO M7i OVER M9_HV M8_HV M7_HV M6_HV M5_HV M4_HV M3_HV M2_HV M1_HV > 0
M7_MVN = NET AREA RATIO M7i OVER M9_MV M8_MV M7_MV M6_MV M5_MV M4_MV M3_MV M2_MV M1_MV > 0
M7_MLVN = NET AREA RATIO M7i OVER M9_MLV M8_MLV M7_MLV M6_MLV M5_MLV M4_MLV M3_MLV M2_MLV M1_MLV > 0
M7_LVN = NET AREA RATIO M7i OVER M9_LV M8_LV M7_LV M6_LV M5_LV M4_LV M3_LV M2_LV M1_LV > 0
M7_VNVN_pre = NET AREA RATIO M7i OVER M9_VNV M8_VNV M7_VNV M6_VNV M5_VNV M4_VNV M3_VNV M2_VNV M1_VNV > 0
M7_NVN = NET AREA RATIO M7i OVER M9_NV M8_NV M7_NV M6_NV M5_NV M4_NV M3_NV M2_NV M1_NV > 0
M7_VNVN = M7_VNVN_pre NOT M7_NVN
M7_NOMARK = (((((((M7i NOT M7_HVN_65V) NOT M7_HVN_5V) NOT M7_HVN) NOT M7_MVN) NOT M7_MLVN) NOT M7_LVN) NOT M7_NVN) NOT M7_VNVN



#IFDEF USE_IO_VOLTAGE_ON_CORE_TO_IO_NET
  M7_NOMARK_65V = NET AREA RATIO M7_NOMARK PSD_65 NSD_65 PSTPix > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSTPix)]
  M7_NOMARK_5V = NET AREA RATIO M7_NOMARK PSD_50 NSD_50 PSTPix > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)]
  M7_NOMARK_HV = NET AREA RATIO M7_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)]
  M7_NOMARK_MV = NET AREA RATIO M7_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)]
  M7_NOMARK_MLV = NET AREA RATIO M7_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)]
  M7_NOMARK_LV = NET AREA RATIO M7_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]  



#ELSE
  M7_NOMARK_65V = NET AREA RATIO M7_NOMARK PSD_65 NSD_65 PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_65)+!!AREA(NSD_65))*!AREA(PSD_50)*!AREA(NSD_50)*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M7_NOMARK_5V = NET AREA RATIO M7_NOMARK PSD_50 NSD_50 PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_50)+!!AREA(NSD_50))*!AREA(PSTPix)*!AREA(PSD_33_33)*!AREA(NSD_33_33)*!AREA(GATE_33_33)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)] 
  M7_NOMARK_HV = NET AREA RATIO M7_NOMARK PSD_33_33 NSD_33_33 GATE_33_33 PSTPix PSD_18_25 NSD_18_25 GATE_18_25 PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_33_33)+!!AREA(NSD_33_33)+!!AREA(GATE_33_33))*!AREA(PSTPix)*!AREA(PSD_18_25)*!AREA(NSD_18_25)*!AREA(GATE_18_25)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M7_NOMARK_MV = NET AREA RATIO M7_NOMARK PSD_18_25 NSD_18_25 GATE_18_25 PSTPix PSD_13_17 NSD_13_17 GATE_13_17 PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_18_25)+!!AREA(NSD_18_25)+!!AREA(GATE_18_25))*!AREA(PSTPix)*!AREA(PSD_13_17)*!AREA(NSD_13_17)*!AREA(GATE_13_17)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M7_NOMARK_MLV = NET AREA RATIO M7_NOMARK PSD_13_17 NSD_13_17 GATE_13_17 PSTPix PSD_00_12 NSD_00_12 GATE_00_12 > 0
    [(!!AREA(PSD_13_17)+!!AREA(NSD_13_17)+!!AREA(GATE_13_17))*!AREA(PSTPix)*!AREA(PSD_00_12)*!AREA(NSD_00_12)*!AREA(GATE_00_12)]
  M7_NOMARK_LV = NET AREA RATIO M7_NOMARK PSD_00_12 NSD_00_12 GATE_00_12 PSTPix > 0
    [(!!AREA(PSD_00_12)+!!AREA(NSD_00_12)+!!AREA(GATE_00_12))*!AREA(PSTPix)]


#ENDIF

M7_HV_65V_ALL = M7_HVN_65V OR M7_NOMARK_65V
M7_HV_5V_ALL = M7_HVN_5V OR M7_NOMARK_5V
M7_HV_ALL = M7_HVN OR M7_NOMARK_HV
M7_MV_ALL = M7_MVN OR M7_NOMARK_MV
M7_MLV_ALL = M7_MLVN OR M7_NOMARK_MLV
M7_LV_ALL = M7_LVN OR M7_NOMARK_LV
M7_NV_ALL = COPY M7_NVN
M7_VNV_ALL = COPY M7_VNVN

M7_VNV_CHK = STAMP M7_VNV_ALL BY M7i
VIA7_VNV_CHK = STAMP (VIA7i AND M7_VNV_ALL) BY M7i
M7_NV_CHK = STAMP M7_NV_ALL BY M7i
VIA7_NV_CHK = STAMP (VIA7i AND M7_NV_ALL) BY M7i  
M7_LV_CHK = STAMP M7_LV_ALL BY M7i
VIA7_LV_CHK = STAMP (VIA7i AND M7_LV_ALL) BY M7i
M7_MLV_CHK = STAMP M7_MLV_ALL BY M7i
VIA7_MLV_CHK = STAMP (VIA7i AND M7_MLV_ALL) BY M7i
M7_MV_CHK = STAMP M7_MV_ALL BY M7i
VIA7_MV_CHK = STAMP (VIA7i AND M7_MV_ALL) BY M7i

M7_HV_CHK = STAMP M7_HV_ALL BY M7i
VIA7_HV_CHK = STAMP (VIA7i AND M7_HV_ALL) BY M7i
M7_HV_5V_CHK = STAMP M7_HV_5V_ALL BY M7i
VIA7_HV_5V_CHK = STAMP (VIA7i AND M7_HV_5V_ALL) BY M7i
M7_HV_65V_CHK = STAMP M7_HV_65V_ALL BY M7i
VIA7_HV_65V_CHK = STAMP (VIA7i AND M7_HV_65V_ALL) BY M7i























M7.S.12 { @ Space of Mx line-end [parallel run length > -0.025 um (T)] . Definition of "Mx line-end": Mx edge with length < 0.07 um (W) between 2 outer vertex >= 0.08 
  A = CONVEX EDGE M7 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < M7_S_12_W
  EXT A < M7_S_12 ABUT < 90 OPPOSITE EXTENDED M7_S_12_T REGION
}

M7.S.13 { @ Space [at least one metal line width > 0.13 um (W1) and the parallel run length > 0.22 um (L1)] >= 0.08 
  X = EXT M7_201 M7 < M7_S_13 OPPOSITE REGION MEASURE ALL
  Y = X NOT M7
  ENCLOSE RECTANGLE Y GRID M7_S_13_L+GRID
}


// M7.EN.0,enclosure of square VIAx-1 is defined by either {Mx.EN.1/Mx.EN.2} or Mx.EN.3
// M7.EN.0 is checked by either {M7.EN.1/M7.EN.2} or M7.EN.3

M7.EN.1 { @ Enclosure of square VIAx-1 >= 0 
  VIA6i NOT M7i
}
M7.EN.2__M7.EN.3__M7.EN.14__M7.EN.15 { @ Enclosure of VIA6 [at least two opposite sides] >= ^M7_EN_2 um OR [all sides] >= ^M7_EN_3 OR [all side] >= ^M7_EN_14 / [at least two opposite sides] >= ^M7_EN_15
  X = RECTANGLE ENCLOSURE SQR_VIA6 M7i ABUT < 90 SINGULAR GOOD 0 M7_EN_2 OPPOSITE 0 M7_EN_2 OPPOSITE GOOD M7_EN_14 M7_EN_15 OPPOSITE M7_EN_14 M7_EN_15 OPPOSITE
  ENC X M7i < M7_EN_3 ABUT < 90 SINGULAR REGION
}

// M7.EN.4, Enclosure of rectangular VIAx-1 is defined by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3
// M7.EN.4 is checked by either {Mx.EN.5/Mx.EN.7} or {Mx.EN.6/Mx.EN.8} or Mx.EN.3

M7.EN.3__M7.EN.5__M7.EN.6__M7.EN.7 { @ Enclosure of rectangular VIA6 [two opposite side >= ^M7_EN_7 and all side >= ^M7_EN_5], OR Enclosure of rectangular VIA6 [at rectangular VIA6 end direction] >= ^M7_EN_6, OR Enclosure of rectangular VIA6 [all sides] >= ^M7_EN_3
  A = RECTANGLE ENCLOSURE REC_VIA6 M7i ABUT < 90 SINGULAR GOOD M7_EN_5 M7_EN_7 OPPOSITE M7_EN_5 M7_EN_7 OPPOSITE GOOD M7_EN_3 M7_EN_3 M7_EN_3 M7_EN_3
  B = LENGTH A == VIA6_W_1
  C = ENC [B] M7i < M7_EN_6 ABUT < 90 OPPOSITE
  A WITH EDGE C
}

// M7.EN.3, M7.EN.5, M7.EN.6 and M7.EN.7 are checked by M7.EN.3__M7.EN.5__M7.EN.6__M7.EN.7
// M7.EN.8 is checked by M7.EN.1

M7_W_55b = M7 WITH WIDTH == M7_EN_9_W 
M7_W_70b = M7 WITH WIDTH > M7_EN_9_W <= M7_EN_10_W 
M7_W_160b = M7 WITH WIDTH > M7_EN_10_W <=M7_EN_11W
M7_W_450b = M7 WITH WIDTH > M7_EN_11W <=M7_EN_12W

M7.EN.9 { @ Enclosure of VIAx-1 [0.055 um >= metal width > 0.05 um, metal space < 0.06 um (D1) and the other side space >= 0.06 um (D1'), parallel run length > 0.1 um] >= 0.005 
  A0 = M7_W_55b INTERACT VIA6i 
  A = EXT A0 [M7] < M7_EN_9_S1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A M7 < M7_EN_9_S1 ABUT < 90 OPPOSITE REGION
  C = EXT A M7 < M7_EN_9_S1 ABUT < 90 OPPOSITE
  D = EXT A [M7] < M7_EN_9_S1 ABUT < 90 OPPOSITE
  E0 = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
  [-= EC(C) ] > M7_EN_9_L
  E1 = E0 NOT WITH EDGE (ANGLE M7 >0 < 90) 
  E = E0 NOT (E1 NOT ENCLOSE RECTANGLE M7_EN_9_L+GRID GRID ORTHOGONAL ONLY)  
  F = D COIN OUTSIDE EDGE E
  G = (EXPAND EDGE F INSIDE BY M7_EN_9_W) INTERACT E != 2  
  H = F COIN INSIDE EDGE G 
  ENC VIA6i H < M7_EN_9 ABUT < 90 OPPOSITE REGION
}
M7.EN.10 { @ Enclosure of VIAx-1 [0.07 um >= metal width > 0.055 um, metal space < 0.065 um (D1) and parallel run length > 0.1 um] >= 0.005 
  W = EXT M7_W_70b [M7] < M7_EN_10_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M7i] < M7_EN_10_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M7i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M7i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M7_EN_10_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M7_EN_10_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA6i S7_H < M7_EN_10 ABUT < 90 OPPOSITE REGION
  ENC VIA6i S7_V < M7_EN_10 ABUT < 90 OPPOSITE REGION

}
M7.EN.11 { @ Enclosure of VIAx-1 [0.16 um >= metal width > 0.07 um, metal space < 0.1 um (D1) and parallel run length > 0.1 um] (For Mx.EN.11, the rule check is not included same VIAx group, which is defined as below.) 1. VIAx space <= 0.11 um2. Mx is same net 3. Mx+1 is same net >= 0.01 
  VIA6_M = SIZE VIA6i BY M7_EN_11_S/2 INSIDE OF SAME_NET_VIA6 STEP M6_S_1*0.6
  VIA6_C = VIA6i NOT INTERACT (VIA6_M INTERACT VIA6i >= 2)
  W = EXT M7_W_160b [M7] < M7_EN_11_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M7i] < M7_EN_11_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M7i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M7i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M7_EN_11_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M7_EN_11_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA6_C S7_H < M7_EN_11 ABUT < 90 OPPOSITE REGION
  ENC VIA6_C S7_V < M7_EN_11 ABUT < 90 OPPOSITE REGION

}
// 'Mx.EN.12' is checked by M7.EN.12
M7.EN.12 { @ Enclosure of VIAx-1 [4.5 um >= metal width > 0.16 um, metal space < 0.13 um and parallel run length > 0.1 um] >= 0.015 
  W = EXT M7_W_450b [M7] < M7_EN_12_D1 ABUT < 90 OPPOSITE MEASURE ALL
  S = EXT W [M7i] < M7_EN_12_D1 ABUT < 90 OPPOSITE
  S1_H = ANGLE S == 0
  S1_V = ANGLE S == 90
  S2_V = INT S1_H [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_V = EXT S1_H [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_V = (M7i TOUCH INSIDE EDGE S2_V) TOUCH INSIDE EDGE S3_V
  S2_H = INT S1_V [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S3_H = EXT S1_V [M7i] < GRID ABUT == 90 INTERSECTING ONLY
  S4_H = (M7i TOUCH INSIDE EDGE S2_H) TOUCH INSIDE EDGE S3_H
  S5_H = (EXPAND EDGE S1_H BY GRID) OR (EXPAND EDGE S4_V BY GRID)
  S5_V = (EXPAND EDGE S1_V BY GRID) OR (EXPAND EDGE S4_H BY GRID)
  S6_H = DFM PROPERTY S5_H S1_H OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_H)] > M7_EN_12_L
  S6_V = DFM PROPERTY S5_V S1_V OVERLAP ABUT ALSO MULTI [-= LENGTH(S1_V)] > M7_EN_12_L
  S7_H = S1_H INSIDE EDGE S6_H
  S7_V = S1_V INSIDE EDGE S6_V
  ENC VIA6i S7_H < M7_EN_12 ABUT < 90 OPPOSITE REGION
  ENC VIA6i S7_V < M7_EN_12 ABUT < 90 OPPOSITE REGION

}
// 'Mx.EN.13' is checked by M7.EN.13
M7.EN.13 { @ Enclosure of VIAx-1 bar in LOWMEDN >= 0.1 
  ENC P_RING_VIA6 M7 < M7_EN_13-2*GRID ABUT < 90 SINGULAR REGION
}
// 'Mx.L.1' is checked by M7.L.1
M7.L.1 { @ Length of 45-degree bent Mx (minimum edge length) >= 0.5 
  (LENGTH M7_EDGE_45 < M7_L_1) NOT INSIDE EDGE SEALRING_ALL
}

M7.A.1 { @ Area (except M2) >= 0.017 
  AREA M7 < M7_A_1
}
//'Mx.A.1' is checked by M7.A.1
M7.A.3 { @ Area [with all of edge lengths < 0.13 um] (Except M2 inside SRAMDMY;0) (This check doesn't include the patterns filling 0.05 um x 0.13 um rectangular tile) >= 0.044 
  A = AREA M7 < M7_A_3
  B = LENGTH A >= M7_A_3_L1
  C = A NOT WITH EDGE B
  NOT ENCLOSE RECTANGLE C M7_A_3_W M7_A_3_L2 ORTHOGONAL ONLY
}

VARIABLE M7_A_4pre ((M7_A_4 + (M7_S_1 * M7_S_1 * 3.142))/(2 * M7_S_1))*((M7_A_4 + (M7_S_1 * M7_S_1 * 3.142))/(2 * M7_S_1))/3.141 // user value

M7.A.4 { @ Enclosed area >= 0.2 
  X = HOLES M7 INNER < M7_A_4pre
  AREA ( X NOT M7 ) < M7_A_4
}

//'DMx_O.R.1' is checked by DM7_O.R.1
DM7_O.R.1 { @ DMx_O INTERACT Mx is not allowed. [Mx, and My only]   
  DM7_O INTERACT M7i
}






// 'Mx.DN.0.1' is checked by related rules




//'My.DN.0' is not necessary to check
//'My.DN.1' is not necessary to check
//'My.DN.2' is not necessary to check
//'My.DN.3' is not necessary to check

//'Mr.DN.0' is not necessary to check
//'Mr.DN.1' is not necessary to check
//'Mr.DN.2' is not necessary to check
//'Mr.DN.3' is not necessary to check



//'Mx.DN.1' is checked by M7.DN.1
#IFDEF CHECK_LOW_DENSITY
M7.DN.1 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum metal density in window 125 um x 125 um, stepping 62.5*20% um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10%+3% 
#ELSE
@ Minimum metal density in window 125 um x 125 um, stepping 62.5 um (Except ICOVL) (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) >= 10% 
#ENDIF
  EXC_LOW = M7_EXC_LOW OR ICOVL
  N = M7x NOT EXC_LOW
  D = CHIP NOT EXC_LOW 
  A = CHIP_M7 NOT EXC_LOW
  X = DENSITY A M7x CHIP N D < M7_DN_1 WINDOW M7_DN_1_W STEP M7_DN_1_S BACKUP INSIDE OF LAYER CHIP_M7 PRINT M7.DN.1.density RDB M7.DN.1.RDB.density
          [~(AREA(A)-M7_DN_1_E)*!!(AREA(A)-M7_DN_1_E)+AREA(N)/AREA(D)+!~(AREA(M7x)/AREA(CHIP)-M7_DN_1)+!(AREA(M7x)/AREA(CHIP)-M7_DN_1)]


  COPY X    
}
#ENDIF



//'Mx.DN.2' is checked by M7.DN.2
M7.DN.2 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum metal density in window 125 um x 125 um, stepping 62.5*20% um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85%-3% 
#ELSE
@ Maximum metal density in window 125 um x 125 um, stepping 62.5 um (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area) Except following condition: 1. Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or 2. Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or 3. SEALRING_ALL, or 4. {INDDMY OR INDDMY_MD}, or 5. ICOVL <= 85% 
#ENDIF
  EXC_HIGH = M7_EXC_HIGH OR ICOVL
  N = M7x NOT EXC_HIGH
  D = CHIP NOT EXC_HIGH 
  A = CHIPx NOT EXC_HIGH
  X = DENSITY A M7x CHIP N D > M7_DN_2 WINDOW M7_DN_2_W STEP M7_DN_2_S BACKUP INSIDE OF LAYER CHIPx PRINT M7.DN.2.density RDB M7.DN.2.RDB.density
          [~(M7_DN_2_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M7x)/AREA(CHIP)-M7_DN_2)]


  COPY X    
}

//'Mx.DN.3' is checked by M7.DN.3
M7.DN.3 { @ The metal density difference between any 2 neighboring checking windows including DMxEXCL [window 200 um x 200 um, stepping 200 um]. Anticipate metal density gradient from layout of small cell by targeting density ~50% (this way, it will limit the risk of low density and of high gradient).(Except ICOVL) <= 50% 
   EXCEPT =  COPY ICOVL
   M7x_Chk = M7x NOT EXCEPT
   DENSITY M7x_Chk EXCEPT CHIP <=1 WINDOW M7_DN_3_W BACKUP GRADIENT > M7_DN_3 ABSOLUTE CORNER INSIDE OF LAYER CHIPx PRINT M7.DN.3.density RDB M7.DN.3.RDB.density
    [ (AREA(M7x_Chk)+AREA(EXCEPT)*M7_DN_3_V)/AREA(CHIP) ] 
}

M7_CORE = M7x NOT SRCSR_P4
//'Mx.DN.4' is checked by Mx.DN.4:M5_M6_M7 
Mx.DN.4:M5_M6_M7 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ It is not allowed to have local density > 85% of all 3 consecutive metal (Mx, Mx+1 and Mx+2) over any window 62.5 um x 62.5 um (stepping 31.25*20% um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density > 85%+3%. 1. The metal layers include M1/Mx and dummy metals. 2. Except following condition: (1). Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or (2). Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or (3). SEALRING_ALL, or (4) Chip corner triangle empty areas
#ELSE
@ It is not allowed to have local density > 85% of all 3 consecutive metal (Mx, Mx+1 and Mx+2) over any window 62.5 um x 62.5 um (stepping 31.25 um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density > 85%. 1. The metal layers include M1/Mx and dummy metals. 2. Except following condition: (1). Mtop-1 for Fully-Stacking pad metal ({{{CB2_WB OR CB} NOT WBDMY} SIZING 5 um}), or (2). Mtop-1 for CUP pad metal ({{{WBDMY AND {CB2_WB OR CB}} SIZING 5 um} OR WBDMY}) (but Mtop-1 for 'Mx+Mu' metal combinations will be checked), or (3). SEALRING_ALL, or (4) Chip corner triangle empty areas   
#ENDIF
 DENSITY  M5_CORE M6_CORE M7_CORE >0 WINDOW M5_DN_4_W STEP M5_DN_4_S BACKUP INSIDE OF LAYER CHIPx 
      [ !~(AREA(M5_CORE)/AREA()- M5_DN_4)*!~(AREA(M6_CORE)/AREA()- M5_DN_4)*!~(AREA(M7_CORE)/AREA()- M5_DN_4) ]
      RDB Mx.DN.4:M5_M6_M7.density
}


#IFDEF CHECK_LOW_DENSITY
M7.DN.6 { @ Metal Density >= ^M7_DN_6 must be followed for item(A) to (C)
@ (A) Metal density [checking window ^M7_DN_6_W_A um x ^M7_DN_6_W_A um, stepping ^M7_DN_6_S_A um] >= ^M7_DN_6
@ (B) Maximum area of merged low density windows [checking window ^M7_DN_6_W_BC um x ^M7_DN_6_W_BC um, stepping ^M7_DN_6_S_BC um, density < ^M7_DN_6] <= ^M7_DN_6_A_B um2. Merged low density windows width <= ^M7_DN_6_U um is except.
@ (C) Maximum area of merged low density windows [checking window ^M7_DN_6_W_BC um x ^M7_DN_6_W_BC um, stepping ^M7_DN_6_S_BC um, density < ^M7_DN_6] <= ^M7_DN_6_A_C um2
@ 1. The following special regions are excluded
@    Chip corner triangle empty areas if sealring is added by tsmc. 
@    LOWMEDN
@ 2. This rule is applied while the width of (checking window NOT above excluding region) >= ^M7_DN_6_E_A um for (A) and >= ^M7_DN_6_E_BC um for both (B)/(C) 
  M7_CHECK = M7x NOT (NEW_DEN_EXC OR ICOVL)
  CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
  // Condition-A
  ERR_WIN_A = DENSITY M7_CHECK CHIP_CHECK < M7_DN_6 WINDOW M7_DN_6_W_A STEP M7_DN_6_S_A INSIDE OF LAYER CHIP_M7 BACKUP 
	[ AREA(M7_CHECK)/AREA(CHIP_CHECK) ]
  F_A = WITH WIDTH (ERR_WIN_A NOT (NEW_DEN_EXC OR ICOVL)) >= M7_DN_6_E_A
  DENSITY F_A M7_CHECK CHIP_CHECK < M7_DN_6 WINDOW M7_DN_6_W_A STEP M7_DN_6_S_A INSIDE OF LAYER CHIP_M7 BACKUP PRINT M7.DN.6_A.density
         [ !AREA(F_A)+AREA(M7_CHECK)/AREA(CHIP_CHECK) ]
  // Condition-B 
  ERR_WIN_B = DENSITY M7_CHECK CHIP_CHECK < M7_DN_6 WINDOW M7_DN_6_W_BC STEP M7_DN_6_S_BC INSIDE OF LAYER CHIP_M7 BACKUP 
	[ AREA(M7_CHECK)/AREA(CHIP_CHECK) ]
  F_B = WITH WIDTH (ERR_WIN_B NOT (NEW_DEN_EXC OR ICOVL)) >= M7_DN_6_E_BC
  A = DENSITY F_B M7_CHECK CHIP_CHECK < M7_DN_6 WINDOW M7_DN_6_W_BC STEP M7_DN_6_S_BC INSIDE OF LAYER CHIP_M7 BACKUP PRINT M7.DN.6_BC.density
         [ !AREA(F_B)+AREA(M7_CHECK)/AREA(CHIP_CHECK) ]
  B = AREA A > M7_DN_6_A_B
  C = SIZE B BY M7_DN_6_U/2 UNDEROVER
  B INTERACT C
  // Condition-C
  AREA B > M7_DN_6_A_C
}
#ENDIF

#IFDEF CHECK_LOW_DENSITY
//'Mx.DN.7' is checked by Mx.DN.7:M5_M6_M7
Mx.DN.7:M5_M6_M7 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ It is not allowed to have local density < 5% of all 3 consecutive metal (Mx, Mx+1, and Mx+2) over any 30 um x 30 um (stepping 15*20% um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density >= 5+3%. 1. The metal layers include M1/Mx and dummy metals for ELK film. 2. The following special regions are excluded while the density checking: - Chip corner triangle empty areas if seal-ring is added by tsmc. - LOWMEDN, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area)    
#ELSE
@ It is not allowed to have local density < 5% of all 3 consecutive metal (Mx, Mx+1, and Mx+2) over any 30 um x 30 um (stepping 15 um), i.e. it is allowed for either one of Mx, Mx+1, or Mx+2 to have a local density >= 5%. 1. The metal layers include M1/Mx and dummy metals for ELK film. 2. The following special regions are excluded while the density checking: - Chip corner triangle empty areas if seal-ring is added by tsmc. - LOWMEDN, ICOVL (This rule only apply while the area of {checking window NOT exclusive region} >= 1/2 window area)   
#ENDIF
   M5_CHECK = M5x NOT (NEW_DEN_EXC OR ICOVL)
   M6_CHECK = M6x NOT (NEW_DEN_EXC OR ICOVL)
   M7_CHECK = M7x NOT (NEW_DEN_EXC OR ICOVL)
   CHIP_CHECK = CHIP NOT (NEW_DEN_EXC OR ICOVL)
   DENSITY M5_CHECK M6_CHECK M7_CHECK CHIP_CHECK >0 WINDOW M5_DN_7_W STEP M5_DN_7_S BACKUP INSIDE OF LAYER CHIP_M7
   [ ~(M5_DN_7_E-AREA(CHIP_CHECK))*!~(M5_DN_7-(AREA(M5_CHECK)/AREA(CHIP_CHECK)))*!~(M5_DN_7-(AREA(M6_CHECK)/AREA(CHIP_CHECK)))*!~(M5_DN_7-(AREA(M7_CHECK)/AREA(CHIP_CHECK))) ]
   RDB Mx.DN.7:M5_M6_M7.density
}
#ENDIF






#IFDEF CHECK_VIRTUAL_CO
//'CO_VIRT.R.5' is checked by CO_VIRT.R.5:CO
CO_VIRT.R.5:CO {@ Only one layer of virtual CO/VIAx is allowed in one chip   
	(CHIP INTERACT VIA1_VIRT) INTERACT CO_VIRT

	    (CHIP INTERACT VIA1_VIRT) INTERACT VIA2_VIRT

	    (CHIP INTERACT VIA1_VIRT) INTERACT VIA3_VIRT

	    (CHIP INTERACT VIA1_VIRT) INTERACT VIA4_VIRT

	    (CHIP INTERACT VIA1_VIRT) INTERACT VIA5_VIRT

	    (CHIP INTERACT VIA1_VIRT) INTERACT VIA6_VIRT





	(CHIP INTERACT VIA2_VIRT) INTERACT CO_VIRT


	    (CHIP INTERACT VIA2_VIRT) INTERACT VIA3_VIRT

	    (CHIP INTERACT VIA2_VIRT) INTERACT VIA4_VIRT

	    (CHIP INTERACT VIA2_VIRT) INTERACT VIA5_VIRT

	    (CHIP INTERACT VIA2_VIRT) INTERACT VIA6_VIRT





	(CHIP INTERACT VIA3_VIRT) INTERACT CO_VIRT



	    (CHIP INTERACT VIA3_VIRT) INTERACT VIA4_VIRT

	    (CHIP INTERACT VIA3_VIRT) INTERACT VIA5_VIRT

	    (CHIP INTERACT VIA3_VIRT) INTERACT VIA6_VIRT





	(CHIP INTERACT VIA4_VIRT) INTERACT CO_VIRT




	    (CHIP INTERACT VIA4_VIRT) INTERACT VIA5_VIRT

	    (CHIP INTERACT VIA4_VIRT) INTERACT VIA6_VIRT





	(CHIP INTERACT VIA5_VIRT) INTERACT CO_VIRT





	    (CHIP INTERACT VIA5_VIRT) INTERACT VIA6_VIRT





	(CHIP INTERACT VIA6_VIRT) INTERACT CO_VIRT










}
#ENDIF
#IFDEF CHECK_VIRTUAL_VIAx
//'CO_VIRT.R.5' is checked by CO_VIRT.R.5:VIAx
CO_VIRT.R.5:VIAx {@ Only one layer of virtual CO/VIAx is allowed in one chip   
	(CHIP INTERACT VIA1_VIRT) INTERACT CO_VIRT

	    (CHIP INTERACT VIA1_VIRT) INTERACT VIA2_VIRT

	    (CHIP INTERACT VIA1_VIRT) INTERACT VIA3_VIRT

	    (CHIP INTERACT VIA1_VIRT) INTERACT VIA4_VIRT

	    (CHIP INTERACT VIA1_VIRT) INTERACT VIA5_VIRT

	    (CHIP INTERACT VIA1_VIRT) INTERACT VIA6_VIRT





	(CHIP INTERACT VIA2_VIRT) INTERACT CO_VIRT


	    (CHIP INTERACT VIA2_VIRT) INTERACT VIA3_VIRT

	    (CHIP INTERACT VIA2_VIRT) INTERACT VIA4_VIRT

	    (CHIP INTERACT VIA2_VIRT) INTERACT VIA5_VIRT

	    (CHIP INTERACT VIA2_VIRT) INTERACT VIA6_VIRT





	(CHIP INTERACT VIA3_VIRT) INTERACT CO_VIRT



	    (CHIP INTERACT VIA3_VIRT) INTERACT VIA4_VIRT

	    (CHIP INTERACT VIA3_VIRT) INTERACT VIA5_VIRT

	    (CHIP INTERACT VIA3_VIRT) INTERACT VIA6_VIRT





	(CHIP INTERACT VIA4_VIRT) INTERACT CO_VIRT




	    (CHIP INTERACT VIA4_VIRT) INTERACT VIA5_VIRT

	    (CHIP INTERACT VIA4_VIRT) INTERACT VIA6_VIRT





	(CHIP INTERACT VIA5_VIRT) INTERACT CO_VIRT





	    (CHIP INTERACT VIA5_VIRT) INTERACT VIA6_VIRT





	(CHIP INTERACT VIA6_VIRT) INTERACT CO_VIRT










}
#ENDIF

//VIA7 CHECKS
//===========

VIA7.W.1 { @ Width (maximum = minimum) = 0.36 
  NOT RECTANGLE VIA7_EXD == VIA7_W_1 BY == VIA7_W_1 ORTHOGONAL ONLY
}
VIA7.S.1 { @ Space >= 0.34 
  EXT VIA7 < VIA7_S_1 ABUT < 90 SINGULAR REGION
}
VIA7.S.2 { @ Space to 3-neighboring VIAz (distance < 0.56 um) >= 0.54 
  X = WITH NEIGHBOR VIA7 > 2 SPACE < VIA7_S_2_S
  EXT X VIA7 < VIA7_S_2 ABUT < 90 SINGULAR REGION
}

// 'VIAz.EN.1.a' is checked by VIA7.EN.1.a
VIA7.EN.1.a { @ Enclosure by Mx, My, or Mz (Except the lowermost VIAz inside TFR) >= 0.02 
  X = (VIA7_EXD NOT INSIDE TFR) NOT CBM8i 
  ENC X M7 < VIA7_EN_1 ABUT < 90 SINGULAR REGION
  ((VIA7 NOT INSIDE TFR) NOT M7) NOT CBM8i 
}

// 'VIAz.EN.2.a' is checked by VIA7.EN.2.a
VIA7.EN.2.a { @ Enclosure by Mx, My, or Mz [at least 2 opposite sides] (Except the lowermost VIAz inside TFR) >= 0.08 
  A = (VIA7_EXD NOT INSIDE TFR) NOT CBM8i 
  X = RECTANGLE ENCLOSURE A M7 ABUT < 90 SINGULAR GOOD VIA7_EN_1 VIA7_EN_2 OPPOSITE VIA7_EN_1 VIA7_EN_2 OPPOSITE
  Y = ENC [X] M7 < VIA7_EN_2 ABUT < 90 OPPOSITE
  Z = X TOUCH EDGE Y
  INT Z < VIA7_W_1 ABUT == 90 INTERSECTING ONLY REGION   // adjacent narrow sides
}

//'VIAz.R.1' is checked by VIA7.W.1

M8Wide_1.8_VIA7T = M8 WITH WIDTH > VIA7_R_2_W
M7Wide_1.8_VIA7T = M7 WITH WIDTH > VIA7_R_2_W
M8Wide_3_VIA7T = M8Wide_1.8_VIA7T WITH WIDTH > VIA7_R_3_W
M7Wide_3_VIA7T =  M7Wide_1.8_VIA7T WITH WIDTH > VIA7_R_3_W

VIA7.R.2.a { @ At least 2 VIAz with spacing <= 1.7 um are required to connect Mz and Mz+1 when one of these metals has a width and length > 1.8 um or (2) TFR and the lowermost Mz   
   MupOvpMdn_W = (((M7Wide_1.8_VIA7T AND M8i) OR (M8Wide_1.8_VIA7T AND M7i)) OR (TFR AND M8i)) NOT OUTSIDE VIA7_EXD
   Mdn_effect = M7i INTERACT MupOvpMdn_W
   Mup_effect = M8i INTERACT MupOvpMdn_W
   TFR_effect = TFR INTERACT MupOvpMdn_W
   effect_MupOvpMdn_ = (Mdn_effect AND Mup_effect) OR (TFR_effect AND Mup_effect)
   effect_MupOvpMdn_R = SIZE MupOvpMdn_W BY VIA7_R_2_S+VIA7_W_1+GRID
   effect_MupOvpMdn = effect_MupOvpMdn_ AND effect_MupOvpMdn_R
   effect_VIA = VIA7_EXD INTERACT effect_MupOvpMdn
   VIAxMerged = SIZE effect_VIA BY VIA7_R_2_S/2 INSIDE OF effect_MupOvpMdn STEP M7_S_1*0.7
   VIAxMerged2 = VIAxMerged INTERACT effect_VIA >=2
   Checked_VIA = effect_VIA NOT OUTSIDE MupOvpMdn_W
   GVIA = Checked_VIA INTERACT VIAxMerged2
   Checked_VIA OUTSIDE (MupOvpMdn_W INTERACT GVIA)
} 


M7Big_3_VIA7T = ENCLOSE RECTANGLE M7Wide_3_VIA7T VIA7_R_3_W VIA7_R_3_L+GRID
M8Big_3_VIA7T = ENCLOSE RECTANGLE M8Wide_3_VIA7T VIA7_R_3_W VIA7_R_3_L+GRID

VIA7.R.3.a:M7 { @ At least 2 VIAz must be used for a connection that distance <= 5 um (D) away from a metal plate (either Mz or Mz+1) with length > 10 um (L) and width > 3 um (W). (Except the lowermost VIAz inside TFR)   
  Branch1 = ((SIZE M7Big_3_VIA7T BY VIA7_R_3_D + GRID) NOT M7Big_3_VIA7T) AND M7
  Branch1HasVia = (Branch1 INTERACT M7Big_3_VIA7T) INTERACT VIA7
  Branch1Edge = M7Big_3_VIA7T COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA7_R_3_D INSIDE OF Branch1HasVia STEP 0.026
  GoodBranch = (Branch AND M8) INTERACT VIA7 > 1
  BranchSingleVia = (VIA7 NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M8 INTERACT BranchSingleVia) AND M7) INTERACT BranchSingleVia) INTERACT VIA7 == 1
  ((BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD) NOT INSIDE TFR
}
VIA7.R.3.a:M8 { @ At least 2 VIAz must be used for a connection that distance <= 5 um (D) away from a metal plate (either Mz or Mz+1) with length > 10 um (L) and width > 3 um (W). (Except the lowermost VIAz inside TFR)   
  Branch1 = ((SIZE M8Big_3_VIA7T BY VIA7_R_3_D + GRID) NOT M8Big_3_VIA7T) AND M8
  Branch1HasVia = (Branch1 INTERACT M8Big_3_VIA7T) INTERACT VIA7
  Branch1Edge = M8Big_3_VIA7T COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA7_R_3_D INSIDE OF Branch1HasVia STEP 0.026
  GoodBranch = (Branch AND M7) INTERACT VIA7 > 1
  BranchSingleVia = (VIA7 NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M7 INTERACT BranchSingleVia) AND M8) INTERACT BranchSingleVia) INTERACT VIA7 == 1
  ((BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD) NOT INSIDE TFR
}

// VIA7.R.3.a is checked by VIA7.R.3.a:M7 and VIA7.R.3.a:M8
//'VIAz.R.4' is checked by VIA7.EN.1.a

//'VIAy.R.13' is not necessary to check
//'VIAr.R.13' is not necessary to check


//M8 CHECKS
//=============

M8Wide_1.5 =  M8 WITH WIDTH > M8_S_2_W
M8Wide_4.5 =  M8Wide_1.5 WITH WIDTH > M8_S_3_W

M81 = COPY M8Wide_1.5
M82 = COPY M8Wide_4.5

M8HO = HOLES M8 INNER
M8HOC = M8HO NOT M8


M8.W.1 { @ Width >= 0.4 
  INT M8 < M8_W_1 ABUT < 90 SINGULAR REGION
}
M8.W.2 { @ Maximum width [except bond pad, {INDDMY SIZING 22 um}] <= 12 
  M8_MAX_WIDTH WITH WIDTH > M8_W_2
}

M8.S.1 { @ Space >= 0.4 
  EXT M8 < M8_S_1 ABUT < 90 SINGULAR REGION
}
M8.S.2 { @ Space [at least one metal line width > 1.5 um (W1) and the parallel run length > 1.5 um (L1)] >= 0.5 
  X = EXT M81 M8 < M8_S_2 OPPOSITE REGION MEASURE ALL
  Y = X NOT M8
  ENCLOSE RECTANGLE Y 0.001 M8_S_2_L+0.001
}
M8.S.3 { @ Space [at least one metal line width > 4.5 um (W2) and the parallel run length > 4.5 um (L2)] >= 1.5 
  X = EXT M82 M8 < M8_S_3 OPPOSITE REGION MEASURE ALL
  Y = X NOT M8
  (ENCLOSE RECTANGLE Y 0.001 M8_S_3_L+0.001) NOT INSIDE IND_REGION
}
M8.EN.1 { @ Enclosure of VIAz-1 >= 0.02 
  ENC VIA7_EXD M8 < M8_EN_1 ABUT < 90 SINGULAR REGION
  VIA7 NOT M8
}
M8.EN.2 { @ Enclosure of VIAz-1 [at least 2 opposite sides] >= 0.08 
  X = RECTANGLE ENCLOSURE VIA7 M8 ABUT < 90 SINGULAR GOOD M8_EN_1 M8_EN_2 OPPOSITE M8_EN_1 M8_EN_2 OPPOSITE
  Y = ENC [X] M8 < M8_EN_2 ABUT < 90 OPPOSITE
  Z = X TOUCH EDGE Y
  INT Z < VIA7_W_1 ABUT == 90 INTERSECTING ONLY REGION   // adjacent narrow sides
}
M8.A.1 { @ Area >= 0.565 
  AREA M8 < M8_A_1
}
M8.A.2 { @ Enclosed area >= 0.565 
  AREA M8HOC < M8_A_2
}







// 'Mz.DN.0' is checked by related rules

//'Mz.DN.1' is checked by M8.DN.1
#IFDEF CHECK_LOW_DENSITY
M8.DN.1 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum metal density in window 125 um x 125 um, stepping 62.5*20% um >= 20%+3% 
#ELSE
@ Minimum metal density in window 125 um x 125 um, stepping 62.5 um >= 20% 
#ENDIF
  N = M8x NOT M8_EXC_LOW
  D = CHIP NOT M8_EXC_LOW 
  EXC_M = COPY M8_EXC_LOW
  A = CHIP_M8 NOT M8_EXC_LOW
  B = CHIP_M8 NOT (SIZE EXC_M BY M8_DN_1_E/2-0.001)
  ERR_WIN = DENSITY A B M8x CHIP N D < M8_DN_1 WINDOW M8_DN_1_W STEP M8_DN_1_S BACKUP INSIDE OF LAYER CHIP_M8 
          [!AREA(B)+~(AREA(A)-M8_DN_1_E*M8_DN_1_E)*!!(AREA(A)-M8_DN_1_E*M8_DN_1_E)+AREA(N)/AREA(D)+!~(AREA(M8x)/AREA(CHIP)-M8_DN_1)+!(AREA(M8x)/AREA(CHIP)-M8_DN_1)]
  F = PUSH (WITH WIDTH (ERR_WIN NOT EXC_M) >= M8_DN_1_E)
  X = DENSITY A B F M8x CHIP N D < M8_DN_1 WINDOW M8_DN_1_W STEP M8_DN_1_S BACKUP INSIDE OF LAYER CHIP_M8 PRINT M8.DN.1.density RDB M8.DN.1.RDB.density
          [!AREA(F)+!AREA(B)+~(AREA(A)-M8_DN_1_E*M8_DN_1_E)*!!(AREA(A)-M8_DN_1_E*M8_DN_1_E)+AREA(N)/AREA(D)+!~(AREA(M8x)/AREA(CHIP)-M8_DN_1)+!(AREA(M8x)/AREA(CHIP)-M8_DN_1)]



  COPY X    
}
#ENDIF






//'Mz.DN.2' is checked by M8.DN.2
M8.DN.2 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum metal density in window 125 um x 125 um, stepping 62.5*20% um. (This check doesn't include bond pad.) <= 85%-3% 
#ELSE
@ Maximum metal density in window 125 um x 125 um, stepping 62.5 um. (This check doesn't include bond pad.) <= 85% 
#ENDIF
  N = M8x NOT M8_EXC_HIGH
  D = CHIP NOT M8_EXC_HIGH 
  EXC_M = COPY M8_EXC_HIGH
  A = CHIPx NOT M8_EXC_HIGH
  B = CHIPx NOT (SIZE EXC_M BY M8_DN_2_E/2-0.001)
  ERR_WIN = DENSITY A B M8x CHIP N D > M8_DN_2 WINDOW M8_DN_2_W STEP M8_DN_2_S BACKUP INSIDE OF LAYER CHIPx 
          [!!AREA(B)*~(M8_DN_2_E*M8_DN_2_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M8x)/AREA(CHIP)-M8_DN_2)]
  F = PUSH (WITH WIDTH (ERR_WIN NOT EXC_M) >= M8_DN_2_E)
  X = DENSITY A B F M8x CHIP N D > M8_DN_2 WINDOW M8_DN_2_W STEP M8_DN_2_S BACKUP INSIDE OF LAYER CHIPx PRINT M8.DN.2.density RDB M8.DN.2.RDB.density
          [!!AREA(F)*!!AREA(B)*~(M8_DN_2_E*M8_DN_2_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M8x)/AREA(CHIP)-M8_DN_2)]



  COPY X      
}


//'Mz.DN.3' is checked by M8.DN.3
M8.DN.3 { @ The metal density difference between any 2 neighboring checking windows including DMxEXCL [window 200 um x 200 um, stepping 200 um] Anticipate metal density gradient from layout of small cell by targeting density ~50% (this way, it will limit the risk of low density and of high gradient.) <= 50% 
  DENSITY M8x CHIP <=1 WINDOW M8_DN_3_W BACKUP GRADIENT > M8_DN_3 ABSOLUTE CORNER INSIDE OF LAYER CHIPx PRINT M8.DN.3.density
    [ AREA(M8x)/AREA(CHIP) ]      
}




//VIA8 CHECKS
//===========

//'VIAu.W.1' is checked by VIA8.W.1
VIA8.W.1 { @ Width (maximum = minimum) = 0.36 
  NOT RECTANGLE VIA8_EXD == VIA8_W_1 BY == VIA8_W_1 ORTHOGONAL ONLY
}
//'VIAu.S.1' is checked by VIA8.S.1
VIA8.S.1 { @ Space >= 0.34 
  EXT VIA8 < VIA8_S_1 ABUT < 90 SINGULAR REGION
}
//'VIAu.S.2' is checked by VIA8.S.2
VIA8.S.2 { @ Space to 3-neighboring VIAu (distance < 0.56 um) >= 0.54 
  X = WITH NEIGHBOR VIA8 > 2 SPACE < VIA8_S_2_S
  EXT X VIA8 < VIA8_S_2 ABUT < 90 SINGULAR REGION
}
//'VIAu.EN.1' is checked by VIA8.EN.1
VIA8.EN.1 { @ Enclosure by Mx, My, or Mz (This check doesn't include SEALRING_ALL (162;2) region) >= 0.08 
  X = VIA8_EXD NOT CBM9i 
  ENC X M8 < VIA8_EN_1 ABUT < 90 SINGULAR REGION
  (VIA8 NOT M8) NOT CBM9i 
}
//'VIAu.R.1' is checked by VIA8.W.1

M9Wide_3_VIA8T = M9 WITH WIDTH > VIA8_R_3_W
M8Wide_3_VIA8T =  M8 WITH WIDTH > VIA8_R_3_W


//'VIAu.R.2' is checked by VIA8.R.2
VIA8.R.2 { @ At least 2 VIAu with space <= 1.7 um are required to connect [Mu to Mz], [Mu to My], or [Mu to Mx] (Please put as many vias as possible for reliability and RF applications)   
   M9OvpM8  = M9 AND M8
   VIA8Merge = SIZE VIA8_EXD BY VIA8_R_2_S /2 INSIDE OF M9OvpM8 STEP M8_S_1*0.7
   VIA8Merge2 = VIA8Merge ENCLOSE VIA8_EXD >= 2
   Good_VIA8 = VIA8_EXD AND VIA8Merge2
   GM9OvpM8 = M9OvpM8 INTERACT Good_VIA8
   VIA8_EXD OUTSIDE GM9OvpM8
}   

M8Big_3_VIA8T = ENCLOSE RECTANGLE M8Wide_3_VIA8T VIA8_R_3_W VIA8_R_3_L+GRID

//'VIAu.R.3' is checked by VIA8.R.3:M8
VIA8.R.3:M8 { @ At least 2 VIAu must be used for a connection that distance <= 5 um (D) away from a metal plate with length > 10 um (L) and width > 3 um (W)   
  Branch1 = ((SIZE M8Big_3_VIA8T BY VIA8_R_3_D + GRID) NOT M8Big_3_VIA8T) AND M8
  Branch1HasVia = (Branch1 INTERACT M8Big_3_VIA8T) INTERACT VIA8
  Branch1Edge = M8Big_3_VIA8T COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA8_R_3_D INSIDE OF Branch1HasVia STEP M8_S_1*0.7
  GoodBranch = (Branch AND M9) INTERACT VIA8 > 1
  BranchSingleVia = (VIA8 NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M9 INTERACT BranchSingleVia) AND M8) INTERACT BranchSingleVia) INTERACT VIA8 == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}

M9Big_3_VIA8T = ENCLOSE RECTANGLE M9Wide_3_VIA8T VIA8_R_3_W VIA8_R_3_L+GRID

//'VIAu.R.3' is checked by VIA8.R.3:M9
VIA8.R.3:M9 { @ At least 2 VIAu must be used for a connection that distance <= 5 um (D) away from a metal plate with length > 10 um (L) and width > 3 um (W)   
  Branch1 = ((SIZE M9Big_3_VIA8T BY VIA8_R_3_D + GRID) NOT M9Big_3_VIA8T) AND M9
  Branch1HasVia = (Branch1 INTERACT M9Big_3_VIA8T) INTERACT VIA8
  Branch1Edge = M9Big_3_VIA8T COIN OUTSIDE EDGE Branch1HasVia
  Branch1Rec = EXPAND EDGE Branch1Edge OUTSIDE BY GRID
  Branch = SIZE Branch1Rec BY VIA8_R_3_D INSIDE OF Branch1HasVia STEP M9_S_1*0.7
  GoodBranch = (Branch AND M8) INTERACT VIA8 > 1
  BranchSingleVia = (VIA8 NOT OUTSIDE Branch) OUTSIDE GoodBranch
  Bad_Region = (((M8 INTERACT BranchSingleVia) AND M9) INTERACT BranchSingleVia) INTERACT VIA8 == 1
  (BranchSingleVia INTERACT Bad_Region) NOT VIA_EXD
}

//'VIAu.R.4' is checked by VIA8.EN.1

//'VIAy.R.13' is not necessary to check
//'VIAr.R.13' is not necessary to check



// Mu CHECKS
//==========
M9Wide_4.5 = M9 WITH WIDTH > M9_S_2_W
//'Mu.W.1' is checked by M9.W.1
M9.W.1 { @ Width >= 2.0 
  INT M9 < M9_W_1 ABUT < 90 SINGULAR REGION
}
//'Mu.W.2' is checked by M9.W.2
M9.W.2 { @ Maximum width [except bond pad] (This check doesn't include the regions covered by layers of {INDDMY SIZING 22 um}, CB, and {UBM INTERACT CBD}.) <= 12.0 
  M9_MAX_WIDTH WITH WIDTH > M9_W_2
}
//'Mu.S.1' is checked by M9.S.1
M9.S.1 { @ Space >= 1.0 
  EXT M9 < M9_S_1 ABUT < 90 SINGULAR REGION	
}
//'Mu.S.2' is checked by M9.S.2
M9.S.2 { @ Space [at least one metal line width > 4.5 um (W1) and the parallel run length > 4.5 um (L1)] >= 1.5 
  X = EXT M9Wide_4.5 M9 < M9_S_2 OPPOSITE REGION MEASURE ALL
  Y = X NOT M9
  (ENCLOSE RECTANGLE Y 0.001 M9_S_2_L+0.001) NOT INSIDE IND_REGION
}


//'Mu.EN.1' is checked by M9.EN.1
M9.EN.1 { @ Enclosure of VIAu >= 0.3 
  ENC VIA8_EXD M9 < M9_EN_1 ABUT < 90 SINGULAR REGION
  VIA8 NOT M9
}
//'Mu.A.1' is checked by M9.A.1
M9.A.1 { @ Area >= 9.0 
  (AREA M9 < M9_A_1) NOT INSIDE IND_REGION
  A = M9 NOT OUTSIDE IND_REGION
  (AREA A < (M9_A_1-M9_R_4)) NOT OUTSIDE IND_REGION
}
//'Mu.A.2' is checked by M9.A.2
M9.A.2 { @ Enclosed area >= 9.0 
  X = (HOLES M9 INNER) NOT M9
  (AREA X < M9_A_2) NOT INSIDE IND_REGION
  A = X NOT OUTSIDE IND_REGION
  (AREA A < (M9_A_2-M9_R_4)) NOT OUTSIDE IND_REGION
}






//'Mu.DN.1' is checked by M9.DN.1
#IFDEF FULL_CHIP
M9.DN.1 { @ Minimum metal density over the whole chip (include INDDMY) >= 20% 
  DENSITY M9x CHIP < M9_DN_1 INSIDE OF LAYER CHIPx [ AREA(M9x)/AREA(CHIP) ] PRINT M9.DN.1.density
}
#ENDIF




//'Mu.DN.2' is checked by M9.DN.2
#IFDEF FULL_CHIP
M9.DN.2 { @ Maximum metal density over the whole chip (include INDDMY) <= 50% 
    DENSITY M9x CHIP > M9_DN_2 INSIDE OF LAYER CHIPx [ AREA(M9x)/AREA(CHIP) ] PRINT M9.DN.2.density
}
#ENDIF

//'Mu.DN.3' is checked by M9.DN.3
#IFDEF CHECK_LOW_DENSITY
M9.DN.3 { @ 
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Minimum Mu density range in window 125 um x 125 um, stepping 62.5*20% um. The following special regions are excluded while the density checking: - Bond pad - Chip corner triangle empty areas if sealring is added by tsmc. - SEALRING_ALL if sealring is added by customer. - LOGO/INDDMY This rule is only applied while the width of (checking window NOT excluded region) >= 1/4 checking window width (31.25 um) >= 20%+3% 
#ELSE
@ Minimum Mu density range in window 125 um x 125 um, stepping 62.5 um. The following special regions are excluded while the density checking: - Bond pad - Chip corner triangle empty areas if sealring is added by tsmc. - SEALRING_ALL if sealring is added by customer. - LOGO/INDDMY This rule is only applied while the width of (checking window NOT excluded region) >= 1/4 checking window width (31.25 um) >= 20% 
#ENDIF
  N = M9x NOT M9_EXC_LOW
  D = CHIP NOT M9_EXC_LOW 
  EXC_M = COPY M9_EXC_LOW
  A = CHIP_M9 NOT M9_EXC_LOW
  B = CHIP_M9 NOT (SIZE EXC_M BY M9_DN_3_E/2-0.001)
  ERR_WIN = DENSITY A B M9x CHIP N D < M9_DN_3 WINDOW M9_DN_3_W STEP M9_DN_3_S BACKUP INSIDE OF LAYER CHIP_M9 
          [!AREA(B)+~(AREA(A)-M9_DN_3_E*M9_DN_3_E)*!!(AREA(A)-M9_DN_3_E*M9_DN_3_E)+AREA(N)/AREA(D)+!~(AREA(M9x)/AREA(CHIP)-M9_DN_3)+!(AREA(M9x)/AREA(CHIP)-M9_DN_3)]
  F = PUSH (WITH WIDTH (ERR_WIN NOT EXC_M) >= M9_DN_3_E)
  X = DENSITY A B F M9x CHIP N D < M9_DN_3 WINDOW M9_DN_3_W STEP M9_DN_3_S BACKUP INSIDE OF LAYER CHIP_M9 PRINT M9.DN.3.density RDB M9.DN.3.RDB.density
          [!AREA(F)+!AREA(B)+~(AREA(A)-M9_DN_3_E*M9_DN_3_E)*!!(AREA(A)-M9_DN_3_E*M9_DN_3_E)+AREA(N)/AREA(D)+!~(AREA(M9x)/AREA(CHIP)-M9_DN_3)+!(AREA(M9x)/AREA(CHIP)-M9_DN_3)]



  COPY X  
}
#ENDIF


//'Mu.DN.4' is checked by M9.DN.4
M9.DN.4 { @
#IFDEF IP_TIGHTEN_DENSITY
@ Note: Switch IP_TIGHTEN_DENSITY is on, stepping and rule value are adjusted
@ Maximum Mu density range in window 125 um x 125 um, stepping 62.5*20% um. The following special regions are excluded while the density checking: - Bond pad - Chip corner triangle empty areas if sealring is added by tsmc. - SEALRING_ALL if sealring is added by customer. - LOGO/INDDMY This rule is only applied while the width of (checking window NOT excluded region) >= 1/4 checking window width (31.25 um) <= 85%-3% 
#ELSE
@ Maximum Mu density range in window 125 um x 125 um, stepping 62.5 um. The following special regions are excluded while the density checking: - Bond pad - Chip corner triangle empty areas if sealring is added by tsmc. - SEALRING_ALL if sealring is added by customer. - LOGO/INDDMY This rule is only applied while the width of (checking window NOT excluded region) >= 1/4 checking window width (31.25 um) <= 85% 
#ENDIF
  N = M9x NOT M9_EXC_HIGH
  D = CHIP NOT M9_EXC_HIGH 
  EXC_M = COPY M9_EXC_HIGH
  A = CHIPx NOT M9_EXC_HIGH
  B = CHIPx NOT (SIZE EXC_M BY M9_DN_4_E/2-0.001)
  ERR_WIN = DENSITY A B M9x CHIP N D > M9_DN_4 WINDOW M9_DN_4_W STEP M9_DN_4_S BACKUP INSIDE OF LAYER CHIPx 
          [!!AREA(B)*~(M9_DN_4_E*M9_DN_4_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M9x)/AREA(CHIP)-M9_DN_4)]
  F = PUSH (WITH WIDTH (ERR_WIN NOT EXC_M) >= M9_DN_4_E)
  X = DENSITY A B F M9x CHIP N D > M9_DN_4 WINDOW M9_DN_4_W STEP M9_DN_4_S BACKUP INSIDE OF LAYER CHIPx PRINT M9.DN.4.density RDB M9.DN.4.RDB.density
          [!!AREA(F)*!!AREA(B)*~(M9_DN_4_E*M9_DN_4_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(M9x)/AREA(CHIP)-M9_DN_4)]



  COPY X    
}



// 'Mu.R.4' is checked by M9.A.1 and M9.A.2.








//IND CHECKS
//============
//'IND.W.1' is checked by IND.W.1:M1
IND.W.1:M1 { @ M1, DM1, and DM1_O width in (INDDMY SIZING 16 um) >= 0.28 
  A = M1x NOT OUTSIDE IND_REGION
