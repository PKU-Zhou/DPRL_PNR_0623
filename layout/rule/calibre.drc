VARIABLE  M1_S_37_A_E 0.080
VARIABLE  M1_S_37_A 0.180
// 'M1.S.37.a' is checked by M1.S.37.a
M1.S.37.a { @ Space of M1 line to line [maximum delta V > 5V] Definition of "M1 line-end": M1 edge with length < 0.08 um (W) between 2 outer vertex. Definition of "M1 line" : M1 edge NOT M1 line-end >= 0.18 
  err_1 = DFM DV DV_M1_LINE  < M1_S_37_A ABUT < 90  NOT CONNECTED  
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > M1_S_37_A_V   ANNOTATE
  err_1_f =  DFM PROPERTY err_1 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_1, "SECOND_VMAX")]
  [ DELTA_V = property(err_1, "DELTA_V")]
  [ SYNC = property(err_1, "SYNC")]  
  DFM COPY err_1_f
  DFM RDB err_1_f "M1.S.37.a.rep" NOEMPTY NOPSEUDO
  err_dmy1 = DFM DV DV_M1_LINE DV_DM1_O_LINE WITH DEFAULT VOLTAGES < M1_S_37_A ABUT < 90  MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" > M1_S_37_A_V   ANNOTATE
  err_dmy1_f =  DFM PROPERTY err_dmy1 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_dmy1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_dmy1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_dmy1, "SECOND_VMIN")]
