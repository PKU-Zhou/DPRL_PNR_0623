SR_M7_OUTER = (SR_M7_P4 NOT SR_M7_INNER) NOT Reinforced_M7

SLDB_M7 = M7 AND SEALRING_DBx                            // Metal7 in SLDB
SLDB_M7_HOLE = (HOLES SLDB_M7) NOT SLDB_M7
SLDB_M7_DOT_EDGE = CONVEX EDGE SLDB_M7_HOLE ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH <= M7_W_6+2*GRID
SLDB_M7_DOT = EXT SLDB_M7_DOT_EDGE <= M7_W_6 OPPOSITE PARALLEL ONLY REGION
SLDB_M7_LINE = (SLDB_M7 NOT SLDB_M7_HOLE) NOT SLDB_M7_DOT    // Metal7 Bar in SLDB

SR_M8_P4 = M8i AND SEALRING_ORI 
SR_M8_INNER = (SR_M8_P4 INSIDE (HOLES SR_M8_P4)) NOT Reinforced_M8
SR_M8_OUTER = (SR_M8_P4 NOT SR_M8_INNER) NOT Reinforced_M8

SLDB_M8 = M8 AND SEALRING_DBx                            // Metal8 in SLDB
SLDB_M8_HOLE = (HOLES SLDB_M8) NOT SLDB_M8
SLDB_M8_DOT_EDGE = CONVEX EDGE SLDB_M8_HOLE ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH <= M8_W_6+2*GRID
SLDB_M8_DOT = EXT SLDB_M8_DOT_EDGE <= M8_W_6 OPPOSITE PARALLEL ONLY REGION
SLDB_M8_LINE = (SLDB_M8 NOT SLDB_M8_HOLE) NOT SLDB_M8_DOT    // Metal8 Bar in SLDB

SR_M9_P4 = M9i AND SEALRING_ORI 
SR_M9_INNER = (SR_M9_P4 INSIDE (HOLES SR_M9_P4)) NOT Reinforced_M9
SR_M9_OUTER = (SR_M9_P4 NOT SR_M9_INNER) NOT Reinforced_M9

