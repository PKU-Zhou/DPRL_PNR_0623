  M1_TypeBRS3_CACB_S3_10 = M1_TypeBRS3_CACB_S3_1 NOT TOUCH EDGE M1_TypeBRS3_CACB_S3_8
  M1_TypeBRS3_CACB_S3_11_1 = EXPAND EDGE M1_TypeBRS3_CACB_S3_9 OUTSIDE BY TypeBRS3_S3
  M1_TypeBRS3_CACB_S3_12_1 = EXPAND EDGE M1_TypeBRS3_CACB_S3_10 OUTSIDE BY TypeBRS3_S3-GRID
  M1_TypeBRS3_CACB_S3_11 = M1_TypeBRS3_CACB_S3_11_1 WITH EDGE ((M1_TypeBRS3_CACB_S3_11_1 AND M1) COIN EDGE M1_TypeBRS3_CACB_S3_11_1) >= 4
  M1_TypeBRS3_CACB_S3_12  = M1_TypeBRS3_CACB_S3_12_1 WITH EDGE ((M1_TypeBRS3_CACB_S3_12_1 AND M1) COIN EDGE M1_TypeBRS3_CACB_S3_12_1) >= 4
  M1_TypeBRS3_CACB_S3_13 = M1_TypeBRS3_CACB_S6_7 OR (M1_TypeBRS3_CACB_S3_11 OR M1_TypeBRS3_CACB_S3_12)
  M1_TypeBRS3_CACB_S3_14 = (M1_TypeBRS3_CACB_S3_13 AND M1i) COIN EDGE M1_TypeBRS3_CACB_S3_13
  M1_TypeBRS3_CACB_S3_15 = ENCLOSE RECTANGLE (M1_TypeBRS3_CACB_S3_13 WITH EDGE M1_TypeBRS3_CACB_S3_14 >= 4) TypeBRS3_S2 2*TypeBRS3_S3
  
