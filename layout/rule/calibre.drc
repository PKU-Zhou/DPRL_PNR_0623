// ICOVL CHECKS
//=============
CHIP_W = ANGLE CHIPx == 0
CHIP_L = ANGLE CHIPx == 90

CHIP_P = DFM PROPERTY CHIPx CHIP_W CHIP_L OVERLAP ABUT ALSO MULTI
[ W = (LENGTH(CHIP_W) / 2000)*0.855 + 2*SEALRING_W ]
[ H = (LENGTH(CHIP_L) / 2000)*0.855 + 2*SEALRING_W ]
[ Rx = FLOOR(( MASK_X - WSx) / (PROPERTY_REF(W) + WSx))]
[ Ry = FLOOR(( MASK_Y - WSy) / (PROPERTY_REF(H) + WSy))]


CHIP_1x1 = DFM PROPERTY CHIP_P [-= PROPERTY(CHIP_P, Rx)] == 1 [-= PROPERTY(CHIP_P, Ry)] == 1
CHIP_1x2 = DFM PROPERTY CHIP_P [-= PROPERTY(CHIP_P, Rx)] == 1 [-= PROPERTY(CHIP_P, Ry)] == 2
CHIP_2x1 = DFM PROPERTY CHIP_P [-= PROPERTY(CHIP_P, Rx)] == 2 [-= PROPERTY(CHIP_P, Ry)] == 1
CHIP_2x2 = DFM PROPERTY CHIP_P [-= PROPERTY(CHIP_P, Rx)] == 2 [-= PROPERTY(CHIP_P, Ry)] == 2
CHIP_1x3 = DFM PROPERTY CHIP_P [-= PROPERTY(CHIP_P, Rx)] == 1 [-= PROPERTY(CHIP_P, Ry)] == 3
CHIP_3x1 = DFM PROPERTY CHIP_P [-= PROPERTY(CHIP_P, Rx)] == 3 [-= PROPERTY(CHIP_P, Ry)] == 1


#IFDEF DBOC
CHIP_AP = COPY EMPTYi  
#ELSE
#IFDEF WITH_APRDL
CHIP_AP = COPY CHIPx
#ELSE
#IFDEF WIRE_BOND
CHIP_AP = COPY EMPTYi  
#ELSE
CHIP_AP = COPY CHIPx
#ENDIF
#ENDIF
#ENDIF

