Reinforced_M4 = ((CSR_M4_P4 NOT SEALRING_ORI) NOT CSR_M4_D) INTERACT CSR_M4_HOLE
CSR_M5_P4 = M5i AND CSRDMY
CSR_2_M5_HOLE = SIZE(SIZE (CSRDMY NOT M5) BY 1.5+4*GRID OVERUNDER) BY 1+4*GRID UNDEROVER
CSR_M5_HOLE = SIZE CSR_2_M5_HOLE BY CSR_W_1B/2 OVERUNDER
CSR_M5_D = M5 INSIDE (CSR_2_M5_HOLE OR CHIP_CORNER_C)
ISO_M5_D = (M5 INSIDE ISOR_P4) NOT CDUDMY
Reinforced_M5 = ((CSR_M5_P4 NOT SEALRING_ORI) NOT CSR_M5_D) INTERACT CSR_M5_HOLE
CSR_M6_P4 = M6i AND CSRDMY
CSR_2_M6_HOLE = SIZE(SIZE (CSRDMY NOT M6) BY 1.5+4*GRID OVERUNDER) BY 1+4*GRID UNDEROVER
CSR_M6_HOLE = SIZE CSR_2_M6_HOLE BY CSR_W_1B/2 OVERUNDER
CSR_M6_D = M6 INSIDE (CSR_2_M6_HOLE OR CHIP_CORNER_C)
ISO_M6_D = (M6 INSIDE ISOR_P4) NOT CDUDMY
Reinforced_M6 = ((CSR_M6_P4 NOT SEALRING_ORI) NOT CSR_M6_D) INTERACT CSR_M6_HOLE
CSR_M7_P4 = M7i AND CSRDMY
CSR_2_M7_HOLE = SIZE(SIZE (CSRDMY NOT M7) BY 1.5+4*GRID OVERUNDER) BY 1+4*GRID UNDEROVER
CSR_M7_HOLE = SIZE CSR_2_M7_HOLE BY CSR_W_1B/2 OVERUNDER
CSR_M7_D = M7 INSIDE (CSR_2_M7_HOLE OR CHIP_CORNER_C)
ISO_M7_D = (M7 INSIDE ISOR_P4) NOT CDUDMY
Reinforced_M7 = ((CSR_M7_P4 NOT SEALRING_ORI) NOT CSR_M7_D) INTERACT CSR_M7_HOLE
CSR_M8_P4 = M8i AND CSRDMY
CSR_2_M8_HOLE = SIZE(SIZE (CSRDMY NOT M8) BY 1.5+4*GRID OVERUNDER) BY 1+4*GRID UNDEROVER
CSR_M8_HOLE = SIZE CSR_2_M8_HOLE BY CSR_W_1B/2 OVERUNDER
