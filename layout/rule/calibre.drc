#IFDEF M1_V1_M2_CHECKS
// M1 Type CIC 
//=============
TypeC_M1	  = CONVEX EDGE M1i ANGLE1 == 270 ANGLE2 == 270 WITH LENGTH < TypeC_LA
TypeC_M1_minw	  = INT TypeC_M1 M1i <=Mx_W ABUT<90 OPPOSITE REGION
TypeC_M1_a	  = TypeC_M1 COIN EDGE TypeC_M1_minw
TypeC_M1_side_ext= EXT TypeC_M1_a M1i <= 0.06 ABUT<90 OPPOSITE REGION
TypeC_M1_side	  = (TypeC_M1_side_ext TOUCH EDGE M1i) NOT TOUCH EDGE TypeC_M1_a
TypeC_M1_b	  = TypeC_M1_a TOUCH EDGE TypeC_M1_side_ext
TypeC_M1_common  = EXT ((EXPAND EDGE TypeC_M1_b OUTSIDE BY 0.001) TOUCH EDGE TypeC_M1_b) == 3*Mx_W+2*Mx_S PARALLEL ONLY OPPOSITE REGION
TypeC_M1_outer	  = (EXPAND EDGE (TypeC_M1_b TOUCH EDGE TypeC_M1_common) INSIDE BY 3*Mx_W+2*Mx_S) WITH EDGE TypeC_M1_b ==2
TypeC_M1_outer_a = TypeC_M1_outer WITH EDGE (LENGTH (TypeC_M1_outer NOT TOUCH EDGE TypeC_M1_b) <= 3*Mx_W+2*Mx_S)
TypeC_M1_outer_b = TypeC_M1_outer_a WITH EDGE (LENGTH (TypeC_M1_outer TOUCH EDGE TypeC_M1_b) < TypeC_LA)
TypeC_M1_outer_side= TypeC_M1_outer_b COIN EDGE TypeC_M1_side_ext
TypeC_M1_inner	  = (EXPAND EDGE TypeC_M1_outer_side INSIDE BY 3*Mx_W+2*Mx_S) WITH EDGE TypeC_M1_outer_side ==2
TypeC_M1_inner_a  = TypeC_M1_inner WITH EDGE (LENGTH (TypeC_M1_inner TOUCH EDGE TypeC_M1_side_ext) >= TypeC_LO_MIN <= TypeC_LO_MAX)
TypeC_M1_inner_M1_sp= EXT (M1i AND TypeC_M1_inner_a) <=Mx_W ABUT<90 OPPOSITE REGION
TypeC_M1_inner_b  = TypeC_M1_inner_a INTERACT TypeC_M1_inner_M1_sp >=2
TypeC_M1_err	   = TypeC_M1_inner_b NOT INSIDE SRAMDMY
EFP.M1.S.1 { @ CIC rule: At least one side space of Mx line [width = 0.05 um (W1), between 2 C-shape Mxs] to opposite C-shape Mx. Definition of "C-shape Mx": Mx has 2 consecutive 270-270 inner vertexes, and the edge [line width = 0.05 um (Wc)] between the consecutive inner vertexes faces to another Mx [width >= 0.055 um (Ws)]. Parallel run length of the edge lengths between individual 2 consecutive 270-270 inner vertexes must be < 0.3 um (L1) in 2 C-shape Mx configuration >= 0.055 
   COPY TypeC_M1_err
}
// EFP.Mx.S.1 is checked by EFP.M1.S.1


M1_NOTCH_pre1 = VERTEX (EXT M1i < COMB_S1 ABUT < 90 NOTCH OPPOSITE REGION) > 4
M1_NOTCH_pre2 = SIZE M1_NOTCH_pre1 BY GRID
M1_NOTCH_pre3 = ENCLOSE RECTANGLE M1_NOTCH_pre2 3*Mx_W+4*Mx_S GRID
M1_NOTCH_pre4 = M1_NOTCH_pre1 INSIDE M1_NOTCH_pre3
M1_NOTCH_L_END_edge_pre = EXPAND EDGE M1_L_END_edge OUTSIDE BY GRID EXTEND BY GRID
M1_NOTCH = M1_NOTCH_pre4 INTERACT (M1_NOTCH_pre4 AND M1_NOTCH_L_END_edge_pre) >= 3
M1_NOTCH_L_END_edge_pre1 = M1_L_END_edge COIN EDGE (M1_NOTCH_L_END_edge_pre INSIDE M1_NOTCH)
M1_NOTCH_L_END_edge = ENC [M1_NOTCH_L_END_edge_pre1] M1_NOTCH <= COMB_S2 OPPOSITE MEASURE COIN

M1_NOTCH_candidate1_1 = M1i INTERACT M1_NOTCH
M1_NOTCH_candidate1_2 = M1_NOTCH_L_END_edge COIN EDGE M1_NOTCH_candidate1_1 
M1_NOTCH_candidate2 = EXT M1_NOTCH_candidate1_1 M1_NOTCH_candidate1_2 <= COMB_S2 ABUT < 90 OPPOSITE REGION
M1_NOTCH_candidate3 = ((M1_NOTCH_L_END_edge TOUCH EDGE M1_NOTCH_candidate2) INSIDE EDGE M1_NOTCH) OR EDGE ((M1_NOTCH_L_END_edge TOUCH EDGE M1_NOTCH_candidate2) TOUCH EDGE M1_NOTCH)
M1_NOTCH_candidate4 = EXPAND EDGE M1_NOTCH_candidate3 INSIDE BY GRID
M1_NOTCH_candidate5 = (SIZE M1_NOTCH_candidate4 BY COMB_marker-GRID INSIDE OF M1_NOTCH_candidate1_1 STEP Mx_S *0.7) INTERACT M1_NOTCH

M1_NOTCH_candidate6 = M1_NOTCH_L_END_edge TOUCH EDGE M1_NOTCH_candidate5 
M1_NOTCH_candidate7 = INT M1_NOTCH_candidate6 [M1i] <= COMB_LL+2*GRID ABUT == 90 INTERSECTING ONLY
M1_NOTCH_candidate8 = EXT M1_NOTCH_candidate7 M1i <= Mx_S ABUT < 90 OPPOSITE REGION
M1_NOTCH_candidate9 = ENCLOSE RECTANGLE M1_NOTCH_candidate8 COMB_LL+GRID GRID
M1_NOTCH_candidate10 = M1_NOTCH_candidate5 NOT INTERACT M1_NOTCH_candidate9

M1_NOTCH_candidate11_1 = EXT M1_L_END_edge M1i <= COMB_S2 ABUT < 90 OPPOSITE REGION
M1_NOTCH_candidate11_2 = M1_NOTCH_L_END_edge TOUCH EDGE M1_NOTCH_candidate10
M1_NOTCH_candidate11_3 = INT M1_NOTCH_candidate11_2 [M1i] <= COMB_LL+GRID ABUT == 90 INTERSECTING ONLY
M1_NOTCH_candidate11_4 = EXPAND EDGE M1_NOTCH_candidate11_3 INSIDE BY GRID
M1_NOTCH_candidate11_5 = M1_NOTCH_candidate11_1 INSIDE M1_NOTCH
M1_NOTCH_candidate12_1 = EXT M1_NOTCH_candidate11_5 [M1_NOTCH_candidate11_3] == Mx_S ABUT < 90 OPPOSITE
M1_NOTCH_candidate12 = M1_NOTCH_candidate11_4 WITH EDGE M1_NOTCH_candidate12_1 == 1 
M1_NOTCH_candidate13 = M1_NOTCH_candidate10 WITH EDGE (M1_NOTCH_candidate11_3 TOUCH EDGE M1_NOTCH_candidate12) == 2
M1_NOTCH_candidate14 = M1_NOTCH_L_END_edge TOUCH EDGE M1_NOTCH_candidate13
M1_NOTCH_candidate15 = INT M1_NOTCH_candidate14 [M1i] <= COMB_LL ABUT == 90 INTERSECTING ONLY
M1_NOTCH_candidate16 = EXT [M1_NOTCH_candidate15] M1i > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE 
M1_NOTCH_candidate17 = M1_NOTCH_candidate15 NOT TOUCH EDGE (M1_NOTCH_candidate15 NOT COIN EDGE M1_NOTCH_candidate16)
M1_NOTCH_candidate18 = M1_NOTCH_candidate13 WITH EDGE M1_NOTCH_candidate17 == 2

M1_NOTCH_candidate19 = M1_NOTCH_candidate2 INTERACT M1_NOTCH_candidate18
M1_NOTCH_candidate20 = M1_NOTCH_L_END_edge COIN EDGE M1_NOTCH_candidate19
M1_NOTCH_candidate21 = INT M1_NOTCH_candidate20 [M1_NOTCH_candidate19] <= COMB_S2 ABUT < 90 OPPOSITE
M1_NOTCH_candidate22 = (M1_NOTCH_candidate19 NOT COIN EDGE M1_NOTCH_candidate20) NOT COIN EDGE M1_NOTCH_candidate21
M1_NOTCH_candidate23 = EXT [M1_NOTCH_candidate22] M1_NOTCH_candidate11_1 > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE
M1_NOTCH_candidate24 = M1_NOTCH_candidate22 NOT TOUCH EDGE (M1_NOTCH_candidate22 NOT COIN EDGE M1_NOTCH_candidate23)
M1_NOTCH_candidate25 = M1_NOTCH_candidate19 WITH EDGE M1_NOTCH_candidate24 == 2
M1_NOTCH_candidate26 = M1_NOTCH_candidate18 INTERACT M1_NOTCH_candidate25

EFP.M1.S.4 { @ Comb rule: At least one side space of Mx line [width = 0.05 um (W1), in a COMB configuration] to Mx lines. Definition of COMB configuration: Middle Mx line space to both Mx lines [width = 0.05 um (W2) and both Mxs are part of one polygon] = 0.05 um (S1) in width direction. Another 2 Mx lines (W3) space to middle Mx = 0.15 um (S3). Parallel run length of 5 Mx lines is within 0 um ~ 0.4 um (L1). In addition, the odd Mx (W1,W3) line-end space to opposite Mx <= 0.08 um (S2) >= 0.055 
  COPY M1_NOTCH_candidate26
}
// EFP.Mx.S.4 is checked by EFP.M1.S.4

// M2 Type CIC 
//=============
TypeC_M2	  = CONVEX EDGE M2i ANGLE1 == 270 ANGLE2 == 270 WITH LENGTH < TypeC_LA
TypeC_M2_minw	  = INT TypeC_M2 M2i <=Mx_W ABUT<90 OPPOSITE REGION
TypeC_M2_a	  = TypeC_M2 COIN EDGE TypeC_M2_minw
TypeC_M2_side_ext= EXT TypeC_M2_a M2i <= 0.06 ABUT<90 OPPOSITE REGION
TypeC_M2_side	  = (TypeC_M2_side_ext TOUCH EDGE M2i) NOT TOUCH EDGE TypeC_M2_a
TypeC_M2_b	  = TypeC_M2_a TOUCH EDGE TypeC_M2_side_ext
TypeC_M2_common  = EXT ((EXPAND EDGE TypeC_M2_b OUTSIDE BY 0.001) TOUCH EDGE TypeC_M2_b) == 3*Mx_W+2*Mx_S PARALLEL ONLY OPPOSITE REGION
TypeC_M2_outer	  = (EXPAND EDGE (TypeC_M2_b TOUCH EDGE TypeC_M2_common) INSIDE BY 3*Mx_W+2*Mx_S) WITH EDGE TypeC_M2_b ==2
TypeC_M2_outer_a = TypeC_M2_outer WITH EDGE (LENGTH (TypeC_M2_outer NOT TOUCH EDGE TypeC_M2_b) <= 3*Mx_W+2*Mx_S)
TypeC_M2_outer_b = TypeC_M2_outer_a WITH EDGE (LENGTH (TypeC_M2_outer TOUCH EDGE TypeC_M2_b) < TypeC_LA)
TypeC_M2_outer_side= TypeC_M2_outer_b COIN EDGE TypeC_M2_side_ext
TypeC_M2_inner	  = (EXPAND EDGE TypeC_M2_outer_side INSIDE BY 3*Mx_W+2*Mx_S) WITH EDGE TypeC_M2_outer_side ==2
TypeC_M2_inner_a  = TypeC_M2_inner WITH EDGE (LENGTH (TypeC_M2_inner TOUCH EDGE TypeC_M2_side_ext) >= TypeC_LO_MIN <= TypeC_LO_MAX)
TypeC_M2_inner_M2_sp= EXT (M2i AND TypeC_M2_inner_a) <=Mx_W ABUT<90 OPPOSITE REGION
TypeC_M2_inner_b  = TypeC_M2_inner_a INTERACT TypeC_M2_inner_M2_sp >=2
TypeC_M2_err	   = TypeC_M2_inner_b NOT INSIDE SRAMDMY
EFP.M2.S.1 { @ CIC rule: At least one side space of Mx line [width = 0.05 um (W1), between 2 C-shape Mxs] to opposite C-shape Mx. Definition of "C-shape Mx": Mx has 2 consecutive 270-270 inner vertexes, and the edge [line width = 0.05 um (Wc)] between the consecutive inner vertexes faces to another Mx [width >= 0.055 um (Ws)]. Parallel run length of the edge lengths between individual 2 consecutive 270-270 inner vertexes must be < 0.3 um (L1) in 2 C-shape Mx configuration >= 0.055 
   COPY TypeC_M2_err
}
// EFP.Mx.S.1 is checked by EFP.M2.S.1


M2_NOTCH_pre1 = VERTEX (EXT M2i < COMB_S1 ABUT < 90 NOTCH OPPOSITE REGION) > 4
M2_NOTCH_pre2 = SIZE M2_NOTCH_pre1 BY GRID
M2_NOTCH_pre3 = ENCLOSE RECTANGLE M2_NOTCH_pre2 3*Mx_W+4*Mx_S GRID
M2_NOTCH_pre4 = M2_NOTCH_pre1 INSIDE M2_NOTCH_pre3
M2_NOTCH_L_END_edge_pre = EXPAND EDGE M2_L_END_edge OUTSIDE BY GRID EXTEND BY GRID
M2_NOTCH = M2_NOTCH_pre4 INTERACT (M2_NOTCH_pre4 AND M2_NOTCH_L_END_edge_pre) >= 3
M2_NOTCH_L_END_edge_pre1 = M2_L_END_edge COIN EDGE (M2_NOTCH_L_END_edge_pre INSIDE M2_NOTCH)
M2_NOTCH_L_END_edge = ENC [M2_NOTCH_L_END_edge_pre1] M2_NOTCH <= COMB_S2 OPPOSITE MEASURE COIN

M2_NOTCH_candidate1_1 = M2i INTERACT M2_NOTCH
M2_NOTCH_candidate1_2 = M2_NOTCH_L_END_edge COIN EDGE M2_NOTCH_candidate1_1 
M2_NOTCH_candidate2 = EXT M2_NOTCH_candidate1_1 M2_NOTCH_candidate1_2 <= COMB_S2 ABUT < 90 OPPOSITE REGION
M2_NOTCH_candidate3 = ((M2_NOTCH_L_END_edge TOUCH EDGE M2_NOTCH_candidate2) INSIDE EDGE M2_NOTCH) OR EDGE ((M2_NOTCH_L_END_edge TOUCH EDGE M2_NOTCH_candidate2) TOUCH EDGE M2_NOTCH)
M2_NOTCH_candidate4 = EXPAND EDGE M2_NOTCH_candidate3 INSIDE BY GRID
M2_NOTCH_candidate5 = (SIZE M2_NOTCH_candidate4 BY COMB_marker-GRID INSIDE OF M2_NOTCH_candidate1_1 STEP Mx_S *0.7) INTERACT M2_NOTCH

M2_NOTCH_candidate6 = M2_NOTCH_L_END_edge TOUCH EDGE M2_NOTCH_candidate5 
M2_NOTCH_candidate7 = INT M2_NOTCH_candidate6 [M2i] <= COMB_LL+2*GRID ABUT == 90 INTERSECTING ONLY
M2_NOTCH_candidate8 = EXT M2_NOTCH_candidate7 M2i <= Mx_S ABUT < 90 OPPOSITE REGION
M2_NOTCH_candidate9 = ENCLOSE RECTANGLE M2_NOTCH_candidate8 COMB_LL+GRID GRID
M2_NOTCH_candidate10 = M2_NOTCH_candidate5 NOT INTERACT M2_NOTCH_candidate9

M2_NOTCH_candidate11_1 = EXT M2_L_END_edge M2i <= COMB_S2 ABUT < 90 OPPOSITE REGION
M2_NOTCH_candidate11_2 = M2_NOTCH_L_END_edge TOUCH EDGE M2_NOTCH_candidate10
M2_NOTCH_candidate11_3 = INT M2_NOTCH_candidate11_2 [M2i] <= COMB_LL+GRID ABUT == 90 INTERSECTING ONLY
M2_NOTCH_candidate11_4 = EXPAND EDGE M2_NOTCH_candidate11_3 INSIDE BY GRID
M2_NOTCH_candidate11_5 = M2_NOTCH_candidate11_1 INSIDE M2_NOTCH
M2_NOTCH_candidate12_1 = EXT M2_NOTCH_candidate11_5 [M2_NOTCH_candidate11_3] == Mx_S ABUT < 90 OPPOSITE
M2_NOTCH_candidate12 = M2_NOTCH_candidate11_4 WITH EDGE M2_NOTCH_candidate12_1 == 1 
M2_NOTCH_candidate13 = M2_NOTCH_candidate10 WITH EDGE (M2_NOTCH_candidate11_3 TOUCH EDGE M2_NOTCH_candidate12) == 2
M2_NOTCH_candidate14 = M2_NOTCH_L_END_edge TOUCH EDGE M2_NOTCH_candidate13
M2_NOTCH_candidate15 = INT M2_NOTCH_candidate14 [M2i] <= COMB_LL ABUT == 90 INTERSECTING ONLY
M2_NOTCH_candidate16 = EXT [M2_NOTCH_candidate15] M2i > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE 
M2_NOTCH_candidate17 = M2_NOTCH_candidate15 NOT TOUCH EDGE (M2_NOTCH_candidate15 NOT COIN EDGE M2_NOTCH_candidate16)
M2_NOTCH_candidate18 = M2_NOTCH_candidate13 WITH EDGE M2_NOTCH_candidate17 == 2

M2_NOTCH_candidate19 = M2_NOTCH_candidate2 INTERACT M2_NOTCH_candidate18
M2_NOTCH_candidate20 = M2_NOTCH_L_END_edge COIN EDGE M2_NOTCH_candidate19
M2_NOTCH_candidate21 = INT M2_NOTCH_candidate20 [M2_NOTCH_candidate19] <= COMB_S2 ABUT < 90 OPPOSITE
M2_NOTCH_candidate22 = (M2_NOTCH_candidate19 NOT COIN EDGE M2_NOTCH_candidate20) NOT COIN EDGE M2_NOTCH_candidate21
M2_NOTCH_candidate23 = EXT [M2_NOTCH_candidate22] M2_NOTCH_candidate11_1 > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE
M2_NOTCH_candidate24 = M2_NOTCH_candidate22 NOT TOUCH EDGE (M2_NOTCH_candidate22 NOT COIN EDGE M2_NOTCH_candidate23)
M2_NOTCH_candidate25 = M2_NOTCH_candidate19 WITH EDGE M2_NOTCH_candidate24 == 2
M2_NOTCH_candidate26 = M2_NOTCH_candidate18 INTERACT M2_NOTCH_candidate25

EFP.M2.S.4 { @ Comb rule: At least one side space of Mx line [width = 0.05 um (W1), in a COMB configuration] to Mx lines. Definition of COMB configuration: Middle Mx line space to both Mx lines [width = 0.05 um (W2) and both Mxs are part of one polygon] = 0.05 um (S1) in width direction. Another 2 Mx lines (W3) space to middle Mx = 0.15 um (S3). Parallel run length of 5 Mx lines is within 0 um ~ 0.4 um (L1). In addition, the odd Mx (W1,W3) line-end space to opposite Mx <= 0.08 um (S2) >= 0.055 
  COPY M2_NOTCH_candidate26
}
// EFP.Mx.S.4 is checked by EFP.M2.S.4
#ENDIF //M1_V1_M2_CHECKS

#IFDEF BACK_END
// M3 Type CIC 
//=============
TypeC_M3	  = CONVEX EDGE M3i ANGLE1 == 270 ANGLE2 == 270 WITH LENGTH < TypeC_LA
TypeC_M3_minw	  = INT TypeC_M3 M3i <=Mx_W ABUT<90 OPPOSITE REGION
TypeC_M3_a	  = TypeC_M3 COIN EDGE TypeC_M3_minw
TypeC_M3_side_ext= EXT TypeC_M3_a M3i <= 0.06 ABUT<90 OPPOSITE REGION
TypeC_M3_side	  = (TypeC_M3_side_ext TOUCH EDGE M3i) NOT TOUCH EDGE TypeC_M3_a
TypeC_M3_b	  = TypeC_M3_a TOUCH EDGE TypeC_M3_side_ext
TypeC_M3_common  = EXT ((EXPAND EDGE TypeC_M3_b OUTSIDE BY 0.001) TOUCH EDGE TypeC_M3_b) == 3*Mx_W+2*Mx_S PARALLEL ONLY OPPOSITE REGION
TypeC_M3_outer	  = (EXPAND EDGE (TypeC_M3_b TOUCH EDGE TypeC_M3_common) INSIDE BY 3*Mx_W+2*Mx_S) WITH EDGE TypeC_M3_b ==2
TypeC_M3_outer_a = TypeC_M3_outer WITH EDGE (LENGTH (TypeC_M3_outer NOT TOUCH EDGE TypeC_M3_b) <= 3*Mx_W+2*Mx_S)
TypeC_M3_outer_b = TypeC_M3_outer_a WITH EDGE (LENGTH (TypeC_M3_outer TOUCH EDGE TypeC_M3_b) < TypeC_LA)
TypeC_M3_outer_side= TypeC_M3_outer_b COIN EDGE TypeC_M3_side_ext
TypeC_M3_inner	  = (EXPAND EDGE TypeC_M3_outer_side INSIDE BY 3*Mx_W+2*Mx_S) WITH EDGE TypeC_M3_outer_side ==2
TypeC_M3_inner_a  = TypeC_M3_inner WITH EDGE (LENGTH (TypeC_M3_inner TOUCH EDGE TypeC_M3_side_ext) >= TypeC_LO_MIN <= TypeC_LO_MAX)
TypeC_M3_inner_M3_sp= EXT (M3i AND TypeC_M3_inner_a) <=Mx_W ABUT<90 OPPOSITE REGION
TypeC_M3_inner_b  = TypeC_M3_inner_a INTERACT TypeC_M3_inner_M3_sp >=2
TypeC_M3_err	   = TypeC_M3_inner_b NOT INSIDE SRAMDMY
EFP.M3.S.1 { @ CIC rule: At least one side space of Mx line [width = 0.05 um (W1), between 2 C-shape Mxs] to opposite C-shape Mx. Definition of "C-shape Mx": Mx has 2 consecutive 270-270 inner vertexes, and the edge [line width = 0.05 um (Wc)] between the consecutive inner vertexes faces to another Mx [width >= 0.055 um (Ws)]. Parallel run length of the edge lengths between individual 2 consecutive 270-270 inner vertexes must be < 0.3 um (L1) in 2 C-shape Mx configuration >= 0.055 
   COPY TypeC_M3_err
}
// EFP.Mx.S.1 is checked by EFP.M3.S.1


M3_NOTCH_pre1 = VERTEX (EXT M3i < COMB_S1 ABUT < 90 NOTCH OPPOSITE REGION) > 4
M3_NOTCH_pre2 = SIZE M3_NOTCH_pre1 BY GRID
M3_NOTCH_pre3 = ENCLOSE RECTANGLE M3_NOTCH_pre2 3*Mx_W+4*Mx_S GRID
M3_NOTCH_pre4 = M3_NOTCH_pre1 INSIDE M3_NOTCH_pre3
M3_NOTCH_L_END_edge_pre = EXPAND EDGE M3_L_END_edge OUTSIDE BY GRID EXTEND BY GRID
M3_NOTCH = M3_NOTCH_pre4 INTERACT (M3_NOTCH_pre4 AND M3_NOTCH_L_END_edge_pre) >= 3
M3_NOTCH_L_END_edge_pre1 = M3_L_END_edge COIN EDGE (M3_NOTCH_L_END_edge_pre INSIDE M3_NOTCH)
M3_NOTCH_L_END_edge = ENC [M3_NOTCH_L_END_edge_pre1] M3_NOTCH <= COMB_S2 OPPOSITE MEASURE COIN

M3_NOTCH_candidate1_1 = M3i INTERACT M3_NOTCH
M3_NOTCH_candidate1_2 = M3_NOTCH_L_END_edge COIN EDGE M3_NOTCH_candidate1_1 
M3_NOTCH_candidate2 = EXT M3_NOTCH_candidate1_1 M3_NOTCH_candidate1_2 <= COMB_S2 ABUT < 90 OPPOSITE REGION
M3_NOTCH_candidate3 = ((M3_NOTCH_L_END_edge TOUCH EDGE M3_NOTCH_candidate2) INSIDE EDGE M3_NOTCH) OR EDGE ((M3_NOTCH_L_END_edge TOUCH EDGE M3_NOTCH_candidate2) TOUCH EDGE M3_NOTCH)
M3_NOTCH_candidate4 = EXPAND EDGE M3_NOTCH_candidate3 INSIDE BY GRID
M3_NOTCH_candidate5 = (SIZE M3_NOTCH_candidate4 BY COMB_marker-GRID INSIDE OF M3_NOTCH_candidate1_1 STEP Mx_S *0.7) INTERACT M3_NOTCH

M3_NOTCH_candidate6 = M3_NOTCH_L_END_edge TOUCH EDGE M3_NOTCH_candidate5 
M3_NOTCH_candidate7 = INT M3_NOTCH_candidate6 [M3i] <= COMB_LL+2*GRID ABUT == 90 INTERSECTING ONLY
M3_NOTCH_candidate8 = EXT M3_NOTCH_candidate7 M3i <= Mx_S ABUT < 90 OPPOSITE REGION
M3_NOTCH_candidate9 = ENCLOSE RECTANGLE M3_NOTCH_candidate8 COMB_LL+GRID GRID
M3_NOTCH_candidate10 = M3_NOTCH_candidate5 NOT INTERACT M3_NOTCH_candidate9

M3_NOTCH_candidate11_1 = EXT M3_L_END_edge M3i <= COMB_S2 ABUT < 90 OPPOSITE REGION
M3_NOTCH_candidate11_2 = M3_NOTCH_L_END_edge TOUCH EDGE M3_NOTCH_candidate10
M3_NOTCH_candidate11_3 = INT M3_NOTCH_candidate11_2 [M3i] <= COMB_LL+GRID ABUT == 90 INTERSECTING ONLY
M3_NOTCH_candidate11_4 = EXPAND EDGE M3_NOTCH_candidate11_3 INSIDE BY GRID
M3_NOTCH_candidate11_5 = M3_NOTCH_candidate11_1 INSIDE M3_NOTCH
M3_NOTCH_candidate12_1 = EXT M3_NOTCH_candidate11_5 [M3_NOTCH_candidate11_3] == Mx_S ABUT < 90 OPPOSITE
M3_NOTCH_candidate12 = M3_NOTCH_candidate11_4 WITH EDGE M3_NOTCH_candidate12_1 == 1 
M3_NOTCH_candidate13 = M3_NOTCH_candidate10 WITH EDGE (M3_NOTCH_candidate11_3 TOUCH EDGE M3_NOTCH_candidate12) == 2
M3_NOTCH_candidate14 = M3_NOTCH_L_END_edge TOUCH EDGE M3_NOTCH_candidate13
M3_NOTCH_candidate15 = INT M3_NOTCH_candidate14 [M3i] <= COMB_LL ABUT == 90 INTERSECTING ONLY
M3_NOTCH_candidate16 = EXT [M3_NOTCH_candidate15] M3i > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE 
M3_NOTCH_candidate17 = M3_NOTCH_candidate15 NOT TOUCH EDGE (M3_NOTCH_candidate15 NOT COIN EDGE M3_NOTCH_candidate16)
M3_NOTCH_candidate18 = M3_NOTCH_candidate13 WITH EDGE M3_NOTCH_candidate17 == 2

M3_NOTCH_candidate19 = M3_NOTCH_candidate2 INTERACT M3_NOTCH_candidate18
M3_NOTCH_candidate20 = M3_NOTCH_L_END_edge COIN EDGE M3_NOTCH_candidate19
M3_NOTCH_candidate21 = INT M3_NOTCH_candidate20 [M3_NOTCH_candidate19] <= COMB_S2 ABUT < 90 OPPOSITE
M3_NOTCH_candidate22 = (M3_NOTCH_candidate19 NOT COIN EDGE M3_NOTCH_candidate20) NOT COIN EDGE M3_NOTCH_candidate21
M3_NOTCH_candidate23 = EXT [M3_NOTCH_candidate22] M3_NOTCH_candidate11_1 > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE
M3_NOTCH_candidate24 = M3_NOTCH_candidate22 NOT TOUCH EDGE (M3_NOTCH_candidate22 NOT COIN EDGE M3_NOTCH_candidate23)
M3_NOTCH_candidate25 = M3_NOTCH_candidate19 WITH EDGE M3_NOTCH_candidate24 == 2
M3_NOTCH_candidate26 = M3_NOTCH_candidate18 INTERACT M3_NOTCH_candidate25

EFP.M3.S.4 { @ Comb rule: At least one side space of Mx line [width = 0.05 um (W1), in a COMB configuration] to Mx lines. Definition of COMB configuration: Middle Mx line space to both Mx lines [width = 0.05 um (W2) and both Mxs are part of one polygon] = 0.05 um (S1) in width direction. Another 2 Mx lines (W3) space to middle Mx = 0.15 um (S3). Parallel run length of 5 Mx lines is within 0 um ~ 0.4 um (L1). In addition, the odd Mx (W1,W3) line-end space to opposite Mx <= 0.08 um (S2) >= 0.055 
  COPY M3_NOTCH_candidate26
}
// EFP.Mx.S.4 is checked by EFP.M3.S.4

// M4 Type CIC 
//=============
TypeC_M4	  = CONVEX EDGE M4i ANGLE1 == 270 ANGLE2 == 270 WITH LENGTH < TypeC_LA
TypeC_M4_minw	  = INT TypeC_M4 M4i <=Mx_W ABUT<90 OPPOSITE REGION
TypeC_M4_a	  = TypeC_M4 COIN EDGE TypeC_M4_minw
TypeC_M4_side_ext= EXT TypeC_M4_a M4i <= 0.06 ABUT<90 OPPOSITE REGION
TypeC_M4_side	  = (TypeC_M4_side_ext TOUCH EDGE M4i) NOT TOUCH EDGE TypeC_M4_a
TypeC_M4_b	  = TypeC_M4_a TOUCH EDGE TypeC_M4_side_ext
TypeC_M4_common  = EXT ((EXPAND EDGE TypeC_M4_b OUTSIDE BY 0.001) TOUCH EDGE TypeC_M4_b) == 3*Mx_W+2*Mx_S PARALLEL ONLY OPPOSITE REGION
TypeC_M4_outer	  = (EXPAND EDGE (TypeC_M4_b TOUCH EDGE TypeC_M4_common) INSIDE BY 3*Mx_W+2*Mx_S) WITH EDGE TypeC_M4_b ==2
TypeC_M4_outer_a = TypeC_M4_outer WITH EDGE (LENGTH (TypeC_M4_outer NOT TOUCH EDGE TypeC_M4_b) <= 3*Mx_W+2*Mx_S)
TypeC_M4_outer_b = TypeC_M4_outer_a WITH EDGE (LENGTH (TypeC_M4_outer TOUCH EDGE TypeC_M4_b) < TypeC_LA)
TypeC_M4_outer_side= TypeC_M4_outer_b COIN EDGE TypeC_M4_side_ext
TypeC_M4_inner	  = (EXPAND EDGE TypeC_M4_outer_side INSIDE BY 3*Mx_W+2*Mx_S) WITH EDGE TypeC_M4_outer_side ==2
TypeC_M4_inner_a  = TypeC_M4_inner WITH EDGE (LENGTH (TypeC_M4_inner TOUCH EDGE TypeC_M4_side_ext) >= TypeC_LO_MIN <= TypeC_LO_MAX)
TypeC_M4_inner_M4_sp= EXT (M4i AND TypeC_M4_inner_a) <=Mx_W ABUT<90 OPPOSITE REGION
TypeC_M4_inner_b  = TypeC_M4_inner_a INTERACT TypeC_M4_inner_M4_sp >=2
TypeC_M4_err	   = COPY TypeC_M4_inner_b
EFP.M4.S.1 { @ CIC rule: At least one side space of Mx line [width = 0.05 um (W1), between 2 C-shape Mxs] to opposite C-shape Mx. Definition of "C-shape Mx": Mx has 2 consecutive 270-270 inner vertexes, and the edge [line width = 0.05 um (Wc)] between the consecutive inner vertexes faces to another Mx [width >= 0.055 um (Ws)]. Parallel run length of the edge lengths between individual 2 consecutive 270-270 inner vertexes must be < 0.3 um (L1) in 2 C-shape Mx configuration >= 0.055 
   COPY TypeC_M4_err
}
// EFP.Mx.S.1 is checked by EFP.M4.S.1


M4_NOTCH_pre1 = VERTEX (EXT M4i < COMB_S1 ABUT < 90 NOTCH OPPOSITE REGION) > 4
