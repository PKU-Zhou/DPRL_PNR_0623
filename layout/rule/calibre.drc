//LOGO CHECKS
//============

LOGO.S.1 { @ Space to OD, PO, or Metals (non-dummy patterns) (This check doesn't include the M1/ Mx protection ring inside {LOWMEDN NOT {LOWMEDN SIZING -4 um}} region, and FEOL/BEOL dummy TCD) >= 10 
  LOGO_EXT = ((SIZE LOGO BY LOGO_S_1) NOT LOGO) NOT PADDMY
// For run-time concern, DRC use "SIZING" methodology to check space
  LOGO_EXT AND (ODi NOT TCDDMY)
  LOGO_EXT AND (POi NOT TCDDMY)
  LOGO_EXT AND (M1i NOT (P_RING_REGION OR TCDDMY_BM1))
  LOGO_EXT AND (M2i NOT (P_RING_REGION OR TCDDMY_BM2))
  LOGO_EXT AND (M3i NOT (P_RING_REGION OR TCDDMY_BM3))
  LOGO_EXT AND (M4i NOT (P_RING_REGION OR TCDDMY_BM4))
  LOGO_EXT AND (M5i NOT (P_RING_REGION OR TCDDMY_BM5))
  LOGO_EXT AND (M6i NOT (P_RING_REGION OR TCDDMY_BM6))
  LOGO_EXT AND (M7i NOT (P_RING_REGION OR TCDDMY_BM7))
  LOGO_EXT AND M8i
  LOGO_EXT AND M9i
}
LOGO.O.1 { @ Overlap of CB, CBD, PM, or UBM is not allowed   
  LOGO AND CBi
  LOGO AND CBDi
  LOGO AND PMi
  LOGO AND UBMi
}

// LOGO.R.2 is checked by related rules



//SRAM CHECKS
//===========
SRAM.W.1 { @ SRAMDMY;0 (186;0) width. The SRAMDMY;0 (186;0) edge should be aligned to the boundary of the cell array, which may include storage, strapping, and dummy edge cells >= 0.16 
  INT SRAMDMY < SRAM_W_1 ABUT < 90 SINGULAR REGION
}
SRAM.S.1 { @ SRAMDMY;0 (186;0) space >= 0.16 
  EXT SRAMDMY < SRAM_S_1 ABUT < 90 SINGULAR REGION
}
SRAM.S.2 { @ SRAMDMY;0 (186;0) space to {GATE not interact with SRAMDMY;0 (186;0)} >= 0.115 
  B = (POi AND ODi) NOT INTERACT SRAMDMY    
  (EXT B SRAMDMY < SRAM_S_2 ABUT < 90 SINGULAR REGION) NOT INSIDE SRM_3
}
SRAM.EN.1__SRAM.EN.2 { @ SRAMDMY (186;0) enclosure of GATE in S/D direction. >= 0.115
                       @ SRAMDMY (186;0) enclosure of GATE in PO ENDCAP direction. >= 0.075
  A = GATEi INTERACT SRAMDMY
  X = A INSIDE EDGE ODi
  B = (EXPAND EDGE X OUTSIDE BY (SRAM_EN_1 - SRAM_EN_2)) OR A
  C = SIZE B BY SRAM_EN_2
  C NOT SRAMDMY
}
SRAM.EX.1 { @ SRAMDMY;0 (186;0) extension on NW (interact with OD). Extension = 0 is allowed >= 0.16 
  ENC (NWi INTERACT ODi) SRAMDMY < SRAM_EX_1 ABUT < 90 > 0 SINGULAR REGION 
}
SRAM.O.1 { @ SRAMDMY;0 (186;0) overlap of NW (interact with OD) (for VTC_N, VTC_P). Extension = 0 is allowed >= 0.16 
  INT (SRAMDMY AND (NWi INTERACT ODi)) < SRAM_O_1 ABUT < 90 OPPOSITE REGION 
}
SRAM.R.12 { @ SRAMDMY;5 (186;5) overlap of SRAMDMY;0 (186;0) is not allowed   
  SRAMDMY_WLD5 AND SRAMDMY
}
SRAM.R.13 { @ SRAMDMY;5 (186;5) must fully cover GATE   
  A = (POi AND ODi) INTERACT SRAMDMY_WLD5
  A NOT SRAMDMY_WLD5    
}

SRAM.R.15 { @ CO;11 (30;11) is a must for CO mask tape-out in SRAM. 1. If CO;11 (30;11) exists, it must cover CO (30;0) 2. CO;11 (30;11) must be 0.04 um x 0.04 um 3. CO;11 (30;11) must be exactly the same as CO (30;0) . 4. CO;11 (30;11) must be fully covered by SRAMDMY;0 (186;0)   
// CO;11 (30;11) is a must for CO mask tape-out in SRAM
// 1.If CO;11 exists, it must cover CO;0 
  COPUSH NOT COi 	
// 2.CO;11 must be 0.06um x 0.06um  
  NOT RECTANGLE COPUSH == CO_W_1 BY == CO_W_1 ORTHOGONAL ONLY
// 3.CO;11 must be exactly the same as CO;0.
  CO_COPUSH = COi INTERACT COPUSH
  CO_COPUSH XOR COPUSH
// 4.CO;11 must be fully covered by SRAMDMY(186;0)
  COPUSH NOT SRAMDMY
}
SRAM.R.17 { @ SRAMDMY;0 (186;0) must fully cover OD, CO, VIA1   
   (ODi CUT SRAMDMY) NOT INSIDE SRM_3
   (COi CUT SRAMDMY) NOT INSIDE SRM_3
   (VIA1i CUT SRAMDMY) NOT INSIDE SRM_3
}
SRAM.R.18 { @ Inside of SRAM array, SRM (50;0), SRAMDMY;0 (186;0) can't have any holes in them   
  HOLES SRM INNER
  HOLES SRAMDMY INNER
}

SRAM.R.19 {@ CPO;12 fully inside SRAMDMY;0 (186;0) region   
  CPO_SRM NOT SRAMDMY
}
CONNECT SRAMDMY
SRAM_NP = NP AND SRAMDMY
SRAM.R.24 {@ Total NP {26;0} area in SRAM {186;0} array >= 5.994, except SRM;3 (50;3)
  X = STAMP SRAM_NP BY SRAMDMY
  (NET AREA X < SRAM_R_24) NOT SRM_3 
}

SRAM_NW = NWEL AND SRAMDMY
SRAM.R.25 {@ Total NW {3;0} area in SRAM {186;0} array	>= 2.376, except SRM;3 (50;3)
  X = STAMP SRAM_NW BY SRAMDMY
  (NET AREA X < SRAM_R_25) NOT SRM_3
}

SRAM_PP = PP AND SRAMDMY
SRAM.R.26 {@ Total PP {25;0} area in SRAM {186;0} array >= 2.376, except SRM;3 (50;3)
  X = STAMP SRAM_PP BY SRAMDMY
  (NET AREA X < SRAM_R_26) NOT SRM_3
}
SRAM.R.27 {@ SRM (50;0) fully inside SRAMDMY;0 (186;0)   
  SRM NOT SRAMDMY
}

SRAM.R.30 {@ CPO_SRM (17;12) space to {CPO OR CPO_SRM} >= 0.09 
  EXT CPO_SRM CPO < SRAM_R_30 ABUT<90 SINGULAR INSIDE ALSO REGION
  EXT CPO_SRM < SRAM_R_30 ABUT<90 SINGULAR REGION
}
SRAM.R.31 {@ Each SRAM array {{{{SRM (50;0) OR SRM;3 (50;3)} OR ROM (50;6)} OR SRAMDMY;0 (186;0)} ORSRAMDMY;7 (186;7)} must have IP (63;63)   
  A = ((SRM OR SRAMDMY) OR (SRAMDMY_7 OR SRM_3)) OR ROM   
  A NOT WITH TEXT "?" IPTAG
}
SRAM.R.32 {@ In SRM;3 (50;3) macro, it needs including SRM (50;0) and SRAMDMY;0 (186;0) layers   
  SRM_3 NOT ENCLOSE SRAMDMY
  SRM_3 NOT ENCLOSE SRM    
}

CPO_xSRM3_END = CONVEX EDGE (CPO_SRM NOT INSIDE SRM_3) == 2 WITH LENGTH == 0.08
CPO_xSRM3_RUN = (CPO_SRM NOT INSIDE SRM_3) NOT TOUCH EDGE CPO_SRM_END

CPO_SRM_END = OR EDGE (CONVEX EDGE CPO_SRM == 2 WITH LENGTH == 0.060) (CONVEX EDGE CPO_SRM == 2 WITH LENGTH == 0.070)
CPO_SRM_RUN = CPO_SRM NOT TOUCH EDGE CPO_SRM_END


LOGIC_PO_check = (((POi OR SRDPO) OR DPO) INTERACT ODi) NOT SRAMDMY

SRAM.R.35 { @ The longer side of SRAM CPO space to logic PO >= ^SRAM_R_35 ,except SRM;3
    EXT CPO_xSRM3_RUN LOGIC_PO_check < SRAM_R_35 ABUT < 90 OPPOSITE REGION
}

SRAM.R.36 { @ The shorter side of SRAM CPO space to logic PO >= ^SRAM_R_36
    EXT CPO_SRM_END LOGIC_PO_check < SRAM_R_36 ABUT < 90  OPPOSITE REGION
}

SRAM.WARN.1 {@ Warning: It is important to add different redundancies according to different memory densities, if the total SRAM area for all cells in one chip is > 2,696,000 um2 (e.g. 16Mb of 0.156 um2 cell). Please refer to T-000-CL-RP-002, TSMC EMBEDDED SRAM REDUNDANCY IMPLEMENTATION RULE AND ECC GUIDELINE, for the details. DRC only flags the total SRAM area in one chip > 2,696,000 um2   
   DENSITY SRM > SRAM_WARN_1 INSIDE OF LAYER CHIPx
   [AREA(SRM)] RDB SRAM.WARN.1.rep
}
SRAM.WARN.2 {@ Warning: It is important to add ECC (Error Correcting-Code), if the total SRAM area for all cells in one chip is > 10,784,000 um2 (e.g. 64Mb of 0.156 um2 cell). Please refer to T-000-CL-RP-002, TSMC EMBEDDED SRAM REDUNDANCY IMPLEMENTATION RULE AND ECC GUIDELINE, for the details. DRC only flags the total SRAM area in one chip > 10,784,000 um2. For ECC implementation, please consult TSMC QR based on product operation spec   
   DENSITY SRM > SRAM_WARN_2 INSIDE OF LAYER CHIPx
   [AREA(SRM)] RDB SRAM.WARN.2.rep
}

// BEGIN OF RULE CHECKS
//======================
SRAM_CO         = COii NOT OUTSIDE SRM
SRAM_COx        = COii OUTSIDE SRM
SRAM_BCO_pre    = (RECTANGLE SRAM_CO == SRAM_CO_W_1 BY >= SRAM_BTC_W_1_L1 ORTHOGONAL ONLY) NOT INTERACT COPUSH
SRAM_BCO        = (RECTANGLE SRAM_BCO_pre == SRAM_CO_W_1 BY <= SRAM_BTC_W_1_L2 ORTHOGONAL ONLY) NOT INTERACT COPUSH // SRAM butted contact
SRAM_SCO        = SRAM_CO NOT SRAM_BCO  // SRAM square contact
SRAM_BTC_CHK    = STAMP SRAM_BCO BY COii
SRAM_SCO_CHK    = STAMP SRAM_SCO BY COii
SRAM_COx_CHK    = STAMP SRAM_COx BY COii

SRAM.BTC.W.1__SRAM.BTC.L.1 { @ Width = 0.04, length of {Butted CO} = 0.11um ~ 0.12um
  NOT RECTANGLE SRAM_SCO == SRAM_BTC_W_1 BY == SRAM_BTC_W_1 ORTHOGONAL ONLY
  NOT RECTANGLE COPUSH == SRAM_BTC_W_1 BY == SRAM_BTC_W_1 ORTHOGONAL ONLY
}
 

SRAM.BTC.S.1 { @ Space >= 0.07
  EXT SRAM_BTC_CHK < SRAM_BTC_S_1 ABUT < 90 SINGULAR NOT CONNECTED REGION
}

SRAM.BTC.S.2 { @ BTC space to M1 [different nets] >= ^SRAM_BTC_S_2 um
  EXT SRAM_BTC_CHK M1i < SRAM_BTC_S_2 ABUT<90 NOT CONNECTED REGION
}

SRAM.BTC.S.3 { @ BTC space CO [different nets] >= ^SRAM_BTC_S_3 um
  EXT SRAM_BTC_CHK SRAM_COx_CHK < SRAM_BTC_S_3 ABUT<90 NOT CONNECTED REGION
  EXT SRAM_BTC_CHK SRAM_SCO_CHK < SRAM_BTC_S_3 ABUT<90 NOT CONNECTED REGION
}


// SRAM METAL/VIA RULES

SRAMDMY_SRM_3   = SRAMDMY OR SRM_3
SRAM_VIA1i = VIA1i NOT OUTSIDE SRAMDMY_SRM_3
SRAM_SQR_VIA1i = RECTANGLE SRAM_VIA1i == VIA1_W_1 BY == VIA1_L_1 ORTHOGONAL ONLY
SRAM_REC_VIA1i = RECTANGLE SRAM_VIA1i == VIA1_W_1 BY == VIA1_L_2 ORTHOGONAL ONLY
SRAM_REC_VIA1i_END = LENGTH SRAM_REC_VIA1i == VIA1_W_1
SRAM_REC_VIA1i_SIDE = LENGTH SRAM_REC_VIA1i == VIA1_L_2
SRAM_VIA2i = VIA2i NOT OUTSIDE SRAMDMY_SRM_3
SRAM_SQR_VIA2i = RECTANGLE SRAM_VIA2i == VIA2_W_1 BY == VIA2_L_1 ORTHOGONAL ONLY
SRAM_REC_VIA2i = RECTANGLE SRAM_VIA2i == VIA2_W_1 BY == VIA2_L_2 ORTHOGONAL ONLY


SRAM_M1  = M1 NOT OUTSIDE SRAMDMY_SRM_3
SRAM_M1i = M1i NOT OUTSIDE SRAMDMY_SRM_3

SRAM_M2 = M2 NOT OUTSIDE SRAMDMY_SRM_3
SRAM_M2i = M2i NOT OUTSIDE SRAMDMY_SRM_3

SRAM_M3 = M3 NOT OUTSIDE SRAMDMY_SRM_3

//SRAM.R.37 is checked by {SRAM.R.38 and SRAM.R.39__SRAM.R.40}
SRAM.R.38 { @ VIA1 enclosure by M1 >= 0 in SRAMDMY (186;0)
  (SRAM_VIA1i NOT SRAM_M1) INSIDE SRAMDMY_SRM_3
}

//SRAM.R.39 is checked by SRAM.R.39__SRAM.R.40
//SRAM.R.40 is checked by SRAM.R.39__SRAM.R.40
SRAM.R.39__SRAM.R.40 { @ VIA1 enclosure by M1 [at least two opposite sides] >= ^SRAM_R_39 or Enclosure by M1 [all sides] >= ^SRAM_R_40
  X = RECTANGLE ENCLOSURE SRAM_SQR_VIA1i SRAM_M1 ABUT < 90 SINGULAR GOOD 0 SRAM_R_39 OPPOSITE 0 SRAM_R_39 OPPOSITE
  (ENC X SRAM_M1 < SRAM_R_40 ABUT < 90 SINGULAR REGION) INSIDE SRAMDMY_SRM_3
}


SRAM_SQR_VIA2i_SRM18 = SRAM_SQR_VIA2i INSIDE SRM_18
SRAM_SQR_VIA2i_NSRM18 = SRAM_SQR_VIA2i NOT INSIDE SRM_18

//SRAM.R.41 is checked by {SRAM.R.43__SRAM.R.44} or {SRAM.R.43.1__SRAM.R.44}
SRAM.R.43__SRAM.R.44 { @ VIA2 enclosure by M2 [at least two opposite sides] >= ^SRAM_R_43 or Enclosure by M2 [all sides] >= ^SRAM_R_44, except SRM_18
	X = RECTANGLE ENCLOSURE SRAM_SQR_VIA2i_NSRM18 SRAM_M2 ABUT < 90 SINGULAR GOOD 0 SRAM_R_43 OPPOSITE 0 SRAM_R_43 OPPOSITE
  (ENC X SRAM_M2 < SRAM_R_44 ABUT < 90 SINGULAR REGION) INSIDE SRAMDMY_SRM_3
}

SRAM.R.43.1__SRAM.R.44 { @ VIA2 enclosure by M2 [at least two opposite sides] in SRM_18 >= ^SRAM_R_43_1 or Enclosure by M2 [all sides] >= ^SRAM_R_44
	X = RECTANGLE ENCLOSURE SRAM_SQR_VIA2i_SRM18 SRAM_M2 ABUT < 90 SINGULAR GOOD 0 SRAM_R_43_1 OPPOSITE 0 SRAM_R_43_1 OPPOSITE
  (ENC X SRAM_M2 < SRAM_R_44 ABUT < 90 SINGULAR REGION) INSIDE SRAMDMY_SRM_3
}
//SRAM.R.43 is checked by SRAM.R.43__SRAM.R.44
//SRAM.R.44 is checked by SRAM.R.43__SRAM.R.44
//SRAM.R.43.1 is checked by SRAM.R.43.1__SRAM.R.44

SRAM.R.45 { @ Enclosure of rectangular VIA1 by M1 >= ^SRAM_R_45
    (ENC SRAM_REC_VIA1i SRAM_M1 < SRAM_R_45 ABUT < 90 OPPOSITE REGION) INSIDE SRAMDMY_SRM_3
}
  
SRAM.R.46 { @ Enclosure of rectangular VIA2 by M2 >= 0 , VIA2 fully inside M2
    (SRAM_REC_VIA2i NOT SRAM_M2) INSIDE SRAMDMY_SRM_3
}

SRAM.R.47 { @ VIA2 enclosure by M2 [0.16 um >= metal width > 0.07 um, space < 0.1 um (D1) and parallel run length > 0.1 um]
                  @ For SRAM.R.44, the rule check is not included same VIA2 group, which is defined as below.                  
		  @ 1. VIAx space to neighboring VIA2 <= 0.11 um                   
		  @ 2. M2 is same net >= 0.005
  SRAM_M2_W_160 = (SRAM_M2 WITH WIDTH > SRAM_R_47_W1 <=SRAM_R_47_W2) NOT OUTSIDE SRAMDMY_SRM_3
  SRAM_SAME_NET_VIA2 = (M2i AND M3i) NOT OUTSIDE SRAMDMY_SRM_3
  VIA2_M = SIZE SRAM_VIA2i BY SRAM_R_47_S/2 INSIDE OF SRAM_SAME_NET_VIA2 STEP M2_S_1*0.6
  VIA2_C = SRAM_VIA2i NOT INTERACT (VIA2_M INTERACT SRAM_VIA2i >= 2)
  A = EXT SRAM_M2_W_160 [SRAM_M2] < SRAM_R_47_D1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A SRAM_M2 < SRAM_R_47_D1 ABUT < 90 OPPOSITE REGION
  C = EXT A SRAM_M2 < SRAM_R_47_D1 ABUT < 90 OPPOSITE
  D = EXT A [SRAM_M2] < SRAM_R_47_D1 ABUT < 90 OPPOSITE
  E = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI   [-= EC(C) ] > SRAM_R_47_L
  F = D COIN OUTSIDE EDGE E
  (ENC VIA2_C F < SRAM_R_47 ABUT < 90 OPPOSITE REGION) INSIDE SRAMDMY_SRM_3
}

SRAM.R.48 { @ VIA1 enclosure by M1 [4.5 um >= metal width > 0.16 um, space < 0.13 um and parallel run length > 0.1 um] >= 0.005
 SRAM_M1_W_450 = (SRAM_M1 WITH WIDTH > SRAM_R_48_W1 <=SRAM_R_48_W2) NOT OUTSIDE SRAMDMY_SRM_3
 A = EXT SRAM_M1_W_450 [SRAM_M1] < SRAM_R_48_D1 ABUT < 90 OPPOSITE MEASURE ALL
 B = EXT A SRAM_M1 < SRAM_R_48_D1 ABUT < 90 OPPOSITE REGION
 C = EXT A SRAM_M1 < SRAM_R_48_D1 ABUT < 90 OPPOSITE
 D = EXT A [SRAM_M1] < SRAM_R_48_D1 ABUT < 90 OPPOSITE
 E = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
   [-= EC(C) ] > SRAM_R_48_L
 F = D COIN OUTSIDE EDGE E
 (ENC SRAM_VIA1i F < SRAM_R_48 ABUT < 90 OPPOSITE REGION) INSIDE SRAMDMY_SRM_3
}

SRAM.R.49:M2 { @ Space [at least one metal line width > 0.16 um (W2) and the parallel run lengths > 0.22 um (L2)] (union projection) >= 0.1 
  	       @ Except space >= 0.09 in SRM(50;13)
  SRAM_M2_160 = (M2 WITH WIDTH > SRAM_R_49_W) NOT OUTSIDE SRAMDMY_SRM_3
  X1 = ((EXT SRAM_M2_160 M2 < SRAM_R_49A OPPOSITE REGION MEASURE ALL) NOT OUTSIDE SRAMDMY_SRM_3) INSIDE SRM_13
  X2 = ((EXT SRAM_M2_160 M2 < SRAM_R_49B OPPOSITE REGION MEASURE ALL) NOT OUTSIDE SRAMDMY_SRM_3) NOT INSIDE SRM_13
  Y = (X1 OR X2) NOT M2
  ENCLOSE RECTANGLE Y GRID SRAM_R_49_L+GRID
}

SRAM.R.49:M3 { @ Space [at least one metal line width > 0.16 um (W2) and the parallel run lengths > 0.22 um (L2)] (union projection) >= 0.1 
  	       @ Except space >= 0.09 in SRM(50;13)
  SRAM_M3_160 = (M3 WITH WIDTH > SRAM_R_49_W) NOT OUTSIDE SRAMDMY_SRM_3
  X1 = ((EXT SRAM_M3_160 M3 < SRAM_R_49A OPPOSITE REGION MEASURE ALL) NOT OUTSIDE SRAMDMY_SRM_3) INSIDE SRM_13
  X2 = ((EXT SRAM_M3_160 M3 < SRAM_R_49B OPPOSITE REGION MEASURE ALL) NOT OUTSIDE SRAMDMY_SRM_3) NOT INSIDE SRM_13
  Y = (X1 OR X2) NOT M3
  ENCLOSE RECTANGLE Y GRID SRAM_R_49_L+GRID
}


SRAM.R.50 { @ Space at M2 line-end (W < 0.07um) in a line-end configuration: If M2 has parallel run length with opposite M2 (measured with T = 0.025 um extension), then end to line space (S1) needs to be at least this value >= 0.055
  A = CONVEX EDGE SRAM_M2 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < SRAM_R_50_W
  (EXT A SRAM_M2 < SRAM_R_50 ABUT < 90 OPPOSITE EXTENDED SRAM_R_50_T REGION) INSIDE SRAMDMY_SRM_3
}

SRAM.R.51 { @ Space at M2 line-end (W < 0.07 um, Q = 0.07 um) in a dense line-end configuration: If M2 has parallel run lengths with opposite M2 (measured with T = 0.025 um extension) along 2 adjacent edges of M2 [any one edge < Q distance from the corner of the 2 edges], and side to side space (S2) + Mx width (W), pitch < 0.115 um, then end to line space (S1) and M2 enclose VIA1 (V) needs to be at least this value. 1 This check doesn't include small jog with edge lengths < 0.05 um (R). 2 The following conditions can pass the check flow. 1 S2+W, pitch < 0.115 um, S1 >= 0.08 um, and M2 enclosure VIA1 >= 0.05 um 2 S2+W, pitch < 0.115 um, S1 >= 0.1 um, and M2 enclosure VIA1 >= 0.03 um (>= 0.06/0.05 or 0.1/0.03 in SRM(50;13), others >= 0.08/0.05 or 0.1/0.03)
  M2_END = CONVEX EDGE SRAM_M2 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < SRAM_R_51_W
  M2_LINE = SRAM_M2 NOT TOUCH EDGE M2_END
  M2_EA = ENC SRAM_VIA1i [M2_END] < SRAM_R_51_EA ABUT < 90 OPPOSITE
  M2_SA1 = (EXT [M2_END] M2_LINE < SRAM_R_51_SA ABUT < 90 OPPOSITE EXTENDED SRAM_R_51_T) NOT INSIDE EDGE SRM_13
  M2_SA2 = (EXT [M2_END] M2_LINE < SRAM_R_51_SA2 ABUT < 90 OPPOSITE EXTENDED SRAM_R_51_T) INSIDE EDGE SRM_13
  M2_EB = ENC SRAM_VIA1i [M2_END] < SRAM_R_51_EB ABUT < 90 OPPOSITE
  M2_SB = EXT [M2_END] M2_LINE < SRAM_R_51_SB ABUT < 90 OPPOSITE EXTENDED SRAM_R_51_T
  M2_PASS_A = ((M2_END NOT TOUCH INSIDE EDGE M2_EA) NOT TOUCH INSIDE EDGE M2_SA1) NOT TOUCH INSIDE EDGE M2_SA2
  M2_PASS_B = (M2_END NOT TOUCH INSIDE EDGE M2_EB) NOT TOUCH INSIDE EDGE M2_SB
  M2_CHECK = (M2_END NOT TOUCH INSIDE EDGE M2_PASS_A) NOT TOUCH INSIDE EDGE M2_PASS_B
 
  M2_Long_side = LENGTH SRAM_M2 >= SRAM_R_51_R
  O = INT M2_CHECK [M2_Long_side] < SRAM_R_51_Q-SRAM_R_51_T ABUT == 90 INTERSECTING ONLY
  PW = INT O SRAM_M2 < (SRAM_R_51_P - M2_S_1) ABUT < 90 OPPOSITE EXTENDED SRAM_R_51_T
  PS = EXT O SRAM_M2 < (SRAM_R_51_P - M2_W_1) ABUT < 90 OPPOSITE EXTENDED SRAM_R_51_T
  Q = DFM PROPERTY O PS PW OVERLAP ABUT ALSO MULTI
     [-= MIN(EW(PW)) + MIN(EW(PS))] < SRAM_R_51_P
  R = M2_CHECK TOUCH EDGE (EXPAND EDGE Q INSIDE BY 0.001)

  (ENC SRAM_VIA1i R < SRAM_R_51_EA ABUT < 90 OPPOSITE REGION) NOT OUTSIDE SRAMDMY_SRM_3
  (EXT R SRAM_M2 < SRAM_R_51_SB ABUT < 90 OPPOSITE EXTENDED SRAM_R_51_T REGION) NOT OUTSIDE SRAMDMY_SRM_3
}
SRAM.R.52 { @ Space at M2 line-end (W < 0.07 um) in a line-end configuration: If M2 has parallel run lengths with opposite M2 (measured with T = 0.025 um extension), then end to end space (S3) needs to be at least this value >= 0.07
  A = CONVEX EDGE SRAM_M2 ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH < SRAM_R_52_W
  (EXT A < SRAM_R_52 ABUT < 90 OPPOSITE EXTENDED SRAM_R_52_T REGION) NOT OUTSIDE SRAMDMY_SRM_3
}
VARIABLE  SRAM_R_53_2	 0.015
VARIABLE  SRAM_R_53_2_A	 0.005

//SRAM.R.53.0 is checked by SRAM.R.53__SRAM.R.53.1
//SRAM.R.53 is checked by SRAM.R.53__SRAM.R.53.1
//SRAM.R.53.1 is checked by SRAM.R.53__SRAM.R.53.1
SRAM.R.53__SRAM.R.53.1 { @ The layer covered SRAMDMY(186;0), enclosure of square VIA1 [at least two opposite sides] >= ^SRAM_R_53
                         @ Enclosure of VIA1 square [at least two opposite sides] >= 0.025 um OR Enclosure of VIA1 [all sides] >= ^SRAM_R_53_1
  Y = (RECTANGLE ENCLOSURE SRAM_SQR_VIA1i SRAM_M2 ABUT < 90 SINGULAR GOOD 0 SRAM_R_53 OPPOSITE 0 SRAM_R_53 OPPOSITE) INSIDE SRAMDMY_SRM_3
  (ENC Y SRAM_M2 < SRAM_R_53_1 ABUT < 90 SINGULAR REGION) INSIDE SRAMDMY_SRM_3
}

SRAM.R.54 { @ M2 enclosure of VIA1 [0.16 um >= metal width > 0.07 um, space < 0.1 um (D1) and parallel run length > 0.1 um] (this rule check is not included same VIA1 group, which is defined as below.) 1. VIA1 space to neighboring VIA1 <= 0.11 um 2. M2 is same net >= 0.005
  SRAM_M2_W_160b = (SRAM_M2 WITH WIDTH > SRAM_R_54_W1 <=SRAM_R_54_W2) NOT OUTSIDE SRAMDMY_SRM_3
  SRAM_SAME_NET_VIA1 = (SRAM_M1i AND SRAM_M2i) NOT OUTSIDE SRAMDMY_SRM_3
  VIA1_M = SIZE SRAM_VIA1i BY SRAM_R_54_S/2 INSIDE OF SRAM_SAME_NET_VIA1 STEP M1_S_1*0.6
  VIA1_C = SRAM_VIA1i NOT INTERACT (VIA1_M INTERACT SRAM_VIA1i >= 2)
  A = EXT SRAM_M2_W_160b [SRAM_M2] < SRAM_R_54_D1 ABUT < 90 OPPOSITE MEASURE ALL
  B = EXT A SRAM_M2 < SRAM_R_54_D1 ABUT < 90 OPPOSITE REGION
  C = EXT A SRAM_M2 < SRAM_R_54_D1 ABUT < 90 OPPOSITE
  D = EXT A [SRAM_M2] < SRAM_R_54_D1 ABUT < 90 OPPOSITE
  E = DFM PROPERTY B C OVERLAP ABUT ALSO MULTI
    [-= EC(C) ] > SRAM_R_54_L
  F = D COIN OUTSIDE EDGE E
  (ENC VIA1_C F < SRAM_R_54 ABUT < 90 OPPOSITE REGION) INSIDE SRAMDMY_SRM_3
}

SRAM.R.55 { @ SRAMDMY(186;0) profile must be rectangular 
	MERGE (NOT RECTANGLE SRAMDMY ORTHOGONAL ONLY)
}

#IFDEF N22_ULL
SRAM.R.56 { @ SRM_ULL(50;28) must be drawn in identically to SRAMDMY;0 (186;0)
  SRAMDMY_CHK = SRAMDMY INTERACT SRM_ULL
	SRM_ULL XOR SRAMDMY_CHK
}
#ENDIF

SRAM.M2.A.2 { @ M2 area >= 0.0119 
   (AREA SRAM_M2 < SRAM_M2_A_2) INSIDE SRAMDMY_SRM_3
  }
//SRAM.M2.S.0 is checked by SRAM.M2.S.1 and SRAM.M2.S.2
SRAM.M2.S.1 { @ Rectangle M2 [Area < 0.014 um2] space to M2 [at least 2 opposite sides] >= 0.055 
   M2_CHK_1 = (AREA SRAM_M2 < SRAM_M2_S_1_A) INSIDE SRAMDMY_SRM_3
   M2_CHK_2 = EXT [M2_CHK_1] SRAM_M2 < SRAM_M2_S_1 ABUT < 90 SINGULAR
   M2_CHK_2_1 = M2_CHK_2 TOUCH EDGE M2_CHK_1
   M2_CHK_1 WITH EDGE M2_CHK_2_1 >= 3
   INT M2_CHK_2_1 < GRID ABUT == 90 INTERSECTING ONLY REGION
   M2_CHK_3 = M2_CHK_1 NOT TOUCH EDGE M2_CHK_2_1
   EXT M2_CHK_3 SRAM_M2 < SRAM_M2_S_1 ABUT < 90 REGION
}
SRAM.M2.S.2 { @ M2 [Area < 0.014 um2] space to M2 [at least one edge at each corner] >= 0.055 
  A = (AREA SRAM_M2 < SRAM_M2_S_1_A) INSIDE SRAMDMY_SRM_3
  A_CONVEX_CORNER = INT [A] < GRID ABUT == 90 INTERSECTING ONLY
  A_CONCAVE_CORNER = EXT [A] < GRID ABUT == 90 INTERSECTING ONLY
  A_CONCAVE_CORNER_IN1 = EXPAND EDGE A_CONCAVE_CORNER INSIDE BY GRID CORNER FILL
  A_CONCAVE_CORNER_IN2 = EXPAND EDGE A_CONCAVE_CORNER INSIDE BY GRID 
  A_CONCAVE_CORNER_CHK = (A_CONCAVE_CORNER_IN1 NOT A_CONCAVE_CORNER_IN2) COIN OUTSIDE EDGE A_CONCAVE_CORNER_IN2
 
  B_CONVEX_CORNER = INT [SRAM_M2] < GRID ABUT == 90 INTERSECTING ONLY
  B_CONCAVE_CORNER = EXT [SRAM_M2] < GRID ABUT == 90 INTERSECTING ONLY
  B_CONCAVE_CORNER_IN1 = EXPAND EDGE B_CONCAVE_CORNER INSIDE BY GRID CORNER FILL
  B_CONCAVE_CORNER_IN2 = EXPAND EDGE B_CONCAVE_CORNER INSIDE BY GRID 
  B_CONCAVE_CORNER_CHK = (B_CONCAVE_CORNER_IN1 NOT B_CONCAVE_CORNER_IN2) COIN OUTSIDE EDGE B_CONCAVE_CORNER_IN2

  Err_A = EXT A_CONVEX_CORNER B_CONCAVE_CORNER_CHK < SRAM_M2_S_1 SQUARE CORNER TO CORNER >= 0
  DFM COPY Err_A TIE
  Err_B = EXT A_CONCAVE_CORNER_CHK B_CONVEX_CORNER < SRAM_M2_S_1 SQUARE CORNER TO CORNER >= 0
  DFM COPY Err_B TIE
  }

SRAM.OD.W.1 { @ Width of OD [INSIDE SRAMDMY OR SRM_3] >= 0.04 
  OD_CHK = ODi INSIDE SRAMDMY_SRM_3
  INT OD_CHK < SRAM_OD_W_1 ABUT < 90 SINGULAR REGION
}

SRAM.OD.W.2 { @ Width of SRM_10 PU OD Edge_Region The definition of SRM_10 PU OD Edge_Region: Expand the vertical edge [length > 0.020 um] of {{{OD AND NW} INTERACT PP} INSIDE SRM (test0) {50;10}} INSIDE BY 0.08 um >= 0.045 
  CHK_pre1 = ((ODi AND NWi) INTERACT PPi) INSIDE SRM_10
  CHK_pre2 = ANGLE CHK_pre1 == 90
  CHK_pre3 = LENGTH CHK_pre2 > SRAM_OD_W_2_L
  CHK = EXPAND EDGE CHK_pre3 INSIDE BY SRAM_OD_W_2_E
  INT CHK < SRAM_OD_W_2 ABUT < 90 OPPOSITE REGION
}

SRAM.OD.A.1 { @ Area of OD [INSIDE SRAMDMY OR SRM_3] (Except OD X*Y in horizontal direction = 0.16 um*0.095 um, 0.17 um*0.090 um, 0.180*0.085 um um, 0.155 um*0.100 um, 0.15 um*0.105 um, and 0.175 um*0.090 um) >= 0.016 
  OD_CHK = ODi INSIDE SRAMDMY_SRM_3
  OD_GOOD1 = RECTANGLE OD_CHK == SRAM_OD_A_1_W1 BY == SRAM_OD_A_1_L1 ORTHOGONAL ONLY FIXED 
  OD_GOOD2 = RECTANGLE OD_CHK == SRAM_OD_A_1_W2 BY == SRAM_OD_A_1_L2 ORTHOGONAL ONLY FIXED 
  OD_GOOD3 = RECTANGLE OD_CHK == SRAM_OD_A_1_W3 BY == SRAM_OD_A_1_L3 ORTHOGONAL ONLY FIXED 
  OD_GOOD4 = RECTANGLE OD_CHK == SRAM_OD_A_1_W4 BY == SRAM_OD_A_1_L4 ORTHOGONAL ONLY FIXED 
  OD_GOOD5 = RECTANGLE OD_CHK == SRAM_OD_A_1_W5 BY == SRAM_OD_A_1_L5 ORTHOGONAL ONLY FIXED 
  OD_GOOD6 = RECTANGLE OD_CHK == SRAM_OD_A_1_W6 BY == SRAM_OD_A_1_L6 ORTHOGONAL ONLY FIXED 
  CHK = OD_CHK NOT INTERACT (OR OD_GOOD1 OD_GOOD2 OD_GOOD3 OD_GOOD4 OD_GOOD5 OD_GOOD6)
  AREA CHK < SRAM_OD_A_1 
}
SRAM.PO.W.1 { @ Width of {PO AND OD} [INSIDE SRAMDMY OR SRM_3] in horizontal direction (Except RODMY (49;0), {SRM_18 (50;18) NOT SRM (50;0)}, and {{PO AND {SRM_18 (50;18) AND SRM (50;0)}} NOT INTERACT SRAMDMY;1 (186;1)}) = 0.035 
  WAIVE_REGION = RODMY OR ((SRM_18 NOT SRM) OR ((POi AND (SRM_18 AND SRM)) NOT INTERACT SRAMDMY_1))
  CHK_pre = (POi AND ODi) INSIDE SRAMDMY_SRM_3
  CHK = ANGLE CHK_pre == 90
  GOOD = INT CHK == SRAM_PO_W_1 OPPOSITE REGION
  (CHK_pre NOT GOOD) NOT INSIDE WAIVE_REGION
}

SRAM.CPO.W.1 { @ Width of CPO [INSIDE SRAMDMY OR SRM_3] (Except {{NP AND NW} OR {PP NOT NW}}) = 0.06 
  WAIVE_REGION = (NPi AND NWi) OR (PPi NOT NWi)
  CPO_CHK = CPO INSIDE SRAMDMY_SRM_3
  (CPO_CHK NOT WITH WIDTH == SRAM_CPO_W_1) NOT INSIDE WAIVE_REGION
}

SRAM.PP.S.1 { @ Space of PP [INSIDE SRAMDMY OR SRM_3] >= 0.125 
  PP_CHK = PPi INSIDE SRAMDMY_SRM_3
  EXT PP_CHK < SRAM_PP_S_1 ABUT < 90 SINGULAR REGION
}

SRAM.PP.S.2 { @ Space of PP [INSIDE SRM_11 (50;11), SRM_13 (50;13), and SRM_18 (50;18)] >= 0.13 
  PP_CHK = PPi INSIDE (OR SRM_11 SRM_13 SRM_18)
  EXT PP_CHK < SRAM_PP_S_2 ABUT < 90 SINGULAR REGION
}

SRAM.PP.A.1 { @ Area of PP [INSIDE SRAMDMY OR SRM_3] (Except PP X*Y in horizontal direction= 0.2 um*0.35 um) >= 0.076 
  PP_CHK = PPi INSIDE SRAMDMY_SRM_3
  PP_GOOD1 = RECTANGLE PP_CHK == SRAM_PP_A_1_W1 BY == SRAM_PP_A_1_L1 ORTHOGONAL ONLY FIXED 
  CHK = PP_CHK NOT INTERACT PP_GOOD1
  AREA CHK < SRAM_PP_A_1 
}

SRAM.NP.W.1 { @ Width of NP [INSIDE SRAMDMY OR SRM_3] >= 0.125 
  NP_CHK = NPi INSIDE SRAMDMY_SRM_3
  INT NP_CHK < SRAM_NP_W_1 ABUT < 90 SINGULAR REGION
}

SRAM.NP.W.2 { @ Width of NP [INSIDE SRM_11 (50;11), SRM_13 (50;13), and SRM_18 (50;18)] >= 0.13 
  NP_CHK = NPi INSIDE (OR SRM_11 SRM_13 SRM_18)
  INT NP_CHK < SRAM_NP_W_2 ABUT < 90 SINGULAR REGION
}

SRAM.TGO_EHVT.R.1 { @ {TGO_EHVT (255;99) AND SRM (50;0)} must be completely covered by {SRM_ULL (50;28) AND SRM_11 (50;11)}   
    (TGO_EHVT AND SRM) NOT (SRM_ULL AND SRM_11)
}

SRAM.M1.W.1 { @ Width of M1 {Except M1 INTERACT BTC} [INSIDE SRAMDMY OR SRM_3] (Except SRM_18 (50;18), L-shape M1 [area = 0.0123 um2, INSIDE SRM (test0) {50;10}], and L-shape M1 [area = 0.0132 um2, INSIDE SRM_11 (50;11)]) >= 0.055 
  M1_CHK_pre = SRAM_M1 NOT INTERACT SRAM_BCO
  M1_NOT_RECT = NOT RECTANGLE M1 ORTHOGONAL ONLY
  L_M1 = (VERTEX M1_NOT_RECT == 6) WITH EDGE (CONVEX EDGE M1_NOT_RECT ANGLE1 == 270 ANGLE2 == 90)
  L_M1_CHK1 = (AREA L_M1 == SRAM_M1_W_1_A1) INSIDE SRM_10
  L_M1_CHK2 = (AREA L_M1 == SRAM_M1_W_1_A2) INSIDE SRM_11
  M1_CHK = M1_CHK_pre NOT INTERACT (L_M1_CHK1 OR L_M1_CHK2)
  ((INT M1_CHK < SRAM_M1_W_1 ABUT < 90 SINGULAR REGION) INSIDE SRAMDMY_SRM_3) NOT INSIDE SRM_18
}

SRAM.M1.S.1 { @ Space of M1 {Except M1 INTERACT BTC} [INSIDE SRAMDMY OR SRM_3] >= 0.05 
  M1_CHK = SRAM_M1 NOT INTERACT SRAM_BCO
  (EXT M1_CHK < SRAM_M1_S_1 ABUT < 90 SINGULAR REGION) INSIDE SRAMDMY_SRM_3
}


SRAM.M1.A.1 {@ Area of M1 [INSIDE SRAMDMY OR SRM_3] (Except M1 X*Y in horizontal direction= 0.09 um*0.1 um, 0.16 um*0.06 um, 0.11 um*0.085 um, 0.095 um*0.095 um) >= 0.01 
  M1_GOOD1 = RECTANGLE SRAM_M1 == SRAM_M1_A_1_W1 BY == SRAM_M1_A_1_L1 ORTHOGONAL ONLY FIXED
  M1_GOOD2 = RECTANGLE SRAM_M1 == SRAM_M1_A_1_W2 BY == SRAM_M1_A_1_L2 ORTHOGONAL ONLY FIXED
  M1_GOOD3 = RECTANGLE SRAM_M1 == SRAM_M1_A_1_W3 BY == SRAM_M1_A_1_L3 ORTHOGONAL ONLY FIXED
  M1_GOOD4 = RECTANGLE SRAM_M1 == SRAM_M1_A_1_W4 BY == SRAM_M1_A_1_L4 ORTHOGONAL ONLY FIXED
  CHK = SRAM_M1 NOT INTERACT (OR M1_GOOD1 M1_GOOD2 M1_GOOD3 M1_GOOD4)
  (AREA CHK < SRAM_M1_A_1) INSIDE SRAMDMY_SRM_3
}

SRAM.M2.W.1 { @ Width of M2 [INSIDE SRAMDMY OR SRM_3] {Excpet SRM_13 (50;13)} >= 0.055 
  ((INT SRAM_M2 < SRAM_M2_W_1 ABUT < 90 SINGULAR REGION) INSIDE SRAMDMY_SRM_3) NOT INSIDE SRM_13
}

SRAM.M2.A.1 {@ Area of M2 [INSIDE SRAMDMY OR SRM_3] (Except M2 X*Y in horizontal direction= 0.085 um*0.14 um, 0.07 um*0.175 um) >= 0.0125 
  M2_GOOD1 = RECTANGLE SRAM_M2 == SRAM_M2_A_1_W1 BY == SRAM_M2_A_1_L1 ORTHOGONAL ONLY FIXED
  M2_GOOD2 = RECTANGLE SRAM_M2 == SRAM_M2_A_1_W2 BY == SRAM_M2_A_1_L2 ORTHOGONAL ONLY FIXED
  CHK = SRAM_M2 NOT INTERACT (OR M2_GOOD1 M2_GOOD2)
  (AREA CHK < SRAM_M2_A_1) INSIDE SRAMDMY_SRM_3
}






// MFUSE CHECK
//=============
MFUSE.R.1 {@ MetalFuseLinkOPC must be fully covered by MetalFuse; MetalFuse must interact with MetalFuseLinkOPC. 156;2 (MetalFuse) includes all fuse cell and purpose for DRC error waive 156;12 (MetalFuseLinkOPC) covers fuse link area   
 MFUSELINK NOT MFUSE
 MFUSE NOT INTERACT MFUSELINK
}
MFUSE.R.2 { @ MetalFuse (152;2) must overlap M2
  A = MFUSE AND M2i
  MFUSE NOT ENCLOSE A
}

MFUSE.R.3 { @ MetalFuse (156;2) must be inside DM1EXCL (150;1), DM2EXCL (150;2), DM3EXCL (150;3), DM4EXCL (150;4), DM5EXCL (150;5), ODBLK (150;20), POBLK (150;21). MetalFuse (156;2) must overlap DM1EXCL (150;1), DM2EXCL (150;2), DM3EXCL (150;3), DM4EXCL (150;4), DM5EXCL (150;5), ODBLK (150;20), POBLK (150;21) at the same time
  MFUSE NOT INSIDE DM1EXCL
  MFUSE NOT INSIDE DM2EXCL
  MFUSE NOT INSIDE DM3EXCL
  MFUSE NOT INSIDE DM4EXCL
  MFUSE NOT INSIDE DM5EXCL
  MFUSE NOT INSIDE ODBLK
  MFUSE NOT INSIDE POBLK
}



