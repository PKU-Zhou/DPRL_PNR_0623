// DFM 
Block = (LOGO OR SRCSR_P4) OR LMARK 

// Nodal NWEL connectivity checks
ILP1i = (POi NOT RPO_RPDMY) NOT (CPO OR CPO_SRM) // Interconnect poly not CPO
NONWRi = NWi NOT INTERACT NWDMY 
NWRiT = (NWi INTERACT NWDMY) NOT NWDMY // NWR terminal  
DNW_NWi = NWi INTERACT DNWi
RWi = ((HOLES DNW_NWi) NOT DNW_NWi) INSIDE DNWi

NPODi = NPi AND ODi
PPODi = PPi AND ODi
NACTi = NPODi NOT NWi
PACTi = PPODi AND NWi
NSDi  = NACTi NOT POi		// NMOS source/drain
NSDc  = NSDi NOT RPO_RPDMY	// NMOS source/drain for connection
PSDi  = PACTi NOT POi		// PMOS source/drain
PSDc  = PSDi NOT RPO_RPDMY	// PMOS source/drain for connection
ODc = (NSDc OR PSDc) OR (PSTPi OR NSTPi)
NSTPi = NPODi AND NONWRi        // Break the connection at NWR  
PSTPi = PPODi NOT NWi
RVi_CBi = RVi OR CBi
CTM8i = CTM_F INSIDE CTMDMY_8
CBM8i = CBM_F INSIDE CTMDMY_8
CTM9i = CTM_F INSIDE CTMDMY_9
CBM9i = CBM_F INSIDE CTMDMY_9



#IFDEF WIRE_BOND
CB1i = COPY CBi
CB2i = COPY CB2Wi
#ELSE
CB1i = COPY CBDi
CB2i = COPY CB2Fi
#ENDIF

EMPTYk = SIZE EMPTYi BY 2
 USE_NET_SYN = CHIP INTERACT ( OR  POV_sync M1V_sync  M2V_sync  M3V_sync  M4V_sync  M5V_sync  M6V_sync  M7V_sync  M8V_sync  M9V_sync  APV_sync)
































