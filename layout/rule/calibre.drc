M5_NOTCH_candidate17 = M5_NOTCH_candidate15 NOT TOUCH EDGE (M5_NOTCH_candidate15 NOT COIN EDGE M5_NOTCH_candidate16)
M5_NOTCH_candidate18 = M5_NOTCH_candidate13 WITH EDGE M5_NOTCH_candidate17 == 2

M5_NOTCH_candidate19 = M5_NOTCH_candidate2 INTERACT M5_NOTCH_candidate18
M5_NOTCH_candidate20 = M5_NOTCH_L_END_edge COIN EDGE M5_NOTCH_candidate19
M5_NOTCH_candidate21 = INT M5_NOTCH_candidate20 [M5_NOTCH_candidate19] <= COMB_S2 ABUT < 90 OPPOSITE
M5_NOTCH_candidate22 = (M5_NOTCH_candidate19 NOT COIN EDGE M5_NOTCH_candidate20) NOT COIN EDGE M5_NOTCH_candidate21
