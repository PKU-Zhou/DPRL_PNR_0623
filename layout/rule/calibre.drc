VARIABLE ap_thickness 2.8 // user value


MOM.S.2:M1 { @ Space of metal (M1/Mx) line-end in MOMDMY_n >= 0.1 
  EXT MOM_M1_LINE_END M1 < MOM_S_2 ABUT < 90 REGION
}
// MOM.S.2 is checked by MOM.S.2:M1
MOM.S.2:M2 { @ Space of metal (M1/Mx) line-end in MOMDMY_n >= 0.1 
  EXT MOM_M2_LINE_END M2 < MOM_S_2 ABUT < 90 REGION
}
// MOM.S.2 is checked by MOM.S.2:M2
MOM.S.2:M3 { @ Space of metal (M1/Mx) line-end in MOMDMY_n >= 0.1 
  EXT MOM_M3_LINE_END M3 < MOM_S_2 ABUT < 90 REGION
}
// MOM.S.2 is checked by MOM.S.2:M3
MOM.S.2:M4 { @ Space of metal (M1/Mx) line-end in MOMDMY_n >= 0.1 
  EXT MOM_M4_LINE_END M4 < MOM_S_2 ABUT < 90 REGION
}
// MOM.S.2 is checked by MOM.S.2:M4
MOM.S.2:M5 { @ Space of metal (M1/Mx) line-end in MOMDMY_n >= 0.1 
  EXT MOM_M5_LINE_END M5 < MOM_S_2 ABUT < 90 REGION
}
// MOM.S.2 is checked by MOM.S.2:M5
MOM.S.2:M6 { @ Space of metal (M1/Mx) line-end in MOMDMY_n >= 0.1 
  EXT MOM_M6_LINE_END M6 < MOM_S_2 ABUT < 90 REGION
}
// MOM.S.2 is checked by MOM.S.2:M6
MOM.S.2:M7 { @ Space of metal (M1/Mx) line-end in MOMDMY_n >= 0.1 
  EXT MOM_M7_LINE_END M7 < MOM_S_2 ABUT < 90 REGION
}
// MOM.S.2 is checked by MOM.S.2:M7
MOM.R.1 { @ VIA in MOMDMY is not allowed   
  MOMDMY_1 AND VIA1
  MOMDMY_2 AND VIA1
  MOMDMY_2 AND VIA2
  MOMDMY_3 AND VIA2
  MOMDMY_3 AND VIA3
  MOMDMY_4 AND VIA3
  MOMDMY_4 AND VIA4
  MOMDMY_5 AND VIA4
  MOMDMY_5 AND VIA5
  MOMDMY_6 AND VIA5
  MOMDMY_6 AND VIA6
  MOMDMY_7 AND VIA6
  MOMDMY_7 AND VIA7
  MOMDMY_8 AND VIA7
  MOMDMY_8 AND VIA8
  MOMDMY_9 AND VIA8
  MOMDMY_9 AND RV
  MOMDMY_AP AND RV
}


#IFDEF FULL_CHIP
MOM.R.2 { @ Each MOM cell must be covered by MOMDMY_n (CAD layer: n = 155;1~155;n (n=top metal), 155;20). DRC only flags no MOMDMY_n (n = 155;1~155;n 155;20) in the chip. But if there is no MOM cell in the chip, the violation can be waived   
 MERGE (CHIP NOT INTERACT MOMDMY_n)
}
#ENDIF

#ENDIF // BACK_END
#ENDIF // ESD_LUP_RULE_CHECK_ONLY
#ENDIF // VOLTAGE_RULE_CHECK_ONLY
#ENDIF // EFP_ONLY
#ENDIF // DFM_ONLY




#IFNDEF DFM_ONLY
#IFNDEF EFP_ONLY
