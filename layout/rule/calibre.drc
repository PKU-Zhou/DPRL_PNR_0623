RR:RE:EFP.M6.S.7 { @ Metal bridge recommendation type-3: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3 and Region B4] when neighboring Mx (polygon3/4) with parallel run length > 0 um and there is no other Mx interact Region B1/B2 Definitions: 1. Region B3/B4 = 0.25 um * 0.09 um (L1), generated from vertex CB and CA respectively. 2. L2 = height difference of vertex CA project to vertex CB <= 0.05 um. 3. Region B1/B2 = 0.16 um * 0.115 um, generated from Mx (polygon3/4) line-end with vertex CA and CB respectively >= 0.055 
  M6_TypeBRS3_prefilter_1 = EXT [M6i] == TypeBRS3_S2 ABUT < 90 OPPOSITE
  M6_TypeBRS3_prefilter_2 = M6i TOUCH EDGE M6_TypeBRS3_prefilter_1
  M6_TypeBRS3_prefilter_3 = (M6_CORNER WITH EDGE M6_TypeBRS3_prefilter_2) COIN EDGE M6i
  
  M6_TypeBRS3_prefilter_4_1 = EXT M6_TypeBRS3_prefilter_3 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
  M6_TypeBRS3_prefilter_4_2 = M6i AND M6_TypeBRS3_prefilter_4_1
  M6_TypeBRS3_prefilter_4_3 = EXT [M6_TypeBRS3_prefilter_3] M6_TypeBRS3_prefilter_4_2 <= Mx_S OPPOSITE EXTENDED TypeBRS3_S6
  M6_TypeBRS3_prefilter_4_4 = M6_TypeBRS3_prefilter_3 TOUCH EDGE M6_TypeBRS3_prefilter_4_3 
  M6_TypeBRS3_prefilter_4_5 = EXT [M6_TypeBRS3_prefilter_3] M6_TypeBRS3_prefilter_4_2 > Mx_S+Mx_W <= 2*Mx_S+Mx_W OPPOSITE EXTENDED TypeBRS3_S6
  M6_TypeBRS3_prefilter_4_6 = M6_TypeBRS3_prefilter_4_4 TOUCH EDGE M6_TypeBRS3_prefilter_4_5
  M6_TypeBRS3_prefilter_4 =  EXT M6_TypeBRS3_prefilter_4_6 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
