  M6_TypeBRS3_CACB_S3_8 = EXPAND EDGE M6_TypeBRS3_CACB_S3_7 OUTSIDE BY GRID EXTEND BY GRID
  M6_TypeBRS3_CACB_S3_9 = M6_TypeBRS3_CACB_S3_1 TOUCH EDGE M6_TypeBRS3_CACB_S3_8
