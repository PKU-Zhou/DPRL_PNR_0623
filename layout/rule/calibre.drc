DTCDS2_TCDDMYCellOut = NOT INSIDE CELL TCDDMY ExclCellsForRRuleRecommended 
DTCDS2_TCDDMYCell = DTCDS2_TCDDMYCellIn AND DTCDS2_TCDDMYCellOut
DTCDS2_TCDDMYMarker = TCDDMY AND RRuleRecommended
DTCDS2_TCDDMY = ((DTCDS2_TCDDMYCell OR DTCDS2_TCDDMYMarker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:DTCD.S.2 { @ Recommended space between 2 TCDDMY >= 150 
  TCDDMY_CHECK = TCDDMY INTERACT DTCDS2_TCDDMY   
  EXT TCDDMY_CHECK < DTCD_S_2_R ABUT<90 SINGULAR REGION
}
#ENDIF
#ENDIF

#IFDEF CHECK_DTCDDN2_
#IFDEF _DTCDDN2_
#IFDEF FULL_CHIP
RR:RE:DTCD.DN.2 { @ Density of Dummy TCD (4mmxmm is one unit) >= 80 %
  ALL_WIN = DENSITY CHIP == DTCD_DN_2_W_R*DTCD_DN_2_W_R WINDOW DTCD_DN_2_W_R STEP DTCD_DN_2_W_R INSIDE OF LAYER CHIPx [AREA(CHIP)]
  BAD_WIN = DENSITY TCDDMY == 0 WINDOW DTCD_DN_2_W_R STEP DTCD_DN_2_W_R INSIDE OF LAYER ALL_WIN PRINT DTCD.DN.2.NO_TCDDMY
  GOOD_WIN = ALL_WIN NOT BAD_WIN
  ERR = DENSITY GOOD_WIN INSIDE OF LAYER ALL_WIN < DTCD_DN_2_R PRINT DTCD.DN.2.density
  ERR AND BAD_WIN
}
#ENDIF
#ENDIF
#ENDIF

