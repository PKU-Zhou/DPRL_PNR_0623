#ENDIF //BACK_END


//For Seal Ring OD/PO rules
//=====================

#IFDEF FRONT_END

SLR_DOD = DOD AND SEALRING_ALL
SLR_DPO = DPO AND SEALRING_ALL

SLR.W.1 { @ Width of DOD in SEALRING_ALL. >= ^SLR_W_1 um
  INT SLR_DOD < SLR_W_1 ABUT < 90 SINGULAR REGION
}

SLR.W.2 { @ Width of DPO in SEALRING_ALL. >= ^SLR_W_2 um
  INT SLR_DPO < SLR_W_2 ABUT < 90 SINGULAR REGION
}

SLR.S.1 { @ Space of DOD in SEALRING_ALL. >= ^SLR_S_1 um
  EXT SLR_DOD < SLR_S_1 ABUT < 90 SINGULAR REGION
}

SLR.S.2 { @ Space of DPO in SEALRING_ALL. >= ^SLR_S_2 um
  EXT SLR_DPO < SLR_S_2 ABUT < 90 SINGULAR REGION
}

SLR.S.3 { @ DPO space to CO in SEALRING_ALL. >= ^SLR_S_3 um
  EXT CO SLR_DPO < SLR_S_3 ABUT < 90 SINGULAR REGION
  DPO AND CO
}

SLR.EN.1 { @ DOD enclosure by SEALRING_ALL. >= ^SLR_EN_1 um
  (DOD INTERACT SEALRING_ALL) NOT INSIDE SEALRING_ALL
  A = ENC [SLR_DOD] SEALRING_ALL < SLR_EN_1 ABUT < 90 SINGULAR 
  B = A NOT COIN EDGE CHIPx
  ENC B SEALRING_ALL < SLR_EN_1 ABUT < 90 REGION
}

SLR.EN.2 { @ DPO enclosure by DOD in SEALRING_ALL. >= ^SLR_EN_2 um
  ENC SLR_DPO SLR_DOD < SLR_EN_2 ABUT < 90 SINGULAR REGION
}

PO.DN.7 { @ Minimum PO local density in SEALRING_ALL [window ^PO_DN_7_W um x ^PO_DN_7_W um, stepping ^PO_DN_7_S um] ^PO_DN_7 
  EXC = CHIP_CHAMFERED_P4 OR CSRDMY
  N = ALL_POLY NOT EXC
  D = CHIP NOT EXC 
  A = CHIP_WISR_P4 NOT EXC
  X = DENSITY A ALL_POLY CHIP N D < PO_DN_7 WINDOW PO_DN_7_W STEP PO_DN_7_S BACKUP INSIDE OF LAYER CHIP_WISR_P4 PRINT PO.DN.7.density RDB PO.DN.7.RDB.density
          [~(AREA(A)-PO_DN_7_E)*!!(AREA(A)-PO_DN_7_E)+AREA(N)/AREA(D)+!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_7)+!(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_7)]


  COPY X    
}

PO.DN.8 { @ Maximum PO local density in SEALRING_ALL [window ^PO_DN_8_W um x ^PO_DN_8_W um, stepping ^PO_DN_8_S um] ^PO_DN_8  
  EXC = COPY CHIP_CHAMFERED_P4
  N = ALL_POLY NOT EXC
  D = CHIP NOT EXC 
  A = CHIP_WISR_P4 NOT EXC
  X = DENSITY A ALL_POLY CHIP N D > PO_DN_8 WINDOW PO_DN_8_W STEP PO_DN_8_S BACKUP INSIDE OF LAYER CHIP_WISR_P4 PRINT PO.DN.8.density RDB PO.DN.8.RDB.density
          [~(PO_DN_8_E-AREA(A))*AREA(N)/AREA(D)*!~(AREA(ALL_POLY)/AREA(CHIP)-PO_DN_8)]


  COPY X  
}


SLR.R.2 { @ SEALRING_ALL overlap SR_DPO, SR_DOD, and CPO is not allowed   
  SEALRING_ALL AND SRDPO
  SEALRING_ALL AND SRDOD
  SEALRING_ALL AND CPO
}

SLR.R.3 { @ DPO must be fully covered by DOD in SEALRING_ALL   
  (DPO NOT DOD) AND SEALRING_ALL
}



#ENDIF   //FRONT_END

//'VIAx.S.8' is checked by VIA1.S.8
VIA1.S.8 {@ Maximum space of VIAx hole [INSIDE SEALRING] DRC flags: {SEALRING AND Mx} must be fully covered by {{SEALRING AND VIAx holes} SIZING 3.5 um} <= 7 
  A = SR_M1_P4 OR Reinforced_M1  
  B = SIZE SR_VIA1_HOLE BY 3.5
  A NOT B
}
//'VIAx.S.8' is checked by VIA2.S.8
VIA2.S.8 {@ Maximum space of VIAx hole [INSIDE SEALRING] DRC flags: {SEALRING AND Mx} must be fully covered by {{SEALRING AND VIAx holes} SIZING 3.5 um} <= 7 
  A = SR_M2_P4 OR Reinforced_M2  
  B = SIZE SR_VIA2_HOLE BY 3.5
  A NOT B
}
//'VIAx.S.8' is checked by VIA3.S.8
VIA3.S.8 {@ Maximum space of VIAx hole [INSIDE SEALRING] DRC flags: {SEALRING AND Mx} must be fully covered by {{SEALRING AND VIAx holes} SIZING 3.5 um} <= 7 
  A = SR_M3_P4 OR Reinforced_M3  
  B = SIZE SR_VIA3_HOLE BY 3.5
  A NOT B
}
//'VIAx.S.8' is checked by VIA4.S.8
VIA4.S.8 {@ Maximum space of VIAx hole [INSIDE SEALRING] DRC flags: {SEALRING AND Mx} must be fully covered by {{SEALRING AND VIAx holes} SIZING 3.5 um} <= 7 
  A = SR_M4_P4 OR Reinforced_M4  
  B = SIZE SR_VIA4_HOLE BY 3.5
  A NOT B
}
//'VIAx.S.8' is checked by VIA5.S.8
VIA5.S.8 {@ Maximum space of VIAx hole [INSIDE SEALRING] DRC flags: {SEALRING AND Mx} must be fully covered by {{SEALRING AND VIAx holes} SIZING 3.5 um} <= 7 
  A = SR_M5_P4 OR Reinforced_M5  
  B = SIZE SR_VIA5_HOLE BY 3.5
  A NOT B
}
//'VIAx.S.8' is checked by VIA6.S.8
VIA6.S.8 {@ Maximum space of VIAx hole [INSIDE SEALRING] DRC flags: {SEALRING AND Mx} must be fully covered by {{SEALRING AND VIAx holes} SIZING 3.5 um} <= 7 
  A = SR_M6_P4 OR Reinforced_M6  
  B = SIZE SR_VIA6_HOLE BY 3.5
  A NOT B
}
//'VIAz.S.3' is checked by VIA7.S.3
VIA7.S.3 {@ Maximum space of VIAz hole [INSIDE SEALRING] DRC flags: {SEALRING AND Mz} must be fully covered by {{SEALRING AND VIAz holes} SIZING 3.5 um} <= 7 
  A = SR_M7_P4 OR Reinforced_M7  
  B = SIZE SR_VIA7_HOLE BY 3.5
  A NOT B
}
//'VIAu.S.3' is checked by VIA8.S.3
VIA8.S.3 {@ Maximum space of VIAu hole [INSIDE SEALRING] DRC flags: {SEALRING AND Mu} must be fully covered by {{SEALRING AND VIAu holes} SIZING 3.5 um} <= 7 
  A = SR_M8_P4 OR Reinforced_M8  
  B = SIZE SR_VIA8_HOLE BY 3.5
  A NOT B
}


#ENDIF // WITH_SEALRING

//No matter seal-ring is added or not, the following rule must be checked
SLR.R.4 { @ LMARK must be inside SEALRING_ALL
    LMARK NOT INSIDE SEALRING_ALL
}



#ENDIF // FULL_CHIP





VARIABLE LNP_W_1_MIN 45
VARIABLE LNP_W_1_MAX 50
VARIABLE LNP_W_1_1_MIN 50
VARIABLE LNP_W_1_1_MAX 65
VARIABLE LNP_W_2       2
VARIABLE LNP_W_3       1.5
VARIABLE LNP_W_4       0.1
VARIABLE LNP_W_4L      45.76
VARIABLE LNP_S_1       6
VARIABLE LNP_S_2       0.12
VARIABLE LNP_S_3       0.1
VARIABLE LNP_R_6       6
VARIABLE LNP_R_7       1
#IFNDEF WIRE_BOND
VARIABLE LNP_FC_R_8     2
VARIABLE LNP_FC_R_8_MIN 4
VARIABLE LNP_FC_R_8_MAX 7
#ENDIF

M6_MOMlike_S = EXT (M6 AND LNP) == 0.1 ABUT < 90 OPPOSITE REGION // LNP.S.3
M6_MOMlike_W = INT (M6 AND LNP) < 1.5 ABUT < 90 OPPOSITE EXCLUDE SHIELDED REGION
M6_MOMlike_not = INT (M6_MOMlike_S OR M6_MOMlike_W) == 0.1 ABUT < 90 OPPOSITE REGION // LNP.W.3
M6_MOMlike = ((M6_MOMlike_S OR M6_MOMlike_W) NOT M6_MOMlike_not) INTERACT M6_MOMlike_W > 2

/// Low Noise Pad Layout Rules
//=====================
LNP.W.1 { @ Width of LNP (the edge parallel to nearby chip edge) = 45 ~ 50 
  LENGTH LNP < LNP_W_1_MIN
  LENGTH (LNP COIN OUTSIDE EDGE SEALRING_ORI) > LNP_W_1_MAX
}
LNP.W.1.1 { @ Length of LNP (the edge perpendicular to nearby chip edge) = 50~65 
  LNP_EDGE_CHK = LNP TOUCH EDGE (INT [LNP] (LNP COIN OUTSIDE EDGE SEALRING_ORI) < GRID ABUT == 90 INTERSECTING ONLY)
  LENGTH LNP_EDGE_CHK < LNP_W_1_1_MIN
  LENGTH LNP > LNP_W_1_1_MAX
}
LNP.W.2:M9 { @ Width of Mtop/Mtop-1/Mtop-3 [within {LNP AND SEALRING_ALL}] = 2 
  M9_CHK = M9 AND (LNP AND SEALRING_ALL)
  M9_CHK NOT WITH WIDTH == LNP_W_2
}

LNP.W.2:M8 { @ Width of Mtop/Mtop-1/Mtop-3 [within {LNP AND SEALRING_ALL}] = 2 
  M8_CHK = M8 AND (LNP AND SEALRING_ALL)
  M8_CHK NOT WITH WIDTH == LNP_W_2
}


LNP.W.2:M6 { @ Width of Mtop/Mtop-1/Mtop-3 [within {LNP AND SEALRING_ALL}] = 2 
  M6_CHK = M6 AND (LNP AND SEALRING_ALL)
  M6_CHK NOT WITH WIDTH == LNP_W_2
}

LNP.W.3 { @ Width of {Mtop-2 AND LNP} = 1.5 
  INT (M7 AND LNP) < LNP_W_3 ABUT < 90 SINGULAR REGION
  (M7 AND LNP) NOT WITH WIDTH == LNP_W_3
}
LNP.W.4 { @ Width of {Mtop-3 AND LNP} in MOM-like region Definition of MOM-like region: Number of metal line >= 3, Space = 0.1 um, PRL = 45.76 um = 0.1 
  M6_MOMlike_W NOT WITH WIDTH == LNP_W_4
}
LNP.S.1:M9 { @ Space of Mtop/Mtop-1/Mtop-3 [within {LNP AND SEALRING_ALL}] = 6 
  M9_CHK = M9 AND (LNP AND SEALRING_ALL)
  EXT M9_CHK < LNP_S_1 ABUT < 90 OPPOSITE REGION
  M9_MERGE = SIZE M9_CHK BY LNP_S_1/2
  M9_MERGE INTERACT M9_CHK != LNP_R_6
}

LNP.S.1:M8 { @ Space of Mtop/Mtop-1/Mtop-3 [within {LNP AND SEALRING_ALL}] = 6 
  M8_CHK = M8 AND (LNP AND SEALRING_ALL)
  EXT M8_CHK < LNP_S_1 ABUT < 90 OPPOSITE REGION
  M8_MERGE = SIZE M8_CHK BY LNP_S_1/2
  M8_MERGE INTERACT M8_CHK != LNP_R_6
}


LNP.S.1:M6 { @ Space of Mtop/Mtop-1/Mtop-3 [within {LNP AND SEALRING_ALL}] = 6 
  M6_CHK = M6 AND (LNP AND SEALRING_ALL)
  EXT M6_CHK < LNP_S_1 ABUT < 90 OPPOSITE REGION
  M6_MERGE = SIZE M6_CHK BY LNP_S_1/2
  M6_MERGE INTERACT M6_CHK != LNP_R_6
}

LNP.S.2 { @ Space to Mtop-3 line-end [width= 0.1 um, INSIDE LNP] = 0.12 
  M6_lineend = LENGTH (CONVEX EDGE (M6 AND LNP) ANGLE1 == 90 ANGLE2 == 90) == LNP_W_4
  EXT M6_lineend M6 < LNP_S_2 ABUT < 90 OPPOSITE REGION
  EXT (M6_lineend) M6 <= LNP_S_2 ABUT < 90 OPPOSITE
}
LNP.S.3 { @ Space of Mtop-3 [width= 0.1 um, INSIDE LNP] = 0.1 
  EXT M6_MOMlike_W < LNP_S_3 ABUT < 90 OPPOSITE REGION
  M6_S_CHK = EXT M6_MOMlike_W < 0.30 ABUT < 90 OPPOSITE REGION
  ENCLOSE RECTANGLE M6_S_CHK LNP_W_4L LNP_S_3+GRID ORTHOGONAL ONLY
  LNP INTERACT M6_MOMlike > 1
}
LNP.R.1:M9 { @ Mtop/Mtop-1/Mtop-2/Mtop-3 [within {LNP AND SEALRING_ALL}] must connect to inner seal-ring   
  M9_CHK = M9 AND (LNP AND SEALRING_ALL)
  M9_CHK NOT INTERACT SEALRING_ORI
}
LNP.R.1:M8 { @ Mtop/Mtop-1/Mtop-2/Mtop-3 [within {LNP AND SEALRING_ALL}] must connect to inner seal-ring   
  M8_CHK = M8 AND (LNP AND SEALRING_ALL)
  M8_CHK NOT INTERACT SEALRING_ORI
}
LNP.R.1:M7 { @ Mtop/Mtop-1/Mtop-2/Mtop-3 [within {LNP AND SEALRING_ALL}] must connect to inner seal-ring   
  M7_CHK = M7 AND (LNP AND SEALRING_ALL)
  M7_CHK NOT INTERACT SEALRING_ORI
}
LNP.R.1:M6 { @ Mtop/Mtop-1/Mtop-2/Mtop-3 [within {LNP AND SEALRING_ALL}] must connect to inner seal-ring   
  M6_CHK = M6 AND (LNP AND SEALRING_ALL)
  M6_CHK NOT INTERACT SEALRING_ORI
}
LNP.R.2 { @ VIAtop-3 [INSIDE LNP] is not allowed   
  VIA5 AND LNP
}
LNP.R.3:M9 { @ {LNP NOT SEALRING_ALL} must interact with Mtop, Mtop-1, Mtop-2, Mtop-3, VIAtop, VIAtop-1, and VIAtop-2   
  (LNP NOT SEALRING_ALL) NOT INTERACT M9
}
LNP.R.3:M8 { @ {LNP NOT SEALRING_ALL} must interact with Mtop, Mtop-1, Mtop-2, Mtop-3, VIAtop, VIAtop-1, and VIAtop-2   
  (LNP NOT SEALRING_ALL) NOT INTERACT M8
}
LNP.R.3:M7 { @ {LNP NOT SEALRING_ALL} must interact with Mtop, Mtop-1, Mtop-2, Mtop-3, VIAtop, VIAtop-1, and VIAtop-2   
  (LNP NOT SEALRING_ALL) NOT INTERACT M7
}
LNP.R.3:M6 { @ {LNP NOT SEALRING_ALL} must interact with Mtop, Mtop-1, Mtop-2, Mtop-3, VIAtop, VIAtop-1, and VIAtop-2   
  (LNP NOT SEALRING_ALL) NOT INTERACT M6
}
LNP.R.3:VIA8 { @ {LNP NOT SEALRING_ALL} must interact with Mtop, Mtop-1, Mtop-2, Mtop-3, VIAtop, VIAtop-1, and VIAtop-2   
  (LNP NOT SEALRING_ALL) NOT INTERACT VIA8
}
LNP.R.3:VIA7 { @ {LNP NOT SEALRING_ALL} must interact with Mtop, Mtop-1, Mtop-2, Mtop-3, VIAtop, VIAtop-1, and VIAtop-2   
  (LNP NOT SEALRING_ALL) NOT INTERACT VIA7
}
LNP.R.3:VIA6 { @ {LNP NOT SEALRING_ALL} must interact with Mtop, Mtop-1, Mtop-2, Mtop-3, VIAtop, VIAtop-1, and VIAtop-2   
  (LNP NOT SEALRING_ALL) NOT INTERACT VIA6
}
LNP.R.5 { @ It is not allowed to connect low noise pattern and sealring by AP DRC check: {AP AND SEALRING_ALL} INTERACT {LNP NOT SEALRING_ALL}   
  (AP AND SEALRING_ALL) INTERACT (LNP NOT SEALRING_ALL)
}
LNP.R.6:M9 { @ The number of Mtop/Mtop-1/Mtop-3 [within {LNP AND SEALRING_ALL}] = 6 
  (LNP AND SEALRING_ALL) INTERACT (M9 AND (LNP AND SEALRING_ALL)) != LNP_R_6
}

LNP.R.6:M8 { @ The number of Mtop/Mtop-1/Mtop-3 [within {LNP AND SEALRING_ALL}] = 6 
  (LNP AND SEALRING_ALL) INTERACT (M8 AND (LNP AND SEALRING_ALL)) != LNP_R_6
}


LNP.R.6:M6 { @ The number of Mtop/Mtop-1/Mtop-3 [within {LNP AND SEALRING_ALL}] = 6 
  (LNP AND SEALRING_ALL) INTERACT (M6 AND (LNP AND SEALRING_ALL)) != LNP_R_6
}

LNP.R.7 { @ The number of Mtop-2 [within {LNP AND SEALRING_ALL}] = 1 
  (LNP AND SEALRING_ALL) INTERACT (M7 AND (LNP AND SEALRING_ALL)) != LNP_R_7
}
LNP.R.9 { @ VIAtop-2 is not allowed in MOM-like region [INSIDE LNP] Definition of MOM-like region: Number of metal line >= 3, Space = 0.1 um, PRL = 45.76 um   
  VIA6 AND M6_MOMlike
}
LNP.R.12 { @ LNP must abut inner seal-ring when seal-ring is added by customer   
  LNP NOT INTERACT SEALRING_ORI
  LNP INSIDE EDGE SEALRING_ORI
}
#IFNDEF WIRE_BOND
LNP_FC.R.8:M9 { @ {{Mtop/Mtop-1 AND LNP} NOT SEALRING_ALL} must be mesh type [regular holes with metal width = 2 um and hole width = 4~7 um] DRC flag: 1. Width (W4) of {{Mtop/Mtop-1 AND LNP} NOT SEALRING_ALL} is not 2 um (except 45-degree corners), or 2. Hole width (C) of {{Mtop/Mtop-1 AND LNP} NOT SEALRING_ALL} is not 4~7 um   
  M9_CHK = (M9 AND LNP) NOT SEALRING_ALL
  M9_CHK NOT WITH WIDTH == LNP_FC_R_8
  NOT ENCLOSE RECTANGLE (HOLES M9_CHK INNER) LNP_FC_R_8_MIN LNP_FC_R_8_MIN ORTHOGONAL ONLY
  ENCLOSE RECTANGLE (HOLES M9_CHK INNER) LNP_FC_R_8_MAX+GRID LNP_FC_R_8_MAX+GRID ORTHOGONAL ONLY
}
LNP_FC.R.8:M8 { @ {{Mtop/Mtop-1 AND LNP} NOT SEALRING_ALL} must be mesh type [regular holes with metal width = 2 um and hole width = 4~7 um] DRC flag: 1. Width (W4) of {{Mtop/Mtop-1 AND LNP} NOT SEALRING_ALL} is not 2 um (except 45-degree corners), or 2. Hole width (C) of {{Mtop/Mtop-1 AND LNP} NOT SEALRING_ALL} is not 4~7 um   
  M8_CHK = (M8 AND LNP) NOT SEALRING_ALL
  M8_CHK NOT WITH WIDTH == LNP_FC_R_8
  NOT ENCLOSE RECTANGLE (HOLES M8_CHK INNER) LNP_FC_R_8_MIN LNP_FC_R_8_MIN ORTHOGONAL ONLY
  ENCLOSE RECTANGLE (HOLES M8_CHK INNER) LNP_FC_R_8_MAX+GRID LNP_FC_R_8_MAX+GRID ORTHOGONAL ONLY
}
#ENDIF
#IFNDEF WIRE_BOND
// LNP_FC.R.8 is not necessary to check
#ENDIF




PO_TCD = POi AND TCDDMY
OD_TCD = ODi AND TCDDMY

GATE_TCD = (PO_TCD AND OD_TCD) AND TCDDMY
GATE_W_TCD = PO_TCD COIN INSIDE EDGE GATE_TCD
GATE_L_TCD = GATE_TCD NOT COIN INSIDE EDGE PO_TCD

TCDDMY_OLD = TCDDMY NOT ((TCDDMY_FH OR TCDDMY_FV) OR (TCDDMY_H OR TCDDMY_V))
TCDDMY_NEW = (TCDDMY_FH OR TCDDMY_FV) OR (TCDDMY_H OR TCDDMY_V)

GATE_TCD_OLD = (PO_TCD AND OD_TCD) AND TCDDMY_OLD
GATE_W_TCD_OLD = PO_TCD COIN INSIDE EDGE GATE_TCD_OLD

DTCD.W.1 { @ Width of {TCDDMY NOT {{{TCDDMY_FH OR TCDDMY_FV} OR TCDDMY_H} OR TCDDMY_V}} (maximum = minimum) = 12, 6 
  A = NOT RECTANGLE TCDDMY_OLD == DTCD_W_1A BY == DTCD_W_1A ORTHOGONAL ONLY
  NOT RECTANGLE A == DTCD_W_1B BY == DTCD_W_1B ORTHOGONAL ONLY
}
DTCD.W.2 { @ Channel width of GATE inside {TCDDMY NOT {{{TCDDMY_FH OR TCDDMY_FV} OR TCDDMY_H} OR TCDDMY_V}} = 5, 2.7, 1, 0.6, 0.3, 0.1 
  LENGTH GATE_W_TCD_OLD < DTCD_W_2A
  LENGTH GATE_W_TCD_OLD > DTCD_W_2A < DTCD_W_2B
  LENGTH GATE_W_TCD_OLD > DTCD_W_2B < DTCD_W_2C
  LENGTH GATE_W_TCD_OLD > DTCD_W_2C < DTCD_W_2D
  LENGTH GATE_W_TCD_OLD > DTCD_W_2D < DTCD_W_2E
  LENGTH GATE_W_TCD_OLD > DTCD_W_2E < DTCD_W_2F  
  LENGTH GATE_W_TCD_OLD > DTCD_W_2F
}
DTCD.W.3 { @ Channel length of GATE inside TCDDMY = 0.03 
  LENGTH GATE_L_TCD < DTCD_W_3
  LENGTH GATE_L_TCD > DTCD_W_3
}

DTCD.S.1 { @ Gate space to neighboring poly inside TCDDMY = 0.1 
  GATE_CHECK = PO_TCD AND OD_TCD
  GOOD_EDGE = EXT [GATE_CHECK] POLY == DTCD_S_1 EXCLUDE SHIELDED 4 OPPOSITE
  (GATE_CHECK TOUCH EDGE GATE_W) NOT COIN INSIDE EDGE GOOD_EDGE
}
DTCD.R.1 { @ TCDDMY should contain OD/PO/PP/NP/POBLK/ODBLK layers   
  TCDDMY OUTSIDE ODi
  TCDDMY OUTSIDE POi
  TCDDMY OUTSIDE PPi
  TCDDMY OUTSIDE NPi
  TCDDMY XOR (POBLK AND TCDDMY)
  TCDDMY XOR (ODBLK AND TCDDMY)
}
DTCD.R.2 { @ TCDDMY overlap of DOD, SR_DOD, DPO, SR_DPO, OD2, NT_N, RPO, RH_OD, RH_PO, VAR, VTH_P, VTH_N, VTL_P, VTL_N, VTUL_P, VTUL_N, UHVT_N, UHVT_P, EHVT_N, EHVT_P, SRM, SRAMDMY, SDI, SR_ESD, BJTDMY, LMARK, INDDMY, or MOMDMY is not allowed   
  TCDDMY AND DOD
  TCDDMY AND SRDOD
  TCDDMY AND DPO
  TCDDMY AND SRDPO
  TCDDMY AND OD2i
  TCDDMY AND NTNi
  TCDDMY AND RPOi
  TCDDMY AND RHOD
  TCDDMY AND RHPO
  TCDDMY AND VARi
  TCDDMY AND VTLPi
  TCDDMY AND VTLNi
  TCDDMY AND VTULNi
  TCDDMY AND VTULPi
  TCDDMY AND VTHPi
  TCDDMY AND VTHNi
  TCDDMY AND VTUHNi
  TCDDMY AND VTUHPi
  TCDDMY AND SRM
  TCDDMY AND SRAMDMY
  TCDDMY AND SDI
  TCDDMY AND SRESD
  TCDDMY AND BJTDMY
  TCDDMY AND LMARK
  TCDDMY AND INDDMY
  TCDDMY AND MOMDMY_ALL
  TCDDMY AND EHVT_N
  TCDDMY AND EHVT_P
}
// DTCD.R.3 is checked by related rules

#IFDEF FULL_CHIP
DTCD.DN.1 { @ Density of DummyTCD (window 2000 um X 2000 um is one unit) >= 50% 
  ALL_WIN = DENSITY CHIP == DTCD_DN_1_W*DTCD_DN_1_W WINDOW DTCD_DN_1_W STEP DTCD_DN_1_W INSIDE OF LAYER CHIPx [AREA(CHIP)]
  BAD_WIN = DENSITY TCDDMY == 0 WINDOW DTCD_DN_1_W STEP DTCD_DN_1_W INSIDE OF LAYER ALL_WIN PRINT DTCD.DN.1.NO_TCDDMY
  GOOD_WIN = ALL_WIN NOT BAD_WIN
  ERR = DENSITY GOOD_WIN INSIDE OF LAYER ALL_WIN < DTCD_DN_1 PRINT DTCD.DN.1.density
  ERR AND BAD_WIN
}
#ENDIF



SYM_DTCD = TCDDMY_FH OR TCDDMY_FV
ASYM_DTCD = TCDDMY_H OR TCDDMY_V
REC_DTCD = SYM_DTCD OR ASYM_DTCD    // horizontal/vertical/square dummy TCD
SQR_DTCD = TCDDMY NOT REC_DTCD

PO_RECTCD = POi AND REC_DTCD
OD_RECTCD = ODi AND REC_DTCD
PO_SQRTCD = POi AND SQR_DTCD
OD_SQRTCD = ODi AND SQR_DTCD

GATE_RECTCD = (PO_RECTCD AND OD_RECTCD) AND REC_DTCD
GATE_W_RECTCD = PO_RECTCD COIN INSIDE EDGE GATE_RECTCD
GATE_SQRTCD = (PO_SQRTCD AND OD_SQRTCD) AND SQR_DTCD
GATE_W_SQRTCD = PO_SQRTCD COIN INSIDE EDGE GATE_SQRTCD
//GATE_L_SQRTCD = GATE_SQRTCD NOT COIN INSIDE EDGE PO_SQRTCD

DTCD.W.4 { @ Dimension of TCDDMY_FH = 9X3.5 
  A = RECTANGLE TCDDMY_FH == DTCD_W_4A BY == DTCD_W_4B ORTHOGONAL ONLY
  TCDDMY_FH NOT A
  B = LENGTH (ANGLE A == 0) == DTCD_W_4B
  A WITH EDGE B
}

DTCD.W.5 { @ Dimension of TCDDMY_FV = 3.5X9 
  A = RECTANGLE TCDDMY_FV == DTCD_W_5A BY == DTCD_W_5B ORTHOGONAL ONLY
  TCDDMY_FV NOT A
  B = LENGTH (ANGLE A == 0) == DTCD_W_5B
  A WITH EDGE B
}

DTCD.W.6 { @ Dimension of TCDDMY_H = 7.41X3.5 
  A = RECTANGLE TCDDMY_H == DTCD_W_6A BY == DTCD_W_6B ORTHOGONAL ONLY
  TCDDMY_H NOT A
  B = LENGTH (ANGLE A == 0) == DTCD_W_6B
  A WITH EDGE B
}

DTCD.W.7 { @ Dimension of TCDDMY_V = 3.11X9 
  A = RECTANGLE TCDDMY_V == DTCD_W_7A BY == DTCD_W_7B ORTHOGONAL ONLY
  TCDDMY_V NOT A
  B = LENGTH (ANGLE A == 0) == DTCD_W_7B
  A WITH EDGE B
}

DTCD.W.8 { @ Channel width of gate inside {{{TCDDMY_FH OR TCDDMY_FV} OR TCDDMY_H} OR TCDDMY_V} = 3.14, 0.29, 0.255 
  LENGTH GATE_W_RECTCD < DTCD_W_8A
  LENGTH GATE_W_RECTCD > DTCD_W_8A < DTCD_W_8B
  LENGTH GATE_W_RECTCD > DTCD_W_8B < DTCD_W_8C
  LENGTH GATE_W_RECTCD > DTCD_W_8C
}

DTCD.R.4 { @ {{{TCDDMY_FH OR TCDDMY_FY} OR TCDDMY_H} OR TCDDMY_V} must be covered and drawn identically to TCDDMY   
  TCDDMY_FH NOT ENCLOSE TCDDMY
  TCDDMY_FH CUT TCDDMY
  TCDDMY_FV NOT ENCLOSE TCDDMY
  TCDDMY_FV CUT TCDDMY
  TCDDMY_H NOT ENCLOSE TCDDMY
  TCDDMY_H CUT TCDDMY
  TCDDMY_V NOT ENCLOSE TCDDMY
  TCDDMY_V CUT TCDDMY
}

DTCD.R.5 { @ TCDDMY_FH/ TCDDMY_FV/TCDDMY_H/ TCDDMY_V should contain CPO and PMET layers   
  REC_DTCD OUTSIDE CPO
  REC_DTCD OUTSIDE PMET
}

DTCD.R.6 { @ Poly gates in TCDDMY_FH/ TCDDMY_FV must keep the same orientation with gates. Any mirror and 180 degree rotation in X,Y are legal, but 90 degree and 270 degree rotations will be illegal. DRC will check relative coordinates of 0.4umX0.4um OD and 0.4umX0.4um PO alignment marks in TCDDMY_FH/ TCDDMY_FV
  CHECK_GATE_W = GATE_W_RECTCD COIN INSIDE EDGE (PO_RECTCD AND SYM_DTCD)
  ANGLE CHECK_GATE_W != 90
  // 90 and 270 degree rotation are checked by DTCD.W.4 AND DTCD.W.5
  CHECK_OD_FH = RECTANGLE (OD_RECTCD AND TCDDMY_FH) == DTCD_R_5_OD BY == DTCD_R_5_OD ORTHOGONAL ONLY
  CHECK_PO_FH = RECTANGLE (PO_RECTCD AND TCDDMY_FH) == DTCD_R_5_PO BY == DTCD_R_5_PO ORTHOGONAL ONLY
  CHECK_OD_FV = RECTANGLE (OD_RECTCD AND TCDDMY_FV) == DTCD_R_5_OD BY == DTCD_R_5_OD ORTHOGONAL ONLY
  CHECK_PO_FV = RECTANGLE (PO_RECTCD AND TCDDMY_FV) == DTCD_R_5_PO BY == DTCD_R_5_PO ORTHOGONAL ONLY

  // check OD alignment mark on TCDDMY_FH
  TCDDMY_FH_0_pre1 = (SHRINK TCDDMY_FH TOP BY 0.2 BOTTOM BY 0.2 LEFT BY 2.6 RIGHT BY 0.2) ENCLOSE CHECK_OD_FH == 6   // 0 degree and X mirror
  TCDDMY_FH_0_OD1 = INT TCDDMY_FH_0_pre1 <= DTCD_R_5_OD ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  TCDDMY_FH_0_pre2 = SHRINK TCDDMY_FH_0_pre1 LEFT BY 2.9 RIGHT BY 2.9
  TCDDMY_FH_0_OD2 = INT TCDDMY_FH_0_pre2 <= DTCD_R_5_OD ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  BAD_OD_FH_0 = CHECK_OD_FH XOR (TCDDMY_FH_0_OD1 OR TCDDMY_FH_0_OD2)
  GOOD_OD_FH_0 = TCDDMY_FH NOT INTERACT BAD_OD_FH_0
  
  TCDDMY_FH_180_pre1 = (SHRINK TCDDMY_FH TOP BY 0.2 BOTTOM BY 0.2 LEFT BY 0.2 RIGHT BY 2.6) ENCLOSE CHECK_OD_FH == 6 // 180 degree and Y, XY mirror
  TCDDMY_FH_180_OD1 = INT TCDDMY_FH_180_pre1 <= DTCD_R_5_OD ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  TCDDMY_FH_180_pre2 = SHRINK TCDDMY_FH_180_pre1 LEFT BY 2.9 RIGHT BY 2.9
  TCDDMY_FH_180_OD2 = INT TCDDMY_FH_180_pre2 <= DTCD_R_5_OD ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  BAD_OD_FH_180 = CHECK_OD_FH XOR (TCDDMY_FH_180_OD1 OR TCDDMY_FH_180_OD2)
  GOOD_OD_FH_180 = TCDDMY_FH NOT INTERACT BAD_OD_FH_180

  (TCDDMY_FH NOT INTERACT (GOOD_OD_FH_0 OR GOOD_OD_FH_180)) AND CHECK_OD_FH

  // check OD alignment mark on TCDDMY_FV
  TCDDMY_FV_0_pre1 = (SHRINK TCDDMY_FV TOP BY 0.2 BOTTOM BY 2.2 LEFT BY 0.1 RIGHT BY 0.1) ENCLOSE CHECK_OD_FV == 8   // 0 degree and Y mirror
  TCDDMY_FV_0_OD1 = INT TCDDMY_FV_0_pre1 <= DTCD_R_5_OD ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  TCDDMY_FV_0_pre2 = SHRINK TCDDMY_FV_0_pre1 TOP BY 2.7 BOTTOM BY 2.7
  TCDDMY_FV_0_OD2 = INT TCDDMY_FV_0_pre2 <= DTCD_R_5_OD ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  BAD_OD_FV_0 = CHECK_OD_FV XOR (TCDDMY_FV_0_OD1 OR TCDDMY_FV_0_OD2)
  GOOD_OD_FV_0 = TCDDMY_FV NOT INTERACT BAD_OD_FV_0
  
  TCDDMY_FV_180_pre1 = (SHRINK TCDDMY_FV TOP BY 2.2 BOTTOM BY 0.2 LEFT BY 0.1 RIGHT BY 0.1) ENCLOSE CHECK_OD_FV == 8 // 180 degree and X, XY mirror
  TCDDMY_FV_180_OD1 = INT TCDDMY_FV_180_pre1 <= DTCD_R_5_OD ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  TCDDMY_FV_180_pre2 = SHRINK TCDDMY_FV_180_pre1 TOP BY 2.7 BOTTOM BY 2.7
  TCDDMY_FV_180_OD2 = INT TCDDMY_FV_180_pre2 <= DTCD_R_5_OD ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  BAD_OD_FV_180 = CHECK_OD_FV XOR (TCDDMY_FV_180_OD1 OR TCDDMY_FV_180_OD2)
  GOOD_OD_FV_180 = TCDDMY_FV NOT INTERACT BAD_OD_FV_180

  (TCDDMY_FV NOT INTERACT (GOOD_OD_FV_0 OR GOOD_OD_FV_180)) AND CHECK_OD_FV

  // check PO alignment mark on TCDDMY_FH
  TCDDMY_FH_0_pre3 = (SHRINK TCDDMY_FH TOP BY 1.175 BOTTOM BY 1.175 LEFT BY 5.5 RIGHT BY 0.2) ENCLOSE CHECK_PO_FH == 4 // 0 degree and X mirror
  TCDDMY_FH_0_PO = INT TCDDMY_FH_0_pre3 <= DTCD_R_5_PO ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  BAD_PO_FH_0 = CHECK_PO_FH XOR TCDDMY_FH_0_PO
  GOOD_PO_FH_0 = TCDDMY_FH NOT INTERACT BAD_PO_FH_0

  TCDDMY_FH_180_pre3 = (SHRINK TCDDMY_FH TOP BY 1.175 BOTTOM BY 1.175 LEFT BY 0.2 RIGHT BY 5.5) ENCLOSE CHECK_PO_FH == 4 // 180 degree and Y, XY mirror
  TCDDMY_FH_180_PO = INT TCDDMY_FH_180_pre3 <= DTCD_R_5_PO ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  BAD_PO_FH_180 = CHECK_PO_FH XOR TCDDMY_FH_180_PO
  GOOD_PO_FH_180 = TCDDMY_FH NOT INTERACT BAD_PO_FH_180

  (TCDDMY_FH NOT INTERACT (GOOD_PO_FH_0 OR GOOD_PO_FH_180)) AND CHECK_PO_FH

  // check PO alignment mark on TCDDMY_FV
  TCDDMY_FV_0_pre3 = (SHRINK TCDDMY_FV TOP BY 1.175 BOTTOM BY 6.675 LEFT BY 0.1 RIGHT BY 0.1) ENCLOSE CHECK_PO_FV == 4 // 0 degree and Y mirror
  TCDDMY_FV_0_PO = INT TCDDMY_FV_0_pre3 <= DTCD_R_5_PO ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  BAD_PO_FV_0 = CHECK_PO_FV XOR TCDDMY_FV_0_PO
  GOOD_PO_FV_0 = TCDDMY_FV NOT INTERACT BAD_PO_FV_0

  TCDDMY_FV_180_pre3 = (SHRINK TCDDMY_FV TOP BY 6.675 BOTTOM BY 1.175 LEFT BY 0.1 RIGHT BY 0.1) ENCLOSE CHECK_PO_FV == 4 // 180 degree and X, XY mirror
  TCDDMY_FV_180_PO = INT TCDDMY_FV_180_pre3 <= DTCD_R_5_PO ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  BAD_PO_FV_180 = CHECK_PO_FV XOR TCDDMY_FV_180_PO
  GOOD_PO_FV_180 = TCDDMY_FV NOT INTERACT BAD_PO_FV_180

  (TCDDMY_FV NOT INTERACT (GOOD_PO_FV_0 OR GOOD_PO_FV_180)) AND CHECK_PO_FV
}

DTCD.R.7 { @ Poly gates in TCDDMY_H/ TCDDMY_V must keep the same orientation with gates. Any rotation, any mirror in X,Y in placement will be illegal. DRC will check relative coordinates of 0.5umX0.5um OD and 0.5umX0.5um PO alignment marks in TCDDMY_H/ TCDDMY_V
  CHECK_GATE_W = GATE_W_RECTCD COIN INSIDE EDGE (PO_RECTCD AND ASYM_DTCD)
  ANGLE CHECK_GATE_W != 90
  CHECK_OD_H = RECTANGLE (OD_RECTCD AND TCDDMY_H) == DTCD_R_6_OD BY == DTCD_R_6_OD ORTHOGONAL ONLY
  CHECK_PO_H = RECTANGLE (PO_RECTCD AND TCDDMY_H) == DTCD_R_6_PO BY == DTCD_R_6_PO ORTHOGONAL ONLY
  CHECK_OD_V = RECTANGLE (OD_RECTCD AND TCDDMY_V) == DTCD_R_6_OD BY == DTCD_R_6_OD ORTHOGONAL ONLY
  CHECK_PO_V = RECTANGLE (PO_RECTCD AND TCDDMY_V) == DTCD_R_6_PO BY == DTCD_R_6_PO ORTHOGONAL ONLY
  // check OD alignment mark on TCDDMY_H/TCDDMY_V
  TCDDMY_H_OD = INT (SHRINK TCDDMY_H TOP BY 0.1 BOTTOM BY 2.15 LEFT BY 4.5 RIGHT BY 2.41) <= DTCD_R_6_OD ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  (TCDDMY_H INTERACT (CHECK_OD_H XOR TCDDMY_H_OD)) AND CHECK_OD_H
  TCDDMY_V_OD = INT (SHRINK TCDDMY_V TOP BY 3.6 BOTTOM BY 4.15 LEFT BY 2.51 RIGHT BY 0.1) <= DTCD_R_6_OD ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  (TCDDMY_V INTERACT (CHECK_OD_V XOR TCDDMY_V_OD)) AND CHECK_OD_V
  // check PO alignment mark on TCDDMY_H/TCDDMY_V
  TCDDMY_H_PO = INT (SHRINK TCDDMY_H TOP BY 2.15 BOTTOM BY 0.1 LEFT BY 4.5 RIGHT BY 2.41) <= DTCD_R_6_PO ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  (TCDDMY_H INTERACT (CHECK_PO_H XOR TCDDMY_H_PO)) AND CHECK_PO_H
  TCDDMY_V_PO = INT (SHRINK TCDDMY_V TOP BY 2.15 BOTTOM BY 5.6 LEFT BY 0.2 RIGHT BY 2.41) <= DTCD_R_6_PO ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  (TCDDMY_V INTERACT (CHECK_PO_V XOR TCDDMY_V_PO)) AND CHECK_PO_V
}




// BDTCD CHECKS
//=============
SYM_M1_TCD = M1 AND (TCDDMY_FM1 OR TCDDMY_FDM1)
ASYM_M1_TCD = M1 AND TCDDMY_M1
M1_TCD = SYM_M1_TCD OR ASYM_M1_TCD
LONGEDGE_SYM_M1_TCD = LENGTH SYM_M1_TCD >= BDTCD_W_3_L
LONGEDGE_ASYM_M1_TCD = LENGTH ASYM_M1_TCD >= BDTCD_W_3_L
LONGEDGE_M1_TCD = LENGTH M1_TCD >= BDTCD_W_3_L
LONG_M1_TCD_050 = INT [LONGEDGE_M1_TCD] == BDTCD_W_3A OPPOSITE
LONG_M1_TCD_100 = INT [LONGEDGE_M1_TCD] == BDTCD_W_3B OPPOSITE
LONG_M1_TCD_200 = INT [LONGEDGE_M1_TCD] == BDTCD_W_3C OPPOSITE
SYM_M2_TCD = M2 AND (TCDDMY_FM2 OR TCDDMY_FDM2)
ASYM_M2_TCD = M2 AND TCDDMY_M2
M2_TCD = SYM_M2_TCD OR ASYM_M2_TCD
LONGEDGE_SYM_M2_TCD = LENGTH SYM_M2_TCD >= BDTCD_W_3_L
LONGEDGE_ASYM_M2_TCD = LENGTH ASYM_M2_TCD >= BDTCD_W_3_L
LONGEDGE_M2_TCD = LENGTH M2_TCD >= BDTCD_W_3_L
LONG_M2_TCD_050 = INT [LONGEDGE_M2_TCD] == BDTCD_W_3A OPPOSITE
LONG_M2_TCD_100 = INT [LONGEDGE_M2_TCD] == BDTCD_W_3B OPPOSITE
LONG_M2_TCD_200 = INT [LONGEDGE_M2_TCD] == BDTCD_W_3C OPPOSITE
SYM_M3_TCD = M3 AND (TCDDMY_FM3 OR TCDDMY_FDM3)
ASYM_M3_TCD = M3 AND TCDDMY_M3
M3_TCD = SYM_M3_TCD OR ASYM_M3_TCD
LONGEDGE_SYM_M3_TCD = LENGTH SYM_M3_TCD >= BDTCD_W_3_L
LONGEDGE_ASYM_M3_TCD = LENGTH ASYM_M3_TCD >= BDTCD_W_3_L
LONGEDGE_M3_TCD = LENGTH M3_TCD >= BDTCD_W_3_L
LONG_M3_TCD_050 = INT [LONGEDGE_M3_TCD] == BDTCD_W_3A OPPOSITE
LONG_M3_TCD_100 = INT [LONGEDGE_M3_TCD] == BDTCD_W_3B OPPOSITE
LONG_M3_TCD_200 = INT [LONGEDGE_M3_TCD] == BDTCD_W_3C OPPOSITE
SYM_M4_TCD = M4 AND (TCDDMY_FM4 OR TCDDMY_FDM4)
ASYM_M4_TCD = M4 AND TCDDMY_M4
M4_TCD = SYM_M4_TCD OR ASYM_M4_TCD
LONGEDGE_SYM_M4_TCD = LENGTH SYM_M4_TCD >= BDTCD_W_3_L
LONGEDGE_ASYM_M4_TCD = LENGTH ASYM_M4_TCD >= BDTCD_W_3_L
LONGEDGE_M4_TCD = LENGTH M4_TCD >= BDTCD_W_3_L
LONG_M4_TCD_050 = INT [LONGEDGE_M4_TCD] == BDTCD_W_3A OPPOSITE
LONG_M4_TCD_100 = INT [LONGEDGE_M4_TCD] == BDTCD_W_3B OPPOSITE
LONG_M4_TCD_200 = INT [LONGEDGE_M4_TCD] == BDTCD_W_3C OPPOSITE
SYM_M5_TCD = M5 AND (TCDDMY_FM5 OR TCDDMY_FDM5)
ASYM_M5_TCD = M5 AND TCDDMY_M5
M5_TCD = SYM_M5_TCD OR ASYM_M5_TCD
LONGEDGE_SYM_M5_TCD = LENGTH SYM_M5_TCD >= BDTCD_W_3_L
LONGEDGE_ASYM_M5_TCD = LENGTH ASYM_M5_TCD >= BDTCD_W_3_L
LONGEDGE_M5_TCD = LENGTH M5_TCD >= BDTCD_W_3_L
LONG_M5_TCD_050 = INT [LONGEDGE_M5_TCD] == BDTCD_W_3A OPPOSITE
LONG_M5_TCD_100 = INT [LONGEDGE_M5_TCD] == BDTCD_W_3B OPPOSITE
LONG_M5_TCD_200 = INT [LONGEDGE_M5_TCD] == BDTCD_W_3C OPPOSITE
SYM_M6_TCD = M6 AND (TCDDMY_FM6 OR TCDDMY_FDM6)
ASYM_M6_TCD = M6 AND TCDDMY_M6
M6_TCD = SYM_M6_TCD OR ASYM_M6_TCD
LONGEDGE_SYM_M6_TCD = LENGTH SYM_M6_TCD >= BDTCD_W_3_L
LONGEDGE_ASYM_M6_TCD = LENGTH ASYM_M6_TCD >= BDTCD_W_3_L
LONGEDGE_M6_TCD = LENGTH M6_TCD >= BDTCD_W_3_L
LONG_M6_TCD_050 = INT [LONGEDGE_M6_TCD] == BDTCD_W_3A OPPOSITE
LONG_M6_TCD_100 = INT [LONGEDGE_M6_TCD] == BDTCD_W_3B OPPOSITE
