  M6_TypeBRS3_CACB_S6_1 = (M6_TypeBRS3_prefilter_8 INTERACT M6_TypeBRS3_prefilter_16 != 6) NOT ENCLOSE M6_TypeBRS3_prefilter_15
  M6_TypeBRS3_CACB_S6_2 = M6_TypeBRS3_CACB_S6_1 WITH WIDTH <= TypeBRS3_S6+GRID
