IND.R.1 { @ In the region of (INDDMY SIZING 16 um), inter-via VIAx, and VIAy are not allowed. (Except VIAx in {LOWMEDN NOT {LOWMEDN SIZING -4 um}})   
   (VIA1 AND IND_REGION) NOT P_RING_REGION


   (VIA2 AND IND_REGION) NOT P_RING_REGION


   (VIA3 AND IND_REGION) NOT P_RING_REGION


   (VIA4 AND IND_REGION) NOT P_RING_REGION


   (VIA5 AND IND_REGION) NOT P_RING_REGION


   (VIA6 AND IND_REGION) NOT P_RING_REGION




}
// IND_MD.R.1 is checked by 'IND.R.1'


// 'IND.R.2' is checked by IND.R.2:VIA7
IND.R.2:VIA7 { @ At least 4 VIAz with space <= 1.7 um are required to connect [two Mz layers], [Mz to inter-My] or [Mz to Mx] in (INDDMY SIZING 16 um). (DRC checks VIAz counts including VIAz beside {INDDMY SIZING 16 um}) <= 1.7 
  M8OvpM7 = (M8 AND M7) AND IND_REGION 
  Check_VIA7 = VIA7 NOT OUTSIDE M8OvpM7

  M8OvpM7_CHK = (M8 AND M7) INTERACT Check_VIA7
  Check_VIA7_CHK = VIA7 NOT OUTSIDE M8OvpM7_CHK

  VIA7Merge = SIZE Check_VIA7_CHK BY (IND_R_2/2) INSIDE OF M8OvpM7_CHK STEP M7_S_1*0.7
  VIA7Merge2 = VIA7Merge ENCLOSE Check_VIA7_CHK >= IND_R_2_N
  Good_VIA7 = Check_VIA7 AND VIA7Merge2
  GM8OvpM7 = M8OvpM7 INTERACT Good_VIA7
  Check_VIA7 OUTSIDE GM8OvpM7
}
// IND.R.2 is checked by IND.R.2:VIA7







// 'IND.R.3' is checked by IND.R.3:VIA8
IND.R.3:VIA8 { @ At least 4 VIAu with space <= 1.7 um are required to connect [Mu to Mz], [Mu to My], or [Mu to Mx] in (INDDMY SIZING 16 um). (DRC checks VIAu counts including VIAu beside {INDDMY SIZING 16 um}) <= 1.7 
  M9OvpM8 = (M9 AND M8) AND IND_REGION 
  Check_VIA8 = VIA8 NOT OUTSIDE M9OvpM8

  M9OvpM8_CHK = (M9 AND M8) INTERACT Check_VIA8
  Check_VIA8_CHK = VIA8 NOT OUTSIDE M9OvpM8_CHK

  VIA8Merge = SIZE Check_VIA8_CHK BY (IND_R_3/2) INSIDE OF M9OvpM8_CHK STEP M8_S_1*0.7
  VIA8Merge2 = VIA8Merge ENCLOSE Check_VIA8_CHK >= IND_R_3_N
  Good_VIA8 = Check_VIA8 AND VIA8Merge2
  GM9OvpM8 = M9OvpM8 INTERACT Good_VIA8
  Check_VIA8 OUTSIDE GM9OvpM8
}

// IND_MD.R.3 is checked by 'IND.R.3'

//'IND.R.4' is not necessary to check



INDR5_M1_DN = DENSITY M1x >= 0.1 WINDOW 125 STEP 62.5 BACKUP INSIDE OF LAYER INDDMY_ALL
INDR5_M2_DN = DENSITY M2x >= 0.1 WINDOW 125 STEP 62.5 BACKUP INSIDE OF LAYER INDDMY_ALL
INDR5_M3_DN = DENSITY M3x >= 0.1 WINDOW 125 STEP 62.5 BACKUP INSIDE OF LAYER INDDMY_ALL
INDR5_M4_DN = DENSITY M4x >= 0.1 WINDOW 125 STEP 62.5 BACKUP INSIDE OF LAYER INDDMY_ALL
INDR5_M5_DN = DENSITY M5x >= 0.1 WINDOW 125 STEP 62.5 BACKUP INSIDE OF LAYER INDDMY_ALL
INDR5_M6_DN = DENSITY M6x >= 0.1 WINDOW 125 STEP 62.5 BACKUP INSIDE OF LAYER INDDMY_ALL
INDR5_M7_DN = DENSITY M7x >= 0.1 WINDOW 125 STEP 62.5 BACKUP INSIDE OF LAYER INDDMY_ALL
 INDR5_DN_BAD1 = INDDMY_ALL NOT INSIDE   ( ( ( ( ( ( INDR5_M1_DN AND INDR5_M2_DN)  AND INDR5_M3_DN)  AND INDR5_M4_DN)  AND INDR5_M5_DN)  AND INDR5_M6_DN)  AND INDR5_M7_DN)  
 INDR5_DN_BAD2 = INDDMY_ALL NOT INSIDE   ( ( ( ( ( ( INDR5_M1_DN AND INDR5_M2_DN)  AND INDR5_M3_DN)  AND INDR5_M4_DN)  AND INDR5_M5_DN)  AND INDR5_M6_DN)  AND INDR5_M7_DN)  
IND.R.5 { @ In the INDDMY identified region "a", except the Mx or My layer (one layer only) directly below [Mz, Mr or Mu], any other inter-metal layer (Mx/My) is not allowed. (e.g., for a 1P6M process with 0.9 um of M6 (Mz), then Mx of M5 is allowed, but other lower Mx metal layers are not allowed for the INDDMY identified inductor.) Except the following condition: 1 Mx in {{LOWMEDN NOT {LOWMEDN SIZING -5 um}} INTERACT VIAx bar}, 2 Inter-metal Mx in INDDMY is allowed if the metal density of all M1/Mx layer in region "a" are all larger than 10% in window 125 um x 125 um, stepping 62.5 um (M1.DN.1 and Mx.DN.1) 3 Inter-metal My in INDDMY is allowed if the metal density of all M1/Mx/My layer in region "a" are all larger than 10% in window 125 um x 125 um, stepping 62.5 um (M1.DN.1, Mx.DN.1 and My.DN.1)   
  (M2 AND INDR5_DN_BAD1) NOT ((M2 AND P_RING_REGION2) INTERACT P_RING_VIA1)

  (M3 AND INDR5_DN_BAD1) NOT ((M3 AND P_RING_REGION2) INTERACT P_RING_VIA2)

  (M4 AND INDR5_DN_BAD1) NOT ((M4 AND P_RING_REGION2) INTERACT P_RING_VIA3)

  (M5 AND INDR5_DN_BAD1) NOT ((M5 AND P_RING_REGION2) INTERACT P_RING_VIA4)

  (M6 AND INDR5_DN_BAD1) NOT ((M6 AND P_RING_REGION2) INTERACT P_RING_VIA5)

}
// IND_MD.R.5 is checked by 'IND.R.5'



// IND.R.8 is checked by RV.R.1
// IND.R.10 is checked by related rules
// IND.R.11 is checked by related rules

#IFDEF FULL_CHIP
IND.DN.1 { @ Maximum density of INDDMY on a whole chip <= 5% 
  DENSITY INDDMY_ALL CHIP > IND_DN_1 INSIDE OF LAYER CHIPx PRINT IND.DN.1.density
    [ AREA(INDDMY_ALL)/AREA(CHIP) ]
}

#ENDIF

IND.DN.2:M1 { @ Maximum M1/Mx/My density within (INDDMY SIZING 16 um) in window 125 um x 125 um, stepping 62.5 um <= 85% 
  DENSITY M1x > IND_DN_2 INSIDE OF LAYER IND_REGION WINDOW IND_DN_2_W STEP IND_DN_2_S BACKUP PRINT IND.DN.2.M1.density 
}
// IND.DN.2 is checked by IND.DN.2:M1
IND.DN.2:M2 { @ Maximum M1/Mx/My density within (INDDMY SIZING 16 um) in window 125 um x 125 um, stepping 62.5 um <= 85% 
  DENSITY M2x > IND_DN_2 INSIDE OF LAYER IND_REGION WINDOW IND_DN_2_W STEP IND_DN_2_S BACKUP PRINT IND.DN.2.M2.density 
}
// IND.DN.2 is checked by IND.DN.2:M2
IND.DN.2:M3 { @ Maximum M1/Mx/My density within (INDDMY SIZING 16 um) in window 125 um x 125 um, stepping 62.5 um <= 85% 
  DENSITY M3x > IND_DN_2 INSIDE OF LAYER IND_REGION WINDOW IND_DN_2_W STEP IND_DN_2_S BACKUP PRINT IND.DN.2.M3.density 
}
// IND.DN.2 is checked by IND.DN.2:M3
IND.DN.2:M4 { @ Maximum M1/Mx/My density within (INDDMY SIZING 16 um) in window 125 um x 125 um, stepping 62.5 um <= 85% 
  DENSITY M4x > IND_DN_2 INSIDE OF LAYER IND_REGION WINDOW IND_DN_2_W STEP IND_DN_2_S BACKUP PRINT IND.DN.2.M4.density 
}
// IND.DN.2 is checked by IND.DN.2:M4
IND.DN.2:M5 { @ Maximum M1/Mx/My density within (INDDMY SIZING 16 um) in window 125 um x 125 um, stepping 62.5 um <= 85% 
  DENSITY M5x > IND_DN_2 INSIDE OF LAYER IND_REGION WINDOW IND_DN_2_W STEP IND_DN_2_S BACKUP PRINT IND.DN.2.M5.density 
}
// IND.DN.2 is checked by IND.DN.2:M5
IND.DN.2:M6 { @ Maximum M1/Mx/My density within (INDDMY SIZING 16 um) in window 125 um x 125 um, stepping 62.5 um <= 85% 
  DENSITY M6x > IND_DN_2 INSIDE OF LAYER IND_REGION WINDOW IND_DN_2_W STEP IND_DN_2_S BACKUP PRINT IND.DN.2.M6.density 
}
// IND.DN.2 is checked by IND.DN.2:M6
IND.DN.2:M7 { @ Maximum M1/Mx/My density within (INDDMY SIZING 16 um) in window 125 um x 125 um, stepping 62.5 um <= 85% 
  DENSITY M7x > IND_DN_2 INSIDE OF LAYER IND_REGION WINDOW IND_DN_2_W STEP IND_DN_2_S BACKUP PRINT IND.DN.2.M7.density 
}
// IND.DN.2 is checked by IND.DN.2:M7


CHIP_IND = CHIP INTERACT INDDMY_ALL
#IFDEF FULL_CHIP

// 'IND.DN.3' is checked by IND.DN.3:M1
IND.DN.3:M1 { @ M1/Mx/My/Mz/Mr/Mu metal density over the whole chip (include INDDMY) >= 20% 
  ERR_WIN = DENSITY M1x CHIP < IND_DN_3 INSIDE OF LAYER CHIPx PRINT IND.DN.3.M1.density [ AREA(M1x)/AREA(CHIP) ]
  ERR_WIN AND CHIP_IND
}
// 'IND.DN.3' is checked by IND.DN.3:M2
IND.DN.3:M2 { @ M1/Mx/My/Mz/Mr/Mu metal density over the whole chip (include INDDMY) >= 20% 
  ERR_WIN = DENSITY M2x CHIP < IND_DN_3 INSIDE OF LAYER CHIPx PRINT IND.DN.3.M2.density [ AREA(M2x)/AREA(CHIP) ]
  ERR_WIN AND CHIP_IND
}
// 'IND.DN.3' is checked by IND.DN.3:M3
IND.DN.3:M3 { @ M1/Mx/My/Mz/Mr/Mu metal density over the whole chip (include INDDMY) >= 20% 
  ERR_WIN = DENSITY M3x CHIP < IND_DN_3 INSIDE OF LAYER CHIPx PRINT IND.DN.3.M3.density [ AREA(M3x)/AREA(CHIP) ]
  ERR_WIN AND CHIP_IND
}
// 'IND.DN.3' is checked by IND.DN.3:M4
IND.DN.3:M4 { @ M1/Mx/My/Mz/Mr/Mu metal density over the whole chip (include INDDMY) >= 20% 
  ERR_WIN = DENSITY M4x CHIP < IND_DN_3 INSIDE OF LAYER CHIPx PRINT IND.DN.3.M4.density [ AREA(M4x)/AREA(CHIP) ]
  ERR_WIN AND CHIP_IND
}
// 'IND.DN.3' is checked by IND.DN.3:M5
IND.DN.3:M5 { @ M1/Mx/My/Mz/Mr/Mu metal density over the whole chip (include INDDMY) >= 20% 
  ERR_WIN = DENSITY M5x CHIP < IND_DN_3 INSIDE OF LAYER CHIPx PRINT IND.DN.3.M5.density [ AREA(M5x)/AREA(CHIP) ]
  ERR_WIN AND CHIP_IND
}
// 'IND.DN.3' is checked by IND.DN.3:M6
IND.DN.3:M6 { @ M1/Mx/My/Mz/Mr/Mu metal density over the whole chip (include INDDMY) >= 20% 
  ERR_WIN = DENSITY M6x CHIP < IND_DN_3 INSIDE OF LAYER CHIPx PRINT IND.DN.3.M6.density [ AREA(M6x)/AREA(CHIP) ]
  ERR_WIN AND CHIP_IND
}
// 'IND.DN.3' is checked by IND.DN.3:M7
IND.DN.3:M7 { @ M1/Mx/My/Mz/Mr/Mu metal density over the whole chip (include INDDMY) >= 20% 
  ERR_WIN = DENSITY M7x CHIP < IND_DN_3 INSIDE OF LAYER CHIPx PRINT IND.DN.3.M7.density [ AREA(M7x)/AREA(CHIP) ]
  ERR_WIN AND CHIP_IND
}
// 'IND.DN.3' is checked by IND.DN.3:M8
IND.DN.3:M8 { @ M1/Mx/My/Mz/Mr/Mu metal density over the whole chip (include INDDMY) >= 20% 
  ERR_WIN = DENSITY M8x CHIP < IND_DN_3 INSIDE OF LAYER CHIPx PRINT IND.DN.3.M8.density [ AREA(M8x)/AREA(CHIP) ]
  ERR_WIN AND CHIP_IND
}
// 'IND.DN.3' is checked by IND.DN.3:M9
IND.DN.3:M9 { @ M1/Mx/My/Mz/Mr/Mu metal density over the whole chip (include INDDMY) >= 20% 
  ERR_WIN = DENSITY M9x CHIP < IND_DN_3 INSIDE OF LAYER CHIPx PRINT IND.DN.3.M9.density [ AREA(M9x)/AREA(CHIP) ]
  ERR_WIN AND CHIP_IND
}
// IND_MD.DN.3 is checked by 'IND.DN.3'
#ENDIF
// IND.DN.4 is checked by [Mz.DN.1 , Mr.DN.1 and Mu.DN.3]
// IND.DN.5 is checked by [Mz.DN.2 , Mr.DN.2 and Mu.DN.4]
IND.DN.7 { @ Maximum density of INDDMY in window 1600 um x 1600 um, stepping 800 um <= 14% 
  DENSITY INDDMY_ALL CHIP > IND_DN_7 INSIDE OF LAYER CHIPx WINDOW IND_DN_7_W STEP IND_DN_7_S BACKUP PRINT IND.DN.7.density 
  [ AREA(INDDMY_ALL)/AREA(CHIP) ]
}




IND_MD.R.18 { @ INDDMY overlap with (INDDMY_HD or INDDMY_MD) is not allowed.
   INDDMY AND INDDMY_HD
   INDDMY AND INDDMY_MD
}
IND_MD.R.19 { @ INDDMY_HD overlap with INDDMY_MD is not allowed.
   INDDMY_HD AND INDDMY_MD
}

//IND_MD.W.1 is checked by 'IND.W.1'
//IND_MD.W.2 is checked by 'IND.W.2'
//IND_MD.W.4 is checked by 'IND.W.4'
//IND_MD.W.5 is checked by 'IND.W.5'
//IND_MD.W.6 is checked by 'IND.W.6'
//IND_MD.W.7 is checked by 'IND.W.7'
//IND_MD.W.9 is checked by 'IND.W.9'
//IND_MD.W.10 is checked by 'IND.W.10'
//IND_MD.S.1 is checked by 'IND.S.1'
//IND_MD.S.2 is checked by 'IND.S.2'
//IND_MD.S.3 is checked by 'IND.S.3'
//IND_MD.S.4 is checked by 'IND.S.4'
//IND_MD.S.5 is checked by 'IND.S.5'
//IND_MD.S.6 is checked by 'IND.S.6'
//IND_MD.S.10 is checked by 'IND.S.10'
//IND_MD.DN.1 is checked by 'IND.DN.1'
//IND_MD.DN.2 is checked by 'IND.DN.2'
//IND_MD.DN.4 is checked by 'IND.DN.4'
//IND_MD.DN.5 is checked by 'IND.DN.5'
//IND_MD.DN.7 is checked by 'IND.DN.7'
//IND_MD.R.2 is checked by 'IND.R.2'
//IND_MD.R.4 is checked by 'IND.R.4'
//IND_MD.R.8 is checked by 'IND.R.8'
//IND_MD.R.10 is checked by 'IND.R.10'
//IND_MD.R.11 is checked by 'IND.R.11'


// RV CHECKS
//==========
RV_NIND = RV NOT INSIDE IND_EXD
RV_IND = RV INSIDE IND_EXD
RV_NINDx = RV_NIND NOT INSIDE SEALRING_ALL
RV_INDx = RV_IND NOT INSIDE SEALRING_ALL

RV.W.1 { @ Width (maximum = minimum) (Except SEALRING_ALL (162;2)) = 3 
  NOT RECTANGLE RV_NINDx == RV_W_1A BY == RV_W_1A ORTHOGONAL ONLY
  NOT RECTANGLE RV_INDx >= (RV_W_1A-2*GRID) <= (RV_W_1A+2*GRID) BY >= (RV_W_1A-2*GRID) <= (RV_W_1A+2*GRID)
}
RV.S.1 { @ Space >= 2 
  EXT RV_NIND RV < RV_S_1 ABUT < 90 SINGULAR REGION
  EXT RV_IND RV < RV_S_1-2*GRID ABUT < 90 SINGULAR REGION
}
RV.EN.1 { @ Enclosure by top metal >= 0.5 
  ENC RV_NINDx M9 < RV_EN_1 ABUT < 90 SINGULAR REGION OUTSIDE ALSO
  ENC RV_INDx M9 < RV_EN_1-2*GRID ABUT < 90 SINGULAR REGION OUTSIDE ALSO
}
RV.R.1 { @ A 45-degree rotated RV is not allowed (Except INDDMY)   
  ((NOT RECTANGLE RV ORTHOGONAL ONLY) NOT INSIDE IND_EXD) NOT INSIDE SEALRING_ALL
}
// RV.R.2 is checked by related rules

// AP CHECKS
//==========

AP.W.1 { @ Width (as interconnect) >= 2 
  (INT AP < AP_W_1 ABUT < 90 SINGULAR REGION) NOT INSIDE IND_EXD
  (INT AP < AP_W_1-2*GRID ABUT < 90 SINGULAR REGION) NOT OUTSIDE IND_EXD
}
AP.W.2 { @ Maximum width by {{AP/AP-MD SIZING 0.995 um} SIZING -0.995 um} (Interconnect only) {Not INSIDE UBM, CBD, CB2_FC, CB or CB2_WB} <= 35 
#IFNDEF WLCSP
  A = AP NOT (UBMi OR (CB1i OR CB2i))
#ELSE
  A = AP NOT (CB1i OR CB2i)
#ENDIF
  B = SIZE A BY (AP_S_1/2-GRID) OVERUNDER    
  (B WITH WIDTH > AP_W_2) NOT INSIDE IND_EXD
  (B WITH WIDTH > AP_W_2+2*GRID) NOT OUTSIDE IND_EXD
}
AP.W.5 { @ AP hole width for 28KA AP should >= 3, except < 100 inner 90-degrees vertex of AP holes [width < 3 um] within window 100 um x 100 um, stepping 50 um	
  AP_HOLE = HOLES AP INNER 
  AP_HOLE_SHOURT_EDGE = LENGTH AP_HOLE < AP_W_5
  GRID_VERTEX = INT AP_HOLE <= 0.01 ABUT >89.5 <90.5 REGION PERPENDICULAR ALSO
  AP_HOLE_SHOURT_EDGE_region = EXPAND EDGE AP_HOLE_SHOURT_EDGE INSIDE BY GRID
  GRID_VERTEX_check = GRID_VERTEX INTERACT AP_HOLE_SHOURT_EDGE_region
  GRID_EXTENT = EXTENTS GRID_VERTEX_check CENTERS 0.01
  DENSITY GRID_EXTENT >= 100 WINDOW 100 STEP 50 INSIDE OF LAYER CHIP BACKUP PRINT AP.W.5.rep 
      [ 1E4 * AREA(GRID_EXTENT) ]
}





VARIABLE AP_W_6_2 2
AP.W.6 { @ AP hole width >= 2 
  D_pre = HOLES AP INNER 
  INT D_pre < AP_W_6_2 ABUT < 90 SINGULAR REGION
}

AP.S.1 { @ Space Except the following conditions in the same polygon: 1. AP_PAD_waived_region 2. Jog [length <= 1 um] interact AP_PAD_waived_region The definition of AP_PAD: The width of AP interact {CB2_WB OR CB2_FC} > 35 um The definition of AP_PAD_waived_region: {{{AP AND {AP_PAD SIZING 2 um}} NOT AP_PAD} INTERACT AP_PAD} >= 2 

  AP_PAD = (AP INTERACT (OR CB2Fi CB2Wi)) SIZE BY 35/2 underover
  AP_PAD_1 = SIZE AP_PAD BY 0.005
  A = ((AP AND (SIZE AP_PAD BY 2)) NOT AP_PAD) INTERACT AP_PAD_1
  B = EXT AP < AP_S_1 NOTCH REGION
  C = (EXT A AP_PAD < AP_S_1 REGION) AND B
  C1 = (EXT A < AP_S_1 REGION) AND B
  C2 = (EXT AP_PAD < AP_S_1 REGION) AND B
  E = LENGTH AP <= 0.5* 2.0
  E1 = EXPAND EDGE E INSIDE BY GRID
  E2 = E1 INTERACT A SINGULAR ALSO
  E3 = E COIN EDGE E2
  F = (EXT E3 AP < AP_S_1 REGION) AND B
  G2 = EXPAND EDGE AP_PAD BY 0.005
  WAIVE_REGION = SIZE (OR C C1 C2 G2 F ) BY 0.005
  ((EXT AP < AP_S_1 SINGULAR REGION) NOT INSIDE IND_EXD) NOT WAIVE_REGION
  ((EXT AP < AP_S_1-2*GRID SINGULAR REGION) NOT OUTSIDE IND_EXD) NOT WAIVE_REGION
  (EXT AP < AP_S_1 SPACE SINGULAR REGION) NOT INSIDE IND_EXD
  (EXT AP < AP_S_1-2*GRID SPACE SINGULAR REGION) NOT OUTSIDE IND_EXD
  Y = EXT APi < 0.1 ABUT < 90 INTERSECTING ONLY REGION
  Y NOT INTERACT AP_PAD_1

}


AP_PAD_p = WITH WIDTH (AP INTERACT CB2Wi) > AP_S_1_1_W
CONNECT AP_PAD_p APu
AP_NOT_SR = AP NOT INSIDE SEALRING_EXCLUDE

AP.S.1.1 {@ Space of metal pad, or space of metal pad to metal line [different nets] Except the following conditions: {{{chip INTERACT CoWAM (109;150)} INTERACT CB2_FC} INTERACT CB2_WB} The definition of metal pad: The width of AP interact CB2_WB > 35 um >= 2.63 
  chip_cowam = ((CHIP INTERACT CoWAM) INTERACT CB2Fi) INTERACT CB2Wi
  (EXT AP_PAD_p APu < AP_S_1_1 REGION NOT CONNECTED MEASURE ALL) NOT INTERACT chip_cowam
}





VARIABLE AP_S_6             3.5
VARIABLE AP_S_6_S1          AP_S_6          // AP space (<)
VARIABLE AP_S_6_S1_L1       10              // PRL (>=) of AP_S_6_S1
VARIABLE AP_S_6_S1_L2       AP_S_6_S1       // Edge Length (<) for line-end of AP space
VARIABLE AP_S_6_S2          8               // Line-end space for space region merged (<=)
VARIABLE AP_S_6_S2_L        1               // PRL (>=) of AP_S_6_S2
VARIABLE AP_S_6_S3          AP_S_6          // Mu space (<)
VARIABLE AP_S_6_S3_L1       10              // PRL (>=) of AP_S_6_S3_L
VARIABLE AP_S_6_S3_L2       AP_S_6_S3       // Edge Length (<) for line-end of Mu space
VARIABLE AP_S_6_S4          8               // Line-end space for space region merged (<=)
VARIABLE AP_S_6_S4_L        1               // PRL (>=) of AP_S_6_S4
VARIABLE AP_S_6_W1          1               // Width of overlapping region of Stacked Space Region (>=)
VARIABLE AP_S_6_L1          100             // Length of overlapping region of Stacked Space Region (>=)
VARIABLE AP_S_6_DN          0.20            // Stacked Space Region density
VARIABLE AP_S_6_DN_W        50              // Stacked Space Region density (window)
VARIABLE AP_S_6_DN_S        AP_S_6_DN_W/2   // Stacked Space Region density (step)

AP.S.6 { @ Stacking space [PRL >= 100 um] of AP to AP and {Mu OR DMu} to {Mu OR DMu} (This rule is only checked for "Mu + AP [THK > 14.5KA]" metal combinations) DRC flags Space_APMu when it's density >= 20% in window 50 um x 50 um, stepping 25 um Definition of Space_APMu: {Space_AP AND Space_Mu} [enclose a 1 um x 100 um rectangle] Definition of AP_Oxide: The region [enclose a GRID x 10 um rectangle] of AP space < 3.5 um [PRL > 0 um] Definition of AP_Oxide_S: (1) The region of space between AP_Oxide edges [NOT ABUT AP from outside, length < 3.5 um] <= 8 um [PRL >= 1 um], and (2) the above-mentioned region is not intersected by AP into 2 or more regions Definition of Space_AP: {AP_Oxide OR AP_Oxide_S} Definition of Mu_Oxide: The region [enclose a GRID x 10 um rectangle] of {Mu OR DMu} space < 3.5 um [PRL > 0 um] Definition of Mu_Oxide_S: (1) The region of space between Mu_Oxide edges [NOT ABUT {Mu OR DMu} from outside, length < 3.5 um] <= 8 um [PRL >= 1 um], and (2) the above-mentioned region is not intersected by {Mu OR DMu} into 2 or more regions Definition of Space_Mu: {Mu_Oxide OR Mu_Oxide_S} >= 3.5 
  AP_Sa = EXT APi < AP_S_6_S1 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED
  AP_Sb = ENCLOSE RECTANGLE  AP_Sa  GRID  AP_S_6_S1_L1
  AP_Sc = LENGTH (AP_Sb NOT COIN OUTSIDE EDGE APi) < AP_S_6_S1_L2
  AP_Sd = EXT AP_Sc <= AP_S_6_S2 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED PROJ >= AP_S_6_S2_L
  AP_Se = AP_Sd INTERACT (AP_Sd NOT APi) == 1
  AP_Sf = OR AP_Sb AP_Se

  Mu_Sa = EXT M9x < AP_S_6_S3 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED
  Mu_Sb = ENCLOSE RECTANGLE  Mu_Sa  GRID  AP_S_6_S3_L1
  Mu_Sc = LENGTH (Mu_Sb NOT COIN OUTSIDE EDGE M9x) < AP_S_6_S3_L2
  Mu_Sd = EXT Mu_Sc <= AP_S_6_S4 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED PROJ >= AP_S_6_S4_L
  Mu_Se = Mu_Sd INTERACT (Mu_Sd NOT M9x) == 1
  Mu_Sf = OR Mu_Sb Mu_Se

  AP_Mu_Sf = AP_Sf AND Mu_Sf
  AP_Mu_S6 = ENCLOSE RECTANGLE AP_Mu_Sf  AP_S_6_W1  AP_S_6_L1
  OVLP_DN6 = DENSITY AP_Mu_S6 CHIP >= AP_S_6_DN WINDOW AP_S_6_DN_W STEP AP_S_6_DN_S BACKUP INSIDE OF LAYER CHIPx PRINT AP.S.6_DN.density RDB AP.S.6_DN.RDB.density
             [AREA(AP_Mu_S6)/AREA(CHIP)]

  AP_Mu_S6 AND OVLP_DN6
}

VARIABLE AP_S_7             5
VARIABLE AP_S_7_S1          AP_S_7          // AP space (<)
VARIABLE AP_S_7_S1_L1       10              // PRL (>=) of AP_S_7_S1
VARIABLE AP_S_7_S1_L2       AP_S_7_S1       // Edge Length (<) for line-end of AP space
VARIABLE AP_S_7_S2          8               // Line-end space for space region merged (<=)
VARIABLE AP_S_7_S2_L        1               // PRL (>=) of AP_S_7_S2
VARIABLE AP_S_7_S3          AP_S_7          // Mu space (<)
VARIABLE AP_S_7_S3_L1       10              // PRL (>=) of AP_S_7_S3_L
VARIABLE AP_S_7_S3_L2       AP_S_7_S3       // Edge Length (<) for line-end of Mu space
VARIABLE AP_S_7_S4          8               // Line-end space for space region merged (<=)
VARIABLE AP_S_7_S4_L        1               // PRL (>=) of AP_S_7_S4
VARIABLE AP_S_7_W1          1               // Width of overlapping region of Stacked Space Region (>=)
VARIABLE AP_S_7_L1          500             // Length of overlapping region of Stacked Space Region (>=)
VARIABLE AP_S_7_DN          0.20            // Stacked Space Region density
VARIABLE AP_S_7_DN_W        150             // Stacked Space Region density (window)
VARIABLE AP_S_7_DN_S        AP_S_7_DN_W/2   // Stacked Space Region density (step)

AP.S.7 { @ Stacking space [PRL >= 500 um] of AP to AP and {Mu OR DMu} to {Mu OR DMu} (This rule is only checked for "Mu + AP [THK > 14.5KA]" metal combinations) DRC flags Space_APMu when it's density >= 20% in window 150 um x 150 um, stepping 75 um Definition of Space_APMu: {Space_AP AND Space_Mu} [enclose a 1 um x 500 um rectangle] Definition of AP_Oxide: The region [enclose a GRID x 10 um rectangle] of AP space < 5 um [PRL > 0 um] Definition of AP_Oxide_S: 1 The region of space between AP_Oxide edges [NOT ABUT AP from outside, length < 5 um] <= 8 um [PRL >= 1 um], and 2 the above-mentioned region is not intersected by AP into 2 or more regions Definition of Space_AP: {AP_Oxide OR AP_Oxide_S} Definition of Mu_Oxide: The region [enclose a GRID x 10 um rectangle] of {Mu OR DMu} space < 5 um [PRL > 0 um] Definition of Mu_Oxide_S: 1 The region of space between Mu_Oxide edges [NOT ABUT {Mu OR DMu} from outside, length < 5 um] <= 8 um [PRL >= 1 um], and 2 the above-mentioned region is not intersected by {Mu OR DMu} into 2 or more regions Definition of Space_Mu: {Mu_Oxide OR Mu_Oxide_S} >= 5 
  AP_Sa = EXT APi < AP_S_7_S1 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED
  AP_Sb = ENCLOSE RECTANGLE  AP_Sa  GRID  AP_S_7_S1_L1
  AP_Sc = LENGTH (AP_Sb NOT COIN OUTSIDE EDGE APi) < AP_S_7_S1_L2
  AP_Sd = EXT AP_Sc <= AP_S_7_S2 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED PROJ >= AP_S_7_S2_L
  AP_Se = AP_Sd INTERACT (AP_Sd NOT APi) == 1
  AP_Sf = OR AP_Sb AP_Se

  Mu_Sa = EXT M9x < AP_S_7_S3 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED
  Mu_Sb = ENCLOSE RECTANGLE  Mu_Sa  GRID  AP_S_7_S3_L1
  Mu_Sc = LENGTH (Mu_Sb NOT COIN OUTSIDE EDGE M9x) < AP_S_7_S3_L2
  Mu_Sd = EXT Mu_Sc <= AP_S_7_S4 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED PROJ >= AP_S_7_S4_L
  Mu_Se = Mu_Sd INTERACT (Mu_Sd NOT M9x) == 1
  Mu_Sf = OR Mu_Sb Mu_Se

  AP_Mu_Sf = AP_Sf AND Mu_Sf
  AP_Mu_S7 = ENCLOSE RECTANGLE AP_Mu_Sf  AP_S_7_W1  AP_S_7_L1
  OVLP_DN7 = DENSITY AP_Mu_S7 CHIP >= AP_S_7_DN WINDOW AP_S_7_DN_W STEP AP_S_7_DN_S BACKUP INSIDE OF LAYER CHIPx PRINT AP.S.7_DN.density RDB AP.S.7_DN.RDB.density
             [AREA(AP_Mu_S7)/AREA(CHIP)]

  AP_Mu_S7 AND OVLP_DN7
}

VARIABLE AP_S_8         3.5
VARIABLE AP_S_8_W1      20      // Wide AP width
VARIABLE AP_S_8_L1      5       // Length of 90-270 or 135-270
VARIABLE AP_S_8_L2      5       // Length of 90-225 or 135-225
VARIABLE AP_S_8_L3      20      // Length of 225-225
VARIABLE AP_S_8_A1      90      // Angle 90
VARIABLE AP_S_8_A2      135     // Angle 135
VARIABLE AP_S_8_A3      225     // Angle 225
VARIABLE AP_S_8_A4      270     // Angle 270
VARIABLE AP_S_8_R1      20      // Pad range


AP.S.8 { @ Z_shape_space [OUTSIDE {Mu OR DMu}, INTERACT {{CB2_WB OR CB2_FC} SIZING 20 um}] of AP to AP (This rule is only checked for "Mu + AP [THK > 14.5KA]" metal combinations) Definition of L_edge: 1 AP edges [length >= 5 um, formed by 2 consecutive 90-270 or 135-270 degree corners] which share endpoint with each other, but don't share endpoint with U-shape AP edge [formed by 2 consecutive 225-270 or 270-270 degree corners], or 2 AP edges [length >= 5 um, formed by 2 consecutive 90-225 or 135-225 degree corners] which share endpoint with AP edge [length <= 20 um, formed by 2 consecutive 225-225 degree corners] in-between (also included as L_edge), but doesn't share endpoint with U-shape AP edge [formed by 2 consecutive 225-225 or 225-270 degree corners, shares endpoint with each other] Definition of Wide_AP: AP [width >= 20 um] Definition of L_edge_AP: Whole edge of L_edge [ABUT Wide_AP] Definition of Z_shape_space: The region of L_edge_AP space to Wide_AP [with L_edge_AP] < 3.5 um [PRL > 0 um] has 2 opposite edges [distance < 3.5 um, PRL > 0 um] with the following conditions: 1 Both edges abut L_edge_AP, or 2 One edge abuts L_edge_AP and the other shares endpoint with L_edge_AP, or One edge abuts L_edge_AP and the other shares endpoint with AP edge [formed by 2 consecutive 135-135 degree corners, doesn't share endpoint with each other, shares endpoint with L_edge_AP] >= 3.5 
  AP_S_8_L_E1m = CONVEX EDGE APi ANGLE1 == AP_S_8_A1 ANGLE2 == AP_S_8_A4 WITH LENGTH >= AP_S_8_L1
  AP_S_8_L_E1n = CONVEX EDGE APi ANGLE1 == AP_S_8_A2 ANGLE2 == AP_S_8_A4 WITH LENGTH >= AP_S_8_L1
  AP_S_8_L_E1  = APi COIN EDGE (AP_S_8_L_E1m OR EDGE AP_S_8_L_E1n)
  AP_S_8_L_E1X = CONVEX EDGE AP_S_8_L_E1 ANGLE1 >= 0 ANGLE2 > 0
  
  AP_S_8_L_E5m = CONVEX EDGE APi ANGLE1 == AP_S_8_A3 ANGLE2 == AP_S_8_A4
  AP_S_8_L_E5n = CONVEX EDGE APi ANGLE1 == AP_S_8_A4 ANGLE2 == AP_S_8_A4
  AP_S_8_L_E5  = APi COIN EDGE (AP_S_8_L_E5m OR EDGE AP_S_8_L_E5n)
  AP_S_8_L_E5a = EXPAND EDGE AP_S_8_L_E5 OUTSIDE BY GRID

  AP_S_8_L_E1T = AP_S_8_L_E1X NOT TOUCH EDGE AP_S_8_L_E5a

  AP_S_8_L_E2m = CONVEX EDGE APi ANGLE1 == AP_S_8_A1 ANGLE2 == AP_S_8_A3 WITH LENGTH >= AP_S_8_L2
  AP_S_8_L_E2n = CONVEX EDGE APi ANGLE1 == AP_S_8_A2 ANGLE2 == AP_S_8_A3 WITH LENGTH >= AP_S_8_L2
  AP_S_8_L_E2  = APi COIN EDGE (AP_S_8_L_E2m OR EDGE AP_S_8_L_E2n)

  AP_S_8_L_E3x = CONVEX EDGE APi ANGLE1 == AP_S_8_A3 ANGLE2 == AP_S_8_A3 WITH LENGTH <= AP_S_8_L3
  AP_S_8_L_E3m = CONVEX EDGE APi ANGLE1 == AP_S_8_A3 ANGLE2 == AP_S_8_A3
  AP_S_8_L_E3n = CONVEX EDGE APi ANGLE1 == AP_S_8_A3 ANGLE2 == AP_S_8_A4
  AP_S_8_L_E3  = APi COIN EDGE (AP_S_8_L_E3m OR EDGE AP_S_8_L_E3n)
  AP_S_8_L_E3a = CONVEX EDGE AP_S_8_L_E3 ANGLE1 >= 0 ANGLE2 > 0

  AP_S_8_L_E3aR = EXTENTS (EXPAND EDGE AP_S_8_L_E3a OUTSIDE BY GRID)
  AP_S_8_L_E2a = AP_S_8_L_E2 NOT TOUCH EDGE AP_S_8_L_E3aR
  AP_S_8_L_E3x1 = AP_S_8_L_E3x NOT TOUCH EDGE AP_S_8_L_E3a
  AP_S_8_L_E3x1R = (EXTENTS (EXPAND EDGE AP_S_8_L_E3x1 OUTSIDE BY GRID)) WITH EDGE AP_S_8_L_E2a >= 2
  AP_S_8_L_E3xT = AP_S_8_L_E3x1 INSIDE EDGE AP_S_8_L_E3x1R
  AP_S_8_L_E2b = AP_S_8_L_E2a TOUCH EDGE AP_S_8_L_E3x1R
  AP_S_8_L_E2T = AP_S_8_L_E2b OR EDGE AP_S_8_L_E3xT

  AP_S_8_L_E12 = AP_S_8_L_E1T OR EDGE AP_S_8_L_E2T
  AP_S_8_L_E12T = APi COIN EDGE AP_S_8_L_E12

  AP_S_8_Wide_AP = WITH WIDTH APi >= AP_S_8_W1
  AP_S_8_L_E12Tx = AP_S_8_L_E12T TOUCH EDGE AP_S_8_Wide_AP
  AP_S_8_Wide_AP_withE12Tx = AP_S_8_Wide_AP WITH EDGE AP_S_8_L_E12Tx
  AP_S_8_SP = EXT AP_S_8_L_E12Tx AP_S_8_Wide_AP_withE12Tx < AP_S_8 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED

  AP_S_8_L_E12TxR = EXPAND EDGE AP_S_8_L_E12Tx INSIDE BY GRID
  AP_S_8_SPa1 = AP_S_8_SP TOUCH EDGE AP_S_8_L_E12Tx
  AP_S_8_SPa2 = AP_S_8_SP TOUCH EDGE (AP_S_8_L_E12TxR NOT TOUCH EDGE AP_S_8_L_E12Tx)
  AP_S_8_SP1 = INT AP_S_8_SPa1 < AP_S_8 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED
  AP_S_8_SP2 = INT AP_S_8_SPa1 AP_S_8_SPa2 < AP_S_8 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED
 
  AP_S_8_L_E4 = CONVEX EDGE APi ANGLE1 == AP_S_8_A2 ANGLE2 == AP_S_8_A2
  AP_S_8_L_E4a = CONVEX EDGE AP_S_8_L_E4 ANGLE1 == 0 ANGLE2 == 0
  AP_S_8_L_E4R = EXTENTS (EXPAND EDGE AP_S_8_L_E4a INSIDE BY GRID)
  AP_S_8_L_E4Ra = AP_S_8_L_E4R WITH EDGE AP_S_8_L_E12Tx

  AP_S_8_SPb = (AP_S_8_SP TOUCH EDGE AP_S_8_L_E4Ra) NOT TOUCH EDGE AP_S_8_L_E12Tx
  AP_S_8_SP3 = INT AP_S_8_SPa1 AP_S_8_SPb < AP_S_8 ABUT < 90 OPPOSITE REGION EXCLUDE SHIELDED

  AP_S_8_SPT = OR AP_S_8_SP1 AP_S_8_SP2 AP_S_8_SP3
  AP_S_8_PAD_RANGE = SIZE (OR CB2Fi CB2Wi) BY AP_S_8_R1
  (AP_S_8_SPT OUTSIDE M9x) INTERACT AP_S_8_PAD_RANGE
}






AP.EN.1 { @ Enclosure of RV >= 0.5 
  ENC RV_NIND AP < AP_EN_1 ABUT < 90 SINGULAR REGION OUTSIDE ALSO
  ENC RV_IND AP < AP_EN_1-2*GRID ABUT < 90 SINGULAR REGION OUTSIDE ALSO
}

#IFDEF FULL_CHIP

AP.DN.1 { @ Minimum AP density across full chip >= 10% 
  DENSITY APi < AP_DN_1 INSIDE OF LAYER CHIP_AP PRINT AP.DN.1.density
}

AP.DN.2 { @ Maximum AP density across full chip <= ^AP_DN_2
  DENSITY APi > AP_DN_2 INSIDE OF LAYER CHIPx PRINT AP.DN.2.density
}
#ENDIF
// AP.R.1 is checked by related rules



#ENDIF // BACK_END
#ENDIF // ESD_LUP_RULE_CHECK_ONLY
#ENDIF // VOLTAGE_RULE_CHECK_ONLY
#ENDIF // EFP_ONLY
#ENDIF // DFM_ONLY

#IFNDEF DFM_ONLY
#IFNDEF EFP_ONLY
#IFNDEF VOLTAGE_RULE_CHECK_ONLY
#IFNDEF ESD_LUP_RULE_CHECK_ONLY

ARRAY_VTx = MERGE ARRAY_VT
VARIABLE ARRAY_VT_A_1_0.55 0.55
VARIABLE ARRAY_VT_A_1_80000 80000
ARRAY_VT.A.1 { @ Maximum area of High_PO_DN_region1 Definition of High_PO_DN_region1: Density of {{{PO OR SR_DPO} OR DPO} NOT CPO} inside ARRAY_VT (255;48) >= 55% <= 80000 

    ARRAY_VT_A_1_CHECK = DFM PROPERTY ARRAY_VT ALL_POLY
    [DN = AREA(ALL_POLY)/AREA(ARRAY_VT)] >= ARRAY_VT_A_1_0.55
    DFM PROPERTY ARRAY_VT_A_1_CHECK
    [-= AREA(ARRAY_VT_A_1_CHECK)] > ARRAY_VT_A_1_80000
}

VARIABLE ARRAY_VT_A_2_0.50 0.50
VARIABLE ARRAY_VT_A_2_300000 300000
ARRAY_VT.A.2 { @ Maximum area of High_PO_DN_region2 Definition of High_PO_DN_region2: Density of {{{PO OR SR_DPO} OR DPO} NOT CPO} inside ARRAY_VT (255;48) >= 50% <= 300000 

    ARRAY_VT_A_2_CHECK = DFM PROPERTY ARRAY_VT ALL_POLY
    [DN = AREA(ALL_POLY)/AREA(ARRAY_VT)] >= ARRAY_VT_A_2_0.50
    DFM PROPERTY ARRAY_VT_A_2_CHECK
    [-= AREA(ARRAY_VT_A_2_CHECK)] > ARRAY_VT_A_2_300000

}

VARIABLE ARRAY_VT_A_3_0.50 0.50
VARIABLE ARRAY_VT_A_3_400000 400000
ARRAY_VT.A.3 { @ Maximum area of High_PO_DN_region3 Definition of High_PO_DN_region3: Density of {{{PO OR SR_DPO} OR DPO} NOT CPO} inside ARRAY_VT (255;48) < 50% <= 400000 

    ARRAY_VT_A_3_CHECK = DFM PROPERTY ARRAY_VT ALL_POLY
    [DN = AREA(ALL_POLY)/AREA(ARRAY_VT)] < ARRAY_VT_A_3_0.50
    DFM PROPERTY ARRAY_VT_A_3_CHECK
    [-= AREA(ARRAY_VT_A_3_CHECK)] > ARRAY_VT_A_3_400000

}

VARIABLE ARRAY_VT_A_4_20000 20000
ARRAY_VT.A.4 { @ Area of ARRAY_VT >= 20000 

        AREA ARRAY_VT < ARRAY_VT_A_4_20000
}
VARIABLE ARRAY_VT_R_1_6 6
VARIABLE ARRAY_VT_R_1_0.1 0.1
ARRAY_VT.R.1 { @ For within 6 um surrounding range around ARRAY_VT (255;48), OD and PO density difference between surrounding and MOS array <= 10% 
    ARRAY_VT_outer = (SIZE ARRAY_VT BY  ARRAY_VT_R_1_6) NOT ARRAY_VT
    ARRAY_VT_inner = ARRAY_VT NOT (SIZE ARRAY_VT BY - ARRAY_VT_R_1_6)
    ARRAY_VT_outerP = DFM PROPERTY ARRAY_VT_outer ALL_OD ALL_POLY [den_od = AREA(ALL_OD)/AREA(ARRAY_VT_outer)] [den_po = AREA(ALL_POLY)/AREA(ARRAY_VT_outer)] 
    ARRAY_VT_innerP = DFM PROPERTY ARRAY_VT_inner ALL_OD ALL_POLY [den_od = AREA(ALL_OD)/AREA(ARRAY_VT_inner)] [den_po = AREA(ALL_POLY)/AREA(ARRAY_VT_inner)]
    ARRAY_VT_OD_err = DFM PROPERTY ARRAY_VT_innerP ARRAY_VT_outerP OVERLAP ABUT ALSO MULTI
    [OD_DN_outer = PROPERTY(ARRAY_VT_outerP,"den_od")]
    [OD_DN_inner = PROPERTY(ARRAY_VT_innerP,"den_od")]
    [OD_DN_diff  = ABS(PROPERTY(ARRAY_VT_outerP,"den_od")-PROPERTY(ARRAY_VT_innerP,"den_od")) ] >  ARRAY_VT_R_1_0.1
    ARRAY_VT_PO_err = DFM PROPERTY ARRAY_VT_innerP ARRAY_VT_outerP OVERLAP ABUT ALSO MULTI
    [PO_DN_outer = PROPERTY(ARRAY_VT_outerP,"den_po")]
    [PO_DN_inner = PROPERTY(ARRAY_VT_innerP,"den_po")]
    [PO_DN_diff  = ABS(PROPERTY(ARRAY_VT_outerP,"den_po")-PROPERTY(ARRAY_VT_innerP,"den_po")) ] >  ARRAY_VT_R_1_0.1    
    COPY ARRAY_VT_OD_err
    COPY ARRAY_VT_PO_err
    DFM RDB ARRAY_VT_OD_err "ARRAY_VT.R.1.rep" NOEMPTY
    DFM RDB ARRAY_VT_PO_err "ARRAY_VT.R.1.rep" NOEMPTY
}

ARRAY_VT.R.2 { @ ARRAY_VT must be orthogonal to grid   

    ANGLE ARRAY_VT > 0 < 90
}
#ENDIF // ESD_LUP_RULE_CHECK_ONLY
