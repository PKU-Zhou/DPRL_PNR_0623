M5_NOTCH_candidate11_5 = M5_NOTCH_candidate11_1 INSIDE M5_NOTCH
M5_NOTCH_candidate12_1 = EXT M5_NOTCH_candidate11_5 [M5_NOTCH_candidate11_3] == Mx_S ABUT < 90 OPPOSITE
