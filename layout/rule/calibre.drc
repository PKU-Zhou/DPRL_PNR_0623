BDTCD.R.3:M1 { @ Any mirror and 180' rotation in X,Y are legal for TCDDMY_FDM1/ TCDDMY_FM1 and TCDDMY_FDMx/ TCDMY_FMx, but 90' and 270' rotations will be not allowed. DRC will check the orientation of M1/Mx length >= 1.2 um in TCDDMY_FDM1/ TCDDMY_FDMx and TCDDMY_FM1/ TCDDMY_FMx respectively   
  ANGLE LONGEDGE_SYM_M1_TCD != 90
}
BDTCD.R.3:M2 { @ Any mirror and 180' rotation in X,Y are legal for TCDDMY_FDM1/ TCDDMY_FM1 and TCDDMY_FDMx/ TCDMY_FMx, but 90' and 270' rotations will be not allowed. DRC will check the orientation of M1/Mx length >= 1.2 um in TCDDMY_FDM1/ TCDDMY_FDMx and TCDDMY_FM1/ TCDDMY_FMx respectively   
  ANGLE LONGEDGE_SYM_M2_TCD != 0
}
BDTCD.R.3:M3 { @ Any mirror and 180' rotation in X,Y are legal for TCDDMY_FDM1/ TCDDMY_FM1 and TCDDMY_FDMx/ TCDMY_FMx, but 90' and 270' rotations will be not allowed. DRC will check the orientation of M1/Mx length >= 1.2 um in TCDDMY_FDM1/ TCDDMY_FDMx and TCDDMY_FM1/ TCDDMY_FMx respectively   
  ANGLE LONGEDGE_SYM_M3_TCD != 90
}
BDTCD.R.3:M4 { @ Any mirror and 180' rotation in X,Y are legal for TCDDMY_FDM1/ TCDDMY_FM1 and TCDDMY_FDMx/ TCDMY_FMx, but 90' and 270' rotations will be not allowed. DRC will check the orientation of M1/Mx length >= 1.2 um in TCDDMY_FDM1/ TCDDMY_FDMx and TCDDMY_FM1/ TCDDMY_FMx respectively   
  ANGLE LONGEDGE_SYM_M4_TCD != 0
}
BDTCD.R.3:M5 { @ Any mirror and 180' rotation in X,Y are legal for TCDDMY_FDM1/ TCDDMY_FM1 and TCDDMY_FDMx/ TCDMY_FMx, but 90' and 270' rotations will be not allowed. DRC will check the orientation of M1/Mx length >= 1.2 um in TCDDMY_FDM1/ TCDDMY_FDMx and TCDDMY_FM1/ TCDDMY_FMx respectively   
  ANGLE LONGEDGE_SYM_M5_TCD != 90
}
BDTCD.R.3:M6 { @ Any mirror and 180' rotation in X,Y are legal for TCDDMY_FDM1/ TCDDMY_FM1 and TCDDMY_FDMx/ TCDMY_FMx, but 90' and 270' rotations will be not allowed. DRC will check the orientation of M1/Mx length >= 1.2 um in TCDDMY_FDM1/ TCDDMY_FDMx and TCDDMY_FM1/ TCDDMY_FMx respectively   
  ANGLE LONGEDGE_SYM_M6_TCD != 0
}
BDTCD.R.3:M7 { @ Any mirror and 180' rotation in X,Y are legal for TCDDMY_FDM1/ TCDDMY_FM1 and TCDDMY_FDMx/ TCDMY_FMx, but 90' and 270' rotations will be not allowed. DRC will check the orientation of M1/Mx length >= 1.2 um in TCDDMY_FDM1/ TCDDMY_FDMx and TCDDMY_FM1/ TCDDMY_FMx respectively   
  ANGLE LONGEDGE_SYM_M7_TCD != 90
}

BDTCD.R.4:M1 { @ TCDDMY_M1 and TCDMY_Mx must keep same block orientation. Any rotation, any mirror in X,Y in placement will be not allowed. DRC will check related coordinates of 0.5 um X 0.5 um M1 or 0.5 um X 0.5 um Mx alignment marks in TCDDMY_M1/Mx   
  CHECK_MET = RECTANGLE ASYM_M1_TCD == BDTCD_R_4 BY == BDTCD_R_4 ORTHOGONAL ONLY
  GOOD_MET_pre = SHRINK TCDDMY_M1 TOP BY 0.7 BOTTOM BY 1.6 LEFT BY 2.505 RIGHT BY 0.445
  GOOD_MET = INT GOOD_MET_pre <= BDTCD_R_4 ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  (TCDDMY_M1 INTERACT (CHECK_MET XOR GOOD_MET)) AND CHECK_MET
}
BDTCD.R.4:M2 { @ TCDDMY_M1 and TCDMY_Mx must keep same block orientation. Any rotation, any mirror in X,Y in placement will be not allowed. DRC will check related coordinates of 0.5 um X 0.5 um M1 or 0.5 um X 0.5 um Mx alignment marks in TCDDMY_M1/Mx   
  CHECK_MET = RECTANGLE ASYM_M2_TCD == BDTCD_R_4 BY == BDTCD_R_4 ORTHOGONAL ONLY
  GOOD_MET_pre = SHRINK TCDDMY_M2 TOP BY 0.45 BOTTOM BY 2.6 LEFT BY 0.105 RIGHT BY 2.095
  GOOD_MET = INT GOOD_MET_pre <= BDTCD_R_4 ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  (TCDDMY_M2 INTERACT (CHECK_MET XOR GOOD_MET)) AND CHECK_MET
}
BDTCD.R.4:M3 { @ TCDDMY_M1 and TCDMY_Mx must keep same block orientation. Any rotation, any mirror in X,Y in placement will be not allowed. DRC will check related coordinates of 0.5 um X 0.5 um M1 or 0.5 um X 0.5 um Mx alignment marks in TCDDMY_M1/Mx   
  CHECK_MET = RECTANGLE ASYM_M3_TCD == BDTCD_R_4 BY == BDTCD_R_4 ORTHOGONAL ONLY
  GOOD_MET_pre = SHRINK TCDDMY_M3 TOP BY 0.7 BOTTOM BY 1.6 LEFT BY 2.505 RIGHT BY 0.445
  GOOD_MET = INT GOOD_MET_pre <= BDTCD_R_4 ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  (TCDDMY_M3 INTERACT (CHECK_MET XOR GOOD_MET)) AND CHECK_MET
}
BDTCD.R.4:M4 { @ TCDDMY_M1 and TCDMY_Mx must keep same block orientation. Any rotation, any mirror in X,Y in placement will be not allowed. DRC will check related coordinates of 0.5 um X 0.5 um M1 or 0.5 um X 0.5 um Mx alignment marks in TCDDMY_M1/Mx   
  CHECK_MET = RECTANGLE ASYM_M4_TCD == BDTCD_R_4 BY == BDTCD_R_4 ORTHOGONAL ONLY
  GOOD_MET_pre = SHRINK TCDDMY_M4 TOP BY 0.45 BOTTOM BY 2.6 LEFT BY 0.105 RIGHT BY 2.095
  GOOD_MET = INT GOOD_MET_pre <= BDTCD_R_4 ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  (TCDDMY_M4 INTERACT (CHECK_MET XOR GOOD_MET)) AND CHECK_MET
}
BDTCD.R.4:M5 { @ TCDDMY_M1 and TCDMY_Mx must keep same block orientation. Any rotation, any mirror in X,Y in placement will be not allowed. DRC will check related coordinates of 0.5 um X 0.5 um M1 or 0.5 um X 0.5 um Mx alignment marks in TCDDMY_M1/Mx   
  CHECK_MET = RECTANGLE ASYM_M5_TCD == BDTCD_R_4 BY == BDTCD_R_4 ORTHOGONAL ONLY
  GOOD_MET_pre = SHRINK TCDDMY_M5 TOP BY 0.7 BOTTOM BY 1.6 LEFT BY 2.505 RIGHT BY 0.445
  GOOD_MET = INT GOOD_MET_pre <= BDTCD_R_4 ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  (TCDDMY_M5 INTERACT (CHECK_MET XOR GOOD_MET)) AND CHECK_MET
}
BDTCD.R.4:M6 { @ TCDDMY_M1 and TCDMY_Mx must keep same block orientation. Any rotation, any mirror in X,Y in placement will be not allowed. DRC will check related coordinates of 0.5 um X 0.5 um M1 or 0.5 um X 0.5 um Mx alignment marks in TCDDMY_M1/Mx   
  CHECK_MET = RECTANGLE ASYM_M6_TCD == BDTCD_R_4 BY == BDTCD_R_4 ORTHOGONAL ONLY
  GOOD_MET_pre = SHRINK TCDDMY_M6 TOP BY 0.45 BOTTOM BY 2.6 LEFT BY 0.105 RIGHT BY 2.095
  GOOD_MET = INT GOOD_MET_pre <= BDTCD_R_4 ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  (TCDDMY_M6 INTERACT (CHECK_MET XOR GOOD_MET)) AND CHECK_MET
}
BDTCD.R.4:M7 { @ TCDDMY_M1 and TCDMY_Mx must keep same block orientation. Any rotation, any mirror in X,Y in placement will be not allowed. DRC will check related coordinates of 0.5 um X 0.5 um M1 or 0.5 um X 0.5 um Mx alignment marks in TCDDMY_M1/Mx   
  CHECK_MET = RECTANGLE ASYM_M7_TCD == BDTCD_R_4 BY == BDTCD_R_4 ORTHOGONAL ONLY
  GOOD_MET_pre = SHRINK TCDDMY_M7 TOP BY 0.7 BOTTOM BY 1.6 LEFT BY 2.505 RIGHT BY 0.445
  GOOD_MET = INT GOOD_MET_pre <= BDTCD_R_4 ABUT == 90 INTERSECTING ONLY REGION EXTENTS
  (TCDDMY_M7 INTERACT (CHECK_MET XOR GOOD_MET)) AND CHECK_MET
}

// BDTCD.R.5 is checked by related rules
// BDTCD.R.6 is checked by related rules

BDTCD.R.7 { @ {M1 CUT TCDDMY_FDM1} is not allowed   
  M1 CUT TCDDMY_FDM1 
}

BDTCD.R.8:M2 { @ {Mx CUT TCDDMY_FDMx} is not allowed   
  M2 CUT TCDDMY_FDM2 
}
BDTCD.R.8:M3 { @ {Mx CUT TCDDMY_FDMx} is not allowed   
  M3 CUT TCDDMY_FDM3 
}
BDTCD.R.8:M4 { @ {Mx CUT TCDDMY_FDMx} is not allowed   
  M4 CUT TCDDMY_FDM4 
}
BDTCD.R.8:M5 { @ {Mx CUT TCDDMY_FDMx} is not allowed   
  M5 CUT TCDDMY_FDM5 
}
BDTCD.R.8:M6 { @ {Mx CUT TCDDMY_FDMx} is not allowed   
  M6 CUT TCDDMY_FDM6 
}
BDTCD.R.8:M7 { @ {Mx CUT TCDDMY_FDMx} is not allowed   
  M7 CUT TCDDMY_FDM7 
}





// ICOVL CHECKS
//=============

ICOVL_BC = SIZE (OR ICOVL_B ICOVL_C) BY 500 OVERUNDER
ICOVL_BE = SIZE (OR ICOVL_B ICOVL_E) BY 500 OVERUNDER
ICOVL_DC = SIZE (OR ICOVL_D ICOVL_C) BY 500 OVERUNDER
ICOVL_DE = SIZE (OR ICOVL_D ICOVL_E) BY 500 OVERUNDER

ICOVL_set = OR ICOVL_A ICOVL_BC ICOVL_BE ICOVL_DC ICOVL_DE


// ICOVL.0 is checked by related rules

ICOVL.W.1 { @ Width of ICOVL_A in horizontal/vertical direction = 140.4/117 
  NOT RECTANGLE ICOVL_A == ICOVL_W_1_H BY == ICOVL_W_1_V ORTHOGONAL ONLY
  LENGTH (ANGLE ICOVL_A == 0) != ICOVL_W_1_H
  LENGTH (ANGLE ICOVL_A == 90) != ICOVL_W_1_V
}

ICOVL.W.1.1 { @ Width of ICOVL_B in horizontal/vertical direction = 70.2/117 
  NOT RECTANGLE ICOVL_B == ICOVL_W_1_1_H BY == ICOVL_W_1_1_V ORTHOGONAL ONLY
  LENGTH (ANGLE ICOVL_B == 0)  != ICOVL_W_1_1_H
  LENGTH (ANGLE ICOVL_B == 90) != ICOVL_W_1_1_V
}

ICOVL.W.1.2 { @ Width of ICOVL_C in horizontal/vertical direction = 70.2/117 
  NOT RECTANGLE ICOVL_C == ICOVL_W_1_2_H BY == ICOVL_W_1_2_V ORTHOGONAL ONLY
  LENGTH (ANGLE ICOVL_C == 0)  != ICOVL_W_1_2_H
  LENGTH (ANGLE ICOVL_C == 90) != ICOVL_W_1_2_V
}

ICOVL.W.1.3 { @ Width of ICOVL_D in horizontal/vertical direction = 117/70.2 
  NOT RECTANGLE ICOVL_D == ICOVL_W_1_3_H BY == ICOVL_W_1_3_V ORTHOGONAL ONLY
  LENGTH (ANGLE ICOVL_D == 0)  != ICOVL_W_1_3_H
  LENGTH (ANGLE ICOVL_D == 90) != ICOVL_W_1_3_V
}

ICOVL.W.1.4 { @ Width of ICOVL_E in horizontal/vertical direction = 117/70.2 
  NOT RECTANGLE ICOVL_E == ICOVL_W_1_4_H BY == ICOVL_W_1_4_V ORTHOGONAL ONLY
  LENGTH (ANGLE ICOVL_E == 0)  != ICOVL_W_1_4_H
  LENGTH (ANGLE ICOVL_E == 90) != ICOVL_W_1_4_V
}


// ICOVL.W.2 is not necessary to check



ICOVL.S.1 { @ Space of ICOVL_A, ICOVL_B, ICOVL_C, ICOVL_D, ICOVL_E. (Overlap is not allowed) (Except following conditions: 1. {ICOVL_C OR ICOVL_E} space to ICOVL_B <= 500 um, 2. {ICOVL_C OR ICOVL_E} space to ICOVL_D <= 500 um) >= 1500 
  EXT ICOVL_A < ICOVL_S_1 ABUT < 90 SINGULAR REGION
  EXT ICOVL_A ICOVL_B < ICOVL_S_1 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL_A ICOVL_C < ICOVL_S_1 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL_A ICOVL_D < ICOVL_S_1 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL_A ICOVL_E < ICOVL_S_1 ABUT < 90 SINGULAR REGION INSIDE ALSO

  EXT ICOVL_B < ICOVL_S_1 ABUT < 90 SINGULAR REGION
  EXT ICOVL_B ICOVL_D < ICOVL_S_1 ABUT < 90 SINGULAR REGION INSIDE ALSO

  EXT ICOVL_C < ICOVL_S_1 ABUT < 90 SINGULAR REGION
  EXT ICOVL_C ICOVL_E < ICOVL_S_1 ABUT < 90 SINGULAR REGION INSIDE ALSO
  
  EXT ICOVL_D < ICOVL_S_1 ABUT < 90 SINGULAR REGION
  
  EXT ICOVL_E < ICOVL_S_1 ABUT < 90 SINGULAR REGION
  
}


ICOVL.S.2 { @ Space of ICOVL_B to ICOVL_C, ICOVL_E. (Overlap is not allowed) = 0, 1~500, >= 1500 
  EXT ICOVL_B ICOVL_C > ICOVL_S_2_B < ICOVL_S_2_C ABUT > 0 < 90 REGION
  ICOVL_B AND ICOVL_C
  EXT ICOVL_B ICOVL_E > ICOVL_S_2_B < ICOVL_S_2_C ABUT > 0 < 90 REGION
  ICOVL_B AND ICOVL_E
  EXT ICOVL_B ICOVL_C < ICOVL_S_2_A ABUT > 0 < 90 REGION
  EXT ICOVL_B ICOVL_E < ICOVL_S_2_A ABUT > 0 < 90 REGION
}

ICOVL.S.3 { @ Space of ICOVL_D to ICOVL_C, ICOVL_E. (Overlap is not allowed) = 0, 1~500, >= 1500 
  EXT ICOVL_D ICOVL_C > ICOVL_S_3_B < ICOVL_S_3_C ABUT > 0 < 90 REGION
  ICOVL_D AND ICOVL_C
  EXT ICOVL_D ICOVL_E > ICOVL_S_3_B < ICOVL_S_3_C ABUT > 0 < 90 REGION
  ICOVL_D AND ICOVL_E
  EXT ICOVL_D ICOVL_C < ICOVL_S_3_A ABUT > 0 < 90 REGION
  EXT ICOVL_D ICOVL_E < ICOVL_S_3_A ABUT > 0 < 90 REGION
}

ICOVL.S.4 { @ Space of ICOVL to DOD, SR_DOD, SR_DPO, DPO, NP [NOT INTERACT PO], PP [NOT INTERACT PO], DM1, DM1_O, DM x, DMx_O (Overlap is not allowed) >= 0.2 
  EXT ICOVL DOD   < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL SRDOD < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL SRDPO < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DPO   < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  NP_CHK = NP NOT INTERACT POLY
  PP_CHK = PP NOT INTERACT POLY
  EXT ICOVL NP_CHK < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL PP_CHK < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO

  EXT ICOVL DM1_O < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DUM1 < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO

  EXT ICOVL DM2_O < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DUM2 < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DM3_O < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DUM3 < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DM4_O < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DUM4 < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DM5_O < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DUM5 < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DM6_O < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DUM6 < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DM7_O < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT ICOVL DUM7 < ICOVL_S_4 ABUT < 90 SINGULAR REGION INSIDE ALSO

}
ICOVL.S.5:NWi { @ Space of ICOVL to NW, DNW, OD, OD2, PO, CPO, NT_N, VTL_N, VTL_P, VTH_N, VTH_P, VTUL_N, VTUL_P, UHVT_N, UHVT_P, EHVT_N, EHVT_P, NP [INTERACT PO], PP [INTERACT PO], PMET, RPO, RH_PO, RH_OD, DIODMY, RFDMY, SRM, SRAMDMY, BJTDMY (Overlap is not allowed) >= 15 
  EXT ICOVL NWi < ICOVL_S_5 ABUT < 90 SINGULAR REGION INSIDE ALSO
}
