VIA3 = COPY VIA3i
#ELSE
VIA3i = COPY VIA3ii
VIA3 = COPY VIA3i

#ENDIF


M4   = M4i OR DM4_O

#IFDEF CHECK_VIRTUAL_VIAx
VIA4i = VIA4ii OR VIA4_VIRT
VIA4 = COPY VIA4i
#ELSE
VIA4i = COPY VIA4ii
VIA4 = COPY VIA4i

#ENDIF


M5   = M5i OR DM5_O

#IFDEF CHECK_VIRTUAL_VIAx
VIA5i = VIA5ii OR VIA5_VIRT
VIA5 = COPY VIA5i
#ELSE
VIA5i = COPY VIA5ii
VIA5 = COPY VIA5i

#ENDIF


M6   = M6i OR DM6_O

#IFDEF CHECK_VIRTUAL_VIAx
VIA6i = VIA6ii OR VIA6_VIRT
VIA6 = COPY VIA6i
#ELSE
VIA6i = COPY VIA6ii
VIA6 = COPY VIA6i

#ENDIF


M7   = M7i OR DM7_O

VIA7 = COPY VIA7i


M8   = COPY M8i 

VIA8 = COPY VIA8i


M9   = COPY M9i 


TFR	= COPY TFRi

RV      = COPY RVi
AP      = COPY APi
CB      = COPY CBi  
PM      = COPY PMi  
VAR	= COPY VARi
mVTL    = COPY mVTLi

ALL_PAD = (CBi OR CBDi) OR RVi
UBM_MT = UBMi INTERACT CBDi
#IFDEF WLCSP
UBM_EXC = SIZE CBDi BY 5 INSIDE OF M9i STEP M9_S_1*0.7
#ELSE
UBM_EXC = SIZE UBM_MT BY 5 INSIDE OF M9i STEP M9_S_1*0.7
#ENDIF
CBMT = SIZE CBi BY 5 INSIDE OF M9i STEP M9_S_1*0.7
CBMT2 = SIZE CBi BY 5 INSIDE OF M8i STEP M8_S_1*0.7

MTOP_EXC = CBMT OR UBM_EXC	// For hidensity limit and max. width rule


INDDMY_ALL = INDDMY OR INDDMY_MD


IND_REGION = SIZE INDDMY_ALL BY 16
IND_EXD = SIZE INDDMY_ALL BY 22
SEALRING_EXCLUDE = COPY SEALRING_ALL

ALL_OD = (ODi OR SRDOD) OR DOD
ALL_POLY = ((POi OR SRDPO) OR DPO) NOT CPO

// metal in silicon
M1x = M1 OR DUM1 
M2x = M2 OR DUM2 
M3x = M3 OR DUM3 
M4x = M4 OR DUM4 
M5x = M5 OR DUM5 
M6x = M6 OR DUM6 
M7x = M7 OR DUM7 
M8x = M8 OR DUM8 
M9x = M9 OR DUM9 

OD2 = ((OD15 OR OD18) OR OD25) OR OD33
OD2i = ((OD15i OR OD18i) OR OD25i) OR OD33i
CTM_F = CTM NOT CTM_O  // N22 doesn't offer CTM_O layer
CBM_F = CBM NOT CBM_O  // N22 doesn't offer CBM_O layer
eHVTN = COPY EHVT_N
eHVTP = COPY EHVT_P
HVD = HVD_N OR HVD_P
HVD_65 = ((HVN_65 OR HVP_65) OR HVN25_65) OR HVP25_65
IMP          = NP OR PP
NPOD         = OD AND NP
PPOD         = OD AND PP
COOD         = CO AND OD        // Diffusion contacts 
SR_COPO      = CO INTERACT SRDPO     // SR_DPO contacts
COPO         = (CO NOT OD) NOT INTERACT SRDPO // POLY contacts + floating contacts


LOGIC_PO = (((POi OR DPO) OR SRDPO) NOT (SRAMDMY OR SRM_3)) INTERACT ODi
SRAM_PO = (((POi OR DPO) OR SRDPO) AND SRAMDMY) NOT SRM_3

RNWEL = NWEL INTERACT NWDMY	// NWEL resistor (Within OD & STI)
NWRES = RNWEL INTERACT RPO	// NWEL resistor (Within OD)
NONWR = NWEL NOT RNWEL		// NWEL exclude resistor area (Within OD)
ODWR  = OD INTERACT NWRES	// OD area of NW resistor (Within OD)
NPWR  = NP INTERACT NWRES	// N+ implant on NW resistor terminals (Within OD)
COWR  = COOD INTERACT NWRES	// Contact on NW resistor terminals (Within OD)
RHWR  = ODWR NOT RPO		// Silicided terminal of NW resistor (Within OD)
NWRES_STI = RNWEL NOT INTERACT RPO	// NWEL resistor (Under STI)
ODWR_STI = OD INTERACT NWRES_STI	// OD area of NW resistor (Under STI)
NPWR_STI = NP INTERACT NWRES_STI
COWR_STI = COOD INTERACT NWRES_STI	// Contact on NW resistor terminals (Under STI)


NSTP         = NPOD AND NONWR          // NWEL tap diffusion
NACT         = NPOD NOT NWEL           // NMOS device active diffusion
PACT         = PPOD AND NWEL           // PMOS device active diffusion
NACT2        = NACT INTERACT OD2
PACT2        = PACT INTERACT OD2
PSTP         = PPOD NOT NWEL           // Substrate (pwell) tap diffusion
DACT         = NACT OR PACT            // NMOS/PMOS device active diffusion
DSTP         = NSTP OR PSTP

GATE         = POLY AND OD	       // Gate regions for NMOS and PMOS
GATEi        = POi AND ODi	       // Gate regions for NMOS and PMOS
SD           = (DACT ENCLOSE GATE) NOT GATE  // Source, drain areas
FPO1         = POLY NOT OD             // Field poly
HV_GATE      = GATE AND OD2
LV_GATE      = GATE NOT OD2
GATE_NP      = GATE AND NP
GATE_PP      = GATE AND PP
GATE_W       = POLY COIN INSIDE EDGE GATE      // Gate width
GATE_L       = GATE NOT TOUCH EDGE GATE_W
GATEN_W      = GATE_W INSIDE EDGE NP
GATEP_W      = GATE_W INSIDE EDGE PP
HV_GATE_W    = GATE_W INSIDE EDGE OD2         // 2.5V/3.3V/1.8V MOS gates
LV_GATE_W    = GATE_W NOT INSIDE EDGE OD2     // 1.0V MOS gates
HV_GATE_L    = GATE_L INSIDE EDGE OD2         // 2.5V/1.8V MOS gates
LV_GATE_L    = GATE_L NOT INSIDE EDGE OD2
15V_GATE_W   = HV_GATE_W INSIDE EDGE OD15
18V_GATE_W   = HV_GATE_W INSIDE EDGE OD18
25V_GATE_W   = HV_GATE_W INSIDE EDGE OD25
33V_GATE_W   = HV_GATE_W INSIDE EDGE OD33


SR_GATE      = SRDPO AND OD
SR_GATE_W    = SRDPO COIN INSIDE EDGE SR_GATE
SR_GATE_L    = SR_GATE NOT TOUCH EDGE SR_GATE_W
SR_HV_GATE   = SR_GATE AND OD2
LV_SR_GATE = SR_GATE NOT OD2
WLD_LV_GATE = LV_GATE NOT OUTSIDE SRAMDMY_WLD

SR_POLY      = SRDPO OR POLY
SRPO_GATE    = SR_POLY AND OD
SRPO_GATE_W  = SR_POLY COIN INSIDE EDGE SRPO_GATE
SRPO_GATE_L  = SRPO_GATE NOT TOUCH EDGE SRPO_GATE_W

GATE_HL      = ANGLE GATE_L == 0
GATE_VL      = ANGLE GATE_L == 90

GATE_L_V = ANGLE GATE_L == 90
GATE_L_H = ANGLE GATE_L == 0
OD_WI_V_POLY = OD WITH EDGE GATE_L_H
OD_WI_H_POLY = OD WITH EDGE GATE_L_V
OD_H_CHK = ANGLE OD_WI_H_POLY == 0
OD_V_CHK = ANGLE OD_WI_V_POLY == 90

OD_SRDOD = OD OR SRDOD


PO55V = (POLY INTERACT (RHPO INTERACT RPO)) INTERACT PO55

PO65V = (POLY INTERACT (RHPO INTERACT RPO)) INTERACT PO65

// For poly and od resistors identify
ODRES_US     = ((OD AND RHOD) AND RPDMY) AND RPO            // unsilicided OD resistor
ODRES_SI     = ((OD AND RHOD) AND RPDMY) NOT INTERACT RPO   // silicided OD resistor
ODRES        = ODRES_US OR ODRES_SI                         // all OD resistor
PORES_US     = ((POLY AND RHPO) AND RPDMY) AND RPO          // unsilicided POLY resistor
PORES_SI     = ((POLY AND RHPO) AND RPDMY) NOT INTERACT RPO // silicided POLY resistor
PORES        = PORES_US OR PORES_SI                         // all POLY resistor

RES_Metal_GATE   = COPY PORES_SI  // Metal GATE resistor
RES_Metal_GATE_N = RES_Metal_GATE AND NP   // N+ Metal GATE resistor
RES_Metal_GATE_P = RES_Metal_GATE AND PP   // P+ Metal GATE resistor
RES_High_R       = PORES_US AND PP   // High R resistor
DUMMY_RES_High_R = ((RPO AND SRDPO) AND RHPO) AND PP   // dummy High R resistor for AN.R.77.2mg/AN.R.77.3mg

AYRE         = ODRES_US OR PORES_US	// unsilicided OD/POLY resistor
RPO_RPDMY    = RPOi OR RPDMY		// resistor marker layers
ILP1         = POLY NOT RPO_RPDMY       // Interconnect poly
INOD         = OD NOT RPO_RPDMY

NP_PP_BTE    = NPOD COIN OUTSIDE EDGE PPOD
BUTT_PSTP    = PSTP TOUCH NACT
BUTT_NSTP    = NSTP TOUCH PACT

// For BJT Device
PP_EMOD = PACT AND BJTDMY
NP_EMOD = NACT AND BJTDMY
EMOD = PP_EMOD OR NP_EMOD
PP_BASE_OD = (PSTP AND BJTDMY) INTERACT ((HOLES (PSTP AND BJTDMY)) INTERACT NP_EMOD)
NP_BASE_OD = (NSTP AND BJTDMY) INTERACT ((HOLES(NSTP AND BJTDMY)) INTERACT PP_EMOD)
BASE_OD = PP_BASE_OD OR NP_BASE_OD

PP_COLLECT_OD = (PSTP AND BJTDMY) INTERACT ((HOLES (PSTP AND BJTDMY)) INTERACT PP_EMOD)
NP_COLLECT_OD = (NSTP AND BJTDMY) INTERACT ((HOLES(NSTP AND BJTDMY)) INTERACT NP_EMOD)
COLLECT_OD = PP_COLLECT_OD OR NP_COLLECT_OD

SEALRING = COPY SEALRING_ALL
GB_ALL = COPY GB_D2

SQR_VIA1i = RECTANGLE VIA1ii == VIA1_W_1 BY == VIA1_L_1 ORTHOGONAL ONLY
SQR_VIA1 = RECTANGLE VIA1i == VIA1_W_1 BY == VIA1_L_1 ORTHOGONAL ONLY
REC_VIA1i = RECTANGLE VIA1ii == VIA1_W_1 BY == VIA1_L_2 ORTHOGONAL ONLY
REC_VIA1 = RECTANGLE VIA1i == VIA1_W_1 BY == VIA1_L_2 ORTHOGONAL ONLY
VIA1_HOLE = SQR_VIA1 OR REC_VIA1
VIA1_BAR = VIA1i NOT VIA1_HOLE

SQR_VIA2i = RECTANGLE VIA2ii == VIA2_W_1 BY == VIA2_L_1 ORTHOGONAL ONLY
SQR_VIA2 = RECTANGLE VIA2i == VIA2_W_1 BY == VIA2_L_1 ORTHOGONAL ONLY
REC_VIA2i = RECTANGLE VIA2ii == VIA2_W_1 BY == VIA2_L_2 ORTHOGONAL ONLY
REC_VIA2 = RECTANGLE VIA2i == VIA2_W_1 BY == VIA2_L_2 ORTHOGONAL ONLY
VIA2_HOLE = SQR_VIA2 OR REC_VIA2
VIA2_BAR = VIA2i NOT VIA2_HOLE

SQR_VIA3i = RECTANGLE VIA3ii == VIA3_W_1 BY == VIA3_L_1 ORTHOGONAL ONLY
SQR_VIA3 = RECTANGLE VIA3i == VIA3_W_1 BY == VIA3_L_1 ORTHOGONAL ONLY
REC_VIA3i = RECTANGLE VIA3ii == VIA3_W_1 BY == VIA3_L_2 ORTHOGONAL ONLY
REC_VIA3 = RECTANGLE VIA3i == VIA3_W_1 BY == VIA3_L_2 ORTHOGONAL ONLY
VIA3_HOLE = SQR_VIA3 OR REC_VIA3
VIA3_BAR = VIA3i NOT VIA3_HOLE

SQR_VIA4i = RECTANGLE VIA4ii == VIA4_W_1 BY == VIA4_L_1 ORTHOGONAL ONLY
SQR_VIA4 = RECTANGLE VIA4i == VIA4_W_1 BY == VIA4_L_1 ORTHOGONAL ONLY
REC_VIA4i = RECTANGLE VIA4ii == VIA4_W_1 BY == VIA4_L_2 ORTHOGONAL ONLY
REC_VIA4 = RECTANGLE VIA4i == VIA4_W_1 BY == VIA4_L_2 ORTHOGONAL ONLY
VIA4_HOLE = SQR_VIA4 OR REC_VIA4
VIA4_BAR = VIA4i NOT VIA4_HOLE

SQR_VIA5i = RECTANGLE VIA5ii == VIA5_W_1 BY == VIA5_L_1 ORTHOGONAL ONLY
SQR_VIA5 = RECTANGLE VIA5i == VIA5_W_1 BY == VIA5_L_1 ORTHOGONAL ONLY
REC_VIA5i = RECTANGLE VIA5ii == VIA5_W_1 BY == VIA5_L_2 ORTHOGONAL ONLY
REC_VIA5 = RECTANGLE VIA5i == VIA5_W_1 BY == VIA5_L_2 ORTHOGONAL ONLY
VIA5_HOLE = SQR_VIA5 OR REC_VIA5
VIA5_BAR = VIA5i NOT VIA5_HOLE

SQR_VIA6i = RECTANGLE VIA6ii == VIA6_W_1 BY == VIA6_L_1 ORTHOGONAL ONLY
SQR_VIA6 = RECTANGLE VIA6i == VIA6_W_1 BY == VIA6_L_1 ORTHOGONAL ONLY
REC_VIA6i = RECTANGLE VIA6ii == VIA6_W_1 BY == VIA6_L_2 ORTHOGONAL ONLY
REC_VIA6 = RECTANGLE VIA6i == VIA6_W_1 BY == VIA6_L_2 ORTHOGONAL ONLY
VIA6_HOLE = SQR_VIA6 OR REC_VIA6
VIA6_BAR = VIA6i NOT VIA6_HOLE

LOWMEDN_CORE1 = SIZE LOWMEDN BY -1
LOWMEDN_CORE2 = SIZE LOWMEDN BY -4
LOWMEDN_CORE3 = SIZE LOWMEDN BY -5
P_RING_REGION1 = LOWMEDN NOT LOWMEDN_CORE1
P_RING_REGION = LOWMEDN NOT LOWMEDN_CORE2
P_RING_REGION2 = LOWMEDN NOT LOWMEDN_CORE3
LOWMEDN_IND = LOWMEDN INTERACT INDDMY
P_RING_VIA1 = P_RING_REGION AND VIA1_BAR
P_RING_VIA1_IND = P_RING_VIA1 INTERACT LOWMEDN_IND
P_RING_VIA1_noIND = P_RING_VIA1 NOT INTERACT LOWMEDN_IND
P_RING_VIA2 = P_RING_REGION AND VIA2_BAR
P_RING_VIA2_IND = P_RING_VIA2 INTERACT LOWMEDN_IND
P_RING_VIA2_noIND = P_RING_VIA2 NOT INTERACT LOWMEDN_IND
P_RING_VIA3 = P_RING_REGION AND VIA3_BAR
P_RING_VIA3_IND = P_RING_VIA3 INTERACT LOWMEDN_IND
P_RING_VIA3_noIND = P_RING_VIA3 NOT INTERACT LOWMEDN_IND
P_RING_VIA4 = P_RING_REGION AND VIA4_BAR
P_RING_VIA4_IND = P_RING_VIA4 INTERACT LOWMEDN_IND
P_RING_VIA4_noIND = P_RING_VIA4 NOT INTERACT LOWMEDN_IND
P_RING_VIA5 = P_RING_REGION AND VIA5_BAR
P_RING_VIA5_IND = P_RING_VIA5 INTERACT LOWMEDN_IND
P_RING_VIA5_noIND = P_RING_VIA5 NOT INTERACT LOWMEDN_IND
P_RING_VIA6 = P_RING_REGION AND VIA6_BAR
P_RING_VIA6_IND = P_RING_VIA6 INTERACT LOWMEDN_IND
P_RING_VIA6_noIND = P_RING_VIA6 NOT INTERACT LOWMEDN_IND

VIA_EXD  = COPY SEALRING_ALL
VIA1_EXD = (VIA1i NOT SEALRING_ALL) NOT P_RING_VIA1

VIA2_EXD = (VIA2i NOT SEALRING_ALL) NOT P_RING_VIA2

VIA3_EXD = (VIA3i NOT SEALRING_ALL) NOT P_RING_VIA3

VIA4_EXD = (VIA4i NOT SEALRING_ALL) NOT P_RING_VIA4

VIA5_EXD = (VIA5i NOT SEALRING_ALL) NOT P_RING_VIA5

VIA6_EXD = (VIA6i NOT SEALRING_ALL) NOT P_RING_VIA6

VIA7_EXD = VIA7i NOT SEALRING_ALL

VIA8_EXD = VIA8i NOT SEALRING_ALL



TCDDMY_BM1 = (TCDDMY_M1 OR TCDDMY_FM1) OR TCDDMY_FDM1 
TCDDMY_BM2 = (TCDDMY_M2 OR TCDDMY_FM2) OR TCDDMY_FDM2 
TCDDMY_BM3 = (TCDDMY_M3 OR TCDDMY_FM3) OR TCDDMY_FDM3 
TCDDMY_BM4 = (TCDDMY_M4 OR TCDDMY_FM4) OR TCDDMY_FDM4 
TCDDMY_BM5 = (TCDDMY_M5 OR TCDDMY_FM5) OR TCDDMY_FDM5 
TCDDMY_BM6 = (TCDDMY_M6 OR TCDDMY_FM6) OR TCDDMY_FDM6 
TCDDMY_BM7 = (TCDDMY_M7 OR TCDDMY_FM7) OR TCDDMY_FDM7 


//  For chip corner stress relief check
//---------------

#IFDEF FULL_CHIP
CHIP_CORE_P4    = SIZE CHIP BY -24
#ELSE
CHIP_CORE_P4    = COPY CHIP
#ENDIF

PADH_P4 = HOLES (ALL_PAD NOT CHIP_CORE_P4) INNER
SCORE_P4 = CHIP_CORE_P4 INSIDE PADH_P4
CHIP_WISR_P4 = CHIP INTERACT SCORE_P4              // CHIP, (with sealring exist)
CHIP_NOSR_P4 = CHIP NOT INTERACT SCORE_P4          // CHIP, (without sealring exist)

SR_EDGE_P4 = CHIP_WISR_P4 NOT SCORE_P4
SR_EXC_P4   = EXT SR_EDGE_P4 < 73.715 ABUT == 90 REGION INTERSECTING ONLY
SRCSR_P4 = SR_EDGE_P4 OR SR_EXC_P4                // Sealring + CSR Corner + Assembly isolation == SEALRING_ALL

#IFDEF FULL_CHIP
EMPTY_AREA_P4 = INT CHIP_NOSR_P4 < CSR_R_1 ABUT == 90 REGION INTERSECTING ONLY   // CSR reserved region
#ELSE
EMPTY_AREA_P4 = COPY EMPTYi
#ENDIF

CHIP_CHAMFERED_P4 = (CHIP NOT EMPTY_AREA_P4) NOT SEALRING_ALL
CHIP_EDGE = CHIP_NOSR_P4 OR (CHIP_WISR_P4 AND CHIP_CORE_P4)

// SEALRING Layers
//---------------

M1_P4_EXD_pre = M1i NOT (CSRDMY OR SEALRING_ORI)
ASSH_P4 = SIZE (HOLES ((M1i NOT M1_P4_EXD_pre) INTERACT SEALRING_ORI) INNER) BY 2.25 OVERUNDER

ASS_P4  = ASSH_P4 NOT INSIDE CSRDMY     // CHIP NOT SealRing region
CORR_P4 = SIZE ASS_P4 BY -SR_S_1        // CHIP NOT (SealRing & Assembly isolation) region 
ISOR_P4 = ASS_P4 NOT CORR_P4            // Assembly isolation region = seal-ring enhance zone

SEALRING_ORI_INNER = SEALRING_ORI INSIDE (HOLES SEALRING_ORI)
SEALRING_ORI_OUTER = SEALRING_ORI NOT SEALRING_ORI_INNER

SR_CO_P4 = CO INTERACT (SEALRING_ORI OR SEALRING_DB)

SEALRING_SIZE_1 = SIZE ((CSRDMY OR EMPTY_AREA_P4) OR SEALRING_ALL) BY 1


//Metal Maximum Width Waive
M1_MAX_WIDTH_EXC_a = ((SEALRING_ORI OR CSRDMY) OR IND_REGION) OR PADDMY
M1_MAX_WIDTH_EXC_b = COPY EMPTYi
M1_MAX_WIDTH = M1 NOT (M1_MAX_WIDTH_EXC_a OR M1_MAX_WIDTH_EXC_b)

M2_MAX_WIDTH_EXC_a = ((SEALRING_ORI OR CSRDMY) OR IND_REGION) OR PADDMY
M2_MAX_WIDTH_EXC_b = COPY EMPTYi
M2_MAX_WIDTH = M2 NOT (M2_MAX_WIDTH_EXC_a OR M2_MAX_WIDTH_EXC_b)

M3_MAX_WIDTH_EXC_a = ((SEALRING_ORI OR CSRDMY) OR IND_REGION) OR PADDMY
M3_MAX_WIDTH_EXC_b = COPY EMPTYi
M3_MAX_WIDTH = M3 NOT (M3_MAX_WIDTH_EXC_a OR M3_MAX_WIDTH_EXC_b)

M4_MAX_WIDTH_EXC_a = ((SEALRING_ORI OR CSRDMY) OR IND_REGION) OR PADDMY
M4_MAX_WIDTH_EXC_b = COPY EMPTYi
M4_MAX_WIDTH = M4 NOT (M4_MAX_WIDTH_EXC_a OR M4_MAX_WIDTH_EXC_b)

M5_MAX_WIDTH_EXC_a = ((SEALRING_ORI OR CSRDMY) OR IND_REGION) OR PADDMY
M5_MAX_WIDTH_EXC_b = COPY EMPTYi
M5_MAX_WIDTH = M5 NOT (M5_MAX_WIDTH_EXC_a OR M5_MAX_WIDTH_EXC_b)

M6_MAX_WIDTH_EXC_a = ((SEALRING_ORI OR CSRDMY) OR IND_REGION) OR PADDMY
M6_MAX_WIDTH_EXC_b = COPY EMPTYi
M6_MAX_WIDTH = M6 NOT (M6_MAX_WIDTH_EXC_a OR M6_MAX_WIDTH_EXC_b)

M7_MAX_WIDTH_EXC_a = ((SEALRING_ORI OR CSRDMY) OR IND_REGION) OR PADDMY
M7_MAX_WIDTH_EXC_b = COPY EMPTYi
M7_MAX_WIDTH = M7 NOT (M7_MAX_WIDTH_EXC_a OR M7_MAX_WIDTH_EXC_b)

M8_MAX_WIDTH_EXC_a = IND_EXD OR PADDMY
M8_MAX_WIDTH_EXC_b = WBDMY OR CBMT2
M8_MAX_WIDTH = M8 NOT (M8_MAX_WIDTH_EXC_a OR M8_MAX_WIDTH_EXC_b)

M9_MAX_WIDTH_EXC_a = IND_EXD OR PADDMY
M9_MAX_WIDTH_EXC_b = (MTOP_EXC OR LMARK) OR WBDMY 
M9_MAX_WIDTH = M9 NOT (M9_MAX_WIDTH_EXC_a OR M9_MAX_WIDTH_EXC_b)



//Metal Density Waive
#IFDEF FULL_CHIP
METAL_DEN_EXC_LOW = ((LOGO OR INDDMY) OR EMPTY_AREA_P4) OR SEALRING_ALL
METAL_DEN_EXC_HIGH = INDDMY_ALL OR SEALRING_ALL
#ELSE
METAL_DEN_EXC_LOW = (LOGO OR INDDMY) OR SEALRING_ALL                
METAL_DEN_EXC_HIGH = INDDMY_ALL OR SEALRING_ALL
#ENDIF

M1_EXC_LOW  = COPY METAL_DEN_EXC_LOW
M1_EXC_HIGH = COPY METAL_DEN_EXC_HIGH

M2_EXC_LOW  = COPY METAL_DEN_EXC_LOW
M2_EXC_HIGH = COPY METAL_DEN_EXC_HIGH

M3_EXC_LOW  = COPY METAL_DEN_EXC_LOW
M3_EXC_HIGH = COPY METAL_DEN_EXC_HIGH

M4_EXC_LOW  = COPY METAL_DEN_EXC_LOW
M4_EXC_HIGH = COPY METAL_DEN_EXC_HIGH

M5_EXC_LOW  = COPY METAL_DEN_EXC_LOW
M5_EXC_HIGH = COPY METAL_DEN_EXC_HIGH

M6_EXC_LOW  = COPY METAL_DEN_EXC_LOW
M6_EXC_HIGH = COPY METAL_DEN_EXC_HIGH

M7_EXC_LOW  = COPY METAL_DEN_EXC_LOW
M7_EXC_HIGH = COPY METAL_DEN_EXC_HIGH

M8_EXC_LOW  = METAL_DEN_EXC_LOW OR INDDMY_MD
M8_EXC_HIGH = METAL_DEN_EXC_HIGH OR (WBDMY OR CBMT2) 

M9_EXC_LOW  = METAL_DEN_EXC_LOW OR INDDMY_MD
M9_EXC_HIGH = METAL_DEN_EXC_HIGH OR MTOP_EXC




NEW_DEN_EXC = EMPTY_AREA_P4 OR LOWMEDN

#IFDEF FULL_CHIP
CHIP_M1 = COPY CHIP
CHIP_M2 = COPY CHIP
CHIP_M3 = COPY CHIP
CHIP_M4 = COPY CHIP
CHIP_M5 = COPY CHIP
CHIP_M6 = COPY CHIP
CHIP_M7 = COPY CHIP
CHIP_M8 = COPY CHIP
CHIP_M9 = COPY CHIP
#ELSE
#IFDEF UseRoutingBlockage
CHIP_M1 = (CHIP INTERACT (EXTENT M1x)) AND M1RBLK 
CHIP_M2 = (CHIP INTERACT (EXTENT M2x)) AND M2RBLK 
CHIP_M3 = (CHIP INTERACT (EXTENT M3x)) AND M3RBLK 
CHIP_M4 = (CHIP INTERACT (EXTENT M4x)) AND M4RBLK 
CHIP_M5 = (CHIP INTERACT (EXTENT M5x)) AND M5RBLK 
CHIP_M6 = (CHIP INTERACT (EXTENT M6x)) AND M6RBLK 
CHIP_M7 = (CHIP INTERACT (EXTENT M7x)) AND M7RBLK 
CHIP_M8 = (CHIP INTERACT (EXTENT M8x)) AND M8RBLK 
CHIP_M9 = (CHIP INTERACT (EXTENT M9x)) AND M9RBLK 
#ELSE
CHIP_M1 = CHIP INTERACT (EXTENT M1x)
CHIP_M2 = CHIP INTERACT (EXTENT M2x)
