M4_NOTCH_candidate8 = EXT M4_NOTCH_candidate7 M4i <= Mx_S ABUT < 90 OPPOSITE REGION
M4_NOTCH_candidate9 = ENCLOSE RECTANGLE M4_NOTCH_candidate8 COMB_LL+GRID GRID
M4_NOTCH_candidate10 = M4_NOTCH_candidate5 NOT INTERACT M4_NOTCH_candidate9

M4_NOTCH_candidate11_1 = EXT M4_L_END_edge M4i <= COMB_S2 ABUT < 90 OPPOSITE REGION
M4_NOTCH_candidate11_2 = M4_NOTCH_L_END_edge TOUCH EDGE M4_NOTCH_candidate10
M4_NOTCH_candidate11_3 = INT M4_NOTCH_candidate11_2 [M4i] <= COMB_LL+GRID ABUT == 90 INTERSECTING ONLY
M4_NOTCH_candidate11_4 = EXPAND EDGE M4_NOTCH_candidate11_3 INSIDE BY GRID
M4_NOTCH_candidate11_5 = M4_NOTCH_candidate11_1 INSIDE M4_NOTCH
M4_NOTCH_candidate12_1 = EXT M4_NOTCH_candidate11_5 [M4_NOTCH_candidate11_3] == Mx_S ABUT < 90 OPPOSITE
M4_NOTCH_candidate12 = M4_NOTCH_candidate11_4 WITH EDGE M4_NOTCH_candidate12_1 == 1 
M4_NOTCH_candidate13 = M4_NOTCH_candidate10 WITH EDGE (M4_NOTCH_candidate11_3 TOUCH EDGE M4_NOTCH_candidate12) == 2
M4_NOTCH_candidate14 = M4_NOTCH_L_END_edge TOUCH EDGE M4_NOTCH_candidate13
M4_NOTCH_candidate15 = INT M4_NOTCH_candidate14 [M4i] <= COMB_LL ABUT == 90 INTERSECTING ONLY
M4_NOTCH_candidate16 = EXT [M4_NOTCH_candidate15] M4i > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE 
M4_NOTCH_candidate17 = M4_NOTCH_candidate15 NOT TOUCH EDGE (M4_NOTCH_candidate15 NOT COIN EDGE M4_NOTCH_candidate16)
M4_NOTCH_candidate18 = M4_NOTCH_candidate13 WITH EDGE M4_NOTCH_candidate17 == 2

M4_NOTCH_candidate19 = M4_NOTCH_candidate2 INTERACT M4_NOTCH_candidate18
M4_NOTCH_candidate20 = M4_NOTCH_L_END_edge COIN EDGE M4_NOTCH_candidate19
M4_NOTCH_candidate21 = INT M4_NOTCH_candidate20 [M4_NOTCH_candidate19] <= COMB_S2 ABUT < 90 OPPOSITE
M4_NOTCH_candidate22 = (M4_NOTCH_candidate19 NOT COIN EDGE M4_NOTCH_candidate20) NOT COIN EDGE M4_NOTCH_candidate21
M4_NOTCH_candidate23 = EXT [M4_NOTCH_candidate22] M4_NOTCH_candidate11_1 > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE
M4_NOTCH_candidate24 = M4_NOTCH_candidate22 NOT TOUCH EDGE (M4_NOTCH_candidate22 NOT COIN EDGE M4_NOTCH_candidate23)
M4_NOTCH_candidate25 = M4_NOTCH_candidate19 WITH EDGE M4_NOTCH_candidate24 == 2
M4_NOTCH_candidate26 = M4_NOTCH_candidate18 INTERACT M4_NOTCH_candidate25

EFP.M4.S.4 { @ Comb rule: At least one side space of Mx line [width = 0.05 um (W1), in a COMB configuration] to Mx lines. Definition of COMB configuration: Middle Mx line space to both Mx lines [width = 0.05 um (W2) and both Mxs are part of one polygon] = 0.05 um (S1) in width direction. Another 2 Mx lines (W3) space to middle Mx = 0.15 um (S3). Parallel run length of 5 Mx lines is within 0 um ~ 0.4 um (L1). In addition, the odd Mx (W1,W3) line-end space to opposite Mx <= 0.08 um (S2) >= 0.055 
  COPY M4_NOTCH_candidate26
}
