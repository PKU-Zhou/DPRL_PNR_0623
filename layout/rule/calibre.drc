#ELSE // WITH_SEALRING

//BiB CHECKS
//===========

SEALRING_INNER 	= SEALRING_ORI INSIDE (HOLES SEALRING_ORI)
CSR_HOLE 	= (HOLES SEALRING_INNER) INTERACT CSRDMY  
CSR_DOD		= (DOD INTERACT SEALRING_ALL) AND CSRDMY
CSR_PO		= POLY INSIDE CSRDMY
DOD_RING_BIB	= CSRDMY NOT CSR_DOD
DOD_BULK_BIB 	= EXTENTS DOD_RING_BIB
PO_RING_BIB	= CSR_PO INTERACT (HOLES CSR_PO) 
PO_BULK_BIB 	= EXTENTS PO_RING_BIB
CO_BIB 		= (CO INSIDE CSR_HOLE) INTERACT CSRDMY

DOD_BULK_BIB_CODOD 	= DOD_BULK_BIB ENCLOSE CO_BIB
PO_BULK_BIB_CODOD 	= PO_BULK_BIB ENCLOSE CO_BIB
DOD_BULK_BIB_PODOD 	= DOD_BULK_BIB ENCLOSE PO_RING_BIB
PO_BULK_BIB_PODOD	= PO_BULK_BIB INSIDE DOD_BULK_BIB
CO_BULK_BIB_RING	= SIZE CO_BIB BY (BiB_S_3/2) OVERUNDER
CO_BULK_BIB		= EXTENTS CO_BULK_BIB_RING

BiB.R.1 { @ PO_DOD, CO_DOD and CO_PO BiB patterns must inside CSR. 
          @ PO_DOD BiB pattern is formed by [DOD reverse tone ring + PO ring inside DOD reverse tone ring] 
	  @ CO_PO {CO_OD} BiB pattern is formed by [PO {DOD reverse tone ring} ring + CO ring inside PO {DOD reverse tone rign} ring]
  (CSR_HOLE NOT INTERACT CSRBIB1DMY) NOT INTERACT CSRBIB2DMY
  (CSR_HOLE INTERACT CSRBIB1DMY) INTERACT CSRBIB2DMY
  A = CSR_HOLE INTERACT CSRBIB1DMY
  A NOT ENCLOSE DOD_BULK_BIB_CODOD
  A NOT ENCLOSE PO_BULK_BIB_CODOD
  B = CSR_HOLE INTERACT CSRBIB2DMY
  B NOT ENCLOSE DOD_BULK_BIB_PODOD
  B NOT ENCLOSE PO_BULK_BIB_CODOD
  CHIP_WISR_P4 NOT INTERACT A == 2
  CHIP_WISR_P4 NOT INTERACT B == 2
}

BiB.W.1 { @ Width of OD ring and PO ring. == ^BIB_W_1
  NOT WITH WIDTH DOD_RING_BIB == BIB_W_1
  NOT WITH WIDTH PO_RING_BIB == BIB_W_1
}

BiB.W.2 { @ Width of CO (maximum = minimum) = ^BiB_W_2 um
  NOT RECTANGLE CO_BIB == BIB_W_2 BY ==BIB_W_2 ORTHOGONAL ONLY
}

BiB.W.3 { @ Width of (CO sizing 0.05 and -0.05) ring == ^BiB_W_3 um
  A = SIZE CO_BIB BY 0.05 OVERUNDER
  NOT WITH WIDTH A == BiB_W_3  
}

BiB.S.1 { @ Space of {DOD reverse tone ring or PO ring} to sealring CO bar 
          @ DRC only select one side of DOD reverse tone ring or PO ring for space check == ^BIB_S_1
  CO_BAR_CSRDMY = CO AND SEALRING_ORI
  A = EXT [DOD_BULK_BIB] CO_BAR_CSRDMY == BIB_S_1 OPPOSITE
  DOD_BULK_BIB NOT WITH EDGE A
  B = EXT [PO_BULK_BIB_CODOD] CO_BAR_CSRDMY == BIB_S_1 OPPOSITE
  PO_BULK_BIB_CODOD NOT WITH EDGE B
}

BiB.S.3 { @ Space of CO to CO [in the same ring]. == ^BIB_S_3
  CO_SPACE_BIB = CO_BULK_BIB_RING NOT CO_BIB
  INT CO_SPACE_BIB < BIB_S_3 OPPOSITE REGION
  SIZE CO_SPACE_BIB BY BIB_S_3/2 UNDEROVER
  CO_BULK_BIB_HOLE = EXTENTS (CO_BULK_BIB NOT CO_BULK_BIB_RING)
  CO_BIB INSIDE CO_BULK_BIB_HOLE
  CO_BIB NOT CO_BULK_BIB_RING
}

BiB.L.1 { @ Length of DOD reverse tone ring inner edge. == ^BIB_L_1
  NOT RECTANGLE (DOD_BULK_BIB_CODOD NOT DOD_RING_BIB) == BIB_L_1 BY ==BIB_L_1 ORTHOGONAL ONLY
  NOT RECTANGLE (DOD_BULK_BIB_PODOD NOT DOD_RING_BIB) == BIB_L_1 BY ==BIB_L_1 ORTHOGONAL ONLY  
}

BiB.L.2 { @ Length of PO ring inner edge [in PO_DOD BiB pattern]. == ^BIB_L_2
  NOT RECTANGLE (PO_BULK_BIB_PODOD NOT PO_RING_BIB) == BIB_L_2 BY ==BIB_L_2 ORTHOGONAL ONLY
}

BiB.L.3 { @ Length of PO ring inner edge [in CO_PO BiB pattern]. == ^BIB_L_3
  NOT RECTANGLE (PO_BULK_BIB_CODOD NOT PO_RING_BIB) == BIB_L_3 BY ==BIB_L_3 ORTHOGONAL ONLY
}

BiB.L.4 { @ Length of outer (CO sizing 0.05 and -0.05) ring == ^BiB_L_4N um
  	  @ Length of inter (CO sizing 0.05 and -0.05) ring == ^BiB_L_4O um
  NOT RECTANGLE (CO_BULK_BIB NOT CO_BULK_BIB_RING) == BiB_L_4O BY ==BiB_L_4O ORTHOGONAL ONLY
  NOT RECTANGLE CO_BULK_BIB == BiB_L_4N BY ==BiB_L_4N ORTHOGONAL ONLY
}

BiB.EN.1 { @ Enclosure of PO to DOD [opposite edge in PO_DOD BiB pattern]. == ^BIB_EN_1
  NOT WITH WIDTH ((DOD_BULK_BIB_PODOD NOT PO_BULK_BIB_PODOD) NOT DOD_RING_BIB) == BIB_EN_1
}

BiB.EN.2 { @ Enclosure of outer CO ring to DOD [opposite edge in CO_DOD BiB pattern]. == ^BIB_EN_2
  NOT WITH WIDTH ((DOD_BULK_BIB_CODOD NOT CO_BULK_BIB) NOT DOD_RING_BIB) == BIB_EN_2
}

BiB.EN.3 { @ Enclosure of outer CO ring to PO [opposite edge in CO_OD BiB pattern]. == ^BIB_EN_3
  NOT WITH WIDTH ((PO_BULK_BIB_CODOD NOT CO_BULK_BIB) NOT PO_RING_BIB) == BIB_EN_3
}

BiB.EN.4 { @ Enclosure of inner CO ring to OD [opposite edge in CO_OD BiB pattern]. == ^BIB_EN_4
  NOT WITH WIDTH ((DOD_BULK_BIB_CODOD NOT DOD_RING_BIB) NOT (CO_BULK_BIB NOT CO_BULK_BIB_RING)) == BIB_EN_4
}

BiB.EN.5 { @ Enclosure of inner CO ring to PO [opposite edge in CO_OD BiB pattern]. == ^BIB_EN_5
  NOT WITH WIDTH ((PO_BULK_BIB_CODOD NOT PO_RING_BIB) NOT (CO_BULK_BIB NOT CO_BULK_BIB_RING)) == BIB_EN_5
}

BiB.R.4 { @ Overlap of OD, PO, CO patterns are not allowed.
  DOD_RING_BIB AND PO_RING_BIB
  DOD_RING_BIB AND CO_BIB
  PO_RING_BIB AND CO_BIB
}


// CSR Layers
//---------------

CHIP_CORNER_C = INT CHIP_WISR_P4 <= 25 ABUT == 90 REGION INTERSECTING ONLY

CSR_M1_P4 = M1i AND CSRDMY
CSR_2_M1_HOLE = SIZE(SIZE (CSRDMY NOT M1) BY 1.5+4*GRID OVERUNDER) BY 1+4*GRID UNDEROVER
CSR_M1_HOLE = SIZE CSR_2_M1_HOLE BY CSR_W_1B/2 OVERUNDER
CSR_M1_D = M1 INSIDE (CSR_2_M1_HOLE OR CHIP_CORNER_C)
ISO_M1_D = (M1 INSIDE ISOR_P4) NOT CDUDMY
Reinforced_M1 = ((CSR_M1_P4 NOT SEALRING_ORI) NOT CSR_M1_D) INTERACT CSR_M1_HOLE
CSR_M2_P4 = M2i AND CSRDMY
CSR_2_M2_HOLE = SIZE(SIZE (CSRDMY NOT M2) BY 1.5+4*GRID OVERUNDER) BY 1+4*GRID UNDEROVER
CSR_M2_HOLE = SIZE CSR_2_M2_HOLE BY CSR_W_1B/2 OVERUNDER
CSR_M2_D = M2 INSIDE (CSR_2_M2_HOLE OR CHIP_CORNER_C)
ISO_M2_D = (M2 INSIDE ISOR_P4) NOT CDUDMY
Reinforced_M2 = ((CSR_M2_P4 NOT SEALRING_ORI) NOT CSR_M2_D) INTERACT CSR_M2_HOLE
CSR_M3_P4 = M3i AND CSRDMY
CSR_2_M3_HOLE = SIZE(SIZE (CSRDMY NOT M3) BY 1.5+4*GRID OVERUNDER) BY 1+4*GRID UNDEROVER
CSR_M3_HOLE = SIZE CSR_2_M3_HOLE BY CSR_W_1B/2 OVERUNDER
CSR_M3_D = M3 INSIDE (CSR_2_M3_HOLE OR CHIP_CORNER_C)
ISO_M3_D = (M3 INSIDE ISOR_P4) NOT CDUDMY
Reinforced_M3 = ((CSR_M3_P4 NOT SEALRING_ORI) NOT CSR_M3_D) INTERACT CSR_M3_HOLE
CSR_M4_P4 = M4i AND CSRDMY
CSR_2_M4_HOLE = SIZE(SIZE (CSRDMY NOT M4) BY 1.5+4*GRID OVERUNDER) BY 1+4*GRID UNDEROVER
CSR_M4_HOLE = SIZE CSR_2_M4_HOLE BY CSR_W_1B/2 OVERUNDER
CSR_M4_D = M4 INSIDE (CSR_2_M4_HOLE OR CHIP_CORNER_C)
