TypeC_M6_outer_b = TypeC_M6_outer_a WITH EDGE (LENGTH (TypeC_M6_outer TOUCH EDGE TypeC_M6_b) < TypeC_LA)
TypeC_M6_outer_side= TypeC_M6_outer_b COIN EDGE TypeC_M6_side_ext
TypeC_M6_inner	  = (EXPAND EDGE TypeC_M6_outer_side INSIDE BY 3*Mx_W+2*Mx_S) WITH EDGE TypeC_M6_outer_side ==2
TypeC_M6_inner_a  = TypeC_M6_inner WITH EDGE (LENGTH (TypeC_M6_inner TOUCH EDGE TypeC_M6_side_ext) >= TypeC_LO_MIN <= TypeC_LO_MAX)
TypeC_M6_inner_M6_sp= EXT (M6i AND TypeC_M6_inner_a) <=Mx_W ABUT<90 OPPOSITE REGION
TypeC_M6_inner_b  = TypeC_M6_inner_a INTERACT TypeC_M6_inner_M6_sp >=2
TypeC_M6_err	   = COPY TypeC_M6_inner_b
EFP.M6.S.1 { @ CIC rule: At least one side space of Mx line [width = 0.05 um (W1), between 2 C-shape Mxs] to opposite C-shape Mx. Definition of "C-shape Mx": Mx has 2 consecutive 270-270 inner vertexes, and the edge [line width = 0.05 um (Wc)] between the consecutive inner vertexes faces to another Mx [width >= 0.055 um (Ws)]. Parallel run length of the edge lengths between individual 2 consecutive 270-270 inner vertexes must be < 0.3 um (L1) in 2 C-shape Mx configuration >= 0.055 
   COPY TypeC_M6_err
}
// EFP.Mx.S.1 is checked by EFP.M6.S.1


M6_NOTCH_pre1 = VERTEX (EXT M6i < COMB_S1 ABUT < 90 NOTCH OPPOSITE REGION) > 4
M6_NOTCH_pre2 = SIZE M6_NOTCH_pre1 BY GRID
M6_NOTCH_pre3 = ENCLOSE RECTANGLE M6_NOTCH_pre2 3*Mx_W+4*Mx_S GRID
M6_NOTCH_pre4 = M6_NOTCH_pre1 INSIDE M6_NOTCH_pre3
M6_NOTCH_L_END_edge_pre = EXPAND EDGE M6_L_END_edge OUTSIDE BY GRID EXTEND BY GRID
M6_NOTCH = M6_NOTCH_pre4 INTERACT (M6_NOTCH_pre4 AND M6_NOTCH_L_END_edge_pre) >= 3
M6_NOTCH_L_END_edge_pre1 = M6_L_END_edge COIN EDGE (M6_NOTCH_L_END_edge_pre INSIDE M6_NOTCH)
M6_NOTCH_L_END_edge = ENC [M6_NOTCH_L_END_edge_pre1] M6_NOTCH <= COMB_S2 OPPOSITE MEASURE COIN

M6_NOTCH_candidate1_1 = M6i INTERACT M6_NOTCH
M6_NOTCH_candidate1_2 = M6_NOTCH_L_END_edge COIN EDGE M6_NOTCH_candidate1_1 
M6_NOTCH_candidate2 = EXT M6_NOTCH_candidate1_1 M6_NOTCH_candidate1_2 <= COMB_S2 ABUT < 90 OPPOSITE REGION
M6_NOTCH_candidate3 = ((M6_NOTCH_L_END_edge TOUCH EDGE M6_NOTCH_candidate2) INSIDE EDGE M6_NOTCH) OR EDGE ((M6_NOTCH_L_END_edge TOUCH EDGE M6_NOTCH_candidate2) TOUCH EDGE M6_NOTCH)
M6_NOTCH_candidate4 = EXPAND EDGE M6_NOTCH_candidate3 INSIDE BY GRID
M6_NOTCH_candidate5 = (SIZE M6_NOTCH_candidate4 BY COMB_marker-GRID INSIDE OF M6_NOTCH_candidate1_1 STEP Mx_S *0.7) INTERACT M6_NOTCH

M6_NOTCH_candidate6 = M6_NOTCH_L_END_edge TOUCH EDGE M6_NOTCH_candidate5 
M6_NOTCH_candidate7 = INT M6_NOTCH_candidate6 [M6i] <= COMB_LL+2*GRID ABUT == 90 INTERSECTING ONLY
M6_NOTCH_candidate8 = EXT M6_NOTCH_candidate7 M6i <= Mx_S ABUT < 90 OPPOSITE REGION
M6_NOTCH_candidate9 = ENCLOSE RECTANGLE M6_NOTCH_candidate8 COMB_LL+GRID GRID
M6_NOTCH_candidate10 = M6_NOTCH_candidate5 NOT INTERACT M6_NOTCH_candidate9

M6_NOTCH_candidate11_1 = EXT M6_L_END_edge M6i <= COMB_S2 ABUT < 90 OPPOSITE REGION
M6_NOTCH_candidate11_2 = M6_NOTCH_L_END_edge TOUCH EDGE M6_NOTCH_candidate10
M6_NOTCH_candidate11_3 = INT M6_NOTCH_candidate11_2 [M6i] <= COMB_LL+GRID ABUT == 90 INTERSECTING ONLY
M6_NOTCH_candidate11_4 = EXPAND EDGE M6_NOTCH_candidate11_3 INSIDE BY GRID
M6_NOTCH_candidate11_5 = M6_NOTCH_candidate11_1 INSIDE M6_NOTCH
M6_NOTCH_candidate12_1 = EXT M6_NOTCH_candidate11_5 [M6_NOTCH_candidate11_3] == Mx_S ABUT < 90 OPPOSITE
M6_NOTCH_candidate12 = M6_NOTCH_candidate11_4 WITH EDGE M6_NOTCH_candidate12_1 == 1 
M6_NOTCH_candidate13 = M6_NOTCH_candidate10 WITH EDGE (M6_NOTCH_candidate11_3 TOUCH EDGE M6_NOTCH_candidate12) == 2
M6_NOTCH_candidate14 = M6_NOTCH_L_END_edge TOUCH EDGE M6_NOTCH_candidate13
M6_NOTCH_candidate15 = INT M6_NOTCH_candidate14 [M6i] <= COMB_LL ABUT == 90 INTERSECTING ONLY
M6_NOTCH_candidate16 = EXT [M6_NOTCH_candidate15] M6i > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE 
M6_NOTCH_candidate17 = M6_NOTCH_candidate15 NOT TOUCH EDGE (M6_NOTCH_candidate15 NOT COIN EDGE M6_NOTCH_candidate16)
M6_NOTCH_candidate18 = M6_NOTCH_candidate13 WITH EDGE M6_NOTCH_candidate17 == 2

M6_NOTCH_candidate19 = M6_NOTCH_candidate2 INTERACT M6_NOTCH_candidate18
M6_NOTCH_candidate20 = M6_NOTCH_L_END_edge COIN EDGE M6_NOTCH_candidate19
M6_NOTCH_candidate21 = INT M6_NOTCH_candidate20 [M6_NOTCH_candidate19] <= COMB_S2 ABUT < 90 OPPOSITE
M6_NOTCH_candidate22 = (M6_NOTCH_candidate19 NOT COIN EDGE M6_NOTCH_candidate20) NOT COIN EDGE M6_NOTCH_candidate21
M6_NOTCH_candidate23 = EXT [M6_NOTCH_candidate22] M6_NOTCH_candidate11_1 > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE
M6_NOTCH_candidate24 = M6_NOTCH_candidate22 NOT TOUCH EDGE (M6_NOTCH_candidate22 NOT COIN EDGE M6_NOTCH_candidate23)
M6_NOTCH_candidate25 = M6_NOTCH_candidate19 WITH EDGE M6_NOTCH_candidate24 == 2
M6_NOTCH_candidate26 = M6_NOTCH_candidate18 INTERACT M6_NOTCH_candidate25

EFP.M6.S.4 { @ Comb rule: At least one side space of Mx line [width = 0.05 um (W1), in a COMB configuration] to Mx lines. Definition of COMB configuration: Middle Mx line space to both Mx lines [width = 0.05 um (W2) and both Mxs are part of one polygon] = 0.05 um (S1) in width direction. Another 2 Mx lines (W3) space to middle Mx = 0.15 um (S3). Parallel run length of 5 Mx lines is within 0 um ~ 0.4 um (L1). In addition, the odd Mx (W1,W3) line-end space to opposite Mx <= 0.08 um (S2) >= 0.055 
  COPY M6_NOTCH_candidate26
}
// EFP.Mx.S.4 is checked by EFP.M6.S.4

// M7 Type CIC 
//=============
TypeC_M7	  = CONVEX EDGE M7i ANGLE1 == 270 ANGLE2 == 270 WITH LENGTH < TypeC_LA
TypeC_M7_minw	  = INT TypeC_M7 M7i <=Mx_W ABUT<90 OPPOSITE REGION
TypeC_M7_a	  = TypeC_M7 COIN EDGE TypeC_M7_minw
TypeC_M7_side_ext= EXT TypeC_M7_a M7i <= 0.06 ABUT<90 OPPOSITE REGION
TypeC_M7_side	  = (TypeC_M7_side_ext TOUCH EDGE M7i) NOT TOUCH EDGE TypeC_M7_a
TypeC_M7_b	  = TypeC_M7_a TOUCH EDGE TypeC_M7_side_ext
TypeC_M7_common  = EXT ((EXPAND EDGE TypeC_M7_b OUTSIDE BY 0.001) TOUCH EDGE TypeC_M7_b) == 3*Mx_W+2*Mx_S PARALLEL ONLY OPPOSITE REGION
TypeC_M7_outer	  = (EXPAND EDGE (TypeC_M7_b TOUCH EDGE TypeC_M7_common) INSIDE BY 3*Mx_W+2*Mx_S) WITH EDGE TypeC_M7_b ==2
TypeC_M7_outer_a = TypeC_M7_outer WITH EDGE (LENGTH (TypeC_M7_outer NOT TOUCH EDGE TypeC_M7_b) <= 3*Mx_W+2*Mx_S)
TypeC_M7_outer_b = TypeC_M7_outer_a WITH EDGE (LENGTH (TypeC_M7_outer TOUCH EDGE TypeC_M7_b) < TypeC_LA)
TypeC_M7_outer_side= TypeC_M7_outer_b COIN EDGE TypeC_M7_side_ext
TypeC_M7_inner	  = (EXPAND EDGE TypeC_M7_outer_side INSIDE BY 3*Mx_W+2*Mx_S) WITH EDGE TypeC_M7_outer_side ==2
TypeC_M7_inner_a  = TypeC_M7_inner WITH EDGE (LENGTH (TypeC_M7_inner TOUCH EDGE TypeC_M7_side_ext) >= TypeC_LO_MIN <= TypeC_LO_MAX)
TypeC_M7_inner_M7_sp= EXT (M7i AND TypeC_M7_inner_a) <=Mx_W ABUT<90 OPPOSITE REGION
TypeC_M7_inner_b  = TypeC_M7_inner_a INTERACT TypeC_M7_inner_M7_sp >=2
TypeC_M7_err	   = COPY TypeC_M7_inner_b
EFP.M7.S.1 { @ CIC rule: At least one side space of Mx line [width = 0.05 um (W1), between 2 C-shape Mxs] to opposite C-shape Mx. Definition of "C-shape Mx": Mx has 2 consecutive 270-270 inner vertexes, and the edge [line width = 0.05 um (Wc)] between the consecutive inner vertexes faces to another Mx [width >= 0.055 um (Ws)]. Parallel run length of the edge lengths between individual 2 consecutive 270-270 inner vertexes must be < 0.3 um (L1) in 2 C-shape Mx configuration >= 0.055 
   COPY TypeC_M7_err
}
// EFP.Mx.S.1 is checked by EFP.M7.S.1


M7_NOTCH_pre1 = VERTEX (EXT M7i < COMB_S1 ABUT < 90 NOTCH OPPOSITE REGION) > 4
M7_NOTCH_pre2 = SIZE M7_NOTCH_pre1 BY GRID
M7_NOTCH_pre3 = ENCLOSE RECTANGLE M7_NOTCH_pre2 3*Mx_W+4*Mx_S GRID
M7_NOTCH_pre4 = M7_NOTCH_pre1 INSIDE M7_NOTCH_pre3
M7_NOTCH_L_END_edge_pre = EXPAND EDGE M7_L_END_edge OUTSIDE BY GRID EXTEND BY GRID
M7_NOTCH = M7_NOTCH_pre4 INTERACT (M7_NOTCH_pre4 AND M7_NOTCH_L_END_edge_pre) >= 3
M7_NOTCH_L_END_edge_pre1 = M7_L_END_edge COIN EDGE (M7_NOTCH_L_END_edge_pre INSIDE M7_NOTCH)
M7_NOTCH_L_END_edge = ENC [M7_NOTCH_L_END_edge_pre1] M7_NOTCH <= COMB_S2 OPPOSITE MEASURE COIN

M7_NOTCH_candidate1_1 = M7i INTERACT M7_NOTCH
M7_NOTCH_candidate1_2 = M7_NOTCH_L_END_edge COIN EDGE M7_NOTCH_candidate1_1 
M7_NOTCH_candidate2 = EXT M7_NOTCH_candidate1_1 M7_NOTCH_candidate1_2 <= COMB_S2 ABUT < 90 OPPOSITE REGION
M7_NOTCH_candidate3 = ((M7_NOTCH_L_END_edge TOUCH EDGE M7_NOTCH_candidate2) INSIDE EDGE M7_NOTCH) OR EDGE ((M7_NOTCH_L_END_edge TOUCH EDGE M7_NOTCH_candidate2) TOUCH EDGE M7_NOTCH)
M7_NOTCH_candidate4 = EXPAND EDGE M7_NOTCH_candidate3 INSIDE BY GRID
M7_NOTCH_candidate5 = (SIZE M7_NOTCH_candidate4 BY COMB_marker-GRID INSIDE OF M7_NOTCH_candidate1_1 STEP Mx_S *0.7) INTERACT M7_NOTCH

M7_NOTCH_candidate6 = M7_NOTCH_L_END_edge TOUCH EDGE M7_NOTCH_candidate5 
M7_NOTCH_candidate7 = INT M7_NOTCH_candidate6 [M7i] <= COMB_LL+2*GRID ABUT == 90 INTERSECTING ONLY
M7_NOTCH_candidate8 = EXT M7_NOTCH_candidate7 M7i <= Mx_S ABUT < 90 OPPOSITE REGION
M7_NOTCH_candidate9 = ENCLOSE RECTANGLE M7_NOTCH_candidate8 COMB_LL+GRID GRID
M7_NOTCH_candidate10 = M7_NOTCH_candidate5 NOT INTERACT M7_NOTCH_candidate9

M7_NOTCH_candidate11_1 = EXT M7_L_END_edge M7i <= COMB_S2 ABUT < 90 OPPOSITE REGION
M7_NOTCH_candidate11_2 = M7_NOTCH_L_END_edge TOUCH EDGE M7_NOTCH_candidate10
M7_NOTCH_candidate11_3 = INT M7_NOTCH_candidate11_2 [M7i] <= COMB_LL+GRID ABUT == 90 INTERSECTING ONLY
M7_NOTCH_candidate11_4 = EXPAND EDGE M7_NOTCH_candidate11_3 INSIDE BY GRID
M7_NOTCH_candidate11_5 = M7_NOTCH_candidate11_1 INSIDE M7_NOTCH
M7_NOTCH_candidate12_1 = EXT M7_NOTCH_candidate11_5 [M7_NOTCH_candidate11_3] == Mx_S ABUT < 90 OPPOSITE
M7_NOTCH_candidate12 = M7_NOTCH_candidate11_4 WITH EDGE M7_NOTCH_candidate12_1 == 1 
M7_NOTCH_candidate13 = M7_NOTCH_candidate10 WITH EDGE (M7_NOTCH_candidate11_3 TOUCH EDGE M7_NOTCH_candidate12) == 2
M7_NOTCH_candidate14 = M7_NOTCH_L_END_edge TOUCH EDGE M7_NOTCH_candidate13
M7_NOTCH_candidate15 = INT M7_NOTCH_candidate14 [M7i] <= COMB_LL ABUT == 90 INTERSECTING ONLY
M7_NOTCH_candidate16 = EXT [M7_NOTCH_candidate15] M7i > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE 
M7_NOTCH_candidate17 = M7_NOTCH_candidate15 NOT TOUCH EDGE (M7_NOTCH_candidate15 NOT COIN EDGE M7_NOTCH_candidate16)
M7_NOTCH_candidate18 = M7_NOTCH_candidate13 WITH EDGE M7_NOTCH_candidate17 == 2

M7_NOTCH_candidate19 = M7_NOTCH_candidate2 INTERACT M7_NOTCH_candidate18
M7_NOTCH_candidate20 = M7_NOTCH_L_END_edge COIN EDGE M7_NOTCH_candidate19
M7_NOTCH_candidate21 = INT M7_NOTCH_candidate20 [M7_NOTCH_candidate19] <= COMB_S2 ABUT < 90 OPPOSITE
M7_NOTCH_candidate22 = (M7_NOTCH_candidate19 NOT COIN EDGE M7_NOTCH_candidate20) NOT COIN EDGE M7_NOTCH_candidate21
M7_NOTCH_candidate23 = EXT [M7_NOTCH_candidate22] M7_NOTCH_candidate11_1 > Mx_W+Mx_S < COMB_S3_S4 ABUT < 90 OPPOSITE
M7_NOTCH_candidate24 = M7_NOTCH_candidate22 NOT TOUCH EDGE (M7_NOTCH_candidate22 NOT COIN EDGE M7_NOTCH_candidate23)
M7_NOTCH_candidate25 = M7_NOTCH_candidate19 WITH EDGE M7_NOTCH_candidate24 == 2
M7_NOTCH_candidate26 = M7_NOTCH_candidate18 INTERACT M7_NOTCH_candidate25

EFP.M7.S.4 { @ Comb rule: At least one side space of Mx line [width = 0.05 um (W1), in a COMB configuration] to Mx lines. Definition of COMB configuration: Middle Mx line space to both Mx lines [width = 0.05 um (W2) and both Mxs are part of one polygon] = 0.05 um (S1) in width direction. Another 2 Mx lines (W3) space to middle Mx = 0.15 um (S3). Parallel run length of 5 Mx lines is within 0 um ~ 0.4 um (L1). In addition, the odd Mx (W1,W3) line-end space to opposite Mx <= 0.08 um (S2) >= 0.055 
  COPY M7_NOTCH_candidate26
}
// EFP.Mx.S.4 is checked by EFP.M7.S.4
EFP.M2.R.1 { @ Risky_VIA1 inside M2_dense_environment is not allowed. Definitions: 1. Risky_VIA1: VIA1 land at M2 island center location which M2 island [width = 0.05 um, length <= 0.30 um] and it's line_end space to {M2 OR DM2_O} < 0.085 um [PRL > 0 um] for both sides. 2. Risky_M2: {M2 island INTERACT Risky_VIA1} 3. Enclosed_region-A: {{{M2 OR DM2_O} [width = 0.05 um] SIZING up/down 0.025 um} AND {Expand long side edge of Risky_M2 OUTSIDE BY 0.30 um}} >= 0.28 um x 0.30 um, and the edge length of {enclosed_region-A touch Risky_M2 outside edge} >= 0.28 um. 4. M2_dense_environment: {Risky_M2 INTERACT enclosed_region-A} = 2   
  M2_island = RECTANGLE M2i == EFP_M2_R_1_W1 BY <= EFP_M2_R_1_L1 

  END = CONVEX EDGE M2_island ANGLE1 == 90 ANGLE2 == 90 WITH LENGTH == EFP_M2_R_1_W1
  M2_s2s = EXT END M2 < EFP_M2_R_1_S ABUT < 90 OPPOSITE REGION
  M2_island_CHK =  M2_island INTERACT M2_s2s == 2
  RISKY_M2 = M2_island_CHK INTERACT RISKY_VIA1 
  VIA1_CHK_PRE = VIA1 INTERACT M2_island_CHK
  M2_island_CHK_center = INT (M2_island_CHK NOT TOUCH INSIDE EDGE VIA1_CHK_PRE) <= EFP_M2_R_1_L1 OPPOSITE REGION CENTERLINE
  VIA1_CHK_center = INT (VIA1_CHK_PRE NOT TOUCH INSIDE EDGE M2_island_CHK) <= EFP_M2_R_1_W2 OPPOSITE REGION CENTERLINE
  CHK1 = M2_island_CHK_center XOR VIA1_CHK_center
  RISKY_VIA1 = VIA1_CHK_PRE NOT INTERACT CHK1

  REGION_A_pre1 = SIZE (M2 WITH WIDTH == EFP_M2_R_1_W1) BY EFP_M2_R_1_E1 OVERUNDER
  REGION_A_pre2 = EXPAND EDGE (LENGTH RISKY_M2 > EFP_M2_R_1_W1) OUTSIDE BY EFP_M2_R_1_E2
  REGION_A_pre3 = REGION_A_pre1 AND REGION_A_pre2
  REGION_A = ENCLOSE RECTANGLE REGION_A_pre3 EFP_M2_R_1_L1 EFP_M2_R_1_L2 ORTHOGONAL ONLY
  VIOLATION_REGION_pre = LENGTH (REGION_A TOUCH OUTSIDE EDGE RISKY_M2) >= EFP_M2_R_1_L2
  VIOLATION_REGION_pre1 = REGION_A WITH EDGE VIOLATION_REGION_pre
  VIOLATION_REGION = RISKY_M2 INTERACT VIOLATION_REGION_pre1 == 2

  RISKY_VIA1 INSIDE VIOLATION_REGION
}
#ENDIF //BACK_END

