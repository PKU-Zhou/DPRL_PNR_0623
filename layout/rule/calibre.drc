RR:RE:EFP.M3.S.7 { @ Metal bridge recommendation type-3: Recommended space of 2 Mx lines (polygon1/2) [width (W) = 0.05 um, cross over Region B3 and Region B4] when neighboring Mx (polygon3/4) with parallel run length > 0 um and there is no other Mx interact Region B1/B2 Definitions: 1. Region B3/B4 = 0.25 um * 0.09 um (L1), generated from vertex CB and CA respectively. 2. L2 = height difference of vertex CA project to vertex CB <= 0.05 um. 3. Region B1/B2 = 0.16 um * 0.115 um, generated from Mx (polygon3/4) line-end with vertex CA and CB respectively >= 0.055 
  M3_TypeBRS3_prefilter_1 = EXT [M3i] == TypeBRS3_S2 ABUT < 90 OPPOSITE
  M3_TypeBRS3_prefilter_2 = M3i TOUCH EDGE M3_TypeBRS3_prefilter_1
  M3_TypeBRS3_prefilter_3 = (M3_CORNER WITH EDGE M3_TypeBRS3_prefilter_2) COIN EDGE M3i
  
  M3_TypeBRS3_prefilter_4_1 = EXT M3_TypeBRS3_prefilter_3 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
  M3_TypeBRS3_prefilter_4_2 = M3i AND M3_TypeBRS3_prefilter_4_1
  M3_TypeBRS3_prefilter_4_3 = EXT [M3_TypeBRS3_prefilter_3] M3_TypeBRS3_prefilter_4_2 <= Mx_S OPPOSITE EXTENDED TypeBRS3_S6
  M3_TypeBRS3_prefilter_4_4 = M3_TypeBRS3_prefilter_3 TOUCH EDGE M3_TypeBRS3_prefilter_4_3 
  M3_TypeBRS3_prefilter_4_5 = EXT [M3_TypeBRS3_prefilter_3] M3_TypeBRS3_prefilter_4_2 > Mx_S+Mx_W <= 2*Mx_S+Mx_W OPPOSITE EXTENDED TypeBRS3_S6
  M3_TypeBRS3_prefilter_4_6 = M3_TypeBRS3_prefilter_4_4 TOUCH EDGE M3_TypeBRS3_prefilter_4_5
  M3_TypeBRS3_prefilter_4 =  EXT M3_TypeBRS3_prefilter_4_6 >= TypeBRS3_S2 <= TypeBRS3_S2S6 REGION
  M3_TypeBRS3_prefilter_5_1 = EXPAND EDGE (M3_TypeBRS3_prefilter_3 COIN EDGE M3_TypeBRS3_prefilter_4) OUTSIDE BY 2*GRID
  M3_TypeBRS3_prefilter_5_2 = INT [M3_TypeBRS3_prefilter_5_1] == GRID OPPOSITE
  M3_TypeBRS3_prefilter_5_3 = EXPAND EDGE M3_TypeBRS3_prefilter_5_2 OUTSIDE BY GRID EXTEND BY GRID
  M3_TypeBRS3_prefilter_5_4 = M3_TypeBRS3_prefilter_5_2 COIN EDGE (M3_TypeBRS3_prefilter_5_3 NOT TOUCH EDGE M3_TypeBRS3_prefilter_3)
  M3_TypeBRS3_prefilter_5_5 = EXPAND EDGE M3_TypeBRS3_prefilter_5_4 OUTSIDE BY GRID
  M3_TypeBRS3_prefilter_5 = M3_TypeBRS3_prefilter_5_1 OR M3_TypeBRS3_prefilter_5_5
  
  M3_TypeBRS3_prefilter_6 = M3_TypeBRS3_prefilter_4 NOT M3_TypeBRS3_prefilter_5
  M3_TypeBRS3_prefilter_7_1 = M3_TypeBRS3_prefilter_6 INTERACT (M3_TypeBRS3_prefilter_6 AND M3i) > 1
  M3_TypeBRS3_prefilter_7 = (M3_TypeBRS3_prefilter_5_1 INTERACT M3_TypeBRS3_prefilter_7_1) OR M3_TypeBRS3_prefilter_7_1
  M3_TypeBRS3_prefilter_8 = EXTENTS M3_TypeBRS3_prefilter_7
  
  M3_TypeBRS3_prefilter_9 = M3_TypeBRS3_prefilter_3 COIN EDGE (M3_CORNER INTERACT M3_TypeBRS3_prefilter_8)
  M3_TypeBRS3_prefilter_10 = EXT M3_TypeBRS3_prefilter_9 M3_TypeBRS3_prefilter_2 == TypeBRS3_S2 OPPOSITE REGION
  M3_TypeBRS3_prefilter_11 = M3_TypeBRS3_prefilter_10 INTERACT (M3_TypeBRS3_prefilter_10 AND M3i) > 1
  M3_TypeBRS3_prefilter_12 = (EXPAND EDGE M3_TypeBRS3_prefilter_3 OUTSIDE BY GRID) NOT INTERACT M3_TypeBRS3_prefilter_11
  M3_TypeBRS3_prefilter_13 = (EXPAND EDGE (M3_TypeBRS3_prefilter_12 NOT COIN EDGE M3i) OUTSIDE BY GRID) OR M3_TypeBRS3_prefilter_12 
  M3_TypeBRS3_prefilter_14 = M3_TypeBRS3_prefilter_11 TOUCH EDGE M3_TypeBRS3_prefilter_13
  M3_TypeBRS3_prefilter_15 = M3_TypeBRS3_prefilter_11 WITH EDGE M3_TypeBRS3_prefilter_14 == 2
  
  M3_TypeBRS3_prefilter_16 = (M3_TypeBRS3_prefilter_11 WITH EDGE (LENGTH (M3_TypeBRS3_prefilter_8 COIN EDGE M3_TypeBRS3_prefilter_11) == TypeBRS3_S2)) NOT M3i
  
  M3_TypeBRS3_CACB_S6_1 = (M3_TypeBRS3_prefilter_8 INTERACT M3_TypeBRS3_prefilter_16 != 6) NOT ENCLOSE M3_TypeBRS3_prefilter_15
  M3_TypeBRS3_CACB_S6_2 = M3_TypeBRS3_CACB_S6_1 WITH WIDTH <= TypeBRS3_S6+GRID
  M3_TypeBRS3_CACB_S6_3 = M3_TypeBRS3_CACB_S6_2 AND M3i
  M3_TypeBRS3_CACB_S6_4 = M3_TypeBRS3_CACB_S6_2 INTERACT M3_TypeBRS3_CACB_S6_3 == 2
  M3_TypeBRS3_CACB_S6_5 = (EXPAND EDGE ((M3_TypeBRS3_CACB_S6_4 AND M3i) COIN EDGE M3i) OUTSIDE BY Mx_S) OR (M3_TypeBRS3_CACB_S6_4 AND M3i)
  M3_TypeBRS3_CACB_S6_6 = M3_TypeBRS3_CACB_S6_4 AND M3_TypeBRS3_CACB_S6_5
  M3_TypeBRS3_CACB_S6_7 = M3_TypeBRS3_CACB_S6_6 WITH EDGE ((M3_TypeBRS3_CACB_S6_6 AND M3i) COIN EDGE M3_TypeBRS3_CACB_S6_6) == 4
  
  M3_TypeBRS3_CACB_S3_1 = LENGTH M3_TypeBRS3_CACB_S6_7 == TypeBRS3_S2
  M3_TypeBRS3_CACB_S3_2 = M3i COIN EDGE M3_TypeBRS3_CACB_S6_7
  M3_TypeBRS3_CACB_S3_3 = LENGTH M3_TypeBRS3_CACB_S3_2 == GRID
  M3_TypeBRS3_CACB_S3_4 = (((M3_CORNER COIN EDGE M3i) NOT COIN EDGE M3_TypeBRS3_CACB_S3_3) NOT COIN EDGE M3_TypeBRS3_CACB_S3_1 ) TOUCH EDGE M3_TypeBRS3_CACB_S6_7
  M3_TypeBRS3_CACB_S3_5 = EXPAND EDGE M3_TypeBRS3_CACB_S3_3 OUTSIDE BY GRID EXTEND BY GRID
  M3_TypeBRS3_CACB_S3_6 = EXPAND EDGE M3_TypeBRS3_CACB_S3_4 OUTSIDE BY GRID EXTEND BY GRID
  
  M3_TypeBRS3_CACB_S3_7 = (((M3_CORNER INTERACT M3_TypeBRS3_CACB_S6_7) NOT INSIDE M3_TypeBRS3_CACB_S6_7) COIN EDGE M3i) NOT COIN EDGE M3_TypeBRS3_CACB_S6_7
  M3_TypeBRS3_CACB_S3_8 = EXPAND EDGE M3_TypeBRS3_CACB_S3_7 OUTSIDE BY GRID EXTEND BY GRID
  M3_TypeBRS3_CACB_S3_9 = M3_TypeBRS3_CACB_S3_1 TOUCH EDGE M3_TypeBRS3_CACB_S3_8
  M3_TypeBRS3_CACB_S3_10 = M3_TypeBRS3_CACB_S3_1 NOT TOUCH EDGE M3_TypeBRS3_CACB_S3_8
  M3_TypeBRS3_CACB_S3_11_1 = EXPAND EDGE M3_TypeBRS3_CACB_S3_9 OUTSIDE BY TypeBRS3_S3
  M3_TypeBRS3_CACB_S3_12_1 = EXPAND EDGE M3_TypeBRS3_CACB_S3_10 OUTSIDE BY TypeBRS3_S3-GRID
  M3_TypeBRS3_CACB_S3_11 = M3_TypeBRS3_CACB_S3_11_1 WITH EDGE ((M3_TypeBRS3_CACB_S3_11_1 AND M3) COIN EDGE M3_TypeBRS3_CACB_S3_11_1) >= 4
  M3_TypeBRS3_CACB_S3_12  = M3_TypeBRS3_CACB_S3_12_1 WITH EDGE ((M3_TypeBRS3_CACB_S3_12_1 AND M3) COIN EDGE M3_TypeBRS3_CACB_S3_12_1) >= 4
  M3_TypeBRS3_CACB_S3_13 = M3_TypeBRS3_CACB_S6_7 OR (M3_TypeBRS3_CACB_S3_11 OR M3_TypeBRS3_CACB_S3_12)
  M3_TypeBRS3_CACB_S3_14 = (M3_TypeBRS3_CACB_S3_13 AND M3i) COIN EDGE M3_TypeBRS3_CACB_S3_13
  M3_TypeBRS3_CACB_S3_15 = ENCLOSE RECTANGLE (M3_TypeBRS3_CACB_S3_13 WITH EDGE M3_TypeBRS3_CACB_S3_14 >= 4) TypeBRS3_S2 2*TypeBRS3_S3
  
  M3_TypeBRS3_CACB_S45_1 = EXPAND EDGE M3_TypeBRS3_CACB_S3_7 OUTSIDE BY 2*GRID 
  M3_TypeBRS3_CACB_S45_2 = M3_TypeBRS3_CACB_S3_15 COIN EDGE M3_TypeBRS3_CACB_S45_1 
  M3_TypeBRS3_CACB_S45_3 = EXT [M3_TypeBRS3_CACB_S3_7] M3i < TypeBRS3_S5 OPPOSITE EXTENDED GRID
  M3_TypeBRS3_CACB_S45_4 = EXT [M3_TypeBRS3_CACB_S45_2] M3i < TypeBRS3_S4 OPPOSITE
  M3_TypeBRS3_CACB_S45_5 = (EXPAND EDGE (M3_TypeBRS3_CACB_S45_1 COIN EDGE M3_TypeBRS3_CACB_S3_15) INSIDE BY 2*GRID) OR M3_TypeBRS3_CACB_S45_1
  M3_TypeBRS3_CACB_S45_6 = (M3_TypeBRS3_CACB_S45_5 NOT COIN EDGE M3i) NOT COIN EDGE M3_TypeBRS3_CACB_S3_15
  M3_TypeBRS3_CACB_S45_7 = ENC M3i [M3_TypeBRS3_CACB_S45_6] == 2*GRID OPPOSITE
  M3_TypeBRS3_CACB_S45_8 = (EXPAND EDGE M3_TypeBRS3_CACB_S45_7 OUTSIDE BY TypeBRS3_S5-2*GRID) OR M3_TypeBRS3_CACB_S45_5 
  M3_TypeBRS3_CACB_S45_9 = LENGTH M3_TypeBRS3_CACB_S45_8  >= TypeBRS3_S5 <= 2*TypeBRS3_S5
  M3_TypeBRS3_CACB_S45_10_1 = M3_TypeBRS3_CACB_S45_9 TOUCH EDGE M3_TypeBRS3_CACB_S3_15
  M3_TypeBRS3_CACB_S45_10_2 = ENC M3i [M3_TypeBRS3_CACB_S45_10_1] < TypeBRS3_S4 OPPOSITE
  M3_TypeBRS3_CACB_S45_10_3 = M3_TypeBRS3_CACB_S45_10_1 TOUCH EDGE M3_TypeBRS3_CACB_S45_10_2 
  M3_TypeBRS3_CACB_S45_10 = M3_TypeBRS3_CACB_S45_10_1 NOT TOUCH EDGE M3_TypeBRS3_CACB_S45_10_2 
  M3_TypeBRS3_CACB_S45_11 = EXPAND EDGE M3_TypeBRS3_CACB_S45_10 INSIDE BY TypeBRS3_S4
  M3_TypeBRS3_CACB_S45_12 = M3_TypeBRS3_CACB_S45_11 INTERACT (M3_TypeBRS3_CACB_S45_11 AND M3i)
  M3_TypeBRS3_CACB_BOXB_waive = (((M3_TypeBRS3_CACB_S45_5 WITH EDGE M3_TypeBRS3_CACB_S45_3) OR (M3_TypeBRS3_CACB_S45_5 WITH EDGE M3_TypeBRS3_CACB_S45_4)) OR (M3_TypeBRS3_CACB_S45_5 INTERACT M3_TypeBRS3_CACB_S45_12)) OR (M3_TypeBRS3_CACB_S45_5 WITH EDGE M3_TypeBRS3_CACB_S45_10_3)
  
  M3_TypeBRS3_CACB_BOXAC_1 = (EXPAND EDGE (M3i COIN EDGE M3_TypeBRS3_CACB_BOXB_waive) INSIDE BY 2*GRID) OR M3_TypeBRS3_CACB_BOXB_waive
  M3_TypeBRS3_CACB_BOXAC_2 = M3_TypeBRS3_CACB_S6_7 NOT INTERACT M3_TypeBRS3_CACB_BOXAC_1 
  M3_TypeBRS3_CACB_BOXAC_3 = M3_TypeBRS3_CACB_S3_9 COIN EDGE M3_TypeBRS3_CACB_BOXAC_2
  M3_TypeBRS3_CACB_BOXAC_4 = M3_TypeBRS3_CACB_S3_10 COIN EDGE M3_TypeBRS3_CACB_BOXAC_2
  M3_TypeBRS3_CACB_BOXAC_5_1 = EXPAND EDGE M3_TypeBRS3_CACB_BOXAC_3 OUTSIDE BY TypeBRS3_S3
  M3_TypeBRS3_CACB_BOXAC_5 = M3_TypeBRS3_CACB_BOXAC_5_1 WITH EDGE ((M3_TypeBRS3_CACB_BOXAC_5_1 AND M3i) COIN EDGE M3_TypeBRS3_CACB_BOXAC_5_1) == 4
  M3_TypeBRS3_CACB_BOXAC_6_1 = EXPAND EDGE M3_TypeBRS3_CACB_BOXAC_4 OUTSIDE BY TypeBRS3_S3-GRID
  M3_TypeBRS3_CACB_BOXAC_6 = M3_TypeBRS3_CACB_BOXAC_6_1 WITH EDGE ((M3_TypeBRS3_CACB_BOXAC_6_1 AND M3i) COIN EDGE M3_TypeBRS3_CACB_BOXAC_6_1) == 4
  M3_TypeBRS3_CACB_BOXAC_7 = ((M3_TypeBRS3_CACB_BOXAC_2 INTERACT M3_TypeBRS3_CACB_BOXAC_5) INTERACT M3_TypeBRS3_CACB_BOXAC_6) OR (M3_TypeBRS3_CACB_BOXAC_5 OR M3_TypeBRS3_CACB_BOXAC_6)
  M3_TypeBRS3_CACB_BOXAC_8 = (M3_TypeBRS3_CACB_BOXAC_7 AND M3i) COIN EDGE M3_TypeBRS3_CACB_BOXAC_7
  M3_TypeBRS3_CACB_BOXAC_9 = INT [M3_TypeBRS3_CACB_BOXAC_8] <= 4*TypeBRS3_S3+2*TypeBRS3_S6+2*GRID OPPOSITE
  M3_TypeBRS3_CACB_BOXAC_10 = ENCLOSE RECTANGLE (M3_TypeBRS3_CACB_BOXAC_7 WITH EDGE M3_TypeBRS3_CACB_BOXAC_9  == 4) TypeBRS3_S2 2*TypeBRS3_S3
  M3_TypeBRS3_CACB_BOXAC_11 = VERTEX (M3_TypeBRS3_CACB_BOXAC_10 AND M3i) != 4
  M3_TypeBRS3_CACB_BOXAC_12 = M3_TypeBRS3_CACB_BOXAC_10 NOT INTERACT M3_TypeBRS3_CACB_BOXAC_11
  M3_TypeBRS3_CACB_BOXC = M3_TypeBRS3_CACB_BOXAC_2 INSIDE M3_TypeBRS3_CACB_BOXAC_12
  M3_TypeBRS3_CACB_MARK = EXT (M3_TypeBRS3_CACB_BOXC AND M3i) <= Mx_S OPPOSITE REGION
  M3_TypeBRS3_CACB_MARK INTERACT EFPM3S7_M3i
}
