// UHVT_P.R.2 and UHVT_P.R.3 are checked by UHVT_P.W.1 and UHVT_P.S.1
UHVT_P.R.1 { @ Overlap of N+ACTIVE (including varactor GATE), VTH_P, VTH_N, VTL_N, VTL_P, VTUL_N, NT_N or OD2 is not allowed.   
  VTUHP AND VAR
  VTUHP AND OD2
  VTUHP AND NTN
