COR6_COCellOut = NOT INSIDE CELL COii ExclCellsForRRuleGuideline 
COR6_COCellIn2 = INSIDE CELL CO_VIRT CellsForRRuleGuideline  
COR6_COCellOut2 = NOT INSIDE CELL CO_VIRT ExclCellsForRRuleGuideline 
COR6_COCell = (COR6_COCellIn AND COR6_COCellOut) OR (COR6_COCellIn2 AND COR6_COCellOut2)
COR6_COMarker1 = COii AND RRuleGuideline
COR6_COMarker2 = CO_VIRT AND RRuleGuideline
COR6_COMarker = OR  COR6_COMarker1 COR6_COMarker2
COR6_CO = ((( COR6_COCell OR COR6_COMarker ) NOT INSIDE SRAM_EXCLUDE ) OUTSIDE Block) NOT excludeRRuleGuideline

RR:GL:CO.R.6 { @ Recommend using redundant CO to avoid high Rc wherever layout allows. 1. Recommended to use double CO or more on the resistor connection 2. For large transistor, if it is impossible to increase the CO to GATE spacing, limit the number of source/drain CO: have the number of CO necessary for the current, and then spread them all over the Source/Drain area. 3. DRC flags only one CO at {{M1 AND {PO NOT CPO}} OR {M1 AND OD}}   
  (((POLY NOT CPO) AND M1) INTERACT COR6_CO == 1) AND COR6_CO
  ((SD AND M1) INTERACT COR6_CO == 1) AND COR6_CO
  ((DSTP AND M1) INTERACT COR6_CO == 1) AND COR6_CO
}
#ENDIF
#ENDIF
// CO.R.6g is checked by RR:GL:CO.R.6

#ENDIF  //END Guideline
#ENDIF // EFP_ONLY








#IFDEF Recommended
#IFNDEF EFP_ONLY
#IFDEF FRONT_END


#IFDEF CHECK_POS50_
#IFDEF _POS50_
#ENDIF //_POS50_
#ENDIF //CHECK_POS50_

#IFDEF CHECK_RHPOR16_
#IFDEF _RHPOR16_
#ENDIF //_RHPOR16_
#ENDIF //CHECK_RHPOR16_

#ENDIF //FRONT_END
#ENDIF // EFP_ONLY
#ENDIF // Recommended







#IFDEF Recommended
#IFNDEF EFP_ONLY
#IFNDEF ESD_LUP_RULE_CHECK_ONLY
#IFDEF VOLTAGE_RULE_CHECK


#IFNDEF FULL_CHIP

RR:RE:DV.R.1 { @ Recommend to place voltage text layer or voltage marker layer in IP level. DRC flags no voltage text layer or voltage marker layer in GDS   
   
  CHIP NOT INTERACT VOLTAGE_TEXT_MARKER
}



#ENDIF 

#IFDEF FRONT_END

#IFDEF CHECK_POS50_
#IFDEF _POS50_
VARIABLE  PO_S_50_A_R_V 1.200
VARIABLE  PO_S_50_A_R 0.060

PO_S_50_A_R_EXCEPT = OR MFUSE RHPO OD2
PO_S_50_A_R_DUMMY = COPY SRDOD

RR:RE:PO.S.50.a { @ {PO NOT CPO} space to {OD OR SR_DOD} [maximum delta V >= 1.2V] (except RH_PO, MetalFuse (156;2), OD2) >= 0.06 

  err_1 = DFM DV ILP1i_edge ODc_edge < PO_S_50_A_R ABUT < 90  NOT CONNECTED MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" >= PO_S_50_A_R_V   ANNOTATE
  err_1_f =  DFM PROPERTY err_1 PO_S_50_A_R_EXCEPT OVERLAP ABUT ALSO MULTI
  [ -= COUNT(PO_S_50_A_R_EXCEPT) ] == 0
  [ FIRST_VMIN = property(err_1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_1, "SECOND_VMAX")]
  [ DELTA_V = property(err_1, "DELTA_V")]
  [ SYNC = property(err_1, "SYNC")]  
  DFM COPY err_1_f
  DFM RDB err_1_f "PO.S.50.a.R.rep" NOEMPTY NOPSEUDO
  err_dmy1 = DFM DV ILP1i_edge PO_S_50_A_R_DUMMY WITH DEFAULT VOLTAGES < PO_S_50_A_R ABUT < 90  MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" >= PO_S_50_A_R_V   ANNOTATE
  err_dmy1_f =  DFM PROPERTY err_dmy1 PO_S_50_A_R_EXCEPT OVERLAP ABUT ALSO MULTI
  [ -= COUNT(PO_S_50_A_R_EXCEPT) ] == 0
  [ FIRST_VMIN = property(err_dmy1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_dmy1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_dmy1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_dmy1, "SECOND_VMAX")]
  [ DELTA_V = property(err_dmy1, "DELTA_V")]
  [ SYNC = property(err_dmy1, "SYNC")]  
  DFM COPY err_dmy1_f
  DFM RDB err_dmy1_f "PO.S.50.a.R.rep" NOEMPTY NOPSEUDO

}
#ENDIF //_POS50_
#ENDIF //CHECK_POS50_

#IFDEF CHECK_RHPOR16_
#IFDEF _RHPOR16_
VARIABLE  RH_PO_R_16_A_R_V 1.200
VARIABLE  RH_PO_R_16_A_R 0.040
RH_PO_R_16_A_R_CHECK = COPY ODc_RHPO_edge
RH_PO_R_16_A_R_DUMMY = SRDOD INSIDE RHPO
RR:RE:RH_PO.R.16.a { @ {PO NOT CPO} space to {OD OR SR_DOD} [INSIDE RH_PO] [maximum delta V >= 1.2V] >= 0.04 
  err_1 = DFM DV ILP1i_edge RH_PO_R_16_A_R_CHECK < RH_PO_R_16_A_R ABUT < 90  NOT CONNECTED MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" >= RH_PO_R_16_A_R_V   ANNOTATE
  err_1_f =  DFM PROPERTY err_1 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_1, "SECOND_VMAX")]
  [ DELTA_V = property(err_1, "DELTA_V")]
  [ SYNC = property(err_1, "SYNC")]  
  DFM COPY err_1_f
  DFM RDB err_1_f "RH_PO.R.16.a.R.rep" NOEMPTY NOPSEUDO
  err_dmy1 = DFM DV ILP1i_edge RH_PO_R_16_A_R_DUMMY WITH DEFAULT VOLTAGES < RH_PO_R_16_A_R ABUT < 90  MEASURE ALL 
  DVPARAMS NET_PROP_LAYER "Volt_Low" 0.0 "Volt_High" 0.0 "sid" >= RH_PO_R_16_A_R_V   ANNOTATE
  err_dmy1_f =  DFM PROPERTY err_dmy1 EMPTYi OVERLAP ABUT ALSO MULTI
  [ -= COUNT(EMPTYi) ] == 0
  [ FIRST_VMIN = property(err_dmy1, "FIRST_VMIN")]
  [ FIRST_VMAX = property(err_dmy1, "FIRST_VMAX")]
  [ SECOND_VMIN = property(err_dmy1, "SECOND_VMIN")]
  [ SECOND_VMAX = property(err_dmy1, "SECOND_VMAX")]
  [ DELTA_V = property(err_dmy1, "DELTA_V")]
  [ SYNC = property(err_dmy1, "SYNC")]  
  DFM COPY err_dmy1_f
  DFM RDB err_dmy1_f "RH_PO.R.16.a.R.rep" NOEMPTY NOPSEUDO


}

#ENDIF //_RHPOR16_
#ENDIF //CHECK_RHPOR16_

#ENDIF //FRONT_END
#ENDIF // VOLTAGE_RULE_CHECK
#ENDIF // ESD_LUP_RULE_CHECK_ONLY
#ENDIF // EFP_ONLY
#ENDIF // Recommended





#ENDIF //DFM
#ENDIF // ESD_LUP_RULE_CHECK_ONLY
#ENDIF // VOLTAGE_RULE_CHECK_ONLY







#DECRYPT %;@~8R&F1B,7(TIR3Z))LMAS>R`$6O;_UUA"<W4N)4Y.6JU!#=)I@/1SF:$4:$),_G&S]-Q!!"
