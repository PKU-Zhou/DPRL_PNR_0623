// MOM.A.0 is checked by [MOM.A.1.1 ~ MOM.A.1.5]



MOM.A.1.1 { @ Maximum sidewall area of total M1/Mx metals in MOM without Via [0V <= maximum delta V <= 1.8V] <= 2.29E+09 
    MOM_SA = DFM PROPERTY CHIP_MOM MOM_M1_CAP_EDGE_V1 MOM_M2_CAP_EDGE_V1 MOM_M3_CAP_EDGE_V1 MOM_M4_CAP_EDGE_V1 MOM_M5_CAP_EDGE_V1 MOM_M6_CAP_EDGE_V1 MOM_M7_CAP_EDGE_V1 OVERLAP
  [
     Sidewall_Area = ( LENGTH(MOM_M1_CAP_EDGE_V1)*0.0825+ LENGTH(MOM_M2_CAP_EDGE_V1)*0.0825+ LENGTH(MOM_M3_CAP_EDGE_V1)*0.0825+ LENGTH(MOM_M4_CAP_EDGE_V1)*0.0825+ LENGTH(MOM_M5_CAP_EDGE_V1)*0.0825+ LENGTH(MOM_M6_CAP_EDGE_V1)*0.0825+ LENGTH(MOM_M7_CAP_EDGE_V1)*0.0825 )/2
  ] > MOM_A_1_1
  MERGE MOM_SA 
  DFM RDB MOM_SA MOM.A.1.1.rep NOEMPTY NOPSEUDO 
}
MOM.A.1.2 { @ Maximum sidewall area of total M1/Mx metals in MOM without Via [1.8V < maximum delta V <= 2.5V] <= 1.00E+07 
    MOM_SA = DFM PROPERTY CHIP_MOM MOM_M1_CAP_EDGE_V2 MOM_M2_CAP_EDGE_V2 MOM_M3_CAP_EDGE_V2 MOM_M4_CAP_EDGE_V2 MOM_M5_CAP_EDGE_V2 MOM_M6_CAP_EDGE_V2 MOM_M7_CAP_EDGE_V2 OVERLAP
  [
     Sidewall_Area = ( LENGTH(MOM_M1_CAP_EDGE_V2)*0.0825+ LENGTH(MOM_M2_CAP_EDGE_V2)*0.0825+ LENGTH(MOM_M3_CAP_EDGE_V2)*0.0825+ LENGTH(MOM_M4_CAP_EDGE_V2)*0.0825+ LENGTH(MOM_M5_CAP_EDGE_V2)*0.0825+ LENGTH(MOM_M6_CAP_EDGE_V2)*0.0825+ LENGTH(MOM_M7_CAP_EDGE_V2)*0.0825 )/2
  ] > MOM_A_1_2
  MERGE MOM_SA 
  DFM RDB MOM_SA MOM.A.1.2.rep NOEMPTY NOPSEUDO 
}
MOM.A.1.3 { @ Maximum sidewall area of total M1/Mx metals in MOM without Via [2.5V < maximum delta V <= 3.3V] <= 1.00E+07 
    MOM_SA = DFM PROPERTY CHIP_MOM MOM_M1_CAP_EDGE_V3 MOM_M2_CAP_EDGE_V3 MOM_M3_CAP_EDGE_V3 MOM_M4_CAP_EDGE_V3 MOM_M5_CAP_EDGE_V3 MOM_M6_CAP_EDGE_V3 MOM_M7_CAP_EDGE_V3 OVERLAP
  [
     Sidewall_Area = ( LENGTH(MOM_M1_CAP_EDGE_V3)*0.0825+ LENGTH(MOM_M2_CAP_EDGE_V3)*0.0825+ LENGTH(MOM_M3_CAP_EDGE_V3)*0.0825+ LENGTH(MOM_M4_CAP_EDGE_V3)*0.0825+ LENGTH(MOM_M5_CAP_EDGE_V3)*0.0825+ LENGTH(MOM_M6_CAP_EDGE_V3)*0.0825+ LENGTH(MOM_M7_CAP_EDGE_V3)*0.0825 )/2
  ] > MOM_A_1_3
  MERGE MOM_SA 
  DFM RDB MOM_SA MOM.A.1.3.rep NOEMPTY NOPSEUDO 
}
MOM.A.1.4 { @ Maximum sidewall area of total M1/Mx metals in MOM without Via [3.3V < maximum delta V <= 5.5V] <= 1.31E+06 
    MOM_SA = DFM PROPERTY CHIP_MOM MOM_M1_CAP_EDGE_V4 MOM_M2_CAP_EDGE_V4 MOM_M3_CAP_EDGE_V4 MOM_M4_CAP_EDGE_V4 MOM_M5_CAP_EDGE_V4 MOM_M6_CAP_EDGE_V4 MOM_M7_CAP_EDGE_V4 OVERLAP
  [
     Sidewall_Area = ( LENGTH(MOM_M1_CAP_EDGE_V4)*0.0825+ LENGTH(MOM_M2_CAP_EDGE_V4)*0.0825+ LENGTH(MOM_M3_CAP_EDGE_V4)*0.0825+ LENGTH(MOM_M4_CAP_EDGE_V4)*0.0825+ LENGTH(MOM_M5_CAP_EDGE_V4)*0.0825+ LENGTH(MOM_M6_CAP_EDGE_V4)*0.0825+ LENGTH(MOM_M7_CAP_EDGE_V4)*0.0825 )/2
  ] > MOM_A_1_4
  MERGE MOM_SA 
  DFM RDB MOM_SA MOM.A.1.4.rep NOEMPTY NOPSEUDO 
}
MOM.A.1.5 { @ Maximum sidewall area of total M1/Mx metals in MOM without Via [5.5V < maximum delta V <= 6.5V] <= 1.31E+06 
    MOM_SA = DFM PROPERTY CHIP_MOM MOM_M1_CAP_EDGE_V5 MOM_M2_CAP_EDGE_V5 MOM_M3_CAP_EDGE_V5 MOM_M4_CAP_EDGE_V5 MOM_M5_CAP_EDGE_V5 MOM_M6_CAP_EDGE_V5 MOM_M7_CAP_EDGE_V5 OVERLAP
  [
     Sidewall_Area = ( LENGTH(MOM_M1_CAP_EDGE_V5)*0.0825+ LENGTH(MOM_M2_CAP_EDGE_V5)*0.0825+ LENGTH(MOM_M3_CAP_EDGE_V5)*0.0825+ LENGTH(MOM_M4_CAP_EDGE_V5)*0.0825+ LENGTH(MOM_M5_CAP_EDGE_V5)*0.0825+ LENGTH(MOM_M6_CAP_EDGE_V5)*0.0825+ LENGTH(MOM_M7_CAP_EDGE_V5)*0.0825 )/2
  ] > MOM_A_1_5
  MERGE MOM_SA 
  DFM RDB MOM_SA MOM.A.1.5.rep NOEMPTY NOPSEUDO 
}






