   (OD INTERACT GATE_HVDN25_65) INTERACT (GATE NOT INTERACT HVN25_65) 
}



//============================================
// HVP25_65 Rules CHECKS 
//============================================
HVP25_65.L.1 { @ Channel length of {GATE INTERACT HVP25_65} (except HVD65_55) = 0.65 ~ 1.2 
   (LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDP25_65) < HVP25_65_L_1_A) NOT INSIDE EDGE HVD65_55         
   (LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDP25_65) > HVP25_65_L_1_B) NOT INSIDE EDGE HVD65_55         
}
HVP25_65.W.1 { @ Width >= 1.06 
   INT HVP25_65 < HVP25_65_W_1 ABUT < 90 SINGULAR REGION
}
HVP25_65.W.2 { @ Channel width of {GATE INTERACT HVP25_65} = 1 ~ 4 
   LENGTH (GATE_W TOUCH INSIDE EDGE GATE_HVDP25_65) < HVP25_65_W_2_A 
   LENGTH (GATE_W TOUCH INSIDE EDGE GATE_HVDP25_65) > HVP25_65_W_2_B 
}
HVP25_65.W.3 { @ Width of {SR_DPO INTERACT HVP25_65} = 0.12 
   NOT WITH WIDTH SRDPO_HVDP25_65 == HVP25_65_W_3 
}
HVP25_65.S.1 { @ Space (except HVD65_55) >= 1.18 
   (EXT HVP25_65 < HVP25_65_S_1 ABUT < 90 SINGULAR REGION) NOT INSIDE HVD65_55
}



HVP25_65.S.4 { @ Space to NW STRAP (overlap is not allowed) >= ^HVP25_65_S_4
   EXT HVP25_65 NSTP < HVP25_65_S_4 ABUT < 90 SINGULAR REGION
   HVP25_65 AND NSTP    
}
HVP25_65.S.5 { @ Space to P+ ACTIVE >= ^HVP25_65_S_5
   EXT HVP25_65 PACT < HVP25_65_S_5 ABUT < 90 SINGULAR REGION
}
HVP25_65.S.8 { @ {GATE edge INSIDE HVP25_65} space to {SR_DPO INTERACT HVP25_65} in drain direction = 0.16
   EXT (GATE_W_HVDP25_65) SRDPO_HVDP25_65 == HVP25_65_S_8 ABUT < 90 OPPOSITE
}
HVP25_65.S.10__HVP25_65.S.13 { @ {CO INSIDE {OD AND HVP25_65}} space to {PO INTERACT HVP25_65} = ^HVP25_65_S_10
                               @ Maximum CO space in Drain of HVNMOS Definition of CO in Drain of HVNMOS: {CO INSIDE {OD AND HVP25_65}} <= ^HVP25_65_S_13
   A = COOD INSIDE HVP25_65
   B = EXT GATE_W_HVDP25_65 [A] == HVP25_65_S_10 ABUT < 90 OPPOSITE
   C = INT B <= CO_W_1 OPPOSITE REGION 
   A XOR C
   D = A NOT COIN INSIDE EDGE B
   E = EXT [D] <= HVP25_65_S_13 ABUT < 90 OPPOSITE
   F = ENC [D] OD_HVDP25_65 <= HVP25_65_S_13 ABUT < 90 OPPOSITE
   (D NOT COIN INSIDE EDGE E) NOT COIN INSIDE EDGE F
}
HVP25_65.S.11 { @ {CO INSIDE {PO INTERACT HVP25_65}} space to {{OD INTERACT HVP25_65} AND PP} >= 0.34 
   A = COPO INSIDE PO_HVDP25_65
   EXT A OD_HVDPP25_65 < HVP25_65_S_11 ABUT < 90 SINGULAR REGION
}
HVP25_65.S.12 { @ {PO OR OD} space to {OD AND HVP25_65} in PO end-cap direction >= ^HVP25_65_S_12   
   A = OD AND HVP25_65
   B = A COIN EDGE OD_HVDP25_65 
   EXT B POLY < HVP25_65_S_12 ABUT < 90 REGION
   EXT B OD < HVP25_65_S_12 ABUT < 90 REGION
}
HVP25_65.S.14 { @ GATE space in drain direction for a multi-finger HVNMOS device. DRC check: {{Space of {GATE INTERACT HVP25_65}} INSIDE HVP25_65} on one OD = ^HVP25_65_S_14
   S2 = HVPMOS25_65_DRAIN INTERACT GATE_HVDP25_65 == 2
   S3 = GATE_HVDP25_65 COIN OUTSIDE EDGE S2
   EXT (S3) == HVP25_65_S_14 ABUT < 90 OPPOSITE 
}
HVP25_65.S.15 { @ GATE space in source direction for multi-finger HVNMOS devices on one OD	>= 0.18
   S2 = HVPMOS25_65_SOURCE INTERACT GATE_HVDP25_65 == 2
   S3 = GATE_HVDP25_65 COIN OUTSIDE EDGE S2
   EXT [S3] < HVP25_65_S_15 ABUT < 90 OPPOSITE
}
HVP25_65.S.16 { @ Space to  {SR_DOD OR DOD} (overlap is not allowed) >= ^HVP25_65_S_16
   A = SRDOD OR DOD 
   EXT HVP25_65 A < HVP25_65_S_16 ABUT < 90 SINGULAR REGION
   HVP25_65 AND A    
}

