}
HVP25_65.EN.2 { @ Enclosure by DNW >= ^HVP25_65_EN_2
   ENC HVP25_65 DNW < HVP25_65_EN_2 ABUT < 90 SINGULAR REGION
}
HVP25_65.EX.1 { @ Extension on P+ ACTIVE (Drian side must be fully inside HVP25_65) = ^HVP25_65_EX_1
   ENC PACT HVP25_65 < HVP25_65_EX_1 ABUT < 90 SINGULAR REGION
   ((HVP25_65 INTERACT PACT) NOT PACT) WITH WIDTH > HVP25_65_EX_1      
   HVPMOS25_65_DRAIN NOT HVP25_65     
}
HVP25_65.EX.2 { @ OD extension on {PO INTERACT HVP25_65} >= ^HVP25_65_EX_2
   ENC PO_HVDP25_65 OD_HVDP25_65 < HVP25_65_EX_2 ABUT < 90 OPPOSITE REGION 
}
HVP25_65.O.1 { @ Overlap of {I/O NMOS GATE} = ^HVP25_65_O_1
   A = EXPAND EDGE GATE_W_HVDP25_65 INSIDE BY HVP25_65_O_1
   B = HVP25_65 AND GATE_HVDP25_65
   A XOR B
}
HVP25_65.A.1 { @ Area >= ^HVP25_65_A_1
   AREA HVP25_65 < HVP25_65_A_1
}
HVP25_65.A.2 { @ Enclosed area >= ^HVP25_65_A_2
   A = HOLES HVP25_65 INNER
   B = A NOT HVP25_65
   AREA B < HVP25_65_A_2
}
HVP25_65.R.1 { @ HVP25_65 edge landing on OD without landing on GATE is not allowed
   (HVP25_65 INSIDE EDGE OD_HVDP25_65) NOT INSIDE EDGE GATE_HVDP25_65
}
HVP25_65.R.2 { @ HVP25_65 must be fully inside OD_25
   HVP25_65 NOT OD25
}
HVP25_65.R.3 { @ HV NMOS with 2 fingers GATE and common HV drain as a unit is must.
   A = ILP1i AND GATE_HVDP25_65
   HVP25_65 INTERACT A > 1 BY NET
   HVPMOS25_65_DRAIN INTERACT GATE_HVDP25_65 == 1
   C = PSDc INTERACT HVPMOS25_65_SOURCE
   D = GATE_HVDP25_65 OR HVPMOS25_65_DRAIN
   D INTERACT C > 1 BY NET
}
HVP25_65.R.4 { @ The finger number, Nf, should be even numbers. Nf means the finger number of the GATE on one OD
   DFM PROPERTY OD_HVDP25_65 GATE_HVDP25_65 OVERLAP MULTI 
   [-= FMOD(COUNT(GATE_HVDP25_65),2)] == 1    
}
HVP25_65.R.5 { @ {(HVP25_65 INTERACT OD) AND PO} must be a rectangle. A concave {(HVP25_65 INTERACT OD) AND PO} is not allowed
   A = (HVP25_65 INTERACT OD) AND POLY
   NOT RECTANGLE A ORTHOGONAL ONLY    
}
HVP25_65.R.6 { @ {{OD OR PO} INTERACT HVP25_65} overlap of VAR, NT_N, TCDDMY. {OD INTERACT NWDMY}, SRM, ROM, BJTDMY. RH_OD, RH_PO, VTL_N, VTL_P, VTUL_N, VTUL_P, VTH_N, VTH_P, UHVT_N, UHVT_P, EHVT_N, EHVT_P, OD_18, OD25_33, OD25_18, OD18_15, or OD18_12 is not allowed   
   A = OD_HVDP25_65 OR PO_HVDP25_65
   A AND VAR
   A AND NTN
   A AND TCDDMY
   A AND (OD INTERACT NWDMY)
   A AND SRM
   A AND ROM
   A AND BJTDMY
   A AND RHOD
   A AND RHPO
   A AND VTLN 
   A AND VTLP 
   A AND VTULN 
   A AND VTULP
   A AND VTHN 
   A AND VTHP
   A AND VTUHN 
   A AND VTUHP
   A AND EHVT_N
   A AND EHVT_P
   A AND OD18
   A AND OD2533
   A AND OD2518
   A AND OD1815
   A AND OD1812
}
HVP25_65.R.7 { @ HVP25_65 must be inside {NW AND DNW} 
   HVP25_65 NOT NWEL
   HVP25_65 NOT DNW
}
HVP25_65.R.8 { @ {{OD INTERACT {GATE INTERACT HVP25_65}} INTERACT {GATE NOT INTERACT HVP25_65}} is not allowed	
   (OD INTERACT GATE_HVDP25_65) INTERACT (GATE NOT INTERACT HVP25_65) 
}


#ENDIF
//============================================
// HVD65_55 Rules CHECKS 
//============================================
HVDN_HVD65_55 = HVN_65 INTERACT HVD65_55
HVDP_HVD65_55 = HVP_65 INTERACT HVD65_55
HVDN25_65_HVD65_55 = HVN25_65 INTERACT HVD65_55
HVDP25_65_HVD65_55 = HVP25_65 INTERACT HVD65_55
HVD65_55.L.1 { @ Channel length of 6.5V HV NMOS underdrive to 5.5V {{GATE INTERACT HVN_65} AND HVD65_55} = HVD65_55_L_1
   GATE_HVDN_HVD65_55 = GATE_HVDN AND HVD65_55
   NOT LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDN_HVD65_55) == HVD65_55_L_1  
}
HVD65_55.L.2 { @ Channel length of 6.5V HV PMOS underdrive to 5.5V {{GATE INTERACT HVP_65} AND HVD65_55} = HVD65_55_L_2
   GATE_HVDP_HVD65_55 = GATE_HVDP AND HVD65_55
   NOT LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDP_HVD65_55) == HVD65_55_L_2  
}
#IFDEF N22_ULL
HVD65_55.L.3 { @ Channel length of 6.5V HV NMOS underdrive to 5.5V {{GATE INTERACT HVN25_65} AND HVD65_55} = HVD65_55_L_3
   GATE_HVDN25_65_HVD65_55 = GATE_HVDN25_65 AND HVD65_55
   LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDN25_65_HVD65_55) < HVD65_55_L_3_A 
   LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDN25_65_HVD65_55) > HVD65_55_L_3_B 
}
HVD65_55.L.4 { @ Channel length of 6.5V HV PMOS underdrive to 5.5V {{GATE INTERACT HVP25_65} AND HVD65_55} = HVD65_55_L_4
   GATE_HVDP25_65_HVD65_55 = GATE_HVDP25_65 AND HVD65_55
   LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDP25_65_HVD65_55) < HVD65_55_L_4_A 
   LENGTH (GATE_L TOUCH INSIDE EDGE GATE_HVDP25_65_HVD65_55) > HVD65_55_L_4_B 
}
#ENDIF
HVD65_55.S.1 { @ Space of {HVN_65 INTERACT HVD65_55} >= HVD65_55_S_1 
   EXT HVDN_HVD65_55 < HVD65_55_S_1 ABUT < 90 SINGULAR REGION
}
HVD65_55.S.2 { @ Space of {HVP_65 INTERACT HVD65_55} >= HVD65_55_S_2 
   EXT HVDP_HVD65_55 < HVD65_55_S_2 ABUT < 90 SINGULAR REGION
}
#IFDEF N22_ULL
HVD65_55.S.3 { @ Space of {HVN25_65 INTERACT HVD65_55} >= HVD65_55_S_3 
   EXT HVDN25_65_HVD65_55 < HVD65_55_S_3 ABUT < 90 SINGULAR REGION
}
HVD65_55.S.4 { @ Space of {HVP25_65 INTERACT HVD65_55} >= HVD65_55_S_4 
   EXT HVDP25_65_HVD65_55 < HVD65_55_S_4 ABUT < 90 SINGULAR REGION
}
#ENDIF
HVD65_55.R.1 { @ GATE cut HVD65_55 is not allowed
   GATE CUT HVD65_55
}
HVD65_55.R.2 { @ {{{{HVN_65 OR HVP_65} OR HVN25_65} OR HVP25_65} INTERACT HVD65_55} must be inside HVD65_55 (cut is not allowed)   
   HVDN_HVD65_55 NOT HVD65_55
   HVDP_HVD65_55 NOT HVD65_55
   HVDN25_65_HVD65_55 NOT HVD65_55
   HVDP25_65_HVD65_55 NOT HVD65_55
   HVDN_HVD65_55 CUT HVD65_55
   HVDP_HVD65_55 CUT HVD65_55
   HVDN25_65_HVD65_55 CUT HVD65_55
   HVDP25_65_HVD65_55 CUT HVD65_55
}

#ENDIF // ESD_LUP_RULE_CHECK
#IFNDEF ESD_LUP_RULE_CHECK_ONLY


// Analog Checks
//==============
  COLLECT_OD_REGION = COLLECT_OD OR (HOLES COLLECT_OD)
  CHECK_REGION_COLLECT = BJTDMY NOT COLLECT_OD_REGION
  BASE_OD_REGION = BASE_OD OR (HOLES BASE_OD)
  CHECK_REGION_BASE = (HOLES COLLECT_OD) NOT BASE_OD_REGION

BJT.W.1 { @ Width of SR_DPO between BJTDMY edge and Collector OD = 0.5~0.8 
  A = LENGTH (SRDPO INTERACT CHECK_REGION_COLLECT) >= BJT_W_1A <= BJT_W_1B
  (SRDPO INTERACT CHECK_REGION_COLLECT) NOT WITH EDGE A
}
BJT.W.2 { @ Width of SR_DPO between Base OD and Collector OD = 0.15 
  A = LENGTH (SRDPO INTERACT CHECK_REGION_BASE) == BJT_W_2
  (SRDPO INTERACT CHECK_REGION_BASE) NOT WITH EDGE A
}

BJT.S.1 { @ Space of SR_DPO to Collector OD [OUTSIDE Collector OD] = 0.1~0.25 
  EXT COLLECT_OD_REGION SRDPO < BJT_S_1A ABUT < 90 SINGULAR REGION  
  (SRDPO INTERACT CHECK_REGION_COLLECT) NOT INTERACT (SIZE COLLECT_OD_REGION BY BJT_S_1B)
}



BJT.S.2 { @ Space of SR_DPO to Base OD between Base OD and Collector OD = 0.035 
      A = EXT [BASE_OD_REGION] SRDPO == BJT_S_2 ABUT < 90
      BASE_OD_REGION NOT TOUCH EDGE A    
    }
    
BJT.S.3 { @ Space of Collect OD to Base OD = 0.22 
      A = EXT [BASE_OD_REGION] COLLECT_OD == BJT_S_3 ABUT < 90
      BASE_OD_REGION NOT COIN EDGE A    
    }
    
BJT.S.4 { @ Space of Base OD to RPO edge [on STI] = 0.22 
      RPO_EMOD = RPO INTERACT EMOD  
      A = EXT BASE_OD [RPO_EMOD] == BJT_S_4 ABUT < 90
      (RPO_EMOD OUTSIDE EDGE OD) NOT COIN EDGE A
    }

BJT.L.1 { @ Length of SR_DPO in BJTDMY region >= 1 
  DPO_BJTDMY = SRDPO AND BJTDMY
  DPO_BJTDMY NOT WITH EDGE (LENGTH DPO_BJTDMY >= BJT_L_1)    
}



BJT.R.1 { @ RPO needs to cover 0.3 um on the Emitter OD edge for both OD and STI sides, i.e. RPO = ((Emitter OD SIZING 0.3 um) NOT (Emitter OD SIZING -0.3 um)) = 0.6 
  X = ( SIZE EMOD BY BJT_R_1 ) NOT ( SIZE EMOD BY -BJT_R_1 )
  Y = RPO INTERACT EMOD
  X XOR Y
}

BJT.R.2 { @ BJTDMY enclosure of Collector OD >= 1 
  ENC COLLECT_OD_REGION BJTDMY < BJT_R_2 ABUT < 90 SINGULAR REGION  
}
BJT.R.4 { @ BJTDMY overlap of NT_N, PO, VTH_N, VTH_P, VTL_N, VTL_P, VTUL_N, VTUL_P, UHVT_N, UHVT_P, EHVT_N, EHVT_P, VAR, and SRM is not recommended   
  BJTDMY AND NTN
  BJTDMY AND POLY
  BJTDMY AND VTLN
  BJTDMY AND VTLP
  BJTDMY AND VTULN
  BJTDMY AND VTULP
  BJTDMY AND VTHN
  BJTDMY AND VTHP
  BJTDMY AND VTUHN
  BJTDMY AND VTUHP  
  BJTDMY AND VTLNIO
  BJTDMY AND VAR
  BJTDMY AND SRM
  BJTDMY AND EHVT_N
  BJTDMY AND EHVT_P
}

#IFDEF GUIDELINE_ANALOG






ANA_POCellIn = INSIDE CELL POi CellsForRRuleAnalog  
ANA_POCellOut = NOT INSIDE CELL POi ExclCellsForRRuleAnalog 
ANA_POCell = ANA_POCellIn AND ANA_POCellOut
ANA_POMarker = POi AND RRuleAnalog
ANA_PO = ((( ANA_POCell OR ANA_POMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleAnalog

ANA_PORES = ANA_PO AND PORES_US

AN.R.17mg { @ Place high R resistor on an N-well for better noise immunity   
  ANA_PORES NOT NWEL
  ANA_PORES NOT PP
}

ANR20mg_VARCellIn = INSIDE CELL VARi CellsForRRuleAnalog  
ANR20mg_VARCellOut = NOT INSIDE CELL VARi ExclCellsForRRuleAnalog 
ANR20mg_VARCell = ANR20mg_VARCellIn AND ANR20mg_VARCellOut
ANR20mg_VARMarker = VARi AND RRuleAnalog
ANR20mg_VAR = ((( ANR20mg_VARCell OR ANR20mg_VARMarker ) NOT SRAM_EXCLUDE ) OUTSIDE Block ) NOT excludeRRuleAnalog

ANR20mg_VAROD = ANR20mg_VAR AND OD
AN.R.20mg { @ Use thick oxide (OD2) MOS varactor and capacitor to reduce gate oxide leakage. DRC can't check capacitor   
  ANR20mg_VAROD NOT OD2
}

//AN.R.77.0mg is checked by AN.R.77.2mg, AN.R.77.3mg
ANA_PORES_W = ANA_PORES INSIDE EDGE POLY
ANA_PORES_L = ANA_PORES NOT INSIDE EDGE POLY
AN.R.77.2mg {@ Add {SR_DPO AND RPO} to surround high R resistor as shown in figure 8.3.2.4.3. The width of {SR_DPO AND RPO} should be identical to the width of high R resistor. DRC flag {PO SIZING 1.2 um} NOT INTERACT {SR_DPO AND RPO} or the width of {SR_DPO AND RPO} is not identical to the width of high R resistor   
	 A = ANA_PO INTERACT ANA_PORES
	 B = (RPO NOT (OR SRDPO ANA_PORES)) INTERACT ANA_PO == 2
	 C = ((EXPAND EDGE (A NOT TOUCH EDGE ANA_PORES_L) OUTSIDE BY AN_R_77_3mg/2) NOT A) INTERACT A == 2
	 PO_NCHK = (A INTERACT B == 2) INTERACT C == 2
     A1 = (EXPAND EDGE (((A NOT PO_NCHK) TOUCH EDGE ANA_PORES_L) NOT TOUCH EDGE B) OUTSIDE BY 1.2) NOT INTERACT B
	 SRDPO_RPO = SRDPO AND RPO
	 A_SRDPO = SRDPO_RPO INTERACT A1
	 A2_pre = A_SRDPO COIN EDGE RPO 
     A2 =  CONVEX EDGE A2_pre ANGLE1 >=0 ANGLE2 ==0
	 L_SRDPO = DFM PROPERTY A2 A1 OVERLAP ABUT ALSO [W = LENGTH(A2)]
	 A3 = ANA_PORES INTERACT A1
	 A4 = A3 COIN EDGE ANA_PORES_W
	 L_ANAPO = DFM PROPERTY A4 A3 ANA_PORES_W OVERLAP ABUT ALSO [W = LENGTH(A4)]
	 HR_TERM =  ((RPO INTERACT SRDPO) NOT (OR SRDPO PORES)) INTERACT PORES == 1
	 SRDPO_TERM = SRDPO_RPO INTERACT HR_TERM  ==1
     UNI_TERM = OR ( (OR SRDPO_RPO PORES ) INTERACT HR_TERM ) HR_TERM
     CHK_TERM = HR_TERM SIZE BY GRID //SIZE GRID TO UNITE LAST TERM
	 W_ERR = DFM PROPERTY CHK_TERM L_SRDPO A2 A4 L_ANAPO OVERLAP ABUT ALSO MULTI [ WERR2 = property(L_SRDPO,"W")-property(L_ANAPO,"W")] !=0
	 SRDPO INTERACT W_ERR 
	 ANA_PO INTERACT W_ERR 
	 DFM RDB W_ERR WERR.rep NOEMPTY
   	 DFM RDB L_SRDPO L_SRDPO.rep NOEMPTY
   	 DFM RDB L_ANAPO L_ANAPO.rep NOEMPTY
     A1_V = (EXPAND EDGE (((A NOT PO_NCHK) NOT TOUCH EDGE ANA_PORES_L) NOT TOUCH EDGE C) OUTSIDE BY 1.2) NOT INTERACT C
	 A2_V = (SRDPO INTERACT RPO) TOUCH EDGE (A1_V NOT SRDPO)
	 L_SRDPO_V = DFM PROPERTY A1_V A2_V OVERLAP ABUT ALSO [W = LENGTH(A2_V)]
	 ANA_PO_W = A TOUCH EDGE A1_V
	 L_ANAPO_V = DFM PROPERTY ANA_PO_W [W = LENGTH(ANA_PO_W)]
	 DFM PROPERTY A1_V L_SRDPO_V L_ANAPO_V OVERLAP ABUT ALSO MULTI [- = property(L_SRDPO_V,"W")-property(L_ANAPO_V,"W")] !=0
	 
}

AN.R.77.3mg {@ Recommend the length of SR_DPO surrounding the high R resistor in the length direction (Fig. 8.3.2.4.3) DRC flag no SR_DPO INTERACT {PO GROW TOP/BOTTOM by 1.2 um} >= 1.2 ##
   A = ANA_PO INTERACT ANA_PORES
   B = SRDPO INTERACT (SIZE A BY AN_R_77_3mg)
   C = A OR B
   D = INT (C) < AN_R_77_3mg OPPOSITE EXCLUDE SHIELDED 4
   E = A NOT TOUCH INSIDE EDGE ANA_PORES_L
   EXT D (E) <= AN_R_77_3mg OPPOSITE EXCLUDE SHIELDED 4
}




#ENDIF
AN.WARN.1 { @ In order to have better matching accuracy for high R resistor, recommend 2 matching of high R resistor must be same at I/O region or same at core region. DRC only flags {{CHIP INTERACT core_HiR} INTERACT IO_HiR} IO_HiR: RH_PO insdie OD2 Core_HiR: RH_PO outside OD2   
	IO_HiR = RHPO INSIDE OD2
	Core_HiR = RHPO OUTSIDE OD2
	(CHIPx INTERACT Core_HiR) INTERACT IO_HiR

}
//AN.R.78.0m is checked by AN.R.78.1m 
AN.R.78.1m {@ Width of STRAP <= 0.5 
  WITH WIDTH (DSTP AND MATCHING_ARRAY) > AN_R_78_1m
}
VARIABLE AN_H_A_2m_20000 20000
AN_H.A.2m { @ Maximum area of ANARRAY_H <= 20000 
    AREA ANARRAY_H > AN_H_A_2m_20000
}
//AN.R.79.0m is checked by AN.R.79.2m, AN.R.79.4m, AN_H.A.2m, AN.R.79.5m

AN.R.79.2m {@ For within 6 um surrounding range around ANARRAY_H, OD and PO density difference between surrounding and MOS array <= 10% 
	ANARRAY_H_outer = (SIZE ANARRAY_H BY AN_R_79_2m_S) NOT ANARRAY_H
    ANARRAY_H_inner = ANARRAY_H NOT (SIZE ANARRAY_H BY -AN_R_79_2m_S)
    ANARRAY_H_outerP = DFM PROPERTY ANARRAY_H_outer ALL_OD ALL_POLY [den_od = AREA(ALL_OD)/AREA(ANARRAY_H_outer)] [den_po = AREA(ALL_POLY)/AREA(ANARRAY_H_outer)]
    ANARRAY_H_innerP = DFM PROPERTY ANARRAY_H_inner ALL_OD ALL_POLY [den_od = AREA(ALL_OD)/AREA(ANARRAY_H_inner)] [den_po = AREA(ALL_POLY)/AREA(ANARRAY_H_inner)]
    ANARRAY_H_OD_err = DFM PROPERTY ANARRAY_H_innerP ANARRAY_H_outerP OVERLAP ABUT ALSO MULTI
    [OD_DN_outer = PROPERTY(ANARRAY_H_outerP,"den_od")]
    [OD_DN_inner = PROPERTY(ANARRAY_H_innerP,"den_od")]
    [OD_DN_diff  = ABS(PROPERTY(ANARRAY_H_outerP,"den_od")-PROPERTY(ANARRAY_H_innerP,"den_od")) ] > AN_R_79_2m
    ANARRAY_H_PO_err = DFM PROPERTY ANARRAY_H_innerP ANARRAY_H_outerP OVERLAP ABUT ALSO MULTI
    [PO_DN_outer = PROPERTY(ANARRAY_H_outerP,"den_po")]
    [PO_DN_inner = PROPERTY(ANARRAY_H_innerP,"den_po")]
    [PO_DN_diff  = ABS(PROPERTY(ANARRAY_H_outerP,"den_po")-PROPERTY(ANARRAY_H_innerP,"den_po")) ] > AN_R_79_2m    
    COPY ANARRAY_H_OD_err
    COPY ANARRAY_H_PO_err
    DFM RDB ANARRAY_H_OD_err "AN.R.79.2m.rep" NOEMPTY
    DFM RDB ANARRAY_H_PO_err "AN.R.79.2m.rep" NOEMPTY
}
VARIABLE AN_R_79_2_1m_6 6
VARIABLE AN_R_79_2_1m_1 1
AN.R.79.2.1m { @ Empty space of {{OD OR SR_DOD} OR DOD} inside {ANARRAY_H SIZING 6 um} DRC flag: {{{ANARRAY_H SIZING 6 um} NOT {{{OD OR SR_DOD} OR DOD} SIZING up/down 1 um}} SIZING down/up 1 um} <= 2 
  SIZE ((SIZE ANARRAY_H BY AN_R_79_2_1m_6) NOT (SIZE ALL_OD BY AN_R_79_2_1m_1 OVERUNDER)) BY AN_R_79_2_1m_1 UNDEROVER
}

VARIABLE AN_R_79_2_2m_6 6
VARIABLE AN_R_79_2_2m_1 1
AN.R.79.2.2m { @ Empty space of {{{PO OR SR_DPO} NOT CPO} OR DPO} inside {ANARRAY_H SIZING 6 um} DRC flag: {{{ANARRAY_H SIZING 6 um} NOT {{{{PO OR SR_DPO} NOT CPO} OR DPO} SIZING up/down 1 um}} SIZING down/up 1 um} <= 2 
  SIZE ((SIZE ANARRAY_H BY AN_R_79_2_2m_6) NOT (SIZE ALL_POLY BY AN_R_79_2_2m_1 OVERUNDER)) BY AN_R_79_2_2m_1 UNDEROVER
}




AN.R.79.4m { @ In order to reduce the current mismatch of MOS array, recommend to follow one of the following conditions: 1. ANARRAY_H space to AP (CUT is not recommended) >= 3 um, or 2. ANARRAY_H enclosure by AP >= 3 um Warning: When violated AN.R.79.4m, > 2X current mean shift will be occurred by comparing with 1-sigma of device mismatch within a MOS array   
  EXT ANARRAY_H AP < AN_R_79_4m ABUT < 90 SINGULAR REGION 
  ENC ANARRAY_H AP < AN_R_79_4m ABUT < 90 SINGULAR REGION 
  ANARRAY_H CUT AP
}


VARIABLE AN_R_79_5m_6 6
AN.R.79.5m { @ {ANARRAY_H SIZING 6 um} must be same MOS type in same ANARRAY_H. DRC check: {{{PO OR SR_DPO} OR DPO} AND {{ANARRAY_H SIZING 6 um} NOT OUTSIDE {{{PO OR SR_DPO} OR DPO} AND PMET}}} must be inside PMET   

  AN_R_79_5_M_CHECK1 = (POi OR SRDPO) OR DPO
  (AN_R_79_5_M_CHECK1 AND ((SIZE ANARRAY_H BY AN_R_79_5m_6) NOT OUTSIDE (AN_R_79_5_M_CHECK1 AND PMET))) NOT INSIDE PMET
}


VARIABLE AN_M_A_2m_300000 300000
AN_M.A.2m { @ Maximum area of ANARRAY_M <= 300000 
    AREA ANARRAY_M > AN_M_A_2m_300000
}

//AN.R.80.0m is checked by AN.R.80.2m, AN.R.80.3m, AN.R.80.4m, AN_M.A.2m and AN.R.80.5m
AN.R.80.2m {@ For within 6 um surrounding range around ANARRAY_M, OD and PO density difference between surrounding and MOS array <= 10% 
    ANARRAY_M_outer = (SIZE ANARRAY_M BY AN_R_80_2m_S) NOT ANARRAY_M
    ANARRAY_M_inner = ANARRAY_M NOT (SIZE ANARRAY_M BY -AN_R_80_2m_S)
    ANARRAY_M_outerP = DFM PROPERTY ANARRAY_M_outer ALL_OD ALL_POLY [den_od = AREA(ALL_OD)/AREA(ANARRAY_M_outer)] [den_po = AREA(ALL_POLY)/AREA(ANARRAY_M_outer)]
    ANARRAY_M_innerP = DFM PROPERTY ANARRAY_M_inner ALL_OD ALL_POLY [den_od = AREA(ALL_OD)/AREA(ANARRAY_M_inner)] [den_po = AREA(ALL_POLY)/AREA(ANARRAY_M_inner)]
//  ANARRAY_M_OD_err = DFM PROPERTY ANARRAY_M_outerP ANARRAY_M_innerP OVERLAP ABUT ALSO 
    ANARRAY_M_OD_err = DFM PROPERTY ANARRAY_M_innerP ANARRAY_M_outerP OVERLAP ABUT ALSO MULTI
    [OD_DN_outer = PROPERTY(ANARRAY_M_outerP,"den_od")]
    [OD_DN_inner = PROPERTY(ANARRAY_M_innerP,"den_od")]
    [OD_DN_diff  = ABS(PROPERTY(ANARRAY_M_outerP,"den_od")-PROPERTY(ANARRAY_M_innerP,"den_od")) ] > AN_R_80_2m
//  ANARRAY_M_PO_err = DFM PROPERTY ANARRAY_M_outerP ANARRAY_M_innerP OVERLAP ABUT ALSO 
    ANARRAY_M_PO_err = DFM PROPERTY ANARRAY_M_innerP ANARRAY_M_outerP OVERLAP ABUT ALSO MULTI
    [PO_DN_outer = PROPERTY(ANARRAY_M_outerP,"den_po")]
    [PO_DN_inner = PROPERTY(ANARRAY_M_innerP,"den_po")]
    [PO_DN_diff  = ABS(PROPERTY(ANARRAY_M_outerP,"den_po")-PROPERTY(ANARRAY_M_innerP,"den_po")) ] > AN_R_80_2m    
    COPY ANARRAY_M_OD_err
    COPY ANARRAY_M_PO_err
    DFM RDB ANARRAY_M_OD_err "AN.R.80.2m.rep" NOEMPTY
    DFM RDB ANARRAY_M_PO_err "AN.R.80.2m.rep" NOEMPTY
}
AN.R.80.2.1m { @ Empty space of {{OD OR SR_DOD} OR DOD} inside {ANARRAY_M SIZING 6 um} DRC flag: {{{ANARRAY_M SIZING 6 um} NOT {{{OD OR SR_DOD} OR DOD} SIZING up/down 1 um}} SIZING down/up 1 um} <= 2 
  SIZE ((SIZE ANARRAY_M BY AN_R_80_2_1m_S) NOT (SIZE ALL_OD BY AN_R_80_2_1m/2 OVERUNDER)) BY AN_R_80_2_1m/2 UNDEROVER
}
AN.R.80.2.2m { @ Empty space of {{{PO OR SR_DPO} NOT CPO} OR DPO} inside {ANARRAY_M SIZING 6 um} DRC flag: {{{ANARRAY_M SIZING 6 um} NOT {{{{PO OR SR_DPO} NOT CPO} OR DPO} SIZING up/down 1 um}} SIZING down/up 1 um} <= 2 
  SIZE ((SIZE ANARRAY_M BY AN_R_80_2_2m_S) NOT (SIZE ALL_POLY BY AN_R_80_2_2m/2 OVERUNDER)) BY AN_R_80_2_2m/2 UNDEROVER
}
AN.R.80.3m {@ For within 3 um surrounding range around ANARRAY_M, width of STRAP <= 0.5 
   ANARRAY_M_S3 = (SIZE ANARRAY_M BY AN_R_80_3m_S) NOT ANARRAY_M   
   WITH WIDTH (DSTP AND ANARRAY_M_S3) > AN_R_80_3m
}
AN.R.80.4m { @ In order to reduce the current mismatch of MOS array, recommend to follow one of the following conditions: 1. ANARRAY_M space to AP (CUT is not recommended) >= 3 um, or 2. ANARRAY_M enclosure by AP >= 3 um Warning: When violated AN.R.80.4m, > 2X current mean shift compared with 1-sigma of device mismatch within a MOS array will be occurred   
  EXT ANARRAY_M AP < AN_R_80_4m ABUT < 90 SINGULAR REGION 
  ENC ANARRAY_M AP < AN_R_80_4m ABUT < 90 SINGULAR REGION 
  ANARRAY_M CUT AP
}



VARIABLE AN_R_80_5m_6 6
AN.R.80.5m { @ {ANARRAY_M SIZING 6 um} must be same MOS type in same ANARRAY_M. DRC check: {{{PO OR SR_DPO} OR DPO} AND {{ANARRAY_M SIZING 6 um} NOT OUTSIDE {{{PO OR SR_DPO} OR DPO} AND PMET}}} must be inside PMET   
  AN_R_80_5_M_CHECK1 = (POi OR SRDPO) OR DPO
  (AN_R_80_5_M_CHECK1 AND ((SIZE ANARRAY_M BY AN_R_80_5m_6) NOT OUTSIDE (AN_R_80_5_M_CHECK1 AND PMET))) NOT INSIDE PMET
}













#ENDIF // ESD_LUP_RULE_CHECK_ONLY

#ENDIF // FRONT_END
#ENDIF // VOLTAGE_RULE_CHECK_ONLY


#IFNDEF VOLTAGE_RULE_CHECK_ONLY
#IFNDEF ESD_LUP_RULE_CHECK_ONLY
#IFDEF FRONT_END


//SR_DOD CHECKS
//=============
SRDOD_OD2 = SRDOD NOT OUTSIDE OD2

SR_DOD.W.1 { @ Width >= 0.05 
  INT SRDOD < SRDOD_W_1 ABUT < 90 SINGULAR REGION
}

SR_DOD.W.2 { @ Maximum width (This check doesn't include the region covered by MOMDMY (155;21) or RH_PO) <= 0.5 
  A = INT SRDOD <= SRDOD_W_2 ABUT < 90 REGION
  (SRDOD NOT A) NOT INSIDE (MOMDMY OR RHPO)
}

SR_DOD.W.3 { @ Width [INSIDE OD2] >= 0.1 
  INT SRDOD_OD2 < SRDOD_W_3 ABUT < 90 SINGULAR REGION
}

SR_DOD.S.1 { @ Space >= 0.08 
  EXT SRDOD < SRDOD_S_1 ABUT < 90 SINGULAR REGION
}

SR_DOD.S.2 { @ Space to PO (overlap is not allowed) >= 0.025 
  EXT SRDOD POi < SRDOD_S_2 ABUT < 90 SINGULAR REGION INSIDE ALSO
}


SR_DOD.S.3 { @ Space to DPO, SR_DPO (SR_DOD OVERLAP DPO is not allowed) >= 0.025 
  EXT SRDOD DPO < SRDOD_S_3 ABUT < 90 SINGULAR REGION 
  EXT SRDOD SRDPO < SRDOD_S_3 ABUT < 90 SINGULAR REGION 
  SRDOD AND DPO
}

SR_DOD.S.4 { @ Space to 45-degree bent OD >= 0.4 
  X = EXPAND EDGE OD_EDGE_45 OUTSIDE BY SRDOD_S_4
  X AND SRDOD
}
SR_DOD.S.5 { @ Space to OD (overlap is not allowed) >= 0.08 
  EXT SRDOD OD < SRDOD_S_5 ABUT < 90 SINGULAR REGION INSIDE ALSO
}


SR_DOD.S.6 { @ Space to OD, DOD (overlap is not allowed) [INSIDE OD2] >= 0.15 
  EXT SRDOD_OD2 OD < SRDOD_S_6 ABUT < 90 SINGULAR REGION INSIDE ALSO
  EXT SRDOD_OD2 DOD < SRDOD_S_6 ABUT < 90 SINGULAR REGION INSIDE ALSO
}

SR_DOD.S.7 { @ Space to NW (for both core and I/O) >= 0.08 
  EXT SRDOD NWi < SRDOD_S_7 ABUT < 90 SINGULAR REGION
}
SR_DOD.S.8 { @ Space to NWDMY (overlap is not allowed) >= 0.6 
  EXT SRDOD NWDMY < SRDOD_S_8 ABUT < 90 SINGULAR REGION INSIDE ALSO
}

SR_DOD.S.10 { @ Space to INDDMY >= 1.2 
  EXT SRDOD INDDMY < SRDOD_S_10 ABUT < 90 SINGULAR REGION
}
SR_DOD.S.11 { @ Space to NT_N (overlap is not allowed if OD inside NT_N) (This check doesn't include the regions covered by MOMDMY (155;21) region) >= 0.14 
  (EXT SRDOD NTNi < SRDOD_S_11 ABUT < 90 SINGULAR REGION) NOT INSIDE MOMDMY
  (SRDOD AND (NTNi INTERACT OD)) NOT INSIDE MOMDMY
}

SR_DOD.S.12 { @ Space [INSIDE OD2] >= 0.15 
  EXT SRDOD_OD2 < SRDOD_S_12 ABUT < 90 SINGULAR REGION 
}


SR_DOD.S.13 { @ Space to OD2 ({SR_DOD CUT OD2} is not allowed) >= 0.08 
  EXT SRDOD OD2 < SRDOD_S_13 ABUT < 90 SINGULAR REGION
  SRDOD CUT OD2
}


SR_DOD.S.14 { @ Space to PP ({SR_DOD CUT PP} is not allowed) >= 0.065 
  EXT SRDOD PP < SRDOD_S_14 ABUT < 90 SINGULAR REGION
  SRDOD CUT PP
}
SR_DOD.S.15 { @ Space to DOD (overlap is not allowed) >= 0.12 
  EXT SRDOD DOD < SRDOD_S_15 ABUT < 90 SINGULAR REGION INSIDE ALSO
}

SR_DOD.EN.1 { @ NW enclosure of SR_DOD (for both core and I/O) >= 0.08 
  ENC SRDOD NWi < SRDOD_EN_1 ABUT < 90 SINGULAR REGION
  SRDOD CUT NWi
}



SR_DOD.EN.3 { @ Enclosure by OD2 >= 0.08 
  ENC SRDOD OD2 < SRDOD_EN_3 ABUT < 90 SINGULAR REGION
  SRDOD CUT OD2
}

SR_DOD.EN.4 { @ Enclosure by PP >= 0.065 
  ENC SRDOD PP < SRDOD_EN_4 ABUT < 90 SINGULAR REGION
  SRDOD CUT PP
}
SR_DOD.A.1 { @ Area >= 0.03 
  AREA SRDOD < SRDOD_A_1
}

SR_DOD.L.1 { @ Length >= ^SRDOD_L_1 um
  NOT ENCLOSE RECTANGLE SRDOD SRDOD_L_1 GRID ORTHOGONAL ONLY
}

SR_DOD.L.2 { @ Maximum Length (This check doesn't include the region covered by MOMDMY_n, and RH_PO) <= 25 
  SRDOD_CHECK = (SRDOD NOT INSIDE RHPO) NOT INSIDE MOMDMY_ALL
  ENCLOSE RECTANGLE SRDOD_CHECK (SRDOD_L_2 + GRID) GRID ORTHOGONAL ONLY
}

SR_DOD.R.1 { @ 45-degree bent SR_DOD is not allowed   
  SRDOD ANGLE == 45
}

SR_DOD.R.2 { @ Overlap of CO is not allowed   
  SRDOD AND CO
}

SR_DOD.R.3 { @ Only rectangle is allowed   
  NOT RECTANGLE SRDOD
}

#IFDEF FULL_CHIP
SR_DOD.R.4 { @ SR_DOD is a must. SR_DOD CAD layer (TSMC default, 6;7) must be different from OD CAD layer   
   MERGE (CHIP NOT INTERACT SRDOD)
}
#ENDIF




#ENDIF // FRONT_END
#ENDIF // ESD_LUP_RULE_CHECK_ONLY
#ENDIF // VOLTAGE_RULE_CHECK_ONLY
#ENDIF // EFP_ONLY
#ENDIF // DFM_ONLY

/////////////////////////////////////
#IFNDEF DFM_ONLY
#IFNDEF EFP_ONLY

#IFNDEF VOLTAGE_RULE_CHECK_ONLY
#IFNDEF ESD_LUP_RULE_CHECK_ONLY


#IFDEF M1_V1_M2_CHECKS

//DUMMY VIA1 CHECKS
//==================

DVIA1.W.1 { @ Width(maximun = minimun) == ^DVIA1_W_1 um
  NOT RECTANGLE DUVIA1 == DVIA1_W_1 BY == DVIA1_W_1 ORTHOGONAL ONLY
}

DVIA1.S.1 { @ Space >= ^DVIA1_S_1 um
  EXT DUVIA1 < DVIA1_S_1 ABUT < 90 SINGULAR REGION
}

DVIA1.S.2 { @ Space to VIAx >= ^DVIA1_S_2 um
  EXT DUVIA1 VIA1 < DVIA1_S_2 ABUT < 90 SINGULAR REGION
}

DVIA1.EN.1 { @ Enclosure by DMx or DM1 >= ^DVIA1_EN_1 um
  DUVIA1 NOT DUM1
}
DVIA1.EN.2 { @ Enclosure by DM1 or DM1 [at least two opposite sides] >= ^DVIA1_EN_2 um
  RECTANGLE ENCLOSURE DUVIA1 DUM1 ABUT < 90 SINGULAR GOOD 0 DVIA1_EN_2 OPPOSITE 0 DVIA1_EN_2 OPPOSITE
}

DVIA1.R.1 { @ DVIAx must fully inside DMx and DMx+1
  DUVIA1 NOT DUM1
  DUVIA1 NOT DUM2      
}

DVIA1.R.2 { @ DVIAx INTERACT {{{Mx OR Mx+1} OR DMx_O} OR DMx+1_O} is not allowed.
  DUVIA1 INTERACT M1
  DUVIA1 INTERACT M2
}

#IFDEF FULL_CHIP
DVIA1.R.3 { @ DVIA1 is a must for Flip Chip. 
@ To comply tsmc dummy utility, DRC will flag as violation when the area ratio of (DVIA1 to DM1) and (DVIA1 to DM2) are < 1% at the same time
  A = DENSITY DUVIA1 DUM1 < DVIA1_R_3 INSIDE OF LAYER DVIAxR3_CHECK PRINT DVIA1DM1.R.3.density
    	[AREA(DUVIA1)/AREA(DUM1)]
  B = DENSITY DUVIA1 DUM2 < DVIA1_R_3 INSIDE OF LAYER DVIAxR3_CHECK PRINT DVIA1DM2.R.3.density
    	[AREA(DUVIA1)/AREA(DUM2)]
  (CHIPx INTERACT A) INTERACT B
}
#ENDIF

#ENDIF //M1_V1_M2_CHECKS

#IFDEF BACK_END

//DUMMY VIA2 CHECKS
//==================

DVIA2.W.1 { @ Width(maximun = minimun) == ^DVIA2_W_1 um
  NOT RECTANGLE DUVIA2 == DVIA2_W_1 BY == DVIA2_W_1 ORTHOGONAL ONLY
}

DVIA2.S.1 { @ Space >= ^DVIA2_S_1 um
  EXT DUVIA2 < DVIA2_S_1 ABUT < 90 SINGULAR REGION
}

DVIA2.S.2 { @ Space to VIAx >= ^DVIA2_S_2 um
  EXT DUVIA2 VIA2 < DVIA2_S_2 ABUT < 90 SINGULAR REGION
}

DVIA2.EN.1 { @ Enclosure by DMx or DM1 >= ^DVIA2_EN_1 um
  DUVIA2 NOT DUM2
}
DVIA2.EN.2 { @ Enclosure by DM2 or DM1 [at least two opposite sides] >= ^DVIA2_EN_2 um
  RECTANGLE ENCLOSURE DUVIA2 DUM2 ABUT < 90 SINGULAR GOOD 0 DVIA2_EN_2 OPPOSITE 0 DVIA2_EN_2 OPPOSITE
}

