//-------------------------------------------------------------------------------------
//
//  NOTICE: (Read Me First!)
//
//  *** Warning: This DRC file CLN22ULL_028_PATCH.09a can not be run alone! ***
//  
//     This DRC file CLN22ULL_028_PATCH.09a is a patch for N22ULL DRC.
//     Please combine the DRC file with (T-N22-CL-DR-001-C1 v1.4a) to get the complete DRC file. 
//     A syntax error will be reported by Calibre DRC tool when CLN22ULL_028_PATCH.09a
//     is run alone. Please be sure to complete the following procedures for correct usage of
//     this DRC deck.
//  
//     Procedures:
//  
//     1. Please download the T-N22-CL-DR-001-C1 v1.4a DRC deck from TSMC-online.
//        Suppose 8M metal layer logic process with 5X1Y1Z METAL OPTION has been chosen,
//        then the generic DRC command file needed is CLN22ULP_8M_5X1Y1Z_001.14a.encrypt
//       
//     2. Read the '3_UserGuide.txt' in the DRC deck package for correct generic usage.
//  
//     3. Use the unix command 'cat' to create the complete DRC file
//        (assuming % is the unix prompt):
//  
//        %cat CLN22ULP_8M_5X1Y1Z_001.14a.encrypt CLN22ULL_028_PATCH.09a > CLN22ULP_8M_5X1Y1Z_001.14a.encrypt+CLN22ULL_028_PATCH.09a
//  
//    As a result, CLN22ULP_8M_5X1Y1Z_001.14a.encrypt+CLN22ULL_028_PATCH.09a is the complete DRC command file.
//
//-------------------------------------------------------------------------------------
LAYER VTSUH_N        25104   
LAYER MAP 151 DATATYPE 4 25104
LAYER VTSUH_P        25204  
LAYER MAP 152 DATATYPE 4 25204
#IFNDEF DFM_ONLY
#IFNDEF EFP_ONLY
#IFNDEF VOLTAGE_RULE_CHECK_ONLY
#IFNDEF ESD_LUP_RULE_CHECK_ONLY
G.1:VTSUH_N { @ grid must be an integer multiple of 0.005 um
  OFFGRID VTSUH_N 5
}
G.1:VTSUH_P { @ grid must be an integer multiple of 0.005 um
  OFFGRID VTSUH_P 5
}
G.2:VTSUH_N { @ LAYERS Shapes with acute angles between line segments are not allowed.
  INT VTSUH_N < 0.1 ABUT < 90 INTERSECTING ONLY
  EXT VTSUH_N < 0.1 ABUT < 90 INTERSECTING ONLY
}
G.2:VTSUH_P { @ LAYERS Shapes with acute angles between line segments are not allowed.
  INT VTSUH_P < 0.1 ABUT < 90 INTERSECTING ONLY
  EXT VTSUH_P < 0.1 ABUT < 90 INTERSECTING ONLY
}
G.3:VTSUH_N { @ Shapes must be orthogonal or on a 45 degree angle.
  ANGLE VTSUH_N >0  <45    
  ANGLE VTSUH_N >45 <90  
}
G.3:VTSUH_P { @ Shapes must be orthogonal or on a 45 degree angle.
  ANGLE VTSUH_P >0  <45    
  ANGLE VTSUH_P >45 <90  
}
#ENDIF // ESD_LUP_RULE_CHECK_ONLY
#ENDIF // VOLTAGE_RULE_CHECK_ONLY
#ENDIF // EFP_ONLY
#ENDIF // DFM_ONLY
#IFNDEF DFM_ONLY
#IFNDEF EFP_ONLY
#IFNDEF VOLTAGE_RULE_CHECK_ONLY
#IFNDEF ESD_LUP_RULE_CHECK_ONLY
#IFDEF FULL_CHIP
#IFNDEF WITH_SEALRING
CSR.R.1:VTSUH_N { @ VTSUH_N is not allowed inside triangle empty areas( ^CSR_R_1 um) at 4 chip corners.
  EMPTY_AREA_P4 AND VTSUH_N
}
CSR.R.1:VTSUH_P { @ VTSUH_P is not allowed inside triangle empty areas( ^CSR_R_1 um) at 4 chip corners.
  EMPTY_AREA_P4 AND VTSUH_P
}
#ELSE // WITH_SEALRING
#ENDIF // WITH_SEALRING
#ENDIF // FULL_CHIP
#ENDIF // ESD_LUP_RULE_CHECK_ONLY
#ENDIF // VOLTAGE_RULE_CHECK_ONLY
#ENDIF // EFP_ONLY
#ENDIF // DFM_ONLY
VARIABLE  VTSUH_N_W_1   0.16   
VARIABLE  VTSUH_N_S_1   0.16 
VARIABLE  VTSUH_N_S_2   0.065 
VARIABLE  VTSUH_N_S_3   0.115 
VARIABLE  VTSUH_N_S_4   0.15
VARIABLE  VTSUH_N_S_5   0.25
VARIABLE  VTSUH_N_S_5_L   0.33
VARIABLE  VTSUH_N_S_7   0.24
VARIABLE  VTSUH_N_S_8   0.065
VARIABLE  VTSUH_N_EN_1  0.115 
VARIABLE  VTSUH_N_EN_2  0.065 
VARIABLE  VTSUH_N_EN_3  0.065
VARIABLE  VTSUH_N_L_1   0.5 
VARIABLE  VTSUH_N_A_1   0.108 
VARIABLE  VTSUH_N_A_2   0.108 
VARIABLE  VTSUH_N_R_3_A  0.10 // user value
VARIABLE  VTSUH_N_R_3_B  0.13 // user value
VARIABLE  VTSUH_P_W_1   0.16   
VARIABLE  VTSUH_P_S_1   0.16 
VARIABLE  VTSUH_P_S_2   0.065 
VARIABLE  VTSUH_P_S_3   0.115 
VARIABLE  VTSUH_P_S_4   0.15
VARIABLE  VTSUH_P_S_5   0.25
VARIABLE  VTSUH_P_S_5_L   0.33
VARIABLE  VTSUH_P_S_7   0.24
VARIABLE  VTSUH_P_S_8   0.065
VARIABLE  VTSUH_P_EN_1  0.115 
VARIABLE  VTSUH_P_EN_2  0.065 
VARIABLE  VTSUH_P_EN_3  0.065
VARIABLE  VTSUH_P_L_1   0.5 
VARIABLE  VTSUH_P_A_1   0.108 
VARIABLE  VTSUH_P_A_2   0.108 
VARIABLE  VTSUH_P_R_3_A  0.10 // user value
VARIABLE  VTSUH_P_R_3_B  0.13 // user value
VARIABLE  VTSUH_N_S_6   0.24 
VARIABLE  VTSUH_N_S_9   0.16
#IFNDEF DFM_ONLY
#IFNDEF EFP_ONLY
#IFNDEF VOLTAGE_RULE_CHECK_ONLY
#IFNDEF ESD_LUP_RULE_CHECK_ONLY
#IFDEF FRONT_END
#IFDEF N22_ULL
//VTSUH_N CHECKS
//============
VTSUH_N.W.1 { @ Width >= 0.16  
  A = INT VTSUH_N < VTSUH_N_W_1 ABUT < 90 REGION PROJ==0
  B = EXT [VTSUH_N] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = INT B >= VTSUH_N_R_3_A < VTSUH_N_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = INT B >= VTSUH_N_R_3_B < VTSUH_N_W_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = INT VTSUH_N < VTSUH_N_W_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
VTSUH_N.S.1 { @ Space >= 0.16  
  A = EXT VTSUH_N < VTSUH_N_S_1 ABUT < 90 REGION PROJ==0
  B = INT [VTSUH_N] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = EXT B >= VTSUH_N_R_3_A < VTSUH_N_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = EXT B >= VTSUH_N_R_3_B < VTSUH_N_S_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = EXT VTSUH_N < VTSUH_N_S_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
VTSUH_N.S.2__VTSUH_N.S.3 { @ Space to GATE in PO ENDCAP direction >= 0.065  
                               @ Space to GATE in S/D direction ({ACTIVE OR GATE} cut VTSUH_N is not allowed) >= 0.115  
  A = GATE NOT INTERACT VTSUH_N
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (VTSUH_N_S_3 - VTSUH_N_S_2)) OR A
  C = SIZE B BY VTSUH_N_S_2
  (VTSUH_N AND C) NOT INSIDE SRAM_WAIVE_N28
  (DACT CUT VTSUH_N) NOT INSIDE SRAM_WAIVE_N28
  (GATE CUT VTSUH_N) NOT INSIDE SRAM_WAIVE_N28
}
VTSUH_N.S.4 { @ Space to unsilicided OD or high R resistor >= 0.15  
  EXT VTSUH_N AYRE < VTSUH_N_S_4 ABUT < 90 SINGULAR REGION
  AND VTSUH_N AYRE    
}  
VTSUH_N.S.5 { @ Space [parallel run length > 0.33 um, VTSUH_N space without INTERACT {{OD OR SR_DOD} OR DOD}] >= 0.25  
  X = EXT VTSUH_N < VTSUH_N_S_5 OPPOSITE REGION
  Y = X NOT INTERACT ALL_OD
  ENCLOSE RECTANGLE Y GRID VTSUH_N_S_5_L+GRID ORTHOGONAL ONLY
}
VTSUH_N.S.6 { @ Space to NW. Space = 0 um is allowed >= 0.24  
     EXT VTSUH_N NWi < VTSUH_N_S_6 ABUT > 0 < 90 SINGULAR REGION
}

VTSUH_N.S.7 { @ Space to OD2 or NT_N. Space = 0 um is allowed >= 0.24  
    EXT VTSUH_N OD2 < VTSUH_N_S_7 ABUT > 0 < 90 SINGULAR REGION
    EXT VTSUH_N NTN < VTSUH_N_S_7 ABUT > 0 < 90 SINGULAR REGION
}
VTSUH_N.S.8 { @ Space to ACTIVE ({ACTIVE OR GATE} cut VTSUH_N is not allowed) >= 0.065  
    EXT VTSUH_N DACT < VTSUH_N_S_8 ABUT <90 SINGULAR REGION
    (DACT OR GATE) CUT VTSUH_N
}
VTSUH_N.S.9 { @ Space to SRM_ULL >= 0.16  
    EXT VTSUH_N SRM_ULL < VTSUH_N_S_9 ABUT< 90 SINGULAR REGION
}

VTSUH_N.EN.1__VTSUH_N.EN.2 { @ Enclosure of GATE in S/D direction >= 0.115  
                                 @ Enclosure of GATE in PO ENDCAP direction >= 0.065  
  A = GATE INTERACT VTSUH_N
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (VTSUH_N_EN_1 - VTSUH_N_EN_2)) OR A
  C = SIZE B BY VTSUH_N_EN_2
  C NOT VTSUH_N
}
VTSUH_N.EN.3 { @ Enclosure of ACTIVE >= 0.065  
    ENC DACT VTSUH_N < VTSUH_N_EN_3 ABUT <90 SINGULAR REGION
}
VTSUH_N.L.1 { @ 45-degree edge length >= 0.5  
  VTSUH_N_EDGE_45 = VTSUH_N ANGLE == 45
  LENGTH VTSUH_N_EDGE_45 < VTSUH_N_L_1  
}
VTSUH_N.A.1 { @ Area, except DMY_SCH >= 0.108  
  (AREA VTSUH_N < VTSUH_N_A_1) NOT INSIDE DMY_SCH
}
VTSUH_N.A.2 { @ Enclosed area, except DMY_SCH >= 0.108  
  A = HOLES VTSUH_N INNER
  B = A NOT VTSUH_N
  (AREA B < VTSUH_N_A_2) NOT INSIDE DMY_SCH
}

VTSUH_N.R.1 { @ Overlap of RH_OD, RH_PO, VAR, BJTDMY, LOGO, TCDDMY, NWDMY, SR_ESD, SDI, GB_ALL, VTH_N, VTH_P, VTL_N, VTL_P, VTUL_N, VTUL_P, UHVT_N, UHVT_P, VTSUH_P, NT_N, OD2, NW, SRM_ULL or P+ACTIVE is not allowed    
    VTSUH_N AND RHOD
    VTSUH_N AND RHPO
    VTSUH_N AND VAR
    VTSUH_N AND BJTDMY
    VTSUH_N AND LOGO
    VTSUH_N AND TCDDMY
    VTSUH_N AND NWDMY
    VTSUH_N AND SRESD
    VTSUH_N AND SDI
    VTSUH_N AND GB_ALL
    VTSUH_N AND VTHN
    VTSUH_N AND VTHP
    VTSUH_N AND VTLN
    VTSUH_N AND VTLP
    VTSUH_N AND VTULN
    VTSUH_N AND VTULP
    VTSUH_N AND VTUHN
    VTSUH_N AND VTUHP
    VTSUH_N AND VTSUH_P
    VTSUH_N AND NTN
    VTSUH_N AND OD2
    VTSUH_N AND NWi
    VTSUH_N AND SRM_ULL
    VTSUH_N AND PACT
}
// VTSUH_N.R.2 and VTSUH_N.R.3 are checked by VTSUH_N.W.1 and VTSUH_N.S.1
VTSUH_N.R.4 { @ VTSUH_N must be fully inside {Chip NOT NW}    
    VTSUH_N NOT (CHIPx NOT NWi)
}
VTSUH_N.R.5 { @ {Chip INTERACT VTSUH_N} must interact SRM_ULL    
    (CHIPx INTERACT VTSUH_N) NOT INTERACT SRM_ULL
}
VTSUH_N.R.6 { @ {{Chip INTERACT VTSUH_N} INTERACT UHVT_N} is not allowed    
    (CHIPx INTERACT VTSUH_N) INTERACT VTUHN
}
//VTSUH_P CHECKS
//============
VTSUH_PS = OR VTSUH_P VTHP
VTSUH_P.W.1 { @ Width of VTSUH_PS >= 0.16  
  A = INT VTSUH_PS < VTSUH_P_W_1 ABUT < 90 REGION PROJ==0
  B = EXT [VTSUH_PS] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = INT B >= VTSUH_P_R_3_A < VTSUH_P_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = INT B >= VTSUH_P_R_3_B < VTSUH_P_W_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = INT VTSUH_PS < VTSUH_P_W_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
VTSUH_P.S.1 { @ Space of VTSUH_PS >= 0.16  
  A = EXT VTSUH_PS < VTSUH_P_S_1 ABUT < 90 REGION PROJ==0
  B = INT [VTSUH_PS] < 0.001 ABUT==90 INTERSECTING ONLY
  C1 = EXT B >= VTSUH_P_R_3_A < VTSUH_P_R_3_A+0.001 ABUT < 90 REGION PROJ==0
  C2 = EXT B >= VTSUH_P_R_3_B < VTSUH_P_S_1 ABUT < 90 REGION PROJ==0
  D = A ENCLOSE (C1 OR C2)    
  X = EXT VTSUH_PS < VTSUH_P_S_1 ABUT < 90 REGION
  X INTERACT (X NOT D)
}
VTSUH_P.S.2__VTSUH_P.S.3 { @ Space of VTSUH_PS to GATE in PO ENDCAP direction >= 0.065  
                               @ Space of VTSUH_PS to GATE in S/D direction ({ACTIVE OR GATE} cut VTSUH_PS is not allowed) >= 0.115  
  A = GATE NOT INTERACT VTSUH_PS
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (VTSUH_P_S_3 - VTSUH_P_S_2)) OR A
  C = SIZE B BY VTSUH_P_S_2
  VTSUH_PS AND C
  DACT CUT VTSUH_PS
  GATE CUT VTSUH_PS
}
VTSUH_P.S.4 { @ Space of VTSUH_PS to unsilicided OD or high R resistor >= 0.15  
  EXT VTSUH_PS AYRE < VTSUH_P_S_4 ABUT < 90 SINGULAR REGION
  AND VTSUH_PS AYRE    
}  
VTSUH_P.S.5 { @ Space of VTSUH_PS [parallel run length > 0.33 um, VTSUH_PS space without INTERACT {{OD OR SR_DOD} OR DOD}] >= 0.25  
  X = EXT VTSUH_PS < VTSUH_P_S_5 OPPOSITE REGION
  Y = X NOT INTERACT ALL_OD
  ENCLOSE RECTANGLE Y GRID VTSUH_P_S_5_L+GRID ORTHOGONAL ONLY
}

VTSUH_P.S.7 { @ Space to OD2 or NT_N. Space = 0 um is allowed >= 0.24  
    EXT VTSUH_P OD2 < VTSUH_P_S_7 ABUT > 0 < 90 SINGULAR REGION
    EXT VTSUH_P NTN < VTSUH_P_S_7 ABUT > 0 < 90 SINGULAR REGION
}
VTSUH_P.S.8 { @ Space to ACTIVE ({ACTIVE OR GATE} cut VTSUH_P is not allowed) >= 0.065  
    EXT VTSUH_P DACT < VTSUH_P_S_8 ABUT <90 SINGULAR REGION
    (DACT OR GATE) CUT VTSUH_P
}

VTSUH_P.EN.1__VTSUH_P.EN.2 { @ Enclosure of GATE in S/D direction >= 0.115  
                                 @ Enclosure of GATE in PO ENDCAP direction >= 0.065  
  A = GATE INTERACT VTSUH_P
  X = A INSIDE EDGE OD
  B = (EXPAND EDGE X OUTSIDE BY (VTSUH_P_EN_1 - VTSUH_P_EN_2)) OR A
  C = SIZE B BY VTSUH_P_EN_2
  C NOT VTSUH_P
}
VTSUH_P.EN.3 { @ Enclosure of ACTIVE >= 0.065  
    ENC DACT VTSUH_P < VTSUH_P_EN_3 ABUT <90 SINGULAR REGION
}
VTSUH_P.L.1 { @ 45-degree edge length >= 0.5  
  VTSUH_P_EDGE_45 = VTSUH_P ANGLE == 45
  LENGTH VTSUH_P_EDGE_45 < VTSUH_P_L_1  
}
VTSUH_P.A.1 { @ Area, except DMY_SCH >= 0.108  
  (AREA VTSUH_P < VTSUH_P_A_1) NOT INSIDE DMY_SCH
}
VTSUH_P.A.2 { @ Enclosed area, except DMY_SCH >= 0.108  
  A = HOLES VTSUH_P INNER
  B = A NOT VTSUH_P
  (AREA B < VTSUH_P_A_2) NOT INSIDE DMY_SCH
}

VTSUH_P.R.1 { @ Overlap of RH_OD, RH_PO, VAR, BJTDMY, LOGO, TCDDMY, NWDMY, SR_ESD, SDI, GB_ALL, VTH_N, VTH_P, VTL_N, VTL_P, VTUL_N, VTUL_P, UHVT_N, UHVT_P, VTSUH_N, NT_N, OD2 or N+ACTIVE is not allowed    
    VTSUH_P AND RHOD
    VTSUH_P AND RHPO
    VTSUH_P AND VAR
    VTSUH_P AND BJTDMY
    VTSUH_P AND LOGO
    VTSUH_P AND TCDDMY
    VTSUH_P AND NWDMY
    VTSUH_P AND SRESD
    VTSUH_P AND SDI
    VTSUH_P AND GB_ALL
    VTSUH_P AND VTHN
    VTSUH_P AND VTHP
    VTSUH_P AND VTLN
    VTSUH_P AND VTLP
    VTSUH_P AND VTULN
    VTSUH_P AND VTULP
    VTSUH_P AND VTUHN
    VTSUH_P AND VTUHP
    VTSUH_P AND VTSUH_N
    VTSUH_P AND NTN
    VTSUH_P AND OD2
    VTSUH_P AND NACT

}
// VTSUH_P.R.2 and VTSUH_P.R.3 are checked by VTSUH_P.W.1 and VTSUH_P.S.1
VTSUH_P.R.4 { @ VTSUH_P must be fully inside NW    
    VTSUH_P NOT NWi
}
VTSUH_P.R.5 { @ {Chip INTERACT VTSUH_P} must interact VTH_P    
    (CHIPx INTERACT VTSUH_P) NOT INTERACT VTHP
}
VTSUH_P.R.6 { @ {{Chip INTERACT VTSUH_P} INTERACT UHVT_P} is not allowed    
    (CHIPx INTERACT VTSUH_P) INTERACT VTUHP
}
#ENDIF // N22_ULL
#ENDIF // FRONT_END
#ENDIF // ESD_LUP_RULE_CHECK_ONLY
#ENDIF // VOLTAGE_RULE_CHECK_ONLY
#ENDIF // EFP_ONLY
#ENDIF // DFM_ONLY

#IFNDEF DFM_ONLY
