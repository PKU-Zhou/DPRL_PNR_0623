#IFDEF CHECK_M5S37_
#IFDEF _M5S37_
M5S37_M5CellIn = INSIDE CELL M5i CellsForRRuleRecommended  
M5S37_M5CellOut = NOT INSIDE CELL M5i ExclCellsForRRuleRecommended 
M5S37_M5Cell = M5S37_M5CellIn AND M5S37_M5CellOut
M5S37_M5Marker = M5i AND RRuleRecommended
M5S37_M5 = ((M5S37_M5Cell OR M5S37_M5Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:M5.S.37 { @ Recommended space to Mx jog filled up region (R1A) Definition of Mx jog: Mx with length < 0.12 um (LA1), 2 adjacent edge length < 0.05 um (WA1) and < 0.06 um (WA2) [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex -90 degree outer vertex] >= 0.05 
  L1_pre = CONVEX EDGE M5S37_M5 ANGLE1==90 ANGLE2==270 LENGTH2 < 0.12 WITH LENGTH < 0.05 
  L2_pre = CONVEX EDGE M5S37_M5 ANGLE1==90 ANGLE2==270 LENGTH1 < 0.06 LENGTH2 <0.05 WITH LENGTH < 0.12
  L3_pre = CONVEX EDGE M5S37_M5 ANGLE1==90 ANGLE2==90  LENGTH1 < 0.12 WITH LENGTH < 0.06
  L1_L2_V = EXT L1_pre L2_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
  L2_L3_V = INT L2_pre L3_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
  L2 = (L2_pre TOUCH OUTSIDE EDGE L1_L2_V) TOUCH INSIDE EDGE L2_L3_V  
  L1 = L1_pre TOUCH OUTSIDE EDGE (L1_L2_V WITH EDGE L2) 
  L1_ex = EXPAND EDGE L1 OUTSIDE BY GRID
  L2_ex = EXPAND EDGE L2 OUTSIDE BY GRID
  JOG_FILL = EXTENTS (L1_ex OR L2_ex)
  S = EXT JOG_FILL M5 < 0.05 ABUT>0<90 SINGULAR REGION
  S OR (JOG_FILL INTERACT S)
}
#ENDIF
#ENDIF

#IFDEF CHECK_M5A1_
#IFDEF _M5A1_
