  M1_TypeBRS3_CACB_S3_1 = LENGTH M1_TypeBRS3_CACB_S6_7 == TypeBRS3_S2
  M1_TypeBRS3_CACB_S3_2 = M1i COIN EDGE M1_TypeBRS3_CACB_S6_7
  M1_TypeBRS3_CACB_S3_3 = LENGTH M1_TypeBRS3_CACB_S3_2 == GRID
