#IFDEF CHECK_M2S37_
#IFDEF _M2S37_
M2S37_M2CellIn = INSIDE CELL M2i CellsForRRuleRecommended  
M2S37_M2CellOut = NOT INSIDE CELL M2i ExclCellsForRRuleRecommended 
M2S37_M2Cell = M2S37_M2CellIn AND M2S37_M2CellOut
M2S37_M2Marker = M2i AND RRuleRecommended
M2S37_M2 = ((M2S37_M2Cell OR M2S37_M2Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:M2.S.37 { @ Recommended space to Mx jog filled up region (R1A) Definition of Mx jog: Mx with length < 0.12 um (LA1), 2 adjacent edge length < 0.05 um (WA1) and < 0.06 um (WA2) [these 2 edges formed by 3 consecutive 270 degree inner vertex-90 degree outer vertex -90 degree outer vertex] >= 0.05 
  L1_pre = CONVEX EDGE M2S37_M2 ANGLE1==90 ANGLE2==270 LENGTH2 < 0.12 WITH LENGTH < 0.05 
  L2_pre = CONVEX EDGE M2S37_M2 ANGLE1==90 ANGLE2==270 LENGTH1 < 0.06 LENGTH2 <0.05 WITH LENGTH < 0.12
  L3_pre = CONVEX EDGE M2S37_M2 ANGLE1==90 ANGLE2==90  LENGTH1 < 0.12 WITH LENGTH < 0.06
  L1_L2_V = EXT L1_pre L2_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
  L2_L3_V = INT L2_pre L3_pre <= GRID ABUT==90 INTERSECTING ONLY REGION
  L2 = (L2_pre TOUCH OUTSIDE EDGE L1_L2_V) TOUCH INSIDE EDGE L2_L3_V  
  L1 = L1_pre TOUCH OUTSIDE EDGE (L1_L2_V WITH EDGE L2) 
  L1_ex = EXPAND EDGE L1 OUTSIDE BY GRID
  L2_ex = EXPAND EDGE L2 OUTSIDE BY GRID
  JOG_FILL = EXTENTS (L1_ex OR L2_ex)
  S = EXT JOG_FILL M2 < 0.05 ABUT>0<90 SINGULAR REGION
  S OR (JOG_FILL INTERACT S)
}
#ENDIF
#ENDIF

#IFDEF CHECK_M2A1_
#IFDEF _M2A1_
M2A1_M2CellIn = INSIDE CELL M2i CellsForRRuleRecommended  
M2A1_M2CellOut = NOT INSIDE CELL M2i ExclCellsForRRuleRecommended 
M2A1_M2Cell = M2A1_M2CellIn AND M2A1_M2CellOut
M2A1_M2Marker = M2i AND RRuleRecommended
M2A1_M2 = ((M2A1_M2Cell OR M2A1_M2Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:M2.A.1 { @ Recommended area (except DMx_O) >= 0.022 
  (AREA M2A1_M2 < M2_A_1_R) NOT INSIDE TCDDMY_BM2
}
#ENDIF
#ENDIF

// VIA2.EN.0.R is checked by either {VIA2.EN.1.R/VIA2.EN.2.R} or VIA2.EN.3.R
#IFDEF CHECK_VIA2EN1_
#IFDEF _VIA2EN1_
VIA2EN1_VIA2CellIn1 = INSIDE CELL VIA2ii CellsForRRuleRecommended  
VIA2EN1_VIA2CellOut1 = NOT INSIDE CELL VIA2ii ExclCellsForRRuleRecommended 
VIA2EN1_VIA2CellIn2 = INSIDE CELL VIA2_VIRT CellsForRRuleRecommended  
VIA2EN1_VIA2CellOut2 = NOT INSIDE CELL VIA2_VIRT ExclCellsForRRuleRecommended 
VIA2EN1_VIA2Cell = (VIA2EN1_VIA2CellIn1 AND VIA2EN1_VIA2CellOut1) OR (VIA2EN1_VIA2CellIn2 AND VIA2EN1_VIA2CellOut2)
VIA2EN1_VIA2Marker = (VIA2ii OR VIA2_VIRT) AND RRuleRecommended
VIA2EN1_VIA2 = ((VIA2EN1_VIA2Cell OR VIA2EN1_VIA2Marker) NOT Block ) NOT excludeRRuleRecommended

// VIAx.EN.1.R is checked by RR:RE:VIA2.EN.1 
RR:RE:VIA2.EN.1 { @ Recommended enclosure by M1 or Mx to avoid high Rc. (for square VIA) >= 0.01 
   CHECK_VIA = SQR_VIA2 INTERACT VIA2EN1_VIA2
   ENC CHECK_VIA M2 < VIA2_EN_1_R ABUT < 90 SINGULAR REGION
}
#ENDIF
#ENDIF

#IFDEF CHECK_VIA2EN2_VIA2EN3_
#IFDEF _VIA2EN2_VIA2EN3_
VIA2EN2_VIA2EN3_VIA2CellIn1 = INSIDE CELL VIA2ii CellsForRRuleRecommended  
VIA2EN2_VIA2EN3_VIA2CellOut1 = NOT INSIDE CELL VIA2ii ExclCellsForRRuleRecommended 
VIA2EN2_VIA2EN3_VIA2CellIn2 = INSIDE CELL VIA2_VIRT CellsForRRuleRecommended  
VIA2EN2_VIA2EN3_VIA2CellOut2 = NOT INSIDE CELL VIA2_VIRT ExclCellsForRRuleRecommended 
VIA2EN2_VIA2EN3_VIA2Cell = (VIA2EN2_VIA2EN3_VIA2CellIn1 AND VIA2EN2_VIA2EN3_VIA2CellOut1) OR (VIA2EN2_VIA2EN3_VIA2CellIn2 AND VIA2EN2_VIA2EN3_VIA2CellOut2)
VIA2EN2_VIA2EN3_VIA2Marker = (VIA2ii OR VIA2_VIRT) AND RRuleRecommended
VIA2EN2_VIA2EN3_VIA2 = ((VIA2EN2_VIA2EN3_VIA2Cell OR VIA2EN2_VIA2EN3_VIA2Marker) NOT Block ) NOT excludeRRuleRecommended

RR:RE:VIA2.EN.2__VIA2.EN.3 { @ Recommended enclosure of {M1 OR Mx} [at least two opposite sides] to avoid high Rc.(for square VIA) >= 0.05
                        @ Recommended enclosure of {M1 OR Mx} to avoid high Rc. [all sides] (for square VIA) >= 0.025       
   CHECK_VIA = SQR_VIA2 INTERACT VIA2EN2_VIA2EN3_VIA2       
   X = RECTANGLE ENCLOSURE CHECK_VIA M2 ABUT < 90 SINGULAR GOOD 0 VIA2_EN_2_R OPPOSITE 0 VIA2_EN_2_R OPPOSITE
   ENC X M2 < VIA2_EN_3_R ABUT < 90 SINGULAR REGION
}
// VIA2.EN.2.R and VIA2.EN.3.R are checked by RR:RE:VIA2.EN.2__VIA2.EN.3
#ENDIF
#ENDIF

#IFDEF CHECK_VIA2R10_
#IFDEF _VIA2R10_
VIA2R10_VIA2CellIn = INSIDE CELL VIA2ii CellsForRRuleRecommended  
VIA2R10_VIA2CellOut = NOT INSIDE CELL VIA2ii ExclCellsForRRuleRecommended 
VIA2R10_VIA2Cell = VIA2R10_VIA2CellIn AND VIA2R10_VIA2CellOut
VIA2R10_VIA2Marker = VIA2ii AND RRuleRecommended
VIA2R10_VIA2 = ((VIA2R10_VIA2Cell OR VIA2R10_VIA2Marker) NOT Block ) NOT excludeRRuleRecommended

//'VIAx.R.10.R' is checked by RR:RE:VIA2.R.10
RR:RE:VIA2.R.10 { @ Recommended VIAx space to VIAx+1 [different net and parallel run length > 0.02 um] >= 0.06 
  CHECK_VIA =  VIA2ii INTERACT VIA2R10_VIA2   
  X = EXT [CHECK_VIA] VIA3ii < VIA2_R_10_R ABUT < 90 OPPOSITE NOT CONNECTED
  LENGTH X > VIA2_R_10_L_R
}
#ENDIF
#ENDIF

// M3.EN.0.R is checked by either {M3.EN.1.R/M3.EN.2.R} or M3.EN.3.R
#IFDEF CHECK_M3EN1_
#IFDEF _M3EN1_
M3EN1_VIA2CellIn1 = INSIDE CELL VIA2ii CellsForRRuleRecommended  
M3EN1_VIA2CellOut1 = NOT INSIDE CELL VIA2ii ExclCellsForRRuleRecommended 
M3EN1_VIA2CellIn2 = INSIDE CELL VIA2_VIRT CellsForRRuleRecommended  
M3EN1_VIA2CellOut2 = NOT INSIDE CELL VIA2_VIRT ExclCellsForRRuleRecommended 
M3EN1_VIA2Cell = (M3EN1_VIA2CellIn1 AND M3EN1_VIA2CellOut1) OR (M3EN1_VIA2CellIn2 AND M3EN1_VIA2CellOut2)
M3EN1_VIA2Marker = (VIA2ii OR VIA2_VIRT) AND RRuleRecommended
M3EN1_VIA2 = ((M3EN1_VIA2Cell OR M3EN1_VIA2Marker) NOT Block ) NOT excludeRRuleRecommended


RR:RE:M3.EN.1 { @ Recommended enclosure of VIAx-1 to avoid high Rc. (for square VIA) >= 0.01
   CHECK_VIA = SQR_VIA2 INTERACT M3EN1_VIA2
   ENC CHECK_VIA M3 < M3_EN_1_R ABUT < 90 SINGULAR REGION
}
#ENDIF
#ENDIF

#IFDEF CHECK_M3EN2_M3EN3_
#IFDEF _M3EN2_M3EN3_
M3EN2_M3EN3_VIA2CellIn1 = INSIDE CELL VIA2ii CellsForRRuleRecommended  
M3EN2_M3EN3_VIA2CellOut1 = NOT INSIDE CELL VIA2ii ExclCellsForRRuleRecommended 
M3EN2_M3EN3_VIA2CellIn2 = INSIDE CELL VIA2_VIRT CellsForRRuleRecommended  
M3EN2_M3EN3_VIA2CellOut2 = NOT INSIDE CELL VIA2_VIRT ExclCellsForRRuleRecommended 
M3EN2_M3EN3_VIA2Cell = (M3EN2_M3EN3_VIA2CellIn1 AND M3EN2_M3EN3_VIA2CellOut1) OR (M3EN2_M3EN3_VIA2CellIn2 AND M3EN2_M3EN3_VIA2CellOut2)
M3EN2_M3EN3_VIA2Marker = (VIA2ii OR VIA2_VIRT) AND RRuleRecommended
M3EN2_M3EN3_VIA2 = ((M3EN2_M3EN3_VIA2Cell OR M3EN2_M3EN3_VIA2Marker) NOT Block ) NOT excludeRRuleRecommended


RR:RE:M3.EN.2__M3.EN.3 { @ Recommended M3 enclosure of square VIA2 >= ^M3_EN_3_R, OR at least two opposite sides >= ^M3_EN_2_R um
  CHECK_VIA = SQR_VIA2 INTERACT M3EN2_M3EN3_VIA2      
  A = RECTANGLE ENCLOSURE CHECK_VIA M3 ABUT < 90 SINGULAR GOOD 0 M3_EN_2_R OPPOSITE 0 M3_EN_2_R OPPOSITE
  ENC A M3 < M3_EN_3_R ABUT < 90 SINGULAR REGION
}
// M3.EN.2.R and M3.EN.3.R are checked by RR:RE:M3.EN.2__M3.EN.3
#ENDIF
#ENDIF

#IFDEF CHECK_M3S1_
#IFDEF _M3S1_
M3S1_M3CellIn = INSIDE CELL M3i CellsForRRuleRecommended  
M3S1_M3CellOut = NOT INSIDE CELL M3i ExclCellsForRRuleRecommended 
