DEVICE MN(nch_ulvt_dnw_mac) n1uvgate_macz n1uvgate_mac(G) tndiff(S) tndiff(D) psub(B) netlist model nch_ulvt_mac netlist element "X" CMACRO dfm_nmos_core
#IFDEF MULTI_DEVICE_EXTRACTION
TEMPLATE "nch_ulvt_dnw_mac" 
n1uvgate_mac_in_edge = n1uvgate_mac INSIDE EDGE tndiff
n1uvgate_mac_coin_edge = n1uvgate_mac COIN EDGE tndiff
n1uvgate_mac_WL = DFM PROPERTY n1uvgate_mac n1uvgate_mac_in_edge n1uvgate_mac_coin_edge MULTI OVERLAP
       [ drawn_w = (length(n1uvgate_mac_in_edge) + length(n1uvgate_mac_coin_edge))/2 ]
       [ drawn_l = area(n1uvgate_mac)/property_ref(drawn_w) ]
nch_ulvt_dnw_mac_ODN_layer = DEVICE LAYER TEMPLATE "nch_ulvt_dnw_mac" ANNOTATE OD_p n1uvgate_mac_WL
       [PROPERTY ODN, pname, drawn_w, drawn_l
       ODN = DFM_NUM_VAL( OD_p, ODNET)
       pname = "nch_ulvt_dnw_mac"
       drawn_w = DFM_NUM_VAL( n1uvgate_mac_WL, "drawn_w" )
       drawn_l = DFM_NUM_VAL( n1uvgate_mac_WL, "drawn_l" )
       ]
