    ftip = area(mom48_extc) / nr / w
    s   = perimeter_coincide(MOM_hole4, fmom48_reg_pw) / (nr-1) / 2
    lr  = perimeter(MOM_hole4) / 2 / (nr-1) - s - 2 * ftip
    stm = 4
    spm = 8
    shield = 2
    dmflag = 0
]
