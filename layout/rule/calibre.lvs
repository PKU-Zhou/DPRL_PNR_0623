    nr = count(MOM_field6)
    w =  perimeter_coincide(MOM_field6,fmom68_rf_reg_pw_110g)/ nr
    ftip = area(mom68_extc) / nr / w
    s   = perimeter_coincide(MOM_hole6, fmom68_rf_reg_pw_110g) / (nr-1) / 2
    lr  = perimeter(MOM_hole6) / 2 / (nr-1) - s - 2 * ftip
    stm = 6
    spm = 8
    shield = 2
    dmflag = 0
]
DEVICE cfmom_wo_rf_110g fmom68_rf_reg_ntn_110g M8(PLUS) M8(MINUS) psub(BULK) <MOM_field6> <MOM_hole6> <mom68_extc> (PLUS MINUS) [
    property w,s,nr,lr,stm,spm,dmflag,shield
    nr = count(MOM_field6)
    w =  perimeter_coincide(MOM_field6,fmom68_rf_reg_ntn_110g)/ nr
    ftip = area(mom68_extc) / nr / w
    s   = perimeter_coincide(MOM_hole6, fmom68_rf_reg_ntn_110g) / (nr-1) / 2
    lr  = perimeter(MOM_hole6) / 2 / (nr-1) - s - 2 * ftip
    stm = 6
    spm = 8
    shield = 3
    dmflag = 0
]
DEVICE cfmom_wo_rf_110g fmom68_rf_reg_nw_dm_110g M8(PLUS) M8(MINUS) nxwell(BULK) <MOM_field6> <MOM_hole6> <mom68_extc>   <dmetal1> <dmetal2> <dmetal3> <dmetal4> <dmetal5> (PLUS MINUS) [
    property w,s,nr,lr,stm,spm,dmflag,shield
    nr = count(MOM_field6)
    w =  perimeter_coincide(MOM_field6,fmom68_rf_reg_nw_dm_110g)/ nr
    ftip = area(mom68_extc)/(nr*w)
    s   = perimeter_coincide(MOM_hole6, fmom68_rf_reg_nw_dm_110g) / (nr-1) / 2
    lr  = perimeter(MOM_hole6) / 2 / (nr-1) - s - 2 * ftip
    stm = 6
    spm = 8
    shield = 1
    ftip = area(mom68_extc)/(nr*w)
    moml = lr + 2*ftip
    momw = (perimeter(fmom68_rf_reg_nw_dm_110g) - (2*moml))/2
    xlen = momw + (2*0.34e-6)
    ylen = moml + (2*0.455e-6)
    dmmax = 0
    dmmin = 1
    dm1 = area(dmetal1) / (xlen * ylen )
    IF( dm1 < dmmin ) { dmmin = dm1 }
    IF( dm1 > dmmax ) { dmmax = dm1 }
    dm2 = area(dmetal2) / (xlen * ylen )
    IF( dm2 < dmmin ) { dmmin = dm2 }
    IF( dm2 > dmmax ) { dmmax = dm2 }
    dm3 = area(dmetal3) / (xlen * ylen )
    IF( dm3 < dmmin ) { dmmin = dm3 }
    IF( dm3 > dmmax ) { dmmax = dm3 }
    dm4 = area(dmetal4) / (xlen * ylen )
    IF( dm4 < dmmin ) { dmmin = dm4 }
    IF( dm4 > dmmax ) { dmmax = dm4 }
    dm5 = area(dmetal5) / (xlen * ylen )
    IF( dm5 < dmmin ) { dmmin = dm5 }
    IF( dm5 > dmmax ) { dmmax = dm5 }
    IF( dmmax > 0.11 && dmmax < 0.13 && dmmin > 0.11 && dmmin < 0.13 ) {
       dmflag = 1
    } ELSE {
       dmflag = 99
    }
]
DEVICE cfmom_wo_rf_110g fmom68_rf_reg_pw_dm_110g M8(PLUS) M8(MINUS) psub(BULK) <MOM_field6> <MOM_hole6> <mom68_extc>   <dmetal1> <dmetal2> <dmetal3> <dmetal4> <dmetal5> (PLUS MINUS) [
