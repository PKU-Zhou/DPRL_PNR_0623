DEVICE cfmom_wo_rf fmom24_rf_reg_ntn M4(PLUS) M4(MINUS) psub(BULK) <MOM_field2> <MOM_hole2> <mom24_extc> (PLUS MINUS) [
    property w,s,nr,lr,stm,spm,dmflag,shield
    nr = count(MOM_field2)
