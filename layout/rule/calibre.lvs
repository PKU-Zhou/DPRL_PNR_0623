    ftip = area(mom37_extc)/(nr*w)
    s   = perimeter_coincide(MOM_hole3, fmom37_wi_reg_p_dm) / (nr-1) / 2
    lr  = perimeter(MOM_hole3) / 2 / (nr-1) - s - 2 * ftip
    stm = 3
    spm = 7
    ftip = area(mom37_extc)/(nr*w)
    moml = lr + 2*ftip
    momw = (perimeter(fmom37_wi_reg_p_dm) - (2*moml))/2
    xlen = momw + (2*0.34e-6)
    ylen = moml + (2*0.46e-6)
    dmmax = 0
    dmmin = 1
    dm2 = area(dmetal2) / (xlen * ylen )
    IF( dm2 < dmmin ) { dmmin = dm2 }
    IF( dm2 > dmmax ) { dmmax = dm2 }
    IF( dmmax > 0.11 && dmmax < 0.13 && dmmin > 0.11 && dmmin < 0.13 ) {
       dmflag = 1
    } ELSE {
       dmflag = 99
    }
]



