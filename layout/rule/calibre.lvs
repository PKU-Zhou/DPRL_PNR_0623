       [PROPERTY ODN, pname, drawn_w, drawn_l
       ODN = DFM_NUM_VAL( OD_p, ODNET)
       pname = "nch_lvt_dnw_mac"
       drawn_w = DFM_NUM_VAL( n1lvgate_mac_WL, "drawn_w" )
       drawn_l = DFM_NUM_VAL( n1lvgate_mac_WL, "drawn_l" )
       ]
