    ftip = area(mom24_extc) / nr / w
    s   = perimeter_coincide(MOM_hole2, fmom24_reg_pw) / (nr-1) / 2
    lr  = perimeter(MOM_hole2) / 2 / (nr-1) - s - 2 * ftip
    stm = 2
    spm = 4
    shield = 2
    dmflag = 0
]
