   WPEX_1 = DFM_VEC_VAL( pIO_WPEPROP, "PER_1" )
   WPEX_2 = DFM_VEC_VAL( pIO_WPEPROP, "PER_2" )
   WPEY_1 = DFM_VEC_VAL( pIO_WPEPROP, "PAR_1" )
