DEVICE cfmom_wo_mx fmom46_mx_reg_nw mom6p1(PLUS1) mom6m1(MINUS1) mom6p2(PLUS2) mom6m2(MINUS2) nxwell(BULK) <MOM_field4> <MOM_hole4> <mom46_mx_aux> <mom46_extc> [
