fmom13_mx_reg_p1   = fmom13_mx_reg INTERACT p_polymom


fmom13_mx_reg_4t    = fmom13_mx_reg3 INTERACT MOMDMY27                    // FMOM MX 4T

fmom13_mx_reg_nw1a   = fmom13_mx_reg4 INTERACT MOMDMY31 
fmom13_mx_reg_nw1    = fmom13_mx_reg_nw1a NOT INTERACT MOMDMY34

