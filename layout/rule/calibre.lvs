#IFDEF extract_as_ad
DEVICE nch_6d5ud3d3_hv18_dnw_mac ngate_hv18_ud3d3_mac d_tndiff_hv(D) ngate_hv18_ud3d3_mac(G) s_tndiff_hv(S) psub(B) psub_under(SUB) <nthin2_hv> <pwell_dnw> <aux_pwell_dnw_gate_count> <d_hvnw_area> [ 
  property W,L,AS,AD
  W=(perimeter_coincide(ngate_hv18_ud3d3_mac, s_tndiff_hv ) + perimeter_coincide(ngate_hv18_ud3d3_mac, d_tndiff_hv)) / 2
  L=area(ngate_hv18_ud3d3_mac) / W
  PI_S_OD = perimeter_inside(S,nthin2_hv)
  PI_D_OD = perimeter_inside(D,nthin2_hv)
  gate_count = dfm_numeric_value (aux_pwell_dnw_gate_count,count_num)
  IF(PI_S_OD == 0) {
   AD = area(pwell_dnw) / gate_count
   AS = area(d_hvnw_area) * W / PI_D_OD }
  ELSE IF(PI_D_OD == 0) {
   AS = area(S) * W / PI_S_OD
   AD = area(pwell_dnw) / gate_count }
  ELSE {
   AS = area(S) * W / PI_S_OD
   AD = area(pwell_dnw) / gate_count }
]
#ELSE
DEVICE nch_6d5ud3d3_hv18_dnw_mac ngate_hv18_ud3d3_mac d_tndiff_hv(D) ngate_hv18_ud3d3_mac(G) s_tndiff_hv(S) psub(B) psub_under(SUB) [ 
  property W,L
  W=(perimeter_coincide(ngate_hv18_ud3d3_mac, s_tndiff_hv ) + perimeter_coincide(ngate_hv18_ud3d3_mac, d_tndiff_hv)) / 2
  L=area(ngate_hv18_ud3d3_mac) / W
]
#ENDIF

#ENDIF

#IFDEF RC_DECK
#IFDEF MULTI_DEVICE_EXTRACTION
nch_6d5ud3d3_hv18_dnw_mac_ODN_layer = DEVICE LAYER nch_6d5ud3d3_hv18_dnw_mac ANNOTATE
       [PROPERTY pname
       pname = "nch_6d5ud3d3_hv18_dnw_mac"
       ]
LVS ANNOTATE DEVICES nch_6d5ud3d3_hv18_dnw_mac_ODN_layer
#ENDIF
#ENDIF

TRACE PROPERTY nch_6d5ud3d3_hv18_dnw_mac L L MOS_Lerr
TRACE PROPERTY nch_6d5ud3d3_hv18_dnw_mac W W MOS_Werr
LVS DEVICE TYPE LDDNMOS nch_6d5ud3d3_hv18_dnw_mac [D=D G=G S=S]

DEVICE ndio_hia_mac hia_ndio_r psub(PLUS) tndiff_woR(MINUS) <hia_ndio> [
  property l,w,nf
  nf = count(hia_ndio)
  A_DIO = area(hia_ndio)/nf
  P_DIO = perimeter(hia_ndio)/nf
  P_2_DIO = P_DIO * P_DIO
  AD4 = A_DIO * 16
  KKK = P_2_DIO-AD4
  IF(KKK<0) {
  KKK=0
  }
  SQ = sqrt(KKK)
  l = (P_DIO+SQ)/4
  w = (P_DIO-SQ)/4
]
TRACE PROPERTY ndio_hia_mac w  w  DIO_Werr
TRACE PROPERTY ndio_hia_mac l  l  DIO_Lerr
TRACE PROPERTY ndio_hia_mac nf nf 0 

   #IFDEF RC_DECK
DEVICE nmos_rf_18_5t ngate_nthin_18_5t d_tndiff(D) n_poly_rf(G) s_tndiff(S) psub(B) DNW(NG) <ngate_rf_18> <gcon_aux> <gcon_aux2> <nmos_SOB> <dinsaflag_aux> <cbflag_aux>   <aux_ngate_nthin_5t> [
   #ELSE
DEVICE nmos_rf_18_5t ngate_nthin_18_5t d_tndiff(D) n_poly_rf(G) s_tndiff(S) psub(B) DNW(NG) <ngate_rf_18> <gcon_aux> <gcon_aux2> <dinsaflag_aux> <cbflag_aux>   [
   #ENDIF
   property lr,wr,nr,ngcon,dinsaflag,cbflag
   #IFDEF RC_DECK
   ,sobn,sobs,sobw,sobe,rcmflag,odnum_rf
   #ENDIF

   nr = count(ngate_rf_18)
   wr = ((perimeter_coincide(ngate_rf_18,s_tndiff)+ perimeter_coincide(ngate_rf_18,d_tndiff))/2)/nr
   lr = (area(ngate_rf_18)/wr)/nr
   #IFDEF RC_DECK
   rcmflag = 0

   RFX_1 = DFM_VEC_VAL( nmos_SOB, "PER_1" )
   RFX_2 = DFM_VEC_VAL( nmos_SOB, "PER_2" )
   RFY_1 = DFM_VEC_VAL( nmos_SOB, "PAR_1" )
   RFY_2 = DFM_VEC_VAL( nmos_SOB, "PAR_2" )

   sobn = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_1, UNIT_LENGTH())
   sobs = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFX_2, UNIT_LENGTH())
   sobw = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_1, UNIT_LENGTH())
   sobe = TVF_NUM_FUN ("cal_sobv_dfm", "device_function", RFY_2, UNIT_LENGTH())
   odnum_rf = dfm_numeric_value (aux_ngate_nthin_5t,count_num)
   #ENDIF
   IF(count(gcon_aux2)/count(gcon_aux) == nr){ ngcon = count(gcon_aux) }ELSE{ ngcon = 99 }
   dinsaflag = 0
   len_dinsaflag_aux = perimeter(dinsaflag_aux)/2 - MINGRID_RECT1_UNIT
   if(len_dinsaflag_aux > MINGRID_RECT1_01_UNIT) {
