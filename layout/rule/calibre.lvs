#IFDEF extract_dnwdio
DEVICE D(pwdnw) rwdio psub DNW
TRACE PROPERTY D(pwdnw) a a DIOWELL_Aerr 
DEVICE D(dnwpsub) dnwdio psub_term DNW [
   property a,pj
   a = area(DNW)
   pj = perimeter(DNW)
]
TRACE PROPERTY D(dnwpsub) a a DIOWELL_Aerr
#ENDIF

DEVICE D(dnwpsub_iso) dnwdio_iso psub_term DNW [
   property a,pj
   a = area(DNW)
   pj = perimeter(DNW)
]
LVS FILTER D(dnwpsub_iso) LAYOUT OPEN


pwell_dnw = psub INTERACT ngate_hv18_ud3d3_mac
aux_pwell_dnw_gate_count = DFM PROPERTY pwell_dnw ngate_hv18_ud3d3_mac OVERLAP
                            [ count_num = COUNT(ngate_hv18_ud3d3_mac)]

  #IFDEF RC_DECK
#IFDEF DFM_RULE
DEVICE nch_6d5ud3d3_hv18_dnw_mac ngate_hv18_ud3d3_mac d_tndiff_hv(D) ngate_hv18_ud3d3_mac(G) s_tndiff_hv(S) psub(B) psub_under(SUB) <nthin2_hv> <OD> <lod_PROP> <nIO_WPEPROP> <ngate_PROP> <pwell_dnw> <aux_pwell_dnw_gate_count> <d_hvnw_area> <hvn_nrd_aux> netlist model nch_6d5ud3d3_hv18_dnw_mac netlist element "X" [
   property sa,sb,sca,scb,scc,W,L,AS,AD,PD,PS,NRD,NRS,sa1,sb1,sa2,sb2,sa3,sb3,DNW_AREA,DNW_PJ,NW_AREA,NW_PJ
   #IFNDEF SKIP_PSE
   ,spa,spa1,spa2,spa3,sap,sa4,spba,spba1,sapb,enx,enx1,eny,eny1,eny2,rex,rey
   #ENDIF
   #IFNDEF SKIP_ODSE
   ,sodx,sodx1,sodx2,sa5,sa6,sody,sodx4,sa7,sodxa,sodxb
   #ENDIF
   #IFNDEF SKIP_MBE
   ,spmt,spomt,spomt1,spmb,spomb,spomb1
   #ENDIF
   LR_EXT  = MOS_LR_EXT
   TOP_EXT = 0
   BOT_EXT = NMOS_BOT_EXT
   SCALE = PRESCALE
   W=(perimeter_coincide(ngate_hv18_ud3d3_mac, s_tndiff_hv ) + perimeter_coincide(ngate_hv18_ud3d3_mac, d_tndiff_hv)) / 2
   L=area(ngate_hv18_ud3d3_mac) / W
   DNW_AREA = 0
   DNW_PJ   = 0
   NW_AREA  = 0
   NW_PJ    = 0
   LODX_1 = DFM_VEC_VAL( lod_PROP, "PER_1" )
   LODX_2 = DFM_VEC_VAL( lod_PROP, "PER_2" )
   sa = TVF_NUM_FUN( "calc_lod_sasb", "device_function", LODX_1, W, L, UNIT_LENGTH(), SCALE )
   sb = TVF_NUM_FUN( "calc_lod_sasb", "device_function", LODX_2, W, L, UNIT_LENGTH(), SCALE )
   sa1 = TVF_NUM_FUN ( "calc_lod_sa1sb1", "device_function", LODX_1, W, L, UNIT_LENGTH(), SCALE )
   sb1 = TVF_NUM_FUN ( "calc_lod_sa1sb1", "device_function", LODX_2, W, L, UNIT_LENGTH(), SCALE )
   sa2 = TVF_NUM_FUN ( "calc_lod_sa2sb2", "device_function", LODX_1, W, L, UNIT_LENGTH(), SCALE )
   sb2 = TVF_NUM_FUN ( "calc_lod_sa2sb2", "device_function", LODX_2, W, L, UNIT_LENGTH(), SCALE )
   sa3 = TVF_NUM_FUN ( "calc_lod_sa3sb3", "device_function", LODX_1, W, L, UNIT_LENGTH(), SCALE )
   sb3 = TVF_NUM_FUN ( "calc_lod_sa3sb3", "device_function", LODX_2, W, L, UNIT_LENGTH(), SCALE )
   PI_S_OD = perimeter_inside(S,nthin2_hv)
   PI_D_OD = perimeter_inside(D,nthin2_hv)
   gate_count = dfm_numeric_value (aux_pwell_dnw_gate_count,count_num) 
   IF(PI_S_OD == 0) {
    AD = area(pwell_dnw) / gate_count
    AS = area(d_hvnw_area) * W / PI_D_OD
    PD = perimeter(pwell_dnw) / gate_count 
    PS = perimeter(d_hvnw_area) * W / PI_D_OD } 
   ELSE IF(PI_D_OD == 0) {
    AS = area(S) * W / PI_S_OD
    AD = area(pwell_dnw) / gate_count
    PS = perimeter(S) * W /PI_S_OD
    PD = perimeter(pwell_dnw) / gate_count } 
   ELSE {
    AS = area(S) * W / PI_S_OD
    AD = area(pwell_dnw) / gate_count 
    PS = perimeter(S) * W /PI_S_OD
    PD = perimeter(pwell_dnw) / gate_count }
 #IFDEF ZERO_NRS_NRD 
   NRS = 0
 #ELSE
   NRS = AS / W / W
 #ENDIF 
   NRD_1 = area(D) - 2 * area(hvn_nrd_aux)
   NRD_2 = NRD_1 * W / PI_D_OD
   NRD   = NRD_2 / W / W
// Well proximity.
   WPEX_1 = DFM_VEC_VAL( nIO_WPEPROP, "PER_1" )
   WPEX_2 = DFM_VEC_VAL( nIO_WPEPROP, "PER_2" )
   WPEY_1 = DFM_VEC_VAL( nIO_WPEPROP, "PAR_1" )
   WPEY_2 = DFM_VEC_VAL( nIO_WPEPROP, "PAR_2" )
   sca = TVF_NUM_FUN( "calc_sca2_dfm", "device_function", WPEX_1, WPEX_2, WPEY_1, WPEY_2, W, L, LR_EXT, TOP_EXT, BOT_EXT, UNIT_LENGTH(), SCALE, WPED )
