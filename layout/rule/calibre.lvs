fmom47_rf_reg_nw1   = fmom47_rf_reg5 INTERACT MOMDMY31
fmom47_rf_reg_nw2   = fmom47_rf_reg_nw1 INTERACT nxwell              
fmom47_rf_reg_nwa        = fmom47_rf_reg_nw2 NOT INTERACT MOM_dmetal1_3
