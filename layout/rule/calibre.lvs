TEMPLATE "nch_suhvt_dnw_mac" 
dnsuhvgate_mac_in_edge = dnsuhvgate_mac INSIDE EDGE tndiff
dnsuhvgate_mac_coin_edge = dnsuhvgate_mac COIN EDGE tndiff
dnsuhvgate_mac_WL = DFM PROPERTY dnsuhvgate_mac dnsuhvgate_mac_in_edge dnsuhvgate_mac_coin_edge MULTI OVERLAP
       [ drawn_w = (length(dnsuhvgate_mac_in_edge) + length(dnsuhvgate_mac_coin_edge))/2 ]
       [ drawn_l = area(dnsuhvgate_mac)/property_ref(drawn_w) ]
nch_suhvt_dnw_mac_ODN_layer = DEVICE LAYER TEMPLATE "nch_suhvt_dnw_mac" ANNOTATE OD_p dnsuhvgate_mac_WL
       [PROPERTY ODN, pname, drawn_w, drawn_l
       ODN = DFM_NUM_VAL( OD_p, ODNET)
       pname = "nch_suhvt_dnw_mac"
       drawn_w = DFM_NUM_VAL( dnsuhvgate_mac_WL, "drawn_w" )
       drawn_l = DFM_NUM_VAL( dnsuhvgate_mac_WL, "drawn_l" )
       ]
LVS ANNOTATE DEVICES nch_suhvt_dnw_mac_ODN_layer
#ENDIF

