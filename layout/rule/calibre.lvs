      sodx1 = TVF_NUM_FUN ( "compute_sodx1","parameter_equation", G2ODX_1, G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
      sodx2 = TVF_NUM_FUN ( "compute_sodx2","parameter_equation", G2ODX_1, G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
