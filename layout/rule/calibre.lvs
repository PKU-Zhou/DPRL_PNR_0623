    lr  = perimeter(MOM_hole4) / 2 / (nr-1) - s - 2 * ftip
    stm = 4
    spm = 7
    shield = 2
    dmflag = 0
]
DEVICE cfmom_wo_rf_110g fmom47_rf_reg_ntn_110g M7(PLUS) M7(MINUS) psub(BULK) <MOM_field4> <MOM_hole4> <mom47_extc> (PLUS MINUS) [
    property w,s,nr,lr,stm,spm,dmflag,shield
    nr = count(MOM_field4)
    w =  perimeter_coincide(MOM_field4,fmom47_rf_reg_ntn_110g)/ nr
    ftip = area(mom47_extc) / nr / w
    s   = perimeter_coincide(MOM_hole4, fmom47_rf_reg_ntn_110g) / (nr-1) / 2
    lr  = perimeter(MOM_hole4) / 2 / (nr-1) - s - 2 * ftip
    stm = 4
    spm = 7
    shield = 3
    dmflag = 0
]
DEVICE cfmom_wo_rf_110g fmom47_rf_reg_nw_dm_110g M7(PLUS) M7(MINUS) nxwell(BULK) <MOM_field4> <MOM_hole4> <mom47_extc>   <dmetal1> <dmetal2> <dmetal3> (PLUS MINUS) [
    property w,s,nr,lr,stm,spm,dmflag,shield
    nr = count(MOM_field4)
    w =  perimeter_coincide(MOM_field4,fmom47_rf_reg_nw_dm_110g)/ nr
    ftip = area(mom47_extc)/(nr*w)
    s   = perimeter_coincide(MOM_hole4, fmom47_rf_reg_nw_dm_110g) / (nr-1) / 2
    lr  = perimeter(MOM_hole4) / 2 / (nr-1) - s - 2 * ftip
    stm = 4
    spm = 7
    shield = 1
    ftip = area(mom47_extc)/(nr*w)
    moml = lr + 2*ftip
    momw = (perimeter(fmom47_rf_reg_nw_dm_110g) - (2*moml))/2
    xlen = momw + (2*0.34e-6)
    ylen = moml + (2*0.455e-6)
    dmmax = 0
    dmmin = 1
    dm1 = area(dmetal1) / (xlen * ylen )
    IF( dm1 < dmmin ) { dmmin = dm1 }
    IF( dm1 > dmmax ) { dmmax = dm1 }
    dm2 = area(dmetal2) / (xlen * ylen )
    IF( dm2 < dmmin ) { dmmin = dm2 }
    IF( dm2 > dmmax ) { dmmax = dm2 }
    dm3 = area(dmetal3) / (xlen * ylen )
    IF( dm3 < dmmin ) { dmmin = dm3 }
    IF( dm3 > dmmax ) { dmmax = dm3 }
    IF( dmmax > 0.11 && dmmax < 0.13 && dmmin > 0.11 && dmmin < 0.13 ) {
       dmflag = 1
    } ELSE {
       dmflag = 99
    }
]
DEVICE cfmom_wo_rf_110g fmom47_rf_reg_pw_dm_110g M7(PLUS) M7(MINUS) psub(BULK) <MOM_field4> <MOM_hole4> <mom47_extc>   <dmetal1> <dmetal2> <dmetal3> (PLUS MINUS) [
