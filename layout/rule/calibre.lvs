fmom16_mx_reg_pw2   = fmom16_mx_reg_pw1 INTERACT psub

fmom16_mx_reg_pw    = fmom16_mx_reg_pw2 NOT INTERACT MOM_dmetal1_0  // FMOM MX 5T wi PW shield wo DM



fmom16_mx_reg_ntn1   = fmom16_mx_reg6 INTERACT MOMDMY33
