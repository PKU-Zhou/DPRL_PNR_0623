      pmet2 = DFM_VEC_VAL( ngate_PROP, "PMET2" )
      spmt   = TVF_NUM_FUN( "compute_spm",   "mbe_equation", pmet2, L, UNIT_LENGTH(), SCALE )
      spomt  = TVF_NUM_FUN( "compute_spom",  "mbe_equation", pmet2, L, UNIT_LENGTH(), SCALE )
      spomt1 = TVF_NUM_FUN( "compute_spom1", "mbe_equation", pmet2, L, UNIT_LENGTH(), SCALE )
      spmb   = TVF_NUM_FUN( "compute_spm",   "mbe_equation", pmet1, L, UNIT_LENGTH(), SCALE )
      spomb  = TVF_NUM_FUN( "compute_spom",  "mbe_equation", pmet1, L, UNIT_LENGTH(), SCALE )
      spomb1 = TVF_NUM_FUN( "compute_spom1", "mbe_equation", pmet1, L, UNIT_LENGTH(), SCALE )
   #ENDIF
]
#IFDEF MULTI_DEVICE_EXTRACTION
TEMPLATE "nch_hia25_dnw_mac" 
nrgate_hia25_mac_in_edge = nrgate_hia25_mac INSIDE EDGE tndiff
nrgate_hia25_mac_coin_edge = nrgate_hia25_mac COIN EDGE tndiff
nrgate_hia25_mac_WL = DFM PROPERTY nrgate_hia25_mac nrgate_hia25_mac_in_edge nrgate_hia25_mac_coin_edge MULTI OVERLAP
       [ drawn_w = (length(nrgate_hia25_mac_in_edge) + length(nrgate_hia25_mac_coin_edge))/2 ]
       [ drawn_l = area(nrgate_hia25_mac)/property_ref(drawn_w) ]
nch_hia25_dnw_mac_ODN_layer = DEVICE LAYER TEMPLATE "nch_hia25_dnw_mac" ANNOTATE OD_p nrgate_hia25_mac_WL
       [PROPERTY ODN, pname, drawn_w, drawn_l
       ODN = DFM_NUM_VAL( OD_p, ODNET)
       pname = "nch_hia25_dnw_mac"
       drawn_w = DFM_NUM_VAL( nrgate_hia25_mac_WL, "drawn_w" )
       drawn_l = DFM_NUM_VAL( nrgate_hia25_mac_WL, "drawn_l" )
       ]
