      PER_2  = DFM_VEC_VAL( pgate_PROP, "PER_2" )
      PAR_1  = DFM_VEC_VAL( pgate_PROP, "PAR_1" )
      PAR_2  = DFM_VEC_VAL( pgate_PROP, "PAR_2" )
