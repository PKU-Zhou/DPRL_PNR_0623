   sodxb = TVF_NUM_FUN ( "compute_sodxab","parameter_equation", G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
   sodx  = TVF_NUM_FUN ( "compute_sodx", "parameter_equation", G2ODX_1, G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
