   NRD = 0
 #ELSE 
   NRS = AS / W / W
   NRD = AD / W / W
 #ENDIF 
]

DEVICE MN(nchpg_ellsr) ngate_pg_ellsr ngate_pg_ellsr(G) tndiff(S) tndiff(D) psub(B) <nthin1> netlist model nchpg_ellsr [
  property W,L,AS,AD,PD,PS,NRD,NRS
   SCALE = PRESCALE
   W = (perimeter_coincide(ngate_pg_ellsr, tndiff ) + perimeter_inside(ngate_pg_ellsr, tndiff)) / 2
   L = area(ngate_pg_ellsr) / W
   PI_S_OD = perimeter_inside(S,nthin1)
   PI_D_OD = perimeter_inside(D,nthin1)
   IF(PI_S_OD == 0) {
    AD = area(D) * W / PI_D_OD
    AS = AD
    PD = perimeter(D) * W /PI_D_OD
    PS = PD } 
   ELSE IF(PI_D_OD == 0) {
    AS = area(S) * W / PI_S_OD
    AD = AS
    PS = perimeter(S) * W /PI_S_OD
    PD = PS } 
   ELSE {
    AS = area(S) * W / PI_S_OD
    AD = area(D) * W / PI_D_OD
    PS = perimeter(S) * W /PI_S_OD
    PD = perimeter(D) * W /PI_D_OD }
 #IFDEF ZERO_NRS_NRD 
