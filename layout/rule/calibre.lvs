   property sa,sb,sca,scb,scc,W,L,AS,AD,PD,PS,NRD,NRS,sa1,sb1,sa2,sb2,sa3,sb3
   #IFNDEF SKIP_PSE
   ,spa,spa1,spa2,spa3,sap,sa4,spba,spba1,sapb,enx,enx1,eny,eny1,eny2,rex,rey
   #ENDIF
