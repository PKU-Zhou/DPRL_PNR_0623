DEVICE D(nwdio_iso) pnwdio_r_iso psub DNW <DNW_HVD_N> [
   property a,pj
   a = area(pnwdio_r_iso)
   pj = perimeter(pnwdio_r_iso) - perimeter_coincide(pnwdio_r_iso,DNW_HVD_N)
]
LVS FILTER D(nwdio_iso) LAYOUT OPEN

DEVICE pdio_hia_mac hia_pdio_r tpdiff_woR(PLUS) nxwell(MINUS) <hia_pdio> [
  property l,w,nf
  nf = count(hia_pdio)
  A_DIO = area(hia_pdio)/nf
  P_DIO = perimeter(hia_pdio)/nf
  P_2_DIO = P_DIO * P_DIO
  AD4 = A_DIO * 16
  KKK = P_2_DIO-AD4
  IF(KKK<0) {
  KKK=0
  }
  SQ = sqrt(KKK)
  l = (P_DIO+SQ)/4
  w = (P_DIO-SQ)/4
]
TRACE PROPERTY pdio_hia_mac w  w  DIO_Werr
TRACE PROPERTY pdio_hia_mac l  l  DIO_Lerr
TRACE PROPERTY pdio_hia_mac nf nf 0 

