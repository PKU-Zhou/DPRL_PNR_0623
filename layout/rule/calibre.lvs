   #ENDIF
   LR_EXT = MOS_LR_EXT
   TOP_EXT = PMOS_TOP_EXT
   BOT_EXT = 0
   SCALE = PRESCALE
   W = (perimeter_coincide(pgate_hv18_ud5d5_mac, s_tpdiff_hv ) + perimeter_coincide(pgate_hv18_ud5d5_mac, d_tpdiff_hv)) / 2
