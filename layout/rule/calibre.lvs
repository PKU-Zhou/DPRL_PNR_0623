   G2SP_1 = DFM_VEC_VAL( ngate_PROP, "G2SP_P_1" )
   G2SP_2 = DFM_VEC_VAL( ngate_PROP, "G2SP_P_2" )
   G2SE_1 = DFM_VEC_VAL( ngate_PROP, "G2SP_E_1" )
   G2SE_2 = DFM_VEC_VAL( ngate_PROP, "G2SP_E_2" )
