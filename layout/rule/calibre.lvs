    w =  perimeter_coincide(MOM_field4,mom46_mx_aux)/ (nr*mf1)
    ftip = area(mom46_extc) / (nr*mf1) / w
    s   = perimeter_coincide(MOM_hole4, mom46_mx_aux) / (mf1*(nr-1)) / 2
