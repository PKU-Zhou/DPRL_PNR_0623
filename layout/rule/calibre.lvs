      eny1 = TVF_NUM_FUN ( "compute_eny1", "device_function", PAR_1, PAR_2, W, L, UNIT_LENGTH(), SCALE )
      eny2 = TVF_NUM_FUN ( "compute_eny2", "device_function", PAR_1, PAR_2, W, L, UNIT_LENGTH(), SCALE )
