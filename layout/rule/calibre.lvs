fmom57_mx_reg_ntn_dm = fmom57_mx_reg_ntn2 INTERACT MOM_dmetal1_4     // FMOM MX 5T wi NTN shield wi DM



fmom57_rf_reg1     = mom57_Left8 NOT INTERACT mom57_idt
fmom57_rf_reg2     = fmom57_rf_reg1 INTERACT MOMDMY100
fmom57_rf_reg3     = fmom57_rf_reg2 NOT INTERACT MOMDMY22
fmom57_rf_reg4     = fmom57_rf_reg3 INTERACT RFDMY
fmom57_rf_reg5     = fmom57_rf_reg4 NOT INTERACT MOMDMY27
fmom57_rf_reg6     = fmom57_rf_reg5 NOT INTERACT MOMDMY31
fmom57_rf_reg7     = fmom57_rf_reg6 NOT INTERACT MOMDMY32
fmom57_rf_reg8     = fmom57_rf_reg7 NOT INTERACT MOMDMY33

fmom57_rf_reg_nw1   = fmom57_rf_reg5 INTERACT MOMDMY31
fmom57_rf_reg_nw2   = fmom57_rf_reg_nw1 INTERACT nxwell              
fmom57_rf_reg_nwa        = fmom57_rf_reg_nw2 NOT INTERACT MOM_dmetal1_4
fmom57_rf_reg_nw         = fmom57_rf_reg_nwa NOT INTERACT RFDMY_mmW            // FMOM 3T RF wi NW shield wo DM
fmom57_rf_reg_nw_110g    = fmom57_rf_reg_nwa INTERACT RFDMY_mmW                // mmW FMOM 3T RF wi NW shield wo DM
fmom57_rf_reg_nw_dma     = fmom57_rf_reg_nw2 INTERACT MOM_dmetal1_4
fmom57_rf_reg_nw_dm      = fmom57_rf_reg_nw_dma NOT INTERACT RFDMY_mmW        // FMOM 3T RF wi NW shield wi DM
fmom57_rf_reg_nw_dm_110g = fmom57_rf_reg_nw_dma INTERACT RFDMY_mmW            // mmW FMOM 3T RF wi NW shield wi DM

fmom57_rf_reg_pw1   = fmom57_rf_reg6 INTERACT MOMDMY32
fmom57_rf_reg_pw2   = fmom57_rf_reg_pw1 INTERACT psub                
fmom57_rf_reg_pwa        = fmom57_rf_reg_pw2 NOT INTERACT MOM_dmetal1_4
fmom57_rf_reg_pw         = fmom57_rf_reg_pwa NOT INTERACT RFDMY_mmW               // FMOM 3T RF wi PW shield wo DM
fmom57_rf_reg_pw_110g    = fmom57_rf_reg_pwa INTERACT RFDMY_mmW                   // mmW FMOM 3T RF wi PW shield wo DM
fmom57_rf_reg_pw_dma     = fmom57_rf_reg_pw2 INTERACT MOM_dmetal1_4
fmom57_rf_reg_pw_dm      = fmom57_rf_reg_pw_dma NOT INTERACT RFDMY_mmW            // FMOM 3T RF wi PW shield wi DM
fmom57_rf_reg_pw_dm_110g = fmom57_rf_reg_pw_dma INTERACT RFDMY_mmW                // mmW FMOM 3T RF wi PW shield wi DM

fmom57_rf_reg_ntn1   = fmom57_rf_reg7 INTERACT MOMDMY33
fmom57_rf_reg_ntn2   = fmom57_rf_reg_ntn1 INTERACT NT_N
fmom57_rf_reg_ntna        = fmom57_rf_reg_ntn2 NOT INTERACT MOM_dmetal1_4
fmom57_rf_reg_ntn         = fmom57_rf_reg_ntna NOT INTERACT RFDMY_mmW          // FMOM 3T RF wi NTN shield wo DM
fmom57_rf_reg_ntn_110g    = fmom57_rf_reg_ntna INTERACT RFDMY_mmW              // mmW FMOM 3T RF wi NTN shield wo DM
fmom57_rf_reg_ntn_dma     = fmom57_rf_reg_ntn2 INTERACT MOM_dmetal1_4
fmom57_rf_reg_ntn_dm      = fmom57_rf_reg_ntn_dma NOT INTERACT RFDMY_mmW       // FMOM 3T RF wi NTN shield wi DM
fmom57_rf_reg_ntn_dm_110g = fmom57_rf_reg_ntn_dma INTERACT RFDMY_mmW           // mmW FMOM 3T RF wi NTN shield wi DM



mom57_mx_aux   = mom57_Left8 AND MOMDMY22
mom57_extc = FM_tip7 NOT INTERACT MOM_field7 > 2


DEVICE cfmom_wo fmom57_reg_nw M7(PLUS) M7(MINUS) nxwell(BULK) <MOM_field5> <MOM_hole5> <mom57_extc> (PLUS MINUS) [
    property w,s,nr,lr,stm,spm,dmflag,shield
    nr = count(MOM_field5)
    w =  perimeter_coincide(MOM_field5,fmom57_reg_nw)/ nr
    ftip = area(mom57_extc) / nr / w
    s   = perimeter_coincide(MOM_hole5, fmom57_reg_nw) / (nr-1) / 2
    lr  = perimeter(MOM_hole5) / 2 / (nr-1) - s - 2 * ftip
    stm = 5
    spm = 7
    shield = 1
    dmflag = 0
]
DEVICE cfmom_wo fmom57_reg_pw M7(PLUS) M7(MINUS) psub(BULK) <MOM_field5> <MOM_hole5> <mom57_extc> (PLUS MINUS) [
