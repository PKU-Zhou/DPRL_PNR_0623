   sb3 = TVF_NUM_FUN ( "calc_lod_sa3sb3", "device_function", LODX_2, W, L, UNIT_LENGTH(), SCALE )
   PI_S_OD = perimeter_inside(S,pthin)
   PI_D_OD = perimeter_inside(D,pthin)
   IF(PI_S_OD == 0) {
    AD = area(D) * W / PI_D_OD
    AS = AD
    PD = perimeter(D) * W /PI_D_OD
    PS = PD } 
   ELSE IF(PI_D_OD == 0) {
