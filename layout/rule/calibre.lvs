    nr = count(MOM_field2)
    w =  perimeter_coincide(MOM_field2,fmom25_reg_ntn_wo_pring)/ nr
    ftip = area(mom25_extc) / nr / w
    s   = perimeter_coincide(MOM_hole2, fmom25_reg_ntn_wo_pring) / (nr-1) / 2
