  }
  ]
DEVICE MP(pchpu_ullsr) pgate_pu_ullsr_mac pgate_pu_ullsr_mac(G) tpdiff(S) tpdiff(D) nxwell(B) <pthin> [
  property W,L,AS,AD
   W=(perimeter_coincide(pgate_pu_ullsr_mac, tpdiff ) + perimeter_inside(pgate_pu_ullsr_mac, tpdiff)) / 2 
   L=area(pgate_pu_ullsr_mac) / W
  PI_S_OD = perimeter_inside(S,pthin)
  PI_D_OD = perimeter_inside(D,pthin)
  IF(PI_S_OD ==0) {
    AD = area(D) * W /PI_D_OD
    AS = AD
    }
  ELSE IF(PI_D_OD==0) {
    AS = area(S) * W /PI_S_OD
    AD = AS
    }
  ELSE {
  AS = area(S) * W /perimeter_inside(S,pthin)
  AD = area(D) * W /perimeter_inside(D,pthin)
  }
  ]


