poly = ( poly_org2 NOT n_poly ) NOT p_poly 
tndiff_cut = s_tndiff_hv OR d_tndiff_hv
tpdiff_cut = s_tpdiff_hv OR d_tpdiff_hv
all_woR_form = hia_pdio_r OR hia_ndio_r
tndiff_woR = tndiff_all INTERACT all_woR_form
tpdiff_woR = tpdiff_all INTERACT all_woR_form
tndiff = tndiff_all NOT ( tndiff_woR OR tndiff_cut )
tpdiff = tpdiff_all NOT ( tpdiff_woR OR tpdiff_cut )


