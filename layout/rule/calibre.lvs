fmom16_mx_reg_p1   = fmom16_mx_reg INTERACT p_polymom


fmom16_mx_reg_4t    = fmom16_mx_reg3 INTERACT MOMDMY27                    // FMOM MX 4T

fmom16_mx_reg_nw1a   = fmom16_mx_reg4 INTERACT MOMDMY31 
