DEVICE cmoscap_rf var11_cvar n_poly3(GATE) tndiff(BULK) psub(GNODE) <var11gt_rf> <nthin> [
  property lr,wr,br,gr
  gr = count(nthin)
  br = count(var11gt_rf)/gr
  wr = (perimeter_coincide(var11gt_rf,tndiff)/2)/(br*gr)
  lr = (area(var11gt_rf)/wr)/(br*gr)
]
