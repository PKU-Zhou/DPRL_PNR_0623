   LR_EXT = MOS_LR_EXT
   TOP_EXT = 0
   BOT_EXT = NMOS_BOT_EXT
   SCALE = PRESCALE
   W = (perimeter_coincide(dnavt2gate_mac, tndiff ) + perimeter_inside(dnavt2gate_mac, tndiff)) / 2
   L = area(dnavt2gate_mac) / W
