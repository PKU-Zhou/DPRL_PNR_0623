fmom37_mx_reg_ntn_dm = fmom37_mx_reg_ntn2 INTERACT MOM_dmetal1_2     // FMOM MX 5T wi NTN shield wi DM



fmom37_rf_reg1     = mom37_Left8 NOT INTERACT mom37_idt
