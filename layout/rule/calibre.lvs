//* Define device -- nmos nch_ulvt_dnw_mac
n1uvgate_mac = nuvgate_mac_ori AND dnwdmy  //  ULTRA LOW_VT NMOS DNW MAC

//* Define device -- nmos nch_uhvt_dnw_mac
nuhvgate_org1 = tngate6 AND UHVT_N 
nuhvgate_org = nuhvgate_org1 NOT OD_HG 
nuhvgate_mac_org = nuhvgate_org NOT LVSDMY 
dnuhvgate_mac = nuhvgate_mac_org AND dnwdmy  //  ULTRA HVT NMOS DNW MAC

//* Define device -- nmos nch_ehvt_dnw_mac
tngate6_c1 = tngate6 NOT OD18_15 
