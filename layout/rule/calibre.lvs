   LR_EXT = MOS_LR_EXT
   TOP_EXT = 0
   BOT_EXT = NMOS_BOT_EXT
   SCALE = PRESCALE
   W = (perimeter_coincide(dnavtgate_mac, tndiff ) + perimeter_inside(dnavtgate_mac, tndiff)) / 2
