   #IFNDEF SKIP_PSE
   ,spa,spa1,spa2,spa3,sap,sa4,spba,spba1,sapb,enx,enx1,eny,eny1,eny2,rex,rey
   #ENDIF
   #IFNDEF SKIP_ODSE
