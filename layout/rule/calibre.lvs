fmom13_rf_reg3     = fmom13_rf_reg2 NOT INTERACT MOMDMY22
fmom13_rf_reg4     = fmom13_rf_reg3 INTERACT RFDMY
fmom13_rf_reg5     = fmom13_rf_reg4 NOT INTERACT MOMDMY27
