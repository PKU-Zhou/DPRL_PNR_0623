fmom13_rf_reg_nw         = fmom13_rf_reg_nwa NOT INTERACT RFDMY_mmW            // FMOM 3T RF wi NW shield wo DM
fmom13_rf_reg_nw_110g    = fmom13_rf_reg_nwa INTERACT RFDMY_mmW                // mmW FMOM 3T RF wi NW shield wo DM

fmom13_rf_reg_pw1   = fmom13_rf_reg6 INTERACT MOMDMY32
