   sca = TVF_NUM_FUN( "calc_sca_dfm", "device_function", WPEX_1, WPEX_2, WPEY_1, WPEY_2, W, L, LR_EXT, TOP_EXT, BOT_EXT, UNIT_LENGTH(), SCALE, WPED )
