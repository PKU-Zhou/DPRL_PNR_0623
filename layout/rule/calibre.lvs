   W=(perimeter_coincide(ngate_ullrpsr, tndiff ) + perimeter_inside(ngate_ullrpsr, tndiff)) / 2
   L=area(ngate_ullrpsr) / W
   PI_S_OD = perimeter_inside(S,nthin1)
