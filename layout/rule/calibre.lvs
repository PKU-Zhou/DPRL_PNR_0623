   sa6   = TVF_NUM_FUN ( "compute_sa6",  "parameter_equation", G2ODX_1, G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
   sa7   = TVF_NUM_FUN ( "compute_sa7",  "parameter_equation", G2ODX_1, G2ODX_2, W, L, UNIT_LENGTH(), SCALE )
