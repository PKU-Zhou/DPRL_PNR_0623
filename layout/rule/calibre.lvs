fmom37_rf_reg3     = fmom37_rf_reg2 NOT INTERACT MOMDMY22
fmom37_rf_reg4     = fmom37_rf_reg3 INTERACT RFDMY
fmom37_rf_reg5     = fmom37_rf_reg4 NOT INTERACT MOMDMY27
fmom37_rf_reg6     = fmom37_rf_reg5 NOT INTERACT MOMDMY31
fmom37_rf_reg7     = fmom37_rf_reg6 NOT INTERACT MOMDMY32
fmom37_rf_reg8     = fmom37_rf_reg7 NOT INTERACT MOMDMY33

fmom37_rf_reg_nw1   = fmom37_rf_reg5 INTERACT MOMDMY31
fmom37_rf_reg_nw2   = fmom37_rf_reg_nw1 INTERACT nxwell              
fmom37_rf_reg_nwa        = fmom37_rf_reg_nw2 NOT INTERACT MOM_dmetal1_2
fmom37_rf_reg_nw         = fmom37_rf_reg_nwa NOT INTERACT RFDMY_mmW            // FMOM 3T RF wi NW shield wo DM
fmom37_rf_reg_nw_110g    = fmom37_rf_reg_nwa INTERACT RFDMY_mmW                // mmW FMOM 3T RF wi NW shield wo DM
fmom37_rf_reg_nw_dma     = fmom37_rf_reg_nw2 INTERACT MOM_dmetal1_2
fmom37_rf_reg_nw_dm      = fmom37_rf_reg_nw_dma NOT INTERACT RFDMY_mmW        // FMOM 3T RF wi NW shield wi DM
fmom37_rf_reg_nw_dm_110g = fmom37_rf_reg_nw_dma INTERACT RFDMY_mmW            // mmW FMOM 3T RF wi NW shield wi DM

fmom37_rf_reg_pw1   = fmom37_rf_reg6 INTERACT MOMDMY32
fmom37_rf_reg_pw2   = fmom37_rf_reg_pw1 INTERACT psub                
fmom37_rf_reg_pwa        = fmom37_rf_reg_pw2 NOT INTERACT MOM_dmetal1_2
fmom37_rf_reg_pw         = fmom37_rf_reg_pwa NOT INTERACT RFDMY_mmW               // FMOM 3T RF wi PW shield wo DM
fmom37_rf_reg_pw_110g    = fmom37_rf_reg_pwa INTERACT RFDMY_mmW                   // mmW FMOM 3T RF wi PW shield wo DM
fmom37_rf_reg_pw_dma     = fmom37_rf_reg_pw2 INTERACT MOM_dmetal1_2
