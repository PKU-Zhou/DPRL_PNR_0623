   G2ODY_2 = DFM_VEC_VAL( ngate_PROP, "LPEPAR_2" )
   sodxa = TVF_NUM_FUN ( "compute_sodxab","parameter_equation", G2ODX_1, W, L, UNIT_LENGTH(), SCALE )
