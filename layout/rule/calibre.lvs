all_mos_gates = (((((((((((pehvgate_mac OR (nehvgate_mac OR (pgate_pu_ulldpsr_mac OR (pgate_pu_ellsr_mac OR (pgate_pu_ullsr_mac OR (ngate_ullrpsr_mac OR (ngate_pd_ulldpsr_mac OR (ngate_pg_ulldpsr_mac OR (ngate_pd_ellsr_mac OR (ngate_pg_ellsr_mac OR (ngate_pd_ullsr_mac OR (ngate_pg_ullsr_mac OR (pgate_sdp_mac OR (pgate_s_mac OR (ngate_rpsr_mac OR (ngate_sdppd_mac OR (ngate_sdppg_mac OR (ngate_spd_mac OR (ngate_spg_mac OR (pgate_sdp OR (pgate_pu_ulldpsr OR (pgate_pu_ellsr OR (pgate_pu_ullsr OR (ngate_pd_ulldpsr OR (ngate_pg_ulldpsr OR (ngate_ullrpsr OR (ngate_pd_ellsr OR (ngate_pg_ellsr OR (ngate_pd_ullsr OR (ngate_pg_ullsr OR (ngate_sdppd OR (ngate_sdppg OR (dngate_lnvt25_mac OR (dngate_25_mac OR (dngate_25od33_mac OR (dngate_25ud18_mac OR (nrgate_hia25_mac OR (pgate_lnvt25_mac OR (pgate_25_mac OR (pgate_25odll_mac OR (pgate_25od_mac OR (pgate_25ud_mac OR (ngate_25na_mac OR (ngate_lnvt25_mac OR (ngate_25_mac OR (ngate_25od_mac OR (ngate_25ud_mac OR (ngate_hia25_mac OR (ngate_hv18_ud3d3_mac OR (pgate_hv25_ud5d5_mac OR (pgate_hv25_mac OR (ngate_hv25_ud5d5_mac OR (ngate_hv25_mac OR (pgate_hv18_ud5d5_mac OR (ngate_hv18_ud5d5_mac OR (pgate_hv18_mac OR (ngate_hv18_mac OR (dnavt2gate_mac OR (navt2gate_mac OR (dnavtgate_mac OR (navtgate_mac OR (pgate_18ud15_mac OR (pgate_18ud12_mac OR (pgate_18_mac OR (pavtgate_mac OR (pavt2gate_mac OR (psuhvgate_mac OR (puhvgate_mac OR (phvgate_mac OR (puvgate_mac OR (plvgate_mac OR (ngate_rpsr OR (pgate_s OR (ngate_spd OR (ngate_spg OR (nlgate_mac OR (dngate_18ud15_mac OR (dngate_18ud12_mac OR (dngate_18_mac OR (nrgate_hia18_mac OR (ngate_18na_mac OR (ngate_18ud15_mac OR (ngate_18ud12_mac OR (ngate_18_mac OR (ngate_hia18_mac OR (nsuhvgate_mac OR (dnsuhvgate_mac OR (nuhvgate_mac OR (dnehvgate_mac OR (dnuhvgate_mac OR (n1uvgate_mac OR (n1hvgate_mac OR (nrgate_hia_mac OR (n1lvgate_mac OR (nrgate_mac OR (nuvgate_mac OR (nhvgate_mac OR (ngate_hia_mac OR (nlvgate_mac OR (ngate_mac OR pgate_mac)))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))) OR ngate_hv18_ud3d3_mac) OR vargt) OR vargt_18) OR vargt_25) OR vargt_ll) OR npolymgcap25_wodnw) OR npolymgcap25_widnw) OR vargt_p) OR vargt_18_p) OR vargt_25_p) OR vargt_ll_p
