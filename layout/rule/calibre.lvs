   SCALE = PRESCALE
   W=(perimeter_coincide(ngate_hv18_mac, s_tndiff_hv ) + perimeter_coincide(ngate_hv18_mac, d_tndiff_hv)) / 2
   L=area(ngate_hv18_mac) / W
