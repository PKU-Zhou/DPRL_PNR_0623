//* Define device -- nmos nch_hia18_mac

//* Define layer -- ngate_18d
ngate_18d_tmp01 = ngate_18a NOT NT_N
ngate_18d_tmp02 = ngate_18d_tmp01 NOT VTL_N_18
ngate_18d_tmp03 = ngate_18d_tmp02 NOT VTL_N
ngate_18d_tmp04 = ngate_18d_tmp03 NOT VTSUH_N
ngate_18d = ngate_18d_tmp04 NOT VTSUH_P

ngate_18e = ngate_18d NOT OD18_15 
ngate_18f = ngate_18e NOT OD18_12 
ngate_hia18_org1 = ngate_18f AND SR_ESD 
ngate_hia18_org = ngate_hia18_org1 INTERACT SDI 
ngate_hia18_mac_org = ngate_hia18_org NOT LVSDMY 
ngate_hia18_mac = ngate_hia18_mac_org NOT dnwdmy  //  1.8v ESD NMOS MAC

//* Define device -- nmos nch_18_mac
ngate_18_org1 = ngate_18f NOT SR_ESD 
ngate_18_org2 = ngate_18_org1 NOT INTERACT HVD_N 
ngate_18_org = ngate_18_org2 NOT INTERACT HVN_65 
ngate_18_mac_org = ngate_18_org NOT LVSDMY 
ngate_18_mac = ngate_18_mac_org NOT dnwdmy  //  1.8v NMOS MAC

//* Define device -- nmos nch_18ud12_mac
