fmom48_mx_reg_pw_dm = fmom48_mx_reg_pw2 INTERACT MOM_dmetal1_3      // FMOM MX 5T wi PW shield wi DM



fmom48_mx_reg_ntn1   = fmom48_mx_reg6 INTERACT MOMDMY33
fmom48_mx_reg_ntn2   = fmom48_mx_reg_ntn1 INTERACT NT_N
