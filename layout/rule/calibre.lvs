dnehvgate_mac = nehvgate_mac_org AND dnwdmy  //  Extra High-Vt NMOS DNW MAC

//* Define device -- nmos nch_uhvt_mac
nuhvgate_mac = nuhvgate_mac_org NOT dnwdmy  //  ULTRA HVT NMOS MAC

